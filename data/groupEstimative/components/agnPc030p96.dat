/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-030p96  (C14H24O8, CAS 72829-16-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc030p96;
formula     C14H24O8;
CAS         72829-16-4;
InChIKey    SGYWYFVTGBVUJD-UHFFFAOYSA-N;
MW          320.338;      // g/mol [origin=calculated method=formula-sum]
Tc          1240.23;      // K   [origin=predictive method=joback]
Pc          22.806;      // bar [origin=predictive method=joback]
omega       1.5633;      // -   [origin=predictive method=lee-kesler]
Tb          1002.78;      // K   [origin=predictive method=joback]
HvapTb      125654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.984 1.63184 -0.0010976 2.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 2; } { group CH=CH; count 1; } { group OH; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 2; } { group dCH; count 2; } { group OH; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-(hydroxymethyl)-2-methyl-3-oxidanyl-propyl] but-2-enedioate" "2-butenedioic acid (2z)-, bis[3-hydroxy-2-(hydroxymethyl)-2-methylpropyl] ester" "bis[3-hydroxy-2-(hydroxymethyl)-2-methylpropyl] (z)-but-2-enedioate" );
gibbsFormation
{
    dHf_298   -1476050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     923.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1015120.0
    phase     gas;
}
