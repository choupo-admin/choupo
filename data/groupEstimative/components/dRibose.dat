/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-ribose  (C5H10O5, CAS 609-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dRibose;
formula     C5H10O5;
CAS         609-06-3;
InChIKey    PYMYPHUHKUWMLA-UHFFFAOYSA-N;
MW          150.13;      // g/mol [origin=calculated method=formula-sum]
Tc          900.87;      // K   [origin=predictive method=joback]
Pc          65.884;      // bar [origin=predictive method=joback]
omega       2.5191;      // -   [origin=predictive method=lee-kesler]
Tb          730.06;      // K   [origin=predictive method=joback]
HvapTb      98996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.861 0.607 -0.0003724 8.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 3; } { group OH; count 4; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 3; } { group OH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5-tetrakis(oxidanyl)pentanal" "pentose" "l-arabinose" "dl-arabinose" "lyxose, d-" "l-xylose" "dl-xylose" "l-(+)-arabinose" "d-ribofuranose" "arabinose, l-" "l-(-)-xylose" "ribose, d-" );
gibbsFormation
{
    dHf_298   -856870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-662900.0
    phase     gas;
}
