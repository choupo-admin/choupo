/*--------------------------------*- Choupo -*-----------------------*\
  Component: tropicamide  (C17H20N2O2, CAS 1508-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tropicamide;
formula     C17H20N2O2;
CAS         1508-75-4;
InChIKey    BGDKAVGWHJFAGW-UHFFFAOYSA-N;
MW          284.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1076.97;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       1.3510;      // -   [origin=predictive method=lee-kesler]
Tb          853.67;      // K   [origin=predictive method=joback]
HvapTb      89278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.037 1.63058 -0.00110016 2.8156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group C5H4N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-3-oxidanyl-2-phenyl-n-(pyridin-4-ylmethyl)propanamide" "mydriaticum" "tropicacyl" "minims tropicamide" "mydriafair" "mydriacyl" "mydrum" "paremyd" "ocu-tropic" "bistropamide" "tropicamida" "tropicamidum" );
standardThermochemistry
{
    dHf_298   -90920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     702.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236730.0
}
