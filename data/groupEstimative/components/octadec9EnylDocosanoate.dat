/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadec-9-enyl docosanoate  (C40H78O2, CAS 66161-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadec9EnylDocosanoate;
formula     C40H78O2;
CAS         66161-52-2;
InChIKey    AOXNDJKHXBKZBT-UHFFFAOYSA-N;
MW          591.062;      // g/mol [origin=calculated method=formula-sum]
Tc          1595.55;      // K   [origin=predictive method=joback]
Pc          3.998;      // bar [origin=predictive method=joback]
omega       -0.2951;      // -   [origin=predictive method=lee-kesler]
Tb          1177.18;      // K   [origin=predictive method=joback]
HvapTb      111999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.245 3.76904 -0.0021414 4.551e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 34; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 35; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "docosanoic acid, (9z)-9-octadecenyl ester" "docosanoic acid, (9z)-9-octadecen-1-yl ester" );
gibbsFormation
{
    dHf_298   -1068990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1758.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55770.0
    phase     gas;
}
