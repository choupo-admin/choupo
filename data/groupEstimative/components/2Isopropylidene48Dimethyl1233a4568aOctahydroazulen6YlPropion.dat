/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropylidene-4,8-dimethyl-1,2,3,3a,4,5,6,8a-octahydroazulen-6-yl propionate  (C18H28O2, CAS 10486-26-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropylidene48Dimethyl1233a4568aOctahydroazulen6YlPropion;
formula     C18H28O2;
CAS         10486-26-7;
InChIKey    ZXXZNGHSKXHZPG-UHFFFAOYSA-N;
MW          276.42;      // g/mol [origin=calculated method=formula-sum]
Tc          911.79;      // K   [origin=predictive method=joback]
Pc          14.884;      // bar [origin=predictive method=joback]
omega       0.7019;      // -   [origin=predictive method=lee-kesler]
Tb          701.54;      // K   [origin=predictive method=joback]
HvapTb      64786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.669 1.6764 -0.00089584 1.505e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 4; } { group CH=C; count 1; } { group CH2COO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4,8-dimethyl-2-propan-2-ylidene-3,3a,4,5,6,8a-hexahydro-1h-azulen-6-yl) propanoate" "6-azulenol, 1,2,3,3a,4,5,6,8a-octahydro-4,8-dimethyl-2-(1-methylethylidene)-, propanoate" "6-azulenol, 1,2,3,3a,4,5,6,8a-octahydro-4,8-dimethyl-2-(1-methylethylidene)-, 6-propanoate" "1,2,3,3a,4,5,6,8a-octahydro-2-isopropylidene-4,8-dimethylazulen-6-yl propionate" "4,8-dimethyl-2-(propan-2-ylidene)-1,2,3,3a,4,5,6,8a-octahydroazulen-6-yl propanoate" );
gibbsFormation
{
    dHf_298   -539300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94770.0
    phase     gas;
}
