/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dichlorobenzyl ether  (C14H10Cl4O, CAS 73927-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DichlorobenzylEther;
formula     C14H10Cl4O;
CAS         73927-56-7;
InChIKey    ITFCEERPJPLHPQ-UHFFFAOYSA-N;
MW          336.033;      // g/mol [origin=calculated method=formula-sum]
Tc          1015.23;      // K   [origin=predictive method=joback]
Pc          22.145;      // bar [origin=predictive method=joback]
omega       0.7896;      // -   [origin=predictive method=lee-kesler]
Tb          765.34;      // K   [origin=predictive method=joback]
HvapTb      73908.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.612 0.902 -0.00050264 8.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Cl; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2,6-bis(chloranyl)phenyl]methoxymethyl]-1,3-bis(chloranyl)benzene" "bis(2,6-dichlorobenzyl)ether" "ether, bis(2,6-dichlorobenzyl)" "di(2,6-dichloro benzyl)ether" "1,3-dichloro-2-[(2,6-dichlorophenyl)methoxymethyl]benzene" "1,3-dichloro-2-{[(2,6-dichlorophenyl)methoxy]methyl}benzene" );
gibbsFormation
{
    dHf_298   -100290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100580.0
    phase     gas;
}
