/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentene, 2-cyclopropyl-  (C8H14, CAS 5457-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentene2Cyclopropyl;
formula     C8H14;
CAS         5457-40-9;
InChIKey    LTTGGSUQUFBJQH-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          571.02;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       0.3161;      // -   [origin=predictive method=lee-kesler]
Tb          385.94;      // K   [origin=predictive method=joback]
HvapTb      32725.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.308 0.89462 -0.0006568 2.025e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-en-2-ylcyclopropane" );
gibbsFormation
{
    dHf_298   -20010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156520.0
    phase     gas;
}
