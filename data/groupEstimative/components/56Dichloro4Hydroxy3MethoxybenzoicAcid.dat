/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6-dichloro-4-hydroxy-3-methoxybenzoic acid  (C8H6Cl2O4, CAS 108544-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56Dichloro4Hydroxy3MethoxybenzoicAcid;
formula     C8H6Cl2O4;
CAS         108544-97-4;
InChIKey    PIUZBDHQOOFIPU-UHFFFAOYSA-N;
MW          237.032;      // g/mol [origin=calculated method=formula-sum]
Tc          989.77;      // K   [origin=predictive method=joback]
Pc          41.463;      // bar [origin=predictive method=joback]
omega       1.1848;      // -   [origin=predictive method=lee-kesler]
Tb          747.67;      // K   [origin=predictive method=joback]
HvapTb      79022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.57 0.66222 -0.00050024 1.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 2; } { group OH_phenol; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)-5-methoxy-4-oxidanyl-benzoic acid" "benzoic acid,2,3-dichloro-4-hydroxy-5-methoxy-" "agn-pc-04q021" "ambap108544-97-4" "benzoic acid, 2,3-dichloro-4-hydroxy-5-methoxy-" "5,6-dichloro-4-hydroxy-3-methoxybenzoic acid;5,6-dichlorovanillic acid;2,3-dichloro-4-hydroxy-5-methoxybenzoicacid" );
standardThermochemistry
{
    dHf_298   -697610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-527390.0
}
