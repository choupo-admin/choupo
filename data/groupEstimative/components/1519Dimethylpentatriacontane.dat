/*--------------------------------*- Choupo -*-----------------------*\
  Component: 15,19-dimethylpentatriacontane  (C37H76, CAS 56987-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1519Dimethylpentatriacontane;
formula     C37H76;
CAS         56987-86-1;
InChIKey    XDMQCULQPXRKOB-UHFFFAOYSA-N;
MW          521.015;      // g/mol [origin=calculated method=formula-sum]
Tc          1340.60;      // K   [origin=predictive method=joback]
Pc          4.425;      // bar [origin=predictive method=joback]
omega       -0.0416;      // -   [origin=predictive method=lee-kesler]
Tb          1045.28;      // K   [origin=predictive method=joback]
HvapTb      97180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.109 3.53068 -0.0019954 4.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 31; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 31; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentatriacontane, 15,19-dimethyl-" );
standardThermochemistry
{
    dHf_298   -817570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1578.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255780.0
}
