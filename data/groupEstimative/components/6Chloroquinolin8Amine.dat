/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-chloroquinolin-8-amine  (C9H7ClN2, CAS 5470-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Chloroquinolin8Amine;
formula     C9H7ClN2;
CAS         5470-75-7;
InChIKey    RRFMPCSQKFOUFO-UHFFFAOYSA-N;
MW          178.619;      // g/mol [origin=calculated method=formula-sum]
Tc          891.90;      // K   [origin=predictive method=joback]
Pc          43.569;      // bar [origin=predictive method=joback]
omega       0.6379;      // -   [origin=predictive method=lee-kesler]
Tb          624.80;      // K   [origin=predictive method=joback]
HvapTb      62104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.6 0.75966 -0.0005727 1.745e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACNH2; count 1; } { group C5H3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 4; } { group Cl; count 1; } { group NH2; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-chloranylquinolin-8-amine" "6-chloro-8-aminoquinoline" "8-quinolinamine, 6-chloro-" "8-amino-6-chloroquinoline" "6-chloro-8-quinolinamine" "6-chloro-8-quinolylamine" );
gibbsFormation
{
    dHf_298   226410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356270.0
    phase     gas;
}
