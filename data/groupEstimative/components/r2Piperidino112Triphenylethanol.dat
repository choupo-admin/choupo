/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(-)-2-piperidino-1,1,2-triphenylethanol  (C25H27NO, CAS 213995-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2Piperidino112Triphenylethanol;
formula     C25H27NO;
CAS         213995-12-1;
InChIKey    BCFJVZGZDXPFBN-XMMPIXPASA-N;
MW          357.497;      // g/mol [origin=calculated method=formula-sum]
Tc          1225.56;      // K   [origin=predictive method=joback]
Pc          18.986;      // bar [origin=predictive method=joback]
omega       1.1721;      // -   [origin=predictive method=lee-kesler]
Tb          972.54;      // K   [origin=predictive method=joback]
HvapTb      95676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-219.53 2.5899 -0.0019306 5.491e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 15; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-1,1,2-triphenyl-2-piperidin-1-yl-ethanol" "(r)-2-piperidinyl-1,1,2-triphenylethanol" "(2r)-1,1,2-triphenyl-2-piperidylethan-1-ol" "(2r)-1,1,2-triphenyl-2-piperidin-1-ylethanol" "(r)-1,1,2-triphenyl-2-(piperidin-1-yl)ethanol" "(r)-(-)-" "a," "a," "a-triphenyl-1-piperidineethanol" "(r)-(-)-alpha,alpha,beta-triphenyl-1-piperidineethanol" );
standardThermochemistry
{
    dHf_298   132350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     821.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=515470.0
}
