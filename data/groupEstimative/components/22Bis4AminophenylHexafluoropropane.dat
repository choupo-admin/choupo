/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(4-aminophenyl)hexafluoropropane  (C15H12F6N2, CAS 1095-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis4AminophenylHexafluoropropane;
formula     C15H12F6N2;
CAS         1095-78-9;
InChIKey    BEKFRNOZJSYWKZ-UHFFFAOYSA-N;
MW          334.263;      // g/mol [origin=calculated method=formula-sum]
Tc          961.72;      // K   [origin=predictive method=joback]
Pc          22.145;      // bar [origin=predictive method=joback]
omega       0.9290;      // -   [origin=predictive method=lee-kesler]
Tb          737.11;      // K   [origin=predictive method=joback]
HvapTb      67352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.85 1.724 -0.00142112 4.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACNH2; count 2; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 6; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-aminophenyl)-1,1,1,3,3,3-hexakis(fluoranyl)propan-2-yl]aniline" "4,4'-(hexafluoroisopropylidene)dianiline" "4-[2-(4-aminophenyl)-1,1,1,3,3,3-hexafluoropropan-2-yl]aniline" "4-[1-(4-aminophenyl)-2,2,2-trifluoro-1-(trifluoromethyl)ethyl]phenylamine" "bekfrnozjsywkz-uhfffaoysa-" "l582" "4,4'-(perfluoropropane-2,2-diyl)dianiline" "4,4'-(1,1,1,3,3,3-hexafluoropropane-2,2-diyl)dianiline" "benzenamine,4,4'-[2,2,2-trifluoro-1-(trifluoromethyl)ethylidene]bis-" "aniline,4,4'-[2,2,2-trifluoro-1-(trifluoromethyl)ethylidene]di- (7ci);aniline,4,4'-[trifluoro-1-(trifluoromethyl)ethylidene]di- (8ci);2,2-bis(4-aminophenyl)hexafluoropropane;4,4'-(hexafluoroisopropylidene)dianiline;bis-a-af;hexafluoroisopropylidiene-4,4'-dianiline;" );
standardThermochemistry
{
    dHf_298   -1038140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-746460.0
}
