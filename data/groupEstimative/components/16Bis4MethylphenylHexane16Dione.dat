/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-bis(4-methylphenyl)hexane-1,6-dione  (C20H22O2, CAS 6280-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Bis4MethylphenylHexane16Dione;
formula     C20H22O2;
CAS         6280-00-8;
InChIKey    ONAXVWKDWBEZCL-UHFFFAOYSA-N;
MW          294.394;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.86;      // K   [origin=predictive method=joback]
Pc          17.654;      // bar [origin=predictive method=joback]
omega       0.9937;      // -   [origin=predictive method=lee-kesler]
Tb          828.26;      // K   [origin=predictive method=joback]
HvapTb      79482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.786 1.57104 -0.00095512 2.0992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-di-(p-methyl benzoyl)-butane" );
gibbsFormation
{
    dHf_298   -231170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65240.0
    phase     gas;
}
