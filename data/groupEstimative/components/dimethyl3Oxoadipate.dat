/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 3-oxoadipate  (C8H12O5, CAS 5457-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl3Oxoadipate;
formula     C8H12O5;
CAS         5457-44-3;
InChIKey    CMGTZMRSJJKAPM-UHFFFAOYSA-N;
MW          188.179;      // g/mol [origin=calculated method=formula-sum]
Tc          739.80;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.8453;      // -   [origin=predictive method=lee-kesler]
Tb          552.95;      // K   [origin=predictive method=joback]
HvapTb      54962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.793 0.62624 -0.0002035 -3.924e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2CO; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 3-oxidanylidenehexanedioate" "dimethyl 3-oxohexanedioate" "hexanedioic acid, 3-oxo-, dimethyl ester" "dimethyl " "a-ketoadipate" "dimethyl beta-ketoadipate" "3-oxo-hexanedioic acid dimethyl ester" "hexanedioic acid,3-oxo-, 1,6-dimethyl ester" );
gibbsFormation
{
    dHf_298   -955590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-733180.0
    phase     gas;
}
