/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (3-methyl-1-butenyl)-  (C11H14, CAS 15325-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene3Methyl1Butenyl;
formula     C11H14;
CAS         15325-61-8;
InChIKey    CEBRPXLXYCFYGU-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          698.59;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.3718;      // -   [origin=predictive method=lee-kesler]
Tb          481.68;      // K   [origin=predictive method=joback]
HvapTb      41926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.88 0.99584 -0.0006928 1.921e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-1-enylbenzene" "agn-pc-03a1ml" "benzene, [(1e)-3-methyl-1-butenyl]-" );
gibbsFormation
{
    dHf_298   78100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=231930.0
    phase     gas;
}
