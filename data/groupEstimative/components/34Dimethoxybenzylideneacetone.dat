/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethoxybenzylideneacetone  (C12H14O3, CAS 15001-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethoxybenzylideneacetone;
formula     C12H14O3;
CAS         15001-27-1;
InChIKey    XUYBNDHXZMIALN-UHFFFAOYSA-N;
MW          206.241;      // g/mol [origin=calculated method=formula-sum]
Tc          828.15;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.7366;      // -   [origin=predictive method=lee-kesler]
Tb          613.67;      // K   [origin=predictive method=joback]
HvapTb      57430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.85 0.81156 -0.00036922 3.606e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3CO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3,4-dimethoxyphenyl)but-3-en-2-one" "(e)-4-(3,4-dimethoxyphenyl)but-3-en-2-one" "4-(3,4-dimethoxyphenyl)-3-buten-2-one" "3-buten-2-one, 4-(3,4-dimethoxyphenyl)-, (3e)-" );
gibbsFormation
{
    dHf_298   -337220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-115390.0
    phase     gas;
}
