/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromoacetonitrile  (C2H2BrN, CAS 590-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromoacetonitrile;
formula     C2H2BrN;
CAS         590-17-0;
InChIKey    REXUYBKPWIPONM-UHFFFAOYSA-N;
MW          119.949;      // g/mol [origin=calculated method=formula-sum]
Tc          630.25;      // K   [origin=predictive method=joback]
Pc          53.592;      // bar [origin=predictive method=joback]
omega       0.3947;      // -   [origin=predictive method=lee-kesler]
Tb          413.60;      // K   [origin=predictive method=joback]
HvapTb      36959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.261 0.1668 -0.0001254 4.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Br; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylethanenitrile" "2-bromoacetonitrile" "acetonitrile, bromo-" "bromomethyl cyanide" "cyanomethyl bromide" "2-bromoethanenitrile" "2-bromoacetonitrile;bromomethyl cyanide;cyanomethyl bromide;" );
standardThermochemistry
{
    dHf_298   106600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     291.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113460.0
}
