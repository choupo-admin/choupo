/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dibromobutan-2-one  (C4H6Br2O, CAS 2648-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dibromobutan2One;
formula     C4H6Br2O;
CAS         2648-69-3;
InChIKey    DNVZPZWJCRLJFI-UHFFFAOYSA-N;
MW          229.899;      // g/mol [origin=calculated method=formula-sum]
Tc          707.46;      // K   [origin=predictive method=joback]
Pc          52.358;      // bar [origin=predictive method=joback]
omega       0.4790;      // -   [origin=predictive method=lee-kesler]
Tb          474.08;      // K   [origin=predictive method=joback]
HvapTb      42818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.48 0.55804 -0.0004897 1.6746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group CH3CO; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group Br; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(bromanyl)butan-2-one" "2-butanone, 3,3-dibromo-" );
gibbsFormation
{
    dHf_298   -194560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114640.0
    phase     gas;
}
