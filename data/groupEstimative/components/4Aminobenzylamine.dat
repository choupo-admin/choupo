/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-aminobenzylamine  (C7H10N2, CAS 4403-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Aminobenzylamine;
formula     C7H10N2;
CAS         4403-71-8;
InChIKey    BFWYZZPDZZGSLJ-UHFFFAOYSA-N;
MW          122.171;      // g/mol [origin=calculated method=formula-sum]
Tc          775.51;      // K   [origin=predictive method=joback]
Pc          46.913;      // bar [origin=predictive method=joback]
omega       0.5979;      // -   [origin=predictive method=lee-kesler]
Tb          536.48;      // K   [origin=predictive method=joback]
HvapTb      55396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.099 0.6542 -0.00040796 9.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2NH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(aminomethyl)aniline" "4-aminobenzylamine 2hcl" "4-(aminomethyl)phenylamine" "alpha-amino-p-toluidine" "4-aminomethyl-phenylamine" "(4-aminophenyl)methylamine" "p-aminobenzylamine;benzenemethanamine, 4-amino-" "4-amino-benzenemethanamine hydrochloride (1:2);benzenemethanamine,4-amino-, dihydrochloride (9ci);p-aminobenzylaminedihydrochloride" "4zy" );
gibbsFormation
{
    dHf_298   104830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243740.0
    phase     gas;
}
