/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipropylamine  (C6H15N, CAS 142-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipropylamine;
formula     C6H15N;
CAS         142-84-7;
InChIKey    WEHWNAOGRSTTBQ-UHFFFAOYSA-N;
MW          101.193;      // g/mol [origin=calculated method=formula-sum]
Tc          557.01;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.4552;      // -   [origin=predictive method=lee-kesler]
Tb          387.05;      // K   [origin=predictive method=joback]
HvapTb      35386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.776 0.65004 -0.0003512 7.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-propylpropan-1-amine" "di-n-propylamine" "1-propanamine, n-propyl-" "n-dipropylamine" "n-propyl-1-propanamine" "dipropyl amine" "dipropyl-amine" "dipropylamine(8ci);di-n-propylamine;dipropanamine;n,n-dipropylamine;n-propyl-1-propanamine;n-dipropylamine;" );
standardThermochemistry
{
    dHf_298   -113700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89030.0
}
