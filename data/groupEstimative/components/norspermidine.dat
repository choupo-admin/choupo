/*--------------------------------*- Choupo -*-----------------------*\
  Component: norspermidine  (C6H17N3, CAS 56-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norspermidine;
formula     C6H17N3;
CAS         56-18-8;
InChIKey    OTBHHUPVCYLGQO-UHFFFAOYSA-N;
MW          131.223;      // g/mol [origin=calculated method=formula-sum]
Tc          726.80;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.8376;      // -   [origin=predictive method=lee-kesler]
Tb          532.11;      // K   [origin=predictive method=joback]
HvapTb      56668.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.206 0.7738 -0.000438 9.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2NH2; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group NH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(3-azanylpropyl)propane-1,3-diamine" "bis(3-aminopropyl)amine" "dipropylenetriamine" "3,3'-iminobispropylamine" "3,3'-iminobis(propylamine)" "caldine" "3,3'-diaminodipropylamine" "aminobis(propylamine)" "iminobis(propylamine)" "1,7-diamino-4-azaheptane" "4-azaheptane-1,7-diamine" "3,3-diaminodipropylamine" );
standardThermochemistry
{
    dHf_298   -46120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221930.0
}
