/*--------------------------------*- Choupo -*-----------------------*\
  Component: monoethyl phthalate  (C10H10O4, CAS 2306-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monoethylPhthalate;
formula     C10H10O4;
CAS         2306-33-4;
InChIKey    YWWHKOHZGJFMIE-UHFFFAOYSA-N;
MW          194.186;      // g/mol [origin=calculated method=formula-sum]
Tc          886.55;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.9506;      // -   [origin=predictive method=lee-kesler]
Tb          663.79;      // K   [origin=predictive method=joback]
HvapTb      65363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.201 0.81142 -0.00046236 7.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxycarbonylbenzoic acid" "phthalic acid, monoethyl ester" "2-(ethoxycarbonyl)benzoic acid" "1,2-benzenecarboxylic acid, monoethyl ester" "ethyl 2-carboxybenzoate" "phthalic acid monoethyl ester" "1,2-benzenedicarboxylic acid, monoethyl ester" "metp" "2-(ethoxycarbonyl)benzoate" "1,2-benzenedicarboxylic acid 1-ethyl ester" "1,2-benzenedicarboxylic acid monoethyl ester" );
standardThermochemistry
{
    dHf_298   -692220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-518180.0
}
