/*--------------------------------*- Choupo -*-----------------------*\
  Component: cumene, 2,4,5-trimethyl-  (C12H18, CAS 10222-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cumene245Trimethyl;
formula     C12H18;
CAS         10222-95-4;
InChIKey    POOXAYBPGIHSME-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          722.65;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.4532;      // -   [origin=predictive method=lee-kesler]
Tb          515.34;      // K   [origin=predictive method=joback]
HvapTb      46180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.71 0.8924 -0.00046228 8.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group ACCH3; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-trimethyl-5-propan-2-yl-benzene" "benzene, 1,2,4-trimethyl-5-(1-methylethyl)-" "5-isopropyl-1,2,4-trimethylbenzene" "1,2,4-trimethyl-5-propan-2-ylbenzene" "1,2,4-trimethyl-5-(propan-2-yl)benzene" "benzene,1,2,4-trimethyl-5-(1-methylethyl)-" "cumene,2,4,5-trimethyl- (6ci,7ci,8ci); 1,2,4-trimethyl-5-(1-methylethyl)benzene;1,2,4-trimethyl-5-isopropylbenzene; 1-isopropyl-2,4,5-trimethylbenzene;2,4,5-trimethylcumene; 5-isopropyl-1,2,4-trimethylbenzene;5-isopropylpseudocumene" );
gibbsFormation
{
    dHf_298   -94170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131240.0
    phase     gas;
}
