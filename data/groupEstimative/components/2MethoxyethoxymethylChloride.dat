/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyethoxymethyl chloride  (C4H9ClO2, CAS 3970-21-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyethoxymethylChloride;
formula     C4H9ClO2;
CAS         3970-21-6;
InChIKey    BIAAQBNMRITRDV-UHFFFAOYSA-N;
MW          124.564;      // g/mol [origin=calculated method=formula-sum]
Tc          547.75;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.4138;      // -   [origin=predictive method=lee-kesler]
Tb          373.39;      // K   [origin=predictive method=joback]
HvapTb      33703.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.143 0.26422 7.8e-06 -6.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyloxy)-2-methoxy-ethane" "mem chloride" "mem-chloride" "1-(chloromethoxy)-2-methoxyethane" "beta-methoxyethoxymethyl chloride" ".beta.-methoxyethoxymethyl chloride" "ethane, 1-(chloromethoxy)-2-methoxy-" "2-methoxyethoxy methyl chloride" "methoxyethoxymethyl chloride" "1-chloro-2,5-dioxahexane" "2-methoxyethoxy chloromethane" "1-chloromethoxy-2-methoxyethane" );
gibbsFormation
{
    dHf_298   -406070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239130.0
    phase     gas;
}
