/*--------------------------------*- Choupo -*-----------------------*\
  Component: amyl acetoacetate  (C9H16O3, CAS 6624-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amylAcetoacetate;
formula     C9H16O3;
CAS         6624-84-6;
InChIKey    IDZAUPYMMSSVHP-UHFFFAOYSA-N;
MW          172.224;      // g/mol [origin=calculated method=formula-sum]
Tc          697.69;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.7308;      // -   [origin=predictive method=lee-kesler]
Tb          517.61;      // K   [origin=predictive method=joback]
HvapTb      49781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.475 0.77604 -0.0003525 2.976e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentyl 3-oxidanylidenebutanoate" "pentyl acetoacetate" "pentyl 3-oxobutanoate" "acetoacetic acid amyl ester" "acetoacetic acid n-amyl ester" "acetoacetic acid pentyl ester" "acetoacetic acid, n-amyl ester" "idzaupymmssvhp-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -658950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-414390.0
    phase     gas;
}
