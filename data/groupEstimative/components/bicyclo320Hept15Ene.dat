/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(3.2.0)hept-1(5)-ene  (C7H10, CAS 10563-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo320Hept15Ene;
formula     C7H10;
CAS         10563-10-7;
InChIKey    VQQXDBPNEPNNNS-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          605.76;      // K   [origin=predictive method=joback]
Pc          42.552;      // bar [origin=predictive method=joback]
omega       0.3012;      // -   [origin=predictive method=lee-kesler]
Tb          395.97;      // K   [origin=predictive method=joback]
HvapTb      33408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.58 0.839 -0.000715 2.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[3.2.0]hept-1(5)-ene" "bicyclo[3.2.0]hept-5(1)-ene" );
gibbsFormation
{
    dHf_298   27150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143580.0
    phase     gas;
}
