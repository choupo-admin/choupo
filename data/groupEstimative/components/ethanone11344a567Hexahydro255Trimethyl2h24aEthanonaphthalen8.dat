/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanone, 1-(1,3,4,4a,5,6,7-hexahydro-2,5,5-trimethyl-2h-2,4a-ethanonaphthalen-8-yl)-  (C17H26O, CAS 32388-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanone11344a567Hexahydro255Trimethyl2h24aEthanonaphthalen8;
formula     C17H26O;
CAS         32388-56-0;
InChIKey    QDPCSMUJYFCULY-UHFFFAOYSA-N;
MW          246.394;      // g/mol [origin=calculated method=formula-sum]
Tc          925.92;      // K   [origin=predictive method=joback]
Pc          21.023;      // bar [origin=predictive method=joback]
omega       0.6261;      // -   [origin=predictive method=lee-kesler]
Tb          685.30;      // K   [origin=predictive method=joback]
HvapTb      58600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-284.89 2.71548 -0.0028547 1.23866e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group C; count 3; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group C_ring; count 3; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-aceto-7,10-ethano-4,4,7-trimethyl-1(9)-octalin" "ethanone, 1-(1,3,4,5,6,7-hexahydro-2,5,5-trimethyl-2h-2,4a-ethanonaphthalen-8-yl)-" "5-acetyl-2,2,8-trimethyltricyclo(6.2.2.01,6)dodec-5-ene" "1,3,4,5,6,7-hexahydro-2,5,5-trimethyl-8-acetyl-2h-2,4a-ethanonaphthalene" "1-(1,3,4,4a,5,6,7-hexahydro-2,5,5-trimethyl-2h-2,4a-ethanonaphthalen-8-yl)ethan-1-one" "4-aceto-6,8a-ethano-1,1,6-trimethyl-1,2,3,5,6,7,8,8a-octahydronaphthalene" );
standardThermochemistry
{
    dHf_298   -226310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     792.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103520.0
}
