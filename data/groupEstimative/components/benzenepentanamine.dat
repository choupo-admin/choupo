/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenepentanamine  (C11H17N, CAS 17734-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenepentanamine;
formula     C11H17N;
CAS         17734-21-3;
InChIKey    CGNLNKFBSBFJHY-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          762.77;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.6144;      // -   [origin=predictive method=lee-kesler]
Tb          550.49;      // K   [origin=predictive method=joback]
HvapTb      52997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.525 1.0318 -0.0006492 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-phenylpentan-1-amine" "5-phenyl-1-pentanamine" "5-phenylpentylamine" "5-phenylpentylammonium bromide" "benzenepentanamine, hydrochloride" );
gibbsFormation
{
    dHf_298   -50.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=220600.0
    phase     gas;
}
