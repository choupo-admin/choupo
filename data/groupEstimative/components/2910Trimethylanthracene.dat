/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,9,10-trimethylanthracene  (C17H16, CAS 63018-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2910Trimethylanthracene;
formula     C17H16;
CAS         63018-94-0;
InChIKey    NHLZLIIJLTXSCJ-UHFFFAOYSA-N;
MW          220.315;      // g/mol [origin=calculated method=formula-sum]
Tc          913.46;      // K   [origin=predictive method=joback]
Pc          22.915;      // bar [origin=predictive method=joback]
omega       0.6435;      // -   [origin=predictive method=lee-kesler]
Tb          673.12;      // K   [origin=predictive method=joback]
HvapTb      61640.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.16 1.29456 -0.00093748 2.792e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 4; } { group ACCH3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anthracene, 2,9,10-trimethyl-" "2,10-trimethylanthracene" "anthracene,9,10-trimethyl-" );
standardThermochemistry
{
    dHf_298   178580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=379450.0
}
