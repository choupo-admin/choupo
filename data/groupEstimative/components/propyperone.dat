/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyperone  (C23H33FN2O2, CAS 3781-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propyperone;
formula     C23H33FN2O2;
CAS         3781-28-0;
InChIKey    JMIUUTJADPMZTQ-UHFFFAOYSA-N;
MW          388.527;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.35;      // K   [origin=predictive method=joback]
Pc          14.850;      // bar [origin=predictive method=joback]
omega       1.1165;      // -   [origin=predictive method=lee-kesler]
Tb          924.86;      // K   [origin=predictive method=joback]
HvapTb      86163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-215.096 2.83582 -0.00223856 7.3062e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 2; } { group CH2N; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 9; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)-4-(4-piperidin-1-yl-4-propanoyl-piperidin-1-yl)butan-1-one" "floropipeton" "propyperonum [inn-latin]" "4'-fluoro-4-(4-piperidino-4-propionylpiperidino)butyrophenone" "butyrophenone, 4'-fluoro-4-(4-piperidino-4-propionylpiperidino)-" "propiperona" "propyperonum" "propyperone [inn]" "1-(4-fluorophenyl)-4-(4'-propanoyl-1,4'-bipiperidin-1'-yl)butan-1-one" "1-(4-fluorophenyl)-4-(4-piperidin-1-yl-4-propanoylpiperidin-1-yl)butan-1-one" "1-butanone, 1-(4-fluorophenyl)-4-(4'-(1-oxopropyl)(1,4'-bipiperidin)-1'-yl)-" "1-butanone, 1-(4-fluorophenyl)-4-(4'-(1-oxopropyl)(1,4'-bipiperidin)-1'-yl)- (9ci)" );
gibbsFormation
{
    dHf_298   -422660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1067.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89790.0
    phase     gas;
}
