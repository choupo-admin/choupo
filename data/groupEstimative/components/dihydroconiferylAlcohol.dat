/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydroconiferyl alcohol  (C10H14O3, CAS 2305-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydroconiferylAlcohol;
formula     C10H14O3;
CAS         2305-13-7;
InChIKey    MWOMNLDJNQWJMK-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          857.44;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       1.2356;      // -   [origin=predictive method=lee-kesler]
Tb          655.28;      // K   [origin=predictive method=joback]
HvapTb      72895.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.937 0.94082 -0.00066012 1.965e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-4-(3-oxidanylpropyl)phenol" "3-(4-hydroxy-3-methoxyphenyl)-1-propanol" "1-propanol, 3-(4-hydroxy-3-methoxyphenyl)" "4-(3-hydroxypropyl)-2-methoxyphenol" "1-propanol, 3-(4-hydroxy-3-methoxyphenyl)-" "guaiacylpropanol;" "dihydro-coniferyl alcohol" "ambap2305-13-7" "cpd-94" "4-hydroxy-3-methoxy-benzenepropanol" "benzenepropanol,4-hydroxy-3-methoxy-" "benzenepropanol, 4-hydroxy-3-methoxy-" );
standardThermochemistry
{
    dHf_298   -486430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260340.0
}
