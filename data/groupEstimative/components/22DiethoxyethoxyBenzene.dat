/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-diethoxyethoxy)benzene  (C12H18O3, CAS 32438-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DiethoxyethoxyBenzene;
formula     C12H18O3;
CAS         32438-31-6;
InChIKey    IISGAJPGMKEIAZ-UHFFFAOYSA-N;
MW          210.273;      // g/mol [origin=calculated method=formula-sum]
Tc          766.17;      // K   [origin=predictive method=joback]
Pc          23.070;      // bar [origin=predictive method=joback]
omega       0.6845;      // -   [origin=predictive method=lee-kesler]
Tb          567.66;      // K   [origin=predictive method=joback]
HvapTb      51424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.893 0.88124 -0.0003304 -7.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethoxyethoxybenzene" "phenoxyacetaldehyde diethyl acetal" "benzene, (2,2-diethoxyethoxy)-" "benzene,2-diethoxyethoxy)-" "1,1-diethoxy-2-phenoxyethane" "phenoxyacetaldehyde diethylacetal" "1-(2,2-diethoxyethoxy)benzene" "benzene,(2,2-diethoxyethoxy)-" "(2,2-diethoxy-ethoxy)-benzene" "phenoxy-acetaldehyde, diethyl acetal" "acetaldehyde, phenoxy-, diethyl acetal" );
standardThermochemistry
{
    dHf_298   -456420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154870.0
}
