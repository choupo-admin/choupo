/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isopropenyl-1-methylcyclopropane  (C7H12, CAS 3422-07-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isopropenyl1Methylcyclopropane;
formula     C7H12;
CAS         3422-07-9;
InChIKey    PQMFTBQGLFFXOQ-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          558.00;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.2305;      // -   [origin=predictive method=lee-kesler]
Tb          363.30;      // K   [origin=predictive method=joback]
HvapTb      29348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.39 1.09154 -0.001135 4.886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-1-prop-1-en-2-yl-cyclopropane" "cyclopropane, 1-methyl-1-isopropenyl-" "1-methyl-1-prop-1-en-2-ylcyclopropane" );
standardThermochemistry
{
    dHf_298   15870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142610.0
}
