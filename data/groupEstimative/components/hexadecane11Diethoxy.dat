/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecane, 1,1-diethoxy-  (C20H42O2, CAS 761-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecane11Diethoxy;
formula     C20H42O2;
CAS         761-60-4;
InChIKey    YURMTKBNIXEQDJ-UHFFFAOYSA-N;
MW          314.554;      // g/mol [origin=calculated method=formula-sum]
Tc          867.14;      // K   [origin=predictive method=joback]
Pc          9.989;      // bar [origin=predictive method=joback]
omega       0.8623;      // -   [origin=predictive method=lee-kesler]
Tb          701.60;      // K   [origin=predictive method=joback]
HvapTb      64546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.026 1.78336 -0.0008454 1.167e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxyhexadecane" "hexadecanal diethyl acetal" "hexadecane,1,1-diethoxy-" "palmitaldehyde,diethyl acetal (7ci,8ci); 1,1-diethoxyhexadecane; hexadecanal diethyl acetal" );
gibbsFormation
{
    dHf_298   -725850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     948.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94920.0
    phase     gas;
}
