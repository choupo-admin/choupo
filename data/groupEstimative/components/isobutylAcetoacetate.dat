/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyl acetoacetate  (C8H14O3, CAS 7779-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylAcetoacetate;
formula     C8H14O3;
CAS         7779-75-1;
InChIKey    ZYXNLVMBIHVDRH-UHFFFAOYSA-N;
MW          158.197;      // g/mol [origin=calculated method=formula-sum]
Tc          680.03;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.6470;      // -   [origin=predictive method=lee-kesler]
Tb          494.29;      // K   [origin=predictive method=joback]
HvapTb      47167.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.702 0.68696 -0.0003013 1.736e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl 3-oxidanylidenebutanoate" "isobutyl 3-oxobutanoate" "butanoic acid, 3-oxo-, 2-methylpropyl ester" "2-methylpropyl 3-oxobutanoate" "acetoacetic acid, isobutyl ester" "isobutyl 3-ketobutyrate" "isobutyl 3-ketobutanoate" "acetoacetic acid isobutyl ester" "2-methyl-1-propyl acetoacetate" "zyxnlvmbihvdrh-uhfffaoysa-" "o328" "acetoaceticacid, isobutyl ester (7ci,8ci);2-methylpropyl 3-oxobutanoate;isobutyl3-oxobutanoate;isobutyl acetoacetate;" );
standardThermochemistry
{
    dHf_298   -643590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-425250.0
}
