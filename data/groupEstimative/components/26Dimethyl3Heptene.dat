/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-3-heptene  (C9H18, CAS 2738-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl3Heptene;
formula     C9H18;
CAS         2738-18-3;
InChIKey    KDISTZUHDQPXDE-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          587.96;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.3543;      // -   [origin=predictive method=lee-kesler]
Tb          408.80;      // K   [origin=predictive method=joback]
HvapTb      34810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.839 0.89068 -0.000556 1.423e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylhept-3-ene" "3-heptene,2,6-dimethyl-" );
standardThermochemistry
{
    dHf_298   -122430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100240.0
}
