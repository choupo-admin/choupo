/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 225-009-9  (C21H10Cl12, CAS 4605-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2250099;
formula     C21H10Cl12;
CAS         4605-91-8;
InChIKey    IBGAOSYQYASNKV-UHFFFAOYSA-N;
MW          687.711;      // g/mol [origin=calculated method=formula-sum]
Tc          1496.74;      // K   [origin=predictive method=joback]
Pc          14.403;      // bar [origin=predictive method=joback]
omega       0.9927;      // -   [origin=predictive method=lee-kesler]
Tb          1191.64;      // K   [origin=predictive method=joback]
HvapTb      112734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-310.4 3.91552 -0.00503292 2.4046e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH; count 2; } { group CCl2; count 2; } { group Cl_C=C_; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:4
    joback ( { group CH3; count 1; } { group CH_ring; count 4; } { group C_ring; count 6; } { group dCH_ring; count 3; } { group dC_ring; count 7; } { group Cl; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6,7,8,13,13,14,14-dodecachloro-1,4,4a,4b,5,8,8a,12b-octahydro-10-methyl-1,4:5,8-dimethanotriphenylene" );
standardThermochemistry
{
    dHf_298   -22480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     890.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341690.0
}
