/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptyl-1,3-thiazolidine  (C10H21NS, CAS 706-19-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptyl13Thiazolidine;
formula     C10H21NS;
CAS         706-19-4;
InChIKey    FLUFGKPXTPJANY-UHFFFAOYSA-N;
MW          187.345;      // g/mol [origin=calculated method=formula-sum]
Tc          748.00;      // K   [origin=predictive method=joback]
Pc          25.533;      // bar [origin=predictive method=joback]
omega       0.5695;      // -   [origin=predictive method=lee-kesler]
Tb          540.06;      // K   [origin=predictive method=joback]
HvapTb      50681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.944 1.08653 -0.0006057 1.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-heptylthiazolidine" "thiazolidine, 2-heptyl-" );
standardThermochemistry
{
    dHf_298   -106180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197440.0
}
