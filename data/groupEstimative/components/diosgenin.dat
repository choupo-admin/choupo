/*--------------------------------*- Choupo -*-----------------------*\
  Component: diosgenin  (C27H42O3, CAS 512-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diosgenin;
formula     C27H42O3;
CAS         512-04-9;
InChIKey    WQLVFSAGQJTQCK-VKROHFNGSA-N;
MW          414.63;      // g/mol [origin=calculated method=formula-sum]
Tc          1258.30;      // K   [origin=predictive method=joback]
Pc          12.847;      // bar [origin=predictive method=joback]
omega       1.0468;      // -   [origin=predictive method=lee-kesler]
Tb          1015.28;      // K   [origin=predictive method=joback]
HvapTb      98033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-417.22 4.06278 -0.00368504 1.4213e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 7; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 10; } { group CH_ring; count 8; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nitogenin" "diosgenin," "(20r,25r)-spirost-5-en-3beta-ol" "dha, 512-04-9" "3beta-hydroxy-5-spirostene" "(25r)-5-spirosten-3beta-ol" "22alpha-spirost-5-en-3beta-ol" "nitrogenin" "sp 37" "spirost-5-en-3-beta-ol, (25r)-" "spirost-5-en-3-ol, (3-beta,25r)-" "disogenin" );
gibbsFormation
{
    dHf_298   -632830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112510.0
    phase     gas;
}
