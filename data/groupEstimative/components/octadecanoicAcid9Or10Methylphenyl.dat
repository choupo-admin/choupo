/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanoic acid, 9(or 10)-(methylphenyl)-  (C25H42O2, CAS 27014-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanoicAcid9Or10Methylphenyl;
formula     C25H42O2;
CAS         27014-49-9;
InChIKey    PNAYIMIYYPMNRM-UHFFFAOYSA-N;
MW          374.609;      // g/mol [origin=calculated method=formula-sum]
Tc          1161.30;      // K   [origin=predictive method=joback]
Pc          9.735;      // bar [origin=predictive method=joback]
omega       0.9412;      // -   [origin=predictive method=lee-kesler]
Tb          948.33;      // K   [origin=predictive method=joback]
HvapTb      90958.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.525 2.29714 -0.00137616 3.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-(4-methylphenyl)octadecanoic acid" );
gibbsFormation
{
    dHf_298   -689820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1060.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83950.0
    phase     gas;
}
