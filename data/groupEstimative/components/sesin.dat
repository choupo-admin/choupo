/*--------------------------------*- Choupo -*-----------------------*\
  Component: sesin  (C15H12Cl2O3, CAS 94-83-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sesin;
formula     C15H12Cl2O3;
CAS         94-83-7;
InChIKey    LGURYBCSJPXHTF-UHFFFAOYSA-N;
MW          311.158;      // g/mol [origin=calculated method=formula-sum]
Tc          1000.67;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       0.8756;      // -   [origin=predictive method=lee-kesler]
Tb          761.62;      // K   [origin=predictive method=joback]
HvapTb      73447.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.732 1.0476 -0.00055572 7.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 8; } { group AC; count 2; } { group CH2O; count 1; } { group ACCl; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(chloranyl)phenoxy]ethyl benzoate" "2-(2,4-dichlorophenoxy)ethyl benzoate" "2,4-dichlorophenoxyethyl benzoate" "2,4-deb" "ethanol, 2-(2,4-dichlorophenoxy)-, benzoate" "ethanol,4-dichlorophenoxy)-, benzoate" );
standardThermochemistry
{
    dHf_298   -383790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158250.0
}
