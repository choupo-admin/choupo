/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofuran-2-carbaldehyde  (C5H8O2, CAS 7681-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofuran2Carbaldehyde;
formula     C5H8O2;
CAS         7681-84-7;
InChIKey    BBNYLDSWVXSNOQ-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          611.00;      // K   [origin=predictive method=joback]
Pc          47.366;      // bar [origin=predictive method=joback]
omega       0.3930;      // -   [origin=predictive method=lee-kesler]
Tb          404.89;      // K   [origin=predictive method=joback]
HvapTb      38211.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.42 0.582 -0.0003547 7.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CHO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolane-2-carbaldehyde" "tetrahydro-2-furancarboxaldehyde" "tetrahydrofurfural" "usaf q-4" "2-furaldehyde, tetrahydro-" "2-furancarboxaldehyde, tetrahydro-" "tetrahydro-2-furancarbaldehyde" "tetrahydro-furan-2-carbaldehyde" "2-furancarboxaldehyde, tetrahydro- (9ci)" );
gibbsFormation
{
    dHf_298   -303630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     267.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157870.0
    phase     gas;
}
