/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropylbicyclohexyl  (C15H28, CAS 66374-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropylbicyclohexyl;
formula     C15H28;
CAS         66374-73-0;
InChIKey    XWULVJMSQHXLOJ-UHFFFAOYSA-N;
MW          208.389;      // g/mol [origin=calculated method=formula-sum]
Tc          801.21;      // K   [origin=predictive method=joback]
Pc          19.355;      // bar [origin=predictive method=joback]
omega       0.4171;      // -   [origin=predictive method=lee-kesler]
Tb          576.79;      // K   [origin=predictive method=joback]
HvapTb      49145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.7 1.65244 -0.000902 1.578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-2-propan-2-yl-cyclohexane" "1,1'-bicyclohexyl, 2-(1-methylethyl)-, cis-" "bicyclohexyl, 2-isopropyl-, cis-" "2-isopropyl-1,1'-bicyclohexane" "bicyclohexyl, 2-isopropyl-, trans-" "1-cyclohexyl-2-propan-2-ylcyclohexane" "1,1'-bicyclohexyl, 2-(1-methylethyl)-" "1,1'-bicyclohexyl, 2-(1-methylethyl)-, trans-" );
gibbsFormation
{
    dHf_298   -269910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114170.0
    phase     gas;
}
