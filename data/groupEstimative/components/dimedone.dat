/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimedone  (C8H12O2, CAS 126-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimedone;
formula     C8H12O2;
CAS         126-81-8;
InChIKey    BADXJIPKFRBFOT-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          785.71;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.4387;      // -   [origin=predictive method=lee-kesler]
Tb          538.07;      // K   [origin=predictive method=joback]
HvapTb      41174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.12 0.84124 -0.000537 1.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethylcyclohexane-1,3-dione" "cyclomethone" "5,5-dimethyl-1,3-cyclohexanedione" "methone" "medon" "dimedon" "methon" "1,3-cyclohexanedione, 5,5-dimethyl-" "5,5-dimethyldihydroresorcinol" "dimethyldihydroresorcinol" "5,5-dimethylhydroresorcinol" "1,1-dimethyl-3,5-cyclohexanedione" );
gibbsFormation
{
    dHf_298   -414290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209740.0
    phase     gas;
}
