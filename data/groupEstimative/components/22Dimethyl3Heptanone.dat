/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-3-heptanone  (C9H18O, CAS 19078-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl3Heptanone;
formula     C9H18O;
CAS         19078-97-8;
InChIKey    ZLMHETMAEHQFHK-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          641.24;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.4748;      // -   [origin=predictive method=lee-kesler]
Tb          456.16;      // K   [origin=predictive method=joback]
HvapTb      41078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.407 0.95668 -0.0006189 1.5876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylheptan-3-one" "3-heptanone,2,2-dimethyl-" "2,2-dimethylheptan-3-one;butyl tert-butyl ketone;2,2-dimethyl-3-heptanone;" );
gibbsFormation
{
    dHf_298   -350420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101180.0
    phase     gas;
}
