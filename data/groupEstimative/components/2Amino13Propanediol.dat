/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-1,3-propanediol  (C3H9NO2, CAS 534-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino13Propanediol;
formula     C3H9NO2;
CAS         534-03-2;
InChIKey    KJJPLEZQSCZCKE-UHFFFAOYSA-N;
MW          91.11;      // g/mol [origin=calculated method=formula-sum]
Tc          698.31;      // K   [origin=predictive method=joback]
Pc          63.289;      // bar [origin=predictive method=joback]
omega       1.3827;      // -   [origin=predictive method=lee-kesler]
Tb          524.69;      // K   [origin=predictive method=joback]
HvapTb      65883.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.552 0.4246 -0.0002468 5.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylpropane-1,3-diol" "serinol" "2-aminopropane-1,3-diol" "1,3-propanediol, 2-amino-" "2-aminopropan-1,3-diol" "2-amino-1,3-dihydroxypropane" "sel" "2-amino-1,3-propandiol" "2-aminopropane-1,3-diol 99%" );
standardThermochemistry
{
    dHf_298   -381200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235250.0
}
