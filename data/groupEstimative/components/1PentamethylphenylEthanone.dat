/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(pentamethylphenyl)ethanone  (C13H18O, CAS 2040-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PentamethylphenylEthanone;
formula     C13H18O;
CAS         2040-01-9;
InChIKey    CTTYWXDVWGKHKJ-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          812.34;      // K   [origin=predictive method=joback]
Pc          21.694;      // bar [origin=predictive method=joback]
omega       0.6576;      // -   [origin=predictive method=lee-kesler]
Tb          602.49;      // K   [origin=predictive method=joback]
HvapTb      56864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.02 0.83452 -0.0003607 3.546e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group ACCH3; count 5; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dC_ring; count 6; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,3,4,5,6-pentamethylphenyl)ethanone" "2',3',4',5',6'-pentamethylacetophenone" "1-(pentamethylphenyl)ethan-1-one" "2,3,4,5,6-pentamethylacetophenone" "1-acetyl-2,3,4,5,6-pentamethylbenzene" "1-(2,3,4,5,6-pentamethylphenyl)ethan-1-one" "ethanone,1-(2,3,4,5,6-pentamethylphenyl)-" "acetophenone,2,3,4,5,6-pentamethyl- (4ci); acetophenone, 2',3',4',5',6'-pentamethyl-(6ci,7ci,8ci); ethanone, 1-(pentamethylphenyl)- (9ci);2,3,4,5,6-pentamethylacetophenone; 2',3',4',5',6'-pentamethylacetophenone;acetylpentamethylbenzene; methyl 2,3,4,5,6-pentamethylphenyl ketone" );
standardThermochemistry
{
    dHf_298   -245050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6080.0
}
