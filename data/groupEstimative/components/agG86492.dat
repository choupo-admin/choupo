/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-86492  (C19H32O3, CAS 72727-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG86492;
formula     C19H32O3;
CAS         72727-71-0;
InChIKey    QRQVLSMUEPAWSS-UHFFFAOYSA-N;
MW          308.462;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.97;      // K   [origin=predictive method=joback]
Pc          14.392;      // bar [origin=predictive method=joback]
omega       1.0685;      // -   [origin=predictive method=lee-kesler]
Tb          804.91;      // K   [origin=predictive method=joback]
HvapTb      80559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.916 2.2059 -0.00167964 5.456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group C; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 3-methyl-3-oxidanyl-5-(2,6,6-trimethylcyclohex-2-en-1-yl)pent-4-enoate" "4-pentenoic acid,3-hydroxy-3-methyl-5-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, butyl ester" );
standardThermochemistry
{
    dHf_298   -701000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     905.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223450.0
}
