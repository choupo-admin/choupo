/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-phenoxyethoxy)ethanol  (C10H14O3, CAS 104-68-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22PhenoxyethoxyEthanol;
formula     C10H14O3;
CAS         104-68-7;
InChIKey    ZUAURMBNZUCEAF-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          781.84;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       1.0368;      // -   [origin=predictive method=lee-kesler]
Tb          592.10;      // K   [origin=predictive method=joback]
HvapTb      61629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.184 0.7825 -0.0003598 3.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenoxydiglycol" "phenyl carbitol" "diethylene glycol monophenyl ether" "ethanol, 2-(2-phenoxyethoxy)-" "diethylene glycolphenyl ether" "diethylene glycol phenyl ether" "fenylkarbitol" "ethanol,2-(2-phenoxyethoxy)-" "2-(2-phenoxyethoxy)ethan-1-ol" );
standardThermochemistry
{
    dHf_298   -429870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201090.0
}
