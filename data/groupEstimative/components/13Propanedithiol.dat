/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-propanedithiol  (C3H8S2, CAS 109-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Propanedithiol;
formula     C3H8S2;
CAS         109-80-8;
InChIKey    ZJLMKPKYJBQJNH-UHFFFAOYSA-N;
MW          108.217;      // g/mol [origin=calculated method=formula-sum]
Tc          614.85;      // K   [origin=predictive method=joback]
Pc          52.663;      // bar [origin=predictive method=joback]
omega       0.2960;      // -   [origin=predictive method=lee-kesler]
Tb          393.96;      // K   [origin=predictive method=joback]
HvapTb      35746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.943 0.3434 -0.0001842 3.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propane-1,3-dithiol" "1,3-dimercaptopropane" "dithiotrimethyleneglycol" "trimethylene dimercaptan" "trimethylenedithiol" "trimethylenedithioglycol" "1,3-propanedimercaptan" "trimethylene dithiol" "1,3-dithiolpropane;1,3-propanedimercaptan;1,3-trimethylenedithiol;3-mercaptopropanethiol;dithiotrimethyleneglycol;trimethylene dimercaptan;trimethylenedithioglycol;trimethylenedithiol;1,3-propanedithiol;" );
gibbsFormation
{
    dHf_298   -28290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33160.0
    phase     gas;
}
