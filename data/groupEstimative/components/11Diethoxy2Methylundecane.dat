/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethoxy-2-methylundecane  (C16H34O2, CAS 67785-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diethoxy2Methylundecane;
formula     C16H34O2;
CAS         67785-65-3;
InChIKey    CNWQANBQCPRGEE-UHFFFAOYSA-N;
MW          258.446;      // g/mol [origin=calculated method=formula-sum]
Tc          773.98;      // K   [origin=predictive method=joback]
Pc          13.014;      // bar [origin=predictive method=joback]
omega       0.8090;      // -   [origin=predictive method=lee-kesler]
Tb          609.64;      // K   [origin=predictive method=joback]
HvapTb      55254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.98 1.40928 -0.000631 6.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxy-2-methyl-undecane" "undecane, 1,1-diethoxy-2-methyl-" );
standardThermochemistry
{
    dHf_298   -648570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     782.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131040.0
}
