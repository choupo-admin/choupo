/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyl-2-phenyl-1,3-dioxolane  (C11H14O2, CAS 25687-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyl2Phenyl13Dioxolane;
formula     C11H14O2;
CAS         25687-77-8;
InChIKey    CIHKNVXTQCYONS-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          784.04;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.4418;      // -   [origin=predictive method=lee-kesler]
Tb          542.71;      // K   [origin=predictive method=joback]
HvapTb      50173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.91 1.36104 -0.0011826 4.371e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2,4-dimethyl-2-phenyl-" "1,3-dioxolane, 2,4-dimethyl-2-phenyl-, (2r,4r)-rel-" "1,3-dioxolane, 2,4-dimethyl-2-phenyl-, (2r,4s)-rel-" );
standardThermochemistry
{
    dHf_298   -242460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5260.0
}
