/*--------------------------------*- Choupo -*-----------------------*\
  Component: norbornyl acetate  (C9H14O2, CAS 34640-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norbornylAcetate;
formula     C9H14O2;
CAS         34640-76-1;
InChIKey    YXNICIBZSREEPY-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          682.46;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.4621;      // -   [origin=predictive method=lee-kesler]
Tb          476.82;      // K   [origin=predictive method=joback]
HvapTb      42724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.55 1.06972 -0.0007098 1.793e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bicyclo[2.2.1]heptanyl ethanoate" "norborneol acetate" "2-norbornyl acetate" "bicyclo[2.2.1]heptan-2-ol, acetate" "bicyclo(2.2.1)hept-2-yl acetate" "bicyclo[2.2.1]hept-2-yl acetate" "bicyclo(2.2.1)heptan-2-ol, acetate" "bicyclo(2.2.1)heptan-2-ol, 2-acetate" "bicyclo[2.2.1]heptan-2-ol, 2-acetate" "3-bicyclo[2.2.1]heptanyl acetate" "[(1r,4s)-3-bicyclo[2.2.1]heptanyl] acetate" );
gibbsFormation
{
    dHf_298   -427270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183780.0
    phase     gas;
}
