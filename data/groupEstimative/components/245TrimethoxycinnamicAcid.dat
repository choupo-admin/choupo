/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5-trimethoxycinnamic acid  (C12H14O5, CAS 24160-53-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        245TrimethoxycinnamicAcid;
formula     C12H14O5;
CAS         24160-53-0;
InChIKey    XCEGAEUDHJEYRY-UHFFFAOYSA-N;
MW          238.239;      // g/mol [origin=calculated method=formula-sum]
Tc          948.91;      // K   [origin=predictive method=joback]
Pc          25.151;      // bar [origin=predictive method=joback]
omega       1.0831;      // -   [origin=predictive method=lee-kesler]
Tb          732.71;      // K   [origin=predictive method=joback]
HvapTb      70920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.89 0.76766 -0.00028248 -6.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2,4,5-trimethoxyphenyl)prop-2-enoic acid" "2,4,5- trimethoxycinnamic acid" "2',4',5'-trimethoxycinnamic acid" "2,4,5-trimethoxy cinnamic acid" "2-propenoic acid,3-(2,4,5-trimethoxyphenyl)-" );
gibbsFormation
{
    dHf_298   -718600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-445010.0
    phase     gas;
}
