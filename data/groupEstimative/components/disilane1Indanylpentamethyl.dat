/*--------------------------------*- Choupo -*-----------------------*\
  Component: disilane,1-indanylpentamethyl-  (C14H24Si2, CAS 27490-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H24Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        disilane1Indanylpentamethyl;
formula     C14H24Si2;
CAS         27490-23-9;
InChIKey    QMXCQCHWADYMTG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.516;      // g/mol [origin=calculated method=formula-sum]
Tc          784.31;      // K   [origin=predictive method=joback]
Pc          18.016;      // bar [origin=predictive method=joback]
omega       0.3505;      // -   [origin=predictive method=lee-kesler]
Tb          561.12;      // K   [origin=predictive method=joback]
HvapTb      50197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.95 0.934 -9.256e-05 -1.791e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-inden-1-yl-dimethyl-trimethylsilyl-silane" "disilane, 1-indanylpentamethyl-" "2,3-dihydro-1h-inden-1-yl-dimethyl-trimethylsilylsilane" );
gibbsFormation
{
    dHf_298   -257670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     751.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21010.0
    phase     gas;
}
