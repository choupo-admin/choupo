/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-(ethylamino)-4-methylcoumarin  (C12H13NO2, CAS 28821-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Ethylamino4Methylcoumarin;
formula     C12H13NO2;
CAS         28821-18-3;
InChIKey    OTNIKUTWXUODJZ-UHFFFAOYSA-N;
MW          203.241;      // g/mol [origin=calculated method=formula-sum]
Tc          846.17;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       0.8332;      // -   [origin=predictive method=lee-kesler]
Tb          630.47;      // K   [origin=predictive method=joback]
HvapTb      60753.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.109 1.03884 -0.00072236 1.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(ethylamino)-4-methyl-chromen-2-one" "7-(ethylamino)-4-methyl-2h-chromen-2-one" "2h-1-benzopyran-2-one, 7-(ethylamino)-4-methyl-" "7-(ethylamino)-4-methylchromen-2-one" "7-(ethylamino)-4-methyl-2-benzopyrone" "7-(ethylamino)-4-methyl-1-benzopyran-2-one" "2h-1-benzopyran-2-one,7-(ethylamino)-4-methyl-" "7-(ethylamino)-4-methyl-2h-1-benzopyran-2-one" );
standardThermochemistry
{
    dHf_298   -195620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23220.0
}
