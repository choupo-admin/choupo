/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(isopropyloxy)-1-methylethyl acetate  (C8H16O3, CAS 54839-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropyloxy1MethylethylAcetate;
formula     C8H16O3;
CAS         54839-25-7;
InChIKey    JQTIDYJFCNWJFO-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          641.32;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.5598;      // -   [origin=predictive method=lee-kesler]
Tb          462.40;      // K   [origin=predictive method=joback]
HvapTb      42443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.161 0.65768 -0.0002122 -2.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group CH3COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-yloxypropan-2-yl ethanoate" "2-propanol, 1-(1-methylethoxy)-, acetate" "2-propanol, 1-(1-methylethoxy)-, 2-acetate" "1-propan-2-yloxypropan-2-yl acetate" );
standardThermochemistry
{
    dHf_298   -668510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403770.0
}
