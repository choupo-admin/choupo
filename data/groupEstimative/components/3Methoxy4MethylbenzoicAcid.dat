/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-4-methylbenzoic acid  (C9H10O3, CAS 7151-68-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy4MethylbenzoicAcid;
formula     C9H10O3;
CAS         7151-68-0;
InChIKey    CEAVPXDEPGAVDA-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          833.25;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.8120;      // -   [origin=predictive method=lee-kesler]
Tb          610.09;      // K   [origin=predictive method=joback]
HvapTb      58802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.5 0.64854 -0.00032452 4.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxy-4-methyl-benzoic acid" "4-methyl-m-anisic acid" "3-methoxy-p-toluic acid" "benzoic acid, 3-methoxy-4-methyl-" "5-carboxy-2-methylanisole" "4-carboxy-2-methoxytoluene" "3-methoxy-4-methyl benzoic acid" "3-methoxy-4-toluic acid" "benzoicacid, 3-methoxy-4-methyl-" "3-methoxy-p-toluic acid; 4-methyl-m-anisic acid" );
standardThermochemistry
{
    dHf_298   -497990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-330860.0
}
