/*--------------------------------*- Choupo -*-----------------------*\
  Component: acrylic acid, ethyl acrylate, methacrylic acid, methyl acrylate polymer  (C16H24O8, CAS 53934-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acrylicAcidEthylAcrylateMethacrylicAcidMethylAcrylatePolymer;
formula     C16H24O8;
CAS         53934-26-2;
InChIKey    LAOIHTUHVHNGAJ-UHFFFAOYSA-N;
MW          344.36;      // g/mol [origin=calculated method=formula-sum]
Tc          1187.52;      // K   [origin=predictive method=joback]
Pc          14.165;      // bar [origin=predictive method=joback]
omega       1.2036;      // -   [origin=predictive method=lee-kesler]
Tb          963.94;      // K   [origin=predictive method=joback]
HvapTb      98634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (159.161 0.81716 0.0003479 -4.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2=CH; count 3; } { group CH2=C; count 1; } { group COOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 4; } { group dCH; count 3; } { group dC; count 1; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl prop-2-enoate;methyl prop-2-enoate;2-methylprop-2-enoic acid;prop-2-enoic acid" "2-propenoic acid, 2-methyl-, polymer with ethyl 2-propenoate, methyl 2-propenoate and 2-propenoic acid" "ethyl prop-2-enoate; methyl prop-2-enoate; 2-methylprop-2-enoic acid; prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1551600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1288.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1196190.0
    phase     gas;
}
