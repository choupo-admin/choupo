/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethylene diisocyanate  (C6H8N2O2, CAS 4538-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetramethyleneDiisocyanate;
formula     C6H8N2O2;
CAS         4538-37-8;
InChIKey    OVBFMUAFNIIQAL-UHFFFAOYSA-N;
MW          140.142;      // g/mol [origin=calculated method=formula-sum]
Tc          659.44;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.6701;      // -   [origin=predictive method=lee-kesler]
Tb          470.22;      // K   [origin=predictive method=joback]
HvapTb      48014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 4; } { group dCd; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diisocyanatobutane" "1,4-butanediol diisocyanate" "1,4-butylene diisocyanate" "1,4-tetramethylenediisocyanate" "butane 1,4-diisocyanate" "butane, 1,4-diisocyanato-" "butylenediisocyanate" "isocyanic acid, tetramethylene ester" "tetramethylene isocyanate" "1,4-butanediisocyanate" "NSC510650" "1,4-diisocyanato-butane" );
