/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyltoluene  (C9H12, CAS 620-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyltoluene;
formula     C9H12;
CAS         620-14-4;
InChIKey    ZLCSFXXPPANWQY-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          645.83;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.3410;      // -   [origin=predictive method=lee-kesler]
Tb          437.18;      // K   [origin=predictive method=joback]
HvapTb      38566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.899 0.72044 -0.00042996 9.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-3-methyl-benzene" "m-ethyltoluene" "1-ethyl-3-methylbenzene" "benzene, 1-ethyl-3-methyl-" "toluene, m-ethyl-" "1-methyl-3-ethylbenzene" "m-ethylmethylbenzene" "m-methylethylbenzene" "3-methylethylbenzene" "3-ethyl-1-methylbenzene" "3-ethyl toluene" "toluene, m-ethyl- (8ci)" );
gibbsFormation
{
    dHf_298   -4030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127680.0
    phase     gas;
}
