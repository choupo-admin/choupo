/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-bipyridine-4,4'-dicarboxylic acid  (C12H8N2O4, CAS 6813-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bipyridine44DicarboxylicAcid;
formula     C12H8N2O4;
CAS         6813-38-3;
InChIKey    FXPLCAKVOYHAJA-UHFFFAOYSA-N;
MW          244.206;      // g/mol [origin=calculated method=formula-sum]
Tc          1205.36;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       1.4803;      // -   [origin=predictive method=lee-kesler]
Tb          935.90;      // K   [origin=predictive method=joback]
HvapTb      94930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.91 1.03612 -0.00072104 1.924e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H3N; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group COOH; count 2; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-carboxypyridin-2-yl)pyridine-4-carboxylic acid" "4,4'-dicarboxy-2,2'-bipyridine" "2,2'-biisonicotinic acid" "2,2'-dipyridyl-4,4'-dicarboxylic acid" "[2,2'-bipyridine]-4,4'-dicarboxylic acid" "2,2'-bipyridyl-4,4'-dicarboxylic acid" "2-(4-carboxy-2-pyridyl)pyridine-4-carboxylic acid" "4,4-dicarboxy-2,2-bipyridine" "2,2'-bipyridine-4,4'-dicarboxylicacid" "2,2-bipyridyl-4,4-dicarboxylic acid" "2,2'-bipyridin-4,4'-dicarboxylic acid" "[2,2']bipyridinyl-4,4'-dicarboxylic acid" );
standardThermochemistry
{
    dHf_298   -475850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-278000.0
}
