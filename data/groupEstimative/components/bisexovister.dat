/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisexovister  (C25H38O4, CAS 2297-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisexovister;
formula     C25H38O4;
CAS         2297-30-5;
InChIKey    ZDDFOEZPFDWEQS-YMKPZFJOSA-N;
MW          402.575;      // g/mol [origin=calculated method=formula-sum]
Tc          1155.29;      // K   [origin=predictive method=joback]
Pc          11.483;      // bar [origin=predictive method=joback]
omega       0.8919;      // -   [origin=predictive method=lee-kesler]
Tb          926.96;      // K   [origin=predictive method=joback]
HvapTb      84295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-255.678 3.21368 -0.00261504 9.105e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 5; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8r,9s,10r,13s,14s,17s)-10,13-dimethyl-17-propanoyloxy-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] propanoate" "stenandiol" "bisexovis" "ginandrin" "androstenediol dipropionate" "androst-5-ene-(3beta,17beta)-diol dipropionate" "androst-5-ene-3-beta,17-beta-diol, dipropionate" "androst-5-ene-3-" "a,17-" "a-diol, dipropionate" "androst-5-ene-3,17-diol, dipropanoate, (3-beta,17-beta)-" "androst-5-ene-3,17-diol, dipropanoate, (3-beta,17-beta)- (9ci)" );
gibbsFormation
{
    dHf_298   -917720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     939.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292400.0
    phase     gas;
}
