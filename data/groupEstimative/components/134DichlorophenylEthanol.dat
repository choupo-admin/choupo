/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3,4-dichlorophenyl)ethanol  (C8H8Cl2O, CAS 1475-11-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        134DichlorophenylEthanol;
formula     C8H8Cl2O;
CAS         1475-11-2;
InChIKey    VZTGSONNNMGQNQ-UHFFFAOYSA-N;
MW          191.051;      // g/mol [origin=calculated method=formula-sum]
Tc          799.23;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.8521;      // -   [origin=predictive method=lee-kesler]
Tb          585.88;      // K   [origin=predictive method=joback]
HvapTb      62063.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.7 0.61942 -0.00038292 8.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,4-dichlorophenyl)ethan-1-ol" "benzenemethanol, 3,4-dichloro-.alpha.-methyl-" "benzyl alcohol, 3,4-dichloro-.alpha.-methyl-" "3,4-dichloro-alpha-methylbenzyl alcohol" "benzenemethanol,3,4-dichloro-a-methyl-" "3,4-dichloro-.alpha.-methylbenzyl alcohol" "benzyl alcohol,4-dichloro-.alpha.-methyl-" "benzenemethanol,4-dichloro-.alpha.-methyl-" );
gibbsFormation
{
    dHf_298   -183850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53490.0
    phase     gas;
}
