/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-fluoro-3-iodobenzene  (C6H4FI, CAS 1121-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Fluoro3Iodobenzene;
formula     C6H4FI;
CAS         1121-86-4;
InChIKey    VSKSBSORLCDRHS-UHFFFAOYSA-N;
MW          221.996;      // g/mol [origin=calculated method=formula-sum]
Tc          704.56;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.2992;      // -   [origin=predictive method=lee-kesler]
Tb          460.95;      // K   [origin=predictive method=joback]
HvapTb      40444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.39 0.4862 -0.00036456 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group I; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-3-iodanyl-benzene" "3-fluoroiodobenzene" "m-fluoroiodobenzene" "3-iodofluorobenzene" "benzene, 1-fluoro-3-iodo-" "m-iodofluorobenzene" "1-fluoro-3-iodo-benzene" "3-fluoro-1-iodobenzene" );
gibbsFormation
{
    dHf_298   -61350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34270.0
    phase     gas;
}
