/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3',5,5'-tetramethylbenzidine  (C16H20N2, CAS 54827-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3355Tetramethylbenzidine;
formula     C16H20N2;
CAS         54827-17-7;
InChIKey    UAIUNKRWKOVEES-UHFFFAOYSA-N;
MW          240.35;      // g/mol [origin=calculated method=formula-sum]
Tc          1039.56;      // K   [origin=predictive method=joback]
Pc          23.383;      // bar [origin=predictive method=joback]
omega       0.9326;      // -   [origin=predictive method=lee-kesler]
Tb          793.98;      // K   [origin=predictive method=joback]
HvapTb      81016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.31 1.13288 -0.00059356 1.028e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group ACCH3; count 4; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-azanyl-3,5-dimethyl-phenyl)-2,6-dimethyl-aniline" "3,5,3',5'-tetramethylbenzidine" "tmb substrate" "tmb plus" "bm blue" "tmb, insoluble" "tmb, soluble" "tmb-e" "tmb/h" "tmb/m" "tetramethylbenzidin" "tmb" );
gibbsFormation
{
    dHf_298   98250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=383780.0
    phase     gas;
}
