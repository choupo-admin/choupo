/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, 1-bromo-2,3-dimethyl-  (C6H13Br, CAS 30540-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane1Bromo23Dimethyl;
formula     C6H13Br;
CAS         30540-31-9;
InChIKey    CNNUHHAUPSXEKI-UHFFFAOYSA-N;
MW          165.074;      // g/mol [origin=calculated method=formula-sum]
Tc          594.88;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.3602;      // -   [origin=predictive method=lee-kesler]
Tb          402.16;      // K   [origin=predictive method=joback]
HvapTb      34609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.261 0.62386 -0.0003804 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2,3-dimethyl-butane" "agn-pc-00nm8u" );
gibbsFormation
{
    dHf_298   -151400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9080.0
    phase     gas;
}
