/*--------------------------------*- Choupo -*-----------------------*\
  Component: tributan-2-yl hydrogen orthosilicate  (C12H28O4Si, CAS 18166-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H28O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tributan2YlHydrogenOrthosilicate;
formula     C12H28O4Si;
CAS         18166-44-4;
InChIKey    IPFHPMNECZXQDM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          264.437;      // g/mol [origin=calculated method=formula-sum]
Tc          803.40;      // K   [origin=predictive method=joback]
Pc          17.005;      // bar [origin=predictive method=joback]
omega       1.0220;      // -   [origin=predictive method=lee-kesler]
Tb          633.68;      // K   [origin=predictive method=joback]
HvapTb      65345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (109.543 0.79982 7.88e-05 -2.417e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group OH; count 1; } { group CH-O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 3; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tri(butan-2-yloxy)-oxidanyl-silane" "silicic acid (h4sio4), tris(1-methylpropyl) ester" "tri(butan-2-yloxy)-hydroxysilane" );
standardThermochemistry
{
    dHf_298   -967360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     806.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-513740.0
}
