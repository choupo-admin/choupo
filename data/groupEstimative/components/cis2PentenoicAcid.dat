/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-pentenoic acid  (C5H8O2, CAS 626-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2PentenoicAcid;
formula     C5H8O2;
CAS         626-98-2;
InChIKey    YIYBQIKDCADOSF-ARJAWSKDSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          664.23;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.5940;      // -   [origin=predictive method=lee-kesler]
Tb          463.67;      // K   [origin=predictive method=joback]
HvapTb      43846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.239 0.54962 -0.0004046 1.237e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-pent-2-enoic acid" "(2z)-pent-2-enoic acid" "pent-2c-ensaeure" "pent-2c-enoic acid" "cis-pent-2-ensaeure" "z-2-pentencarbonsaeure" "(z)-2-pentenoic acid" "2-pentenoic acid (z)" "cis-3-ethylacrylic acid" "cis-beta-aethylacrylsaeure" "2-pentenoic acid, (2z)-" "cis-alpha,beta-penteneoic acid" );
gibbsFormation
{
    dHf_298   -379580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272470.0
    phase     gas;
}
