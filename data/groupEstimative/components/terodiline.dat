/*--------------------------------*- Choupo -*-----------------------*\
  Component: terodiline  (C20H27N, CAS 15793-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        terodiline;
formula     C20H27N;
CAS         15793-40-5;
InChIKey    UISARWKNNNHPGI-UHFFFAOYSA-N;
MW          281.443;      // g/mol [origin=calculated method=formula-sum]
Tc          989.04;      // K   [origin=predictive method=joback]
Pc          16.963;      // bar [origin=predictive method=joback]
omega       0.7411;      // -   [origin=predictive method=lee-kesler]
Tb          756.62;      // K   [origin=predictive method=joback]
HvapTb      69030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.149 1.95988 -0.0013534 3.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-tert-butyl-4,4-diphenyl-butan-2-amine" "terodilinum [inn-latin]" "terodiline [inn:ban:jan]" "n-tert-butyl-4,4-diphenylbutan-2-amine" "propylamine, n-tert-butyl-1-methyl-3,3-diphenyl-" "benzenepropanamine, n-(1,1-dimethylethyl)-alpha-methyl-gamma-phenyl-" "benzenepropanamine, n-(1,1-dimethylethyl)-.alpha.-methyl-.gamma.-phenyl-" "terodilina" "terodilinum" "agn-pc-00nrtp" "n-tert-butyl-1-methyl-3,3-diphenylpropylamine" "n-tert-butyl-3,3-diphenyl-1-methylpropylamine" );
standardThermochemistry
{
    dHf_298   51090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=429690.0
}
