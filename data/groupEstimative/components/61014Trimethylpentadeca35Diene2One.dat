/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,10,14-trimethylpentadeca-3,5-diene-2-one  (C18H32O, CAS 1604-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        61014Trimethylpentadeca35Diene2One;
formula     C18H32O;
CAS         1604-32-6;
InChIKey    LGSXJEDIGQMTRC-BYYJQVKUSA-N;
MW          264.453;      // g/mol [origin=calculated method=formula-sum]
Tc          856.49;      // K   [origin=predictive method=joback]
Pc          13.147;      // bar [origin=predictive method=joback]
omega       0.7894;      // -   [origin=predictive method=lee-kesler]
Tb          672.63;      // K   [origin=predictive method=joback]
HvapTb      61628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.534 1.7376 -0.001113 2.8956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 2; } { group dCH; count 3; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,5e)-6,10,14-trimethylpentadeca-3,5-dien-2-one" "pentadeca-3,5-diene-2-one, 6,10,14-trimethyl-" );
gibbsFormation
{
    dHf_298   -313340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118770.0
    phase     gas;
}
