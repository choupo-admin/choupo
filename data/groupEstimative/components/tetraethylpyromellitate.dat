/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraethylpyromellitate  (C18H22O8, CAS 6634-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraethylpyromellitate;
formula     C18H22O8;
CAS         6634-01-1;
InChIKey    FRBIXZIRQKZWGN-UHFFFAOYSA-N;
MW          366.366;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.20;      // K   [origin=predictive method=joback]
Pc          14.348;      // bar [origin=predictive method=joback]
omega       1.1829;      // -   [origin=predictive method=lee-kesler]
Tb          885.94;      // K   [origin=predictive method=joback]
HvapTb      89552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (97.154 1.23728 -0.00040708 -7.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group ACH; count 2; } { group AC; count 4; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetraethyl benzene-1,2,4,5-tetracarboxylate" );
gibbsFormation
{
    dHf_298   -1481850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     937.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1057280.0
    phase     gas;
}
