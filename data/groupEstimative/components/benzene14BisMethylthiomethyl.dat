/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,4-bis(methylthiomethyl)-  (C10H14S2, CAS 75919-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene14BisMethylthiomethyl;
formula     C10H14S2;
CAS         75919-81-2;
InChIKey    RXSOGQQIXHXMGS-UHFFFAOYSA-N;
MW          198.342;      // g/mol [origin=calculated method=formula-sum]
Tc          845.23;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.5238;      // -   [origin=predictive method=lee-kesler]
Tb          597.62;      // K   [origin=predictive method=joback]
HvapTb      54426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.392 0.80422 -0.00040396 5.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 2; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(methylsulfanylmethyl)benzene" "1,4-bis[(methylsulfanyl)methyl]benzene" );
gibbsFormation
{
    dHf_298   59070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202340.0
    phase     gas;
}
