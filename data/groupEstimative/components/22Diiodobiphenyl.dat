/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-diiodobiphenyl  (C12H8I2, CAS 2236-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Diiodobiphenyl;
formula     C12H8I2;
CAS         2236-52-4;
InChIKey    OZVRXSGTNWILMN-UHFFFAOYSA-N;
MW          405.996;      // g/mol [origin=calculated method=formula-sum]
Tc          1038.36;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.4704;      // -   [origin=predictive method=lee-kesler]
Tb          723.76;      // K   [origin=predictive method=joback]
HvapTb      66928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.85 0.945 -0.00072012 2.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-2-(2-iodanylphenyl)benzene" "2,2'-diiodo-1,1'-biphenyl" "1-iodo-2-(2-iodophenyl)benzene" "ambap2236-52-4" "1,1'-biphenyl,2,2'-diiodo-" "2,2'-diiodo-1,1'-biphenyl;1-iodo-2-(2-iodophenyl)benzene;" );
gibbsFormation
{
    dHf_298   312850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=371960.0
    phase     gas;
}
