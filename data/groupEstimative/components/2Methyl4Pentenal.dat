/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-4-pentenal  (C6H10O, CAS 5187-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl4Pentenal;
formula     C6H10O;
CAS         5187-71-3;
InChIKey    RCQKLWAPRHHRNN-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          562.13;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.3983;      // -   [origin=predictive method=lee-kesler]
Tb          381.78;      // K   [origin=predictive method=joback]
HvapTb      34612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.161 0.53422 -0.0003217 7.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpent-4-enal" "2-methyl-pent-4-enal" "4-pentenal, 2-methyl-" );
gibbsFormation
{
    dHf_298   -132600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14480.0
    phase     gas;
}
