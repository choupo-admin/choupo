/*--------------------------------*- Choupo -*-----------------------*\
  Component: zactane citrate  (C22H31NO9, CAS 6700-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zactaneCitrate;
formula     C22H31NO9;
CAS         6700-56-7;
InChIKey    KCVHFFSPDODYOG-UHFFFAOYSA-N;
MW          453.488;      // g/mol [origin=calculated method=formula-sum]
Tc          1667.49;      // K   [origin=predictive method=joback]
Pc          16.578;      // bar [origin=predictive method=joback]
omega       1.2775;      // -   [origin=predictive method=lee-kesler]
Tb          1346.97;      // K   [origin=predictive method=joback]
HvapTb      142739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.457 2.60404 -0.001841 5.125e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group COOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-methyl-4-phenyl-azepane-4-carboxylate;2-oxidanylpropane-1,2,3-tricarboxylic acid" "ethoheptazine citrate" "1-methyl-1-carbethoxy-4-phenyl hexamethylenimine citrate" "ethyl hexahydro-1-methyl-4-phenyl-1h-azepine-4-carboxylate, compound with citric acid (1:1)" "ethyl 1-methyl-4-phenylazepane-4-carboxylate; 2-hydroxypropane-1,2,3-tricarboxylic acid" "ethoheptazine citrate (jan)" "77-15-6 (parent)" );
standardThermochemistry
{
    dHf_298   -1764480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1292.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1204330.0
}
