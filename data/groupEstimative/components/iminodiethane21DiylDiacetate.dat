/*--------------------------------*- Choupo -*-----------------------*\
  Component: iminodiethane-2,1-diyl diacetate  (C8H15NO4, CAS 65121-95-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iminodiethane21DiylDiacetate;
formula     C8H15NO4;
CAS         65121-95-1;
InChIKey    JYGXQTZBIRNFBN-UHFFFAOYSA-N;
MW          189.211;      // g/mol [origin=calculated method=formula-sum]
Tc          729.61;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.8729;      // -   [origin=predictive method=lee-kesler]
Tb          549.25;      // K   [origin=predictive method=joback]
HvapTb      54652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.224 0.73044 -0.0002708 -1.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH3COO; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group COO; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-acetyloxyethylamino)ethyl ethanoate" "ethanol, 2,2'-iminobis-, 1,1'-diacetate" "ethanol, 2,2'-iminobis-, diacetate (ester)" "2,2'-iminobisethyl diacetate" "2-(2-acetyloxyethylamino)ethyl acetate" );
gibbsFormation
{
    dHf_298   -789540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-514870.0
    phase     gas;
}
