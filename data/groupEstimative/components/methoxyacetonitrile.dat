/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxyacetonitrile  (C3H5NO, CAS 1738-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxyacetonitrile;
formula     C3H5NO;
CAS         1738-36-9;
InChIKey    QKPVEISEHYYHRH-UHFFFAOYSA-N;
MW          71.079;      // g/mol [origin=calculated method=formula-sum]
Tc          586.14;      // K   [origin=predictive method=joback]
Pc          41.731;      // bar [origin=predictive method=joback]
omega       0.3952;      // -   [origin=predictive method=lee-kesler]
Tb          392.74;      // K   [origin=predictive method=joback]
HvapTb      35160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.661 0.16042 2.6e-06 -3.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethanenitrile" "acetonitrile, methoxy-" "acetonitrile, 2-methoxy-" "2-methoxyacetonitrile" "2-methoxy-acetonitrile" );
gibbsFormation
{
    dHf_298   -72590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     290.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2560.0
    phase     gas;
}
