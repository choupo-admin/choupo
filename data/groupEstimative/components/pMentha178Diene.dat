/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-mentha-1(7),8-diene  (C10H16, CAS 499-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMentha178Diene;
formula     C10H16;
CAS         499-97-8;
InChIKey    GOQRXDTWKVYHJH-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          650.85;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.3113;      // -   [origin=predictive method=lee-kesler]
Tb          443.67;      // K   [origin=predictive method=joback]
HvapTb      37852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.2 0.93832 -0.000534 1.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylidene-4-prop-1-en-2-yl-cyclohexane" "trans-p-mentha-1(7),8-diene" "1-methylene-4-(1-methylvinyl)cyclohexane" "1-methylidene-4-prop-1-en-2-ylcyclohexane" "cyclohexane, 1-methylene-4-(1-methylethenyl)-" "cyclohexane,1-methylene-4-(1-methylethenyl)-" "p-mentha-1(7),8-diene(8ci); 1(7),8-p-menthadiene; 1-isopropenyl-4-methylenecyclohexane;pseudolimonen; pseudolimonene; y-limonene" );
gibbsFormation
{
    dHf_298   4470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190140.0
    phase     gas;
}
