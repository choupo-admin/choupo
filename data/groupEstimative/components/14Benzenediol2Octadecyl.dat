/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenediol, 2-octadecyl-  (C24H42O2, CAS 1706-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Benzenediol2Octadecyl;
formula     C24H42O2;
CAS         1706-70-3;
InChIKey    GDOYYIKTCYJSRI-UHFFFAOYSA-N;
MW          362.598;      // g/mol [origin=calculated method=formula-sum]
Tc          1148.11;      // K   [origin=predictive method=joback]
Pc          11.948;      // bar [origin=predictive method=joback]
omega       1.1151;      // -   [origin=predictive method=lee-kesler]
Tb          936.64;      // K   [origin=predictive method=joback]
HvapTb      97322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.673 2.51412 -0.00182572 5.661e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octadecylbenzene-1,4-diol" "hydroquinone, octadecyl-" "2-octadecylhydroquinone" "1,4-benzenediol,2-octadecyl-" "hydroquinone,octadecyl- (6ci,7ci,8ci); 2-(n-octadecyl)hydroquinone; 2-octadecylhydroquinone;octadecylhydroquinone" );
gibbsFormation
{
    dHf_298   -656780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1037.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45630.0
    phase     gas;
}
