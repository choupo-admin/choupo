/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1,1-dichloro-  (C3H6Cl2O, CAS 53894-19-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol11Dichloro;
formula     C3H6Cl2O;
CAS         53894-19-2;
InChIKey    ZOKHGHDRKCYWTH-UHFFFAOYSA-N;
MW          128.98;      // g/mol [origin=calculated method=formula-sum]
Tc          619.80;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       0.6658;      // -   [origin=predictive method=lee-kesler]
Tb          434.40;      // K   [origin=predictive method=joback]
HvapTb      46945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.87 0.34822 -0.000217 5.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)propan-2-ol" "agn-pc-00b8m8" "1,1-dichloro-2-propanol" );
standardThermochemistry
{
    dHf_298   -299520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191180.0
}
