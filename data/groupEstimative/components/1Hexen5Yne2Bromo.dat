/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexen-5-yne, 2-bromo-  (C6H7Br, CAS 72121-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexen5Yne2Bromo;
formula     C6H7Br;
CAS         72121-84-7;
InChIKey    RYWBCDINHDBAQL-UHFFFAOYSA-N;
MW          159.026;      // g/mol [origin=calculated method=formula-sum]
Tc          596.05;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.3034;      // -   [origin=predictive method=lee-kesler]
Tb          389.72;      // K   [origin=predictive method=joback]
HvapTb      34653.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.722 0.498 -0.00039513 1.3189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 1; } { group Br; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group tCH; count 1; } { group tC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylhex-1-en-5-yne" "2-bromo-1-hexen-5-yne" "2-bromohex-1-en-5-yne" );
standardThermochemistry
{
    dHf_298   266700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316320.0
}
