/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl stearate  (C24H40O2, CAS 637-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylStearate;
formula     C24H40O2;
CAS         637-55-8;
InChIKey    NUMNZKICGJJSHN-UHFFFAOYSA-N;
MW          360.582;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.50;      // K   [origin=predictive method=joback]
Pc          9.852;      // bar [origin=predictive method=joback]
omega       0.9005;      // -   [origin=predictive method=lee-kesler]
Tb          833.62;      // K   [origin=predictive method=joback]
HvapTb      78701.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.424 2.15012 -0.0012184 2.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl octadecanoate" "octadecanoic acid, phenyl ester" "stearic acid, phenyl ester" "stearic acid phenyl ester" "stearic acid, phenyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -619440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1035.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46760.0
    phase     gas;
}
