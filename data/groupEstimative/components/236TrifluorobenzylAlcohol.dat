/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,6-trifluorobenzyl alcohol  (C7H5F3O, CAS 114152-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        236TrifluorobenzylAlcohol;
formula     C7H5F3O;
CAS         114152-19-1;
InChIKey    DWOWBLURUYIVOU-UHFFFAOYSA-N;
MW          162.11;      // g/mol [origin=calculated method=formula-sum]
Tc          666.77;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.9005;      // -   [origin=predictive method=lee-kesler]
Tb          491.37;      // K   [origin=predictive method=joback]
HvapTb      49666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.081 0.4808 -0.00026668 4.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,6-tris(fluoranyl)phenyl]methanol" "(2,3,6-trifluorophenyl)methanol" "2, 3, 6-trifluorobenzyl alcohol" "(2,3,6-trifluorophenyl)methan-1-ol" "benzenemethanol,2,3,6-trifluoro-" "(2,3,6-trifluoro-phenyl)methanol" "(2,3,6-trifluoro-phenyl)-methanol" "2,3,6-trifluorobenzyl alcohol 97%" "n564" "(2,3,6-trifluorophenyl)methanol;2,3,6-trifluorobenzyl alcohol;" );
standardThermochemistry
{
    dHf_298   -726250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-629670.0
}
