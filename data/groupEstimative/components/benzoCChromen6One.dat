/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzo[c]chromen-6-one  (C13H8O2, CAS 2005-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoCChromen6One;
formula     C13H8O2;
CAS         2005-10-9;
InChIKey    TVKNXKLYVUVOCV-UHFFFAOYSA-N;
MW          196.205;      // g/mol [origin=calculated method=formula-sum]
Tc          857.54;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.6754;      // -   [origin=predictive method=lee-kesler]
Tb          617.18;      // K   [origin=predictive method=joback]
HvapTb      57521.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.55 1.1134 -0.00093192 3.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6h-dibenzo[b,d]pyran-6-one" "6h-dibenzo(b,d)pyran, 6-oxo-" "6h-dibenzo-(b,d)-pyran-6-one" "6h-dibenzo(b,d)pyran-6-one" "6h-dibenzo[b, 6-oxo-" "6h-benzo[c]chromen-6-one" "8-oxatricyclo[8.4.0.0^{2,7}]tetradeca-1(10),2(7),3,5,11,13-hexaen-9-one" );
standardThermochemistry
{
    dHf_298   -67190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58530.0
}
