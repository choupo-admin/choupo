/*--------------------------------*- Choupo -*-----------------------*\
  Component: aniline, n-allyl-o-tert-butyl-  (C13H19N, CAS 193338-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anilineNAllylOTertButyl;
formula     C13H19N;
CAS         193338-72-6;
InChIKey    JTNWLMYDECZVFY-UHFFFAOYSA-N;
MW          189.302;      // g/mol [origin=calculated method=formula-sum]
Tc          787.12;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.5644;      // -   [origin=predictive method=lee-kesler]
Tb          572.32;      // K   [origin=predictive method=joback]
HvapTb      51940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.209 1.28246 -0.00089086 2.439e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-n-prop-2-enyl-aniline" "2-tert-butyl-n-prop-2-enylaniline" "benzenamine, 2-(1,1-dimethylethyl)-n-2-propenyl-" );
gibbsFormation
{
    dHf_298   83560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341430.0
    phase     gas;
}
