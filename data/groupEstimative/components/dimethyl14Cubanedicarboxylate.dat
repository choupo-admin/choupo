/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 1,4-cubanedicarboxylate  (C12H12O4, CAS 29412-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl14Cubanedicarboxylate;
formula     C12H12O4;
CAS         29412-62-2;
InChIKey    OXBMFCGRQJNAOY-UHFFFAOYSA-N;
MW          220.224;      // g/mol [origin=calculated method=formula-sum]
Tc          784.60;      // K   [origin=predictive method=joback]
Pc          27.877;      // bar [origin=predictive method=joback]
omega       0.7835;      // -   [origin=predictive method=lee-kesler]
Tb          580.88;      // K   [origin=predictive method=joback]
HvapTb      52252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-254.73 2.36024 -0.0027646 1.2346e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 6; } { group C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 6; } { group C_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl cubane-1,4-dicarboxylate" "cubane-1,4-dicarboylic acid dimethyl ester" "bm440" "methyl 4-(methoxycarbonyl)pentacyclo[4.2.0.0<2,5>.0<3,8>.0<4,7>]octanecarboxyl ate" "pentacyclo[4.2.0.02,5.03,8.04,7]octane-1,4-dicarboxylicacid, 1,4-dimethyl ester" );
gibbsFormation
{
    dHf_298   -548990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     147.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216240.0
    phase     gas;
}
