/*--------------------------------*- Choupo -*-----------------------*\
  Component: .delta.(sup1,9)-2-octalone  (C10H14O, CAS 1196-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deltaSup192Octalone;
formula     C10H14O;
CAS         1196-55-0;
InChIKey    FOCKPZOFYCTNIA-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          778.88;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.4285;      // -   [origin=predictive method=lee-kesler]
Tb          535.59;      // K   [origin=predictive method=joback]
HvapTb      43878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.6 0.9599 -0.00050664 8.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4a,5,6,7,8-hexahydro-3h-naphthalen-2-one" "4,4a,5,6,7,8-hexahydronaphthalen-2(3h)-one" "2(3h)-naphthalenone, 4,4a,5,6,7,8-hexahydro-" ".delta.1,9-2-octalone" "4,5,6,7,8-hexahydronaphthalen-2(3h)-one" "2(3h)-naphthalenone,4a,5,6,7,8-hexahydro-" "4,4a,5,6,7,8-hexahydro-2(3h)-naphthalenone" "2(3h)-naphthalenone,4,4a,5,6,7,8-hexahydro-" );
gibbsFormation
{
    dHf_298   -199820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11870.0
    phase     gas;
}
