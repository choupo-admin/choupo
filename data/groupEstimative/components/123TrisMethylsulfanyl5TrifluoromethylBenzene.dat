/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-tris(methylsulfanyl)-5-(trifluoromethyl)benzene  (C10H11F3S3, CAS 65516-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123TrisMethylsulfanyl5TrifluoromethylBenzene;
formula     C10H11F3S3;
CAS         65516-85-0;
InChIKey    FQGDLFLKJDPASE-UHFFFAOYSA-N;
MW          284.372;      // g/mol [origin=calculated method=formula-sum]
Tc          916.36;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.6699;      // -   [origin=predictive method=lee-kesler]
Tb          670.94;      // K   [origin=predictive method=joback]
HvapTb      58820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.39 0.84083 -0.00045068 6.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group CF3; count 1; } { group CH3S; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group S; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,5-tris(methylthio)benzotrifluoride" "1,2,3-tri(methylthio)-5-(trifluoromethyl)benzene" );
standardThermochemistry
{
    dHf_298   -519080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-365390.0
}
