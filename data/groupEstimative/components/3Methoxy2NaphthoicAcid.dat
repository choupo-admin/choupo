/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-2-naphthoic acid  (C12H10O3, CAS 883-62-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy2NaphthoicAcid;
formula     C12H10O3;
CAS         883-62-5;
InChIKey    RTBQQRFTCVDODF-UHFFFAOYSA-N;
MW          202.209;      // g/mol [origin=calculated method=formula-sum]
Tc          935.27;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.9304;      // -   [origin=predictive method=lee-kesler]
Tb          697.71;      // K   [origin=predictive method=joback]
HvapTb      67120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.67 0.92982 -0.00062444 1.616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxynaphthalene-2-carboxylic acid" "2-methoxy-3-naphthoic acid" "2-naphthalenecarboxylic acid, 3-methoxy-" "2-naphthoic acid, 3-methoxy-" "2-naphthalenecarboxylicacid, 3-methoxy-" "3-methoxy-naphthalene-2-carboxylic acid" );
gibbsFormation
{
    dHf_298   -368840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198950.0
    phase     gas;
}
