/*--------------------------------*- Choupo -*-----------------------*\
  Component: acrolein  (C3H4O, CAS 107-02-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acrolein;
formula     C3H4O;
CAS         107-02-8;
InChIKey    HGINCPLSRVDWNT-UHFFFAOYSA-N;
MW          56.064;      // g/mol [origin=calculated method=formula-sum]
Tc          489.92;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.2868;      // -   [origin=predictive method=lee-kesler]
Tb          313.58;      // K   [origin=predictive method=joback]
HvapTb      28322.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.57 0.2433 -0.0001553 3.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enal" "acrylaldehyde" "acrylic aldehyde" "propenal" "allyl aldehyde" "ethylene aldehyde" "acraldehyde" "aqualin" "magnacide h" "acquinite" "aqualine" "slimicide" );
gibbsFormation
{
    dHf_298   -65400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     286.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37300.0
    phase     gas;
}
