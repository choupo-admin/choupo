/*--------------------------------*- Choupo -*-----------------------*\
  Component: bamipine  (C19H24N2, CAS 4945-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bamipine;
formula     C19H24N2;
CAS         4945-47-5;
InChIKey    VZSXTYKGYWISGQ-UHFFFAOYSA-N;
MW          280.415;      // g/mol [origin=calculated method=formula-sum]
Tc          966.78;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       0.7358;      // -   [origin=predictive method=lee-kesler]
Tb          727.84;      // K   [origin=predictive method=joback]
HvapTb      66783.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.059 2.03052 -0.0014248 3.802e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-n-phenyl-n-(phenylmethyl)piperidin-4-amine" "piperamine" "bamipinum [inn-latin]" "soventol" "4-(n-benzyl-n-phenylamino)-1-methylpiperidine" "piperidine, 4-(n-benzyl-n-phenylamino)-1-methyl-" "1-methyl-n-phenyl-n-(phenylmethyl)-4-piperidinamine" "4-piperidinamine, 1-methyl-n-phenyl-n-(phenylmethyl)-" "n-phenyl-n-benzyl-4-amino-1-methyl-piperidin [german]" "bamipina" "bamipinum" "bamipine (inn)" );
standardThermochemistry
{
    dHf_298   233110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=592030.0
}
