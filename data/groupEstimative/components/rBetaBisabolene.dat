/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-beta-bisabolene  (C15H24, CAS 495-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rBetaBisabolene;
formula     C15H24;
CAS         495-61-4;
InChIKey    XZRVRYFILCSYSP-HNNXBMFYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          774.03;      // K   [origin=predictive method=joback]
Pc          18.452;      // bar [origin=predictive method=joback]
omega       0.4917;      // -   [origin=predictive method=lee-kesler]
Tb          567.09;      // K   [origin=predictive method=joback]
HvapTb      49815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.828 1.43526 -0.00090474 2.246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r)-1-methyl-4-(6-methylhepta-1,5-dien-2-yl)cyclohexene" "1-methyl-4-(5-methyl-1-methylenehex-4-en-1-yl)cyclohexene" "(1r)-bisabola-4,7(11),10(15)-triene" "cyclohexene, 1-methyl-4-(5-methyl-1-methylene-4-hexenyl)-" "(4r)-1-methyl-4-(5-methyl-1-methylenehex-4-en-1-yl)cyclohexene" "6-methyl-2-[(1r)-4-methyl-1-cyclohex-3-enyl]hepta-1,5-diene" "(1r)-bisabola-4,7(11),10(15)-triene (4r)-1-methyl-4-(5-methyl-1-methylenehex-4-en-1-yl)cyclohexene" );
gibbsFormation
{
    dHf_298   -29230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=271160.0
    phase     gas;
}
