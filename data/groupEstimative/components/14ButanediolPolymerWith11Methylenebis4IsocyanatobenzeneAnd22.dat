\*---------------------------------------------------------------------------*/

name        14ButanediolPolymerWith11Methylenebis4IsocyanatobenzeneAnd22;
formula     C23H30N2O6S;
CAS         67846-24-6;
InChIKey    WIFVWHBOVJDFCT-UHFFFAOYSA-N;
MW          462.561;      // g/mol [origin=calculated method=formula-sum]
Tc          1757.56;      // K   [origin=predictive method=joback]
Pc          16.838;      // bar [origin=predictive method=joback]
omega       0.8503;      // -   [origin=predictive method=lee-kesler]
Tb          1362.80;      // K   [origin=predictive method=joback]
HvapTb      165853.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 7; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 4; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 9; } { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 4; } { group dO_oth; count 2; } { group Nd; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;2-(2-hydroxyethylsulfanyl)ethanol;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "butane-1,4-diol; 2-(2-hydroxyethylsulfanyl)ethanol; 1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" );
