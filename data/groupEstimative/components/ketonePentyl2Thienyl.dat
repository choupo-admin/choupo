/*--------------------------------*- Choupo -*-----------------------*\
  Component: ketone, pentyl 2-thienyl  (C10H14OS, CAS 26447-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ketonePentyl2Thienyl;
formula     C10H14OS;
CAS         26447-67-6;
InChIKey    CVDZQNUYYOLFOO-UHFFFAOYSA-N;
MW          182.281;      // g/mol [origin=calculated method=formula-sum]
Tc          770.46;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       0.6029;      // -   [origin=predictive method=lee-kesler]
Tb          553.35;      // K   [origin=predictive method=joback]
HvapTb      52224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.586 0.92693 -0.00061052 1.5876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2CO; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-thiophen-2-ylhexan-1-one" "1-hexanone, 1-(2-thienyl)-" "1-(2-thienyl)hexan-1-one" "2-hexanoylthiophene" );
gibbsFormation
{
    dHf_298   -132140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38810.0
    phase     gas;
}
