/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-3-methyl-1-pentene  (C8H16, CAS 3404-67-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl3Methyl1Pentene;
formula     C8H16;
CAS         3404-67-9;
InChIKey    YXLCVBVDFKWWRW-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          552.90;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.3225;      // -   [origin=predictive method=lee-kesler]
Tb          378.76;      // K   [origin=predictive method=joback]
HvapTb      32424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.748 0.74966 -0.0004398 1.027e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-methylidene-hexane" "hexane, 3-methyl-4-methylene-" "3-methyl-4-methylenehexane" "2-ethyl-3-methylpentene-1" "3-methyl-4-methylidenehexane" );
gibbsFormation
{
    dHf_298   -98090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93330.0
    phase     gas;
}
