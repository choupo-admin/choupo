/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethenyl-2-methyl-benzene;2-methylpropyl 2-methylprop-2-enoate;octadecyl 2-methylprop-2-enoate  (C39H66O4, CAS 53879-74-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethenyl2MethylBenzene2Methylpropyl2Methylprop2EnoateOctadec;
formula     C39H66O4;
CAS         53879-74-6;
InChIKey    SIMCIWVUKKYWNA-UHFFFAOYSA-N;
MW          598.953;      // g/mol [origin=calculated method=formula-sum]
Tc          1575.63;      // K   [origin=predictive method=joback]
Pc          4.589;      // bar [origin=predictive method=joback]
omega       -0.0018;      // -   [origin=predictive method=lee-kesler]
Tb          1232.18;      // K   [origin=predictive method=joback]
HvapTb      118510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.248 2.99422 -0.00111966 -3.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 18; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 18; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-2-methyl-benzene; 2-methylpropyl 2-methylprop-2-enoate; octadecyl 2-methylprop-2-enoate" "1-ethenyl-2-methylbenzene; 2-methylpropyl 2-methylprop-2-enoate; octadecyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-methylpropyl ester, polymer with ethenylmethylbenzene and octadecyl 2-methyl-2-propenoate;iso-butyl methacrylate, vinyltoluene, stearyl methacrylate polymer" );
gibbsFormation
{
    dHf_298   -1129600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1848.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206000.0
    phase     gas;
}
