/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-thiabicyclo(4.2.1)nona-2,4-diene  (C8H10S, CAS 50669-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Thiabicyclo421Nona24Diene;
formula     C8H10S;
CAS         50669-04-0;
InChIKey    HLEWYYGGPXROGP-UHFFFAOYSA-N;
MW          138.228;      // g/mol [origin=calculated method=formula-sum]
Tc          695.76;      // K   [origin=predictive method=joback]
Pc          39.805;      // bar [origin=predictive method=joback]
omega       0.2811;      // -   [origin=predictive method=lee-kesler]
Tb          455.08;      // K   [origin=predictive method=joback]
HvapTb      40140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.85 0.93921 -0.00070586 2.101e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 2; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-thiabicyclo[4.2.1]nona-2,4-diene" "9-thiabicylo[4.2.1]nona-2,4-diene" );
gibbsFormation
{
    dHf_298   79490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201460.0
    phase     gas;
}
