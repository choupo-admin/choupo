/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentan-2-yl(pentyl)amine  (C10H23N, CAS 61361-18-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentan2YlPentylAmine;
formula     C10H23N;
CAS         61361-18-0;
InChIKey    ZHGJYFYOVKKNQY-UHFFFAOYSA-N;
MW          157.301;      // g/mol [origin=calculated method=formula-sum]
Tc          647.96;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.6180;      // -   [origin=predictive method=lee-kesler]
Tb          478.13;      // K   [origin=predictive method=joback]
HvapTb      43902.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.094 1.03596 -0.000572 1.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-pentan-2-ylpentan-1-amine" "n-(pentan-2-yl)pentan-1-amine" "1-pentanamine, n-(2-methylbutyl)-" "n-(2-methylbutyl)-1-pentanamine" );
standardThermochemistry
{
    dHf_298   -201540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120270.0
}
