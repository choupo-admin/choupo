/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyltridecylamine  (C14H31N, CAS 45165-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyltridecylamine;
formula     C14H31N;
CAS         45165-81-9;
InChIKey    XMRPIOZXPHTSCE-UHFFFAOYSA-N;
MW          213.409;      // g/mol [origin=calculated method=formula-sum]
Tc          733.14;      // K   [origin=predictive method=joback]
Pc          15.391;      // bar [origin=predictive method=joback]
omega       0.8135;      // -   [origin=predictive method=lee-kesler]
Tb          570.09;      // K   [origin=predictive method=joback]
HvapTb      53194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.048 1.41004 -0.0007864 1.659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyltridecan-1-amine" );
standardThermochemistry
{
    dHf_298   -278820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     742.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156390.0
}
