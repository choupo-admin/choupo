/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclohexylamine  (C12H23N, CAS 101-83-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclohexylamine;
formula     C12H23N;
CAS         101-83-7;
InChIKey    XBPCUCUWBYBCDP-UHFFFAOYSA-N;
MW          181.323;      // g/mol [origin=calculated method=formula-sum]
Tc          794.88;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.4802;      // -   [origin=predictive method=lee-kesler]
Tb          563.43;      // K   [origin=predictive method=joback]
HvapTb      49600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.44 1.4642 -0.0008396 1.613e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-cyclohexylcyclohexanamine" "cyclohexanamine, n-cyclohexyl-" "dicha" "n,n-dicyclohexylamine" "dodecahydrodiphenylamine" "dcha" "dicyklohexylamin" "n-cyclohexyl-cyclohexylamine" "n,n-diclohexylamine" "dicyclohexylammonium" "dicyclohexylamine nitrite" "di-cha" );
standardThermochemistry
{
    dHf_298   -128900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188450.0
}
