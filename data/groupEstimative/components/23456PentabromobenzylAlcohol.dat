/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5,6-pentabromobenzyl alcohol  (C7H3Br5O, CAS 79415-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23456PentabromobenzylAlcohol;
formula     C7H3Br5O;
CAS         79415-41-1;
InChIKey    KKWHDMUCBWSKGL-UHFFFAOYSA-N;
MW          502.62;      // g/mol [origin=calculated method=formula-sum]
Tc          1097.01;      // K   [origin=predictive method=joback]
Pc          69.793;      // bar [origin=predictive method=joback]
omega       1.5777;      // -   [origin=predictive method=lee-kesler]
Tb          834.32;      // K   [origin=predictive method=joback]
HvapTb      85616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (80.361 0.5174 -0.0004404 1.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group Br; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dC_ring; count 6; } { group Br; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,4,5,6-pentakis(bromanyl)phenyl]methanol" "(2,3,4,5,6-pentabromophenyl)methanol" "kkwhdmucbwskgl-uhfffaoysa-" "benzenemethanol,2,3,4,5,6-pentabromo-" );
gibbsFormation
{
    dHf_298   -29210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7100.0
    phase     gas;
}
