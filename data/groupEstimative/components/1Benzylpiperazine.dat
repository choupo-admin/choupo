/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzylpiperazine  (C11H16N2, CAS 2759-28-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzylpiperazine;
formula     C11H16N2;
CAS         2759-28-6;
InChIKey    IQXXEPZFOOTTBA-UHFFFAOYSA-N;
MW          176.263;      // g/mol [origin=calculated method=formula-sum]
Tc          795.82;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.5477;      // -   [origin=predictive method=lee-kesler]
Tb          558.90;      // K   [origin=predictive method=joback]
HvapTb      51723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.209 1.2386 -0.0008406 2.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(phenylmethyl)piperazine" "benzylpiperazine" "n-benzylpiperazine" "4-benzylpiperazine" "piperazine, 1-benzyl-" "1-benzyl-piperazine" "piperazine, 1-(phenylmethyl)-" "piperazine, polymer-bound" "1-benzyl-piperazine hydrochloride" "bzp" "1- benzylpiperazine" "1-benzyl-piperazine 2hcl salt" );
gibbsFormation
{
    dHf_298   152320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=396900.0
    phase     gas;
}
