/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-benzylidenefluorene  (C20H14, CAS 1836-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Benzylidenefluorene;
formula     C20H14;
CAS         1836-87-9;
InChIKey    RMQMLYMBZGDKBY-UHFFFAOYSA-N;
MW          254.332;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.63;      // K   [origin=predictive method=joback]
Pc          24.195;      // bar [origin=predictive method=joback]
omega       0.7018;      // -   [origin=predictive method=lee-kesler]
Tb          756.71;      // K   [origin=predictive method=joback]
HvapTb      68931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.25 1.6672 -0.00136062 4.417e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 13; } { group AC; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-(phenylmethylidene)fluorene" "fluorene, 9-benzylidene-" "9h-fluorene, 9-(phenylmethylene)-" "9-(phenylmethylene)fluorene" "benzalfluorene" "9-benzylidene-9h-fluorene" "1-phenyl-2-biphenyleneethylene" "9h-fluorene,9-(phenylmethylene)-" );
standardThermochemistry
{
    dHf_298   412010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=573610.0
}
