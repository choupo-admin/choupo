/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-sec-butylpyridine  (C9H13N, CAS 25224-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3SecButylpyridine;
formula     C9H13N;
CAS         25224-14-0;
InChIKey    UEOMUYCGCCSHAP-UHFFFAOYSA-N;
MW          135.21;      // g/mol [origin=calculated method=formula-sum]
Tc          708.96;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.4027;      // -   [origin=predictive method=lee-kesler]
Tb          485.46;      // K   [origin=predictive method=joback]
HvapTb      43726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.819 0.8196 -0.00050946 1.227e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butan-2-ylpyridine" "pyridine, 3-(1-methylpropyl)-" "3-(butan-2-yl)pyridine" "agn-pc-00pnt7" );
gibbsFormation
{
    dHf_298   34950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=211920.0
    phase     gas;
}
