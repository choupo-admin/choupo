/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-benzenedicarboxylic acid,monodecyl ester  (C18H26O4, CAS 24539-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BenzenedicarboxylicAcidMonodecylEster;
formula     C18H26O4;
CAS         24539-60-4;
InChIKey    FEFCILUKYGHITK-UHFFFAOYSA-N;
MW          306.402;      // g/mol [origin=calculated method=formula-sum]
Tc          1052.26;      // K   [origin=predictive method=joback]
Pc          15.549;      // bar [origin=predictive method=joback]
omega       1.1768;      // -   [origin=predictive method=lee-kesler]
Tb          846.83;      // K   [origin=predictive method=joback]
HvapTb      83171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.071 1.57142 -0.00089756 1.745e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-decoxycarbonylbenzoic acid" "1,2-benzenedicarboxylic acid, 1-decyl ester" "1,2-benzenedicarboxylic acid, monodecyl ester" "decyl hydrogen phthalate" "2-(decyloxycarbonyl)benzoic acid" "2-[(decyloxy)carbonyl]benzoic acid" "1,2-benzenedicarboxylicacid, 1-decyl ester" "1,2-benzenedicarboxylicacid, monodecyl ester (9ci); phthalic acid, monodecyl ester (8ci); decylhydrogen phthalate; monodecyl phthalate" );
gibbsFormation
{
    dHf_298   -857340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     848.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-450820.0
    phase     gas;
}
