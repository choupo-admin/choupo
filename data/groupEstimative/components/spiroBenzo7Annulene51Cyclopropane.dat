/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[benzo[7]annulene-5,1'-cyclopropane]  (C13H12, CAS 29150-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiroBenzo7Annulene51Cyclopropane;
formula     C13H12;
CAS         29150-13-8;
InChIKey    MQRCXKKUJOEQKF-UHFFFAOYSA-N;
MW          168.239;      // g/mol [origin=calculated method=formula-sum]
Tc          803.35;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.4117;      // -   [origin=predictive method=lee-kesler]
Tb          549.68;      // K   [origin=predictive method=joback]
HvapTb      47210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-174.51 1.599 -0.00160412 6.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[7h-benzocycloheptene-7,1'cyclopropane]" "spiro(7h-benzocycloheptene-7,1'cyclopropane)" );
gibbsFormation
{
    dHf_298   203990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=332900.0
    phase     gas;
}
