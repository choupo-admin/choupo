/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1,3-dioxolan-2-yl)pyridine  (C8H9NO2, CAS 5693-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        213Dioxolan2YlPyridine;
formula     C8H9NO2;
CAS         5693-54-9;
InChIKey    FPSCKCFSKOKOHC-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          787.15;      // K   [origin=predictive method=joback]
Pc          44.922;      // bar [origin=predictive method=joback]
omega       0.4637;      // -   [origin=predictive method=lee-kesler]
Tb          532.20;      // K   [origin=predictive method=joback]
HvapTb      51165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.07 0.84436 -0.00055146 1.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group FCH2O; count 2; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "picolinaldehyde, cyclic ethylene acetal" "pyridine, 2-(1,3-dioxolan-2-yl)-" "2-(1,3-dioxalan-2-yl)pyridine" "pyridine,3-dioxolan-2-yl)-" "2-pyridinecarboxaldehyde,2-ethanediyl acetal" "2-pyridinecarboxaldehyde, cyclic 1,2-ethanediyl acetal" );
standardThermochemistry
{
    dHf_298   -142650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     220.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70250.0
}
