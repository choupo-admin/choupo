/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenenitrile, polymer with diethenylbenzene and ethenylethylbenzene  (C23H25N, CAS 9078-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenenitrilePolymerWithDiethenylbenzeneAndEthenylethylben;
formula     C23H25N;
CAS         9078-84-6;
InChIKey    PPUVMUCBAGCZLO-UHFFFAOYSA-N;
MW          315.46;      // g/mol [origin=calculated method=formula-sum]
Tc          1122.99;      // K   [origin=predictive method=joback]
Pc          12.513;      // bar [origin=predictive method=joback]
omega       0.7416;      // -   [origin=predictive method=lee-kesler]
Tb          880.76;      // K   [origin=predictive method=joback]
HvapTb      81054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.441 1.35442 -0.00038672 -1.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 3; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group ACRY; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 4; } { group dCH; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(ethenyl)benzene;1-ethenyl-2-ethyl-benzene;prop-2-enenitrile" "acrylonitrile, polymer with divinylbenzene and ethylvinylbenzene" );
gibbsFormation
{
    dHf_298   375430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1029.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=623360.0
    phase     gas;
}
