/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethynyloxy radical  (C2HO, CAS 51095-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        ethynyloxyRadical;
formula     C2HO;
CAS         51095-15-9;
InChIKey    QEJQAPYSVNHDJF-UHFFFAOYSA-N;
role        radical;
MW          41.029;      // g/mol [origin=calculated method=formula-sum]
Tc          372.57;      // K   [origin=predictive method=joback]
Pc          75.746;      // bar [origin=predictive method=joback]
omega       0.1965;      // -   [origin=predictive method=lee-kesler]
Tb          224.28;      // K   [origin=predictive method=joback]
HvapTb      25666.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.26 0.2226 -0.00027563 1.2179e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group tCH; count 1; } { group tC; count 1; } { group dO_oth; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "$l^{1}-oxidanylethyne" "ethynyloxy" "hcco" );
standardThermochemistry
{
    dHf_298   15490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     262.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9420.0
}
