/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isocyanato-3-(trifluoromethyl)benzene  (C8H4F3NO, CAS 329-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isocyanato3TrifluoromethylBenzene;
formula     C8H4F3NO;
CAS         329-01-1;
InChIKey    SXJYSIBLFGQAND-UHFFFAOYSA-N;
MW          187.12;      // g/mol [origin=calculated method=formula-sum]
Tc          677.34;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.5435;      // -   [origin=predictive method=lee-kesler]
Tb          475.55;      // K   [origin=predictive method=joback]
HvapTb      42125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group C; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(trifluoromethyl)phenyl isocyanate" "benzene, 1-isocyanato-3-(trifluoromethyl)-" "isocyanobenzotrifluoride" "a,a,a-trifluoro-m-tolyl isocyanate" "alpha,alpha,alpha-trifluoro-m-tolyl isocyanate" "3-isocyanatobenzotrifluoride" "3-trifluoromethylphenyl isocyanate" "isocyanic acid, (m-trifluoromethylphenyl) ester" "alpha,alpha,alpha-trifluoro-3-tolyl isocyanate" "isocyanic acid 3-(trifluoromethyl)phenyl ester" "(alpha,alpha,alpha-trifluoro-m-tolyl) isocyanate" "isocyanic acid, alpha,alpha,alpha-trifluoro-m-tolyl ester" );
