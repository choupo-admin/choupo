/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2,2-dimethoxypropane  (C5H11BrO2, CAS 126-38-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo22Dimethoxypropane;
formula     C5H11BrO2;
CAS         126-38-5;
InChIKey    SGTITUFGCGGICE-UHFFFAOYSA-N;
MW          183.045;      // g/mol [origin=calculated method=formula-sum]
Tc          618.79;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.4270;      // -   [origin=predictive method=lee-kesler]
Tb          421.77;      // K   [origin=predictive method=joback]
HvapTb      36683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.061 0.51646 -0.0002694 4.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group CH3O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Br; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2,2-dimethoxy-propane" "propane,1-bromo-2,2-dimethoxy-" "propane, 1-bromo-2,2-dimethoxy-" "bromoacetone dimethyl ketal" "bromoacetone dimethyl acetal" "2-propanone,bromo-, dimethyl acetal (6ci,7ci,8ci);1-bromo-2,2-dimethoxypropane;bromoacetone dimethyl ketal;1-bromo-2,2-dimethoxypropane;propane, 1-bromo-2,2-dimethoxy-;" );
standardThermochemistry
{
    dHf_298   -393390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201620.0
}
