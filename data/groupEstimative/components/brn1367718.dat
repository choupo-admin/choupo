  Component: brn 1367718  (C12H21NS, CAS 34548-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1367718;
formula     C12H21NS;
CAS         34548-72-6;
InChIKey    YWHHQMYICWAHJH-UHFFFAOYSA-N;
MW          211.367;      // g/mol [origin=calculated method=formula-sum]
Tc          764.71;      // K   [origin=predictive method=joback]
Pc          22.849;      // bar [origin=predictive method=joback]
omega       0.5651;      // -   [origin=predictive method=lee-kesler]
Tb          556.80;      // K   [origin=predictive method=joback]
HvapTb      51197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.818 1.28069 -0.00085702 2.28e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group CH3N; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group N; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,3-trimethyl-2-thiophen-2-yl-pentan-1-amine" "n,n,3-trimethyl-2-(thiophen-2-yl)pentan-1-amine" "thiophene, 2-(1-(sec-butyl)-2-(dimethylamino)ethyl)-" "2-thiopheneethanamine, n,n-dimethyl-beta-(1-methylpropyl)-" "n,n,3-trimethyl-2-thiophen-2-ylpentan-1-amine" "2-(1-sec-butyl-2-(dimethylamino)ethyl) thiophene" );
gibbsFormation
{
    dHf_298   -3870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290470.0
    phase     gas;
}
