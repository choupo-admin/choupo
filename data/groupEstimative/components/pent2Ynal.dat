/*--------------------------------*- Choupo -*-----------------------*\
  Component: pent-2-ynal  (C5H6O, CAS 55136-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pent2Ynal;
formula     C5H6O;
CAS         55136-52-2;
InChIKey    VLTOSDJJTWPWLS-UHFFFAOYSA-N;
MW          82.102;      // g/mol [origin=calculated method=formula-sum]
Tc          571.20;      // K   [origin=predictive method=joback]
Pc          46.657;      // bar [origin=predictive method=joback]
omega       0.3143;      // -   [origin=predictive method=lee-kesler]
Tb          371.66;      // K   [origin=predictive method=joback]
HvapTb      35596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.301 0.30352 -0.00014906 2.518e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CHO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tC; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentynal" );
standardThermochemistry
{
    dHf_298   40190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94500.0
}
