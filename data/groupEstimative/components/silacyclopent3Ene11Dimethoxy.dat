/*--------------------------------*- Choupo -*-----------------------*\
  Component: silacyclopent-3-ene,1,1-dimethoxy-  (C6H12O2Si, CAS 61667-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H12O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silacyclopent3Ene11Dimethoxy;
formula     C6H12O2Si;
CAS         61667-33-2;
InChIKey    RWBCRMOSJZITFJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          144.245;      // g/mol [origin=calculated method=formula-sum]
Tc          594.75;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.3107;      // -   [origin=predictive method=lee-kesler]
Tb          397.96;      // K   [origin=predictive method=joback]
HvapTb      34750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.73 0.35304 0.00011772 -1.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH3O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxy-2,5-dihydrosilole" "cyclopent-3-ene, 1,1-dimethoxy-1-sila-" "1,1-dimethoxy-2,5-dihydro-1h-silole" );
standardThermochemistry
{
    dHf_298   -398470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228800.0
}
