/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylbutyl dichloroacetate  (C7H12Cl2O2, CAS 90380-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylbutylDichloroacetate;
formula     C7H12Cl2O2;
CAS         90380-55-5;
InChIKey    BSBLGRPLLFXELO-UHFFFAOYSA-N;
MW          199.071;      // g/mol [origin=calculated method=formula-sum]
Tc          685.34;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.5530;      // -   [origin=predictive method=lee-kesler]
Tb          491.96;      // K   [origin=predictive method=joback]
HvapTb      46577.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.352 0.63944 -0.0003096 3.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentan-2-yl 2,2-bis(chloranyl)ethanoate" "dichloroacetic acid, 2-pentyl ester" "pentan-2-yl 2,2-dichloroacetate" "acetic acid, dichloro-, 1-methylbutyl ester" );
standardThermochemistry
{
    dHf_298   -547130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-331050.0
}
