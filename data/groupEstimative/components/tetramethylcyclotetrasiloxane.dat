/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethylcyclotetrasiloxane  (C4H12O4Si4, CAS 2370-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H12O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetramethylcyclotetrasiloxane;
formula     C4H12O4Si4;
CAS         2370-88-9;
InChIKey    WZJUBBHODHNQPW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          236.476;      // g/mol [origin=calculated method=formula-sum]
Tc          625.68;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       0.2862;      // -   [origin=predictive method=lee-kesler]
Tb          417.40;      // K   [origin=predictive method=joback]
HvapTb      43520.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (88.87 0.12728 0.0004622 -3.352e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 4; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6,8-tetramethyl-1,3,5,7,2$l^{3},4$l^{3},6$l^{3},8$l^{3}-tetraoxatetrasilocane" "2,4,6,8-tetramethylcyclotetrasiloxane" "cyclotetrasiloxane, 2,4,6,8-tetramethyl-" "1,3,5,7-tetramethylcyclotetrasiloxane" "tmcts" "agn-pc-0coh4e" "agn-pc-0coh4i" "agn-pc-0coh4k" "1,2,5,7-tetramethylcyclotetrasiloxane" "2,4,6,8-tetramethyl-1,3,5,7,2" "2,4,6,8-tetramethyl-1,3,5,7,2,4,6,8$l^{3}-tetraoxatetrasilocane" "2,4,6,8-tetramethyl-1,3,5,7,2,4$l^{3},6$l^{3},8$l^{3}-tetraoxatetrasilocane" );
standardThermochemistry
{
    dHf_298   -790150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-514840.0
}
