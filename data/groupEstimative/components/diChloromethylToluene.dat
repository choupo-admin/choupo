/*--------------------------------*- Choupo -*-----------------------*\
  Component: di(chloromethyl)toluene  (C9H10Cl2, CAS 2735-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diChloromethylToluene;
formula     C9H10Cl2;
CAS         2735-05-9;
InChIKey    HKCWYAWNOIYUAS-UHFFFAOYSA-N;
MW          189.079;      // g/mol [origin=calculated method=formula-sum]
Tc          738.84;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.4560;      // -   [origin=predictive method=lee-kesler]
Tb          517.02;      // K   [origin=predictive method=joback]
HvapTb      47998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.182 0.67452 -0.00040372 8.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloromethyl)-1-methyl-benzene" "2,4-bis(chloromethyl)toluene" "benzene, 2,4-bis(chloromethyl)-1-methyl-" "2,4-bis(chloromethyl)-1-methylbenzene" "di(chloromethyl) toluene" "benzene,2,4-bis(chloromethyl)-1-methyl-" "1-methyl-2,4-bis(chloromethyl)benzene;2,4-bis(chloromethyl)toluene" );
gibbsFormation
{
    dHf_298   -46980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94190.0
    phase     gas;
}
