/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanone, 2,2-diphenyl-  (C18H18O, CAS 22612-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanone22Diphenyl;
formula     C18H18O;
CAS         22612-62-0;
InChIKey    VVZQVFCTDWFOOD-UHFFFAOYSA-N;
MW          250.341;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.63;      // K   [origin=predictive method=joback]
Pc          25.025;      // bar [origin=predictive method=joback]
omega       0.6038;      // -   [origin=predictive method=lee-kesler]
Tb          752.41;      // K   [origin=predictive method=joback]
HvapTb      63739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-160.45 1.8017 -0.0013874 4.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diphenylcyclohexan-1-one" "2,2-diphenylcyclohexanone" "cyclohexanone,2-diphenyl-" "2,2-diphenyl-cyclohexan-1-one" );
gibbsFormation
{
    dHf_298   -9930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221870.0
    phase     gas;
}
