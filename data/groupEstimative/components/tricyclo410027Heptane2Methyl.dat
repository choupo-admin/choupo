/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.1.0.02,7]heptane,2-methyl-  (C8H12, CAS 40391-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo410027Heptane2Methyl;
formula     C8H12;
CAS         40391-49-9;
InChIKey    FHTIMEMQMNAAPH-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          591.89;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.2872;      // -   [origin=predictive method=lee-kesler]
Tb          389.89;      // K   [origin=predictive method=joback]
HvapTb      31337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-188.92 1.50112 -0.001642 7.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 3; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(4.1.0.02,7)heptane, 2-methyl-" );
standardThermochemistry
{
    dHf_298   17170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     184.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209730.0
}
