/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-2-hexenyl formate  (C7H12O2, CAS 53398-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H12O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trans2HexenylFormate;
formula     C7H12O2;
CAS         53398-78-0;
InChIKey    SLWYMCAVYPZTRN-SNAWJCMRSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          509.58;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.2616;      // -   [origin=predictive method=lee-kesler]
Tb          340.34;      // K   [origin=predictive method=joback]
HvapTb      28761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.157 0.69692 -0.0005938 2.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-hex-2-enyl] methanoate" "(e)-2-hexenyl formate" "2-hexen-1-ol, formate, (2e)-" "2-hexen-1-ol, 1-formate, (2e)-" "(z)-2-hexenyl formate" "(e)-hex-2-enyl formate" "[(e)-hex-2-enyl] formate" "3-methylpentyl ethylphosphonofluoridoate" );
gibbsFormation
{
    dHf_298   5860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132240.0
    phase     gas;
}
