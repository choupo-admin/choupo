/*--------------------------------*- Choupo -*-----------------------*\
  Component: glutaconic acid  (C5H6O4, CAS 628-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glutaconicAcid;
formula     C5H6O4;
CAS         628-48-8;
InChIKey    XVOUMQNXTGKGMA-OWOJBTEDSA-N;
MW          130.099;      // g/mol [origin=calculated method=formula-sum]
Tc          824.74;      // K   [origin=predictive method=joback]
Pc          46.403;      // bar [origin=predictive method=joback]
omega       1.0441;      // -   [origin=predictive method=lee-kesler]
Tb          609.18;      // K   [origin=predictive method=joback]
HvapTb      61010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.639 0.6004 -0.0004772 1.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-pent-2-enedioic acid" "2-pentenedioic acid" "trans-glutaconic acid" "pent-2-enedioic acid" "trans-glutaconate" "(e)-glutaconate" "(e)-glutaconic acid" "pent-2-ene-1,5-dioic acid" "(e)-2-pentenedioic acid" "(2e)-pent-2-enedioic acid" "glutaconate" "pentenedioate" );
gibbsFormation
{
    dHf_298   -729850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-616380.0
    phase     gas;
}
