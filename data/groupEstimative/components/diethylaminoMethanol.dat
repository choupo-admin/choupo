/*--------------------------------*- Choupo -*-----------------------*\
  Component: (diethylamino)methanol  (C5H13NO, CAS 15931-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylaminoMethanol;
formula     C5H13NO;
CAS         15931-59-6;
InChIKey    NTMDBTSKNAXHGK-UHFFFAOYSA-N;
MW          103.165;      // g/mol [origin=calculated method=formula-sum]
Tc          579.16;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       0.7821;      // -   [origin=predictive method=lee-kesler]
Tb          418.62;      // K   [origin=predictive method=joback]
HvapTb      45446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.057 0.63674 -0.0003912 9.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethylaminomethanol" "methanol, (diethylamino)-" "methanol, 1-(diethylamino)-" "methanol,1-(diethylamino)-" "methanol,(diethylamino)- (8ci,9ci); (diethylamino)methanol" );
standardThermochemistry
{
    dHf_298   -231230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34820.0
}
