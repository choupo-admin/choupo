/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-bis(dimethylamino)fluorene  (C17H20N2, CAS 86943-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45BisDimethylaminoFluorene;
formula     C17H20N2;
CAS         86943-85-3;
InChIKey    BBIVISPSERUSIC-UHFFFAOYSA-N;
MW          252.361;      // g/mol [origin=calculated method=formula-sum]
Tc          912.58;      // K   [origin=predictive method=joback]
Pc          21.856;      // bar [origin=predictive method=joback]
omega       0.8006;      // -   [origin=predictive method=lee-kesler]
Tb          689.59;      // K   [origin=predictive method=joback]
HvapTb      64600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.5 1.66748 -0.00128884 4.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 5; } { group ACCH2; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n4,n4,n5,n5-tetramethyl-9h-fluorene-4,5-diamine" "n,n,n',n'-tetramethyl-9h-fluorene-4,5-diamine" "4-n,4-n,5-n,5-n-tetramethyl-9h-fluorene-4,5-diamine" );
standardThermochemistry
{
    dHf_298   273490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=592780.0
}
