/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1,3-dithiane  (C5H10S2, CAS 52884-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl13Dithiane;
formula     C5H10S2;
CAS         52884-63-6;
InChIKey    HAXRZEWLQORZFV-UHFFFAOYSA-N;
MW          134.255;      // g/mol [origin=calculated method=formula-sum]
Tc          672.34;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       0.2284;      // -   [origin=predictive method=lee-kesler]
Tb          429.21;      // K   [origin=predictive method=joback]
HvapTb      38777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.62 0.62974 -0.0003666 7.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95390.0
    phase     gas;
}
