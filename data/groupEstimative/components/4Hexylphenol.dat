/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexylphenol  (C12H18O, CAS 2446-69-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexylphenol;
formula     C12H18O;
CAS         2446-69-7;
InChIKey    SZWBRVPZWJYIHI-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          792.64;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       0.7196;      // -   [origin=predictive method=lee-kesler]
Tb          581.46;      // K   [origin=predictive method=joback]
HvapTb      57596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.845 1.21952 -0.00091656 2.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-n-hexylphenol" "phenol, 4-hexyl-" "p-n-hexylphenol" "p-hexylphenol" "phenol, p-hexyl-" "1-(4-hydroxyphenyl)hexane" );
standardThermochemistry
{
    dHf_298   -231790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7950.0
}
