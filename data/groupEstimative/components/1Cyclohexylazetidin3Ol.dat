/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexylazetidin-3-ol  (C9H17NO, CAS 13156-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexylazetidin3Ol;
formula     C9H17NO;
CAS         13156-01-9;
InChIKey    GPNSPIGRLLHVCN-UHFFFAOYSA-N;
MW          155.241;      // g/mol [origin=calculated method=formula-sum]
Tc          736.31;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.8078;      // -   [origin=predictive method=lee-kesler]
Tb          536.43;      // K   [origin=predictive method=joback]
HvapTb      54692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.54 1.2897 -0.00091 2.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azetidinol, 1-cyclohexyl-" "1-cyclohexyl-3-azetidinol" );
standardThermochemistry
{
    dHf_298   -186670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84060.0
}
