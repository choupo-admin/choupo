/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylcyclodecanamine  (C11H23N, CAS 80789-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylcyclodecanamine;
formula     C11H23N;
CAS         80789-66-8;
InChIKey    BOYGZZJDNIMQTC-UHFFFAOYSA-N;
MW          169.312;      // g/mol [origin=calculated method=formula-sum]
Tc          764.93;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       0.4361;      // -   [origin=predictive method=lee-kesler]
Tb          538.08;      // K   [origin=predictive method=joback]
HvapTb      47633.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.41 1.20872 -0.0005186 2.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-cyclodecylmethylamine" "cyclodecanamine, n-methyl-" "n-methylcyclodecylamine" "n-methyl cyclodecanamine" );
standardThermochemistry
{
    dHf_298   -187220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107180.0
}
