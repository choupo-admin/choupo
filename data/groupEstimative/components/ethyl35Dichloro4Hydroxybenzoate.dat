/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3,5-dichloro-4-hydroxybenzoate  (C9H8Cl2O3, CAS 17302-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl35Dichloro4Hydroxybenzoate;
formula     C9H8Cl2O3;
CAS         17302-82-8;
InChIKey    WMKNGSJJEMFQOT-UHFFFAOYSA-N;
MW          235.06;      // g/mol [origin=calculated method=formula-sum]
Tc          890.11;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.8646;      // -   [origin=predictive method=lee-kesler]
Tb          655.86;      // K   [origin=predictive method=joback]
HvapTb      68419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.671 0.77432 -0.00056548 1.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group ACCl; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,5-bis(chloranyl)-4-oxidanyl-benzoate" "3,5-dichloro-4-hydroxybenzoic acid ethyl ester" "benzoic acid, 3,5-dichloro-4-hydroxy-, ethyl ester" "ethyl 3,5-dichloro-4-hydroxybenzoate hydrate" "3,5-dichloro-4-hydroxy-benzoic acid ethyl ester" "benzoic acid,5-dichloro-4-hydroxy-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -541570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-370800.0
}
