/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethyl-2,3-bis(4-tert-butylphenyl)butane  (C26H38, CAS 5171-91-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethyl23Bis4TertButylphenylButane;
formula     C26H38;
CAS         5171-91-5;
InChIKey    VKUOFKIWVLOZFE-UHFFFAOYSA-N;
MW          350.59;      // g/mol [origin=calculated method=formula-sum]
Tc          1083.21;      // K   [origin=predictive method=joback]
Pc          11.067;      // bar [origin=predictive method=joback]
omega       0.6078;      // -   [origin=predictive method=lee-kesler]
Tb          844.88;      // K   [origin=predictive method=joback]
HvapTb      74162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.85 2.7004 -0.00200612 5.87e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group C; count 4; } { group ACH; count 8; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group C; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-[3-(4-tert-butylphenyl)-2,3-dimethyl-butan-2-yl]benzene" "1-tert-butyl-4-[3-(4-tert-butylphenyl)-2,3-dimethylbutan-2-yl]benzene" );
standardThermochemistry
{
    dHf_298   -164850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     788.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=384960.0
}
