/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 4-(ethylamino)benzoate  (C11H15NO2, CAS 42265-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl4EthylaminoBenzoate;
formula     C11H15NO2;
CAS         42265-58-7;
InChIKey    GDIMKVMLVSCQJB-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          799.31;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.7516;      // -   [origin=predictive method=lee-kesler]
Tb          591.33;      // K   [origin=predictive method=joback]
HvapTb      56861.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.518 0.93184 -0.00049276 7.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 4-(ethylamino)-, ethyl ester" "benzoic acid,4-(ethylamino)-, ethyl ester" "4-(ethylamino)benzoicacid ethyl ester; ethyl 4-ethylaminobenzoate" );
gibbsFormation
{
    dHf_298   -309120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76460.0
    phase     gas;
}
