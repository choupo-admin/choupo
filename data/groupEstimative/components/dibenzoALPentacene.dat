/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzo(a,l)pentacene  (C30H18, CAS 227-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzoALPentacene;
formula     C30H18;
CAS         227-09-8;
InChIKey    XSTMLGGLUNLJRY-UHFFFAOYSA-N;
MW          378.474;      // g/mol [origin=calculated method=formula-sum]
Tc          1330.73;      // K   [origin=predictive method=joback]
Pc          17.773;      // bar [origin=predictive method=joback]
omega       1.0739;      // -   [origin=predictive method=lee-kesler]
Tb          1051.46;      // K   [origin=predictive method=joback]
HvapTb      97800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-175.45 2.4552 -0.00212452 7.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 18; } { group AC; count 12; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 18; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo[a,l]pentacene" "1,2,8,9-dibenzpentacene" "1,8,9-dibenzpentacene" "1,8,9-dibenzopentacene" "dibenzo-1,8,9-pentacene" "1,2,8,9-dibenzopentacene" "1,2:8,9-dibenzopentacene" );
standardThermochemistry
{
    dHf_298   663070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=905880.0
}
