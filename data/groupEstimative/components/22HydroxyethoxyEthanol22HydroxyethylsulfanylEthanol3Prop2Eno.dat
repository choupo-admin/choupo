/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-hydroxyethoxy)ethanol; 2-(2-hydroxyethylsulfanyl)ethanol; 3-prop-2-enoxypropane-1,2-diol  (C14H32O8S, CAS 67674-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HydroxyethoxyEthanol22HydroxyethylsulfanylEthanol3Prop2Eno;
formula     C14H32O8S;
CAS         67674-61-7;
InChIKey    PHDAYALFAKWKBR-UHFFFAOYSA-N;
MW          360.462;      // g/mol [origin=calculated method=formula-sum]
Tc          1578.31;      // K   [origin=predictive method=joback]
Pc          21.573;      // bar [origin=predictive method=joback]
omega       0.7470;      // -   [origin=predictive method=lee-kesler]
Tb          1185.66;      // K   [origin=predictive method=joback]
HvapTb      157999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (169.471 0.97929 0.0001455 -3.405e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2=CH; count 1; } { group OH; count 4; } { group C2H5O2; count 1; } { group C2H4O2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 11; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 6; } { group O; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethyloxy)ethanol;2-(2-hydroxyethylsulfanyl)ethanol;3-prop-2-enoxypropane-1,2-diol" "1,2-propanediol, 3-(2-propen-1-yloxy)-, polymer with 2,2'-oxybis(ethanol) and 2,2'-thiobis(ethanol)" "1,2-propanediol, 3-(2-propenyloxy)-, polymer with 2,2'-oxybis(ethanol) and 2,2'-thiobis(ethanol)" );
standardThermochemistry
{
    dHf_298   -1571330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1291.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1054920.0
}
