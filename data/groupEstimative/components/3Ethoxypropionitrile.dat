/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethoxypropionitrile  (C5H9NO, CAS 2141-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethoxypropionitrile;
formula     C5H9NO;
CAS         2141-62-0;
InChIKey    DCWQZPJHHVLHSV-UHFFFAOYSA-N;
MW          99.133;      // g/mol [origin=calculated method=formula-sum]
Tc          628.61;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.4949;      // -   [origin=predictive method=lee-kesler]
Tb          438.50;      // K   [origin=predictive method=joback]
HvapTb      39612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.843 0.35042 -0.0001062 -1.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxypropanenitrile" "propanenitrile, 3-ethoxy-" "propionitrile, 3-ethoxy-" "3-ethoxy-propionitrile" "3-ethoxypropiononitrile" "beta-ethoxypropionitrile" "alpha-ethoxypropionitrile" "propionitrile, 2-ethoxy-" "beta-aethoxypropionitril [german]" "2-ethoxypropannitril" "3- ethoxypropionitrile" "beta-aethoxypropionitril" );
gibbsFormation
{
    dHf_298   -113870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19400.0
    phase     gas;
}
