/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichloroacrylic acid  (C3HCl3O2, CAS 2257-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichloroacrylicAcid;
formula     C3HCl3O2;
CAS         2257-35-4;
InChIKey    WMUBNWIGNSIRDH-UHFFFAOYSA-N;
MW          175.389;      // g/mol [origin=calculated method=formula-sum]
Tc          762.14;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.6234;      // -   [origin=predictive method=lee-kesler]
Tb          529.96;      // K   [origin=predictive method=joback]
HvapTb      52709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.87 0.3798 -0.0003616 1.305e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group Cl_C=C_; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group Cl; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,3-tris(chloranyl)prop-2-enoic acid" "2,3,3-trichloroacrylic acid" "2,3,3-trichloroprop-2-enoic acid" "perchlorovinylic acid" "trichloroprop-2-enoic acid" "2-propenoic acid, 2,3,3-trichloro-" "acrylicacid, trichloro- (6ci,7ci,8ci); 2,3,3-trichloroacrylic acid; perchlorovinylicacid; trichloroacrylic acid" );
standardThermochemistry
{
    dHf_298   -405100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-342200.0
}
