/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,2,4,6-pentamethylaniline  (C11H17N, CAS 13021-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nN246Pentamethylaniline;
formula     C11H17N;
CAS         13021-15-3;
InChIKey    JZBZLRKFJWQZHU-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          708.31;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.4953;      // -   [origin=predictive method=lee-kesler]
Tb          505.34;      // K   [origin=predictive method=joback]
HvapTb      46385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.81 0.9154 -0.00051728 1.079e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylmesidine" "2-(dimethylamino)mesitylene" "n,n,2,4,6-pentamethylbenzenamine" "2-dimethylaminomesitylene" "dimethyl(2,4,6-trimethylphenyl)amine" );
gibbsFormation
{
    dHf_298   -720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236040.0
    phase     gas;
}
