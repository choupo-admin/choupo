/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyloxolan-2-one  (C6H10O2, CAS 3709-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyloxolan2One;
formula     C6H10O2;
CAS         3709-08-8;
InChIKey    UPVAIJPDWVTFKT-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          599.33;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.3700;      // -   [origin=predictive method=lee-kesler]
Tb          402.08;      // K   [origin=predictive method=joback]
HvapTb      35119.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.39 0.96184 -0.0009608 4.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "alpha,alpha-dimethyl-gamma-butyrolactone" "2(3h)-furanone, dihydro-3,3-dimethyl-" "3,3-dimethyldihydrofuran-2(3h)-one" "butyric acid, 2,2-dimethyl-4-hydroxy-, g-lactone" "alpha-dmgbl" "2,2-dimethyl-4-butyrolactone" "2(3h)-furanone, dihydrodimethyl-" "3,3-dimethyl-dihydro-furan-2-one" "dihydro-3,3-dimethyl-2(3h)-furanone" "4-hydroxy-2, .gamma.-lactone" );
standardThermochemistry
{
    dHf_298   -396410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255470.0
}
