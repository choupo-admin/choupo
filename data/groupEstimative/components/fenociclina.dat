/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenociclina  (C19H22O3, CAS 15372-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenociclina;
formula     C19H22O3;
CAS         15372-34-6;
InChIKey    HZZSXUIUESWVSS-UHFFFAOYSA-N;
MW          298.382;      // g/mol [origin=calculated method=formula-sum]
Tc          1106.63;      // K   [origin=predictive method=joback]
Pc          19.372;      // bar [origin=predictive method=joback]
omega       1.0775;      // -   [origin=predictive method=lee-kesler]
Tb          869.43;      // K   [origin=predictive method=joback]
HvapTb      81989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.149 1.94206 -0.0015892 5.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-7-methoxy-2-methyl-3,4-dihydro-1h-phenanthrene-2-carboxylic acid" "fenocyclin" "fenocycline" "fenocylin" "phenocyclin" "surestrine" "surestryl" "doisynoestrol" "bdda me" "dehydrofolliculinic acid" "dl-cis-bisdehydrodoisynolic acid methyl ether" "7-methylbisdehydrodoisynolic acid" );
standardThermochemistry
{
    dHf_298   -463250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114190.0
}
