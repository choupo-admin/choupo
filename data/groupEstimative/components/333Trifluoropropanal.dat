/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3-trifluoropropanal  (C3H3F3O, CAS 460-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Trifluoropropanal;
formula     C3H3F3O;
CAS         460-40-2;
InChIKey    UTMIEQASUFFADK-UHFFFAOYSA-N;
MW          112.05;      // g/mol [origin=calculated method=formula-sum]
Tc          466.26;      // K   [origin=predictive method=joback]
Pc          41.731;      // bar [origin=predictive method=joback]
omega       0.3823;      // -   [origin=predictive method=lee-kesler]
Tb          311.48;      // K   [origin=predictive method=joback]
HvapTb      25245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.361 0.4245 -0.0003534 1.111e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHO; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group F; count 3; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(fluoranyl)propanal" "3,3,3-trifluoropropionaldehyde" "trifluoropropionaldehyde" "propanal, 3,3,3-trifluoro-" "propionaldehyde, 3,3,3-trifluoro-" "3,3,3-trifluoropropaldehyde" "propanal,3,3,3-trifluoro-" "propanal, 3,3,3-trifluoro- (9ci)" "3,3,3-trifluoropropanal contains condensation products" "propionaldehyde,3,3,3-trifluoro- (6ci,8ci);3,3,3-trifluoropropionaldehyde;" );
gibbsFormation
{
    dHf_298   -787910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-706730.0
    phase     gas;
}
