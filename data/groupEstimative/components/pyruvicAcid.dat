/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyruvic acid  (C3H4O3, CAS 127-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyruvicAcid;
formula     C3H4O3;
CAS         127-17-3;
InChIKey    LCTONWCANYUPML-UHFFFAOYSA-N;
MW          88.062;      // g/mol [origin=calculated method=formula-sum]
Tc          674.39;      // K   [origin=predictive method=joback]
Pc          54.546;      // bar [origin=predictive method=joback]
omega       0.6739;      // -   [origin=predictive method=lee-kesler]
Tb          467.62;      // K   [origin=predictive method=joback]
HvapTb      46182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.12 0.31162 -0.0001933 4.346e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylidenepropanoic acid" "2-oxopropanoic acid" "pyroracemic acid" "acetylformic acid" "2-oxopropionic acid" "alpha-ketopropionic acid" "pyruvate" "2-ketopropionic acid" "propanoic acid, 2-oxo-" "2-oxopropanoate" "2-oxopropansaeure" "2-oxopropionsaeure" );
gibbsFormation
{
    dHf_298   -568100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-498450.0
    phase     gas;
}
