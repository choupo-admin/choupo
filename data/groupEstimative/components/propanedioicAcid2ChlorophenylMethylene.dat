/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanedioic acid, [(2-chlorophenyl)methylene]-  (C10H7ClO4, CAS 20851-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanedioicAcid2ChlorophenylMethylene;
formula     C10H7ClO4;
CAS         20851-50-7;
InChIKey    AWICIAINVVRWQR-UHFFFAOYSA-N;
MW          226.612;      // g/mol [origin=calculated method=formula-sum]
Tc          1036.13;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       1.2247;      // -   [origin=predictive method=lee-kesler]
Tb          792.55;      // K   [origin=predictive method=joback]
HvapTb      79543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.59 0.9437 -0.00073606 2.226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group COOH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-chlorophenyl)methylidene]propanedioic acid" "agn-pc-00fbjt" );
standardThermochemistry
{
    dHf_298   -633520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-491980.0
}
