/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-2-pentanone  (C7H14O, CAS 20669-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl2Pentanone;
formula     C7H14O;
CAS         20669-04-9;
InChIKey    QSHJLBQLQVSEFV-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          598.77;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.3774;      // -   [origin=predictive method=lee-kesler]
Tb          410.40;      // K   [origin=predictive method=joback]
HvapTb      36626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.589 0.76668 -0.0005101 1.3496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylpentan-2-one" "agn-pc-0d1hwn" "2-pentanone,3,3-dimethyl-" "c2h5c(ch3)2coch3" "2-pentanone, 3,3-dimethyl-" );
gibbsFormation
{
    dHf_298   -309140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-118020.0
    phase     gas;
}
