/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(1-hydroxyethyl)phenol  (C8H10O2, CAS 2380-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        41HydroxyethylPhenol;
formula     C8H10O2;
CAS         2380-91-8;
InChIKey    PMRFBLQVGJNGLU-UHFFFAOYSA-N;
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          795.46;      // K   [origin=predictive method=joback]
Pc          50.586;      // bar [origin=predictive method=joback]
omega       1.0063;      // -   [origin=predictive method=lee-kesler]
Tb          581.68;      // K   [origin=predictive method=joback]
HvapTb      64983.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.6 0.87942 -0.00073256 2.519e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-hydroxyphenyl)ethanol" "1-(4'-hydroxyphenyl)ethanol" "4-hydroxy-alpha-methylbenzyl alcohol" "4-hydroxy-alpha-methyl-benzenemethanol" "4-hydroxyphenyl ethanol" "1-(p-hydroxyphenyl)ethanol" "1-(p-hydroxyphenyl) ethanol" "ambap2380-91-8" "4-hydroxyphenyl methyl carbinol" "benzenemethanol, 4-hydroxy-alpha-methyl-" "benzenemethanol, 4-hydroxy-.alpha.-methyl-" "benzenemethanol, 4-hydroxy-alpha-methyl-, homopolymer" );
gibbsFormation
{
    dHf_298   -306740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164990.0
    phase     gas;
}
