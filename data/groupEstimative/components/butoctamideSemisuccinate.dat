/*--------------------------------*- Choupo -*-----------------------*\
  Component: butoctamide semisuccinate  (C16H29NO5, CAS 32838-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butoctamideSemisuccinate;
formula     C16H29NO5;
CAS         32838-28-1;
InChIKey    CQONVBIGUJWUFE-UHFFFAOYSA-N;
MW          315.41;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.24;      // K   [origin=predictive method=joback]
Pc          15.164;      // bar [origin=predictive method=joback]
omega       1.2844;      // -   [origin=predictive method=lee-kesler]
Tb          872.57;      // K   [origin=predictive method=joback]
HvapTb      88187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.138 1.57986 -0.0008609 1.5056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group CH2COO; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4-(2-ethylhexylamino)-4-oxidanylidene-butan-2-yl]oxy-4-oxidanylidene-butanoic acid" "listomin s" "butoctamide hydrogen succinate" "m-2h" "n-2-ethylhexyl-beta-oxybutyramide semisuccinate" "n-(2-ethylhexyl)-3-hydroxybutyramide hydrogen succinate" "4-({4-[(2-ethylhexyl)amino]-4-oxobutan-2-yl}oxy)-4-oxobutanoic acid" "succinic acid, monoester with n-(2-ethylhexyl)-3-hydroxybutyramide" "listomin" "listomin s (tn)" "butoctamide hemisuccinate" "butoctamide semisuccinate (jan)" );
gibbsFormation
{
    dHf_298   -1110790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     931.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-614850.0
    phase     gas;
}
