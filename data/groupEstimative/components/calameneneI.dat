/*--------------------------------*- Choupo -*-----------------------*\
  Component: calamenene i  (C15H22, CAS 483-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        calameneneI;
formula     C15H22;
CAS         483-77-2;
InChIKey    PGTJIOWQJWHTJJ-UHFFFAOYSA-N;
MW          202.341;      // g/mol [origin=calculated method=formula-sum]
Tc          803.90;      // K   [origin=predictive method=joback]
Pc          20.163;      // bar [origin=predictive method=joback]
omega       0.5011;      // -   [origin=predictive method=lee-kesler]
Tb          585.34;      // K   [origin=predictive method=joback]
HvapTb      51972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.16 1.35168 -0.00081092 1.837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-dimethyl-4-propan-2-yl-1,2,3,4-tetrahydronaphthalene" "calamenene ii" "1,6-dimethyl-4-isopropyltetralin" "naphthalene, 1,2,3,4-tetrahydro-1,6-dimethyl-4-(1-methylethyl)-" "1,2,3,4-tetrahydro-4-isopropyl-1,6-dimethylnaphthalene" "cadina-1,3,5-triene" "naphthalene, 1,2,3,4-tetrahydro-1,6-dimethyl-4-(1-methylethyl)-, (1s-cis)-" "(-)-calamenene" "calamenene" "4-isopropyl-1,6-dimethyl-1,2,3,4-tetrahydro-naphthalene" "1,2,3,4-tetrahydro-1,6-dimethyl-4-(1-methylethyl)naphthalene" "(1s-cis)-1,6-dimethyl-4-(1-methylethyl)-1,2,3,4-tetrahydronaphthalene" );
standardThermochemistry
{
    dHf_298   -98320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207070.0
}
