/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diphenylbutane  (C16H18, CAS 719-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenylbutane;
formula     C16H18;
CAS         719-79-9;
InChIKey    SZFDQMKAGLCYPA-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          853.67;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.5399;      // -   [origin=predictive method=lee-kesler]
Tb          618.60;      // K   [origin=predictive method=joback]
HvapTb      55374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.148 1.37192 -0.0009122 2.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylbutylbenzene" "benzene, 1,1'-butylidenebis-" "(phenylbutyl)benzene" "(1-phenylbutyl)benzene" "benzene,1,1'-butylidenebis-" "butane,1,1-diphenyl- (6ci,7ci,8ci); 1,1-diphenylbutane" );
standardThermochemistry
{
    dHf_298   94210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=306220.0
}
