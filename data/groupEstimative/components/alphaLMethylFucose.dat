/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-l-methyl-fucose  (C7H14O5, CAS 14687-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaLMethylFucose;
formula     C7H14O5;
CAS         14687-15-1;
InChIKey    OHWCAVRRXKJCRB-CXNFULCWSA-N;
MW          178.184;      // g/mol [origin=calculated method=formula-sum]
Tc          862.54;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       1.8072;      // -   [origin=predictive method=lee-kesler]
Tb          686.54;      // K   [origin=predictive method=joback]
HvapTb      87326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.37 0.72074 -0.0001827 -6.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 4; } { group OH; count 3; } { group CH3O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 5; } { group OH; count 3; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3s,4r,5s,6s)-2-methoxy-6-methyl-oxane-3,4,5-triol" "methyl a-l-fucopyranoside" "mfu" "alpha-l-1-methyl-fucose" "methyl alpha-l-fucopyranoside" "(2r,3s,4r,5s,6s)-2-methoxy-6-methyloxane-3,4,5-triol" );
gibbsFormation
{
    dHf_298   -935760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-599910.0
    phase     gas;
}
