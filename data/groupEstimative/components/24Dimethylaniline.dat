/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethylaniline  (C8H11N, CAS 95-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethylaniline;
formula     C8H11N;
CAS         95-68-1;
InChIKey    CZZZABOKJQXEBO-UHFFFAOYSA-N;
MW          121.183;      // g/mol [origin=calculated method=formula-sum]
Tc          717.55;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.4612;      // -   [origin=predictive method=lee-kesler]
Tb          491.81;      // K   [origin=predictive method=joback]
HvapTb      47643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.2 0.62784 -0.00035192 7.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-xylidine" "2,4-dimethyl aniline" "m-xylidine" "benzenamine, 2,4-dimethyl-" "m-4-xylidine" "1-amino-2,4-dimethylbenzene" "2-methyl-p-toluidine" "4-methyl-o-toluidine" "4-amino-1,3-dimethylbenzene" "2,4-dimethylbenzenamine" "2,4-dimethylphenylamine" "4-amino-1,3-xylene" );
standardThermochemistry
{
    dHf_298   38930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176080.0
}
