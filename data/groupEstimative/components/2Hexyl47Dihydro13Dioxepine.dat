/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyl-4,7-dihydro-1,3-dioxepine  (C11H20O2, CAS 61732-96-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexyl47Dihydro13Dioxepine;
formula     C11H20O2;
CAS         61732-96-5;
InChIKey    BKMHRWAUFCKQFT-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          730.15;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.5575;      // -   [origin=predictive method=lee-kesler]
Tb          528.16;      // K   [origin=predictive method=joback]
HvapTb      49993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.415 1.09932 -0.00056868 8.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxepin, 2-hexyl-4,7-dihydro-" "heptanal, butene-1,4-glycol acetal" "2-hexyl-4,7-dihydro-1,3-dioxepin" );
standardThermochemistry
{
    dHf_298   -428430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88190.0
}
