/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dichloro-3,3-dimethylpentane  (C7H14Cl2, CAS 62496-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dichloro33Dimethylpentane;
formula     C7H14Cl2;
CAS         62496-53-1;
InChIKey    FKWZFRHUYPBHBJ-UHFFFAOYSA-N;
MW          169.089;      // g/mol [origin=calculated method=formula-sum]
Tc          621.95;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       0.3724;      // -   [origin=predictive method=lee-kesler]
Tb          431.39;      // K   [origin=predictive method=joback]
HvapTb      38650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.166 0.80824 -0.0005696 1.62e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-bis(chloranyl)-3,3-dimethyl-pentane" "pentane, 1,5-dichloro-3,3-dimethyl-" );
standardThermochemistry
{
    dHf_298   -228040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12960.0
}
