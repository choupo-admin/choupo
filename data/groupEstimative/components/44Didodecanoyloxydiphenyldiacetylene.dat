/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-didodecanoyloxydiphenyldiacetylene  (C40H54O4, CAS 92341-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Didodecanoyloxydiphenyldiacetylene;
formula     C40H54O4;
CAS         92341-29-2;
InChIKey    YYJQUZHMNWZSFS-UHFFFAOYSA-N;
MW          598.868;      // g/mol [origin=calculated method=formula-sum]
Tc          1652.90;      // K   [origin=predictive method=joback]
Pc          5.960;      // bar [origin=predictive method=joback]
omega       0.2806;      // -   [origin=predictive method=lee-kesler]
Tb          1312.56;      // K   [origin=predictive method=joback]
HvapTb      129628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.25 3.11784 -0.00170704 3.0976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 20; } { group tC; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-dodecanoyloxyphenyl)buta-1,3-diynyl]phenyl] dodecanoate" "buta-1,3-diyne-1,4-diyldibenzene-4,1-diyl didodecanoate" );
standardThermochemistry
{
    dHf_298   -508770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1534.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=276340.0
}
