/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propionylthiophene  (C7H8OS, CAS 13679-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propionylthiophene;
formula     C7H8OS;
CAS         13679-75-9;
InChIKey    MFPZQZZWAMAHOY-UHFFFAOYSA-N;
MW          140.2;      // g/mol [origin=calculated method=formula-sum]
Tc          713.45;      // K   [origin=predictive method=joback]
Pc          40.934;      // bar [origin=predictive method=joback]
omega       0.4510;      // -   [origin=predictive method=lee-kesler]
Tb          484.71;      // K   [origin=predictive method=joback]
HvapTb      45546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.859 0.64193 -0.00044732 1.2306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2CO; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-thiophen-2-ylpropan-1-one" "1-(2-thienyl)-1-propanone" "1-(2-thienyl)propan-1-one" "ethyl 2-thienyl ketone" "1-(thiophen-2-yl)propan-1-one" "1-propanone, 1-(2-thienyl)-" "ethyl-2-thienyl ketone" "ethyl thienyl ketone" "2-propanoylthiophene" "2-(propionyl)thiophene" "1-thien-2-ylpropan-1-one" "1-thiophen-2-yl-1-propanone" );
standardThermochemistry
{
    dHf_298   -70220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13550.0
}
