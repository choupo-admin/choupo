/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentachlorobenzene  (C6HCl5, CAS 608-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentachlorobenzene;
formula     C6HCl5;
CAS         608-93-5;
InChIKey    CEOCDNVZRAIOQZ-UHFFFAOYSA-N;
MW          250.324;      // g/mol [origin=calculated method=formula-sum]
Tc          822.12;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.4848;      // -   [origin=predictive method=lee-kesler]
Tb          570.63;      // K   [origin=predictive method=joback]
HvapTb      55799.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.18 0.2909 -0.00016764 3.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCl; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(chloranyl)benzene" "1,2,3,4,5-pentachlorobenzene" "benzene, pentachloro-" "1,2,3,4,5-pentachloro-benzene" "benzene, 1,2,3,4,5-pentachloro-" "qcb" "pecb" "u - pentachlorobenzene" "1,3,4,5-pentachlorobenzene" "5cl" );
standardThermochemistry
{
    dHf_298   -55220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13880.0
}
