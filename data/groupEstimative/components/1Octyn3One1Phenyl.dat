/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octyn-3-one, 1-phenyl-  (C14H16O, CAS 62059-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octyn3One1Phenyl;
formula     C14H16O;
CAS         62059-61-4;
InChIKey    BPPAZYIIOUNGMM-UHFFFAOYSA-N;
MW          200.281;      // g/mol [origin=calculated method=formula-sum]
Tc          835.48;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.6190;      // -   [origin=predictive method=lee-kesler]
Tb          609.47;      // K   [origin=predictive method=joback]
HvapTb      57932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.826 1.07712 -0.00065816 1.5084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyloct-1-yn-3-one" );
standardThermochemistry
{
    dHf_298   63960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253290.0
}
