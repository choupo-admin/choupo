/*--------------------------------*- Choupo -*-----------------------*\
  Component: mixed salts of glycolic acid with hexamethylenetetramine and alkylpyridines  (C13H21N5O3, CAS 99924-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mixedSaltsOfGlycolicAcidWithHexamethylenetetramineAndAlkylpy;
formula     C13H21N5O3;
CAS         99924-46-6;
InChIKey    XXORKNUSZSIRMG-UHFFFAOYSA-N;
MW          295.343;      // g/mol [origin=calculated method=formula-sum]
Tc          1106.47;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       1.7279;      // -   [origin=predictive method=lee-kesler]
Tb          884.11;      // K   [origin=predictive method=joback]
HvapTb      95109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.489 1.98216 -0.0014807 4.209e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH2N; count 4; } { group C5H5N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group dCH_ring; count 5; } { group OH; count 1; } { group COOH; count 1; } { group N; count 4; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "acetic acid, 2-hydroxy-, compds. with alkylpyridines and hexamethylenetetramine" "acetic acid, hydroxy-, compds. with alkylpyridines and hexamethylenetetramine" );
standardThermochemistry
{
    dHf_298   -188580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252220.0
}
