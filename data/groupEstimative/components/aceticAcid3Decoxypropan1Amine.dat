/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetic acid; 3-decoxypropan-1-amine  (C15H33NO3, CAS 68310-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aceticAcid3Decoxypropan1Amine;
formula     C15H33NO3;
CAS         68310-74-7;
InChIKey    MQXJONYFWRNZIZ-UHFFFAOYSA-N;
MW          275.433;      // g/mol [origin=calculated method=formula-sum]
Tc          974.38;      // K   [origin=predictive method=joback]
Pc          14.601;      // bar [origin=predictive method=joback]
omega       1.1319;      // -   [origin=predictive method=lee-kesler]
Tb          784.66;      // K   [origin=predictive method=joback]
HvapTb      79493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.662 1.27214 -0.0003824 -6.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-decoxypropan-1-amine;ethanoic acid" "1-propanamine, 3-(decyloxy)-, acetate" "3-(decyloxy)-1-propanamine acetate" "1-propanamine, 3-(decyloxy)-, acetate (1:1)" "3-(decyloxy)propylammonium acetate" "3-decoxypropane-1-amine acetate" "3-decyloxypropanamine acetate" "acetic acid, 3-decyloxypropylamine salt" );
gibbsFormation
{
    dHf_298   -913250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     963.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411800.0
    phase     gas;
}
