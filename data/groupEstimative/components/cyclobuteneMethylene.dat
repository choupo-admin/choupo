/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutene, methylene-  (C5H6, CAS 27538-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobuteneMethylene;
formula     C5H6;
CAS         27538-13-2;
InChIKey    AQSOFHKMDGNCDW-UHFFFAOYSA-N;
MW          66.103;      // g/mol [origin=calculated method=formula-sum]
Tc          519.42;      // K   [origin=predictive method=joback]
Pc          47.236;      // bar [origin=predictive method=joback]
omega       0.2130;      // -   [origin=predictive method=lee-kesler]
Tb          328.00;      // K   [origin=predictive method=joback]
HvapTb      27569.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.89 0.4731 -0.00037228 1.21e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylidenecyclobutene" );
gibbsFormation
{
    dHf_298   82470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     259.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130620.0
    phase     gas;
}
