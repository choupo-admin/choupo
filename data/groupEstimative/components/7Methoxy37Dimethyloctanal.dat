/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methoxy-3,7-dimethyloctanal  (C11H22O2, CAS 3613-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methoxy37Dimethyloctanal;
formula     C11H22O2;
CAS         3613-30-7;
InChIKey    IDWULKZGRNHZNR-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          698.63;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       0.6427;      // -   [origin=predictive method=lee-kesler]
Tb          518.69;      // K   [origin=predictive method=joback]
HvapTb      47526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.634 1.09188 -0.0006316 1.342e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CHO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methoxy-3,7-dimethyl-octanal" "methoxycitronellal" "octanal, 7-methoxy-3,7-dimethyl-" "7-methoxycitronellal" "methoxydihydrocitronellal" "hydroxycitronellal methyl ether" "3,7-dimethyl-7-methoxy-1-octanal" "1-octanal, 3,7-dimethyl-7-methoxy-" "(s)-7-methoxy-3,7-dimethyloctanal" "7-methoxy-3.7-dimethylactanal" "octanal,7-methoxy-3,7-dimethyl-" "7-methoxy-3,7-dimethyl-1-octanal;7-methoxy-3,7-dimethyloctanal;7-methoxy-6,7-dihydrocitronellal;7-methoxycitronellal;methoxycitronellal;methoxydihydrocitronellal;" );
gibbsFormation
{
    dHf_298   -502200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162380.0
    phase     gas;
}
