/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-tolyldiethanolamine  (C11H17NO2, CAS 28005-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oTolyldiethanolamine;
formula     C11H17NO2;
CAS         28005-74-5;
InChIKey    LWAFETVQZHKDIS-UHFFFAOYSA-N;
MW          195.262;      // g/mol [origin=calculated method=formula-sum]
Tc          861.36;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       1.4951;      // -   [origin=predictive method=lee-kesler]
Tb          679.74;      // K   [origin=predictive method=joback]
HvapTb      78419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.826 1.10232 -0.00071216 1.773e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl-(2-methylphenyl)amino]ethanol" "2,2'-(o-toluidino)diethanol" "2,2'-((methylphenyl)imino)bisethanol" "di-(hydroxyethyl)-o-tolylamine" "2,2'-(o-tolylimino)diethanol" "n,n-bis(2-hydroxyethyl)-o-toluidine" "o-toluidine, n,n-bis(2-hydroxyethyl)-" "2,2'-((2-methylphenyl)imino)bisethanol" "ethanol, 2,2'-((2-methylphenyl)imino)bis-" "2,2'-[(methylphenyl)imino]bisethanol" "ethanol, 2,2'-[(2-methylphenyl)imino]bis-" "di(hydroxyethyl)-o-tolylamine" );
gibbsFormation
{
    dHf_298   -282240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18340.0
    phase     gas;
}
