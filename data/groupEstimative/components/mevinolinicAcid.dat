/*--------------------------------*- Choupo -*-----------------------*\
  Component: mevinolinic acid  (C24H38O6, CAS 75225-51-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mevinolinicAcid;
formula     C24H38O6;
CAS         75225-51-3;
InChIKey    QLJODMDSTUBWDW-BXMDZJJMSA-N;
MW          422.562;      // g/mol [origin=calculated method=formula-sum]
Tc          1433.04;      // K   [origin=predictive method=joback]
Pc          11.874;      // bar [origin=predictive method=joback]
omega       0.9712;      // -   [origin=predictive method=lee-kesler]
Tb          1155.34;      // K   [origin=predictive method=joback]
HvapTb      126616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.675 2.37798 -0.00132632 2.413e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 8; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,5r)-7-[(1s,2s,6r,8s,8ar)-2,6-dimethyl-8-[(2s)-2-methylbutanoyl]oxy-1,2,6,7,8,8a-hexahydronaphthalen-1-yl]-3,5-bis(oxidanyl)heptanoic acid" "lovastatin acid" "monacolinic k acid" "msd 803 free acid" "msd 803 acid" "1-naphthaleneheptanoic acid, 1,2,6,7,8,8a-hexahydro-beta,delta-dihydroxy-2,6-dimethyl-8-(2-methyl-1-oxobutoxy)-" "1-naphthaleneheptanoic acid, 1,2,6,7,8,8a-hexahydro-beta,delta-dihydroxy-2,6-dimethyl-8-(2-methyl-1-oxobutoxy)-, (1s-(1alpha(betas*,deltas*),2alpha,6beta,8beta(r*),8aalpha))-" "lva" "(3r,5r)-7-[(1s,2s,6r,8s,8ar)-2,6-dimethyl-8-[(2s)-2-methylbutanoyl]oxy-1,2,6,7,8,8a-hexahydronaphthalen-1-yl]-3,5-dihydroxyheptanoic acid" "(3r,5r)-7-[(1s,2s,6r,8s,8ar)-2,6-dimethyl-8-{[(2s)-2-methylbutanoyl]oxy}-1,2,6,7,8,8a-hexahydronaphthalen-1-yl]-3,5-dihydroxyheptanoic acid" );
standardThermochemistry
{
    dHf_298   -1362510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     959.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-683780.0
}
