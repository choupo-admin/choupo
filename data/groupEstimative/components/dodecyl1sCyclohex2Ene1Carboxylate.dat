/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl (1s)-cyclohex-2-ene-1-carboxylate  (C19H34O2, CAS 70693-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecyl1sCyclohex2Ene1Carboxylate;
formula     C19H34O2;
CAS         70693-21-9;
InChIKey    ZXPNQYISXDDMGI-GOSISDBHSA-N;
MW          294.479;      // g/mol [origin=calculated method=formula-sum]
Tc          896.74;      // K   [origin=predictive method=joback]
Pc          12.792;      // bar [origin=predictive method=joback]
omega       0.8618;      // -   [origin=predictive method=lee-kesler]
Tb          711.25;      // K   [origin=predictive method=joback]
HvapTb      66016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.799 1.82012 -0.00098348 1.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5(6)-carboxy-4-hexyl-2-cyclohexene-1-octanoic acid, (c12-c16) alkyl alcohol esters" );
standardThermochemistry
{
    dHf_298   -640670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     879.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146860.0
}
