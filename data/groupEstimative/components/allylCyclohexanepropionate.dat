/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl cyclohexanepropionate  (C12H20O2, CAS 2705-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylCyclohexanepropionate;
formula     C12H20O2;
CAS         2705-87-5;
InChIKey    TWXUTZNBHUWMKJ-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          749.52;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.5850;      // -   [origin=predictive method=lee-kesler]
Tb          548.61;      // K   [origin=predictive method=joback]
HvapTb      49472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.207 1.1911 -0.0006383 1.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 3-cyclohexylpropanoate" "allyl cyclohexylpropionate" "cyclohexanepropanoic acid, 2-propenyl ester" "allyl 3-cyclohexylpropanoate" "2-propenyl 3-cyclohexylpropanoate" "3-allylcyclohexyl propionate" "allyl 3-cyclohexylpropionate" "allyl hexahydrophenylpropionate" "allyl beta-cyclohexylpropionate" "2-propenyl cyclohexanepropanoate" "cyclohexanol, 3-allyl-, propionate" "2-propen-1-yl cyclohexanepropionate" );
standardThermochemistry
{
    dHf_298   -428540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147920.0
}
