/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-eicosanone  (C20H40O, CAS 2955-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Eicosanone;
formula     C20H40O;
CAS         2955-56-8;
InChIKey    BWVLRRQCABCGBO-UHFFFAOYSA-N;
MW          296.539;      // g/mol [origin=calculated method=formula-sum]
Tc          880.28;      // K   [origin=predictive method=joback]
Pc          10.576;      // bar [origin=predictive method=joback]
omega       0.8939;      // -   [origin=predictive method=lee-kesler]
Tb          711.07;      // K   [origin=predictive method=joback]
HvapTb      66860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.933 1.87584 -0.0010455 2.1776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosan-3-one" "3-icosanone" );
standardThermochemistry
{
    dHf_298   -568710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     961.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11400.0
}
