/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10,12-octadecadienoic acid  (C18H32O2, CAS 22880-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1012OctadecadienoicAcid;
formula     C18H32O2;
CAS         22880-03-1;
InChIKey    GKJZMAHZJGSBKD-UHFFFAOYSA-N;
MW          280.452;      // g/mol [origin=calculated method=formula-sum]
Tc          951.23;      // K   [origin=predictive method=joback]
Pc          13.194;      // bar [origin=predictive method=joback]
omega       1.0359;      // -   [origin=predictive method=lee-kesler]
Tb          765.27;      // K   [origin=predictive method=joback]
HvapTb      72742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.238 1.80462 -0.0011956 3.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH=CH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group dCH; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadeca-10,12-dienoic acid" "conjugated linoleic acid (10e,12z)" "10,12-octadecadienoic acid, (z,z)-" "10,12-octadecadienoicacid, (10z,12e)-" "10,12-octadecadienoic acid, (10e,12e)-" "10,12-octadecadienoicacid, (10e,12z)- (9ci)" "10,12-octadecadienoicacid, (e,z)- (8ci); 10-cis,12-trans-linoleic acid;10-cis,12-trans-octadecadienoic acid" );
gibbsFormation
{
    dHf_298   -530680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     897.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82790.0
    phase     gas;
}
