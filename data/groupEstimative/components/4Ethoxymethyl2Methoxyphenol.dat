/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(ethoxymethyl)-2-methoxyphenol  (C10H14O3, CAS 13184-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethoxymethyl2Methoxyphenol;
formula     C10H14O3;
CAS         13184-86-6;
InChIKey    KOCVACNWDMSLBM-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          800.01;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.7861;      // -   [origin=predictive method=lee-kesler]
Tb          585.52;      // K   [origin=predictive method=joback]
HvapTb      58626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.272 0.84364 -0.00051872 1.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(ethoxymethyl)-2-methoxy-phenol" "vanillyl ethyl ether" "phenol, 4-(ethoxymethyl)-2-methoxy-" "ethyl vanillyl ether" "alpha-ethoxy-2-methoxy-p-cresol" "p-cresol, alpha-ethoxy-2-methoxy-" "ethyl 4-hydroxy-3-methoxybenzyl ether" "p-cresol, a-ethoxy-2-methoxy- (7ci,8ci);4-(ethoxymethyl)-2-methoxyphenol;4-hydroxy-3-methoxybenzyl ethyl ether;ethyl4-hydroxy-3-methoxybenzyl ether;ethyl vanillyl ether;phenol,4-(ethoxymethyl)-2-methoxy-;" );
standardThermochemistry
{
    dHf_298   -466420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228520.0
}
