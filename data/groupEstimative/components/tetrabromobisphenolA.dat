/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrabromobisphenol a  (C15H12Br4O2, CAS 79-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrabromobisphenolA;
formula     C15H12Br4O2;
CAS         79-94-7;
InChIKey    VEORPZCZECFIRK-UHFFFAOYSA-N;
MW          543.875;      // g/mol [origin=calculated method=formula-sum]
Tc          1336.63;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       1.5783;      // -   [origin=predictive method=lee-kesler]
Tb          1038.73;      // K   [origin=predictive method=joback]
HvapTb      106656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.91 1.62084 -0.00155656 5.932e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 6; } { group ACOH; count 2; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Br; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-[3,5-bis(bromanyl)-4-oxidanyl-phenyl]propan-2-yl]-2,6-bis(bromanyl)phenol" "bromdian" "3,3',5,5'-tetrabromobisphenol a" "4,4'-isopropylidenebis(2,6-dibromophenol)" "firemaster bp 4a" "tetrabromodian" "great lakes ba-59p" "2,2-bis(3,5-dibromo-4-hydroxyphenyl)propane" "4,4'-(propane-2,2-diyl)bis(2,6-dibromophenol)" "2,2',6,6'-tetrabromobisphenol a" "phenol, 4,4'-(1-methylethylidene)bis[2,6-dibromo-" "tetrabromodiphenylopropane" );
standardThermochemistry
{
    dHf_298   -183800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12600.0
}
