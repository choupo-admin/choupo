/*--------------------------------*- Choupo -*-----------------------*\
  Component: hentetracontane  (C41H84, CAS 7194-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hentetracontane;
formula     C41H84;
CAS         7194-87-8;
InChIKey    IMQDQLFUWRBGGN-UHFFFAOYSA-N;
MW          577.123;      // g/mol [origin=calculated method=formula-sum]
Tc          1544.02;      // K   [origin=predictive method=joback]
Pc          3.765;      // bar [origin=predictive method=joback]
omega       -0.3309;      // -   [origin=predictive method=lee-kesler]
Tb          1137.68;      // K   [origin=predictive method=joback]
HvapTb      106860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.381 3.89884 -0.0022066 4.767e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 39; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 39; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hentetracontane, analytical standard" "DB-243573" "NS00044410" "Q11878802" "C41" "nc41" "n-c41" );
gibbsFormation
{
    dHf_298   -889570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1753.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=294340.0
    phase     gas;
}
