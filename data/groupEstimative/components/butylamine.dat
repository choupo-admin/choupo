/*--------------------------------*- Choupo -*-----------------------*\
  Component: butylamine  (C4H11N, CAS 109-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylamine;
formula     C4H11N;
CAS         109-73-9;
InChIKey    HQABUPZFAYXKJW-UHFFFAOYSA-N;
MW          73.139;      // g/mol [origin=calculated method=formula-sum]
Tc          545.43;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.3753;      // -   [origin=predictive method=lee-kesler]
Tb          363.65;      // K   [origin=predictive method=joback]
HvapTb      35139.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.743 0.44572 -0.0002372 4.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-1-amine" "1-butanamine" "1-aminobutane" "n-butylamine" "monobutylamine" "n-butylamin" "mono-n-butylamine" "norvalamine" "1-aminobutan" "1-amino-butaan" "n-butylamin [german]" "1-butylamine" );
standardThermochemistry
{
    dHf_298   -92100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49250.0
}
