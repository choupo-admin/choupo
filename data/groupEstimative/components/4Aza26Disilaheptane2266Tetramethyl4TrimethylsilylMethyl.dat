/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-aza-2,6-disilaheptane, 2,2,6,6-tetramethyl-4-[(trimethylsilyl)methyl]-  (C12H33NSi3, CAS 4438-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H33NSi3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Aza26Disilaheptane2266Tetramethyl4TrimethylsilylMethyl;
formula     C12H33NSi3;
CAS         4438-47-5;
InChIKey    PPRSCEZFBAOLDG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          275.658;      // g/mol [origin=calculated method=formula-sum]
Tc          665.69;      // K   [origin=predictive method=joback]
Pc          13.398;      // bar [origin=predictive method=joback]
omega       0.3569;      // -   [origin=predictive method=lee-kesler]
Tb          490.80;      // K   [origin=predictive method=joback]
HvapTb      45231.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (103.743 0.64928 0.0005028 -4.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group CH2; count 2; } { group CH2N; count 1; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH2; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-trimethylsilyl-n,n-bis(trimethylsilylmethyl)methanamine" "4-aza-2,6-disilaheptane, 2,2,6,6-tetramethyl-4-((trimethylsilyl)methyl)-" "1-(trimethylsilyl)-n,n-bis[(trimethylsilyl)methyl]methanamine" );
standardThermochemistry
{
    dHf_298   -558340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1018.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153340.0
}
