/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dimethyloct-7-en-3-one  (C10H18O, CAS 63323-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dimethyloct7En3One;
formula     C10H18O;
CAS         63323-26-2;
InChIKey    BOBHRIZDBFPAKV-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          661.86;      // K   [origin=predictive method=joback]
Pc          23.634;      // bar [origin=predictive method=joback]
omega       0.5339;      // -   [origin=predictive method=lee-kesler]
Tb          478.07;      // K   [origin=predictive method=joback]
HvapTb      43154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.198 0.91766 -0.0005308 1.1516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH2=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-octen-3-one, 4,6-dimethyl-" );
gibbsFormation
{
    dHf_298   -247440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12640.0
    phase     gas;
}
