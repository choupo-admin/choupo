/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(diethylamino)ethanol  (C6H15NO, CAS 100-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DiethylaminoEthanol;
formula     C6H15NO;
CAS         100-37-8;
InChIKey    BFSVOASYOCHEOV-UHFFFAOYSA-N;
MW          117.192;      // g/mol [origin=calculated method=formula-sum]
Tc          601.47;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.8338;      // -   [origin=predictive method=lee-kesler]
Tb          441.50;      // K   [origin=predictive method=joback]
HvapTb      47672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.966 0.73174 -0.0004456 1.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-diethylaminoethanol" "n,n-diethylethanolamine" "(diethylamino)ethanol" "diethylaminoethanol" "deae" "diethylethanolamine" "n,n-diethyl-2-aminoethanol" "ethanol, 2-(diethylamino)-" "(2-hydroxyethyl)diethylamine" "diethyl(2-hydroxyethyl)amine" "2-hydroxytriethylamine" "beta-hydroxytriethylamine" );
standardThermochemistry
{
    dHf_298   -251870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26400.0
}
