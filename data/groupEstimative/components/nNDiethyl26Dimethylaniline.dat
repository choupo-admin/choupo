/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-2,6-dimethylaniline  (C12H19N, CAS 3995-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl26Dimethylaniline;
formula     C12H19N;
CAS         3995-38-8;
InChIKey    KECFTDQVRIBMCH-UHFFFAOYSA-N;
MW          177.291;      // g/mol [origin=calculated method=formula-sum]
Tc          722.26;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       0.5447;      // -   [origin=predictive method=lee-kesler]
Tb          523.24;      // K   [origin=predictive method=joback]
HvapTb      47949.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.018 1.06988 -0.00063872 1.447e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2,6-dimethyl-aniline" "benzenamine, n,n-diethyl-2,6-dimethyl-" "n-(2,6-dimethylphenyl)-n,n-diethylamine" );
standardThermochemistry
{
    dHf_298   -9890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254090.0
}
