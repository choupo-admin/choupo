/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diamino-3,3'-dimethyldiphenylmethane  (C15H18N2, CAS 838-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diamino33Dimethyldiphenylmethane;
formula     C15H18N2;
CAS         838-88-0;
InChIKey    WECDUOXQLAIPQW-UHFFFAOYSA-N;
MW          226.323;      // g/mol [origin=calculated method=formula-sum]
Tc          1010.27;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.8924;      // -   [origin=predictive method=lee-kesler]
Tb          761.14;      // K   [origin=predictive method=joback]
HvapTb      77466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.379 1.15684 -0.00067324 1.407e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-azanyl-3-methyl-phenyl)methyl]-2-methyl-aniline" "me-mda" "mbot" "4,4'-methylenebis(2-methylaniline)" "4,4'-methylenedi-o-toluidine" "4,4'-methylene bis(2-methylaniline)" "o-toluidine, 4,4'-methylenedi-" "bis(3-methyl-4-aminophenyl)methane" "4,4'-methanediylbis(2-methylaniline)" "4,4'-methylene-bis(2-methylaniline)" "3,3'-dimethyl-4,4'-diaminodiphenylmethane" "4,4'-methylene di-o-toluidine" );
standardThermochemistry
{
    dHf_298   141830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=394620.0
}
