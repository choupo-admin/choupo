/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-allylcyclohexene  (C9H14, CAS 15232-95-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Allylcyclohexene;
formula     C9H14;
CAS         15232-95-8;
InChIKey    RGURBRHZWFDJBM-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          626.54;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       0.2955;      // -   [origin=predictive method=lee-kesler]
Tb          420.91;      // K   [origin=predictive method=joback]
HvapTb      35679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.109 0.9049 -0.00055698 1.271e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-enylcyclohexene" "cyclohexene,3-(2-propenyl)-" "cyclohexene, 3-(2-propenyl)-" "3-(prop-2-en-1-yl)cyclohexene" );
gibbsFormation
{
    dHf_298   8440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167150.0
    phase     gas;
}
