/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,4-(ch3)3-1,2,3,4-tetrahydropyridine  (C8H15N, CAS 35079-50-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        144Ch331234Tetrahydropyridine;
formula     C8H15N;
CAS         35079-50-6;
InChIKey    OBNANVWKTAVJEL-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          611.27;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.3169;      // -   [origin=predictive method=lee-kesler]
Tb          409.76;      // K   [origin=predictive method=joback]
HvapTb      34843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.77 1.25536 -0.00117128 4.631e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,4-trimethyl-2,3-dihydropyridine" "1,4,4-trimethyl-1,2,3,4-tetrahydropyridine" );
standardThermochemistry
{
    dHf_298   -7420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188280.0
}
