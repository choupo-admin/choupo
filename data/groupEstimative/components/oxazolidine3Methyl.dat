/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxazolidine, 3-methyl-  (C4H9NO, CAS 27970-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxazolidine3Methyl;
formula     C4H9NO;
CAS         27970-32-7;
InChIKey    FNKSTXGVEUSZJJ-UHFFFAOYSA-N;
MW          87.122;      // g/mol [origin=calculated method=formula-sum]
Tc          534.81;      // K   [origin=predictive method=joback]
Pc          49.246;      // bar [origin=predictive method=joback]
omega       0.3123;      // -   [origin=predictive method=lee-kesler]
Tb          346.19;      // K   [origin=predictive method=joback]
HvapTb      31445.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.42 0.67252 -0.0005217 1.627e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group FCH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1,3-oxazolidine" "n-methyloxazolidine" "3-methyloxazolidine" "3-methyl-1,3-oxazolidine;3-methyloxazolidine; n-methyloxazolidine" );
gibbsFormation
{
    dHf_298   -103380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     248.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63820.0
    phase     gas;
}
