/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-chlorophenyl)(phenyl)methanamine  (C13H12ClN, CAS 28022-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorophenylPhenylMethanamine;
formula     C13H12ClN;
CAS         28022-43-7;
InChIKey    XAFODXGEQUOEKN-UHFFFAOYSA-N;
MW          217.696;      // g/mol [origin=calculated method=formula-sum]
Tc          926.26;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.6314;      // -   [origin=predictive method=lee-kesler]
Tb          664.90;      // K   [origin=predictive method=joback]
HvapTb      64384.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.74 1.0961 -0.00074576 1.891e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group CHNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-chlorophenyl)-phenyl-methanamine" "(4-chloropheny)phenylmethylamine" "4-chlorobenzhydrylamine" "(4-chlorophenyl)phenylmethylamine" "(4-chlorophenyl)-phenylmethanamine" "1-(4-chlorophenyl)-1-phenylmethylamine" "benzenemethanamine, 4-chloro-.alpha.-phenyl-" "(r)-1-(4-chlorophenyl)-1-phenylmethylamine" "4-chlorobenzhydrylamine hcl" "(4-chlorophenyl)(phenyl)methylamine" "1-(4-chlorophenyl)-1-phenylmethanamine" "benzenemethanamine, 4-chloro-alpha-phenyl-" );
standardThermochemistry
{
    dHf_298   162710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=325850.0
}
