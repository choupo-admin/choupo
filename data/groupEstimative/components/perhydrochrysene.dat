/*--------------------------------*- Choupo -*-----------------------*\
  Component: perhydrochrysene  (C18H30, CAS 2090-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perhydrochrysene;
formula     C18H30;
CAS         2090-14-4;
InChIKey    ZEMKTMFBYLHVNN-UHFFFAOYSA-N;
MW          246.438;      // g/mol [origin=calculated method=formula-sum]
Tc          893.02;      // K   [origin=predictive method=joback]
Pc          18.232;      // bar [origin=predictive method=joback]
omega       0.4891;      // -   [origin=predictive method=lee-kesler]
Tb          654.68;      // K   [origin=predictive method=joback]
HvapTb      55728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-233.29 2.2068 -0.001447 3.644e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group CH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,4a,4b,5,6,6a,7,8,9,10,10a,10b,11,12,12a-octadecahydrochrysene" "chrysene, octadecahydro-" "d-homo-18-norestrane" "octadecahydrochrysene" "chrysitane" );
standardThermochemistry
{
    dHf_298   -201290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255660.0
}
