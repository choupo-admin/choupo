/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-buten-2-ol, 3-methyl-4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, acetate  (C16H26O2, CAS 68555-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Buten2Ol3Methyl4266Trimethyl2Cyclohexen1YlAcetate;
formula     C16H26O2;
CAS         68555-61-3;
InChIKey    TYUPZTIJMKMYHL-UHFFFAOYSA-N;
MW          250.382;      // g/mol [origin=calculated method=formula-sum]
Tc          857.37;      // K   [origin=predictive method=joback]
Pc          16.714;      // bar [origin=predictive method=joback]
omega       0.6260;      // -   [origin=predictive method=lee-kesler]
Tb          646.76;      // K   [origin=predictive method=joback]
HvapTb      58190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.38 1.76692 -0.00131974 4.295e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-methyl-4-(2,6,6-trimethylcyclohex-2-en-1-yl)but-3-en-2-yl] ethanoate" "3-buten-2-ol, 3-methyl-4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, 2-acetate" );
gibbsFormation
{
    dHf_298   -493170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125720.0
    phase     gas;
}
