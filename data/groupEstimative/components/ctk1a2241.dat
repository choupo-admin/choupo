/*--------------------------------*- Choupo -*-----------------------*\
  Component: ctk1a2241  (C19H12, CAS 205-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ctk1a2241;
formula     C19H12;
CAS         205-94-7;
InChIKey    HQJPYLIAWVSUHC-UHFFFAOYSA-N;
MW          240.305;      // g/mol [origin=calculated method=formula-sum]
Tc          990.08;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.7374;      // -   [origin=predictive method=lee-kesler]
Tb          731.08;      // K   [origin=predictive method=joback]
HvapTb      66639.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.72 1.7104 -0.00156304 5.681e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 6; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   424960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=597520.0
    phase     gas;
}
