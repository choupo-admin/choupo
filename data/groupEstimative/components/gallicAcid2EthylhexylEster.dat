/*--------------------------------*- Choupo -*-----------------------*\
  Component: gallic acid, 2-ethylhexyl ester  (C15H22O5, CAS 34531-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gallicAcid2EthylhexylEster;
formula     C15H22O5;
CAS         34531-26-5;
InChIKey    MTPIQEWGULCIPM-UHFFFAOYSA-N;
MW          282.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.06;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       1.5055;      // -   [origin=predictive method=lee-kesler]
Tb          869.12;      // K   [origin=predictive method=joback]
HvapTb      97321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.685 1.76484 -0.00150108 5.345e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl 3,4,5-tris(oxidanyl)benzoate" "2-ethylhexyl 3,4,5-trihydroxybenzoate" "benzoic acid, 3,4,5-trihydroxy-, 2-ethylhexyl ester" "2-ethylhexyl gallate" "3,4,5-trihydroxybenzoic acid, 2-ethylhexyl ester" );
standardThermochemistry
{
    dHf_298   -970890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-588840.0
}
