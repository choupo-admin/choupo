/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-2,4-dimethylpentan-3-ol  (C9H20O, CAS 3970-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl24Dimethylpentan3Ol;
formula     C9H20O;
CAS         3970-59-0;
InChIKey    PZPYIRQFCOFLGJ-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          668.20;      // K   [origin=predictive method=joback]
Pc          26.164;      // bar [origin=predictive method=joback]
omega       0.7323;      // -   [origin=predictive method=lee-kesler]
Tb          493.59;      // K   [origin=predictive method=joback]
HvapTb      50235.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.839 1.0305 -0.0006744 1.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-2,4-dimethyl-pentan-3-ol" "2,4-dimethyl-3-ethyl-3-pentanol" );
standardThermochemistry
{
    dHf_298   -400630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113960.0
}
