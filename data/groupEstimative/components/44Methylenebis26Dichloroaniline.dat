/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-methylenebis(2,6-dichloroaniline)  (C13H10Cl4N2, CAS 25464-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Methylenebis26Dichloroaniline;
formula     C13H10Cl4N2;
CAS         25464-95-3;
InChIKey    YZHBFXOFILAJSC-UHFFFAOYSA-N;
MW          336.037;      // g/mol [origin=calculated method=formula-sum]
Tc          1142.64;      // K   [origin=predictive method=joback]
Pc          26.902;      // bar [origin=predictive method=joback]
omega       1.0471;      // -   [origin=predictive method=lee-kesler]
Tb          875.06;      // K   [origin=predictive method=joback]
HvapTb      91878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.601 0.875 -0.00051196 1.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group ACNH2; count 2; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Cl; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-azanyl-3,5-bis(chloranyl)phenyl]methyl]-2,6-bis(chloranyl)aniline" "benzenamine, 4,4'-methylenebis(2,6-dichloro-" "benzenamine, 4,4'-methylenebis[2,6-dichloro-" "4,4'-methanediylbis(2,6-dichloroaniline)" "4-[(4-amino-3,5-dichloro-phenyl)methyl]-2,6-dichloro-aniline" "4-[(4-amino-3,5-dichlorophenyl)methyl]-2,6-dichloroaniline" );
standardThermochemistry
{
    dHf_298   97210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310800.0
}
