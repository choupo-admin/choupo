/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentyl  (C5H11, CAS 2672-01-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        pentyl;
formula     C5H11;
CAS         2672-01-7;
InChIKey    BFKVXNPJXXJUGQ-UHFFFAOYSA-N;
role        radical;
MW          71.143;      // g/mol [origin=calculated method=formula-sum]
Tc          470.08;      // K   [origin=predictive method=joback]
Pc          35.347;      // bar [origin=predictive method=joback]
omega       0.2546;      // -   [origin=predictive method=lee-kesler]
Tb          308.60;      // K   [origin=predictive method=joback]
HvapTb      26075.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.443 0.44882 -0.0002292 4.2e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane" "amyl" "n-pentyl" "pent-1-yl" "1-pentyl radical" "1-c5h11" );
standardThermochemistry
{
    dHf_298   -79710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38950.0
}
