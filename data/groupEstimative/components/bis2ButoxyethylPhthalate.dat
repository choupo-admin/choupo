/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-butoxyethyl) phthalate  (C20H30O6, CAS 117-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2ButoxyethylPhthalate;
formula     C20H30O6;
CAS         117-83-9;
InChIKey    CMCJNODIWQEOAI-UHFFFAOYSA-N;
MW          366.454;      // g/mol [origin=calculated method=formula-sum]
Tc          1047.85;      // K   [origin=predictive method=joback]
Pc          12.346;      // bar [origin=predictive method=joback]
omega       1.0769;      // -   [origin=predictive method=lee-kesler]
Tb          850.14;      // K   [origin=predictive method=joback]
HvapTb      82686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.92 1.52944 -0.00061716 3.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-butoxyethyl) benzene-1,2-dicarboxylate" "kesscoflex" "kronisol" "palatinol k" "kesscoflex bcp" "beta-butoxyethyl phthalate" "bis(2-butoxyethyl)phthalate" "butyl glycol phthalate" "dibutylglycol phthalate" "palatinol" "dibutyl cellosolve phthalate" "di(2-butoxyethyl) phthalate" );
standardThermochemistry
{
    dHf_298   -1130070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     947.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-610440.0
}
