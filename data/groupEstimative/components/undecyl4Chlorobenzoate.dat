/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecyl 4-chlorobenzoate  (C18H27ClO2, CAS 5458-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecyl4Chlorobenzoate;
formula     C18H27ClO2;
CAS         5458-41-3;
InChIKey    MEWVVEWZGJOCOB-UHFFFAOYSA-N;
MW          310.862;      // g/mol [origin=calculated method=formula-sum]
Tc          933.47;      // K   [origin=predictive method=joback]
Pc          14.112;      // bar [origin=predictive method=joback]
omega       0.9153;      // -   [origin=predictive method=lee-kesler]
Tb          738.75;      // K   [origin=predictive method=joback]
HvapTb      70392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.22 1.52742 -0.00084536 1.555e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecyl 4-chloranylbenzoate" "4-chlorobenzoic acid, undecyl ester" );
gibbsFormation
{
    dHf_298   -522810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     829.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-118840.0
    phase     gas;
}
