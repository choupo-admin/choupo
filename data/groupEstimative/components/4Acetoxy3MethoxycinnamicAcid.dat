/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetoxy-3-methoxycinnamic acid  (C12H12O5, CAS 2596-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Acetoxy3MethoxycinnamicAcid;
formula     C12H12O5;
CAS         2596-47-6;
InChIKey    IHKNVZISLLDMOR-UHFFFAOYSA-N;
MW          236.223;      // g/mol [origin=calculated method=formula-sum]
Tc          962.83;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       1.0883;      // -   [origin=predictive method=lee-kesler]
Tb          741.11;      // K   [origin=predictive method=joback]
HvapTb      72845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.0 0.89874 -0.00047692 7.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3COO; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-acetyloxy-3-methoxy-phenyl)prop-2-enoic acid" "3-(4-acetyloxy-3-methoxyphenyl)prop-2-enoic acid" "2-propenoicacid, 3-[4-(acetyloxy)-3-methoxyphenyl]-" "(2e)-3-[4-(acetyloxy)-3-methoxyphenyl]acrylic acid" );
gibbsFormation
{
    dHf_298   -759970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-535750.0
    phase     gas;
}
