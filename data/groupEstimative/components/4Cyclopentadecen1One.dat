/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-cyclopentadecen-1-one  (C15H26O, CAS 14595-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Cyclopentadecen1One;
formula     C15H26O;
CAS         14595-54-1;
InChIKey    JIYIHILAGIZIMD-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          939.31;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.4523;      // -   [origin=predictive method=lee-kesler]
Tb          672.43;      // K   [origin=predictive method=joback]
HvapTb      55809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.17 1.2667 -0.00025428 -1.728e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentadec-4-en-1-one" "cis-4-cyclopentadecen-1-one" "musk z4" "agn-pc-02ws6b" "4-cyclopentadecen-1-one,(4z)-" "4-cyclopentadecen-1-one,(z)- (8ci); exaltenone; cis-4-cyclopentadecenone" );
standardThermochemistry
{
    dHf_298   -413630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     815.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93950.0
}
