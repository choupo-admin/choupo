/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipic acid, dipropylene glycol, methylenebis(4-cyclohexylisocyanate) polymer  (C27H46N2O9, CAS 68258-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipicAcidDipropyleneGlycolMethylenebis4Cyclohexylisocyanate;
formula     C27H46N2O9;
CAS         68258-78-6;
InChIKey    AEUVADYLJPORNN-UHFFFAOYSA-N;
MW          542.67;      // g/mol [origin=calculated method=formula-sum]
Tc          1979.87;      // K   [origin=predictive method=joback]
Pc          10.085;      // bar [origin=predictive method=joback]
omega       0.2765;      // -   [origin=predictive method=lee-kesler]
Tb          1481.06;      // K   [origin=predictive method=joback]
HvapTb      165684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 18; } { group CH; count 4; } { group OH; count 2; } { group CH2O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 11; } { group dCd; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group OH; count 2; } { group O; count 1; } { group COOH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid;1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane;3-(3-oxidanylpropoxy)propan-1-ol" "hexanedioic acid, polymer with 1,1'-methylenebis(4-isocyanatocyclohexane) and oxybis(propanol)" "hexanedioic acid; 3-(3-hydroxypropoxy)propan-1-ol; 1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" );
