/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3|a,5|a)-3-(cyclohexylmethoxy)cholestane  (C34H60O, CAS 67055-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3A5A3CyclohexylmethoxyCholestane;
formula     C34H60O;
CAS         67055-59-8;
InChIKey    WCTTZDAXXREAIV-FBLHGACZSA-N;
MW          484.853;      // g/mol [origin=calculated method=formula-sum]
Tc          1288.36;      // K   [origin=predictive method=joback]
Pc          7.404;      // bar [origin=predictive method=joback]
omega       0.6609;      // -   [origin=predictive method=lee-kesler]
Tb          1048.72;      // K   [origin=predictive method=joback]
HvapTb      90315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-374.286 4.338 -0.0032946 1.0781e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 17; } { group CH; count 9; } { group C; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 2; } { group CH2_ring; count 14; } { group CH_ring; count 7; } { group C_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,5s,8r,9s,10s,13r,14s,17r)-3-(cyclohexylmethoxy)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthrene" );
standardThermochemistry
{
    dHf_298   -624030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1150.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290650.0
}
