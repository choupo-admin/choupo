/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyl-3,6-dihydro-2h-pyran  (C6H10O, CAS 55230-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyl36Dihydro2hPyran;
formula     C6H10O;
CAS         55230-25-6;
InChIKey    QGXRIEQVMZFYOR-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          589.70;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.2606;      // -   [origin=predictive method=lee-kesler]
Tb          382.54;      // K   [origin=predictive method=joback]
HvapTb      34181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.07 0.63692 -0.00035698 6.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-pyran, 5,6-dihydro-2-methyl-" "2-methyl-5,6-dihydro-2h-pyran" );
standardThermochemistry
{
    dHf_298   -187070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     270.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32070.0
}
