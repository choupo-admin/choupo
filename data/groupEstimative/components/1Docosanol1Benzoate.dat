/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-docosanol, 1-benzoate  (C29H50O2, CAS 103403-38-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Docosanol1Benzoate;
formula     C29H50O2;
CAS         103403-38-9;
InChIKey    IACXYDVFQDGXJF-UHFFFAOYSA-N;
MW          430.717;      // g/mol [origin=calculated method=formula-sum]
Tc          1162.09;      // K   [origin=predictive method=joback]
Pc          7.441;      // bar [origin=predictive method=joback]
omega       0.6868;      // -   [origin=predictive method=lee-kesler]
Tb          948.02;      // K   [origin=predictive method=joback]
HvapTb      89831.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.969 2.62512 -0.0014904 3.023e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "docosyl benzoate" "1-docosanol, benzoate" "behenyl benzoate" "docosyl benzoate;behenyl benzoate;" );
gibbsFormation
{
    dHf_298   -722640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1230.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4660.0
    phase     gas;
}
