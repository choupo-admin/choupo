/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butoxybenzoic acid  (C11H14O3, CAS 1498-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ButoxybenzoicAcid;
formula     C11H14O3;
CAS         1498-96-0;
InChIKey    LAUFPZPAKULAGB-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          865.42;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.9125;      // -   [origin=predictive method=lee-kesler]
Tb          650.87;      // K   [origin=predictive method=joback]
HvapTb      62592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.383 0.89802 -0.00050036 9.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-butoxybenzoic acid" "4-n-butoxybenzoic acid" "benzoic acid, 4-butoxy-" "p-butyloxybenzoic acid" "4-butoxy-benzoic acid" "4-butyloxybenzoic acid" "p-n-butoxybenzoic acid" "p-n-butyloxybenzoic acid" "benzoic acid, p-butoxy-" "4-n-butyloxybenzoic acid" );
standardThermochemistry
{
    dHf_298   -527800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304390.0
}
