/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallyl terephthalate  (C14H14O4, CAS 1026-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diallylTerephthalate;
formula     C14H14O4;
CAS         1026-92-2;
InChIKey    ZDNFTNPFYCKVTB-UHFFFAOYSA-N;
MW          246.262;      // g/mol [origin=calculated method=formula-sum]
Tc          870.43;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.8380;      // -   [origin=predictive method=lee-kesler]
Tb          661.38;      // K   [origin=predictive method=joback]
HvapTb      63170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.392 1.0458 -0.00055856 7.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(prop-2-enyl) benzene-1,4-dicarboxylate" "diallyl terethiolate" "terephthalic acid, diallyl ester" "1,4-benzenedicarboxylic acid, di-2-propenyl ester" "1,4-benzenedicarboxylic acid, 1,4-di-2-propen-1-yl ester" "terephthalic acid diallyl ester" );
gibbsFormation
{
    dHf_298   -490930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275280.0
    phase     gas;
}
