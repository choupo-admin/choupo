/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-1-octyne  (C14H18, CAS 16967-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl1Octyne;
formula     C14H18;
CAS         16967-02-5;
InChIKey    YVCYLGYUDUYFQZ-UHFFFAOYSA-N;
MW          186.298;      // g/mol [origin=calculated method=formula-sum]
Tc          774.00;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       0.4915;      // -   [origin=predictive method=lee-kesler]
Tb          555.60;      // K   [origin=predictive method=joback]
HvapTb      51186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.185 1.10512 -0.00067686 1.5988e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-1-ynylbenzene" "1-octynylbenzene" "1-hexyl-2-phenylacetylene" "benzene, 1-octyn-1-yl-" "1-octyne,1-phenyl- (8ci); benzene, 1-octynyl- (9ci); 1-hexyl-2-phenylacetylene;1-octynylbenzene; 1-phenyl-1-octyne; oct-1-yn-1-ylbenzene" );
gibbsFormation
{
    dHf_298   176540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=382210.0
    phase     gas;
}
