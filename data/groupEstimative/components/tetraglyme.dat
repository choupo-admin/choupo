/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraglyme  (C10H22O5, CAS 143-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraglyme;
formula     C10H22O5;
CAS         143-24-8;
InChIKey    ZUHZGEOKBKGPSW-UHFFFAOYSA-N;
MW          222.281;      // g/mol [origin=calculated method=formula-sum]
Tc          703.04;      // K   [origin=predictive method=joback]
Pc          19.527;      // bar [origin=predictive method=joback]
omega       0.8741;      // -   [origin=predictive method=lee-kesler]
Tb          540.50;      // K   [origin=predictive method=joback]
HvapTb      49904.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (121.298 0.63784 3.48e-05 -1.662e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH3O; count 2; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-[2-[2-(2-methoxyethoxy)ethoxy]ethoxy]ethane" "tetraethylene glycol dimethyl ether" "2,5,8,11,14-pentaoxapentadecane" "glyme 5" "dimethoxytetraethylene glycol" "dimethoxytetraglycol" "bis[2-(2-methoxyethoxy)ethyl] ether" "dimethyltetraglycol" "e181 (ether)" "bis(2-(2-methoxyethoxy)ethyl) ether" "ether, bis(2-(2-methoxyethoxy)ethyl)" "ether, bis[2-(2-methoxyethoxy)ethyl]" );
standardThermochemistry
{
    dHf_298   -910830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-491680.0
}
