/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-tritolylethane  (C23H24, CAS 27497-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Tritolylethane;
formula     C23H24;
CAS         27497-47-8;
InChIKey    UELJFQQBQVFDMT-UHFFFAOYSA-N;
MW          300.445;      // g/mol [origin=calculated method=formula-sum]
Tc          1068.07;      // K   [origin=predictive method=joback]
Pc          16.391;      // bar [origin=predictive method=joback]
omega       0.7515;      // -   [origin=predictive method=lee-kesler]
Tb          820.38;      // K   [origin=predictive method=joback]
HvapTb      75218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.519 1.77956 -0.00112308 2.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 1; } { group ACCH3; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1,2-bis(4-methylphenyl)ethyl]-4-methyl-benzene" "1-[1,2-bis(4-methylphenyl)ethyl]-4-methylbenzene" );
standardThermochemistry
{
    dHf_298   151850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=448680.0
}
