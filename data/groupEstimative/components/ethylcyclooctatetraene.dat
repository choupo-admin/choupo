/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylcyclooctatetraene  (C10H12, CAS 13402-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylcyclooctatetraene;
formula     C10H12;
CAS         13402-35-2;
InChIKey    PLXZDLFMJXAOPJ-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          686.54;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.3253;      // -   [origin=predictive method=lee-kesler]
Tb          462.78;      // K   [origin=predictive method=joback]
HvapTb      40766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.569 0.79972 -0.00044588 7.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   32260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151490.0
}
