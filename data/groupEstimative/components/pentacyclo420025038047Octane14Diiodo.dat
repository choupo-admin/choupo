/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentacyclo(4.2.0.02,5.03,8.04,7)octane, 1,4-diiodo-  (C8H6I2, CAS 97229-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentacyclo420025038047Octane14Diiodo;
formula     C8H6I2;
CAS         97229-08-8;
InChIKey    ZDXGXJUGHIMJOD-UHFFFAOYSA-N;
MW          355.936;      // g/mol [origin=calculated method=formula-sum]
Tc          838.63;      // K   [origin=predictive method=joback]
Pc          40.881;      // bar [origin=predictive method=joback]
omega       0.3670;      // -   [origin=predictive method=lee-kesler]
Tb          559.20;      // K   [origin=predictive method=joback]
HvapTb      47280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-278.53 2.1678 -0.002899 1.381e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 6; } { group C; count 2; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 6; } { group C_ring; count 2; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(iodanyl)cubane" "pentacyclo[4.2.0.02,5.03,8.04,7]octane, 1,4-diiodo-" "1,4-diiodocubane" "1,4-diiodopentacyclo[4.2.0.02,5.03,8.04,7]octane" );
gibbsFormation
{
    dHf_298   321870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     0.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=487060.0
    phase     gas;
}
