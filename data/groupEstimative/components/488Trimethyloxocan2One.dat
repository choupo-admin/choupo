/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,8,8-trimethyloxocan-2-one  (C10H18O2, CAS 70333-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        488Trimethyloxocan2One;
formula     C10H18O2;
CAS         70333-06-1;
InChIKey    JUYPSDYNGRGPOO-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          712.59;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       0.4410;      // -   [origin=predictive method=lee-kesler]
Tb          501.74;      // K   [origin=predictive method=joback]
HvapTb      44230.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.45 1.28656 -0.0009838 3.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxocanone, 4,8,8-trimethyl-" );
gibbsFormation
{
    dHf_298   -517790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265800.0
    phase     gas;
}
