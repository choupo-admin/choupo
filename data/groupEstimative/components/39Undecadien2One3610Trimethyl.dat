/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,9-undecadien-2-one, 3,6,10-trimethyl-  (C14H24O, CAS 20056-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        39Undecadien2One3610Trimethyl;
formula     C14H24O;
CAS         20056-22-8;
InChIKey    FJHNHGPWIXCZGA-UHFFFAOYSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          771.69;      // K   [origin=predictive method=joback]
Pc          17.699;      // bar [origin=predictive method=joback]
omega       0.6517;      // -   [origin=predictive method=lee-kesler]
Tb          581.43;      // K   [origin=predictive method=joback]
HvapTb      53192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.907 1.3516 -0.0008945 2.4426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6,10-trimethylundeca-3,9-dien-2-one" "3,9-undecadien-2-one, 3,6,10-trimethyl-, (3e)-" );
standardThermochemistry
{
    dHf_298   -235290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78980.0
}
