/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-diethylbutylenediamine  (C8H20N2, CAS 19435-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylbutylenediamine;
formula     C8H20N2;
CAS         19435-68-8;
InChIKey    WHDUKLPCKZTPFY-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          655.03;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.7166;      // -   [origin=predictive method=lee-kesler]
Tb          482.98;      // K   [origin=predictive method=joback]
HvapTb      46274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.804 0.91624 -0.0005086 1.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-diethylbutane-1,4-diamine" "1,4-butanediamine, n,n'-diethyl-" "n,n'-diethyltetramethylenediamine" "n,n'-diethyl-1,4-butanediamine" "1,4-butanediamine, n1,n4-diethyl-" );
standardThermochemistry
{
    dHf_298   -101510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195260.0
}
