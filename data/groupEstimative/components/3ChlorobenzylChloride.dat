/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chlorobenzyl chloride  (C7H6Cl2, CAS 620-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChlorobenzylChloride;
formula     C7H6Cl2;
CAS         620-20-2;
InChIKey    DDGRAFHHXYIQQR-UHFFFAOYSA-N;
MW          161.025;      // g/mol [origin=calculated method=formula-sum]
Tc          694.39;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.3585;      // -   [origin=predictive method=lee-kesler]
Tb          466.28;      // K   [origin=predictive method=joback]
HvapTb      42884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.701 0.544 -0.00036196 9.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2Cl; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-(chloromethyl)benzene" "alpha,3-dichlorotoluene" "1-chloro-3-(chloromethyl)benzene" "m-chlorobenzyl chloride" "m-chlorbenzyl chloride" "benzene, 1-chloro-3-(chloromethyl)-" "1-chloro-3-chloromethyl-benzene" "3,alpha-dichlorotoluene" "toluene, m,.alpha.-dichloro-" "mcbc" "m,alpha-dichlorotoluene" "m,.alpha.-dichlorotoluene" );
standardThermochemistry
{
    dHf_298   5770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86980.0
}
