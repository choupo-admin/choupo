/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylicosylamine  (C22H47N, CAS 45275-74-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylicosylamine;
formula     C22H47N;
CAS         45275-74-9;
InChIKey    AYNZRGVSQNDHIX-UHFFFAOYSA-N;
MW          325.625;      // g/mol [origin=calculated method=formula-sum]
Tc          880.29;      // K   [origin=predictive method=joback]
Pc          9.007;      // bar [origin=predictive method=joback]
omega       0.8186;      // -   [origin=predictive method=lee-kesler]
Tb          715.40;      // K   [origin=predictive method=joback]
HvapTb      66609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.801 2.21776 -0.0012856 2.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 19; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylicosan-1-amine" "1-eicosanamine,n,n-dimethyl-" "eicosyldimethylamine;n,n-dimethyleicosanamine; n,n-dimethyleicosylamine" );
gibbsFormation
{
    dHf_298   -429880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1029.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245140.0
    phase     gas;
}
