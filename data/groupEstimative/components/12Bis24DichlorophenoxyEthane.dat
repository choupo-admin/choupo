/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(2,4-dichlorophenoxy)ethane  (C14H10Cl4O2, CAS 6339-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis24DichlorophenoxyEthane;
formula     C14H10Cl4O2;
CAS         6339-70-4;
InChIKey    UWGCTYZENHHSID-UHFFFAOYSA-N;
MW          352.032;      // g/mol [origin=calculated method=formula-sum]
Tc          1033.80;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       0.8679;      // -   [origin=predictive method=lee-kesler]
Tb          787.76;      // K   [origin=predictive method=joback]
HvapTb      76318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (82.112 0.8388 -0.00039164 3.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group CH2O; count 2; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Cl; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[2,4-bis(chloranyl)phenoxy]ethoxy]-2,4-bis(chloranyl)benzene" "2,4-dichloro-1-[2-(2,4-dichlorophenoxy)ethoxy]benzene" "1-[2-(2,4-dichlorophenoxy)ethoxy]-2,4-dichlorobenzene" );
gibbsFormation
{
    dHf_298   -232510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4420.0
    phase     gas;
}
