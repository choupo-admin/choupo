/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-2-methyl-4-vinyldecahydro-4-quinolinol  (C14H25NO, CAS 38463-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl2Methyl4Vinyldecahydro4Quinolinol;
formula     C14H25NO;
CAS         38463-57-9;
InChIKey    LKEYOSUGLGHCCU-UHFFFAOYSA-N;
MW          223.36;      // g/mol [origin=calculated method=formula-sum]
Tc          835.42;      // K   [origin=predictive method=joback]
Pc          22.334;      // bar [origin=predictive method=joback]
omega       0.9081;      // -   [origin=predictive method=lee-kesler]
Tb          638.41;      // K   [origin=predictive method=joback]
HvapTb      63383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.189 1.98364 -0.0016267 5.705e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethenyl-1-ethyl-2-methyl-2,3,4a,5,6,7,8,8a-octahydroquinolin-4-ol" "4-quinolinol,4-ethenyl-1-ethyldecahydro-2-methyl-(2.alpha.,4.alpha.,4a.alpha.,8a.beta.)" "4-quinolinol,4-ethenyl-1-ethyldecahydro-2-methyl-(2.alpha.,4.alpha.,4a.beta.,8a.alpha." "4-quinolinol,4-ethenyl-1-ethyldecahydro-2-methyl-(2.alpha.,4.beta.,4a.alpha.,8a.beta.)" "4-quinolinol, 4-ethenyl-1-ethyldecahydro-2-methyl-, (2alpha,4beta,4aalpha,8abeta)-" "(2s,4s,4ar,8ar)-4-ethenyl-1-ethyl-2-methyl-2,3,4a,5,6,7,8,8a-octahydroquinolin-4-ol" "4-quinolinol, 4-ethenyl-1-ethyldecahydro-2-methyl-, (2alpha,4alpha,4aalpha,8abeta)-" "4-quinolinol, 4-ethenyl-1-ethyldecahydro-2-methyl-, (2alpha,4alpha,4abeta,8aalpha)-" );
standardThermochemistry
{
    dHf_298   -189880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193090.0
}
