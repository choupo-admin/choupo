/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-benzyloxy-1-pentanol  (C12H18O2, CAS 4541-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Benzyloxy1Pentanol;
formula     C12H18O2;
CAS         4541-15-5;
InChIKey    RZVDPWSEPVHOPU-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          802.27;      // K   [origin=predictive method=joback]
Pc          25.925;      // bar [origin=predictive method=joback]
omega       1.0393;      // -   [origin=predictive method=lee-kesler]
Tb          615.44;      // K   [origin=predictive method=joback]
HvapTb      63671.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.134 1.0357 -0.0005796 1.121e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-phenylmethoxypentan-1-ol" "1-pentanol, 5-(benzyloxy)-" "1-pentanol, 5-(phenylmethoxy)-" "5-(benzyloxy)pentan-1-ol" );
standardThermochemistry
{
    dHf_298   -338930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79250.0
}
