/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3a,4,7,7a-tetrahydro-4,7-methano-1h-indene, 5-methylbicyclo(2.2.1)hept-2-ene polymer  (C18H24, CAS 69376-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3a477aTetrahydro47Methano1hIndene5Methylbicyclo221Hept2EnePo;
formula     C18H24;
CAS         69376-38-1;
InChIKey    UHVLIRYVSXIAOE-UHFFFAOYSA-N;
MW          240.39;      // g/mol [origin=calculated method=formula-sum]
Tc          880.53;      // K   [origin=predictive method=joback]
Pc          19.036;      // bar [origin=predictive method=joback]
omega       0.4905;      // -   [origin=predictive method=lee-kesler]
Tb          643.22;      // K   [origin=predictive method=joback]
HvapTb      56123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-198.89 2.02192 -0.00139984 3.787e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 7; } { group CH=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 7; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-methano-1h-indene, 3a,4,7,7a-tetrahydro-, polymer with 5-methylbicyclo(2.2.1)hept-2-ene" );
gibbsFormation
{
    dHf_298   -42130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349930.0
    phase     gas;
}
