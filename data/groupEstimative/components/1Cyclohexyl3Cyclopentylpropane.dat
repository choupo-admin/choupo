/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexyl-3-cyclopentylpropane  (C14H26, CAS 2883-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexyl3Cyclopentylpropane;
formula     C14H26;
CAS         2883-07-0;
InChIKey    CPBZARXQRZTYGI-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          770.66;      // K   [origin=predictive method=joback]
Pc          21.100;      // bar [origin=predictive method=joback]
omega       0.4587;      // -   [origin=predictive method=lee-kesler]
Tb          554.75;      // K   [origin=predictive method=joback]
HvapTb      47444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.927 1.5876 -0.0009462 2.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 9; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclopentylpropylcyclohexane" "cyclohexane, (3-cyclopentylpropyl)-" "propane, 1-cyclohexyl-3-cyclopentyl-" "(3-cyclopentylpropyl)cyclohexane" );
gibbsFormation
{
    dHf_298   -217490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128000.0
    phase     gas;
}
