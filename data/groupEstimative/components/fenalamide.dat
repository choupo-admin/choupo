/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenalamide  (C19H30N2O3, CAS 4551-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenalamide;
formula     C19H30N2O3;
CAS         4551-59-1;
InChIKey    RMQKPRRJSKFBRU-UHFFFAOYSA-N;
MW          334.46;      // g/mol [origin=calculated method=formula-sum]
Tc          1036.91;      // K   [origin=predictive method=joback]
Pc          14.646;      // bar [origin=predictive method=joback]
omega       1.0987;      // -   [origin=predictive method=lee-kesler]
Tb          832.47;      // K   [origin=predictive method=joback]
HvapTb      81500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.894 1.97308 -0.0012607 2.9406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group COO; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-[2-(diethylamino)ethylcarbamoyl]-2-phenyl-butanoate" "spasmamide" "femamide" "phenamide" "fenalamidum [inn-latin]" "ethyl n-(2-diethylaminoethyl)-2-phenyl-2-ethylmalonate" "n-(2-(diethylamino)ethyl)-2-ethyl-2-phenylmalonamic acid ethyl ester" "phenylaethylmalonsaeure-aethylester-diaethylaminoaethyl-amid [german]" "benzeneacetic acid, alpha-(((2-(diethylamino)ethyl)amino)carbonyl)-alpha-ethyl-, ethyl ester" "malonamic acid, n-(2-(diethylamino)ethyl)-2-ethyl-2-phenyl-, ethyl ester" "fenalamida" "fenalamidum" );
standardThermochemistry
{
    dHf_298   -516570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     885.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14770.0
}
