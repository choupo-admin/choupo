/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexylethanamine  (C8H17N, CAS 4442-85-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexylethanamine;
formula     C8H17N;
CAS         4442-85-7;
InChIKey    HFACYWDPMNWMIW-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          689.50;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.4369;      // -   [origin=predictive method=lee-kesler]
Tb          474.72;      // K   [origin=predictive method=joback]
HvapTb      44472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.498 0.9478 -0.0005358 1.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexaneethanamine" "cyclohexaneethylamine" "2-cyclohexylethylamine" "2-aminoethylcyclohexane" "2-cyclohexyl ethylamine" "2-cyclohexyl-ethylamine" "ethylamine, 2-cyclohexyl-" "2-cyclohexylethan-1-amine" "cyclohexaneethanamine (9ci)" "cyclohexaneethylamine (8ci)" "1-amino-2-cyclohexylethane" "(2-cyclohexylethyl)amine hydrochloride" );
gibbsFormation
{
    dHf_298   -120340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107380.0
    phase     gas;
}
