/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[(4-methylphenyl)thio]propionic acid  (C10H12O2S, CAS 13739-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34MethylphenylThioPropionicAcid;
formula     C10H12O2S;
CAS         13739-35-0;
InChIKey    ZRYGVBRPRKRFHJ-UHFFFAOYSA-N;
MW          196.264;      // g/mol [origin=calculated method=formula-sum]
Tc          912.01;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.8569;      // -   [origin=predictive method=lee-kesler]
Tb          674.35;      // K   [origin=predictive method=joback]
HvapTb      64773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.608 0.86061 -0.00051676 1.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-methylphenyl)sulfanylpropanoic acid" "3-(p-tolylthio)propionic acid" "3-p-tolylsulfanyl-propionic acid" "3-[(4-methylphenyl)thio]propanoic acid" "3-[(4-methylphenyl)sulfanyl]propanoic acid" "3-((4-methylphenyl)thio)propionic acid" "3-(4-methylphenylthio)propanoic acid" "propanoic acid, 3-[(4-methylphenyl)thio]-" );
standardThermochemistry
{
    dHf_298   -333070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174690.0
}
