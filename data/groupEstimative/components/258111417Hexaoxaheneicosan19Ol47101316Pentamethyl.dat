/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,8,11,14,17-hexaoxaheneicosan-19-ol, 4,7,10,13,16-pentamethyl-  (C20H42O7, CAS 72187-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        258111417Hexaoxaheneicosan19Ol47101316Pentamethyl;
formula     C20H42O7;
CAS         72187-25-8;
InChIKey    PNVMQWAENBPTDS-UHFFFAOYSA-N;
MW          394.549;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.54;      // K   [origin=predictive method=joback]
Pc          10.406;      // bar [origin=predictive method=joback]
omega       0.9977;      // -   [origin=predictive method=lee-kesler]
Tb          881.26;      // K   [origin=predictive method=joback]
HvapTb      88925.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (132.907 1.59414 -0.0004478 -9.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 5; } { group CH3O; count 1; } { group CH2O; count 4; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 7; } { group CH; count 6; } { group OH; count 1; } { group O; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1-[1-[1-[1-(1-methoxypropan-2-yloxy)propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]propan-2-yloxy]butan-2-ol" "5,8,11,14,17,20-hexaoxaheneicosan-3-ol, 6,9,12,15,18-pentamethyl-" );
gibbsFormation
{
    dHf_298   -1433360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     996.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-663940.0
    phase     gas;
}
