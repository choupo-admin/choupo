/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-cyclohexanediol  (C6H12O2, CAS 556-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Cyclohexanediol;
formula     C6H12O2;
CAS         556-48-9;
InChIKey    VKONPUDBRVKQLM-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          720.63;      // K   [origin=predictive method=joback]
Pc          48.360;      // bar [origin=predictive method=joback]
omega       1.1304;      // -   [origin=predictive method=lee-kesler]
Tb          536.12;      // K   [origin=predictive method=joback]
HvapTb      62428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.65 0.7374 -0.000389 6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane-1,4-diol" "trans-1,4-cyclohexanediol" "cis-1,4-cyclohexanediol" "quinitol" "1,4-cyclohexanediol, trans-" "1,4-cyclohexanediol, cis-" "trans-1,4-dihydroxycyclohexane" "cis-cyclohexane-1,4-diol" "trans-cyclohexane-1,4-diol" "hexahydrohydroquinone" "cis-1,4-dihydroxycyclohexane" "1,4-dihydroxycyclohexane" );
gibbsFormation
{
    dHf_298   -437650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-257260.0
    phase     gas;
}
