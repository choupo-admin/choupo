/*--------------------------------*- Choupo -*-----------------------*\
  Component: monoethyl fumarate  (C6H8O4, CAS 2459-05-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monoethylFumarate;
formula     C6H8O4;
CAS         2459-05-4;
InChIKey    XLYMOEINVGRTEX-ONEGZZNKSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          747.39;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.8169;      // -   [origin=predictive method=lee-kesler]
Tb          544.77;      // K   [origin=predictive method=joback]
HvapTb      53479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.261 0.58982 -0.0003644 7.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-ethoxy-4-oxidanylidene-but-2-enoic acid" "fumaric acid monoethyl ester" "ethyl hydrogen fumarate" "mono-ethyl fumarate" "fumaric acid, monoethyl ester" "(e)-4-ethoxy-4-oxobut-2-enoic acid" "(e)-4-ethoxy-4-oxo-2-butenoic acid" "(2e)-4-ethoxy-4-oxobut-2-enoic acid" "(2e)-3-(ethoxycarbonyl)prop-2-enoic acid" "fumaric acid, ethyl ester" "magnesium diethyl difumarate" "monoethyl trans-2-butenedioate" );
standardThermochemistry
{
    dHf_298   -717500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-574420.0
}
