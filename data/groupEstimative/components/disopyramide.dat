/*--------------------------------*- Choupo -*-----------------------*\
  Component: disopyramide  (C21H29N3O, CAS 3737-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        disopyramide;
formula     C21H29N3O;
CAS         3737-09-5;
InChIKey    UVTNFZQICZKOEM-UHFFFAOYSA-N;
MW          339.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1164.54;      // K   [origin=predictive method=joback]
Pc          17.104;      // bar [origin=predictive method=joback]
omega       1.0649;      // -   [origin=predictive method=lee-kesler]
Tb          921.87;      // K   [origin=predictive method=joback]
HvapTb      90460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.628 2.17024 -0.00150576 4.0176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group C5H4N; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[di(propan-2-yl)amino]-2-phenyl-2-pyridin-2-yl-butanamide" "dicorantil" "ritmodan" "rythmodan" "disopiramida" "disopyramidum" "isorythm" "lispine" "disopyramidum [inn-latin]" "xi-disopyramide" "rythmodan-la" "rythmodan p" );
standardThermochemistry
{
    dHf_298   -1490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     810.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=474080.0
}
