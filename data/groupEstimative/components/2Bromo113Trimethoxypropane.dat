/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1,1,3-trimethoxypropane  (C6H13BrO3, CAS 759-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo113Trimethoxypropane;
formula     C6H13BrO3;
CAS         759-97-7;
InChIKey    GAFSXURUCDQGFB-UHFFFAOYSA-N;
MW          213.071;      // g/mol [origin=calculated method=formula-sum]
Tc          659.94;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.5928;      // -   [origin=predictive method=lee-kesler]
Tb          469.42;      // K   [origin=predictive method=joback]
HvapTb      41839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.761 0.43426 -4.74e-05 -7.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH3O; count 3; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,1,3-trimethoxy-propane" "propane, 2-bromo-1,1,3-trimethoxy-" "1-bromo-2-methoxypropional dimethylacetal" "2-bromo-3-methoxypropionaldehyde dimethyl acetal" "propionaldehyde, 2-bromo-3-methoxy-, dimethyl acetal" "propane,1,3-trimethoxy-" "propane,2-bromo-1,1,3-trimethoxy-" );
gibbsFormation
{
    dHf_298   -548060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-305920.0
    phase     gas;
}
