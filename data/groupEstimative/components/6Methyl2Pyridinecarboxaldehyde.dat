/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyl-2-pyridinecarboxaldehyde  (C7H7NO, CAS 1122-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H7NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        6Methyl2Pyridinecarboxaldehyde;
formula     C7H7NO;
CAS         1122-72-1;
InChIKey    AHISYUZBWDSPQL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          121.139;      // g/mol [origin=calculated method=formula-sum]
Tc          647.13;      // K   [origin=predictive method=joback]
Pc          42.775;      // bar [origin=predictive method=joback]
omega       0.2898;      // -   [origin=predictive method=lee-kesler]
Tb          421.54;      // K   [origin=predictive method=joback]
HvapTb      37951.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.52 0.57228 -0.00048342 1.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHO; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylpyridine-2-carbaldehyde" "6-methylpicolinaldehyde" "2-formyl-6-methylpyridine" "6-methylpyridine-2-carboxaldehyde" "2-picoline-6-carboxaldehyde" "6-methylpyridine-2-aldehyde" "2-formyl-6-picoline" "2-pyridinecarboxaldehyde, 6-methyl-" "6-methyl-2-pyridinecarbaldehyde" "6-methyl-2-picolinaldehyde" "6-methylpyridyl-2-aldehyde" "picolinaldehyde, 6-methyl-" );
gibbsFormation
{
    dHf_298   146490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=231850.0
    phase     gas;
}
