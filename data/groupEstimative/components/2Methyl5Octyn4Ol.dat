/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-5-octyn-4-ol  (C9H16O, CAS 60657-70-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl5Octyn4Ol;
formula     C9H16O;
CAS         60657-70-7;
InChIKey    YBGQRUFRRPFNKW-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          691.17;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       0.7462;      // -   [origin=predictive method=lee-kesler]
Tb          505.82;      // K   [origin=predictive method=joback]
HvapTb      53683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.192 0.75486 -0.00041046 8.368e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyloct-5-yn-4-ol" "2-methyl-5-octyn-4-ol;" "5-octyn-4-ol, 2-methyl-" );
gibbsFormation
{
    dHf_298   -119580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86000.0
    phase     gas;
}
