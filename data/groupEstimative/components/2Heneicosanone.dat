/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heneicosanone  (C21H42O, CAS 22589-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heneicosanone;
formula     C21H42O;
CAS         22589-04-4;
InChIKey    VUVUIDMZOWHIIJ-UHFFFAOYSA-N;
MW          310.566;      // g/mol [origin=calculated method=formula-sum]
Tc          904.98;      // K   [origin=predictive method=joback]
Pc          9.945;      // bar [origin=predictive method=joback]
omega       0.8837;      // -   [origin=predictive method=lee-kesler]
Tb          733.95;      // K   [origin=predictive method=joback]
HvapTb      69086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.842 1.97084 -0.0010999 2.2966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "henicosan-2-one" "heneicosa-2-one" "heneicosan-2-one" );
gibbsFormation
{
    dHf_298   -589350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1000.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2980.0
    phase     gas;
}
