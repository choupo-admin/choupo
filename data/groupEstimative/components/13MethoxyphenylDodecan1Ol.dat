/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-methoxyphenyl)dodecan-1-ol  (C19H32O2, CAS 29665-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13MethoxyphenylDodecan1Ol;
formula     C19H32O2;
CAS         29665-46-1;
InChIKey    VWGZSBISNACTFM-UHFFFAOYSA-N;
MW          292.463;      // g/mol [origin=calculated method=formula-sum]
Tc          966.15;      // K   [origin=predictive method=joback]
Pc          14.315;      // bar [origin=predictive method=joback]
omega       1.1477;      // -   [origin=predictive method=lee-kesler]
Tb          780.14;      // K   [origin=predictive method=joback]
HvapTb      79527.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.88 1.64714 -0.00089656 1.7e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzyl alcohol, m-methoxy-alpha-undecyl-" "benzyl alcohol, m-methoxy-.alpha.-undecyl" );
gibbsFormation
{
    dHf_298   -500160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     836.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32380.0
    phase     gas;
}
