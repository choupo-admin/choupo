/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, 1,4-bis(chloromethyl)-  (C8H14Cl2, CAS 824-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane14BisChloromethyl;
formula     C8H14Cl2;
CAS         824-93-1;
InChIKey    VUBDYLKZHRQEBS-UHFFFAOYSA-N;
MW          181.1;      // g/mol [origin=calculated method=formula-sum]
Tc          686.89;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.3578;      // -   [origin=predictive method=lee-kesler]
Tb          472.38;      // K   [origin=predictive method=joback]
HvapTb      42292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.268 0.873 -0.0004778 8.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(chloromethyl)cyclohexane" "cyclohexane,4-bis(chloromethyl)-" );
standardThermochemistry
{
    dHf_298   -205950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9360.0
}
