/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, pentachlorotrifluoro-  (C3Cl5F3, CAS 1652-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanePentachlorotrifluoro;
formula     C3Cl5F3;
CAS         1652-89-7;
InChIKey    GKXWTRSVUPXQMM-UHFFFAOYSA-N;
MW          270.277;      // g/mol [origin=calculated method=formula-sum]
Tc          657.07;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.3275;      // -   [origin=predictive method=lee-kesler]
Tb          443.51;      // K   [origin=predictive method=joback]
HvapTb      37858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.47 0.7356 -0.000806 3.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 1; } { group CCl3; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 3; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2-pentakis(chloranyl)-3,3,3-tris(fluoranyl)propane" "1,1,1-trifluoro-2,2,3,3,3-pentachloro propane" "1,1,1,2,2-pentachloro-3,3,3-trifluoropropane" "propane, 1,1,1,2,2-pentachloro-3,3,3-trifluoro-" "2,2,3,3,3-pentachloro-1,1,1-trifluoropropane" "1,1,1-trifluoro-2,2,3,3,3-pentachloro-propane" );
standardThermochemistry
{
    dHf_298   -798530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-661180.0
}
