/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyloct-6-en-1-yn-3-yl propionate  (C13H20O2, CAS 65416-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyloct6En1Yn3YlPropionate;
formula     C13H20O2;
CAS         65416-30-0;
InChIKey    VFZVKWGNULCLCW-UHFFFAOYSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          742.70;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       0.5569;      // -   [origin=predictive method=lee-kesler]
Tb          546.19;      // K   [origin=predictive method=joback]
HvapTb      50539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.087 1.23588 -0.00084263 2.2589e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group tCH; count 1; } { group tC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-6-en-1-yn-3-yl propanoate" "6-octen-1-yn-3-ol, 3,7-dimethyl-, propanoate" "6-octen-1-yn-3-ol, 3,7-dimethyl-, 3-propanoate" );
gibbsFormation
{
    dHf_298   -238350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45790.0
    phase     gas;
}
