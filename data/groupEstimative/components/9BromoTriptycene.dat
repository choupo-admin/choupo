/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-bromo triptycene  (C20H13Br, CAS 15364-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9BromoTriptycene;
formula     C20H13Br;
CAS         15364-55-3;
InChIKey    HSROKCVTEYMWHO-UHFFFAOYSA-N;
MW          333.228;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.43;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.8145;      // -   [origin=predictive method=lee-kesler]
Tb          814.98;      // K   [origin=predictive method=joback]
HvapTb      73350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-195.91 2.1589 -0.00218668 8.789e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 12; } { group AC; count 5; } { group ACCH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10(1',2')-benzenoanthracene, 9-bromo-9,10-dihydro-" "9,10[1',2']-benzenoanthracene, 9-bromo-9,10-dihydro-" "1-bromohexacyclo[6.6.5.1<15,19>.0<1,18>.0<2,7>.0<9,14>]icosa-2(7),3,5,9(14),10 ,12,15,17,19-nonaene" "1-bromopentacyclo[6.6.6.02,7.09,14.015,20]icosa-2,4,6,9,11,13,15,17,19-nonaene (non-preferred name)" );
standardThermochemistry
{
    dHf_298   430860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=604590.0
}
