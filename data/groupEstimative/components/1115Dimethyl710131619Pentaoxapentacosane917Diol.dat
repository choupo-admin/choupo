/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11,15-dimethyl-7,10,13,16,19-pentaoxapentacosane-9,17-diol  (C22H46O7, CAS 73179-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1115Dimethyl710131619Pentaoxapentacosane917Diol;
formula     C22H46O7;
CAS         73179-35-8;
InChIKey    IUQSQGHDEWZMCR-UHFFFAOYSA-N;
MW          422.603;      // g/mol [origin=calculated method=formula-sum]
Tc          1249.84;      // K   [origin=predictive method=joback]
Pc          9.772;      // bar [origin=predictive method=joback]
omega       0.7108;      // -   [origin=predictive method=lee-kesler]
Tb          997.66;      // K   [origin=predictive method=joback]
HvapTb      108422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (114.244 1.86948 -0.0006916 -5.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH2O; count 1; } { group CH-O; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group CH; count 4; } { group OH; count 2; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexoxy-1-[1-[2-(2-hexoxy-1-oxidanyl-ethoxy)propoxy]propan-2-yloxy]ethanol" "7,10,13,16,19-pentaoxapentacosane-9,17-diol, 11,15-dimethyl-" "7,10,13,16,19-pentaoxapentacosane-9,17-diol,11,15-dimethyl-" "2-hexoxy-1-[1-[2-(2-hexoxy-1-hydroxyethoxy)propoxy]propan-2-yloxy]ethanol" );
gibbsFormation
{
    dHf_298   -1484090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1132.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-674040.0
    phase     gas;
}
