/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1-cyclopentenecarboxylate  (C7H10O2, CAS 25662-28-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1Cyclopentenecarboxylate;
formula     C7H10O2;
CAS         25662-28-6;
InChIKey    VTYCAXIAUKEGBQ-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          648.64;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.4232;      // -   [origin=predictive method=lee-kesler]
Tb          442.07;      // K   [origin=predictive method=joback]
HvapTb      40103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.41 0.65672 -0.00036544 6.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl cyclopentene-1-carboxylate" "methyl 1-cyclopentene-1-carboxylate" "methyl cyclopent-1-enecarboxylate" "cyclopentene-1-carboxylic acid methyl ester" "methyl cyclopent-1-ene-1-carboxylate" "1-cyclopentenecarboxylic acid methyl ester" "n535" "1-cyclopentene-1-carboxylic acid methyl ester" "1-cyclopentene-1-carboxylicacid, methyl ester" "1-cyclopentene-1-carboxylic acid, methyl ester" );
gibbsFormation
{
    dHf_298   -377960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237720.0
    phase     gas;
}
