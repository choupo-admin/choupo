/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.2.2.02,5]dec-7-ene,9,10-bis(methylene)-(1.alpha.,2.alpha.,5.alpha.,6.alpha.)-  (C12H14, CAS 57297-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo422025Dec7Ene910BisMethylene1Alpha2Alpha5Alpha6Alpha;
formula     C12H14;
CAS         57297-56-0;
InChIKey    ZOFZXGBHQXCMJY-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          705.09;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.4094;      // -   [origin=predictive method=lee-kesler]
Tb          491.46;      // K   [origin=predictive method=joback]
HvapTb      42518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.57 1.2694 -0.00099028 3.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   127150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     240.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348720.0
    phase     gas;
}
