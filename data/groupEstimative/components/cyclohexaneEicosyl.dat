/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, eicosyl-  (C26H52, CAS 4443-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexaneEicosyl;
formula     C26H52;
CAS         4443-55-4;
InChIKey    PSPNTGGVAYLSJO-UHFFFAOYSA-N;
MW          364.702;      // g/mol [origin=calculated method=formula-sum]
Tc          999.32;      // K   [origin=predictive method=joback]
Pc          8.121;      // bar [origin=predictive method=joback]
omega       0.7508;      // -   [origin=predictive method=lee-kesler]
Tb          814.03;      // K   [origin=predictive method=joback]
HvapTb      73899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.351 2.59592 -0.0014716 3.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 24; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosylcyclohexane" "eicosane, 1-cyclohexyl-" "n-eicosylcyclohexane" "1-cyclohexyleicosane" );
gibbsFormation
{
    dHf_298   -525650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1138.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192490.0
    phase     gas;
}
