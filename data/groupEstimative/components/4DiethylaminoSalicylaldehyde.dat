/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(diethylamino)salicylaldehyde  (C11H15NO2, CAS 17754-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H15NO2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4DiethylaminoSalicylaldehyde;
formula     C11H15NO2;
CAS         17754-90-4;
InChIKey    XFVZSRRZZNLWBW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          765.25;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.6803;      // -   [origin=predictive method=lee-kesler]
Tb          552.42;      // K   [origin=predictive method=joback]
HvapTb      55702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.828 1.19704 -0.00106072 3.875e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CHO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(diethylamino)-2-oxidanyl-benzaldehyde" "4-(diethylamino)-2-hydroxybenzaldehyde" "4-diethylaminosalicylaldehyde" "benzaldehyde, 4-(diethylamino)-2-hydroxy-" "p-(diethylamino)salicylaldehyde" "2-hydroxy-4-diethylaminobenzaldehyde" "4-diethylamino-2-hydroxybenzaldehyde" "4-n,n-diethylaminosalicylic aldehyde" "salicylaldehyde, 4-(diethylamino)- (6ci,8ci)" "4-(n,n-diethylamino)salicylaldehyde" "salicylaldehyde,4-(diethylamino)- (6ci,8ci);4-(diethylamino)-2-hydroxybenzaldehyde;4-(n,n-diethylamino)-2-hydroxybenzaldehyde;p-(diethylamino)salicylaldehyde;" );
gibbsFormation
{
    dHf_298   -78640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144640.0
    phase     gas;
}
