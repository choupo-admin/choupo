/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3.3.3]propellane-2-one, 8,9-bis(methylene)-  (C13H16O, CAS 58435-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Propellane2One89BisMethylene;
formula     C13H16O;
CAS         58435-05-5;
InChIKey    FRBFVMMKTNLPDM-UHFFFAOYSA-N;
MW          188.27;      // g/mol [origin=calculated method=formula-sum]
Tc          847.04;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.5064;      // -   [origin=predictive method=lee-kesler]
Tb          597.09;      // K   [origin=predictive method=joback]
HvapTb      47187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.81 1.8793 -0.001943 8.346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 2; } { group CH2=C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 6; } { group C_ring; count 2; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3.3.3)-propellane-2-one, 8,9-bis(methylene)-" "6,7-dimethylidenetetrahydro-1h,4h-3a,6a-propanopentalen-1-one" );
gibbsFormation
{
    dHf_298   -23970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196930.0
    phase     gas;
}
