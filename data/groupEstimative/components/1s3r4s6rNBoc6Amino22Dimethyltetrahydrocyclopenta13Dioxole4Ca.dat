/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s,3r,4s,6r)-n-boc-6-amino-2,2-dimethyltetrahydrocyclopenta[1.3]dioxole-4-carb acid  (C9H15NO4, CAS 220497-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s3r4s6rNBoc6Amino22Dimethyltetrahydrocyclopenta13Dioxole4Ca;
formula     C9H15NO4;
CAS         220497-93-8;
InChIKey    VVNDXTWUBVAXBA-VZFHVOOUSA-N;
MW          201.222;      // g/mol [origin=calculated method=formula-sum]
Tc          920.64;      // K   [origin=predictive method=joback]
Pc          34.684;      // bar [origin=predictive method=joback]
omega       0.9529;      // -   [origin=predictive method=lee-kesler]
Tb          685.71;      // K   [origin=predictive method=joback]
HvapTb      70545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.46 1.46054 -0.001268 4.697e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH-O; count 2; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group C_ring; count 1; } { group O_ring; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3as,4r,6s,6as)-4-azanyl-2,2-dimethyl-4,5,6,6a-tetrahydro-3ah-cyclopenta[d][1,3]dioxole-6-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -722070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     310.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-356120.0
}
