/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-2-amino-2-phenylacetamide  (C8H10N2O, CAS 6485-67-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2Amino2Phenylacetamide;
formula     C8H10N2O;
CAS         6485-67-2;
InChIKey    KIYRSYYOVDHSPG-SSDOTTSWSA-N;
MW          150.181;      // g/mol [origin=calculated method=formula-sum]
Tc          854.02;      // K   [origin=predictive method=joback]
Pc          46.277;      // bar [origin=predictive method=joback]
omega       0.7634;      // -   [origin=predictive method=lee-kesler]
Tb          607.81;      // K   [origin=predictive method=joback]
HvapTb      63318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.63 0.7866 -0.0005139 1.2196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CHNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanyl-2-phenyl-ethanamide" "(2r)-2-amino-2-phenylacetamide" "d(-)-phenylglycinamide" "h-d-phg-nh2" "d-(-)-phenylglycine amide" );
gibbsFormation
{
    dHf_298   -22200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130430.0
    phase     gas;
}
