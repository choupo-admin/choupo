/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-(2-(2-chloroethoxy)ethoxy)-2-methyl-4-(1,1,3,3-tetramethylbutyl)-  (C19H31ClO2, CAS 65925-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene122ChloroethoxyEthoxy2Methyl41133Tetramethylbutyl;
formula     C19H31ClO2;
CAS         65925-29-3;
InChIKey    ANJNNGCPSIRLMC-UHFFFAOYSA-N;
MW          326.905;      // g/mol [origin=calculated method=formula-sum]
Tc          951.32;      // K   [origin=predictive method=joback]
Pc          12.995;      // bar [origin=predictive method=joback]
omega       0.7769;      // -   [origin=predictive method=lee-kesler]
Tb          746.77;      // K   [origin=predictive method=joback]
HvapTb      68101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.745 1.74302 -0.00104892 2.338e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 5; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(2-chloroethyloxy)ethoxy]-2-methyl-4-(2,4,4-trimethylpentan-2-yl)benzene" "benzene, 1-[2-(2-chloroethoxy)ethoxy]-2-methyl-4-(1,1,3,3-tetramethylbutyl)-" "1-[2-(2-chloroethoxy)ethoxy]-2-methyl-4-(2,4,4-trimethylpentan-2-yl)benzene" );
standardThermochemistry
{
    dHf_298   -519580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14000.0
}
