/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5-tp methyl ester  (C10H9Cl3O3, CAS 4841-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        245TpMethylEster;
formula     C10H9Cl3O3;
CAS         4841-20-7;
InChIKey    YTAXYXOJOYIQQO-UHFFFAOYSA-N;
MW          283.529;      // g/mol [origin=calculated method=formula-sum]
Tc          889.23;      // K   [origin=predictive method=joback]
Pc          24.826;      // bar [origin=predictive method=joback]
omega       0.7658;      // -   [origin=predictive method=lee-kesler]
Tb          662.51;      // K   [origin=predictive method=joback]
HvapTb      64700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (90.69 0.60474 -0.00020908 -2.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 1; } { group CH-O; count 1; } { group ACCl; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-[2,4,5-tris(chloranyl)phenoxy]propanoate" "propanoic acid, 2-(2,4,5-trichlorophenoxy)-, methyl ester" "methyl 2-(2,4,5-trichlorophenoxy)propanoate" "methyl 2-(2,4,5-trichlorophenoxy)propionate" "fenoprop-methyl" "silvex methyl ester" "silvex, methyl ester" "fenoprop-methyl [iso]" "silvex(r) methyl ester" "silvex&reg; methyl ester" "2-(2,4,5-trichlorophenoxy)propionic acid methyl ester" "propanoic acid,2-(2,4,5-trichlorophenoxy)-, methyl ester" );
gibbsFormation
{
    dHf_298   -549610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-336760.0
    phase     gas;
}
