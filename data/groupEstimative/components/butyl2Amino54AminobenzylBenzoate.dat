/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-amino-5-(4-aminobenzyl)benzoate  (C18H22N2O2, CAS 66037-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2Amino54AminobenzylBenzoate;
formula     C18H22N2O2;
CAS         66037-56-7;
InChIKey    BBZZGMZYNGWQBB-UHFFFAOYSA-N;
MW          298.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1119.38;      // K   [origin=predictive method=joback]
Pc          20.475;      // bar [origin=predictive method=joback]
omega       1.1625;      // -   [origin=predictive method=lee-kesler]
Tb          883.02;      // K   [origin=predictive method=joback]
HvapTb      90889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.004 1.44652 -0.00080888 1.442e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group ACNH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group COO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 5-[(4-aminophenyl)methyl]-2-azanyl-benzoate" "benzoic acid, 2-amino-5-((4-aminophenyl)methyl)-, butyl ester" "benzoic acid, 2-amino-5-[(4-aminophenyl)methyl]-, butyl ester" "butyl 2-amino-5-[(4-aminophenyl)methyl]benzoate" );
gibbsFormation
{
    dHf_298   -225900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119140.0
    phase     gas;
}
