/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-methoxyethyl) but-2-enedioate  (C10H16O6, CAS 10232-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2MethoxyethylBut2Enedioate;
formula     C10H16O6;
CAS         10232-93-6;
InChIKey    INJVHPRSHKTTBD-UHFFFAOYSA-N;
MW          232.232;      // g/mol [origin=calculated method=formula-sum]
Tc          774.20;      // K   [origin=predictive method=joback]
Pc          21.633;      // bar [origin=predictive method=joback]
omega       0.9206;      // -   [origin=predictive method=lee-kesler]
Tb          593.84;      // K   [origin=predictive method=joback]
HvapTb      57446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (81.434 0.73784 -0.0001928 -6.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=CH; count 1; } { group CH3O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-03muzv" "bis(2-methoxyethyl) (e)-but-2-enedioate" "2-butenedioic acid(2z)-, bis(2-methoxyethyl) ester (9ci)" "2-butenedioicacid (z)-, bis(2-methoxyethyl) ester; maleic acid, bis(2-methoxyethyl) ester(8ci); bis(2-methoxyethyl) maleate; di(2-methoxyethyl) maleate; methoxyethyleneglycol maleate" );
gibbsFormation
{
    dHf_298   -1031510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     664.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-717200.0
    phase     gas;
}
