/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propene, 1,2-dichloro-, (e)-  (C3H4Cl2, CAS 7069-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propene12DichloroE;
formula     C3H4Cl2;
CAS         7069-38-7;
InChIKey    PPKPKFIWDXDAGC-NSCUHMNNSA-N;
MW          110.965;      // g/mol [origin=calculated method=formula-sum]
Tc          544.07;      // K   [origin=predictive method=joback]
Pc          43.112;      // bar [origin=predictive method=joback]
omega       0.2194;      // -   [origin=predictive method=lee-kesler]
Tb          347.14;      // K   [origin=predictive method=joback]
HvapTb      31080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.07 0.32232 -0.0002663 9.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group Cl_C=C_; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1,2-bis(chloranyl)prop-1-ene" "(e)-1,2-dichloroprop-1-ene" "propene, 1,2-dichloro-" "1-propene, 1,2-dichloro-" "trans-1,2-dichloropropene" "1-propene, 1,2-dichloro-, (1e)-" "(e)-1,2-dichloro-1-propene" );
standardThermochemistry
{
    dHf_298   -29300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22190.0
}
