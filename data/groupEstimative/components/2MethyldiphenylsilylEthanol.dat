/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methyldiphenylsilyl)ethanol  (C15H18OSi, CAS 40438-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H18OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2MethyldiphenylsilylEthanol;
formula     C15H18OSi;
CAS         40438-48-0;
InChIKey    RYVPOJDQPLVTLT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          242.393;      // g/mol [origin=calculated method=formula-sum]
Tc          911.95;      // K   [origin=predictive method=joback]
Pc          24.411;      // bar [origin=predictive method=joback]
omega       0.8750;      // -   [origin=predictive method=lee-kesler]
Tb          689.74;      // K   [origin=predictive method=joback]
HvapTb      70509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.448 1.09882 -0.0004702 1.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[methyl(diphenyl)silyl]ethanol" "2-(diphenylmethylsilyl)ethanol" "ethanol, 2-(methyldiphenylsilyl)-" "(2-hydroxyethyl)diphenylmethylsilane" "ethanol,2-(methyldiphenylsilyl)-" "(2-hydroxyethyl)diphenylmethylsilane;2-(diphenylmethylsilyl)ethanol; 2-(methyldiphenylsilyl)ethanol" );
standardThermochemistry
{
    dHf_298   -143720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58660.0
}
