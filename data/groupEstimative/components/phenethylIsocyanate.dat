/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethyl isocyanate  (C9H9NO, CAS 1943-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenethylIsocyanate;
formula     C9H9NO;
CAS         1943-82-4;
InChIKey    HACRKYQRZABURO-UHFFFAOYSA-N;
MW          147.177;      // g/mol [origin=calculated method=formula-sum]
Tc          716.36;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.5175;      // -   [origin=predictive method=lee-kesler]
Tb          498.87;      // K   [origin=predictive method=joback]
HvapTb      47436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH2; count 2; } { group dCd; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-isocyanatoethylbenzene" "(2-isocyanatoethyl)benzene" "phenylethyl isocyanate" "2-phenylethylisocyanate" "phenylethylisocyanate" "2-phenylethyl isocyanate" "phenethylisocyanate" "2-(isocyanatoethyl)benzene" "2-phenethyl isocyanate" "isocyanic acid phenethyl ester" "beta-phenylethyl isocyanate" "isocyanic acid 2-phenylethyl ester" );
