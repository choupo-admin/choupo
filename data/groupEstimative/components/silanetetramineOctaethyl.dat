/*--------------------------------*- Choupo -*-----------------------*\
  Component: silanetetramine, octaethyl-  (C16H40N4Si, CAS 17048-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H40N4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silanetetramineOctaethyl;
formula     C16H40N4Si;
CAS         17048-10-1;
InChIKey    GURMJCMOXLWZHZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          316.609;      // g/mol [origin=calculated method=formula-sum]
Tc          776.84;      // K   [origin=predictive method=joback]
Pc          12.040;      // bar [origin=predictive method=joback]
omega       0.8257;      // -   [origin=predictive method=lee-kesler]
Tb          616.84;      // K   [origin=predictive method=joback]
HvapTb      59676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.602 1.81336 -0.0008822 1.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 4; } { group CH2N; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 8; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n-[tris(diethylamino)silyl]ethanamine" "tetrakis(diethylamino)silane" "silanetetramine, n,n,n',n',n'',n'',n''',n'''-octaethyl-" "octaethylsilanetetramine" "silanetetramine,n,n,n',n',n'',n'',n''',n'''-octaethyl-" "silanetetramine,octaethyl- (8ci,9ci); tetrakisdiethylaminosilane" );
standardThermochemistry
{
    dHf_298   -215070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     970.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=422200.0
}
