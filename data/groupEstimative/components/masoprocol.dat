/*--------------------------------*- Choupo -*-----------------------*\
  Component: masoprocol  (C18H22O4, CAS 27686-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        masoprocol;
formula     C18H22O4;
CAS         27686-84-6;
InChIKey    HCZKYJDFEPMADG-TXEJJXNPSA-N;
MW          302.37;      // g/mol [origin=calculated method=formula-sum]
Tc          1243.12;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       1.6610;      // -   [origin=predictive method=lee-kesler]
Tb          986.40;      // K   [origin=predictive method=joback]
HvapTb      111494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.328 2.18624 -0.00204964 7.854e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group ACH; count 6; } { group ACCH2; count 2; } { group ACOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(2s,3r)-4-[3,4-bis(oxidanyl)phenyl]-2,3-dimethyl-butyl]benzene-1,2-diol" "actinex" "meso-ndga" "masoprocolum" "meso-nordihydroguaiaretic acid" "ndga" "masoprocolum [inn-latin]" "actinex (tn)" "masoprocol (usan/inn)" "masoprocol [usan:inn]" "nordihydroguaiaretic acid (meso-form)" "nordihydroguaiaretic acid from larrea divaricata (creosote bush)" );
standardThermochemistry
{
    dHf_298   -661590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     731.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297860.0
}
