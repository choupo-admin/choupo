/*--------------------------------*- Choupo -*-----------------------*\
  Component: mono-2-(methacryloyloxy)ethyl maleate  (C10H12O6, CAS 51978-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mono2MethacryloyloxyEthylMaleate;
formula     C10H12O6;
CAS         51978-15-5;
InChIKey    HSFXEOPJXMFQHG-UHFFFAOYSA-N;
MW          228.2;      // g/mol [origin=calculated method=formula-sum]
Tc          892.67;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       1.1188;      // -   [origin=predictive method=lee-kesler]
Tb          691.07;      // K   [origin=predictive method=joback]
HvapTb      69200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.352 0.89492 -0.0005126 8.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(2-methylprop-2-enoyloxy)ethoxy]-4-oxidanylidene-but-2-enoic acid" "4-[2-(2-methylprop-2-enoyloxy)ethoxy]-4-oxobut-2-enoic acid" "4-{2-[(2-methylacryloyl)oxy]ethoxy}-4-oxobut-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1001700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-771820.0
    phase     gas;
}
