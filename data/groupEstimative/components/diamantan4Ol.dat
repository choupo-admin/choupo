/*--------------------------------*- Choupo -*-----------------------*\
  Component: diamantan-4-ol  (C14H20O, CAS 30651-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diamantan4Ol;
formula     C14H20O;
CAS         30651-03-7;
InChIKey    HLMNGNITCLNFFJ-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          837.20;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.8796;      // -   [origin=predictive method=lee-kesler]
Tb          627.76;      // K   [origin=predictive method=joback]
HvapTb      60752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-282.81 2.3443 -0.002282 9.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 7; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 7; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,1,7-[1,2,3,4]butanetetraylnaphthalen-3(2h)-ol, octahydro" "pentacyclo[7.3.1.14,12.02,7.06,11]tetradecan-4-ol (non-preferred name)" );
standardThermochemistry
{
    dHf_298   -160140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     223.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217410.0
}
