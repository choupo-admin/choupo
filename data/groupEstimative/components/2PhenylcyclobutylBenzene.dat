/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-phenylcyclobutyl)benzene  (C16H16, CAS 20071-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylcyclobutylBenzene;
formula     C16H16;
CAS         20071-09-4;
InChIKey    AERGGMDNGDDGPI-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          881.38;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.4749;      // -   [origin=predictive method=lee-kesler]
Tb          625.38;      // K   [origin=predictive method=joback]
HvapTb      55538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.89 1.4808 -0.0010274 2.714e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1,1'-(1,2-cyclobutanediyl)bis-, trans-" "benzene, 1,1'-(1,2-cyclobutanediyl)bis-" "trans-1,2-diphenylcyclobutane" "benzene, 1,1'-(1,2-cyclobutanediyl)bis-, cis-" "agn-pc-00iocw" "cyclobutane, 1,2-diphenyl-" "1,2-diphenylcyclobutane, trans-" "1,1'-cyclobutane-1,2-diyldibenzene" );
standardThermochemistry
{
    dHf_298   145790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349600.0
}
