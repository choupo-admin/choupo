/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dichloro-1,4-dimethylbenzene  (C8H8Cl2, CAS 34840-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dichloro14Dimethylbenzene;
formula     C8H8Cl2;
CAS         34840-79-4;
InChIKey    UGHIQYNKFXEQPU-UHFFFAOYSA-N;
MW          175.052;      // g/mol [origin=calculated method=formula-sum]
Tc          726.07;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.4063;      // -   [origin=predictive method=lee-kesler]
Tb          499.12;      // K   [origin=predictive method=joback]
HvapTb      46434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.39 0.52004 -0.00028228 5.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)-1,4-dimethyl-benzene" "2,3-dichloro-1,4-dimethyl-benzene" "benzene, 2,3-dichloro-1,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -37810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76140.0
    phase     gas;
}
