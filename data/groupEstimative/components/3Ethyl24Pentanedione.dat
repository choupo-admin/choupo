/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-2,4-pentanedione  (C7H12O2, CAS 1540-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl24Pentanedione;
formula     C7H12O2;
CAS         1540-34-7;
InChIKey    GUARKOVVHJSMRW-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          659.10;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.5729;      // -   [origin=predictive method=lee-kesler]
Tb          467.06;      // K   [origin=predictive method=joback]
HvapTb      44280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.561 0.61876 -0.0003228 5.352e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethylpentane-2,4-dione" "3-acetyl-2-pentanone" "2,4-pentanedione, 3-ethyl-" "3-ethylacetylacetone" "2, 3-ethyl-" "3-acetylpentanone-2" "2,4-pentanedione,3-ethyl-" "3-ethyl-4-hydroxy-3-penten-3-one" "3-ethyl-2,4-pentanedione, mixture of tautomers" );
gibbsFormation
{
    dHf_298   -418250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252220.0
    phase     gas;
}
