/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylprop-2-enyl benzoate  (C16H14O2, CAS 5320-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylprop2EnylBenzoate;
formula     C16H14O2;
CAS         5320-75-2;
InChIKey    UARVBDPGNUHYQT-UHFFFAOYSA-N;
MW          238.286;      // g/mol [origin=calculated method=formula-sum]
Tc          922.20;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.6907;      // -   [origin=predictive method=lee-kesler]
Tb          681.42;      // K   [origin=predictive method=joback]
HvapTb      63127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.239 1.3312 -0.0008982 2.205e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propen-1-ol, 3-phenyl-, benzoate" "2-propen-1-ol, 3-phenyl-, 1-benzoate" "2-propen-1-ol,3-phenyl-, 1-benzoate" );
gibbsFormation
{
    dHf_298   -100570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78510.0
    phase     gas;
}
