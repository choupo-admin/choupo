/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyloct-7-enal  (C10H18O, CAS 141-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyloct7Enal;
formula     C10H18O;
CAS         141-26-4;
InChIKey    KQZAHMIZMBERJX-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          651.80;      // K   [origin=predictive method=joback]
Pc          23.819;      // bar [origin=predictive method=joback]
omega       0.5680;      // -   [origin=predictive method=lee-kesler]
Tb          473.18;      // K   [origin=predictive method=joback]
HvapTb      43596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.834 0.91414 -0.0005416 1.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-octenal, 3,7-dimethyl-" "alpha-citronellal" );
gibbsFormation
{
    dHf_298   -224950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10650.0
    phase     gas;
}
