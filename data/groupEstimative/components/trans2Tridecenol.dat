/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-2-tridecenol  (C13H26O, CAS 68480-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans2Tridecenol;
formula     C13H26O;
CAS         68480-25-1;
InChIKey    VPYJHNADOJDSGU-UHFFFAOYSA-N;
MW          198.35;      // g/mol [origin=calculated method=formula-sum]
Tc          756.30;      // K   [origin=predictive method=joback]
Pc          18.547;      // bar [origin=predictive method=joback]
omega       1.0315;      // -   [origin=predictive method=lee-kesler]
Tb          593.38;      // K   [origin=predictive method=joback]
HvapTb      61169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.82 1.29282 -0.0007976 2.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridec-2-en-1-ol" "2-tridecen-1-ol, (z)-" "2-tridecen-1-ol, (2e)-" "2-tridecen-1-ol,(e)-; (e)-2-tridecen-1-ol; trans-2-tridecen-1-ol" );
standardThermochemistry
{
    dHf_298   -346660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1980.0
}
