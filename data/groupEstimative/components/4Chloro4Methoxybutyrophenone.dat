/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-4'-methoxybutyrophenone  (C11H13ClO2, CAS 40877-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro4Methoxybutyrophenone;
formula     C11H13ClO2;
CAS         40877-19-8;
InChIKey    NGBTWDPPZFGUAY-UHFFFAOYSA-N;
MW          212.673;      // g/mol [origin=calculated method=formula-sum]
Tc          811.14;      // K   [origin=predictive method=joback]
Pc          26.325;      // bar [origin=predictive method=joback]
omega       0.7059;      // -   [origin=predictive method=lee-kesler]
Tb          596.66;      // K   [origin=predictive method=joback]
HvapTb      56559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.033 0.82602 -0.00042946 6.546e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group CH3O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-1-(4-methoxyphenyl)butan-1-one" "4-chloro-1-(4-methoxyphenyl)butan-1-one" "l689" "1-butanone,4-chloro-1-(4-methoxyphenyl)-" "4-chloro-4 inverted exclamation marka-methoxybutyrophenone" );
standardThermochemistry
{
    dHf_298   -305850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101330.0
}
