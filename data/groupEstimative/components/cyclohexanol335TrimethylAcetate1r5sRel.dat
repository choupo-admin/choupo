/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 3,3,5-trimethyl-, acetate,(1r,5s)-rel-  (C11H20O2, CAS 24691-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol335TrimethylAcetate1r5sRel;
formula     C11H20O2;
CAS         24691-18-7;
InChIKey    OIVWFAFCHQDCCG-PSASIEDQSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          727.42;      // K   [origin=predictive method=joback]
Pc          23.003;      // bar [origin=predictive method=joback]
omega       0.4617;      // -   [origin=predictive method=lee-kesler]
Tb          519.95;      // K   [origin=predictive method=joback]
HvapTb      46147.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.42 1.35508 -0.0009828 3.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,5s)-3,3,5-trimethylcyclohexyl] ethanoate" "cyclohexanol, 3,3,5-trimethyl-, acetate, (1r,5s)-rel-" "cyclohexanol, 3,3,5-trimethyl-, 1-acetate, (1r,5s)-rel-" "trans-3,3,5-trimethylcyclohexyl acetate" "cyclohexanol,3,5-trimethyl-, acetate, trans-" "[(1r,5s)-3,3,5-trimethylcyclohexyl] acetate" "cyclohexanol, 3,3,5-trimethyl-, acetate, trans-" "cyclohexanol, 3,3,5-trimethyl-, acetate, trans- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -558770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265090.0
    phase     gas;
}
