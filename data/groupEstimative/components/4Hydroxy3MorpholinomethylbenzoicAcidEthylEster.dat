/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-3-morpholinomethylbenzoic acid ethyl ester  (C14H19NO4, CAS 78330-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy3MorpholinomethylbenzoicAcidEthylEster;
formula     C14H19NO4;
CAS         78330-02-6;
InChIKey    LHTGLKDOIOFXHF-UHFFFAOYSA-N;
MW          265.309;      // g/mol [origin=calculated method=formula-sum]
Tc          978.17;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       1.0813;      // -   [origin=predictive method=lee-kesler]
Tb          749.76;      // K   [origin=predictive method=joback]
HvapTb      77236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.748 1.57432 -0.00114522 3.284e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(morpholin-4-ylmethyl)-4-oxidanyl-benzoate" "ethyl 4-hydroxy-3-morpholinomethylbenzoate" "ethyl 4-hydroxy-3-(morpholin-4-ylmethyl)benzoate" "benzoic acid, 4-hydroxy-3-morpholinomethyl-, ethyl ester" );
gibbsFormation
{
    dHf_298   -585470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-226290.0
    phase     gas;
}
