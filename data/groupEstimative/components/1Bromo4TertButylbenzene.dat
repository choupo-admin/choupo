/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-tert-butylbenzene  (C10H13Br, CAS 3972-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4TertButylbenzene;
formula     C10H13Br;
CAS         3972-65-4;
InChIKey    XHCAGOVGSDHHNP-UHFFFAOYSA-N;
MW          213.118;      // g/mol [origin=calculated method=formula-sum]
Tc          760.08;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.4107;      // -   [origin=predictive method=lee-kesler]
Tb          522.99;      // K   [origin=predictive method=joback]
HvapTb      45931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.09 0.97946 -0.00072756 2.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-tert-butyl-benzene" "4-tert-butylbromobenzene" "butylbromobenzene" "1-bromo-p-t-butylbenzene" "p-bromo-t-butylbenzene" "p-bromo-tert-butylbenzene" "4-bromo-tert-butylbenzene" "p-tert-butyl bromo benzene" "bromo(4-)-tert-butylbenzene" "1-bromo-4-tert-butylbenzene," "1-bromo-4-(tert-butyl)benzene" "benzene, 1-bromo-4-tert-butyl-" );
gibbsFormation
{
    dHf_298   -7090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153260.0
    phase     gas;
}
