/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1,2-diphenyl-1-methylcyclopropane  (C16H16, CAS 14161-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis12Diphenyl1Methylcyclopropane;
formula     C16H16;
CAS         14161-72-9;
InChIKey    MEPKNRHJYLWJON-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          878.88;      // K   [origin=predictive method=joback]
Pc          26.298;      // bar [origin=predictive method=joback]
omega       0.4649;      // -   [origin=predictive method=lee-kesler]
Tb          621.35;      // K   [origin=predictive method=joback]
HvapTb      54215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-173.76 1.78232 -0.0016064 5.993e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methyl-2-phenyl-cyclopropyl)benzene" "trans-1,2-diphenyl-1-methylcyclopropane" "1-methyl-1,2-diphenylcyclopropane" "(1-methyl-2-phenylcyclopropyl)benzene" "1,1'-(1-methylcyclopropane-1,2-diyl)dibenzene" "benzene, 1,1'-(1-methyl-1,2-cyclopropanediyl)bis-" );
standardThermochemistry
{
    dHf_298   167190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356210.0
}
