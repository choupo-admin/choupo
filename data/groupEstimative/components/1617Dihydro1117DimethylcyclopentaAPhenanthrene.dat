/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16,17-dihydro-11,17-dimethylcyclopenta(a)phenanthrene  (C19H18, CAS 5831-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1617Dihydro1117DimethylcyclopentaAPhenanthrene;
formula     C19H18;
CAS         5831-16-3;
InChIKey    YKHYPHKYWZWOOY-UHFFFAOYSA-N;
MW          246.353;      // g/mol [origin=calculated method=formula-sum]
Tc          971.65;      // K   [origin=predictive method=joback]
Pc          21.613;      // bar [origin=predictive method=joback]
omega       0.7042;      // -   [origin=predictive method=lee-kesler]
Tb          725.62;      // K   [origin=predictive method=joback]
HvapTb      66005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.22 1.63544 -0.00126648 4.023e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 7; } { group AC; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11,17-dimethyl-16,17-dihydro-15h-cyclopenta[a]phenanthrene" "11,17-dimethyl-16,17-dihydro-15h-cyclopenta(a)phenanthrene" "16,17-dihydro-11,17-dimethyl-15h-cyclopenta(a)phenanthrene" "15h-cyclopenta(a)phenanthrene, 11,17-dimethyl-16,17-dihydro-" "11,17-dimethylgona-1(10),2,4,6,8,11,13-heptaene" );
gibbsFormation
{
    dHf_298   210100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=457040.0
    phase     gas;
}
