/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1-chloro-2-methylpropane  (C4H8BrCl, CAS 2074-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo1Chloro2Methylpropane;
formula     C4H8BrCl;
CAS         2074-80-8;
InChIKey    YEZMNTBSGDUYBT-UHFFFAOYSA-N;
MW          171.462;      // g/mol [origin=calculated method=formula-sum]
Tc          599.64;      // K   [origin=predictive method=joback]
Pc          41.570;      // bar [origin=predictive method=joback]
omega       0.2887;      // -   [origin=predictive method=lee-kesler]
Tb          391.48;      // K   [origin=predictive method=joback]
HvapTb      34022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.139 0.55464 -0.0004574 1.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2Cl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1-chloranyl-2-methyl-propane" "2-bromo-1-chloro-2-methyl-propane" "2-bromo-1-chloro-2-methylpropane;" );
gibbsFormation
{
    dHf_298   -124050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11970.0
    phase     gas;
}
