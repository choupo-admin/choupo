/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(1-methyl-2-phenylvinyl)pyridine  (C14H13N, CAS 18150-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        41Methyl2PhenylvinylPyridine;
formula     C14H13N;
CAS         18150-12-4;
InChIKey    RSKRXANPEHDBRN-UHFFFAOYSA-N;
MW          195.265;      // g/mol [origin=calculated method=formula-sum]
Tc          893.82;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.5087;      // -   [origin=predictive method=lee-kesler]
Tb          631.02;      // K   [origin=predictive method=joback]
HvapTb      57558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.46 1.22968 -0.00089556 2.574e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(1-phenylprop-1-en-2-yl)pyridine" "4-[(z)-1-phenylprop-1-en-2-yl]pyridine" "pyridine,4-(a-methylstyryl)-, (e)- (8ci)" "pyridine,4-(1-methyl-2-phenylethenyl)-, (e)- (9ci)" );
gibbsFormation
{
    dHf_298   280990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=440540.0
    phase     gas;
}
