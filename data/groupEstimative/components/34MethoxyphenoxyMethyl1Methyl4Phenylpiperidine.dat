/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[(4-methoxyphenoxy)methyl]-1-methyl-4-phenylpiperidine  (C20H25NO2, CAS 56222-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34MethoxyphenoxyMethyl1Methyl4Phenylpiperidine;
formula     C20H25NO2;
CAS         56222-04-9;
InChIKey    OJSFTALXCYKKFQ-UHFFFAOYSA-N;
MW          311.425;      // g/mol [origin=calculated method=formula-sum]
Tc          1016.00;      // K   [origin=predictive method=joback]
Pc          17.654;      // bar [origin=predictive method=joback]
omega       0.8334;      // -   [origin=predictive method=lee-kesler]
Tb          783.43;      // K   [origin=predictive method=joback]
HvapTb      72139.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.039 1.78924 -0.00102216 1.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(4-methoxyphenoxy)methyl]-1-methyl-4-phenyl-piperidine" "femoxetine [inn]" "femoxetinum [inn-latin]" "femoxitine" "(3r)-3-[(4-methoxyphenoxy)methyl]-1-methyl-4-phenylpiperidine" "(+)-trans-3-((p-methoxyphenoxy)methyl)-1-methyl-4-phenylpiperidine" "piperidine, 3-[(4-methoxyphenoxy)methyl]-1-methyl-4-phenyl-, cis-" "piperidine, 3-((4-methoxyphenoxy)methyl)-1-methyl-4-phenyl-, (3r-trans)-" "trans-3-((4-methoxyphenoxy)methyl)-1-methyl-4-phenylpiperidine" "trans-(+)-3-((4-methoxyphenoxy)methyl)-1-methyl-4-phenylpiperidine" );
standardThermochemistry
{
    dHf_298   -151310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=262330.0
}
