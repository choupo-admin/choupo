/*--------------------------------*- Choupo -*-----------------------*\
  Component: mesitylene  (C9H12, CAS 108-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mesitylene;
formula     C9H12;
CAS         108-67-8;
InChIKey    AUHZEENZYGFFBQ-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          652.25;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.3406;      // -   [origin=predictive method=lee-kesler]
Tb          442.16;      // K   [origin=predictive method=joback]
HvapTb      39228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.6 0.66096 -0.00036292 7.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-trimethylbenzene" "benzene, 1,3,5-trimethyl-" "sym-trimethylbenzene" "trimethylbenzol" "fleet-x" "3,5-dimethyltoluene" "trimethylbenzene, 1,3,5-" "s-trimethylbenzene" "agn-pc-00jpns" "1,3,5-trimethyl-benzene" "agn-pc-00ks9x" "benzene,1,3,5-trimethyl" );
gibbsFormation
{
    dHf_298   -15500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118050.0
    phase     gas;
}
