/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydrocodone  (C18H21NO3, CAS 125-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydrocodone;
formula     C18H21NO3;
CAS         125-29-1;
InChIKey    LLPOLZWFYMWNKH-CMKMFDCUSA-N;
MW          299.37;      // g/mol [origin=calculated method=formula-sum]
Tc          1047.24;      // K   [origin=predictive method=joback]
Pc          22.398;      // bar [origin=predictive method=joback]
omega       0.9700;      // -   [origin=predictive method=lee-kesler]
Tb          805.62;      // K   [origin=predictive method=joback]
HvapTb      71463.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-181.76 2.25094 -0.00198898 7.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } { group O_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4ar,7ar,12bs)-9-methoxy-3-methyl-1,2,4,4a,5,6,7a,13-octahydro-4,12-methanobenzofuro[3,2-e]isoquinoline-7-one" "dihydrocodeinone" "hydrocodon" "hydrocone" "dicodid" "codinovo" "hydroconum" "bekadid" "hidrocodona" "hydrocodonum" "idrocodone" "multacodin" );
gibbsFormation
{
    dHf_298   -234520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230880.0
    phase     gas;
}
