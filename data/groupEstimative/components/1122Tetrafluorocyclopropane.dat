/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetrafluorocyclopropane  (C3H2F4, CAS 3899-71-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122Tetrafluorocyclopropane;
formula     C3H2F4;
CAS         3899-71-6;
InChIKey    GAUOXRYNXHWONS-UHFFFAOYSA-N;
MW          114.041;      // g/mol [origin=calculated method=formula-sum]
Tc          418.12;      // K   [origin=predictive method=joback]
Pc          44.504;      // bar [origin=predictive method=joback]
omega       0.2430;      // -   [origin=predictive method=lee-kesler]
Tb          267.87;      // K   [origin=predictive method=joback]
HvapTb      16306.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.76 1.0442 -0.001435 7.14e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group C_ring; count 2; } { group F; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(fluoranyl)cyclopropane" );
standardThermochemistry
{
    dHf_298   -806750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-762800.0
}
