/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesta-3,5-diene  (C27H44, CAS 747-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesta35Diene;
formula     C27H44;
CAS         747-90-0;
InChIKey    RLHIRZFWJBOHHD-HKQCOZBKSA-N;
MW          368.649;      // g/mol [origin=calculated method=formula-sum]
Tc          1084.41;      // K   [origin=predictive method=joback]
Pc          10.624;      // bar [origin=predictive method=joback]
omega       0.7094;      // -   [origin=predictive method=lee-kesler]
Tb          859.23;      // K   [origin=predictive method=joback]
HvapTb      73758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-309.837 3.4956 -0.00296212 1.0799e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 6; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,7,8,9,11,12,14,15,16,17-decahydro-1h-cyclopenta[a]phenanthrene" "cholesterilene" "cholesterylene" "delta-3,5-cholestadiene" "delta(sup 3,5)-cholestadiene" "delta-(sup 3,5)-cholestadien [german]" ".delta.-3,5-cholestadiene" ".delta.3,5-cholestadiene" "delta-(sup 3,5)-cholestadien" ".delta.-(sup 3,5)-cholestadien" );
gibbsFormation
{
    dHf_298   -256880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     900.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=377970.0
    phase     gas;
}
