/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromoundecane  (C11H23Br, CAS 693-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromoundecane;
formula     C11H23Br;
CAS         693-67-4;
InChIKey    IKPSIIAXIDAQLG-UHFFFAOYSA-N;
MW          235.209;      // g/mol [origin=calculated method=formula-sum]
Tc          693.62;      // K   [origin=predictive method=joback]
Pc          20.568;      // bar [origin=predictive method=joback]
omega       0.6682;      // -   [origin=predictive method=lee-kesler]
Tb          517.44;      // K   [origin=predictive method=joback]
HvapTb      46515.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.08 1.08702 -0.000646 1.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylundecane" "undecane, 1-bromo-" "undecyl bromide" "hendecyl bromide" "n-undecyl-1-bromide" "bromoundecane" "1-bromo-undecane" "n-undecyl bromide" "undecane, bromo-" "k942" );
standardThermochemistry
{
    dHf_298   -244040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56060.0
}
