/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethoxyphenol  (C8H10O3, CAS 500-99-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethoxyphenol;
formula     C8H10O3;
CAS         500-99-2;
InChIKey    XQDNFAMOIPNVES-UHFFFAOYSA-N;
MW          154.165;      // g/mol [origin=calculated method=formula-sum]
Tc          761.91;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.6822;      // -   [origin=predictive method=lee-kesler]
Tb          539.76;      // K   [origin=predictive method=joback]
HvapTb      54174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.09 0.65364 -0.00040992 1.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phloroglucinol dimethyl ether" "taxicatigenin" "phenol, 3,5-dimethoxy-" "1-hydroxy-3,5-dimethoxybenzene" "phenol,5-dimethoxy-" "phenol, 3,5-dimethoxy- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -425140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245360.0
    phase     gas;
}
