/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-bis(trifluoromethyl)benzoic acid  (C9H4F6O2, CAS 24821-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26BisTrifluoromethylBenzoicAcid;
formula     C9H4F6O2;
CAS         24821-22-5;
InChIKey    XZNLSDPNMNWCRE-UHFFFAOYSA-N;
MW          258.117;      // g/mol [origin=calculated method=formula-sum]
Tc          767.75;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.8805;      // -   [origin=predictive method=lee-kesler]
Tb          576.83;      // K   [origin=predictive method=joback]
HvapTb      48898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.4 1.0341 -0.00087752 2.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group COOH; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-di(trifluoromethyl)benzoic acid" "benzoic acid, 2,6-bis(trifluoromethyl)-" "buttpark 44\01-73" "2,6-bis-trifluoromethylbenzoic acid" "2,6-bis-trifluoromethyl-benzoic acid" "benzoic acid,2,6-bis(trifluoromethyl)-" "2,6-bis(trifluoromethyl)benzoicacid; 2,6-di(trifluoromethyl)benzoic acid" );
standardThermochemistry
{
    dHf_298   -1559930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1389040.0
}
