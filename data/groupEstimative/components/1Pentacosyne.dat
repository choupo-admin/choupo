/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentacosyne  (C25H48, CAS 61847-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentacosyne;
formula     C25H48;
CAS         61847-85-6;
InChIKey    PSVIFCMEORUFBZ-UHFFFAOYSA-N;
MW          348.659;      // g/mol [origin=calculated method=formula-sum]
Tc          935.19;      // K   [origin=predictive method=joback]
Pc          8.305;      // bar [origin=predictive method=joback]
omega       0.7698;      // -   [origin=predictive method=lee-kesler]
Tb          761.72;      // K   [origin=predictive method=joback]
HvapTb      71102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.058 2.28492 -0.00133213 3.0469e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 22; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 22; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentacos-1-yne" );
standardThermochemistry
{
    dHf_298   -267430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1099.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=382690.0
}
