/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-5-methyl-3-methylenecyclohexene  (C9H14O, CAS 69697-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy5Methyl3Methylenecyclohexene;
formula     C9H14O;
CAS         69697-81-0;
InChIKey    UCGJGGYPYPCYCO-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          654.06;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       0.3825;      // -   [origin=predictive method=lee-kesler]
Tb          450.79;      // K   [origin=predictive method=joback]
HvapTb      39580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.03 0.68474 -0.00026364 9e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-5-methyl-3-methylidene-cyclohexene" "1-methoxy-5-methyl-3-methylidenecyclohexene" );
standardThermochemistry
{
    dHf_298   -176440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17760.0
}
