/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylacetic acid  (C5H8O2, CAS 591-80-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylaceticAcid;
formula     C5H8O2;
CAS         591-80-0;
InChIKey    HVAMZGADVCBITI-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          651.47;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.6062;      // -   [origin=predictive method=lee-kesler]
Tb          456.19;      // K   [origin=predictive method=joback]
HvapTb      43218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.048 0.5096 -0.0003437 9.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-4-enoic acid" "4-pentenoic acid" "3-vinylpropionic acid" "delta 4-pentenoic acid" ".delta.4-pentenoic acid" "allylessigsaeure" "4-pentensaeure" "4-pentenic acid" "4-penten-1-oic acid" "delta(4)-pentenoic acid" "hvamzgadvcbiti-uhfffaoysa-" "c5:1n-1" );
gibbsFormation
{
    dHf_298   -371370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264850.0
    phase     gas;
}
