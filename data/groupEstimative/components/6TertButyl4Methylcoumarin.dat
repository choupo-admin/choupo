/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-tert-butyl-4-methylcoumarin  (C14H16O2, CAS 17874-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6TertButyl4Methylcoumarin;
formula     C14H16O2;
CAS         17874-32-7;
InChIKey    BVQZHRREUVIRFZ-UHFFFAOYSA-N;
MW          216.28;      // g/mol [origin=calculated method=formula-sum]
Tc          844.31;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       0.6564;      // -   [origin=predictive method=lee-kesler]
Tb          622.83;      // K   [origin=predictive method=joback]
HvapTb      57473.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.19 1.27848 -0.00095436 2.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-tert-butyl-4-methyl-chromen-2-one" "6-t-butyl-4-methylcoumarin" "6-(tert-butyl)-4-methylchromen-2-one" "6-tert-butyl-4-methylchromen-2-one" "6-(tert-butyl)-4-methyl-2h-chromen-2-one" "2h-1-benzopyran-2-one,6-(1,1-dimethylethyl)-4-methyl-" );
gibbsFormation
{
    dHf_298   -299120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46490.0
    phase     gas;
}
