/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-indene, 3a,4,7,7a-tetrahydro-4-methyl-  (C10H14, CAS 7413-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hIndene3a477aTetrahydro4Methyl;
formula     C10H14;
CAS         7413-02-7;
InChIKey    YVLGRGCYQOZGCO-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          666.02;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.3017;      // -   [origin=predictive method=lee-kesler]
Tb          448.34;      // K   [origin=predictive method=joback]
HvapTb      38471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.55 1.08832 -0.00074056 1.969e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-3a,4,7,7a-tetrahydro-1h-indene" "2-methylbicyclo(4.3.0)nona-3,8-diene" "agn-pc-03f072" "3a,4,7,7a-tetrahydro-4-methyl-1h-indene" );
gibbsFormation
{
    dHf_298   -27390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170730.0
    phase     gas;
}
