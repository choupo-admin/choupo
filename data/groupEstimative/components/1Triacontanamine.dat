/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-triacontanamine  (C30H63N, CAS 66214-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Triacontanamine;
formula     C30H63N;
CAS         66214-00-4;
InChIKey    WFLJHDLVVWUGGZ-UHFFFAOYSA-N;
MW          437.841;      // g/mol [origin=calculated method=formula-sum]
Tc          1189.26;      // K   [origin=predictive method=joback]
Pc          6.124;      // bar [origin=predictive method=joback]
omega       0.4100;      // -   [origin=predictive method=lee-kesler]
Tb          958.53;      // K   [origin=predictive method=joback]
HvapTb      93015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.891 2.91572 -0.0016516 3.568e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 28; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 29; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triacontan-1-amine" "1-triacontylamine" );
gibbsFormation
{
    dHf_298   -628740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1376.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=268170.0
    phase     gas;
}
