/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylcyclopentadecanone  (C16H30O, CAS 541-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylcyclopentadecanone;
formula     C16H30O;
CAS         541-91-3;
InChIKey    ALHUZKCOMYUFRB-UHFFFAOYSA-N;
MW          238.415;      // g/mol [origin=calculated method=formula-sum]
Tc          949.68;      // K   [origin=predictive method=joback]
Pc          19.086;      // bar [origin=predictive method=joback]
omega       0.4730;      // -   [origin=predictive method=lee-kesler]
Tb          691.48;      // K   [origin=predictive method=joback]
HvapTb      57434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.92 1.39122 -0.000266 -1.933e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 13; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylcyclopentadecan-1-one" "muscone" "cyclopentadecanone, 3-methyl-" "muskone" "methylexaltone" "moschus ketone" "3-methyl-1-cyclopentadecanone" "5-methyl-1-cyclopentadecanone" "3-methylcyclopentadecanone, dl-" "dl-muscone or 3-methylcyclopentadecanone" "3-methyl-cyclopentadecan-1-one" );
gibbsFormation
{
    dHf_298   -512390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     849.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123200.0
    phase     gas;
}
