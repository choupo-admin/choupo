/*--------------------------------*- Choupo -*-----------------------*\
  Component: morphine  (C17H19NO3, CAS 57-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morphine;
formula     C17H19NO3;
CAS         57-27-2;
InChIKey    BQJCRHHNABKAKU-KBQPJGBKSA-N;
MW          285.343;      // g/mol [origin=calculated method=formula-sum]
Tc          1085.19;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       1.4715;      // -   [origin=predictive method=lee-kesler]
Tb          854.81;      // K   [origin=predictive method=joback]
HvapTb      91594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-246.99 2.55302 -0.00257526 1.0395e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4ar,7s,7ar,12bs)-3-methyl-2,4,4a,7,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7,9-diol" "morphinum" "morphia" "morphium" "morphin" "(-)-morphine" "ms contin" "duromorph" "meconium" "morphina" "morphinism" "moscontin" );
standardThermochemistry
{
    dHf_298   -224590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190490.0
}
