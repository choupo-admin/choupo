/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(p-tolylthio)-ethanol  (C9H12OS, CAS 13290-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PTolylthioEthanol;
formula     C9H12OS;
CAS         13290-16-9;
InChIKey    KYCQIPSCAOIEKN-UHFFFAOYSA-N;
MW          168.254;      // g/mol [origin=calculated method=formula-sum]
Tc          812.02;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.8904;      // -   [origin=predictive method=lee-kesler]
Tb          598.14;      // K   [origin=predictive method=joback]
HvapTb      62062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.008 0.74881 -0.00042016 7.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylphenyl)sulfanylethanol" "ethanol, 2-[(4-methylphenyl)thio]-" "ethanol, 2-((4-methylphenyl)thio)-" "2-[(4-methylphenyl)sulfanyl]ethan-1-ol" );
standardThermochemistry
{
    dHf_298   -114390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23980.0
}
