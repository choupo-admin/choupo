/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7-octadiene  (C8H14, CAS 3710-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Octadiene;
formula     C8H14;
CAS         3710-30-3;
InChIKey    XWJBRBSPAODJER-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          546.29;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.3556;      // -   [origin=predictive method=lee-kesler]
Tb          376.00;      // K   [origin=predictive method=joback]
HvapTb      32062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.366 0.7238 -0.0004572 1.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octa-1,7-diene" ".alpha.,.omega.-octadiene" );
gibbsFormation
{
    dHf_298   42410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192160.0
    phase     gas;
}
