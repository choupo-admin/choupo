/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylhexyl methacrylate  (C11H20O2, CAS 60250-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylhexylMethacrylate;
formula     C11H20O2;
CAS         60250-80-8;
InChIKey    KQOAGTHDNCRFCU-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          683.25;      // K   [origin=predictive method=joback]
Pc          20.401;      // bar [origin=predictive method=joback]
omega       0.6086;      // -   [origin=predictive method=lee-kesler]
Tb          505.62;      // K   [origin=predictive method=joback]
HvapTb      46509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.934 0.97986 -0.0005084 8.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylhexyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-methylhexyl ester" "2-propenoic acid,2-methyl-, 2-methylhexyl ester" );
gibbsFormation
{
    dHf_298   -477290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191780.0
    phase     gas;
}
