/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-nonylaniline  (C15H25N, CAS 3007-72-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNonylaniline;
formula     C15H25N;
CAS         3007-72-5;
InChIKey    KBNHOFDIDSVFMZ-UHFFFAOYSA-N;
MW          219.372;      // g/mol [origin=calculated method=formula-sum]
Tc          812.34;      // K   [origin=predictive method=joback]
Pc          18.676;      // bar [origin=predictive method=joback]
omega       0.7791;      // -   [origin=predictive method=lee-kesler]
Tb          619.65;      // K   [origin=predictive method=joback]
HvapTb      57696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.862 1.42612 -0.000872 2.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenamine, n-nonyl-" "nonylamine,n-phenyl- (6ci,7ci,8ci); n-nonylaniline" );
standardThermochemistry
{
    dHf_298   -62930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=277220.0
}
