/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-3-methylbenzyl chloride  (C9H11ClO, CAS 60736-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy3MethylbenzylChloride;
formula     C9H11ClO;
CAS         60736-71-2;
InChIKey    BHEHNICAPZVKRH-UHFFFAOYSA-N;
MW          170.636;      // g/mol [origin=calculated method=formula-sum]
Tc          716.34;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.4729;      // -   [origin=predictive method=lee-kesler]
Tb          502.01;      // K   [origin=predictive method=joback]
HvapTb      46023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.791 0.60454 -0.00027232 2.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH3O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(chloromethyl)-1-methoxy-2-methyl-benzene" "4-(chloromethyl)-1-methoxy-2-methylbenzene" "4-(chloromethyl)-2-methylphenyl methyl ether" "4-methoxy-3-methylbenzyl chloride stablilized with calcium carbonate" );
gibbsFormation
{
    dHf_298   -163460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1120.0
    phase     gas;
}
