/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine,2-[1-(2-chlorophenyl)ethenyl]-  (C13H10ClN, CAS 74309-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine212ChlorophenylEthenyl;
formula     C13H10ClN;
CAS         74309-55-0;
InChIKey    BLHXHLXLRDYKJM-UHFFFAOYSA-N;
MW          215.68;      // g/mol [origin=calculated method=formula-sum]
Tc          910.11;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.5301;      // -   [origin=predictive method=lee-kesler]
Tb          643.07;      // K   [origin=predictive method=joback]
HvapTb      59751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.17 1.04196 -0.00073362 1.996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group C5H4N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Cl; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(2-chlorophenyl)ethenyl]pyridine" "pyridine, 2-(1-(2-chlorophenyl)ethenyl)-" );
gibbsFormation
{
    dHf_298   282630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=418180.0
    phase     gas;
}
