/*--------------------------------*- Choupo -*-----------------------*\
  Component: neodelpregnin  (C44H56O6, CAS 8064-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neodelpregnin;
formula     C44H56O6;
CAS         8064-66-2;
InChIKey    NIXVMBBZNVOBHS-ASRKUVFVSA-N;
MW          680.926;      // g/mol [origin=calculated method=formula-sum]
Tc          2074.37;      // K   [origin=predictive method=joback]
Pc          8.154;      // bar [origin=predictive method=joback]
omega       0.5377;      // -   [origin=predictive method=lee-kesler]
Tb          1650.08;      // K   [origin=predictive method=joback]
HvapTb      160233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-506.13 5.79452 -0.00534303 2.09955e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 5; } { group C; count 5; } { group CH=C; count 2; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 12; } { group CH_ring; count 6; } { group C_ring; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group OH; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17r)-17-ethanoyl-6,10,13-trimethyl-3-oxidanylidene-2,8,9,11,12,14,15,16-octahydro-1h-cyclopenta[a]phenanthren-17-yl] ethanoate;(8r,9s,13s,14s,17r)-17-ethynyl-13-methyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthrene-3,17-diol" "oraconal" "kombiquens" "megethinyl" "menoquens" "nuvacon" "serial" "voldys" "tri-ervonum" "ethynylestradiol-magestrol acetate" "ethinylestradiol mixed with megestrol acetate" "megestrol acetate mixed with ethinyloestradiol" );
gibbsFormation
{
    dHf_298   -889310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1509.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10290.0
    phase     gas;
}
