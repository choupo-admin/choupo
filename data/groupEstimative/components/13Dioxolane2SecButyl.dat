/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane, 2-sec-butyl-  (C7H14O2, CAS 14447-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane2SecButyl;
formula     C7H14O2;
CAS         14447-25-7;
InChIKey    FRBNVSJPLIGZIP-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          628.33;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.3941;      // -   [origin=predictive method=lee-kesler]
Tb          428.50;      // K   [origin=predictive method=joback]
HvapTb      40065.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.999 0.80044 -0.0004598 9.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butan-2-yl-1,3-dioxolane" "1,3-dioxolane, 2-(1-methylpropyl)-" );
standardThermochemistry
{
    dHf_298   -396610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     266.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130070.0
}
