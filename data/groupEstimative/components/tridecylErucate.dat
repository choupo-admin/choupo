/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecyl erucate  (C35H68O2, CAS 131154-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecylErucate;
formula     C35H68O2;
CAS         131154-74-0;
InChIKey    BGNWQYFHLCCUTB-UHFFFAOYSA-N;
MW          520.927;      // g/mol [origin=calculated method=formula-sum]
Tc          1359.08;      // K   [origin=predictive method=joback]
Pc          4.893;      // bar [origin=predictive method=joback]
omega       0.0438;      // -   [origin=predictive method=lee-kesler]
Tb          1062.78;      // K   [origin=predictive method=joback]
HvapTb      100869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.7 3.29404 -0.0018694 3.956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 29; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 30; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecyl docos-13-enoate" "erucic acid tridecyl ester;" );
gibbsFormation
{
    dHf_298   -965790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1564.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13670.0
    phase     gas;
}
