/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-difluorobenzyl alcohol  (C7H6F2O, CAS 79538-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DifluorobenzylAlcohol;
formula     C7H6F2O;
CAS         79538-20-8;
InChIKey    LOGIHEKXJKHXEC-UHFFFAOYSA-N;
MW          144.12;      // g/mol [origin=calculated method=formula-sum]
Tc          670.11;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.8358;      // -   [origin=predictive method=lee-kesler]
Tb          487.12;      // K   [origin=predictive method=joback]
HvapTb      49821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.691 0.5285 -0.00031732 6.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,5-bis(fluoranyl)phenyl]methanol" "(3,5-difluorophenyl)methanol" "3, 5-difluorobenzyl alcohol" "(3,5-difluorophenyl)methan-1-ol" "3,5-difluorobenzylalcohol" "(3,5-difluorophenyl)methanol;" "(3,5-difluoro-phenyl)-methanol" "l448" "79538-20-8 3,5-difluorobenzyl alcohol" );
gibbsFormation
{
    dHf_298   -518670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-425230.0
    phase     gas;
}
