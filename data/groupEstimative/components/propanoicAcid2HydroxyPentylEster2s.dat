/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 2-hydroxy-, pentyl ester, (2s)-  (C8H16O3, CAS 171056-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid2HydroxyPentylEster2s;
formula     C8H16O3;
CAS         171056-23-8;
InChIKey    GXOHBWLPQHTYPF-ZETCQYMHSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          701.57;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.9972;      // -   [origin=predictive method=lee-kesler]
Tb          532.60;      // K   [origin=predictive method=joback]
HvapTb      57100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.634 0.74894 -0.0003504 3.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentyl (2s)-2-oxidanylpropanoate" );
gibbsFormation
{
    dHf_298   -683240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-433150.0
    phase     gas;
}
