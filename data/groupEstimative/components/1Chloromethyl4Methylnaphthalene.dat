/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloromethyl-4-methylnaphthalene  (C12H11Cl, CAS 5261-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloromethyl4Methylnaphthalene;
formula     C12H11Cl;
CAS         5261-50-7;
InChIKey    QHXSBKTZBDHBKF-UHFFFAOYSA-N;
MW          190.67;      // g/mol [origin=calculated method=formula-sum]
Tc          803.20;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.5010;      // -   [origin=predictive method=lee-kesler]
Tb          567.21;      // K   [origin=predictive method=joback]
HvapTb      51931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.879 0.94902 -0.00068324 1.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH3; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-4-methyl-naphthalene" "1-(chloromethyl)-4-methylnaphthalene" );
gibbsFormation
{
    dHf_298   97910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238030.0
    phase     gas;
}
