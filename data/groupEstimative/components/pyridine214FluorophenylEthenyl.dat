/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine,2-[1-(4-fluorophenyl)ethenyl)-  (C13H10FN, CAS 63346-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine214FluorophenylEthenyl;
formula     C13H10FN;
CAS         63346-70-3;
InChIKey    RTIFKRRVRCEAEO-UHFFFAOYSA-N;
MW          199.228;      // g/mol [origin=calculated method=formula-sum]
Tc          855.62;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.5293;      // -   [origin=predictive method=lee-kesler]
Tb          604.91;      // K   [origin=predictive method=joback]
HvapTb      54549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.97 1.04696 -0.00072962 1.962e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group C5H4N; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group F; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(4-fluorophenyl)ethenyl]pyridine" "pyridine, 2-(1-(4-fluorophenyl)ethenyl)-" "imidazolidine,2-(2,6-difluorophenylimino)-" );
gibbsFormation
{
    dHf_298   102260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235300.0
    phase     gas;
}
