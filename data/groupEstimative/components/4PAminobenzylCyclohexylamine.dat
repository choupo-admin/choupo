/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(p-aminobenzyl)cyclohexylamine  (C13H20N2, CAS 28480-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PAminobenzylCyclohexylamine;
formula     C13H20N2;
CAS         28480-77-5;
InChIKey    NRVOGWCXEOJNFS-UHFFFAOYSA-N;
MW          204.317;      // g/mol [origin=calculated method=formula-sum]
Tc          939.26;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.7304;      // -   [origin=predictive method=lee-kesler]
Tb          688.64;      // K   [origin=predictive method=joback]
HvapTb      68872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.219 1.3198 -0.00075996 1.475e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-azanylcyclohexyl)methyl]aniline" "benzenamine, 4-((4-aminocyclohexyl)methyl)-" "benzenamine, 4-[(4-aminocyclohexyl)methyl]-" "alpha-(4-aminocyclohexyl)-ptoluidine" "4-[(4-aminocyclohexyl)methyl]aniline" );
gibbsFormation
{
    dHf_298   14970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=311000.0
    phase     gas;
}
