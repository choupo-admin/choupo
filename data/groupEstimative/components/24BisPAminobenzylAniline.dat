/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-bis(p-aminobenzyl)aniline  (C20H21N3, CAS 25834-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24BisPAminobenzylAniline;
formula     C20H21N3;
CAS         25834-80-4;
InChIKey    KKVLCJIOPNYOQN-UHFFFAOYSA-N;
MW          303.409;      // g/mol [origin=calculated method=formula-sum]
Tc          1243.52;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       1.2141;      // -   [origin=predictive method=lee-kesler]
Tb          974.75;      // K   [origin=predictive method=joback]
HvapTb      101513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.338 1.6148 -0.00101984 2.367e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 2; } { group ACCH2; count 2; } { group ACNH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group NH2; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis[(4-aminophenyl)methyl]aniline" "2,4-bis(4-aminobenzyl)aniline" "2,4-bis(p-aminobenzyl) aniline" "benzenamine, 2,4-bis[(4-aminophenyl)methyl]-" "benzenamine, 2,4-bis((4-aminophenyl)methyl)-" "2,4-bis((4-aminophenyl)methyl)benzenamine" "benzenamine,2,4-bis[(4-aminophenyl)methyl]-" "2,4-xylidine,a,a'-bis(p-aminophenyl)- (7ci);2,4-bis(4-aminobenzyl)aniline;2,4-bis(p-aminobenzyl)aniline;3-(p-aminobenzyl)-4,4'-diaminodiphenylmethane;a,a'-bis(p-aminophenyl)-2,4-xylidine;" );
standardThermochemistry
{
    dHf_298   308950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     745.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=615580.0
}
