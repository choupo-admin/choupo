/*--------------------------------*- Choupo -*-----------------------*\
  Component: caprolactone, neopentyl glycol polymer  (C11H22O4, CAS 69089-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        caprolactoneNeopentylGlycolPolymer;
formula     C11H22O4;
CAS         69089-45-8;
InChIKey    GCBWZABFKKFDAH-UHFFFAOYSA-N;
MW          218.293;      // g/mol [origin=calculated method=formula-sum]
Tc          901.16;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       1.3760;      // -   [origin=predictive method=lee-kesler]
Tb          711.98;      // K   [origin=predictive method=joback]
HvapTb      80409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.198 1.13984 -0.0004806 4.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 5; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropane-1,3-diol;oxepan-2-one" "neopentyl glycol, epsilon-caprolactone polymer" );
standardThermochemistry
{
    dHf_298   -931660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     798.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-599930.0
}
