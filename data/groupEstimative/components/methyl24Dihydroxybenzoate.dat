/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,4-dihydroxybenzoate  (C8H8O4, CAS 2150-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl24Dihydroxybenzoate;
formula     C8H8O4;
CAS         2150-47-2;
InChIKey    IIFCLXHRIYTHPV-UHFFFAOYSA-N;
MW          168.148;      // g/mol [origin=calculated method=formula-sum]
Tc          868.60;      // K   [origin=predictive method=joback]
Pc          54.707;      // bar [origin=predictive method=joback]
omega       0.9659;      // -   [origin=predictive method=lee-kesler]
Tb          628.78;      // K   [origin=predictive method=joback]
HvapTb      69113.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.72 0.93932 -0.00086072 3.186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,4-bis(oxidanyl)benzoate" "benzoic acid, 2,4-dihydroxy-, methyl ester" "2,4-dihydroxybenzoic acid methyl ester" "methyl beta-resorcylate" ".beta.-resorcylic acid, methyl ester" "methyl-2,4-dihydroxybenzoate" "beta-resorcylic acid methyl ester" "m645" "2,4-dihydroxybenzoic acid methyl ester;methyl b-resorcylate;b-resorcylic acid, methyl ester(6ci,7ci,8ci);" );
gibbsFormation
{
    dHf_298   -643820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-490720.0
    phase     gas;
}
