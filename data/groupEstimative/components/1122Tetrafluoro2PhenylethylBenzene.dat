/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,1,2,2-tetrafluoro-2-phenylethyl)benzene  (C14H10F4, CAS 425-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122Tetrafluoro2PhenylethylBenzene;
formula     C14H10F4;
CAS         425-32-1;
InChIKey    OVEWNBYMFPGNRR-UHFFFAOYSA-N;
MW          254.226;      // g/mol [origin=calculated method=formula-sum]
Tc          785.21;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       0.5076;      // -   [origin=predictive method=lee-kesler]
Tb          563.90;      // K   [origin=predictive method=joback]
HvapTb      45450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.23 1.4748 -0.0012094 3.726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group F; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1,1,2,2-tetrakis(fluoranyl)-2-phenyl-ethyl]benzene" "benzene, 1,1'-(1,1,2,2-tetrafluoro-1,2-ethanediyl)bis-" "1,2-diphenyl-1,1,2,2-tetrafluoroethane" "bibenzyl, .alpha.,.alpha.,.alpha.',.alpha.'-tetrafluoro-" "(1,1,2,2-tetrafluoro-2-phenyl-ethyl)-benzene" );
standardThermochemistry
{
    dHf_298   -661170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-481740.0
}
