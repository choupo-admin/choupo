/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricetamide  (C16H24N2O5, CAS 363-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricetamide;
formula     C16H24N2O5;
CAS         363-20-2;
InChIKey    NLRFFZRHTICQBO-UHFFFAOYSA-N;
MW          324.377;      // g/mol [origin=calculated method=formula-sum]
Tc          1049.65;      // K   [origin=predictive method=joback]
Pc          17.624;      // bar [origin=predictive method=joback]
omega       1.2843;      // -   [origin=predictive method=lee-kesler]
Tb          844.91;      // K   [origin=predictive method=joback]
HvapTb      84673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.653 1.221 -0.00046748 -4.58e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group CONHCH2; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CdO; count 2; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(diethylamino)-2-oxidanylidene-ethyl]-3,4,5-trimethoxy-benzamide" "trimeglamide" "trimethobenzglycin" "tricetamide (usan)" "tricetamide [usan]" "n-((diethylcarbamoyl)methyl)-3,4,5-trimethoxybenzamide" "n-3,4,5-trimethoxybenzoylglycin-diethylamid" "n-(3,4,5-trimethoxybenzoyl)glycine diethylamide" "benzamide, n-((diethylcarbamoyl)methyl)-3,4,5-trimethoxy-" "benzamide, n-(2-(diethylamino)-2-oxoethyl)-3,4,5-trimethoxy-" "n-[2-(diethylamino)-2-oxoethyl]-3,4,5-trimethoxybenzamide" "benzamide,n-[2-(diethylamino)-2-oxoethyl]-3,4,5-trimethoxy-" );
standardThermochemistry
{
    dHf_298   -672270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     798.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205310.0
}
