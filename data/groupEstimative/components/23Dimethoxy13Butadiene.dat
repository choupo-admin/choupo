/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethoxy-1,3-butadiene  (C6H10O2, CAS 3588-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethoxy13Butadiene;
formula     C6H10O2;
CAS         3588-31-6;
InChIKey    NHBDKDZHQKQPTF-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          554.16;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.3516;      // -   [origin=predictive method=lee-kesler]
Tb          374.84;      // K   [origin=predictive method=joback]
HvapTb      32590.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.07 0.40724 -0.000131 -1.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethoxybuta-1,3-diene" "2,3-dimethoxybuta-1,3-diene;2,3-dimethoxybutadiene;1,3-butadiene, 2,3-dimethoxy-;" );
gibbsFormation
{
    dHf_298   -200330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51780.0
    phase     gas;
}
