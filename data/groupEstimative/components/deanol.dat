/*--------------------------------*- Choupo -*-----------------------*\
  Component: deanol  (C4H11NO, CAS 108-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deanol;
formula     C4H11NO;
CAS         108-01-0;
InChIKey    UEEJHVSXFDXPFK-UHFFFAOYSA-N;
MW          89.138;      // g/mol [origin=calculated method=formula-sum]
Tc          556.71;      // K   [origin=predictive method=joback]
Pc          43.742;      // bar [origin=predictive method=joback]
omega       0.7295;      // -   [origin=predictive method=lee-kesler]
Tb          395.74;      // K   [origin=predictive method=joback]
HvapTb      43220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.148 0.54174 -0.0003368 8.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethanol" "n,n-dimethylethanolamine" "dimethylaminoethanol" "dimethylethanolamine" "2-dimethylaminoethanol" "norcholine" "ethanol, 2-(dimethylamino)-" "dmae" "propamine a" "n,n-dimethyl-2-aminoethanol" "n,n-dimethylaminoethanol" "bimanol" );
standardThermochemistry
{
    dHf_298   -210590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43240.0
}
