/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 2-methyl-6-(1-methylethyl)-  (C14H16, CAS 7383-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene2Methyl61Methylethyl;
formula     C14H16;
CAS         7383-88-2;
InChIKey    KRVWMPNTAYTOGS-UHFFFAOYSA-N;
MW          184.282;      // g/mol [origin=calculated method=formula-sum]
Tc          803.14;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.5073;      // -   [origin=predictive method=lee-kesler]
Tb          575.10;      // K   [origin=predictive method=joback]
HvapTb      51610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.27 1.13816 -0.00077484 2.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-6-propan-2-yl-naphthalene" "agn-pc-00fsfr" );
gibbsFormation
{
    dHf_298   67090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264360.0
    phase     gas;
}
