/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dihydroanthracene-9,10-diol  (C14H12O2, CAS 56136-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dihydroanthracene910Diol;
formula     C14H12O2;
CAS         56136-13-1;
InChIKey    XNGBCVRGPNWAGY-UHFFFAOYSA-N;
MW          212.248;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.51;      // K   [origin=predictive method=joback]
Pc          44.802;      // bar [origin=predictive method=joback]
omega       1.0256;      // -   [origin=predictive method=lee-kesler]
Tb          751.62;      // K   [origin=predictive method=joback]
HvapTb      78712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.95 1.5532 -0.00150084 5.802e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-anthracenediol, 1,4-dihydro-" "1,4-dihydro-9,10-anthracenediol" );
standardThermochemistry
{
    dHf_298   -137490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43880.0
}
