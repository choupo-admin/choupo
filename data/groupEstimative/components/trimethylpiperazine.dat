/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylpiperazine  (C7H16N2, CAS 120-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylpiperazine;
formula     C7H16N2;
CAS         120-85-4;
InChIKey    UAIVFDJJMVMUGY-UHFFFAOYSA-N;
MW          128.219;      // g/mol [origin=calculated method=formula-sum]
Tc          578.30;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.4001;      // -   [origin=predictive method=lee-kesler]
Tb          395.65;      // K   [origin=predictive method=joback]
HvapTb      35347.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.22 1.05796 -0.000756 2.163e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-trimethylpiperazine" "piperazine, 1,2,4-trimethyl-" "1,4-trimethylpiperazine" "piperazine,2,4-trimethyl-" "1,2,4-trimethyldiethylenediamine" );
standardThermochemistry
{
    dHf_298   13890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278270.0
}
