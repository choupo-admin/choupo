/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxybenzylamine  (C8H11NO, CAS 2393-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxybenzylamine;
formula     C8H11NO;
CAS         2393-23-9;
InChIKey    IDPURXSQCKYKIJ-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          731.26;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.5417;      // -   [origin=predictive method=lee-kesler]
Tb          509.25;      // K   [origin=predictive method=joback]
HvapTb      49391.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.001 0.62412 -0.00030796 4.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl)methanamine" "benzenemethanamine, 4-methoxy-" "p-methoxybenzylamine" "anisylamine" "4-methoxy-benzylamine" "benzylamine, p-methoxy-" "4-aminomethyl-anisole" "4-methoxybenzyl amine" "(4-methoxyphenyl)methylamine" "1-(4-methoxyphenyl)methanamine" "4-methoxylbenzylamine" "4-(aminomethyl)anisole" );
gibbsFormation
{
    dHf_298   -81820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80710.0
    phase     gas;
}
