/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromo-4,4-dimethylpentane  (C7H14Br2, CAS 6300-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromo44Dimethylpentane;
formula     C7H14Br2;
CAS         6300-00-1;
InChIKey    WFQMMFFMGBXAOE-UHFFFAOYSA-N;
MW          257.997;      // g/mol [origin=calculated method=formula-sum]
Tc          705.38;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.4642;      // -   [origin=predictive method=lee-kesler]
Tb          488.41;      // K   [origin=predictive method=joback]
HvapTb      42362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.248 0.87696 -0.0006748 2.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-4,4-dimethyl-pentane" "pentane,1,2-dibromo-4,4-dimethyl-" "1,2-dibromo-4,4-dimethyl-pentane" );
standardThermochemistry
{
    dHf_298   -149180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37100.0
}
