/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyltetrahydro-2-furanol  (C5H10O2, CAS 7326-46-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyltetrahydro2Furanol;
formula     C5H10O2;
CAS         7326-46-7;
InChIKey    WBESQMVRIKXRFL-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          646.38;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.6578;      // -   [origin=predictive method=lee-kesler]
Tb          448.65;      // K   [origin=predictive method=joback]
HvapTb      47019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.52 0.93342 -0.0009247 3.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyloxolan-2-ol" "2-furanol, tetrahydro-2-methyl-" "agn-pc-0dbdtx" "furanol, tetrahydromethyl-" "2-methyl-tetrahydro-furan-2-ol" "tetrahydro-2-methyl-2-furanol" );
gibbsFormation
{
    dHf_298   -355040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200660.0
    phase     gas;
}
