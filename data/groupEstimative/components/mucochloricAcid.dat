/*--------------------------------*- Choupo -*-----------------------*\
  Component: mucochloric acid  (C4H2Cl2O3, CAS 87-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mucochloricAcid;
formula     C4H2Cl2O3;
CAS         87-56-9;
InChIKey    LUMLZKVIXLWTCI-UHFFFAOYSA-N;
MW          168.957;      // g/mol [origin=calculated method=formula-sum]
Tc          790.34;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       0.7943;      // -   [origin=predictive method=lee-kesler]
Tb          564.07;      // K   [origin=predictive method=joback]
HvapTb      57270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.47 0.4425 -0.0003886 1.313e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group COOH; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group Cl; count 2; } { group OdCH_al; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)-4-oxidanylidene-but-2-enoic acid" "(z)-2,3-dichloro-4-oxo-but-2-enoic acid" );
gibbsFormation
{
    dHf_298   -495580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-421370.0
    phase     gas;
}
