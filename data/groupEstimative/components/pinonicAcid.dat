/*--------------------------------*- Choupo -*-----------------------*\
  Component: pinonic acid  (C10H16O3, CAS 473-72-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pinonicAcid;
formula     C10H16O3;
CAS         473-72-3;
InChIKey    SIZDUQQDBXJXLQ-UHFFFAOYSA-N;
MW          184.235;      // g/mol [origin=calculated method=formula-sum]
Tc          843.79;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       0.8456;      // -   [origin=predictive method=lee-kesler]
Tb          629.69;      // K   [origin=predictive method=joback]
HvapTb      60080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.719 1.35686 -0.0011697 4.3776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-ethanoyl-2,2-dimethyl-cyclobutyl)ethanoic acid" "cyclobutaneacetic acid, 3-acetyl-2,2-dimethyl-" "cis-pinonic acid" "3-acetyl-2,2-dimethyl-cyclobutaneacetic acid" "cis-3-acetyl-2,2-dimethylcyclobutylacetic acid" "2-(3-acetyl-2,2-dimethylcyclobutyl)acetic acid" "3-acetyl-2,2-dimethylcyclobutaneacetic acid" "cyclobutaneacetic acid,2-dimethyl-" "(+) pinonic acid" "(+)-pinonic acid" "cyclobutaneacetic acid, 3-acetyl-2,2-dimethyl-, (1r,3r)-rel-" "pinonic acid (mixed isomers)" );
gibbsFormation
{
    dHf_298   -671380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411770.0
    phase     gas;
}
