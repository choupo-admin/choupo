/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-lauroylamidopropyl-n,n-bis(2-hydroxyethyl)amine  (C19H40N2O3, CAS 66161-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nLauroylamidopropylNNBis2HydroxyethylAmine;
formula     C19H40N2O3;
CAS         66161-63-5;
InChIKey    OQRZKRYPYZNLFV-UHFFFAOYSA-N;
MW          344.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1155.24;      // K   [origin=predictive method=joback]
Pc          12.902;      // bar [origin=predictive method=joback]
omega       1.0885;      // -   [origin=predictive method=lee-kesler]
Tb          935.16;      // K   [origin=predictive method=joback]
HvapTb      106471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.343 2.04892 -0.0012131 2.7336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group OH; count 2; } { group CH2N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 2; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[3-[bis(2-hydroxyethyl)amino]propyl]dodecanamide" "n-(3-(bis(2-hydroxyethyl)amino)propyl)dodecanamide" "n-{3-[bis(2-hydroxyethyl)amino]propyl}dodecanamide" "dodecanamide, n-(3-(bis(2-hydroxyethyl)amino)propyl)-" "dodecanamide, n-[3-[bis(2-hydroxyethyl)amino]propyl]-" );
standardThermochemistry
{
    dHf_298   -731530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1081.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93290.0
}
