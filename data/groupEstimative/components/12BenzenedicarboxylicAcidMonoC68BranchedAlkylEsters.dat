/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-benzenedicarboxylic acid, mono-c6-8-branched alkyl esters  (C14H18O4, CAS 71888-90-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BenzenedicarboxylicAcidMonoC68BranchedAlkylEsters;
formula     C14H18O4;
CAS         71888-90-9;
InChIKey    HFVPVWMVRZNFOP-JTQLQIEISA-N;
MW          250.294;      // g/mol [origin=calculated method=formula-sum]
Tc          968.14;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       1.0818;      // -   [origin=predictive method=lee-kesler]
Tb          754.87;      // K   [origin=predictive method=joback]
HvapTb      73879.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.117 1.19734 -0.00068316 1.264e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(3s)-3-methylpentoxy]carbonylbenzoic acid" );
gibbsFormation
{
    dHf_298   -780060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-486940.0
    phase     gas;
}
