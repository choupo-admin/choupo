/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,6-trichlorobenzaldehyde  (C7H3Cl3O, CAS 4659-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H3Cl3O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        236Trichlorobenzaldehyde;
formula     C7H3Cl3O;
CAS         4659-47-6;
InChIKey    AURSMWWOMOVHBM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          209.45;      // g/mol [origin=calculated method=formula-sum]
Tc          726.73;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       0.3666;      // -   [origin=predictive method=lee-kesler]
Tb          490.09;      // K   [origin=predictive method=joback]
HvapTb      46220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.69 0.4399 -0.00040128 1.466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CHO; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,6-tris(chloranyl)benzaldehyde" "benzaldehyde, 2,3,6-trichloro-" );
gibbsFormation
{
    dHf_298   43540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99750.0
    phase     gas;
}
