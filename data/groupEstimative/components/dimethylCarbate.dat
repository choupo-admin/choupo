/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl carbate  (C11H14O4, CAS 5826-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylCarbate;
formula     C11H14O4;
CAS         5826-73-3;
InChIKey    VGQLNJWOULYVFV-UHFFFAOYSA-N;
MW          210.229;      // g/mol [origin=calculated method=formula-sum]
Tc          780.82;      // K   [origin=predictive method=joback]
Pc          24.777;      // bar [origin=predictive method=joback]
omega       0.6846;      // -   [origin=predictive method=lee-kesler]
Tb          575.29;      // K   [origin=predictive method=joback]
HvapTb      54566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.24 1.12244 -0.00065588 1.22e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylate" "methyl 3-(methoxycarbonyl)bicyclo[2.2.1]hept-5-ene-2-carboxylate" "dimethyl-5-norbornene-2,3-dicarboxylate" "compound 3,916" "dimethyl carbate [iso]" "dimethyl bicyclo[2.2.1]-5-heptene-2,3-dicarboxylate" "5-norbornene-2, dimethyl ester" "5-norbornene-2, dimethyl ester, cis-" "2-norbornene, 5,6-bis(methoxycarbonyl)-" "bicyclo[2.2.1]hept-5-ene-2, dimethyl ester" "dimethyl cis-bicyclo[2,1]-5-heptene-2,3-dicarboxylate" "dimethyl cis-bicyclo[2.2.1]-5-heptene-2,3-dicarboxylate" );
gibbsFormation
{
    dHf_298   -748390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-455060.0
    phase     gas;
}
