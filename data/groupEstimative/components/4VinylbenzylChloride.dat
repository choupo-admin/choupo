/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-vinylbenzyl chloride  (C9H9Cl, CAS 1592-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4VinylbenzylChloride;
formula     C9H9Cl;
CAS         1592-20-7;
InChIKey    ZRZHXNCATOYMJH-UHFFFAOYSA-N;
MW          152.621;      // g/mol [origin=calculated method=formula-sum]
Tc          691.29;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.3742;      // -   [origin=predictive method=lee-kesler]
Tb          471.29;      // K   [origin=predictive method=joback]
HvapTb      42281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.999 0.7072 -0.00047326 1.229e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-4-ethenyl-benzene" "4-chloromethylstyrene" "4-(chloromethyl)styrene" "1-(chloromethyl)-4-vinylbenzene" "4-chloromethyl styrene" "1-(chloromethyl)-4-ethenylbenzene" "benzene, 1-(chloromethyl)-4-ethenyl-" "4-vinylbenzylchloride" "vinyl-benzyl chloride" "toluene, .alpha.-chlorovinyl-" "n964" "styrene,p-(chloromethyl)- (6ci,7ci,8ci);1-(chloromethyl)-4-vinylbenzene;4-(chloromethyl)styrene;cms 14;p-(chloromethyl)styrene;p-vinylbenzyl chloride;" );
gibbsFormation
{
    dHf_298   105660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203590.0
    phase     gas;
}
