/*--------------------------------*- Choupo -*-----------------------*\
  Component: dispiro(cyclopropane-1,2'-bicyclo(2.2.1)heptane-3',1-cyclopropane)  (C11H16, CAS 40827-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dispiroCyclopropane12Bicyclo221Heptane31Cyclopropane;
formula     C11H16;
CAS         40827-29-0;
InChIKey    SPMZJHBUXLRTDB-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          705.36;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.3475;      // -   [origin=predictive method=lee-kesler]
Tb          474.45;      // K   [origin=predictive method=joback]
HvapTb      37258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-302.94 2.2458 -0.002567 1.1428e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 2; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( ""dispiro[cyclopropane-1,2'-bicyclo[2.2.1]heptane-3',1""-cyclopropane]"" "dispiro[cyclopropane-1,2'-bicyclo[2.2.1]heptane-3',1''-cyclopropane]" );
gibbsFormation
{
    dHf_298   57470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285860.0
    phase     gas;
}
