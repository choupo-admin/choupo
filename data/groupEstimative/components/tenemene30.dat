/*--------------------------------*- Choupo -*-----------------------*\
  Component: tenemene 30  (C22H40N2, CAS 103-96-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tenemene30;
formula     C22H40N2;
CAS         103-96-8;
InChIKey    APTGHASZJUAUCP-UHFFFAOYSA-N;
MW          332.576;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.02;      // K   [origin=predictive method=joback]
Pc          11.321;      // bar [origin=predictive method=joback]
omega       0.9794;      // -   [origin=predictive method=lee-kesler]
Tb          834.08;      // K   [origin=predictive method=joback]
HvapTb      79600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.5 2.11968 -0.00124076 2.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group CHNH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n4-di(octan-2-yl)benzene-1,4-diamine" "antozite 1" "elastozone 30" "1,4-benzenediamine, n,n'-bis(1-methylheptyl)-" "n,n'-di(octan-2-yl)benzene-1,4-diamine" "n,n'-bis(1-methylheptyl)-p-phenylenediamine" "p-phenylenediamine, n,n'-bis(1-methylheptyl)-" "di-2-octyl-p-phenylenediamine" "n,n'-di(2-octyl)-p-phenylenediamine" "n,n'-bis(2-octyl)-p-phenylenediamine" "1,4-benzenediamine, n,n'-di-sec-octyl-" "n,n'-di(1-methylheptyl)-p-phenylenediamine" );
standardThermochemistry
{
    dHf_298   -175970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     962.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=411040.0
}
