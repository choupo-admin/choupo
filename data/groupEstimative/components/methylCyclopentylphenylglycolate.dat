/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl cyclopentylphenylglycolate  (C14H18O3, CAS 19833-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylCyclopentylphenylglycolate;
formula     C14H18O3;
CAS         19833-96-6;
InChIKey    FGMUSNHTKNGVQD-UHFFFAOYSA-N;
MW          234.295;      // g/mol [origin=calculated method=formula-sum]
Tc          929.31;      // K   [origin=predictive method=joback]
Pc          26.708;      // bar [origin=predictive method=joback]
omega       1.0077;      // -   [origin=predictive method=lee-kesler]
Tb          709.05;      // K   [origin=predictive method=joback]
HvapTb      72081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.0 1.49162 -0.001004 2.45e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-cyclopentyl-2-oxidanyl-2-phenyl-ethanoate" "methyl 2-cyclopentyl-2-hydroxy-2-phenylacetate" "methylcyclopentylphenylglycolate" "cyclopentyl(hydroxy)phenylacetic acid, methyl ester" "methylcyclopentyl(hydroxy)phenylacetat" "benzeneacetic acid, .alpha.-cyclopentyl-.alpha.-hydroxy-, methyl ester" "methyl cyclopentyl phenyl glycolate" "methyl-alpha-phenylcyclopentylglycolate" "(s)-2-cyclopentyl-2-methoxy-2-phenylacetic acid" "methyl-2-cyclopentyl-2-hydroxy-2-phenylacetate" "benzeneacetic acid, a-cyclopentyl-a-hydroxy-, methyl ester" );
gibbsFormation
{
    dHf_298   -513540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228390.0
    phase     gas;
}
