/*--------------------------------*- Choupo -*-----------------------*\
  Component: decen-3-yl acetate  (C12H22O2, CAS 56991-23-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decen3YlAcetate;
formula     C12H22O2;
CAS         56991-23-2;
InChIKey    WZHRMNRJRZTTCG-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          701.83;      // K   [origin=predictive method=joback]
Pc          18.659;      // bar [origin=predictive method=joback]
omega       0.6808;      // -   [origin=predictive method=lee-kesler]
Tb          528.62;      // K   [origin=predictive method=joback]
HvapTb      48655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.716 1.07494 -0.0005605 9.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-1-en-3-yl ethanoate" "1-vinyloctyl acetate" "1-decen-3-ol, acetate" "1-decen-3-ol, 3-acetate" "dec-1-en-3-yl acetate" );
standardThermochemistry
{
    dHf_298   -488140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174810.0
}
