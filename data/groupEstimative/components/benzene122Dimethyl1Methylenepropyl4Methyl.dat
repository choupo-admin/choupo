/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-(2,2-dimethyl-1-methylenepropyl)-4-methyl-  (C13H18, CAS 31006-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene122Dimethyl1Methylenepropyl4Methyl;
formula     C13H18;
CAS         31006-98-1;
InChIKey    YAHLCBIEBGPTJE-UHFFFAOYSA-N;
MW          174.287;      // g/mol [origin=calculated method=formula-sum]
Tc          740.91;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.3879;      // -   [origin=predictive method=lee-kesler]
Tb          522.03;      // K   [origin=predictive method=joback]
HvapTb      45584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.69 1.20618 -0.00084456 2.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,3-dimethylbut-1-en-2-yl)-4-methyl-benzene" "1-(3,3-dimethylbut-1-en-2-yl)-4-methylbenzene" );
standardThermochemistry
{
    dHf_298   20300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243490.0
}
