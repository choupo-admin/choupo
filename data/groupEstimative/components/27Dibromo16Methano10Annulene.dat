/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-dibromo-1,6-methano(10)annulene  (C11H8Br2, CAS 15825-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Dibromo16Methano10Annulene;
formula     C11H8Br2;
CAS         15825-93-1;
InChIKey    GZZQNARJTHEHTJ-UHFFFAOYSA-N;
MW          299.993;      // g/mol [origin=calculated method=formula-sum]
Tc          917.25;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.6180;      // -   [origin=predictive method=lee-kesler]
Tb          643.49;      // K   [origin=predictive method=joback]
HvapTb      58362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.6 0.914 -0.00070484 2.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 4; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,7-bis(bromanyl)bicyclo[4.4.1]undeca-1,3,5,7,9-pentaene" "2,7-dibromo-1,6-methano[10]annulene" "1,5-dibromo-1,6-methano[10]annulene" "gzzqnarjthehtj-uhfffaoysa-" "2,7-dibromobicyclo[4.4.1]undeca-1,3,5,7,9-pentaene" );
gibbsFormation
{
    dHf_298   180790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=258080.0
    phase     gas;
}
