/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-morpholin-4-ylethoxy)ethanol  (C8H17NO3, CAS 3603-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Morpholin4YlethoxyEthanol;
formula     C8H17NO3;
CAS         3603-45-0;
InChIKey    BLIMWOGCOCPQEU-UHFFFAOYSA-N;
MW          175.228;      // g/mol [origin=calculated method=formula-sum]
Tc          737.53;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       1.0600;      // -   [origin=predictive method=lee-kesler]
Tb          556.58;      // K   [origin=predictive method=joback]
HvapTb      59610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.386 1.0137 -0.0006123 1.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group FCH2O; count 1; } { group CH2N; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group OH; count 1; } { group O; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(4-morpholinyl)-ethoxy]ethanol" "ethanol, 2-[2-(4-morpholinyl)ethoxy]-" );
gibbsFormation
{
    dHf_298   -476550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156420.0
    phase     gas;
}
