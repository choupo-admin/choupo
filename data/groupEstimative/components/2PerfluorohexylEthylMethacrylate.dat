/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(perfluorohexyl)ethyl methacrylate  (C12H9F13O2, CAS 2144-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PerfluorohexylEthylMethacrylate;
formula     C12H9F13O2;
CAS         2144-53-8;
InChIKey    CDXFIRXEAJABAZ-UHFFFAOYSA-N;
MW          432.176;      // g/mol [origin=calculated method=formula-sum]
Tc          636.07;      // K   [origin=predictive method=joback]
Pc          12.856;      // bar [origin=predictive method=joback]
omega       0.7827;      // -   [origin=predictive method=lee-kesler]
Tb          500.07;      // K   [origin=predictive method=joback]
HvapTb      30726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.948 1.97712 -0.0018036 5.979e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CF3; count 1; } { group CF2; count 5; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 6; } { group dCH2; count 1; } { group dC; count 1; } { group F; count 13; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,7,7,8,8,8-tridecakis(fluoranyl)octyl 2-methylprop-2-enoate" "3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluorooctyl methacrylate" "1h,1h,2h,2h-perfluorooctyl methacrylate" "3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluorooctyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluorooctyl ester" "1h,1h,2h,2h-perfluorooctylmethacrylate" );
gibbsFormation
{
    dHf_298   -3094580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     844.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2696410.0
    phase     gas;
}
