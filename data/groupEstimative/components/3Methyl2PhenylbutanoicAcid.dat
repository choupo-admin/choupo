/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-phenylbutanoic acid  (C11H14O2, CAS 3508-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2PhenylbutanoicAcid;
formula     C11H14O2;
CAS         3508-94-9;
InChIKey    HDLQGISFYDYWFJ-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          847.78;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.7569;      // -   [origin=predictive method=lee-kesler]
Tb          622.59;      // K   [origin=predictive method=joback]
HvapTb      58744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.78 1.03254 -0.0006848 1.722e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2-phenyl-butanoic acid" "alpha-isopropylphenylacetic acid" "3-methyl-2-phenyl-butyric acid" "2-isopropyl-2-phenylacetic acid" "3-methyl-2-phenylbutyric acid" "butyric acid, 3-methyl-2-phenyl-" "benzeneacetic acid, alpha-(1-methylethyl)-" "(s)-3-methyl-2-phenyl-butyric acid" "benzeneacetic acid, alpha-(1-methylethyl)- (9ci)" "benzeneacetic acid, a-(1-methylethyl)-, sodium salt(1:1)" );
gibbsFormation
{
    dHf_298   -394670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194640.0
    phase     gas;
}
