/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-[(2,2',3,3',5,5',6,6'-octachlorobiphenyl-4,4'-diyl)diimino]diethanol  (C16H12Cl8N2O2, CAS 16088-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2222335566Octachlorobiphenyl44DiylDiiminoDiethanol;
formula     C16H12Cl8N2O2;
CAS         16088-56-5;
InChIKey    IQQMBEJKKYHXKS-UHFFFAOYSA-N;
MW          547.884;      // g/mol [origin=calculated method=formula-sum]
Tc          1539.89;      // K   [origin=predictive method=joback]
Pc          18.452;      // bar [origin=predictive method=joback]
omega       1.4698;      // -   [origin=predictive method=lee-kesler]
Tb          1252.98;      // K   [origin=predictive method=joback]
HvapTb      143692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (174.814 1.0458 -0.0005598 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group AC; count 4; } { group OH; count 2; } { group CH2NH; count 2; } { group ACCl; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dC_ring; count 12; } { group Cl; count 8; } { group OH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2,3,5,6-tetrakis(chloranyl)-4-[2,3,5,6-tetrakis(chloranyl)-4-(2-hydroxyethylamino)phenyl]phenyl]amino]ethanol" "2,2'-(2,2',3,3',5,5',6,6'-octachlorobiphenyl-4,4'-ylenediimino)diethanol" "2-[2,3,5,6-tetrachloro-4-[2,3,5,6-tetrachloro-4-(2-hydroxyethylamino)phenyl]anilino]ethanol" );
gibbsFormation
{
    dHf_298   -338650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     955.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22060.0
    phase     gas;
}
