/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-trimethoxybutane  (C7H16O3, CAS 10138-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Trimethoxybutane;
formula     C7H16O3;
CAS         10138-89-3;
InChIKey    OMAKZNALRADTRX-UHFFFAOYSA-N;
MW          148.202;      // g/mol [origin=calculated method=formula-sum]
Tc          598.65;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.5138;      // -   [origin=predictive method=lee-kesler]
Tb          426.14;      // K   [origin=predictive method=joback]
HvapTb      37630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.661 0.49108 -3.04e-05 -9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxybutyraldehyde dimethyl acetal" "butane, 1,1,3-trimethoxy-" "butyraldehyde, 3-methoxy-, dimethyl acetal" "1,3-trimethoxybutane" "butane,1,3-trimethoxy-" "butane,1,1,3-trimethoxy-" "butyraldehyde, dimethyl acetal" "butyraldehyde, 3-methoxy-, dimethyl acetal (8ci)" );
standardThermochemistry
{
    dHf_298   -595030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311820.0
}
