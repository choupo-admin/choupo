/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl methyl ether  (C8H10O, CAS 538-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylMethylEther;
formula     C8H10O;
CAS         538-86-3;
InChIKey    GQKZBCPTCWJTAS-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          640.21;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.3661;      // -   [origin=predictive method=lee-kesler]
Tb          431.74;      // K   [origin=predictive method=joback]
HvapTb      38088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.789 0.62172 -0.0003316 5.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxymethylbenzene" "(methoxymethyl)benzene" "benzene, (methoxymethyl)-" "methyl benzyl ether" "ether, benzyl methyl" "methoxyphenylmethane" "benzyl-methyl ether" "alpha-methoxytoluene" ".alpha.-methoxytoluene" "benzene, methoxymethyl-" "1-(methoxymethyl)benzene" "agn-pc-0d0s4s" );
gibbsFormation
{
    dHf_298   -104140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23890.0
    phase     gas;
}
