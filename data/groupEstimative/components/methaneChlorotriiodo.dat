/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, chlorotriiodo-  (CClI3, CAS 14349-82-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneChlorotriiodo;
formula     CClI3;
CAS         14349-82-7;
InChIKey    NHPRHZOZGKPNLB-UHFFFAOYSA-N;
MW          428.161;      // g/mol [origin=calculated method=formula-sum]
Tc          866.26;      // K   [origin=predictive method=joback]
Pc          51.166;      // bar [origin=predictive method=joback]
omega       0.1735;      // -   [origin=predictive method=lee-kesler]
Tb          536.10;      // K   [origin=predictive method=joback]
HvapTb      49028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.47 0.3484 -0.000467 2.013e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group C; count 1; } { group Cl; count 1; } { group I; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranyl-tris(iodanyl)methane" );
gibbsFormation
{
    dHf_298   142150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122810.0
    phase     gas;
}
