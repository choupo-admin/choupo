/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-(2-(tridecyloxy)ethoxy)ethoxy)ethanol  (C19H40O4, CAS 4403-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222TridecyloxyEthoxyEthoxyEthanol;
formula     C19H40O4;
CAS         4403-12-7;
InChIKey    KLFVDTRVIFNWIH-UHFFFAOYSA-N;
MW          332.525;      // g/mol [origin=calculated method=formula-sum]
Tc          971.80;      // K   [origin=predictive method=joback]
Pc          11.104;      // bar [origin=predictive method=joback]
omega       1.0635;      // -   [origin=predictive method=lee-kesler]
Tb          793.76;      // K   [origin=predictive method=joback]
HvapTb      81797.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.408 1.65322 -0.0007072 6.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2O; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-tridecoxyethoxy)ethoxy]ethanol" "triethylene glycol monotridecyl ether" "2-{2-[2-(tridecyloxy)ethoxy]ethoxy}ethanol" "ethanol, 2-(2-(2-(tridecyloxy)ethoxy)ethoxy)-" "ethanol, 2-[2-[2-(tridecyloxy)ethoxy]ethoxy]-" "tridecyl alcohol di(oxyethylene) ethanol" );
standardThermochemistry
{
    dHf_298   -984380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     980.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-342720.0
}
