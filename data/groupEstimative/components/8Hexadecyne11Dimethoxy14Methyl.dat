/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-hexadecyne, 1,1-dimethoxy-14-methyl-  (C19H36O2, CAS 71566-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Hexadecyne11Dimethoxy14Methyl;
formula     C19H36O2;
CAS         71566-66-0;
InChIKey    CHUDCFHFRGFLQT-GOSISDBHSA-N;
MW          296.495;      // g/mol [origin=calculated method=formula-sum]
Tc          864.55;      // K   [origin=predictive method=joback]
Pc          11.891;      // bar [origin=predictive method=joback]
omega       0.8272;      // -   [origin=predictive method=lee-kesler]
Tb          687.28;      // K   [origin=predictive method=joback]
HvapTb      64084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.811 1.54448 -0.00070206 8.328e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 2; } { group CH3O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 2; } { group tC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(14r)-1,1-dimethoxy-14-methyl-hexadec-8-yne" "14-methyl-8-hexadecynal dimethyl acetal" "(14r)-1,1-dimethoxy-14-methylhexadec-8-yne" );
standardThermochemistry
{
    dHf_298   -438190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     871.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97020.0
}
