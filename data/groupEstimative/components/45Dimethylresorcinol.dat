/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-dimethylresorcinol  (C8H10O2, CAS 527-55-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45Dimethylresorcinol;
formula     C8H10O2;
CAS         527-55-9;
InChIKey    RCNCKKACINZDOI-UHFFFAOYSA-N;
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          815.08;      // K   [origin=predictive method=joback]
Pc          53.124;      // bar [origin=predictive method=joback]
omega       0.7748;      // -   [origin=predictive method=lee-kesler]
Tb          575.54;      // K   [origin=predictive method=joback]
HvapTb      62368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.83 0.93464 -0.00088828 3.508e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-dimethylbenzene-1,3-diol" "o-xylorcinol" "4-methylorcinol" "3,2-dimethylbenzene" "1,5-dihydroxybenzene" "resorcinol,5-dimethyl-" "4,5-dimethyl resorcinol" "resorcinol, 4,5-dimethyl-" "1,3-benzenediol,4,5-dimethyl-" "1,3-benzenediol, 4,5-dimethyl-" "1,2-dimethyl-3,5-dihydroxybenzene" "1,3-dihydroxy-4,5-dimethylbenzene" );
standardThermochemistry
{
    dHf_298   -338010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189980.0
}
