/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methylquinolin-8-amine  (C10H10N2, CAS 68420-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methylquinolin8Amine;
formula     C10H10N2;
CAS         68420-93-9;
InChIKey    ZAKYERLVLCYWJN-UHFFFAOYSA-N;
MW          158.204;      // g/mol [origin=calculated method=formula-sum]
Tc          868.11;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.6247;      // -   [origin=predictive method=lee-kesler]
Tb          610.25;      // K   [origin=predictive method=joback]
HvapTb      59945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.4 0.84788 -0.0006067 1.774e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 4; } { group NH2; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-quinolinamine, 6-methyl-" "6-methyl-8-quinolinamine" "8-amino-6-methylquinoline" "6-methyl-quinolin-8-ylamine" "8-quinolinamine, 6-methyl-;6-methyl-8-quinolinamine;" );
gibbsFormation
{
    dHf_298   221510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=376620.0
    phase     gas;
}
