/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-hydroxyisovaleric acid  (C5H10O3, CAS 625-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaHydroxyisovalericAcid;
formula     C5H10O3;
CAS         625-08-1;
InChIKey    AXFYFNCPONWUHW-UHFFFAOYSA-N;
MW          118.132;      // g/mol [origin=calculated method=formula-sum]
Tc          740.26;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       1.0483;      // -   [origin=predictive method=lee-kesler]
Tb          548.46;      // K   [origin=predictive method=joback]
HvapTb      59271.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.239 0.68944 -0.000523 1.58e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-3-oxidanyl-butanoic acid" "3-hydroxy-3-methylbutanoic acid" "3-hydroxy-3-methylbutyric acid" "3-hydroxyisovaleric acid" "3-oh-isovaleric acid" "3-hydroxy-isovaleric acid" "hmb-d6" "b-hydroxyisovaleric acid" "beta-hydroxy-beta-methylbutyrate" "3-hydroxy-3-methyl-butanoic acid" "beta-hydroxy-beta-methylbutyric acid" "3-hydroxy-3-methyl butanoic acid" );
standardThermochemistry
{
    dHf_298   -657780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-486670.0
}
