/*--------------------------------*- Choupo -*-----------------------*\
  Component: nacconate 310  (C17H14N2O2, CAS 139-25-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nacconate310;
formula     C17H14N2O2;
CAS         139-25-3;
InChIKey    DTZHXCBUWSTOPO-UHFFFAOYSA-N;
MW          278.311;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.27;      // K   [origin=predictive method=joback]
Pc          22.676;      // bar [origin=predictive method=joback]
omega       0.9909;      // -   [origin=predictive method=lee-kesler]
Tb          795.18;      // K   [origin=predictive method=joback]
HvapTb      79700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH3; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCd; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-[(4-isocyanato-3-methyl-phenyl)methyl]-2-methyl-benzene" "3,3'-dimethyldiphenylmethane-4,4'-diisocyanate" "5,5'-methylenebis(2-isocyanatotoluene)" "4,4'-diisocyanato-3,3'-dimethyldiphenylmethane" "toluene, 5,5'-methylenebis(2-isocyanato-" "3,3'-dimethyldiphenylmethane 4,4'-diisocyanate" "benzene, 1,1'-methylenebis(4-isocyanato-3-methyl-" "isocyanic acid, methylenebis(2-methyl-p-phenylene) ester" "3,3'-dimethyldiphenylmethane-4,4'-diisocyanate [diisocyanates]" "benzene, 1,1'-methylenebis[4-isocyanato-3-methyl-" "toluene,5'-methylenebis[2-isocyanato-" "bis(4-isocyanato-3-methylphenyl)methane" );
