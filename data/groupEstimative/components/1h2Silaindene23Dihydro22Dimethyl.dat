/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-2-silaindene,2,3-dihydro-2,2-dimethyl-  (C10H14Si, CAS 2764-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H14Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1h2Silaindene23Dihydro22Dimethyl;
formula     C10H14Si;
CAS         2764-87-6;
InChIKey    GCMFIUAXWRNTCR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          162.307;      // g/mol [origin=calculated method=formula-sum]
Tc          691.40;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.3131;      // -   [origin=predictive method=lee-kesler]
Tb          468.60;      // K   [origin=predictive method=joback]
HvapTb      41136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.05 0.79624 -0.00039156 4.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH2; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-1,3-dihydro-2-benzosilole" "2,2-dimethyl-2,3-dihydro-1h-2-benzosilole" "1h-2-silaindene, 2,3-dihydro-2,2-dimethyl-" "8,8-dimethyl-8-silabicyclo[4.3.0]nona-1,3,5-triene" "2-silaindan,2,2-dimethyl- (7ci,8ci); 2,2-dimethyl-2-silaindan;3,4-benzo-1,1-dimethyl-1-silacyclopentene" );
standardThermochemistry
{
    dHf_298   -36990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111900.0
}
