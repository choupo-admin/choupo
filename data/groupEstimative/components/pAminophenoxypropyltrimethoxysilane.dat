/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-aminophenoxypropyltrimethoxysilane  (C12H21NO4Si, CAS 55648-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H21NO4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pAminophenoxypropyltrimethoxysilane;
formula     C12H21NO4Si;
CAS         55648-29-8;
InChIKey    FGYPEIBVFQOQKC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          271.388;      // g/mol [origin=calculated method=formula-sum]
Tc          876.64;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       0.8609;      // -   [origin=predictive method=lee-kesler]
Tb          669.43;      // K   [origin=predictive method=joback]
HvapTb      65819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (121.683 0.60836 0.00022224 -2.932e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH3O; count 3; } { group CH2O; count 1; } { group ACNH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-trimethoxysilylpropoxy)aniline" "4-[3-(trimethoxysilyl)propoxy]aniline" "benzenamine, 4-(3-(trimethoxysilyl)propoxy)-" "benzenamine, 4-[3-(trimethoxysilyl)propoxy]-" "3-(4-aminophenoxy)propyltrimethoxysilane" "4-(3-trimethoxysilylpropoxy)aniline;p-aminophenoxypropyltrimethoxysilane;" );
gibbsFormation
{
    dHf_298   -672660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-305370.0
    phase     gas;
}
