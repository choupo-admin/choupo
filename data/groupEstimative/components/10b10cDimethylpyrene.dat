/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10b,10c-dimethylpyrene  (C18H16, CAS 956-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10b10cDimethylpyrene;
formula     C18H16;
CAS         956-84-3;
InChIKey    SHCAFRNIXFPCQX-UHFFFAOYSA-N;
MW          232.326;      // g/mol [origin=calculated method=formula-sum]
Tc          939.95;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.5762;      // -   [origin=predictive method=lee-kesler]
Tb          679.34;      // K   [origin=predictive method=joback]
HvapTb      59010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-235.13 2.28584 -0.0024694 1.0628e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 2; } { group ACH; count 10; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrene,10b,10c-dihydro-10b,10c-dimethyl-,trans-" "pyrene, 10b,10c-dihydro-10b,10c-dimethyl-, trans-" );
gibbsFormation
{
    dHf_298   281450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=470920.0
    phase     gas;
}
