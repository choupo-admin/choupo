/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-butoxy-5-methylhex-1-en-3-yne  (C11H18O, CAS 819-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Butoxy5Methylhex1En3Yne;
formula     C11H18O;
CAS         819-41-0;
InChIKey    OUIQSMDXNSJEQD-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          673.75;      // K   [origin=predictive method=joback]
Pc          23.338;      // bar [origin=predictive method=joback]
omega       0.4090;      // -   [origin=predictive method=lee-kesler]
Tb          476.15;      // K   [origin=predictive method=joback]
HvapTb      42676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.483 0.94166 -0.00056616 1.3318e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-butoxy-5-methyl-hex-1-en-3-yne" "dimethylvinylethynylmethanol butyl ether" );
gibbsFormation
{
    dHf_298   -13610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230220.0
    phase     gas;
}
