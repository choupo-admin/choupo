name        fenylaminomethylsilatran;
formula     C13H20N2O3Si;
CAS         36350-95-5;
InChIKey    YGHSPISFNKUQEY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          280.399;      // g/mol [origin=calculated method=formula-sum]
Tc          948.37;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.8200;      // -   [origin=predictive method=lee-kesler]
Tb          704.21;      // K   [origin=predictive method=joback]
HvapTb      70071.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.679 1.4708 -0.0008313 1.389e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 3; } { group CH2NH; count 1; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 3; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecan-5-ylmethyl)aniline" "phenylaminomethylsilatrane" "silatrane, phenylaminomethyl-" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, phenylaminomethyl-" "n-(2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undec-1-ylmethyl)aniline" "n-(2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undec-1-ylmethyl)aniline; n-phenyl-n-(2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undec-1-ylmethyl)amine" );
standardThermochemistry
{
    dHf_298   -293940.0;      // J/mol ideal-gas [origin=predictive method=joback]
