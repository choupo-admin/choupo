/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl ether  (C24H50O, CAS 4542-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecylEther;
formula     C24H50O;
CAS         4542-57-8;
InChIKey    CMCBDXRRFKYBDG-UHFFFAOYSA-N;
MW          354.663;      // g/mol [origin=calculated method=formula-sum]
Tc          944.64;      // K   [origin=predictive method=joback]
Pc          7.984;      // bar [origin=predictive method=joback]
omega       0.7575;      // -   [origin=predictive method=lee-kesler]
Tb          771.14;      // K   [origin=predictive method=joback]
HvapTb      71428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.572 2.22064 -0.0011708 2.196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 21; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-dodecoxydodecane" "didodecyl ether" "dilauryl ether" "lauryl ether" "dodecane, 1,1'-oxybis-" "1,1'-oxybisdodecane" "dodecane,1'-oxybis-" "dodecyl ether (8ci)" );
gibbsFormation
{
    dHf_298   -670910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1102.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46200.0
    phase     gas;
}
