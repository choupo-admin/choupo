/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-ethyl-2,4-xylidine  (C10H15N, CAS 40813-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Ethyl24Xylidine;
formula     C10H15N;
CAS         40813-98-7;
InChIKey    VBOWSMQIENLDDN-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          761.77;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.5615;      // -   [origin=predictive method=lee-kesler]
Tb          542.55;      // K   [origin=predictive method=joback]
HvapTb      52757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.281 0.75836 -0.00039368 6.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-4,6-dimethyl-aniline" "2-ethyl-4,6-dimethylaniline" "2,4-xylidine, 6-ethyl-" "benzenamine,2-ethyl-4,6-dimethyl-" "2,4-xylidine,6-ethyl- (6ci); 2,4-dimethyl-6-ethylaniline; 2-ethyl-4,6-dimethylaniline;6-ethyl-2,4-xylidine" );
gibbsFormation
{
    dHf_298   -13820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183290.0
    phase     gas;
}
