/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-ethoxypropionate  (C7H14O3, CAS 763-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Ethoxypropionate;
formula     C7H14O3;
CAS         763-69-9;
InChIKey    BHXIWUJLHYHGSJ-UHFFFAOYSA-N;
MW          146.186;      // g/mol [origin=calculated method=formula-sum]
Tc          613.08;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.5777;      // -   [origin=predictive method=lee-kesler]
Tb          440.40;      // K   [origin=predictive method=joback]
HvapTb      40993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.434 0.55084 -0.0001514 -3.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-ethoxypropanoate" "propanoic acid, 3-ethoxy-, ethyl ester" "3-ethoxypropionic acid ethyl ester" "ethoxypropionic acid, ethyl ester" "ethyl-3-ethoxypropionate" "propionic acid, 3-ethoxy-, ethyl ester" "ethyl beta-ethoxypropionate" "ethyl .beta.-ethoxypropionate" "bhxiwujlhyhgsj-uhfffaoysa-" "ethylester kyseliny 3-ethoxypropionove" "3-ethoxypropionic acid ethyl ester(beta-)" );
gibbsFormation
{
    dHf_298   -637310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407310.0
    phase     gas;
}
