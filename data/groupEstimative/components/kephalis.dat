/*--------------------------------*- Choupo -*-----------------------*\
  Component: kephalis  (C14H24O2, CAS 36306-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        kephalis;
formula     C14H24O2;
CAS         36306-87-3;
InChIKey    YLNYLLVKHRZLGO-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          838.90;      // K   [origin=predictive method=joback]
Pc          19.441;      // bar [origin=predictive method=joback]
omega       0.5471;      // -   [origin=predictive method=lee-kesler]
Tb          617.41;      // K   [origin=predictive method=joback]
HvapTb      50334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.299 1.7352 -0.0014434 5.56e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group CH2=C; count 1; } { group CH2CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(1-ethoxyethenyl)-3,3,5,5-tetramethyl-cyclohexan-1-one" "4-(1-ethoxyvinyl)-3,3,5,5-tetramethylcyclohexanone" "cyclohexanone, 4-(1-ethoxyethenyl)-3,3,5,5-tetramethyl-" "3,3,5,5-etramethyl-4-ethoxyvinylcyclohexanone" "3,3,5,5-tetramethyl-4-ethoxyvinylcyclohexanone" "3,3,5,5-tetramethyl-4-(1-ethoxyvinyl)cyclohexanone" "4-(1-ethoxyethenyl)-3,3,5,5-tetramethylcyclohexanone" "3,3,5,5-tetramethyl-4-(1-ethoxyvinyl)-1-cyclohexanone" "4-(1-ethoxyethenyl)-3,3,5,5-tetramethyl-1-cyclohexanone" "4-(1-ethoxyethenyl)-3,3,5,5-tetramethylcyclohexan-1-one" );
standardThermochemistry
{
    dHf_298   -442450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83250.0
}
