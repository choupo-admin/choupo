/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methylthio)cyclohexanone  (C7H12OS, CAS 52190-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylthioCyclohexanone;
formula     C7H12OS;
CAS         52190-35-9;
InChIKey    QFABNUVNDKOIEH-UHFFFAOYSA-N;
MW          144.232;      // g/mol [origin=calculated method=formula-sum]
Tc          763.74;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.3912;      // -   [origin=predictive method=lee-kesler]
Tb          515.91;      // K   [origin=predictive method=joback]
HvapTb      42669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.05 0.61701 -0.0001538 -5.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylsulfanylcyclohexan-1-one" );
gibbsFormation
{
    dHf_298   -229320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56960.0
    phase     gas;
}
