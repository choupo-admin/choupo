/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl 3,5-diamino-4-methylbenzoate  (C16H26N2O2, CAS 42908-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylhexyl35Diamino4Methylbenzoate;
formula     C16H26N2O2;
CAS         42908-15-6;
InChIKey    IUSWWMQKWNMRSQ-UHFFFAOYSA-N;
MW          278.396;      // g/mol [origin=calculated method=formula-sum]
Tc          1023.52;      // K   [origin=predictive method=joback]
Pc          18.247;      // bar [origin=predictive method=joback]
omega       1.1129;      // -   [origin=predictive method=lee-kesler]
Tb          810.14;      // K   [origin=predictive method=joback]
HvapTb      83773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.045 1.34136 -0.00067208 9.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACNH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl 3,5-bis(azanyl)-4-methyl-benzoate" "benzoic acid, 3,5-diamino-4-methyl-, 2-ethylhexyl ester" "4-methyl-3,5-diaminobenzoic acid, 2-ethylhexyl ester" );
standardThermochemistry
{
    dHf_298   -426430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     799.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12550.0
}
