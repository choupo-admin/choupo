/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylheptane-3,5-dione  (C9H16O2, CAS 20734-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylheptane35Dione;
formula     C9H16O2;
CAS         20734-29-6;
InChIKey    LHQYNVWJWUCTSS-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          705.03;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.6027;      // -   [origin=predictive method=lee-kesler]
Tb          510.03;      // K   [origin=predictive method=joback]
HvapTb      47824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.048 0.92868 -0.0006002 1.4972e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-3,5-heptanedione" "2,2-dimethylheptane-3,5-dione, keto form" );
gibbsFormation
{
    dHf_298   -463000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230100.0
    phase     gas;
}
