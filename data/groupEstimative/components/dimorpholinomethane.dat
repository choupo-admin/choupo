/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimorpholinomethane  (C9H18N2O2, CAS 5625-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimorpholinomethane;
formula     C9H18N2O2;
CAS         5625-90-1;
InChIKey    MIFZZKZNMWTHJK-UHFFFAOYSA-N;
MW          186.255;      // g/mol [origin=calculated method=formula-sum]
Tc          740.63;      // K   [origin=predictive method=joback]
Pc          35.515;      // bar [origin=predictive method=joback]
omega       0.6073;      // -   [origin=predictive method=lee-kesler]
Tb          524.20;      // K   [origin=predictive method=joback]
HvapTb      49866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.879 1.417 -0.0010288 2.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group FCH2O; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 8; } { group O_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(morpholin-4-ylmethyl)morpholine" "n,n'-dimorpholinomethane" "4,4-methylenedimorpholine" "dimorpholinomethone" "bismorpholino methane" "n,n-dimorpholinomethane" "4,4'-methylenedimorpholine" "n,n'-methylenebismorpholine" "bis(morpholino-)methan [german]" "morpholine, 4,4'-methylenebis-" "morpholine, 4,4'-methylenedi-" "bis(morpholino-)methan" );
gibbsFormation
{
    dHf_298   -196390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162740.0
    phase     gas;
}
