/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisphenol tmc  (C21H26O2, CAS 129188-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisphenolTmc;
formula     C21H26O2;
CAS         129188-99-4;
InChIKey    UMPGNGRIGSEMTC-UHFFFAOYSA-N;
MW          310.437;      // g/mol [origin=calculated method=formula-sum]
Tc          1177.44;      // K   [origin=predictive method=joback]
Pc          23.912;      // bar [origin=predictive method=joback]
omega       1.0089;      // -   [origin=predictive method=lee-kesler]
Tb          905.37;      // K   [origin=predictive method=joback]
HvapTb      90429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-255.56 2.80316 -0.00272912 1.1051e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-(4-hydroxyphenyl)-3,3,5-trimethyl-cyclohexyl]phenol" "phenol, 4,4'-(3,3,5-trimethylcyclohexylidene)bis-" "1,1-bis(4-hydroxyphenyl)-3,3,5-trimethylcyclohexane" "bptmc" "bisp-tmc" "4,4'-(3,3,5-trimethylcyclohexylidene)diphenol" "bis(4-hydroxyphenyl)-3,3,5-trimethylcyclohexane" "3,3,5-trimethyl-1,1-bis(4-hydroxyphenyl)cyclohexane" "4-[1-(4-hydroxyphenyl)-3,3,5-trimethylcyclohexyl]phenol" );
standardThermochemistry
{
    dHf_298   -314210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     837.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39570.0
}
