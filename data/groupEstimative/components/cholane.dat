/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholane  (C24H42, CAS 548-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholane;
formula     C24H42;
CAS         548-98-1;
InChIKey    QSHQKIURKJITMZ-BRPMRXRMSA-N;
MW          330.6;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.36;      // K   [origin=predictive method=joback]
Pc          12.073;      // bar [origin=predictive method=joback]
omega       0.6262;      // -   [origin=predictive method=lee-kesler]
Tb          783.06;      // K   [origin=predictive method=joback]
HvapTb      65913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-329.348 3.34968 -0.0028328 1.033e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 6; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 5; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10s,13r,14s,17r)-10,13-dimethyl-17-[(2r)-pentan-2-yl]-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthrene" "cholane [mi]" "(8r-(8alpha,9beta,10alpha,13alpha,14beta,17alpha(r*))-hexadecahydro-10,13-dimethyl-17-(1-methylbutyl)-1h-cyclopenta(a)phenanthrene" "1h-cyclopenta(a)phenanthrene, hexadecahydro-10,13-dimethyl-17-(1-methylbutyl)-, (8r-(8alpha,9beta,10alpha,13alpha,14beta,17alpha(r*)))-" );
gibbsFormation
{
    dHf_298   -314110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     831.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=297150.0
    phase     gas;
}
