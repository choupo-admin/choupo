/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethylbicyclo[1.1.0]butane  (C6H10, CAS 930-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethylbicyclo110Butane;
formula     C6H10;
CAS         930-25-6;
InChIKey    IGAOOQCFXPSZTQ-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          538.70;      // K   [origin=predictive method=joback]
Pc          44.802;      // bar [origin=predictive method=joback]
omega       0.2174;      // -   [origin=predictive method=lee-kesler]
Tb          342.30;      // K   [origin=predictive method=joback]
HvapTb      26130.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-192.79 1.47864 -0.001901 9.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethylbicyclo(1.1.0)butane" );
gibbsFormation
{
    dHf_298   21230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     308.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134360.0
    phase     gas;
}
