/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyldimethoxysilane  (C8H20O2Si, CAS 18230-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H20O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diisopropyldimethoxysilane;
formula     C8H20O2Si;
CAS         18230-61-0;
InChIKey    VHPUZTHRFWIGAW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          176.331;      // g/mol [origin=calculated method=formula-sum]
Tc          605.45;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.3871;      // -   [origin=predictive method=lee-kesler]
Tb          428.00;      // K   [origin=predictive method=joback]
HvapTb      37740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.07 0.44312 0.000219 -2.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH3O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethoxy-di(propan-2-yl)silane" "diisopropyl(dimethoxy)silane" "silane, dimethoxybis(1-methylethyl)-" "silane,dimethoxybis(1-methylethyl)-" "m309" );
gibbsFormation
{
    dHf_298   -595070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-303160.0
    phase     gas;
}
