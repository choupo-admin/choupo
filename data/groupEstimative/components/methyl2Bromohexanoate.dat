/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-bromohexanoate  (C7H13BrO2, CAS 5445-19-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Bromohexanoate;
formula     C7H13BrO2;
CAS         5445-19-2;
InChIKey    YGLPDRIMFIXNBI-UHFFFAOYSA-N;
MW          209.083;      // g/mol [origin=calculated method=formula-sum]
Tc          676.94;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.5944;      // -   [origin=predictive method=lee-kesler]
Tb          483.70;      // K   [origin=predictive method=joback]
HvapTb      44630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.443 0.65814 -0.000337 4.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-bromanylhexanoate" "methyl 2-bromocaproate" "2-bromohexanoic acid methyl ester" "hexanoic acid, 2-bromo-, methyl ester" "hexanoic acid, 2-bromo-, methyl ester, (s)-" );
standardThermochemistry
{
    dHf_298   -484040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-290430.0
}
