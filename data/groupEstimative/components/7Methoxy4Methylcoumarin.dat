/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methoxy-4-methylcoumarin  (C11H10O3, CAS 2555-28-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methoxy4Methylcoumarin;
formula     C11H10O3;
CAS         2555-28-4;
InChIKey    UDFPKNSWSYBIHO-UHFFFAOYSA-N;
MW          190.198;      // g/mol [origin=calculated method=formula-sum]
Tc          797.40;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.6955;      // -   [origin=predictive method=lee-kesler]
Tb          579.84;      // K   [origin=predictive method=joback]
HvapTb      54501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.51 0.80444 -0.00050836 1.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methoxy-4-methyl-chromen-2-one" "2h-1-benzopyran-2-one, 7-methoxy-4-methyl-" "7-methoxy-4-methylchromen-2-one" "7-methoxy-4-methyl-2h-chromen-2-on" "7-methoxy-4-methyl-2h-chromen-2-one" "methyl 4-methylumbelliferyl ether" "coumarin,4-methyl-7-methoxy" "sdccgmls-0066546.p001" "7-methoxy-4-methyl-1-benzopyran-2-one" "7-methoxy-4-methyl-2h-1-benzopyran-2-one" "2h-1-benzopyran-2-one,7-methoxy-4-methyl-" "brd-k55766625-001-02-6" );
gibbsFormation
{
    dHf_298   -360670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-179590.0
    phase     gas;
}
