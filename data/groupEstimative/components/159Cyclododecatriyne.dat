/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5,9-cyclododecatriyne  (C12H12, CAS 60323-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        159Cyclododecatriyne;
formula     C12H12;
CAS         60323-50-4;
InChIKey    PYXWKTZVNXGDJK-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          810.40;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       0.2219;      // -   [origin=predictive method=lee-kesler]
Tb          525.38;      // K   [origin=predictive method=joback]
HvapTb      49500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.89 0.843 -0.00048898 1.0634e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C_C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 6; } { group CH2_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclododeca-1,5,9-triyne" );
standardThermochemistry
{
    dHf_298   600550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=690720.0
}
