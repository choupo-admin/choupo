/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,5,5,8,8-hexamethylnona-3,6-diyne  (C15H24, CAS 116503-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        225588Hexamethylnona36Diyne;
formula     C15H24;
CAS         116503-39-0;
InChIKey    XQCLEAPKEXXCOD-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          787.17;      // K   [origin=predictive method=joback]
Pc          19.220;      // bar [origin=predictive method=joback]
omega       0.2788;      // -   [origin=predictive method=lee-kesler]
Tb          551.11;      // K   [origin=predictive method=joback]
HvapTb      49400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.05 1.50676 -0.00112332 3.4096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group C; count 3; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 3; } { group tC; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-nonadiyne, 2,2,5,5,8,8-hexamethyl-" "2,2,5,5,8,8-hexamethylnona-3,6-diyne;" );
standardThermochemistry
{
    dHf_298   165420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=489540.0
}
