/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-hexadecyl-1,2,3,4-tetrahydronaphthalene  (C26H44, CAS 2655-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Hexadecyl1234Tetrahydronaphthalene;
formula     C26H44;
CAS         2655-96-1;
InChIKey    CEJDNZVHBMHQMZ-UHFFFAOYSA-N;
MW          356.638;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.38;      // K   [origin=predictive method=joback]
Pc          9.615;      // bar [origin=predictive method=joback]
omega       0.8516;      // -   [origin=predictive method=lee-kesler]
Tb          846.80;      // K   [origin=predictive method=joback]
HvapTb      77464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.355 2.44372 -0.00151692 3.715e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 3; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecane, 1-(5,6,7,8-tetrahydro-2-naphthyl)-" "hexadecane, 1-(5,6,7,8-tetrahydro-2-naphthyl)-," );
standardThermochemistry
{
    dHf_298   -279400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1022.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=317550.0
}
