/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexene-1-carboxylic acid, 2-ethyl-3,6,6-trimethyl-, ethyl ester  (C14H24O2, CAS 94333-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexene1CarboxylicAcid2Ethyl366TrimethylEthylEster;
formula     C14H24O2;
CAS         94333-50-3;
InChIKey    KTRBAYCZFGTSLJ-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          804.64;      // K   [origin=predictive method=joback]
Pc          18.357;      // bar [origin=predictive method=joback]
omega       0.6276;      // -   [origin=predictive method=lee-kesler]
Tb          602.38;      // K   [origin=predictive method=joback]
HvapTb      54750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.708 1.4916 -0.0010546 3.321e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-ethyl-3,6,6-trimethyl-cyclohexene-1-carboxylate" "ethyl 2-ethyl-3,6,6-trimethylcyclohexenecarboxylate" "ethyl 2-ethyl-3,6,6-trimethylcyclohexene-1-carboxylate" );
gibbsFormation
{
    dHf_298   -565510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-221420.0
    phase     gas;
}
