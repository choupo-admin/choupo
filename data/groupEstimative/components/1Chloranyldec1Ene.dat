/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloranyldec-1-ene  (C10H19Cl, CAS 66291-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloranyldec1Ene;
formula     C10H19Cl;
CAS         66291-47-2;
InChIKey    FBECTVVCBRAZRM-UHFFFAOYSA-N;
MW          174.712;      // g/mol [origin=calculated method=formula-sum]
Tc          646.54;      // K   [origin=predictive method=joback]
Pc          21.374;      // bar [origin=predictive method=joback]
omega       0.5211;      // -   [origin=predictive method=lee-kesler]
Tb          469.99;      // K   [origin=predictive method=joback]
HvapTb      42197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.493 0.98062 -0.0006244 1.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=CH; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-decene, 1-chloro-, (1e)-" );
standardThermochemistry
{
    dHf_298   -148250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101610.0
}
