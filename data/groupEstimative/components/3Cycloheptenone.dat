/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cycloheptenone  (C7H10O, CAS 1121-64-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cycloheptenone;
formula     C7H10O;
CAS         1121-64-8;
InChIKey    PKTLJWUNHIKVME-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          691.17;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       0.3204;      // -   [origin=predictive method=lee-kesler]
Tb          455.23;      // K   [origin=predictive method=joback]
HvapTb      36625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.93 0.5835 -0.00019028 -2.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohept-3-en-1-one" "3-cyclohepten-1-one" );
standardThermochemistry
{
    dHf_298   -199230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     344.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64510.0
}
