/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene, 1,1-bis(p-bromo-phenyl)-2,2-dichloro-  (C14H8Br2Cl2, CAS 21655-73-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylene11BisPBromoPhenyl22Dichloro;
formula     C14H8Br2Cl2;
CAS         21655-73-2;
InChIKey    XYMOLSVHRUAQPB-UHFFFAOYSA-N;
MW          406.926;      // g/mol [origin=calculated method=formula-sum]
Tc          1083.01;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.7677;      // -   [origin=predictive method=lee-kesler]
Tb          794.34;      // K   [origin=predictive method=joback]
HvapTb      74392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.45 1.1668 -0.00093812 2.938e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group Br; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-[1-(4-bromophenyl)-2,2-bis(chloranyl)ethenyl]benzene" "benzene,1,1'-(dichloroethenylidene)bis[4-bromo- (9ci)" "1-bromo-4-[1-(4-bromophenyl)-2,2-dichloroethenyl]benzene" "ethylene, 1,1-bis(p-bromo-phenyl)-2,2-dichloro-;1,1'-(2,2-dichloroethene-1,1-diyl)bis(4-bromobenzene);" );
gibbsFormation
{
    dHf_298   236650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340460.0
    phase     gas;
}
