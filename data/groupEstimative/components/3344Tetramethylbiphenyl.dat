/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3',4,4'-tetramethylbiphenyl  (C16H18, CAS 4920-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3344Tetramethylbiphenyl;
formula     C16H18;
CAS         4920-95-0;
InChIKey    YXBIAYXZUDJVEB-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          872.82;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.5693;      // -   [origin=predictive method=lee-kesler]
Tb          638.96;      // K   [origin=predictive method=joback]
HvapTb      58410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.27 1.12808 -0.00064084 1.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3,4-dimethylphenyl)-1,2-dimethyl-benzene" "biphenyl, 3,3',4,4'-tetramethyl-" "3,3',4,4'-tetramethyl-1,1'-biphenyl" "1,1'-biphenyl, 3,3',4,4'-tetramethyl-" "3,3',4,4'-tetramethyldiphenyl" "3,4,3',4'-tetramethylbiphenyl" "4-(3,4-dimethylphenyl)-1,2-dimethylbenzene" "1,1'-biphenyl,3,3',4,4'-tetramethyl-" "1,1'-biphenyl, 3,3',4,4'-tetramethyl- (9ci)" "biphenyl,3,3',4,4'-tetramethyl- (6ci,7ci,8ci); 3,3',4,4'-tetramethylbiphenyl;3,3',4,4'-tetramethyldiphenyl; 3,4,3',4'-tetramethylbiphenyl" );
gibbsFormation
{
    dHf_298   53610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270140.0
    phase     gas;
}
