/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hepta-2,5-dien-7-ol  (C7H8O, CAS 822-80-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hepta25Dien7Ol;
formula     C7H8O;
CAS         822-80-0;
InChIKey    YKRVEGFRYRZTEY-UHFFFAOYSA-N;
MW          108.14;      // g/mol [origin=calculated method=formula-sum]
Tc          660.14;      // K   [origin=predictive method=joback]
Pc          46.026;      // bar [origin=predictive method=joback]
omega       0.6734;      // -   [origin=predictive method=lee-kesler]
Tb          463.34;      // K   [origin=predictive method=joback]
HvapTb      48128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.29 0.8565 -0.00070056 2.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 3; } { group dCH_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-hydroxynorbornadiene" "2,5-norbornadien-7-ol" "2,5-norbornadien-7-ol(6ci,7ci,8ci); 7-hydroxynorbornadiene; 7-norbornadienol" );
gibbsFormation
{
    dHf_298   -105380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     201.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32850.0
    phase     gas;
}
