/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-penten-4-yn-1-ol  (C6H8O, CAS 105-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2Penten4Yn1Ol;
formula     C6H8O;
CAS         105-29-3;
InChIKey    ZSJHASYJQIRSLE-UHFFFAOYSA-N;
MW          96.129;      // g/mol [origin=calculated method=formula-sum]
Tc          607.18;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       0.6192;      // -   [origin=predictive method=lee-kesler]
Tb          423.22;      // K   [origin=predictive method=joback]
HvapTb      45525.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.631 0.53382 -0.00041503 1.3759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpent-2-en-4-yn-1-ol" "2-penten-4-yn-1-ol, 3-methyl-" "2-penten-4-yn-1-ol,3-methyl-, (2e)-" "2-penten-4-yn-1-ol,3-methyl-, (e)- (8ci);(2e)-3-methyl-2-penten-4-yn-1-ol;(e)-3-methyl-2-pentene-4-yn-1-ol;(e)-3-methylpent-2-en-4-ynol;e-3-methyl-2-penten-4-yn-1-ol;trans-3-methyl-2-penten-4-yn-1-ol;trans-3-methyl-2-penten-4-ynol;" );
standardThermochemistry
{
    dHf_298   79930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157560.0
}
