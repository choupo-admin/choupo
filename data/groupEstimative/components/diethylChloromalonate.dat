/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl chloromalonate  (C7H11ClO4, CAS 14064-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylChloromalonate;
formula     C7H11ClO4;
CAS         14064-10-9;
InChIKey    WLWCQKMQYZFTDR-UHFFFAOYSA-N;
MW          194.611;      // g/mol [origin=calculated method=formula-sum]
Tc          702.30;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.6825;      // -   [origin=predictive method=lee-kesler]
Tb          513.19;      // K   [origin=predictive method=joback]
HvapTb      49987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.552 0.57194 -0.0001914 -3.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CHCl; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-chloranylpropanedioate" "ethyl chloromalonate" "ethylmonochloromalonate" "diethyl 2-chloromalonate" "chloromalonic acid, diethyl ester" "diethyl chloropropanedioate" "propanedioic acid, chloro-, diethyl ester" "malonic acid, chloro-, diethyl ester" "propanedioic acid, 2-chloro-, 1,3-diethyl ester" "diethyl-chloromalonate" "diethyl 2-chloropropanedioate" "wlwcqkmqyzftdr-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -843390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-627050.0
    phase     gas;
}
