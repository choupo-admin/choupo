/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexanol  (C6H14O, CAS 626-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexanol;
formula     C6H14O;
CAS         626-93-7;
InChIKey    QNVRIHYSUZMSGM-UHFFFAOYSA-N;
MW          102.177;      // g/mol [origin=calculated method=formula-sum]
Tc          593.25;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.7276;      // -   [origin=predictive method=lee-kesler]
Tb          428.62;      // K   [origin=predictive method=joback]
HvapTb      45241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.043 0.61374 -0.0003362 6.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexan-2-ol" "sec-hexyl alcohol" "2-hexanol, (r)-" "2-hexanol, (s)-" "2-hydroxyhexane" "(s)-(+)-2-hexanol" "n-c4h9ch(oh)ch3" "methylamyl alcohol" "butyl methyl carbinol" "(+/-)-2-hexanol" "sec-hexanol" "2-hexyl alcohol" );
standardThermochemistry
{
    dHf_298   -324680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-139620.0
}
