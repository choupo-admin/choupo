/*--------------------------------*- Choupo -*-----------------------*\
  Component: curcumenone  (C15H22O2, CAS 100347-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        curcumenone;
formula     C15H22O2;
CAS         100347-96-4;
InChIKey    HUZJLWLCLJEXEL-NFAWXSAZSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          905.62;      // K   [origin=predictive method=joback]
Pc          20.127;      // bar [origin=predictive method=joback]
omega       0.7507;      // -   [origin=predictive method=lee-kesler]
Tb          684.33;      // K   [origin=predictive method=joback]
HvapTb      59382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.208 1.71258 -0.0013715 4.8646e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,6s,7r)-6-methyl-7-(3-oxidanylidenebutyl)-3-propan-2-ylidene-bicyclo[4.1.0]heptan-4-one" "(1r,6s,7r)-6-methyl-7-(3-oxobutyl)-3-propan-2-ylidenebicyclo[4.1.0]heptan-4-one" "bicyclo(4.1.0)heptan-3-one, 1-methyl-4-(1-methylethylidene)-7-(3-oxobutyl)-, (1s,6r,7r)-" );
gibbsFormation
{
    dHf_298   -402630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42980.0
    phase     gas;
}
