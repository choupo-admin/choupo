/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctadecanonaene  (C18H18, CAS 2040-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctadecanonaene;
formula     C18H18;
CAS         2040-73-5;
InChIKey    STQWAGYDANTDNA-UHFFFAOYSA-N;
MW          234.342;      // g/mol [origin=calculated method=formula-sum]
Tc          964.08;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.3884;      // -   [origin=predictive method=lee-kesler]
Tb          679.34;      // K   [origin=predictive method=joback]
HvapTb      61092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.45 1.2432 -0.00042052 -8.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[18]-annulene" "(18)-annulene" "(1,3,5,7,9,11,13,15,17)-cyclooctadecanonaene" "1,3,5,7,9,11,13,15,17-cyclooctadecanonaene" "[18]annulene" "cyclooctadeca-1,3,5,7,9,11,13,15,17-nonaene" "(1e,3z,5e,7e,9z,11e,13e,15z,17e)-cyclooctadeca-1,3,5,7,9,11,13,15,17-nonaene" "(1z,3e,5e,7e,9z,11z,13e,15e,17e)-cyclooctadeca-1,3,5,7,9,11,13,15,17-nonaene" );
gibbsFormation
{
    dHf_298   105910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     771.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=257280.0
    phase     gas;
}
