/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyramide  (C4H9NO, CAS 541-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyramide;
formula     C4H9NO;
CAS         541-35-5;
InChIKey    DNSISZSEWVHGLH-UHFFFAOYSA-N;
MW          87.122;      // g/mol [origin=calculated method=formula-sum]
Tc          612.95;      // K   [origin=predictive method=joback]
Pc          45.531;      // bar [origin=predictive method=joback]
omega       0.5049;      // -   [origin=predictive method=lee-kesler]
Tb          417.52;      // K   [origin=predictive method=joback]
HvapTb      41885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.102 0.41772 -0.0002185 3.836e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanamide" "n-butyramide" "n-butylamide" "butanimidic acid" "butanoic acid, amide" "butyroamide" "amide c4" "butyrylamide" "butyramid" "n-butanamide" "n-c3h7c(o)nh2" "c3h7c(o)nh2" );
standardThermochemistry
{
    dHf_298   -204680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79670.0
}
