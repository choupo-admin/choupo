/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-bis(chloromethyl)anthracene  (C16H12Cl2, CAS 10387-13-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910BisChloromethylAnthracene;
formula     C16H12Cl2;
CAS         10387-13-0;
InChIKey    UOSROERWQJTVNU-UHFFFAOYSA-N;
MW          275.172;      // g/mol [origin=calculated method=formula-sum]
Tc          969.65;      // K   [origin=predictive method=joback]
Pc          23.749;      // bar [origin=predictive method=joback]
omega       0.7174;      // -   [origin=predictive method=lee-kesler]
Tb          720.12;      // K   [origin=predictive method=joback]
HvapTb      67522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.768 1.2726 -0.00099092 3.102e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 6; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 6; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-di(chloromethyl)anthracene" "9,10-bis-(chloromethyl)-anthracene" "anthracene, 9,10-bis(chloromethyl)-" "9,10-bis(chlormethyl)anthracene" "uosroerwqjtvnu-uhfffaoysa-" "9,10-bis-chloromethyl-anthracene" "anthracene,10-bis(chloromethyl)-" "9, 10-di(chloromethyl)anthracene" "9,10-dis-(chloromethyl)anthracene" "n959" );
standardThermochemistry
{
    dHf_298   179210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356800.0
}
