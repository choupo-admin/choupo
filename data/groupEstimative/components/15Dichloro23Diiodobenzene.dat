/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dichloro-2,3-diiodobenzene  (C6H2Cl2I2, CAS 27128-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dichloro23Diiodobenzene;
formula     C6H2Cl2I2;
CAS         27128-50-3;
InChIKey    YTPSETUAQWRHEH-UHFFFAOYSA-N;
MW          398.782;      // g/mol [origin=calculated method=formula-sum]
Tc          945.23;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.4024;      // -   [origin=predictive method=lee-kesler]
Tb          639.64;      // K   [origin=predictive method=joback]
HvapTb      60728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.59 0.408 -0.00033628 1.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCl; count 2; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-bis(chloranyl)-2,3-bis(iodanyl)benzene" );
gibbsFormation
{
    dHf_298   157210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175540.0
    phase     gas;
}
