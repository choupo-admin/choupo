/*--------------------------------*- Choupo -*-----------------------*\
  Component: massoia lactone  (C10H16O2, CAS 54814-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        massoiaLactone;
formula     C10H16O2;
CAS         54814-64-1;
InChIKey    NEDIAPMWNCQWNW-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          687.02;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       0.5773;      // -   [origin=predictive method=lee-kesler]
Tb          496.79;      // K   [origin=predictive method=joback]
HvapTb      45638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.376 0.98432 -0.00058668 1.243e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentyl-2,3-dihydropyran-6-one" "cocolactone" "massoilactone" "(r)-(-)-massoilactone" "2h-pyran-2-one, 5,6-dihydro-6-pentyl-" "2h-pyran-2-one, 5,6-dihydro-6-pentyl-, (r)-" "5-hydroxy-2-decenoic acid lactone" "2h-pyran-2-one, 5,6-dihydro-6-pentyl-, (6r)-" "5-hydroxy-2-decenoic acid delta-lactone" "6-pentyl-5,6-dihydro-2h-pyran-2-one" "5,6-dihydro-6-pentyl-2h-pyran-2-one, (r)-" "2h-pyran-2-one, 5,6-dihydro-6-pentyl-, (theta)-" );
gibbsFormation
{
    dHf_298   -442590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198440.0
    phase     gas;
}
