/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethylidenecyclohexene  (C8H12, CAS 16631-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethylidenecyclohexene;
formula     C8H12;
CAS         16631-62-2;
InChIKey    HCKKIWXIMBMLCD-WAPJZHGLSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          624.35;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.2795;      // -   [origin=predictive method=lee-kesler]
Tb          412.66;      // K   [origin=predictive method=joback]
HvapTb      35219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.05 0.77892 -0.00050358 1.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e)-3-ethylidenecyclohexene" "e,z-3-ethylidenecyclohexene" );
standardThermochemistry
{
    dHf_298   20.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124060.0
}
