/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoprene (racemate)  (C19H34O3, CAS 40596-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methopreneRacemate;
formula     C19H34O3;
CAS         40596-69-8;
InChIKey    NFGXHKASABOEEW-UHFFFAOYSA-N;
MW          310.478;      // g/mol [origin=calculated method=formula-sum]
Tc          906.43;      // K   [origin=predictive method=joback]
Pc          11.809;      // bar [origin=predictive method=joback]
omega       0.8016;      // -   [origin=predictive method=lee-kesler]
Tb          719.05;      // K   [origin=predictive method=joback]
HvapTb      65629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.366 1.86844 -0.0011523 2.705e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group dCH; count 3; } { group dC; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 11-methoxy-3,7,11-trimethyl-dodeca-2,4-dienoate" "s-methoprene" "s-(+)-methoprene" "propan-2-yl 11-methoxy-3,7,11-trimethyldodeca-2,4-dienoate" "propan-2-yl (2e,4e,7r)-11-methoxy-3,7,11-trimethyldodeca-2,4-dienoate" "2,4-dodecadienoic acid, 11-methoxy-3,7,11-trimethyl-, 1-methylethyl ester, (2e,4e)-" "2,4-dodecadienoic acid, 11-methoxy-3,7,11-trimethyl-, 1-methylethyl ester, (2z,4e,7s)-" "isopropyl (2e,4e)-11-methoxy-3,7,11-trimethyl-2,4-dodecadienoate" );
standardThermochemistry
{
    dHf_298   -679650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     883.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156420.0
}
