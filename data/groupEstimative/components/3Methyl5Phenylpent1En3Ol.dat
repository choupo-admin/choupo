/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-5-phenylpent-1-en-3-ol  (C12H16O, CAS 55066-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl5Phenylpent1En3Ol;
formula     C12H16O;
CAS         55066-45-0;
InChIKey    UWRYPWSHHZVMHR-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          788.54;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.8228;      // -   [origin=predictive method=lee-kesler]
Tb          586.47;      // K   [origin=predictive method=joback]
HvapTb      59295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.098 1.20472 -0.0008853 2.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-5-phenyl-pent-1-en-3-ol" "3-methyl-5-phenyl-1-penten-3-ol" "benzenepropanol, a-ethenyl-a-methyl-" "benzenepropanol, alpha-ethenyl-alpha-methyl-" "benzenepropanol, .alpha.-ethenyl-.alpha.-methyl-" );
standardThermochemistry
{
    dHf_298   -90030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116430.0
}
