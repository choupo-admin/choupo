/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-3-buten-2-one  (C5H8O2, CAS 4652-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy3Buten2One;
formula     C5H8O2;
CAS         4652-27-1;
InChIKey    VLLHEPHWWIDUSS-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          582.51;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       0.4177;      // -   [origin=predictive method=lee-kesler]
Tb          394.45;      // K   [origin=predictive method=joback]
HvapTb      35838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.02 0.40764 -0.0002023 3.186e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxybut-3-en-2-one" "3-buten-2-one, 4-methoxy-, (3z)-" );
gibbsFormation
{
    dHf_298   -274110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162480.0
    phase     gas;
}
