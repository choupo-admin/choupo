/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethylmorpholine  (C6H13NO, CAS 141-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethylmorpholine;
formula     C6H13NO;
CAS         141-91-3;
InChIKey    HNVIQLPOGUDBSU-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          640.61;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.3489;      // -   [origin=predictive method=lee-kesler]
Tb          427.26;      // K   [origin=predictive method=joback]
HvapTb      40338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.99 0.65304 -0.0002537 -0.0);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH-O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholine, 2,6-dimethyl-" "dimethylmorpholine" "2,6-dimethyl morpholine" "2,6-dimethyl-2,3,5,6-tetrahydro-4h-1,4-oxazine" "2,6-dimethylmorfolin" "morpholine, 2,6-dimethyl-, cis-" "2,3,5,6-tetrahydro-4h-1,4-oxazine" );
gibbsFormation
{
    dHf_298   -227380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     259.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17970.0
    phase     gas;
}
