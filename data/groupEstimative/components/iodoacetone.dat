/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodoacetone  (C3H5IO, CAS 3019-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodoacetone;
formula     C3H5IO;
CAS         3019-04-3;
InChIKey    WEFSXBPMNKAUDL-UHFFFAOYSA-N;
MW          183.972;      // g/mol [origin=calculated method=formula-sum]
Tc          635.89;      // K   [origin=predictive method=joback]
Pc          46.593;      // bar [origin=predictive method=joback]
omega       0.3277;      // -   [origin=predictive method=lee-kesler]
Tb          415.25;      // K   [origin=predictive method=joback]
HvapTb      38391.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.211 0.29982 -0.0002021 5.536e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group I; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylpropan-2-one" "1-iodoacetone" "1-iodo-2-propanone" "1-iodopropan-2-one" "1-iodo-propan-2-one" "2-propanone, 1-iodo-" "2-propanone, 1-iodo-(8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -140960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96420.0
}
