/*--------------------------------*- Choupo -*-----------------------*\
  Component: triphenylmethane  (C19H16, CAS 519-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triphenylmethane;
formula     C19H16;
CAS         519-73-3;
InChIKey    AAAQKTZKLRYKHR-UHFFFAOYSA-N;
MW          244.337;      // g/mol [origin=calculated method=formula-sum]
Tc          982.43;      // K   [origin=predictive method=joback]
Pc          24.006;      // bar [origin=predictive method=joback]
omega       0.5781;      // -   [origin=predictive method=lee-kesler]
Tb          713.92;      // K   [origin=predictive method=joback]
HvapTb      64328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.78 1.578 -0.0011066 2.909e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(diphenylmethyl)benzene" "tritane" "benzene, 1,1',1''-methylidynetris-" "benzhydrylbenzene" "1,1',1''-methanetriyltribenzene" "methane, triphenyl-" "benzhydryl-benzene" "1,1,1-triphenylmethane" "methane, triphenyl- (8ci)" ""1,1',1""-methylidynetrisbenzene"" "1,1',1''-methylidynetrisbenzene" "benzene,1',1''-methylidynetris-" );
gibbsFormation
{
    dHf_298   268820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=443890.0
    phase     gas;
}
