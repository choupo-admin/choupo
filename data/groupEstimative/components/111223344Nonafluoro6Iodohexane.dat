/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,2,2,3,3,4,4-nonafluoro-6-iodohexane  (C6H4F9I, CAS 2043-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111223344Nonafluoro6Iodohexane;
formula     C6H4F9I;
CAS         2043-55-2;
InChIKey    CXHFIVFPHDGZIS-UHFFFAOYSA-N;
MW          373.98;      // g/mol [origin=calculated method=formula-sum]
Tc          570.21;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.4740;      // -   [origin=predictive method=lee-kesler]
Tb          410.53;      // K   [origin=predictive method=joback]
HvapTb      25786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.948 1.2222 -0.0012188 4.381e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group I; count 1; } { group CF3; count 1; } { group CF2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 4; } { group F; count 9; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2,3,3,4,4-nonakis(fluoranyl)-6-iodanyl-hexane" "1h,1h,2h,2h-perfluorohexyl iodide" "2-(perfluorobutyl)ethyl iodide" "1-iodo-1h,1h,2h,2h-perfluorohexane" "1h,1h,2h,2h-nonafluorohexyl iodide" "hexane, 1,1,1,2,2,3,3,4,4-nonafluoro-6-iodo-" "2-(nonafluorobutyl)ethyl iodide" "cxhfivfphdgzis-uhfffaoysa-" "1h,1h,2h,2h-perfluorohexyliodide" "1-iodo-1h,1h,2h,2h-nonafluorohexane" "1,1,2,2-tetrahydroperfluorohexyl iodide" "hexane,1,1,1,2,2,3,3,4,4-nonafluoro-6-iodo-" );
standardThermochemistry
{
    dHf_298   -1890290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1684170.0
}
