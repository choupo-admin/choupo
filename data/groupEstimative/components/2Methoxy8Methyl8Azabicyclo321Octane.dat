/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-8-methyl-8-azabicyclo[3.2.1]octane  (C9H17NO, CAS 20411-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy8Methyl8Azabicyclo321Octane;
formula     C9H17NO;
CAS         20411-17-0;
InChIKey    LWXRLTQBGGVKIK-UHFFFAOYSA-N;
MW          155.241;      // g/mol [origin=calculated method=formula-sum]
Tc          649.22;      // K   [origin=predictive method=joback]
Pc          29.250;      // bar [origin=predictive method=joback]
omega       0.4493;      // -   [origin=predictive method=lee-kesler]
Tb          453.46;      // K   [origin=predictive method=joback]
HvapTb      39770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.15 1.18524 -0.000806 2.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH3O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-8-methyl-8-azabicyclo[3.2.1]octane" "8-azabicyclo[3.2.1]octane,3-methoxy-8-methyl-endo-" "8-azabicyclo(3.2.1)octane, 3-methoxy-8-methyl-, endo-" );
standardThermochemistry
{
    dHf_298   -174680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132370.0
}
