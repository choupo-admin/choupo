/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorocyclohexene  (C6H9Cl, CAS 930-66-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorocyclohexene;
formula     C6H9Cl;
CAS         930-66-5;
InChIKey    BUAKPITZELZWNI-UHFFFAOYSA-N;
MW          116.588;      // g/mol [origin=calculated method=formula-sum]
Tc          620.34;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.2587;      // -   [origin=predictive method=lee-kesler]
Tb          402.67;      // K   [origin=predictive method=joback]
HvapTb      35027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.14 0.6137 -0.00037964 8.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylcyclohexene" "cyclohexene, 1-chloro-" "1-chloro-cyclohexene" "1-chlorocyclohex-1-ene" "i-chlorocyclohexane" "cyclohexene, 1-chloro- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -61940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40200.0
}
