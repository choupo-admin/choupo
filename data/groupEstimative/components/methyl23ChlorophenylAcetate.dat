/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-(3-chlorophenyl)acetate  (C9H9ClO2, CAS 53088-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl23ChlorophenylAcetate;
formula     C9H9ClO2;
CAS         53088-68-9;
InChIKey    HTBBVKFFDDQVER-UHFFFAOYSA-N;
MW          184.619;      // g/mol [origin=calculated method=formula-sum]
Tc          752.33;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.5482;      // -   [origin=predictive method=lee-kesler]
Tb          532.83;      // K   [origin=predictive method=joback]
HvapTb      50358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.401 0.67242 -0.00035576 4.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2COO; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(3-chlorophenyl)ethanoate" "methyl 3-chlorophenylacetate" "methyl (3-chlorophenyl)acetate" "phenylacetic acid, 3-chloro, methyl ester" "(3-chlorophenyl)acetic acid methyl ester" "2-(3-chlorophenyl)acetic acid methyl ester" "3-chloro phenyl acetic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -337050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194620.0
}
