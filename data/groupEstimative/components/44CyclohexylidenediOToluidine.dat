/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-cyclohexylidenedi-o-toluidine  (C20H26N2, CAS 6442-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44CyclohexylidenediOToluidine;
formula     C20H26N2;
CAS         6442-08-6;
InChIKey    CGEPGDQNCRDJHS-UHFFFAOYSA-N;
MW          294.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1162.87;      // K   [origin=predictive method=joback]
Pc          21.197;      // bar [origin=predictive method=joback]
omega       0.9415;      // -   [origin=predictive method=lee-kesler]
Tb          895.33;      // K   [origin=predictive method=joback]
HvapTb      87874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.52 2.04584 -0.00155884 5.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-(4-azanyl-3-methyl-phenyl)cyclohexyl]-2-methyl-aniline" "4-[1-(4-amino-3-methylphenyl)cyclohexyl]-2-methylphenylamine" "4,4'-cyclohexane-1,1-diylbis(2-methylaniline)" "benzenamine, 4,4'-cyclohexylidenebis(2-methyl-" "benzenamine, 4,4'-cyclohexylidenebis[2-methyl-" "4-[1-(4-amino-3-methylphenyl)cyclohexyl]-2-methylaniline" "aniline, 4,4'-cyclohexylidenebis(2-methyl-" "o-toluidine,4,4'-cyclohexylidenedi- (8ci);" );
standardThermochemistry
{
    dHf_298   108190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     839.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=455680.0
}
