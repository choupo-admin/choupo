/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexene-1-acetonitrile  (C8H11N, CAS 6975-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexene1Acetonitrile;
formula     C8H11N;
CAS         6975-71-9;
InChIKey    OYEXEQFKIPJKJK-UHFFFAOYSA-N;
MW          121.183;      // g/mol [origin=calculated method=formula-sum]
Tc          740.10;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.4574;      // -   [origin=predictive method=lee-kesler]
Tb          513.08;      // K   [origin=predictive method=joback]
HvapTb      45572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.849 0.7317 -0.00043704 9.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=C; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclohexen-1-yl)ethanenitrile" "1-cyclohexenylacetonitrile" "2-(cyclohex-1-en-1-yl)acetonitrile" "cyclohexenylacetonitrile" "1-cyclohexen-1-ylacetonitrile" "1-cyclohexeneacetonitrile" "l6utj a1cn" "1-cyclohexenacetonitrile" "cyclohex-1-enyl-acetonitrile" "2-cyclohex-1-enylethanenitrile" "1-cyclohexenylacetonitile" "1-cyclo hexenylacetonitrile" );
standardThermochemistry
{
    dHf_298   77400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202150.0
}
