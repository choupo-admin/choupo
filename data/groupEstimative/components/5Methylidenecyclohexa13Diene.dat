/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylidenecyclohexa-1,3-diene  (C7H8, CAS 20679-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylidenecyclohexa13Diene;
formula     C7H8;
CAS         20679-59-8;
InChIKey    OSBSXTGABLIDRX-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          591.11;      // K   [origin=predictive method=joback]
Pc          41.039;      // bar [origin=predictive method=joback]
omega       0.2425;      // -   [origin=predictive method=lee-kesler]
Tb          381.46;      // K   [origin=predictive method=joback]
HvapTb      32657.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.17 0.5879 -0.00037556 8.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylene-1,3-cyclohexadiene" "5-methylene 1,3-cyclohexadiene" );
gibbsFormation
{
    dHf_298   86650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153220.0
    phase     gas;
}
