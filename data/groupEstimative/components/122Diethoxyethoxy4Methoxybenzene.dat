/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,2-diethoxyethoxy)-4-methoxybenzene  (C13H20O4, CAS 69034-13-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122Diethoxyethoxy4Methoxybenzene;
formula     C13H20O4;
CAS         69034-13-5;
InChIKey    XWIJNGRJPFEZIF-UHFFFAOYSA-N;
MW          240.299;      // g/mol [origin=calculated method=formula-sum]
Tc          813.16;      // K   [origin=predictive method=joback]
Pc          20.475;      // bar [origin=predictive method=joback]
omega       0.8060;      // -   [origin=predictive method=lee-kesler]
Tb          617.94;      // K   [origin=predictive method=joback]
HvapTb      56722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.783 0.85356 -0.00020676 -7.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,2-diethoxyethoxy)-4-methoxy-benzene" "4-methoxyphenoxyacetaldehyde diethyl acetal" "1-(2,2-diethoxy-ethoxy)-4-methoxy-benzene" "benzene,1-(2,2-diethoxyethoxy)-4-methoxy-" );
standardThermochemistry
{
    dHf_298   -620750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-261080.0
}
