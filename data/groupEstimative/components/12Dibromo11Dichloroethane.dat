/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromo-1,1-dichloroethane  (C2H2Br2Cl2, CAS 75-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromo11Dichloroethane;
formula     C2H2Br2Cl2;
CAS         75-81-0;
InChIKey    FIYBYNHDEOSJPL-UHFFFAOYSA-N;
MW          256.746;      // g/mol [origin=calculated method=formula-sum]
Tc          692.01;      // K   [origin=predictive method=joback]
Pc          56.788;      // bar [origin=predictive method=joback]
omega       0.3704;      // -   [origin=predictive method=lee-kesler]
Tb          449.31;      // K   [origin=predictive method=joback]
HvapTb      40390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.761 0.4096 -0.0004404 1.707e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CCl2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group Cl; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-1,1-bis(chloranyl)ethane" "ethane, 1,2-dibromo-1,1-dichloro-" "1,2-dibromo-2,2-dichloroethane" "ethane, dibromodichloro-" "ethane,2-dibromo-1,1-dichloro-" );
standardThermochemistry
{
    dHf_298   -72180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26420.0
}
