/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-hexadiene-3,4-diol  (C6H10O2, CAS 1069-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Hexadiene34Diol;
formula     C6H10O2;
CAS         1069-23-4;
InChIKey    KUQWZSZYIQGTHT-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          682.46;      // K   [origin=predictive method=joback]
Pc          43.858;      // bar [origin=predictive method=joback]
omega       1.1842;      // -   [origin=predictive method=lee-kesler]
Tb          513.72;      // K   [origin=predictive method=joback]
HvapTb      60192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.33 0.6136 -0.0004156 1.136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH2=CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-1,5-diene-3,4-diol" "divinylglycol" "3,4-dihydroxy-1,5-hexadiene" "1,5-hexadiene,3,4-dihydroxy-" "3,5-hexadiene" "1,2-divinylglycol" "divinylethylene glycol" "1,3,4-dihydroxy-" "1,4-diol" "diethylene glycol divinyl;" "(1r,2r)-hexa-1,5-diene-3,4-diol" "1,5-hexadiene-3,4-diol, mixture of (+/-) and meso" );
standardThermochemistry
{
    dHf_298   -231330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103200.0
}
