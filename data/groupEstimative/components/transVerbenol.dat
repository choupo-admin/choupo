/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-verbenol  (C10H16O, CAS 1820-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transVerbenol;
formula     C10H16O;
CAS         1820-09-3;
InChIKey    WONIGEXYPVIKFS-DJLDLDEBSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          729.57;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.7464;      // -   [origin=predictive method=lee-kesler]
Tb          533.37;      // K   [origin=predictive method=joback]
HvapTb      53716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.55 1.40346 -0.00128664 5.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2r,5s)-4,6,6-trimethylbicyclo[3.1.1]hept-3-en-2-ol" "bicyclo(3.1.1)hept-3-en-2-ol,4,6,6-trimethyl-,(1s,2r,5s)-" "1s-cis-verbenol" "bicyclo(3.1.1)hept-3-en-2-ol, 4,6,6-trimethyl-, (1r,2s,5r)-rel-" "bicyclo(3.1.1)hept-3-en-2-ol, 4,6,6-trimethyl-, (1s,2r,5s)-" "bicyclo(3.1.1)hept-3-en-2-ol, 4,6,6-trimethyl-, trans-(-)-" "(1alpha,2alpha,5alpha)-4,6,6-trimethylbicyclo(3.1.1)hept-3-en-2-ol" "(1s-(1alpha,2alpha,5alpha))-4,6,6-trimethylbicyclo(3.1.1)hept-3-en-2-ol" );
gibbsFormation
{
    dHf_298   -241650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5320.0
    phase     gas;
}
