/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-diazabicyclo[4.3.1]decane  (C8H16N2, CAS 25337-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Diazabicyclo431Decane;
formula     C8H16N2;
CAS         25337-75-1;
InChIKey    GQPHXHFRXIIFCF-UHFFFAOYSA-N;
MW          140.23;      // g/mol [origin=calculated method=formula-sum]
Tc          644.59;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.4363;      // -   [origin=predictive method=lee-kesler]
Tb          438.88;      // K   [origin=predictive method=joback]
HvapTb      38276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.37 1.3472 -0.001095 3.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-diazabicyclo(4.3.1)decane" "1,6-diazabicyclo[4.3.1]decane(8ci,9ci)" );
gibbsFormation
{
    dHf_298   100570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=350760.0
    phase     gas;
}
