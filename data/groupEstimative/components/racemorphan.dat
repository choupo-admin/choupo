/*--------------------------------*- Choupo -*-----------------------*\
  Component: racemorphan  (C17H23NO, CAS 5985-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        racemorphan;
formula     C17H23NO;
CAS         5985-35-3;
InChIKey    JAQUASYNZVUNQP-UHFFFAOYSA-N;
MW          257.377;      // g/mol [origin=calculated method=formula-sum]
Tc          986.02;      // K   [origin=predictive method=joback]
Pc          26.930;      // bar [origin=predictive method=joback]
omega       0.8480;      // -   [origin=predictive method=lee-kesler]
Tb          738.01;      // K   [origin=predictive method=joback]
HvapTb      70191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-257.62 2.49392 -0.00238092 9.282e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dextrorphan" "morphinan-3-ol, 17-methyl-, (.+/-.)-" "2h-10,4a-(iminoethano)phenanthren-6-ol, 1,3,4,9,10,10a-hexahydro-11-methyl-,(+)-" "(+)-cis-1,3,4,9,10,10a-hexahydro-11-methyl-2h-10,4a-iminoethanophenanthren-6-ol" );
gibbsFormation
{
    dHf_298   -51450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=315860.0
    phase     gas;
}
