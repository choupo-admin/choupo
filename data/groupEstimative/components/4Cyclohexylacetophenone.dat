/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-cyclohexylacetophenone  (C14H18O, CAS 18594-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Cyclohexylacetophenone;
formula     C14H18O;
CAS         18594-05-3;
InChIKey    MSDQNIRGPBARGC-UHFFFAOYSA-N;
MW          202.297;      // g/mol [origin=calculated method=formula-sum]
Tc          864.84;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.5757;      // -   [origin=predictive method=lee-kesler]
Tb          625.00;      // K   [origin=predictive method=joback]
HvapTb      56871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.69 1.28952 -0.00076426 1.5656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-cyclohexylphenyl)ethanone" "4'-cyclohexylacetophenone" "1-(4-cyclohexylphenyl)ethan-1-one" "ethanone, 1-(4-cyclohexylphenyl)-" "1-acetyl-4-cyclohexylbenzene" "msdqnirgpbargc-uhfffaoysa-" "1-(4-cyclohexyl-phenyl)-ethanone" "upcmld0enat5883753:001" );
gibbsFormation
{
    dHf_298   -165490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65310.0
    phase     gas;
}
