/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluorophenetole  (C8H9FO, CAS 458-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Fluorophenetole;
formula     C8H9FO;
CAS         458-03-7;
InChIKey    UWWCZZMOTBWUAB-UHFFFAOYSA-N;
MW          140.157;      // g/mol [origin=calculated method=formula-sum]
Tc          634.57;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.4231;      // -   [origin=predictive method=lee-kesler]
Tb          435.99;      // K   [origin=predictive method=joback]
HvapTb      37933.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.601 0.57402 -0.00028096 3.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-3-fluoranyl-benzene" "1-ethoxy-3-fluorobenzene" "m-ethoxyfluorobenzene" "phenetole, m-fluoro-" "3-fluoro ethoxybenzene" "benzene, 1-ethoxy-3-fluoro-" "3-ethoxyfluorobenzene" "3-ethoxy-1-fluorobenzene" "benzene,1-ethoxy-3-fluoro-" "i282" "phenetole,m-fluoro- (8ci);1-ethoxy-3-fluorobenzene;m-fluorophenylethyl ether;ethyl 3-fluorophenyl ether;m-fluorophenetole;" );
gibbsFormation
{
    dHf_298   -311720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180550.0
    phase     gas;
}
