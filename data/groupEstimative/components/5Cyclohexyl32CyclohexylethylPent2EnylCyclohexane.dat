/*--------------------------------*- Choupo -*-----------------------*\
  Component: [5-cyclohexyl-3-(2-cyclohexylethyl)pent-2-enyl]cyclohexane  (C25H44, CAS 66374-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Cyclohexyl32CyclohexylethylPent2EnylCyclohexane;
formula     C25H44;
CAS         66374-92-3;
InChIKey    NWFICPMWZSXENT-UHFFFAOYSA-N;
MW          344.627;      // g/mol [origin=calculated method=formula-sum]
Tc          1062.05;      // K   [origin=predictive method=joback]
Pc          11.522;      // bar [origin=predictive method=joback]
omega       0.6952;      // -   [origin=predictive method=lee-kesler]
Tb          834.29;      // K   [origin=predictive method=joback]
HvapTb      72569.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-230.525 2.765 -0.0016653 3.643e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 20; } { group CH; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 15; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[5-cyclohexyl-3-(2-cyclohexylethyl)pent-2-en-1-yl]cyclohexane" "cyclohexane,1'-[3-(2-cyclohexylethyl)-2-pentene-1,5-diyl]bis-" );
gibbsFormation
{
    dHf_298   -288940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1027.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=304640.0
    phase     gas;
}
