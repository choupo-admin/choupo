/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-methoxy-4,6-dimethylphenyl)ethanone  (C11H14O2, CAS 21009-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Methoxy46DimethylphenylEthanone;
formula     C11H14O2;
CAS         21009-92-7;
InChIKey    LQNUZJNWPUSUMG-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          781.66;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.6418;      // -   [origin=predictive method=lee-kesler]
Tb          569.19;      // K   [origin=predictive method=joback]
HvapTb      53498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.74 0.70028 -0.00027498 6.66e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methoxy-4,6-dimethyl-phenyl)ethanone" "2'-methoxy-4',6'-dimethylacetophenone" "1-acetyl-2-methoxy-4,6-dimethylbenzene" );
gibbsFormation
{
    dHf_298   -313050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108660.0
    phase     gas;
}
