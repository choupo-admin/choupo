/*--------------------------------*- Choupo -*-----------------------*\
  Component: dehydromevalonic lactone  (C6H8O2, CAS 2381-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dehydromevalonicLactone;
formula     C6H8O2;
CAS         2381-87-5;
InChIKey    RPEASMBMVIKUTH-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          615.54;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.4066;      // -   [origin=predictive method=lee-kesler]
Tb          414.92;      // K   [origin=predictive method=joback]
HvapTb      37705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.38 0.57132 -0.00035744 8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2,3-dihydropyran-6-one" "2h-pyran-2-one, 5,6-dihydro-4-methyl-" "4-methyl-5,6-dihydro-2h-pyran-2-one" "ghl.pd_mitscher_leg0.315" "2,3-anhydromevalonic acid" "4-methyl-5,6-dihydro-pyran-2-one" "2h-pyran-2-one,5,6-dihydro-4-methyl-" "2-pentenoic acid,5-hydroxy-3-methyl-, lactone (6ci); 2,3-anhydromevalonic acid d-lactone;2-methyl-4-hydroxy-1-butenoic acid lactone; 3-methylpent-2-en-5-olide;4-methyl-5,6-dihydro-2-pyranone; 4-methyl-5,6-dihydro-a-pyrone;5,6-dihydro-4-methyl-2h-pyran-2-one; 5-hydroxy-3-methyl-2-pentenoic acidlactone; mevalonic lactone, d2-anhydro-" );
standardThermochemistry
{
    dHf_298   -351160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-234040.0
}
