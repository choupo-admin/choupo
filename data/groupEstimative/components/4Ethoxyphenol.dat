/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethoxyphenol  (C8H10O2, CAS 622-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethoxyphenol;
formula     C8H10O2;
CAS         622-62-8;
InChIKey    LKVFCSWBKOVHAH-UHFFFAOYSA-N;
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          735.95;      // K   [origin=predictive method=joback]
Pc          43.112;      // bar [origin=predictive method=joback]
omega       0.5978;      // -   [origin=predictive method=lee-kesler]
Tb          512.36;      // K   [origin=predictive method=joback]
HvapTb      51102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.709 0.77632 -0.00058796 1.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 4-ethoxy-" "hydroquinone monoethyl ether" "phenol, p-ethoxy-" "p-ethoxyphenol" "4-ethyloxyphenol" "p-hydroxyphenetole" "ethoxyphenol, p-" "4-hydroxyphenetole" "1-ethoxy-4-hydroxybenzene" "ether monoethylique de l'hydroquinone [french]" "4-ethoxy-phenol" "hydroquinone mono ethyl ether" );
gibbsFormation
{
    dHf_298   -281450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130730.0
    phase     gas;
}
