/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,8,11-tetraoxatetradec-13-ene  (C10H20O4, CAS 19685-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25811Tetraoxatetradec13Ene;
formula     C10H20O4;
CAS         19685-21-3;
InChIKey    QOQTULDKYFWBLQ-UHFFFAOYSA-N;
MW          204.266;      // g/mol [origin=calculated method=formula-sum]
Tc          680.06;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       0.7776;      // -   [origin=predictive method=lee-kesler]
Tb          514.76;      // K   [origin=predictive method=joback]
HvapTb      46824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.807 0.68102 -9.91e-05 -9.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 1; } { group CH3O; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-[2-(2-methoxyethoxy)ethoxy]ethoxy]prop-1-ene" "allyloxymethoxytriglycol" "2,5,8,11-tetraoxatetradec-13-ene;allyloxymethoxytriglycol;allyloxy(triethylene oxide), methyl ether" );
standardThermochemistry
{
    dHf_298   -653180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-298840.0
}
