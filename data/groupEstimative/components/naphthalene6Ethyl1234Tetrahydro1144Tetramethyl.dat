/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 6-ethyl-1,2,3,4-tetrahydro-1,1,4,4-tetramethyl-  (C16H24, CAS 80-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene6Ethyl1234Tetrahydro1144Tetramethyl;
formula     C16H24;
CAS         80-81-9;
InChIKey    SLIOAQVQWDNBNB-UHFFFAOYSA-N;
MW          216.368;      // g/mol [origin=calculated method=formula-sum]
Tc          836.18;      // K   [origin=predictive method=joback]
Pc          19.912;      // bar [origin=predictive method=joback]
omega       0.4975;      // -   [origin=predictive method=lee-kesler]
Tb          609.14;      // K   [origin=predictive method=joback]
HvapTb      52284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.369 2.0246 -0.00192732 7.921e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-ethyl-1,1,4,4-tetramethyl-2,3-dihydronaphthalene" "1,1,4,4-tetramethyl-6-ethyltetralin" "6-ethyl-1,1,4,4-tetramethyltetralin" "1,1,4,4-tetramethyl-1,2,3,4-tetrahydro-6-ethylnaphthalene" "6-ethyl-1,1,4,4-tetramethyl-1,2,3,4-tetrahydronaphthalene" "6-ethyl-1,2,3,4-tetrahydro-1,1,4,4-tetramethylnaphthalene" "naphthalene, 1,2,3,4-tetrahydro-6-ethyl-1,1,4,4-tetramethyl-" "naphthalene,6-ethyl-1,2,3,4-tetrahydro-1,1,4,4-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -83200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=206950.0
}
