/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-Nonylnaphthalene  (C19H26, CAS 26438-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonylnaphthalene;
formula     C19H26;
CAS         26438-26-6;
InChIKey    AZLNHMGSTZDDIY-UHFFFAOYSA-N;
MW          254.417;      // g/mol [origin=calculated method=formula-sum]
Tc          889.84;      // K   [origin=predictive method=joback]
Pc          16.246;      // bar [origin=predictive method=joback]
omega       0.7634;      // -   [origin=predictive method=lee-kesler]
Tb          684.96;      // K   [origin=predictive method=joback]
HvapTb      62466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.432 1.66672 -0.00111068 2.966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-n-nonylnaphthalene" "naphthalene, 1-nonyl-" "nonylnaphthalene" "ai3-14637" "naphthalene, nonyl-" "NS00028271" "Q15410165" );
standardThermochemistry
{
    dHf_298   -19360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318530.0
}
