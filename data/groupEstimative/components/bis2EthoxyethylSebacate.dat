/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-ethoxyethyl)sebacate  (C18H34O6, CAS 624-10-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2EthoxyethylSebacate;
formula     C18H34O6;
CAS         624-10-2;
InChIKey    UVRXDBUBNLXONB-UHFFFAOYSA-N;
MW          346.464;      // g/mol [origin=calculated method=formula-sum]
Tc          950.20;      // K   [origin=predictive method=joback]
Pc          11.337;      // bar [origin=predictive method=joback]
omega       1.0296;      // -   [origin=predictive method=lee-kesler]
Tb          772.72;      // K   [origin=predictive method=joback]
HvapTb      75296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (88.344 1.47784 -0.0005442 -2.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2COO; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-ethoxyethyl) decanedioate" "decanedioic acid, bis(2-ethoxyethyl) ester" "a-ethoxyethyl sebacate" "bis(2-ethoxyethyl) sebacate" "sebacic acid, bis(2-ethoxyethyl) ester" "decanedioic acid, 1,10-bis(2-ethoxyethyl) ester" "beta-ethoxyethyl sebacate" "decanedioic acid,1,10-bis(2-ethoxyethyl) ester" );
gibbsFormation
{
    dHf_298   -1313850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     982.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-730060.0
    phase     gas;
}
