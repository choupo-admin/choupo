/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5h-benzocycloheptene, 6,7,8,9-tetrahydro-5-methylene-  (C12H14, CAS 40562-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5hBenzocycloheptene6789Tetrahydro5Methylene;
formula     C12H14;
CAS         40562-09-2;
InChIKey    FXXLVNARLGNNLX-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          760.30;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.4050;      // -   [origin=predictive method=lee-kesler]
Tb          524.93;      // K   [origin=predictive method=joback]
HvapTb      45969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.76 1.0461 -0.00068356 1.708e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylidene-6,7,8,9-tetrahydrobenzo[7]annulene" "5h-benzocycloheptene,6,7,8,9-tetrahydro-5-methylene-" );
gibbsFormation
{
    dHf_298   99110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=250280.0
    phase     gas;
}
