/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.2.1.02,5]nona-3,7-diene,9-(1-methylethylidene)-,(1.alpha.,2.alpha.,5.alpha.,6.alpha.)-  (C12H14, CAS 27237-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo421025Nona37Diene91Methylethylidene1Alpha2Alpha5Alph;
formula     C12H14;
CAS         27237-73-6;
InChIKey    JVSQYAKRTBPSLB-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          709.94;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.4096;      // -   [origin=predictive method=lee-kesler]
Tb          494.55;      // K   [origin=predictive method=joback]
HvapTb      43187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.84 1.38044 -0.00117956 4.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 4; } { group CH=CH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   88850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     203.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=321530.0
}
