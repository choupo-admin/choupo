/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl dibromomalonate  (C7H10Br2O4, CAS 631-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylDibromomalonate;
formula     C7H10Br2O4;
CAS         631-22-1;
InChIKey    PFZYFZRUPFUEOB-UHFFFAOYSA-N;
MW          317.961;      // g/mol [origin=calculated method=formula-sum]
Tc          824.15;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.8262;      // -   [origin=predictive method=lee-kesler]
Tb          605.29;      // K   [origin=predictive method=joback]
HvapTb      57564.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.252 0.76144 -0.0004824 9.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Br; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Br; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,2-bis(bromanyl)propanedioate" "ethyl dibromomalonate" "diethyl 2,2-dibromomalonate" "propanedioic acid, dibromo-, diethyl ester" "propanedioic acid, 2,2-dibromo-, 1,3-diethyl ester" "diethyl 2,2-dibromopropanedioate" "1,3-diethyl 2,2-dibromopropanedioate" "malonic acid, dibromo-, diethyl ester" "diethyl 2,2-dibromopropane-1,3-dioate" );
gibbsFormation
{
    dHf_298   -778460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-581200.0
    phase     gas;
}
