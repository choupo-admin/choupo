/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-2-bromanylbut-2-enedioic acid  (C4H3BrO4, CAS 584-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e2Bromanylbut2EnedioicAcid;
formula     C4H3BrO4;
CAS         584-99-6;
InChIKey    SOWPGKJPEXNMCS-OWOJBTEDSA-N;
MW          194.968;      // g/mol [origin=calculated method=formula-sum]
Tc          887.80;      // K   [origin=predictive method=joback]
Pc          59.354;      // bar [origin=predictive method=joback]
omega       1.1314;      // -   [origin=predictive method=lee-kesler]
Tb          652.34;      // K   [origin=predictive method=joback]
HvapTb      65299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.77 0.5435 -0.0004965 1.757e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group COOH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group Br; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -692670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-619030.0
}
