/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-dimethyl-1,3-dioxolan-4-yl)methyl methacrylate  (C10H16O4, CAS 7098-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl13Dioxolan4YlMethylMethacrylate;
formula     C10H16O4;
CAS         7098-80-8;
InChIKey    JPFPDGRVRGETED-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          756.53;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.6024;      // -   [origin=predictive method=lee-kesler]
Tb          547.93;      // K   [origin=predictive method=joback]
HvapTb      52488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.369 1.27006 -0.0010276 3.618e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,2-dimethyl-1,3-dioxolan-4-yl)methyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, (2,2-dimethyl-1,3-dioxolan-4-yl)methyl ester" );
standardThermochemistry
{
    dHf_298   -659990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-346650.0
}
