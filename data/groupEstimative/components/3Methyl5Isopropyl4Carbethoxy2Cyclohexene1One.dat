/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-5-isopropyl-4-carbethoxy-2-cyclohexene-1-one  (C13H20O3, CAS 24079-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl5Isopropyl4Carbethoxy2Cyclohexene1One;
formula     C13H20O3;
CAS         24079-95-6;
InChIKey    QBMOPULUXAKJTR-UHFFFAOYSA-N;
MW          224.3;      // g/mol [origin=calculated method=formula-sum]
Tc          854.92;      // K   [origin=predictive method=joback]
Pc          20.199;      // bar [origin=predictive method=joback]
omega       0.7017;      // -   [origin=predictive method=lee-kesler]
Tb          641.66;      // K   [origin=predictive method=joback]
HvapTb      56872.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.641 1.00178 -0.00029384 -6.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 3; } { group CH=C; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methyl-4-oxidanylidene-6-propan-2-yl-cyclohex-2-ene-1-carboxylate" "2-cyclohexene-1-carboxylic acid, 2-methyl-6-(1-methylethyl)-4-oxo-, ethyl ester" "ethyl 2-methyl-4-oxo-6-(propan-2-yl)cyclohex-2-ene-1-carboxylate" "m-menth-6-ene-2-carboxylic acid, ethyl ester" "ethyl 6-isopropyl-2-methyl-4-oxocyclohex-2-enecarboxylate" "m-menth-6-ene-2-carboxylic acid, 5-oxo-, ethyl ester (8ci)" "ethyl 2-methyl-4-oxo-6-propan-2-ylcyclohex-2-ene-1-carboxylate" "ethyl 6-(isopropyl)-2-methyl-4-oxocyclohex-2-ene-1-carboxylate" );
gibbsFormation
{
    dHf_298   -691620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-339750.0
    phase     gas;
}
