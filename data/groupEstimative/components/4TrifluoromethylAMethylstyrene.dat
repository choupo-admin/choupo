/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(trifluoromethyl)-a-methylstyrene  (C10H9F3, CAS 55186-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TrifluoromethylAMethylstyrene;
formula     C10H9F3;
CAS         55186-75-9;
InChIKey    JQIVSZSXUMTYJJ-UHFFFAOYSA-N;
MW          186.176;      // g/mol [origin=calculated method=formula-sum]
Tc          645.98;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.4119;      // -   [origin=predictive method=lee-kesler]
Tb          451.20;      // K   [origin=predictive method=joback]
HvapTb      36455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.69 0.95652 -0.00073056 2.163e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-1-en-2-yl-4-(trifluoromethyl)benzene" "benzene, 1-(1-methylethenyl)-4-(trifluoromethyl)-" "4-(1-methylvinyl)-1-(trifluoromethyl)benzene" "4-cf3c6h4c(ch3)ch2" "(4-trifluoromethyl)-alpha-methylstyrene" "4-(trifluoromethyl)-alpha-methylstyrene" "1-isopropenyl-4-(trifluoromethyl)benzene" );
standardThermochemistry
{
    dHf_298   -506110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-366200.0
}
