/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2(or 4)-sec-triacontyl-  (C36H66O, CAS 234446-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol2Or4SecTriacontyl;
formula     C36H66O;
CAS         234446-39-0;
InChIKey    MZXHNRNVPHKCOJ-UHFFFAOYSA-N;
MW          514.923;      // g/mol [origin=calculated method=formula-sum]
Tc          1427.11;      // K   [origin=predictive method=joback]
Pc          5.707;      // bar [origin=predictive method=joback]
omega       0.2292;      // -   [origin=predictive method=lee-kesler]
Tb          1130.14;      // K   [origin=predictive method=joback]
HvapTb      110632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.343 3.50544 -0.00222536 5.753e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 27; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 27; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-triacontan-2-ylphenol" );
gibbsFormation
{
    dHf_298   -732430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1468.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207590.0
    phase     gas;
}
