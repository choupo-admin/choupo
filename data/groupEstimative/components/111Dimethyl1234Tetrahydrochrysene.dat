/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,11-dimethyl-1,2,3,4-tetrahydrochrysene  (C20H20, CAS 52171-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Dimethyl1234Tetrahydrochrysene;
formula     C20H20;
CAS         52171-94-5;
InChIKey    HJQPFVFZAZFPRE-UHFFFAOYSA-N;
MW          260.38;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.04;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.7175;      // -   [origin=predictive method=lee-kesler]
Tb          752.77;      // K   [origin=predictive method=joback]
HvapTb      68403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.25 1.72084 -0.00127448 3.843e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 7; } { group AC; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chrysene, 1,11-dimethyl-1,2,3,4-tetrahydro-" );
standardThermochemistry
{
    dHf_298   183300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=453360.0
}
