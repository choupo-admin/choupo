/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylethylmalonamide  (C11H14N2O2, CAS 7206-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylethylmalonamide;
formula     C11H14N2O2;
CAS         7206-76-0;
InChIKey    JFZHPFOXAAIUMB-UHFFFAOYSA-N;
MW          206.245;      // g/mol [origin=calculated method=formula-sum]
Tc          973.04;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.9949;      // -   [origin=predictive method=lee-kesler]
Tb          727.53;      // K   [origin=predictive method=joback]
HvapTb      75834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.789 1.16352 -0.000827 2.2102e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-2-phenyl-propanediamide" "2-ethyl-2-phenylmalonamide" "pema" "propanediamide, 2-ethyl-2-phenyl-" "phenylethylmalondiamide" "2-ethyl-2-phenylpropanediamide" "2-phenyl-2-ethylmalondiamide" "pema (amide)" "malonamide, 2-ethyl-2-phenyl-" "2-phenyl-2-ethylmalonamide" "ethylphenylmethane-1,1-dicarboxamide" "2-ethyl-2-phenylmalondiamide" );
standardThermochemistry
{
    dHf_298   -200170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32050.0
}
