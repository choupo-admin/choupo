/*--------------------------------*- Choupo -*-----------------------*\
  Component: silanediol, diethyl-  (C4H12O2Si, CAS 63148-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H12O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silanediolDiethyl;
formula     C4H12O2Si;
CAS         63148-61-8;
InChIKey    DAKRXZUXJUPCOF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          120.223;      // g/mol [origin=calculated method=formula-sum]
Tc          640.26;      // K   [origin=predictive method=joback]
Pc          42.275;      // bar [origin=predictive method=joback]
omega       1.0649;      // -   [origin=predictive method=lee-kesler]
Tb          476.88;      // K   [origin=predictive method=joback]
HvapTb      58150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.652 0.24564 0.0001602 -1.612e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group OH; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl-bis(oxidanyl)silane" "siloxanes and silicones, di-et" "polydiethylsiloxances" "diethyl(dihydroxy)silane" );
gibbsFormation
{
    dHf_298   -541970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-395600.0
    phase     gas;
}
