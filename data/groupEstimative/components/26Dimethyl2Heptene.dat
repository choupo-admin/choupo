/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-2-heptene  (C9H18, CAS 5557-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl2Heptene;
formula     C9H18;
CAS         5557-98-2;
InChIKey    JDJYGSMZGYTCML-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          587.66;      // K   [origin=predictive method=joback]
Pc          24.580;      // bar [origin=predictive method=joback]
omega       0.3590;      // -   [origin=predictive method=lee-kesler]
Tb          409.12;      // K   [origin=predictive method=joback]
HvapTb      35278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.848 0.88468 -0.0005551 1.446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylhept-2-ene" "2-heptene, 2,6-dimethyl-" );
gibbsFormation
{
    dHf_298   -126940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94130.0
    phase     gas;
}
