/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-1-naphthol  (C11H10O2, CAS 84-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy1Naphthol;
formula     C11H10O2;
CAS         84-85-5;
InChIKey    BOTGCZBEERTTDQ-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          847.71;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.7131;      // -   [origin=predictive method=lee-kesler]
Tb          604.96;      // K   [origin=predictive method=joback]
HvapTb      60082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.58 0.99812 -0.00082084 2.797e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxynaphthalen-1-ol" "1-naphthalenol, 4-methoxy-" "1-hydroxy-4-methoxynaphthalene" "4-methoxynaphthol" "4-methoxy-1-naphthalenol" "1-naphthol, 4-methoxy-" "1-naphthol,4-methoxy- (7ci,8ci);1-hydroxy-4-methoxynaphthalene;4-methoxy-1-naphthalenol;4-methoxy-1-naphthol;4-methoxy-a-naphthol;c.i. 76620;et 2111;ursol grounding blue bl;" );
gibbsFormation
{
    dHf_298   -163770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8450.0
    phase     gas;
}
