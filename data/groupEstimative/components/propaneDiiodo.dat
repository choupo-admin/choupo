/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, diiodo-  (C3H6I2, CAS 10250-52-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propaneDiiodo;
formula     C3H6I2;
CAS         10250-52-9;
InChIKey    GELJRMXFVDEVLN-UHFFFAOYSA-N;
MW          295.881;      // g/mol [origin=calculated method=formula-sum]
Tc          708.59;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       0.2262;      // -   [origin=predictive method=lee-kesler]
Tb          454.08;      // K   [origin=predictive method=joback]
HvapTb      40630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.861 0.37272 -0.0003054 1.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(iodanyl)propane" "propylidene diiodide" );
standardThermochemistry
{
    dHf_298   43210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88180.0
}
