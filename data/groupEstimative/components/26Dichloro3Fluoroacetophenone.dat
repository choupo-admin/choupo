/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',6'-dichloro-3'-fluoroacetophenone  (C8H5Cl2FO, CAS 290835-85-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dichloro3Fluoroacetophenone;
formula     C8H5Cl2FO;
CAS         290835-85-7;
InChIKey    VJBFZHHRVCPAPZ-UHFFFAOYSA-N;
MW          207.025;      // g/mol [origin=calculated method=formula-sum]
Tc          776.33;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.5955;      // -   [origin=predictive method=lee-kesler]
Tb          552.26;      // K   [origin=predictive method=joback]
HvapTb      52363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.84 0.50382 -0.00027998 4.936e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH3CO; count 1; } { group ACCl; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Cl; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,6-bis(chloranyl)-3-fluoranyl-phenyl]ethanone" "1-(2,6-dichloro-3-fluorophenyl)ethanone" "2,6-dichloro-3-fluoroacetophenone" "1-(2,6-dichloro-3-fluorophenyl)ethan-1-one" "2,6-dichloro-3-fluro acetophenone" "2,6-dichloro-5-fluoro acetophenone" "1-acetyl-2,6-dichloro-3-fluorobenzene" "2,6-dichloro-3-fluoro acetophenone" "2,6-dichloro-3-fluoroacetophenone;" "2',6'-dichloro-3'-fluroacetophenone" "2',6'-dichloro-3'-fluoro acetophenone" "h614" );
gibbsFormation
{
    dHf_298   -346500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247590.0
    phase     gas;
}
