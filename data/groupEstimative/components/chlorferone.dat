/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorferone  (C10H7ClO3, CAS 6174-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorferone;
formula     C10H7ClO3;
CAS         6174-86-3;
InChIKey    ODZHLDRQCZXQFQ-UHFFFAOYSA-N;
MW          210.613;      // g/mol [origin=calculated method=formula-sum]
Tc          890.45;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.8878;      // -   [origin=predictive method=lee-kesler]
Tb          652.59;      // K   [origin=predictive method=joback]
HvapTb      67264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.11 0.93402 -0.00084172 3.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group Cl; count 1; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-4-methyl-7-oxidanyl-chromen-2-one" "3-chloro-7-hydroxy-4-methyl-2h-chromen-2-one" "3-chloro-4-methyl-7-hydroxycoumarin" "7-hydroxy-4-methyl-3-chlorocoumarin" "2h-1-benzopyran-2-one, 3-chloro-7-hydroxy-4-methyl-" "3-chloro-7-hydroxy-4-methylchromen-2-one" "3-chloro-4-methylumbelliferone" "3-chloro-7-hydroxy-4-methylcoumarin" "coumarin, 3-chloro-7-hydroxy-4-methyl-" "3-chloro-7-hydroxy-4-methyl-2-benzopyrone" "chlorferron" "y-4-methyl-" );
standardThermochemistry
{
    dHf_298   -400860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-249560.0
}
