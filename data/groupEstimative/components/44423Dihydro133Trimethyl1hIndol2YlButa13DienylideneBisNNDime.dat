/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-(4-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)buta-1,3-dienylidene)bis(n,n-dimethylaniline)  (C31H37N3, CAS 54268-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44423Dihydro133Trimethyl1hIndol2YlButa13DienylideneBisNNDime;
formula     C31H37N3;
CAS         54268-90-5;
InChIKey    AVBBJFZWWYSGND-UHFFFAOYSA-N;
MW          451.658;      // g/mol [origin=calculated method=formula-sum]
Tc          1293.01;      // K   [origin=predictive method=joback]
Pc          10.921;      // bar [origin=predictive method=joback]
omega       0.9523;      // -   [origin=predictive method=lee-kesler]
Tb          1047.42;      // K   [origin=predictive method=joback]
HvapTb      97820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-233.41 3.37124 -0.00280658 9.673e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 12; } { group AC; count 6; } { group CH3N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group dCH; count 3; } { group dC; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-[4-(dimethylamino)phenyl]-4-(1,3,3-trimethyl-2h-indol-2-yl)buta-1,3-dienyl]-n,n-dimethyl-aniline" "benzenamine, 4,4'-(4-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)-1,3-butadien-1-ylidene)bis(n,n-dimethyl-" "benzenamine, 4,4'-(4-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)-1,3-butadienylidene)bis(n,n-dimethyl-" "benzenamine, 4,4'-[4-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)-1,3-butadien-1-ylidene]bis[n,n-dimethyl-" "benzenamine, 4,4'-[4-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)-1,3-butadienylidene]bis[n,n-dimethyl-" "agn-pc-03cb1x" "4,4'-(4-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)-1,3-butadienylidene)bis(n,n-dimethylbenzenamine)" "4-[(3e)-1-[4-(dimethylamino)phenyl]-4-(1,3,3-trimethyl-2h-indol-2-yl)buta-1,3-dienyl]-n,n-dimethylaniline" "4-[1-(4-dimethylaminophenyl)-4-(1,3,3-trimethyl-2h-indol-2-yl)buta-1,3-dienyl]-n,n-dimethylaniline" "benzenamine,4,4'-[4-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)-1,3-butadien-1-ylidene]bis[n,n-dimethyl-" "benzenamine,4,4'-[4-(2,3-dihydro-1,3,3-trimethyl-1h-indol-2-yl)-1,3-butadienylidene]bis[n,n-dimethyl-(9ci); 2-[4,4-bis(4-dimethylaminophenyl)butadienyl]-1,3,3-trimethylindoline" );
gibbsFormation
{
    dHf_298   493110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     973.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1062360.0
    phase     gas;
}
