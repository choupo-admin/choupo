/*--------------------------------*- Choupo -*-----------------------*\
  Component: nikethamide  (C10H14N2O, CAS 59-26-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nikethamide;
formula     C10H14N2O;
CAS         59-26-7;
InChIKey    NCYVXEGFNDZQCU-UHFFFAOYSA-N;
MW          178.235;      // g/mol [origin=calculated method=formula-sum]
Tc          795.23;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.6819;      // -   [origin=predictive method=lee-kesler]
Tb          575.09;      // K   [origin=predictive method=joback]
HvapTb      55129.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.378 1.0046 -0.00065456 1.6346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C5H4N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylpyridine-3-carboxamide" "n,n-diethylnicotinamide" "nicethamide" "coramine" "corvin" "nicotinic acid diethylamide" "3-pyridinecarboxamide, n,n-diethyl-" "canfodiamina" "coraetamidum" "coraethamide" "coraethamidum" "corethamide" );
standardThermochemistry
{
    dHf_298   -25460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204640.0
}
