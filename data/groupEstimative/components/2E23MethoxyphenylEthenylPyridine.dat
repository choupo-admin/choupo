/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[(e)-2-(3-methoxyphenyl)ethenyl]pyridine  (C14H13NO, CAS 5847-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2E23MethoxyphenylEthenylPyridine;
formula     C14H13NO;
CAS         5847-73-4;
InChIKey    OJMUQBRJFDVGJA-CMDGGOBGSA-N;
MW          211.264;      // g/mol [origin=calculated method=formula-sum]
Tc          912.80;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       0.6159;      // -   [origin=predictive method=lee-kesler]
Tb          658.54;      // K   [origin=predictive method=joback]
HvapTb      60550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.97 1.10708 -0.00071522 1.759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine, trans-3-(2-(4-methoxyphenyl)ethenyl)-" );
standardThermochemistry
{
    dHf_298   147090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=334460.0
}
