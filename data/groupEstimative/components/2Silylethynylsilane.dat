/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-silylethynylsilane  (C2H6Si2, CAS 1070-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2H6Si2 (delta H+6Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Silylethynylsilane;
formula     C2H6Si2;
CAS         1070-76-4;
InChIKey    OFIDJMJLBNOBIL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          86.24;      // g/mol [origin=calculated method=formula-sum]
Tc          430.32;      // K   [origin=predictive method=joback]
Pc          49.733;      // bar [origin=predictive method=joback]
omega       0.0332;      // -   [origin=predictive method=lee-kesler]
Tb          252.96;      // K   [origin=predictive method=joback]
HvapTb      21904.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.19 0.2502 -0.00040766 2.0878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C_C; count 1; } { group SiH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-silanylethynylsilane" "silane,1,2-ethynediylbis- (9ci)" "1,4-disilabut-2-yne(6ci,7ci,8ci); disilylacetylene; ethynylenebis(silane)" );
standardThermochemistry
{
    dHf_298   299310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=273520.0
}
