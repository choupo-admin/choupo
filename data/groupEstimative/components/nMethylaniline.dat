/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylaniline  (C7H9N, CAS 100-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylaniline;
formula     C7H9N;
CAS         100-61-8;
InChIKey    AFBPFSWMIHJQDM-UHFFFAOYSA-N;
MW          107.156;      // g/mol [origin=calculated method=formula-sum]
Tc          651.99;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.3937;      // -   [origin=predictive method=lee-kesler]
Tb          436.61;      // K   [origin=predictive method=joback]
HvapTb      39888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.59 0.66612 -0.0004368 1.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "monomethylaniline" "n-methyl aniline" "methylaniline" "n-monomethylaniline" "benzenamine, n-methyl-" "(methylamino)benzene" "methylphenylamine" "n-methylbenzenamine" "n-phenylmethylamine" "anilinomethane" "n-methylaminobenzene" "aniline, n-methyl-" );
standardThermochemistry
{
    dHf_298   102190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209860.0
}
