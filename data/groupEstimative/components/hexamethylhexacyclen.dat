/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethylhexacyclen  (C18H42N6, CAS 79676-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethylhexacyclen;
formula     C18H42N6;
CAS         79676-97-4;
InChIKey    KVXKXUJAIKWPHT-UHFFFAOYSA-N;
MW          342.576;      // g/mol [origin=calculated method=formula-sum]
Tc          936.70;      // K   [origin=predictive method=joback]
Pc          15.140;      // bar [origin=predictive method=joback]
omega       0.8966;      // -   [origin=predictive method=lee-kesler]
Tb          735.92;      // K   [origin=predictive method=joback]
HvapTb      69690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.89 2.54832 -0.001489 2.858e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH3N; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 12; } { group N; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,10,13,16-hexamethyl-1,4,7,10,13,16-hexazacyclooctadecane" "1,4,7,10,13,16-hexamethyl-1,4,7,10,13,16-hexaazacyclooctadecane" );
standardThermochemistry
{
    dHf_298   28030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1085.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=724920.0
}
