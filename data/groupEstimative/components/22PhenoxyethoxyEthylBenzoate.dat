/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-phenoxyethoxy)ethyl benzoate  (C17H18O4, CAS 67845-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22PhenoxyethoxyEthylBenzoate;
formula     C17H18O4;
CAS         67845-81-2;
InChIKey    TZHGOJUYMUTMTF-UHFFFAOYSA-N;
MW          286.327;      // g/mol [origin=calculated method=formula-sum]
Tc          966.56;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       0.9240;      // -   [origin=predictive method=lee-kesler]
Tb          744.98;      // K   [origin=predictive method=joback]
HvapTb      70215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.966 1.2798 -0.0006468 7.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2-(2-phenoxyethoxy)-, benzoate" "ethanol, 2-(2-phenoxyethoxy)-, 1-benzoate" );
standardThermochemistry
{
    dHf_298   -502870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203290.0
}
