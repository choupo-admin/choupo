/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8,19,20-tetraoxatrispiro[5.2.2.5.2.2]heneicosane  (C17H28O4, CAS 57565-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        81920Tetraoxatrispiro522522Heneicosane;
formula     C17H28O4;
CAS         57565-08-9;
InChIKey    UELKTOZXAAYYTH-UHFFFAOYSA-N;
MW          296.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1047.58;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       0.6625;      // -   [origin=predictive method=lee-kesler]
Tb          767.14;      // K   [origin=predictive method=joback]
HvapTb      69532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-346.25 3.0262 -0.0029618 1.2066e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group C; count 3; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 14; } { group C_ring; count 3; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8,10,19,20-tetraoxatrispiro[5.2.2.5^{12}.2^{9}.2^{6}]henicosane" "8,10,19,20-tetraoxatrispiro[5.2.2.5.2.2]heneicosane" "8,10,19,20-tetraoxatrispiro(5.2.2.5.2.2)heneicosane" );
gibbsFormation
{
    dHf_298   -620390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126880.0
    phase     gas;
}
