/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptatriacontene  (C37H74, CAS 61868-15-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptatriacontene;
formula     C37H74;
CAS         61868-15-3;
InChIKey    VKVLQEVZERYUAZ-UHFFFAOYSA-N;
MW          518.999;      // g/mol [origin=calculated method=formula-sum]
Tc          1341.37;      // K   [origin=predictive method=joback]
Pc          4.473;      // bar [origin=predictive method=joback]
omega       -0.0471;      // -   [origin=predictive method=lee-kesler]
Tb          1042.84;      // K   [origin=predictive method=joback]
HvapTb      97286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.736 3.49882 -0.0020119 4.465e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 34; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 34; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptatriacont-1-ene" "1-heptatriacontene" "agn-pc-00o5oo" );
gibbsFormation
{
    dHf_298   -681580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1592.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348500.0
    phase     gas;
}
