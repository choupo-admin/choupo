/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethylurea  (C5H12N2O, CAS 632-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetramethylurea;
formula     C5H12N2O;
CAS         632-22-4;
InChIKey    AVQQQNCBBIEMEU-UHFFFAOYSA-N;
MW          116.164;      // g/mol [origin=calculated method=formula-sum]
Tc          568.15;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.4984;      // -   [origin=predictive method=lee-kesler]
Tb          392.75;      // K   [origin=predictive method=joback]
HvapTb      37556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.68 0.69868 -0.0004547 1.1406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3N; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3-tetramethylurea" "temur" "urea, tetramethyl-" "n,n,n',n'-tetramethylurea" "urea, n,n,n',n'-tetramethyl-" "tetramethyluree [french]" "tmu" "urea, 1,1,3,3-tetramethyl-" "(dimethylamino)-n,n-dimethylcarboxamide" "tetramethyluree" "tetramethyl-urea" "tetramethyl urea" );
gibbsFormation
{
    dHf_298   -124050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83860.0
    phase     gas;
}
