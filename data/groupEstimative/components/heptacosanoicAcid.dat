/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptacosanoic acid  (C27H54O2, CAS 7138-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptacosanoicAcid;
formula     C27H54O2;
CAS         7138-40-1;
InChIKey    VXZBFBRLRNDJCS-UHFFFAOYSA-N;
MW          410.727;      // g/mol [origin=calculated method=formula-sum]
Tc          1188.90;      // K   [origin=predictive method=joback]
Pc          7.222;      // bar [origin=predictive method=joback]
omega       0.5917;      // -   [origin=predictive method=lee-kesler]
Tb          962.87;      // K   [origin=predictive method=joback]
HvapTb      92860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.055 2.61962 -0.0015176 3.381e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 25; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 25; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "carbocerate" "c27:0" "carboxylic acids, c27-47" "(c24-c44) alpha olefins, propionic acid reaction product" "563cbb30-089b-45e1-be24-439806fb6ff4" );
standardThermochemistry
{
    dHf_298   -950880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1260.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167450.0
}
