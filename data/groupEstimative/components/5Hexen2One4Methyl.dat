/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexen-2-one, 4-methyl-  (C7H12O, CAS 61675-14-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexen2One4Methyl;
formula     C7H12O;
CAS         61675-14-7;
InChIKey    MXGGBUKCVFGCAG-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          594.45;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.4192;      // -   [origin=predictive method=lee-kesler]
Tb          409.87;      // K   [origin=predictive method=joback]
HvapTb      36864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.789 0.62674 -0.0003644 7.996e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylhex-5-en-2-one" "agn-pc-00lkiv" "4-methyl-5-hexen-2-one" "4-methyl-hex-5-en-2-one" );
standardThermochemistry
{
    dHf_298   -180240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35460.0
}
