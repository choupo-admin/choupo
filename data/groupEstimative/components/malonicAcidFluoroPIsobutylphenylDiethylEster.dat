/*--------------------------------*- Choupo -*-----------------------*\
  Component: malonic acid, fluoro-p-isobutylphenyl-, diethyl ester  (C17H23FO4, CAS 23197-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        malonicAcidFluoroPIsobutylphenylDiethylEster;
formula     C17H23FO4;
CAS         23197-71-9;
InChIKey    CVEADRMKLCECBY-UHFFFAOYSA-N;
MW          310.365;      // g/mol [origin=calculated method=formula-sum]
Tc          932.50;      // K   [origin=predictive method=joback]
Pc          15.476;      // bar [origin=predictive method=joback]
omega       0.9079;      // -   [origin=predictive method=lee-kesler]
Tb          732.26;      // K   [origin=predictive method=joback]
HvapTb      68687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.417 1.51438 -0.00086736 1.545e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CF; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-fluoranyl-2-[4-(2-methylpropyl)phenyl]propanedioate" "diethyl 2-fluoro-2-[4-(2-methylpropyl)phenyl]propanedioate" "malonic acid, 2-fluoro-2-(p-isobutylphenyl)-, diethyl ester" );
gibbsFormation
{
    dHf_298   -1013850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-620110.0
    phase     gas;
}
