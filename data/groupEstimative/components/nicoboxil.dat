/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicoboxil  (C12H17NO3, CAS 1322-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicoboxil;
formula     C12H17NO3;
CAS         1322-29-8;
InChIKey    IZJRISIINLJVBU-UHFFFAOYSA-N;
MW          223.272;      // g/mol [origin=calculated method=formula-sum]
Tc          843.99;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.8192;      // -   [origin=predictive method=lee-kesler]
Tb          635.18;      // K   [origin=predictive method=joback]
HvapTb      60609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.045 0.98068 -0.00046386 4.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2O; count 1; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethyl pyridine-3-carboxylate" "butoxyethyl nicotinate" "beta-butoxyethyl nicotinate" "3-pyridinecarboxylic acid, 2-butoxyethyl ester" "nicoboxilo" "nicoboxilum" "nicoboxil (inn)" "nicoboxilum [inn-latin]" "butoxyethyl 3-pyridinecarboxylate" "nicotinsaeure-beta-butoxyethylester" "beta-butoxyethyl nicotinate (jan)" "2-butoxyethyl 3-pyridinecarboxylate" );
standardThermochemistry
{
    dHf_298   -471190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-175750.0
}
