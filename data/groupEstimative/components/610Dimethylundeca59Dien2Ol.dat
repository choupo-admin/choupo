/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,10-dimethylundeca-5,9-dien-2-ol  (C13H24O, CAS 53837-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        610Dimethylundeca59Dien2Ol;
formula     C13H24O;
CAS         53837-34-6;
InChIKey    LYFDNQZGOHRKNK-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          772.76;      // K   [origin=predictive method=joback]
Pc          19.718;      // bar [origin=predictive method=joback]
omega       0.9222;      // -   [origin=predictive method=lee-kesler]
Tb          596.86;      // K   [origin=predictive method=joback]
HvapTb      60899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.066 1.31858 -0.0008892 2.512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,9-undecadien-2-ol, 6,10-dimethyl-" "(2r,5z)-6,10-dimethylundeca-5,9-dien-2-ol" "(2s,5e)-6,10-dimethylundeca-5,9-dien-2-ol" "(2s,5z)-6,10-dimethylundeca-5,9-dien-2-ol" "5,9-undecadien-2-ol, 6,10-dimethyl-, (5e)-" "5,9-undecadien-2-ol, 6,10-dimethyl-, (z)-" );
gibbsFormation
{
    dHf_298   -254300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62660.0
    phase     gas;
}
