/*--------------------------------*- Choupo -*-----------------------*\
  Component: docosyl docosanoate  (C44H88O2, CAS 17671-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        docosylDocosanoate;
formula     C44H88O2;
CAS         17671-27-1;
InChIKey    NJIMZDGGLTUCPX-UHFFFAOYSA-N;
MW          649.186;      // g/mol [origin=calculated method=formula-sum]
Tc          1857.25;      // K   [origin=predictive method=joback]
Pc          3.383;      // bar [origin=predictive method=joback]
omega       -0.5100;      // -   [origin=predictive method=lee-kesler]
Tb          1264.54;      // K   [origin=predictive method=joback]
HvapTb      120945.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.699 4.12904 -0.0022752 4.553e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 40; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 41; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "behenyl behenate" "docosanyl docosanoate" "docosanoic acid, docosyl ester" "behenic acid behenyl ester" "docosanoic acid,docosyl ester" "we(22:0/22:0)" );
standardThermochemistry
{
    dHf_298   -1268770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1921.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9230.0
}
