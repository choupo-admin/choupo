/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-heptadiyne  (C7H8, CAS 2396-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Heptadiyne;
formula     C7H8;
CAS         2396-63-6;
InChIKey    RSPZSDWVQWRAEF-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          528.43;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.2190;      // -   [origin=predictive method=lee-kesler]
Tb          340.00;      // K   [origin=predictive method=joback]
HvapTb      30892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.083 0.481 -0.00034886 1.0888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hepta-1,6-diyne" );
gibbsFormation
{
    dHf_298   395990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=454200.0
    phase     gas;
}
