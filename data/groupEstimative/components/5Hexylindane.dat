/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexylindane  (C15H22, CAS 54889-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexylindane;
formula     C15H22;
CAS         54889-55-3;
InChIKey    HCJRTBCEQLVXLX-UHFFFAOYSA-N;
MW          202.341;      // g/mol [origin=calculated method=formula-sum]
Tc          798.00;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       0.6220;      // -   [origin=predictive method=lee-kesler]
Tb          590.85;      // K   [origin=predictive method=joback]
HvapTb      52806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.235 1.40832 -0.00096492 2.705e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 3; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-hexyl-2,3-dihydro-1h-indene" "1h-indene, 5-hexyl-2,3-dihydro-" );
standardThermochemistry
{
    dHf_298   -46200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=237030.0
}
