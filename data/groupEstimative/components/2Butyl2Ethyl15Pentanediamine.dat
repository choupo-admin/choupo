/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyl-2-ethyl-1,5-pentanediamine  (C11H26N2, CAS 137605-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyl2Ethyl15Pentanediamine;
formula     C11H26N2;
CAS         137605-95-9;
InChIKey    NDXNCTAJOQSKIO-UHFFFAOYSA-N;
MW          186.343;      // g/mol [origin=calculated method=formula-sum]
Tc          785.16;      // K   [origin=predictive method=joback]
Pc          21.816;      // bar [origin=predictive method=joback]
omega       0.7968;      // -   [origin=predictive method=lee-kesler]
Tb          593.11;      // K   [origin=predictive method=joback]
HvapTb      60066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.602 1.29844 -0.0008332 2.136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group C; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butyl-2-ethyl-pentane-1,5-diamine" "2-butyl-2-ethylpentane-1,5-diamine" "2-butyl-2-ethyl-1 5-pentanediamine" "2-butyl-2-ethyl-1,5-pentanediamine 96+%;2-butyl-2-ethyl-1,5-diaminopentane" );
gibbsFormation
{
    dHf_298   -211540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177480.0
    phase     gas;
}
