/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenpentadiol  (C12H17ClO2, CAS 15687-18-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenpentadiol;
formula     C12H17ClO2;
CAS         15687-18-0;
InChIKey    SNJDSTGQYRTZJT-UHFFFAOYSA-N;
MW          228.716;      // g/mol [origin=calculated method=formula-sum]
Tc          922.73;      // K   [origin=predictive method=joback]
Pc          28.627;      // bar [origin=predictive method=joback]
omega       1.3021;      // -   [origin=predictive method=lee-kesler]
Tb          721.15;      // K   [origin=predictive method=joback]
HvapTb      80395.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.099 1.33186 -0.00101796 3.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chlorophenyl)-4-methyl-pentane-2,4-diol" "tredum" "fenpentadiolum [inn-latin]" "2-(4-chlorophenyl)-4-methylpentane-2,4-diol" "2-(4-chlorophenyl)-4-methyl-2,4-pentanediol" "2-(p-chlorophenyl)-4-methylpentane-2,4-diol" "2-methyl-4-(p-chlorophenyl)-2,4-pentanediol" "2,4-pentanediol, 2-(p-chlorophenyl)-4-methyl-" "fempentadiol" "fenpentadiolum" "fenpentadiol [inn:dcf]" "2-(p-chlorophenyl)-4-methyl-2,4-pentanediol" );
gibbsFormation
{
    dHf_298   -403650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126950.0
    phase     gas;
}
