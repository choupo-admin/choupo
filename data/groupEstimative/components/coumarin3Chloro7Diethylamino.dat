/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin, 3-chloro-7-diethylamino-  (C13H14ClNO2, CAS 133590-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin3Chloro7Diethylamino;
formula     C13H14ClNO2;
CAS         133590-12-2;
InChIKey    CZUSPFIQJDLTQE-UHFFFAOYSA-N;
MW          251.71;      // g/mol [origin=calculated method=formula-sum]
Tc          866.34;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       0.8379;      // -   [origin=predictive method=lee-kesler]
Tb          653.05;      // K   [origin=predictive method=joback]
HvapTb      62971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.608 1.18834 -0.00086116 2.452e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2N; count 1; } { group Cl_C=C_; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group Cl; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-7-(diethylamino)chromen-2-one" "2h-1-benzopyran-2-one,3-chloro-7-(diethylamino)-" "3-chloro-7-diethylamino-chromen-2-one" "3-chloro-7-(diethylamino)chromen-2-one" "3-chloro-7-(diethylamino)-2h-chromen-2-one" );
gibbsFormation
{
    dHf_298   -217940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41100.0
    phase     gas;
}
