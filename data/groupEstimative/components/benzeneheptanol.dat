/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneheptanol  (C13H20O, CAS 3208-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneheptanol;
formula     C13H20O;
CAS         3208-25-1;
InChIKey    UXMUSYTXSNVRMW-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          801.90;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.9994;      // -   [origin=predictive method=lee-kesler]
Tb          615.90;      // K   [origin=predictive method=joback]
HvapTb      63487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.543 1.1939 -0.000745 1.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-phenylheptan-1-ol" "1-heptanol,7-phenyl- (6ci,7ci,8ci); 7-phenyl-1-heptanol; 7-phenylheptanol; 7-phenylheptylalcohol" );
standardThermochemistry
{
    dHf_298   -227350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34170.0
}
