/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-2-p-menthene  (C10H18, CAS 5113-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PMenthene;
formula     C10H18;
CAS         5113-93-9;
InChIKey    WHNGPXQYYRWQAS-UWVGGRQHSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          645.22;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.3098;      // -   [origin=predictive method=lee-kesler]
Tb          442.00;      // K   [origin=predictive method=joback]
HvapTb      37878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.77 0.99936 -0.00053628 9.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,6s)-3-methyl-6-propan-2-yl-cyclohexene" "(+)-trans-p-menth-2-ene" "(3s,6r)-3-isopropyl-6-methylcyclohexene" "p-menth-2-ene, trans-" "cyclohexene, 3-methyl-6-(1-methylethyl)-, trans-" "(3r,6s)-3-methyl-6-propan-2-ylcyclohexene" );
standardThermochemistry
{
    dHf_298   -163250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77580.0
}
