/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorodocosane  (C22H45Cl, CAS 71662-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorodocosane;
formula     C22H45Cl;
CAS         71662-62-9;
InChIKey    VUAGIIPUXBAOEO-QFIPXVFZSA-N;
MW          345.052;      // g/mol [origin=calculated method=formula-sum]
Tc          911.11;      // K   [origin=predictive method=joback]
Pc          8.863;      // bar [origin=predictive method=joback]
omega       0.7974;      // -   [origin=predictive method=lee-kesler]
Tb          739.95;      // K   [origin=predictive method=joback]
HvapTb      68563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.901 2.10654 -0.0011966 2.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-chloranyldocosane" "docosane, 2-chloro-" "(2s)-2-chlorodocosane" );
gibbsFormation
{
    dHf_298   -518430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1036.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119990.0
    phase     gas;
}
