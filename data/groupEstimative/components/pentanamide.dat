/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentanamide  (C5H11NO, CAS 626-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentanamide;
formula     C5H11NO;
CAS         626-97-1;
InChIKey    IPWFJLQDVFKJDU-UHFFFAOYSA-N;
MW          101.149;      // g/mol [origin=calculated method=formula-sum]
Tc          633.92;      // K   [origin=predictive method=joback]
Pc          40.159;      // bar [origin=predictive method=joback]
omega       0.5562;      // -   [origin=predictive method=lee-kesler]
Tb          440.40;      // K   [origin=predictive method=joback]
HvapTb      44111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.193 0.51272 -0.0002729 5.026e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "valeramide" "n-valeramide" "pentanimidic acid" "ipwfjlqdvfkjdu-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -225320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71250.0
}
