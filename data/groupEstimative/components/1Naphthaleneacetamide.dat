/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthaleneacetamide  (C12H11NO, CAS 86-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Naphthaleneacetamide;
formula     C12H11NO;
CAS         86-86-2;
InChIKey    XFNJVKMNNVCYEK-UHFFFAOYSA-N;
MW          185.226;      // g/mol [origin=calculated method=formula-sum]
Tc          896.72;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.7656;      // -   [origin=predictive method=lee-kesler]
Tb          651.20;      // K   [origin=predictive method=joback]
HvapTb      64271.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.219 1.0356 -0.00075458 2.1526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-naphthalen-1-ylethanamide" "1-naphthylacetamide" "rootone" "frufix" "2-(1-naphthyl)acetamide" "amid-thin" "dirigol n" "alpha-naa amide" "alpha-naphthaleneacetamide" "amid-thin w" "naam" "naphthaleneacetamide" );
gibbsFormation
{
    dHf_298   46330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197120.0
    phase     gas;
}
