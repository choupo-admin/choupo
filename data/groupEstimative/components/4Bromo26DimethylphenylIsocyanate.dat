/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-2,6-dimethylphenyl isocyanate  (C9H8BrNO, CAS 77159-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo26DimethylphenylIsocyanate;
formula     C9H8BrNO;
CAS         77159-76-3;
InChIKey    XGBDVSJAHTYSBK-UHFFFAOYSA-N;
MW          226.073;      // g/mol [origin=calculated method=formula-sum]
Tc          815.50;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.6499;      // -   [origin=predictive method=lee-kesler]
Tb          579.97;      // K   [origin=predictive method=joback]
HvapTb      55857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 2; } { group dCd; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanyl-2-isocyanato-1,3-dimethyl-benzene" "5-bromo-2-isocyanato-1,3-dimethylbenzene" "4-bromo-2,6-dimethylbenzenisocyanate" "4-bromo-2,6-dimethylphenylisocyanate;" "benzene,5-bromo-2-isocyanato-1,3-dimethyl-" );
