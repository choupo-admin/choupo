/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-9-hexadecenal  (C16H30O, CAS 56219-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis9Hexadecenal;
formula     C16H30O;
CAS         56219-04-6;
InChIKey    QFPVVMKZTVQDTL-FPLPWBNLSA-N;
MW          238.415;      // g/mol [origin=calculated method=formula-sum]
Tc          787.74;      // K   [origin=predictive method=joback]
Pc          14.479;      // bar [origin=predictive method=joback]
omega       0.8580;      // -   [origin=predictive method=lee-kesler]
Tb          618.50;      // K   [origin=predictive method=joback]
HvapTb      57888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.438 1.51832 -0.0009234 2.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group dCH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-hexadec-9-enal" "(z)-9-hexadecenal" "9z-hexadecenal" "z-9-hexadecenal" "9-hexadecenal, (z)-" "9-hexadecenal, (9z)-" "palmitolealdehyde" "(9z)-9-hexadecenal" );
gibbsFormation
{
    dHf_298   -341930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64540.0
    phase     gas;
}
