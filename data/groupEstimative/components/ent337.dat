/*--------------------------------*- Choupo -*-----------------------*\
  Component: ent-337  (C12H22O5, CAS 6280-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ent337;
formula     C12H22O5;
CAS         6280-99-5;
InChIKey    PDSCSYLDRHAHOX-UHFFFAOYSA-N;
MW          246.303;      // g/mol [origin=calculated method=formula-sum]
Tc          854.53;      // K   [origin=predictive method=joback]
Pc          19.579;      // bar [origin=predictive method=joback]
omega       1.2699;      // -   [origin=predictive method=lee-kesler]
Tb          682.34;      // K   [origin=predictive method=joback]
HvapTb      73411.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.407 1.07414 -0.0004734 2.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutyl 2-oxidanylbutanedioate" "butanedioic acid, hydroxy-, dibutyl ester" "dl-dibutyl malate" "dibutyl (1)-malate" "malic acid, dibutyl ester" "dibutyl (+-)-hydroxybutanedioate" "malic acid, dibutyl ester, (+-)-" "butanedioic acid, 2-hydroxy-, 1,4-dibutyl ester" "butanedioic acid, hydroxy-, dibutyl ester, (.+/-.)-" "dibutyl dl-malate" "dibutylmalate" "butanedioic acid, hydroxy-, dibutyl ester, (2r)-" );
standardThermochemistry
{
    dHf_298   -1083080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-709840.0
}
