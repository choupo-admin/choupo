/*--------------------------------*- Choupo -*-----------------------*\
  Component: carpipramine  (C28H38N4O, CAS 5942-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carpipramine;
formula     C28H38N4O;
CAS         5942-95-0;
InChIKey    NWPJLRSCSQHPJV-UHFFFAOYSA-N;
MW          446.639;      // g/mol [origin=calculated method=formula-sum]
Tc          1368.44;      // K   [origin=predictive method=joback]
Pc          14.977;      // bar [origin=predictive method=joback]
omega       1.2419;      // -   [origin=predictive method=lee-kesler]
Tb          1109.89;      // K   [origin=predictive method=joback]
HvapTb      107036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-307.957 3.5614 -0.00295502 9.9996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH2N; count 3; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 11; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 1; } { group NH2; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-(5,6-dihydrobenzo[b][1]benzazepin-11-yl)propyl]-4-piperidin-1-yl-piperidine-4-carboxamide" "carbadipimidine" "carpipramine [inn]" "carpipraminum [inn-latin]" "carpipramine (inn)" "5-(3-(4-piperidino-4-carbamoylpiperidino)propyl)-10,11-dihydro-5(h)-dibenz(b,f)azepine" "5h-dibenz(b,f)azepine, 10,11-dihydro-5-(3-(4-piperidino-4-carbamoylpiperidino)propyl)-" "carpipramina" "carpipraminum" "7075-03-8 (di-hydrochloride)" "1'-[3-(10,11-dihydro-5h-dibenzo[b,f]azepin-5-yl)propyl]-1,4'-bipiperidine-4'-carboxamide" "1-[3-(5,6-dihydrobenzo[b][1]benzazepin-11-yl)propyl]-4-piperidin-1-ylpiperidine-4-carboxamide" );
standardThermochemistry
{
    dHf_298   208510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1091.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=816190.0
}
