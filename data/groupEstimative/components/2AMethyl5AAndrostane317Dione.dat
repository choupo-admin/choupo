/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2|a-methyl-5|a-androstane-3,17-dione  (C20H30O2, CAS 5470-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AMethyl5AAndrostane317Dione;
formula     C20H30O2;
CAS         5470-27-9;
InChIKey    RVSSFXUENQNQJK-ROGQGFJNSA-N;
MW          302.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1086.04;      // K   [origin=predictive method=joback]
Pc          16.907;      // bar [origin=predictive method=joback]
omega       0.7085;      // -   [origin=predictive method=lee-kesler]
Tb          827.62;      // K   [origin=predictive method=joback]
HvapTb      65891.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-251.17 2.62716 -0.002124 7.599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 5; } { group C; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,5s,8r,9s,10s,13s,14s)-2,10,13-trimethyl-2,4,5,6,7,8,9,11,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthrene-3,17-dione" "2alpha-methyl-5alpha-androstane-3,17-dione" );
gibbsFormation
{
    dHf_298   -501670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20730.0
    phase     gas;
}
