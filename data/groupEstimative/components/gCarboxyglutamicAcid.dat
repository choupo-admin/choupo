/*--------------------------------*- Choupo -*-----------------------*\
  Component: g-carboxyglutamic acid  (C6H9NO6, CAS 53861-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gCarboxyglutamicAcid;
formula     C6H9NO6;
CAS         53861-57-7;
InChIKey    UHBYWPGGCSDKFX-VKHMYHEASA-N;
MW          191.139;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.17;      // K   [origin=predictive method=joback]
Pc          47.301;      // bar [origin=predictive method=joback]
omega       1.7777;      // -   [origin=predictive method=lee-kesler]
Tb          845.06;      // K   [origin=predictive method=joback]
HvapTb      90307.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.361 0.7999 -0.0005702 1.542e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CHNH2; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 2; } { group COOH; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-3-azanylpropane-1,1,3-tricarboxylic acid" "gamma-carboxy-glutamic acid" "gamma-carboxyglutamic acid" "(3s)-3-aminopropane-1,1,3-tricarboxylic acid" "l-gla-oh" "h-l-gla-oh" "gamma-carboxy-l-glutamic acid" "gamma-carboxy-glutamic acid zwitterion" "(3s)-3-amino-1,1,3-propanetricarboxylic acid" "(s)-3-aminopropane-1,1,3-tricarboxylic acid" "1,1,3-propanetricarboxylicacid, 3-amino-, (3s)-" "1,1,3-propanetricarboxylicacid, 3-amino-, (r)-; d-g-carboxyglutamic acid; g-carboxy-d-glutamic acid" );
gibbsFormation
{
    dHf_298   -1194750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-970520.0
    phase     gas;
}
