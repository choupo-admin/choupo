/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylpyrrolidine  (C5H11N, CAS 765-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylpyrrolidine;
formula     C5H11N;
CAS         765-38-8;
InChIKey    RGHPCLZJAFCTIK-UHFFFAOYSA-N;
MW          85.15;      // g/mol [origin=calculated method=formula-sum]
Tc          584.81;      // K   [origin=predictive method=joback]
Pc          44.862;      // bar [origin=predictive method=joback]
omega       0.2752;      // -   [origin=predictive method=lee-kesler]
Tb          377.83;      // K   [origin=predictive method=joback]
HvapTb      33739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.22 0.59712 -0.000315 5.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrrolidine, 2-methyl-" "agn-pc-03f3hg" "r(-)-2-methyl-pyrrolidine" "pyrrolidine,2-methyl-, (?a'a a'a currency)-;a-methylpyrrolidine;" );
gibbsFormation
{
    dHf_298   -48240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     294.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115480.0
    phase     gas;
}
