/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methyl-4-nonyne  (C10H18, CAS 70732-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methyl4Nonyne;
formula     C10H18;
CAS         70732-43-3;
InChIKey    PPAFZGNCAFJAEV-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          625.72;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.3765;      // -   [origin=predictive method=lee-kesler]
Tb          436.96;      // K   [origin=predictive method=joback]
HvapTb      39618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.674 0.80996 -0.00043126 8.628e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methylnon-4-yne" "agn-pc-01zmjj" );
gibbsFormation
{
    dHf_298   17290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233680.0
    phase     gas;
}
