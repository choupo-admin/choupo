/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylphenylacetonitrile  (C11H13N, CAS 4395-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropylphenylacetonitrile;
formula     C11H13N;
CAS         4395-87-3;
InChIKey    RIPHZOPMCRSGSI-UHFFFAOYSA-N;
MW          159.232;      // g/mol [origin=calculated method=formula-sum]
Tc          809.73;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.5710;      // -   [origin=predictive method=lee-kesler]
Tb          584.58;      // K   [origin=predictive method=joback]
HvapTb      53108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.399 0.85114 -0.00051096 1.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-propan-2-ylphenyl)ethanenitrile" "2-(4-isopropylphenyl)acetonitrile" "(4-isopropylphenyl)acetonitrile" "[4-(propan-2-yl)phenyl]acetonitrile" "2-(4-propan-2-ylphenyl)acetonitrile" "2-[4-(methylethyl)phenyl]ethanenitrile" "4-isopropylphenylacetonitrile, 98+%;benzeneacetonitrile, 4-(1-methylethyl)- (9ci);2-(4-isopropylphenyl)acetonitrile;2-(4-propan-2-ylphenyl)ethanenitrile;" );
gibbsFormation
{
    dHf_298   114290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=275260.0
    phase     gas;
}
