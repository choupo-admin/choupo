/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxy-5-propylphenol  (C11H16O2, CAS 68399-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxy5Propylphenol;
formula     C11H16O2;
CAS         68399-69-9;
InChIKey    XDZLFEKELKUEPL-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          799.31;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.7515;      // -   [origin=predictive method=lee-kesler]
Tb          585.98;      // K   [origin=predictive method=joback]
HvapTb      58442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.137 1.00184 -0.00068412 1.986e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-5-propyl-phenol" "phenol, 2-ethoxy-5-propyl-" );
gibbsFormation
{
    dHf_298   -354840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-115100.0
    phase     gas;
}
