/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[2-(4-bromophenyl)ethenyl]-n,n-dimethylaniline  (C16H16BrN, CAS 2844-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        424BromophenylEthenylNNDimethylaniline;
formula     C16H16BrN;
CAS         2844-19-1;
InChIKey    OJAOHXMMLZIIOY-UHFFFAOYSA-N;
MW          302.215;      // g/mol [origin=calculated method=formula-sum]
Tc          960.66;      // K   [origin=predictive method=joback]
Pc          24.925;      // bar [origin=predictive method=joback]
omega       0.7272;      // -   [origin=predictive method=lee-kesler]
Tb          711.76;      // K   [origin=predictive method=joback]
HvapTb      65522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.55 1.42914 -0.00104272 2.993e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Br; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-bromophenyl)ethenyl]-n,n-dimethyl-aniline" "4-[(e)-2-(4-bromophenyl)vinyl]-n,n-dimethyl-aniline" "agn-pc-0d91jr" "benzenamine, 4-[2-(4-bromophenyl)ethenyl]-n,n-dimethyl-" "benzenamine,4-[(1e)-2-(4-bromophenyl)ethenyl]-n,n-dimethyl-" "benzenamine,4-[2-(4-bromophenyl)ethenyl]-n,n-dimethyl-, (e)-" );
gibbsFormation
{
    dHf_298   287630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=494720.0
    phase     gas;
}
