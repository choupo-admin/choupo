/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-dimethyl-dba  (C24H18, CAS 35335-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910DimethylDba;
formula     C24H18;
CAS         35335-07-0;
InChIKey    KFOMXRLGNXVJPI-UHFFFAOYSA-N;
MW          306.408;      // g/mol [origin=calculated method=formula-sum]
Tc          1135.77;      // K   [origin=predictive method=joback]
Pc          19.136;      // bar [origin=predictive method=joback]
omega       0.8916;      // -   [origin=predictive method=lee-kesler]
Tb          876.22;      // K   [origin=predictive method=joback]
HvapTb      81164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.11 1.89264 -0.00152468 4.998e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 8; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,14-dimethylnaphtho[1,2-b]phenanthrene" "7,14-dimethyldibenz(a,h)anthracene" "9,10-dimethyl-1,2,5,6-dibenzanthracene" "dibenz(a,h)anthracene, 7,14-dimethyl-" "7,14-dimethylbenzo[k]tetraphene" "benzo[k]benz[a]anthracene,7,14-dimethyl-" "dibenz[a,h]anthracene,7,14-dimethyl- (6ci,7ci,9ci); 7,14-dimethyldibenz[a,h]anthracene" );
standardThermochemistry
{
    dHf_298   404770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=642060.0
}
