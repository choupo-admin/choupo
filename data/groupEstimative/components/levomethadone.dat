/*--------------------------------*- Choupo -*-----------------------*\
  Component: levomethadone  (C21H27NO, CAS 125-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        levomethadone;
formula     C21H27NO;
CAS         125-58-6;
InChIKey    USSIQXCVUWKGNF-QGZVFWFLSA-N;
MW          309.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1024.65;      // K   [origin=predictive method=joback]
Pc          16.207;      // bar [origin=predictive method=joback]
omega       0.8416;      // -   [origin=predictive method=lee-kesler]
Tb          796.08;      // K   [origin=predictive method=joback]
HvapTb      73997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.498 2.06868 -0.0014499 3.8946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6r)-6-(dimethylamino)-4,4-diphenyl-heptan-3-one" "(r)-methadone" "polamivet" "l-methadone" "(-)-methadone" "levothyl" "l-polamivet" "l-polamidon" "(6r)-methadone" "levadone" "levomethadone (inn)" "d-(-)-methadone" );
gibbsFormation
{
    dHf_298   -62790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=333020.0
    phase     gas;
}
