/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2-(hydroxymethyl)-2-(octadec-9-enoyloxymethyl)butyl] octadec-9-enoate  (C42H78O5, CAS 25111-05-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxymethyl2Octadec9EnoyloxymethylButylOctadec9Enoate;
formula     C42H78O5;
CAS         25111-05-1;
InChIKey    NKSZWBYBTXAALC-UHFFFAOYSA-N;
MW          663.081;      // g/mol [origin=calculated method=formula-sum]
Tc          2075.31;      // K   [origin=predictive method=joback]
Pc          3.960;      // bar [origin=predictive method=joback]
omega       -0.4812;      // -   [origin=predictive method=lee-kesler]
Tb          1374.27;      // K   [origin=predictive method=joback]
HvapTb      139199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.018 4.08406 -0.0024416 5.509e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 30; } { group C; count 1; } { group CH=CH; count 2; } { group OH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 32; } { group C; count 1; } { group dCH; count 4; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-octadecenoic acid (9z)-, 2-ethyl-2-(hydroxymethyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -1471310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1893.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-291520.0
    phase     gas;
}
