/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromocholest-5-ene  (C27H45Br, CAS 516-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromocholest5Ene;
formula     C27H45Br;
CAS         516-91-6;
InChIKey    WDRGNJZPWVRVSN-UHFFFAOYSA-N;
MW          449.561;      // g/mol [origin=calculated method=formula-sum]
Tc          1154.90;      // K   [origin=predictive method=joback]
Pc          10.624;      // bar [origin=predictive method=joback]
omega       0.7743;      // -   [origin=predictive method=lee-kesler]
Tb          921.56;      // K   [origin=predictive method=joback]
HvapTb      79592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-303.487 3.5633 -0.00299084 1.0816e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene" "cholest-5-ene, 3-bromo-, (3.beta.)-" "cholesteryl bromide" "cholest-5-ene, 3-bromo-, (3beta)-" "3beta-bromo-5-cholestene" "3beta-bromocholest-5-ene" "cholest-5-ene, 3.beta.-bromo-" "(8s,9s,10r,13r,14s,17r)-3-bromo-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene" "3-bromo-10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene" );
gibbsFormation
{
    dHf_298   -308670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     946.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=354620.0
    phase     gas;
}
