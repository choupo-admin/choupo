/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-bis(2-methoxyethoxy)-3-methylbutane  (C11H24O4, CAS 71808-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Bis2Methoxyethoxy3Methylbutane;
formula     C11H24O4;
CAS         71808-62-3;
InChIKey    VUMJODFZOIYYSY-UHFFFAOYSA-N;
MW          220.309;      // g/mol [origin=calculated method=formula-sum]
Tc          707.68;      // K   [origin=predictive method=joback]
Pc          18.483;      // bar [origin=predictive method=joback]
omega       0.7764;      // -   [origin=predictive method=lee-kesler]
Tb          540.08;      // K   [origin=predictive method=joback]
HvapTb      48944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (91.525 0.80788 -0.000137 -1.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH3O; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(2-methoxyethoxy)-3-methyl-butane" "1,1-di(beta-methoxyethoxy)-3-methylbutane" "2,5,7,10-tetraoxaundecane, 6-(2-methylpropyl)-" "isovaleraldehyde, bis(2-methoxyethyl acetal)" "6-(2-methylpropyl)-2,5,7,10-tetraoxaundecane" );
gibbsFormation
{
    dHf_298   -809810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383140.0
    phase     gas;
}
