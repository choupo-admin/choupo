/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-tert-amylaniline  (C11H17N, CAS 2049-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pTertAmylaniline;
formula     C11H17N;
CAS         2049-92-5;
InChIKey    RQUPXQYTWVIBIV-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          779.31;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.5097;      // -   [origin=predictive method=lee-kesler]
Tb          552.24;      // K   [origin=predictive method=joback]
HvapTb      52363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.699 1.09816 -0.00075396 2.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-methylbutan-2-yl)aniline" "4-tert-amylaniline" "4-(tert-pentyl)aniline" "benzenamine,1-dimethylpropyl)-" "p-tert. amyl aniline" "benzenamine, 4-(1,1-dimethylpropyl)-" );
standardThermochemistry
{
    dHf_298   -20270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213810.0
}
