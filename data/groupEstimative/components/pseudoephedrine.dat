/*--------------------------------*- Choupo -*-----------------------*\
  Component: pseudoephedrine  (C10H15NO, CAS 90-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pseudoephedrine;
formula     C10H15NO;
CAS         90-82-4;
InChIKey    KWGRBVOPPLSCSI-WCBMZHEXSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          797.69;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.9683;      // -   [origin=predictive method=lee-kesler]
Tb          596.55;      // K   [origin=predictive method=joback]
HvapTb      62469.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.39 0.99694 -0.0006368 1.526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2s)-2-(methylamino)-1-phenyl-propan-1-ol" "d-pseudoephedrine" "sudafed" "d-isoephedrine" "(+)-pseudoephedrine" "trans-ephedrine" "psi-ephedrin" "besan" "psi-ephedrine" "d-psi-ephedrine" "(+)-psi-ephedrine" "(+)-threo-ephedrine" );
standardThermochemistry
{
    dHf_298   -122520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93420.0
}
