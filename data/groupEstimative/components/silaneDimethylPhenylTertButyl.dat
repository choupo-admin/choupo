/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, dimethyl-phenyl-(tert-butyl)-  (C12H20Si, CAS 90467-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneDimethylPhenylTertButyl;
formula     C12H20Si;
CAS         90467-12-2;
InChIKey    LHBSHRHABGHGRB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          192.377;      // g/mol [origin=calculated method=formula-sum]
Tc          718.72;      // K   [origin=predictive method=joback]
Pc          21.836;      // bar [origin=predictive method=joback]
omega       0.2968;      // -   [origin=predictive method=lee-kesler]
Tb          499.01;      // K   [origin=predictive method=joback]
HvapTb      43580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.58 0.9846 -0.0004172 1.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl-dimethyl-phenyl-silane" "tert-butyl-dimethyl-phenylsilane" );
gibbsFormation
{
    dHf_298   -174850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60650.0
    phase     gas;
}
