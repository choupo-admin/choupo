/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6,10-trimethyltetradecane  (C17H36, CAS 14905-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2610Trimethyltetradecane;
formula     C17H36;
CAS         14905-56-7;
InChIKey    IMTCMWSWXFQQDL-UHFFFAOYSA-N;
MW          240.475;      // g/mol [origin=calculated method=formula-sum]
Tc          753.19;      // K   [origin=predictive method=joback]
Pc          12.521;      // bar [origin=predictive method=joback]
omega       0.6918;      // -   [origin=predictive method=lee-kesler]
Tb          587.24;      // K   [origin=predictive method=joback]
HvapTb      52272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.611 1.6366 -0.0009106 1.896e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 9; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 9; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecane, 2,6,10-trimethyl-" "tetradecane,2,6,10-trimethyl-" );
standardThermochemistry
{
    dHf_298   -410050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     789.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84940.0
}
