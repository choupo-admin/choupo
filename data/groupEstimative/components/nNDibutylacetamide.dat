/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dibutylacetamide  (C10H21NO, CAS 1563-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDibutylacetamide;
formula     C10H21NO;
CAS         1563-90-2;
InChIKey    MEXKFCWMWJZDMF-UHFFFAOYSA-N;
MW          171.284;      // g/mol [origin=calculated method=formula-sum]
Tc          665.94;      // K   [origin=predictive method=joback]
Pc          22.313;      // bar [origin=predictive method=joback]
omega       0.6846;      // -   [origin=predictive method=lee-kesler]
Tb          494.71;      // K   [origin=predictive method=joback]
HvapTb      46643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.534 1.04976 -0.0006141 1.3616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dibutylethanamide" "acetamide, n,n-dibutyl-" "acetamide,n-dibutyl-" "mexkfcwmwjzdmf-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -294780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15180.0
}
