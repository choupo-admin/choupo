/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylaminoacetaldehyde dimethyl acetal  (C5H13NO2, CAS 122-07-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylaminoacetaldehydeDimethylAcetal;
formula     C5H13NO2;
CAS         122-07-6;
InChIKey    HUMIEJNVCICTPJ-UHFFFAOYSA-N;
MW          119.164;      // g/mol [origin=calculated method=formula-sum]
Tc          583.69;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.5276;      // -   [origin=predictive method=lee-kesler]
Tb          408.57;      // K   [origin=predictive method=joback]
HvapTb      37592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.451 0.43456 -7.8e-05 -5.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 2; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group O; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethoxy-n-methyl-ethanamine" "2,2-dimethoxy-n-methylethanamine" "ethanamine, 2,2-dimethoxy-n-methyl-" "acetaldehyde, (methylamino)-, dimethyl acetal" "2,2-dimethoxy-n-methylethylamine" "n-(2,2-dimethoxyethyl)methylamine" "2,2-dimethoxyethyl(methyl)amine" "(methylamino)acetaldehyde dimethyl acetal" "n-methylaminoacetaldehyde dimethyl acetal" "2-(methylamino)acetaldehyde dimethyl acetal" "2,2-dimethoxyethylmethylamine" "humiejnvcictpj-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -362780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-131830.0
}
