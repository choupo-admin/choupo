/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropene, 1,2-dimethyl-3-phenyl-  (C11H12, CAS 23063-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropene12Dimethyl3Phenyl;
formula     C11H12;
CAS         23063-31-2;
InChIKey    ASCFKFSNSITADI-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          717.24;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.3986;      // -   [origin=predictive method=lee-kesler]
Tb          493.82;      // K   [origin=predictive method=joback]
HvapTb      43885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.88 0.94584 -0.0006792 1.989e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3-dimethylcycloprop-2-en-1-yl)benzene" "cyclopropene,1,2-dimethyl-3-phenyl-" "1-cyclopropene, 1,2-dimethyl-3-phenyl-" );
gibbsFormation
{
    dHf_298   73800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225600.0
    phase     gas;
}
