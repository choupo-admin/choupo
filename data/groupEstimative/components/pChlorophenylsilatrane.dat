/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-chlorophenylsilatrane  (C12H16ClNO3Si, CAS 29025-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H16ClNO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pChlorophenylsilatrane;
formula     C12H16ClNO3Si;
CAS         29025-67-0;
InChIKey    IKFVTMCLFHXPQF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          285.799;      // g/mol [origin=calculated method=formula-sum]
Tc          930.08;      // K   [origin=predictive method=joback]
Pc          29.569;      // bar [origin=predictive method=joback]
omega       0.6615;      // -   [origin=predictive method=lee-kesler]
Tb          673.57;      // K   [origin=predictive method=joback]
HvapTb      66456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.37 1.2469 -0.00068166 1.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 3; } { group CH2N; count 1; } { group ACCl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(4-chlorophenyl)-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "1-(p-chlorophenyl)silatrane" "silatrane, p-chlorophenyl-" "5-(4-chlorophenyl)silatrane" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 1-(p-chlorophenyl)-" "1-(p-chlorophenyl)-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "2,8,9-trioxa-5-aza-1-sila-1-(p-chlorophenyl)bicyclo(3.3.3)undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-(p-chlorophenyl)-" "1-(4-chlorophenyl)silatrane" "p-chlorfenylsilatran" "1-(p-chlorophenyl)-2,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-(4-chlorophenyl)-" );
gibbsFormation
{
    dHf_298   -353980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10710.0
    phase     gas;
}
