/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(4-hydroxycyclohexyl)propane dimethacrylate  (C23H36O4, CAS 39664-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis4HydroxycyclohexylPropaneDimethacrylate;
formula     C23H36O4;
CAS         39664-33-0;
InChIKey    RIVWLNPMWPTCEP-UHFFFAOYSA-N;
MW          376.537;      // g/mol [origin=calculated method=formula-sum]
Tc          1084.48;      // K   [origin=predictive method=joback]
Pc          11.421;      // bar [origin=predictive method=joback]
omega       0.7936;      // -   [origin=predictive method=lee-kesler]
Tb          861.93;      // K   [origin=predictive method=joback]
HvapTb      79370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.37 2.35608 -0.0013116 2.214e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 4; } { group C; count 1; } { group CH2=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[2-[4-(2-methylprop-2-enoyloxy)cyclohexyl]propan-2-yl]cyclohexyl] 2-methylprop-2-enoate" "propane-2,2-diyldicyclohexane-4,1-diyl bis(2-methylprop-2-enoate)" "2-propenoic acid, 2-methyl-, 1,1'-((1-methylethylidene)di-4,1-cyclohexanediyl) ester" "2-propenoic acid, 2-methyl-, 1,1'-[(1-methylethylidene)di-4,1-cyclohexanediyl] ester" "hydrogenated bisphenol a dimethacrylate" "(1-methylethylidene)di-4,1-cyclohexanediyl bismethacrylate" "2-propenoic acid, 2-methyl-, (1-methylethylidene)di-4,1-cyclohexanediyl ester" );
gibbsFormation
{
    dHf_298   -862120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     952.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-283060.0
    phase     gas;
}
