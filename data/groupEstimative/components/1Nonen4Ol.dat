/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonen-4-ol  (C9H18O, CAS 35192-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonen4Ol;
formula     C9H18O;
CAS         35192-73-5;
InChIKey    NDUPBTSXOSZHON-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          658.92;      // K   [origin=predictive method=joback]
Pc          26.570;      // bar [origin=predictive method=joback]
omega       0.8524;      // -   [origin=predictive method=lee-kesler]
Tb          493.94;      // K   [origin=predictive method=joback]
HvapTb      51249.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.675 0.87872 -0.0005223 1.226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-1-en-4-ol" "1-nonen-4-ol, (4s)-" "allyl n-pentyl carbinol" );
standardThermochemistry
{
    dHf_298   -261170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26520.0
}
