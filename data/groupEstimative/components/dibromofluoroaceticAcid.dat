/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromofluoroacetic acid  (C2HBr2FO2, CAS 353-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromofluoroaceticAcid;
formula     C2HBr2FO2;
CAS         353-99-1;
InChIKey    NWIYDZBYJAJLNC-UHFFFAOYSA-N;
MW          235.834;      // g/mol [origin=calculated method=formula-sum]
Tc          754.78;      // K   [origin=predictive method=joback]
Pc          68.414;      // bar [origin=predictive method=joback]
omega       0.7206;      // -   [origin=predictive method=lee-kesler]
Tb          519.23;      // K   [origin=predictive method=joback]
HvapTb      47967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.67 0.4586 -0.0004886 1.863e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group Br; count 2; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group F; count 1; } { group Br; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(bromanyl)-2-fluoranyl-ethanoic acid" "dibromo(fluoro)acetic acid" "2,2-dibromo-2-fluoroacetic acid" "snpljqbkdtadtaetp@" "acetic acid,2,2-dibromo-2-fluoro-" "aceticacid, dibromofluoro- (7ci,8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -587080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-541280.0
}
