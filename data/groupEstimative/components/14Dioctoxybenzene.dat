/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioctoxybenzene  (C22H38O2, CAS 67399-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dioctoxybenzene;
formula     C22H38O2;
CAS         67399-94-4;
InChIKey    KFQGWEDSKAPIDJ-UHFFFAOYSA-N;
MW          334.544;      // g/mol [origin=calculated method=formula-sum]
Tc          964.87;      // K   [origin=predictive method=joback]
Pc          10.764;      // bar [origin=predictive method=joback]
omega       0.9097;      // -   [origin=predictive method=lee-kesler]
Tb          779.46;      // K   [origin=predictive method=joback]
HvapTb      72324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.284 1.82904 -0.00091516 1.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-di(octyloxy)benzene" );
standardThermochemistry
{
    dHf_298   -536790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     922.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27140.0
}
