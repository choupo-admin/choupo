/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-ditert-butyl-6-(1-phenylethyl)phenol  (C22H30O, CAS 63428-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DitertButyl61PhenylethylPhenol;
formula     C22H30O;
CAS         63428-98-8;
InChIKey    XOVCWYXPFJNQLU-UHFFFAOYSA-N;
MW          310.481;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.97;      // K   [origin=predictive method=joback]
Pc          15.962;      // bar [origin=predictive method=joback]
omega       0.8247;      // -   [origin=predictive method=lee-kesler]
Tb          840.00;      // K   [origin=predictive method=joback]
HvapTb      80476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.87 2.22924 -0.00170448 5.282e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group C; count 2; } { group ACH; count 7; } { group AC; count 3; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 1; } { group C; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 2,4-bis(1,1-dimethylethyl)-6-(1-phenylethyl)-" "4,6-di-t-butyl-2-alpha-methylbenzylphenol" "2,4-di-tert-butyl-6-(1-phenylethyl)phenol" "2,4-di-tert-butyl-6-(alpha-methylbenzyl)phenol" "2,4-bis(1,1-dimethylethyl)-6-(1-phenylethyl)phenol" "2,4-bis(1,1-dimethylethyl)-6-(1-phenyl ethyl)phenol" "2,4-di-tert-butyl-6-(1-phenylethyl)phenol, 4a" "2,4-di-tert-butyl-6-(.alpha.-methylbenzyl)phenol" "phenol,4-bis(1,1-dimethylethyl)-6-(1-phenylethyl)-" );
standardThermochemistry
{
    dHf_298   -247380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     726.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188540.0
}
