/*--------------------------------*- Choupo -*-----------------------*\
  Component: morphinan-3-ol, 17-(p-aminophenethyl)-, (-)-  (C24H30N2O, CAS 63307-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morphinan3Ol17PAminophenethyl;
formula     C24H30N2O;
CAS         63307-29-9;
InChIKey    ZRCMOECJOLTRBV-QPTUXGOLSA-N;
MW          362.517;      // g/mol [origin=calculated method=formula-sum]
Tc          1262.89;      // K   [origin=predictive method=joback]
Pc          20.181;      // bar [origin=predictive method=joback]
omega       1.2216;      // -   [origin=predictive method=lee-kesler]
Tb          1002.36;      // K   [origin=predictive method=joback]
HvapTb      99352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-277.098 3.0824 -0.00276928 1.0231e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group ACH; count 7; } { group AC; count 1; } { group ACCH2; count 2; } { group ACOH; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(-)-17-(p-aminophenethyl)morphinan-3-ol" );
gibbsFormation
{
    dHf_298   62920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     778.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=544030.0
    phase     gas;
}
