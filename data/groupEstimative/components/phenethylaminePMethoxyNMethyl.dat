/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethylamine, p-methoxy-n-methyl-  (C10H15NO, CAS 4091-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenethylaminePMethoxyNMethyl;
formula     C10H15NO;
CAS         4091-50-3;
InChIKey    JCMWSVNNSPUNER-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          738.31;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.6228;      // -   [origin=predictive method=lee-kesler]
Tb          532.65;      // K   [origin=predictive method=joback]
HvapTb      49638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.518 0.82844 -0.00042196 6.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methoxyphenyl)-n-methyl-ethanamine" "p-methoxy-n-methylphenethylamine" "n-methyl 4-methoxyphenethylamine" "4-methoxy-n-methylbenzeneethanamine" "n-(p-methoxyphenethyl)methylamine" "2-(4-methoxyphenyl)-n-methylethanamine" "n-[2-(4-methoxyphenyl)ethyl]-n-methylamine" "benzeneethanamine, 4-methoxy-n-methyl-" "[2-(4-methoxy-phenyl)-ethyl]-methyl-amine" "n-methyl-p-methoxyphenethylamine" "4-methoxy-n-methylphenethylamine" "n-(4-methoxyphenethyl)methylamine" );
gibbsFormation
{
    dHf_298   -103420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120490.0
    phase     gas;
}
