/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(trimethoxysilyl)propyl methacrylate  (C10H20O5Si, CAS 2530-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H20O5Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3TrimethoxysilylPropylMethacrylate;
formula     C10H20O5Si;
CAS         2530-85-0;
InChIKey    XDLMVUHYZWKMMD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.35;      // g/mol [origin=calculated method=formula-sum]
Tc          730.57;      // K   [origin=predictive method=joback]
Pc          18.953;      // bar [origin=predictive method=joback]
omega       0.7114;      // -   [origin=predictive method=lee-kesler]
Tb          551.84;      // K   [origin=predictive method=joback]
HvapTb      52195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (133.843 0.48318 0.000297 -3.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=C; count 1; } { group CH3O; count 3; } { group COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-trimethoxysilylpropyl 2-methylprop-2-enoate" "dynasylan memo" "3-methacryloxypropyltrimethoxysilane" "mops-m" "2-propenoic acid, 2-methyl-, 3-(trimethoxysilyl)propyl ester" "methacrylic acid, 3-(trimethoxysilyl)propyl ester" "methacryloxypropyltrimethoxysilane" "methacryloyloxypropyltrimethoxysilane" "silane, 3-methacryloxypropyltrimethoxy-" "trimethoxysilylpropyl methacrylate" "silane adduct, allyl methacrylate trimethoxy-" "3-trimethoxysilylpropyl methacrylate" );
gibbsFormation
{
    dHf_298   -959650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-617520.0
    phase     gas;
}
