/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,5-bis(trifluoromethyl)benzoate  (C10H6F6O2, CAS 26107-80-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl35BisTrifluoromethylBenzoate;
formula     C10H6F6O2;
CAS         26107-80-2;
InChIKey    LTYNBDAJUXZFHP-UHFFFAOYSA-N;
MW          272.144;      // g/mol [origin=calculated method=formula-sum]
Tc          690.23;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       0.6868;      // -   [origin=predictive method=lee-kesler]
Tb          512.42;      // K   [origin=predictive method=joback]
HvapTb      41367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.5 1.02352 -0.00076472 2.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CF3; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl3,5-bis(trifluoromethyl)benzoate" "methyl 3,5-di(trifluoromethyl)benzoate radical" "buttpark 89\07-68" "methyl 3,5-dicf3-benzoate radical" "methyl 3,5-bistrifluoromethylbenzoate" "methyl 3,5-di(trifluoromethyl)benzoate" "3,5-bis-trifluoromethyl-benzoic acid methyl ester" "benzoic acid,3,5-bis(trifluoromethyl)-, methyl ester" "3,5-bis(trifluoromethyl)benzoic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -1547580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1347080.0
}
