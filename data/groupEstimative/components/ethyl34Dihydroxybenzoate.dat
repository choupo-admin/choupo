/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3,4-dihydroxybenzoate  (C9H10O4, CAS 3943-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl34Dihydroxybenzoate;
formula     C9H10O4;
CAS         3943-89-3;
InChIKey    KBPUBCVJHFXPOC-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          886.53;      // K   [origin=predictive method=joback]
Pc          47.694;      // bar [origin=predictive method=joback]
omega       1.0181;      // -   [origin=predictive method=lee-kesler]
Tb          651.66;      // K   [origin=predictive method=joback]
HvapTb      71339.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.629 1.03432 -0.00091512 3.305e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,4-bis(oxidanyl)benzoate" "ethyl protocatechuate" "3,4-dihydroxybenzoic acid ethyl ester" "ethyl-3,4-dihydroxybenzoate" "protocatechuic acid ethyl ester" "3,4-dihydroxybenzoicacidethylester" "edhb" "3,4-dhbeeop" "protocatechuic acid, ethyl ester" "3,4-dihydroxy-benzoic acid ethyl ester" "benzoic acid,4-dihydroxy-, ethyl ester" "ethyl ester of 3,4-dihydroxybenzoic acid" );
gibbsFormation
{
    dHf_298   -664460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-482300.0
    phase     gas;
}
