/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethyltetracyclo(2.2.0(2,6).0(3,5))hexane  (C12H18, CAS 14551-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethyltetracyclo22026035Hexane;
formula     C12H18;
CAS         14551-30-5;
InChIKey    VOPARGKYDVBSNG-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          689.78;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.3342;      // -   [origin=predictive method=lee-kesler]
Tb          467.60;      // K   [origin=predictive method=joback]
HvapTb      33402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-466.33 3.50352 -0.004873 2.4398e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6-hexamethylprismane" "hexamethyltetracyclo[2.2.0(2,6).0(3,5)]hexane" );
gibbsFormation
{
    dHf_298   87910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=317400.0
    phase     gas;
}
