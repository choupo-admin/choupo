/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopromedol  (C17H25NO2, CAS 64-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopromedol;
formula     C17H25NO2;
CAS         64-39-1;
InChIKey    UVITTYOJFDLOGI-LICQEQMYSA-N;
MW          275.392;      // g/mol [origin=calculated method=formula-sum]
Tc          910.61;      // K   [origin=predictive method=joback]
Pc          18.000;      // bar [origin=predictive method=joback]
omega       0.7270;      // -   [origin=predictive method=lee-kesler]
Tb          692.08;      // K   [origin=predictive method=joback]
HvapTb      63650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.349 1.97968 -0.0014994 4.78e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2s,5r)-1,2,5-trimethyl-4-phenyl-piperidin-4-yl] propanoate" "trimeperidine" "trimeperidinum [inn-latin]" "promedol" "trimeperidine [inn:ban:dcf]" "(2s,5r)-1,2,5-trimethyl-4-phenylpiperidin-4-yl propanoate" "1,2,5-trimethyl-4-phenyl-4-propionoxypiperidine" "1,2,5-trimethyl-4-phenyl-4-propionyloxypiperidine" "4-piperidinol, 4-phenyl-1,2,5-trimethyl-, propionate" "1,2,5-trimethyl-4-phenyl-4-piperidinol, propionate (ester)" "4-piperidinol, 1,2,5-trimethyl-4-phenyl-, propanoate (ester)" "4-piperidinol, 1,2,5-trimethyl-4-phenyl-, propionate (ester)" );
standardThermochemistry
{
    dHf_298   -372390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20720.0
}
