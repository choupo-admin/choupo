/*--------------------------------*- Choupo -*-----------------------*\
  Component: tiglyl tiglate  (C10H16O2, CAS 72845-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tiglylTiglate;
formula     C10H16O2;
CAS         72845-40-0;
InChIKey    QJXVZKLQKPUDPW-XVYDYJIPSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          686.35;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       0.5204;      // -   [origin=predictive method=lee-kesler]
Tb          494.70;      // K   [origin=predictive method=joback]
HvapTb      45337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.539 0.93888 -0.0005978 1.491e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH=C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 2; } { group dC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-2-methylbut-2-enyl] (e)-2-methylbut-2-enoate" "2-butenoic acid, 2-methyl-, 2-methyl-2-butenyl ester" "2-butenoic acid, 2-methyl-, 2-methyl-2-buten-1-yl ester" "2-butenoic acid, 2-methyl-, (2e)-2-methyl-2-buten-1-yl ester, (2e)-" "2-butenoic acid, 2-methyl-, (2e)-2-methyl-2-butenyl ester, (2e)-" "2-methyl-2-butenyl 2-methylcrotonate" "(e)-2-methylcrotonic acid (e)-2-methyl-2-butenyl ester" );
standardThermochemistry
{
    dHf_298   -352150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133710.0
}
