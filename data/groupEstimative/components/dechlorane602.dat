/*--------------------------------*- Choupo -*-----------------------*\
  Component: dechlorane 602  (C14H4Cl12O, CAS 31107-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dechlorane602;
formula     C14H4Cl12O;
CAS         31107-44-5;
InChIKey    CDBKZZACXQLFMK-UHFFFAOYSA-N;
MW          613.585;      // g/mol [origin=calculated method=formula-sum]
Tc          1331.91;      // K   [origin=predictive method=joback]
Pc          19.788;      // bar [origin=predictive method=joback]
omega       0.9009;      // -   [origin=predictive method=lee-kesler]
Tb          1026.06;      // K   [origin=predictive method=joback]
HvapTb      98234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-286.53 3.4358 -0.0046947 2.307e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group CH-O; count 1; } { group CCl2; count 2; } { group Cl_C=C_; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:4
    joback ( { group CH_ring; count 4; } { group C_ring; count 6; } { group dC_ring; count 4; } { group Cl; count 12; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,6,7,8,9,10,10,11,11-dodecachloro-1,4,4a,5a,6,9,9a,9b-octahydro-1,4:6,9-dimethanodibenzofuran" "1,4:6,9-dimethanodibenzofuran, 1,2,3,4,6,7,8,9,10,10,11,11-dodecachloro-1,4,4a,5a,6,9,9a,9b-octahydro-" "1,2,3,4,6,7,8,9,10,10,11,11-dodecachloro-1,4,4a'a" "afa,5a'a" "afa,6,9,9a'a" "afa,9a'a" "afas-octahydro-1,4:6,9-dimethanodibenzofuran;dechlorane 602;" );
gibbsFormation
{
    dHf_298   -229750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     705.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91380.0
    phase     gas;
}
