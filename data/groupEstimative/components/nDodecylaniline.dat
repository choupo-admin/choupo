/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-dodecylaniline  (C18H31N, CAS 3007-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nDodecylaniline;
formula     C18H31N;
CAS         3007-74-7;
InChIKey    LQKYCMRSWKQVBQ-UHFFFAOYSA-N;
MW          261.453;      // g/mol [origin=calculated method=formula-sum]
Tc          875.76;      // K   [origin=predictive method=joback]
Pc          14.770;      // bar [origin=predictive method=joback]
omega       0.8819;      // -   [origin=predictive method=lee-kesler]
Tb          688.29;      // K   [origin=predictive method=joback]
HvapTb      64374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.589 1.71112 -0.0010352 2.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenamine, n-dodecyl-" "n-n-dodecylaniline" "n-dodecyl-n-phenylamine" "dodecylphenylamine" "lqkycmrswkqvbq-uhfffaoysa-" "u769" "dodecylamine,n-phenyl- (6ci,7ci,8ci); 4-(n-dodecyl)phenylamine; n-dodecylaminobenzene;n-dodecylaniline; n-dodecylbenzenamine" );
gibbsFormation
{
    dHf_298   -124850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=302480.0
    phase     gas;
}
