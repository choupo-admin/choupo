/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]heptane, 2-ethylidene-1,7,7-trimethyl-, (e)-  (C12H20, CAS 62413-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Heptane2Ethylidene177TrimethylE;
formula     C12H20;
CAS         62413-60-9;
InChIKey    CXSZQFQLQRAPTP-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          710.80;      // K   [origin=predictive method=joback]
Pc          25.025;      // bar [origin=predictive method=joback]
omega       0.3620;      // -   [origin=predictive method=lee-kesler]
Tb          494.36;      // K   [origin=predictive method=joback]
HvapTb      40480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-196.57 1.91588 -0.0020013 8.69e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethylidene-4,7,7-trimethyl-bicyclo[2.2.1]heptane" "(2e)-2-ethylidene-1,7,7-trimethylbicyclo[2.2.1]heptane" "2-ethylidene-1,7,7-trimethylbicyclo(2.2.1)heptane" "2-ethylidene-1,7,7-trimethylbicyclo[2.2.1]heptane" "3-ethylidene-4,7,7-trimethylbicyclo[2.2.1]heptane" "(3z)-3-ethylidene-4,7,7-trimethylbicyclo[2.2.1]heptane" );
gibbsFormation
{
    dHf_298   -65400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186330.0
    phase     gas;
}
