/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-phenylethenyl)pyridine, (e)-  (C13H11N, CAS 2633-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32PhenylethenylPyridineE;
formula     C13H11N;
CAS         2633-06-9;
InChIKey    RMSGACVDMOLUPL-UHFFFAOYSA-N;
MW          181.238;      // g/mol [origin=calculated method=formula-sum]
Tc          872.40;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.4869;      // -   [origin=predictive method=lee-kesler]
Tb          608.26;      // K   [origin=predictive method=joback]
HvapTb      55252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.86 1.13476 -0.00083886 2.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-phenylethenyl)pyridine" "pyridine,3-(2-phenylethenyl)-" "3-stilbazole(6ci); pyridine, 3-styryl- (7ci,8ci); 1-phenyl-2-(3'-pyridyl)-ethylene;3-styrylpyridine; b-(3-pyridyl)styrene" );
standardThermochemistry
{
    dHf_298   311420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=440670.0
}
