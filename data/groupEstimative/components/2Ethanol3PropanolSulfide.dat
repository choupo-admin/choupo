/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethanol 3-propanol sulfide  (C5H12O2S, CAS 5323-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethanol3PropanolSulfide;
formula     C5H12O2S;
CAS         5323-60-4;
InChIKey    YJGRQEWXDDCCCV-UHFFFAOYSA-N;
MW          136.209;      // g/mol [origin=calculated method=formula-sum]
Tc          741.49;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       1.3597;      // -   [origin=predictive method=lee-kesler]
Tb          567.14;      // K   [origin=predictive method=joback]
HvapTb      66899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.525 0.54119 -0.0002688 4.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group OH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-hydroxyethylsulfanyl)propan-1-ol" "1-propanol, 3-[(2-hydroxyethyl)thio]-" "3-[(2-hydroxyethyl)sulfanyl]propan-1-ol" "3-[(2-hydroxyethyl)thio]-1-propanol" );
standardThermochemistry
{
    dHf_298   -409120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-249300.0
}
