/*--------------------------------*- Choupo -*-----------------------*\
  Component: (trimethylsilyl)acetonitrile  (C5H11NSi, CAS 18293-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H11NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylAcetonitrile;
formula     C5H11NSi;
CAS         18293-53-3;
InChIKey    WJKMUGYQMMXILX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          113.235;      // g/mol [origin=calculated method=formula-sum]
Tc          615.17;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.3190;      // -   [origin=predictive method=lee-kesler]
Tb          417.48;      // K   [origin=predictive method=joback]
HvapTb      37496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.161 0.20746 0.0001976 -1.752e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2CN; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-trimethylsilylethanenitrile" "tmsan" "(cyanomethyl)trimethylsilane" "2-trimethylsilylacetonitrile" "trimethylsilylacetonitrile" "acetonitrile,2-(trimethylsilyl)-" );
standardThermochemistry
{
    dHf_298   -93270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19640.0
}
