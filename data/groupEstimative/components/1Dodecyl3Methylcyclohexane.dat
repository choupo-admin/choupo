/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dodecyl-3-methylcyclohexane  (C19H38, CAS 5452-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dodecyl3Methylcyclohexane;
formula     C19H38;
CAS         5452-29-9;
InChIKey    IBPYRQACWYCFPT-UHFFFAOYSA-N;
MW          266.513;      // g/mol [origin=calculated method=formula-sum]
Tc          828.40;      // K   [origin=predictive method=joback]
Pc          12.140;      // bar [origin=predictive method=joback]
omega       0.7129;      // -   [origin=predictive method=lee-kesler]
Tb          649.20;      // K   [origin=predictive method=joback]
HvapTb      58008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.049 1.90444 -0.0010354 1.963e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-dodecyl-3-methyl-cyclohexane" "cyclohexane, 1-dodecyl-3-methyl-" );
standardThermochemistry
{
    dHf_298   -401510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     823.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125840.0
}
