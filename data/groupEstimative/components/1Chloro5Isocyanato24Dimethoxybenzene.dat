/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-5-isocyanato-2,4-dimethoxybenzene  (C9H8ClNO3, CAS 55440-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro5Isocyanato24Dimethoxybenzene;
formula     C9H8ClNO3;
CAS         55440-55-6;
InChIKey    COSVEXSXJCUYOT-UHFFFAOYSA-N;
MW          213.617;      // g/mol [origin=calculated method=formula-sum]
Tc          816.27;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.7431;      // -   [origin=predictive method=lee-kesler]
Tb          596.08;      // K   [origin=predictive method=joback]
HvapTb      58627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group CH3O; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 2; } { group dCd; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-5-isocyanato-2,4-dimethoxy-benzene" "5-chloro-2,4-dimethoxyphenyl isocyanate" "5-chloro-2,4-dimethoxybenzenisocyanate" "benzene, 1-chloro-5-isocyanato-2,4-dimethoxy-" );
