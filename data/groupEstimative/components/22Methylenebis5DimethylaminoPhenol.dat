/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-methylenebis[5-(dimethylamino)phenol]  (C17H22N2O2, CAS 63468-95-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Methylenebis5DimethylaminoPhenol;
formula     C17H22N2O2;
CAS         63468-95-1;
InChIKey    CFEFGULMFHEIBY-UHFFFAOYSA-N;
MW          286.375;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.60;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       1.2466;      // -   [origin=predictive method=lee-kesler]
Tb          838.00;      // K   [origin=predictive method=joback]
HvapTb      89426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.999 1.89908 -0.00156724 5.333e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(dimethylamino)-2-[[4-(dimethylamino)-2-oxidanyl-phenyl]methyl]phenol" "phenol, 2,2'-methylenebis(5-(dimethylamino)-" "phenol, 2,2'-methylenebis[5-(dimethylamino)-" "5-(dimethylamino)-2-[4-(dimethylamino)-2-hydroxybenzyl]phenol" "5-(dimethylamino)-2-[[4-(dimethylamino)-2-hydroxyphenyl]methyl]phenol" );
gibbsFormation
{
    dHf_298   -163650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210140.0
    phase     gas;
}
