/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-hydroxypentanoate  (C7H14O3, CAS 54074-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Hydroxypentanoate;
formula     C7H14O3;
CAS         54074-85-0;
InChIKey    YESYELHMPYCIAQ-UHFFFAOYSA-N;
MW          146.186;      // g/mol [origin=calculated method=formula-sum]
Tc          679.88;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.9507;      // -   [origin=predictive method=lee-kesler]
Tb          509.72;      // K   [origin=predictive method=joback]
HvapTb      54874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.543 0.65394 -0.000296 2.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylpentanoate" "pentanoic acid, 3-hydroxy-, ethyl ester" "ethyl 3-hydroxyvalerate" );
gibbsFormation
{
    dHf_298   -662600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-441570.0
    phase     gas;
}
