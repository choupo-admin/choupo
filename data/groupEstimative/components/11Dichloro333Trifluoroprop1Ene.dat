/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloro-3,3,3-trifluoroprop-1-ene  (C3HCl2F3, CAS 460-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloro333Trifluoroprop1Ene;
formula     C3HCl2F3;
CAS         460-70-8;
InChIKey    ISCYUDAHBJMFNT-UHFFFAOYSA-N;
MW          164.935;      // g/mol [origin=calculated method=formula-sum]
Tc          518.33;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.2883;      // -   [origin=predictive method=lee-kesler]
Tb          341.72;      // K   [origin=predictive method=joback]
HvapTb      27333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.87 0.4835 -0.0004873 1.804e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group Cl_C=C_; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } { group F; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)-3,3,3-tris(fluoranyl)prop-1-ene" "1-propene, 1,1-dichloro-3,3,3-trifluoro-" "1,1-dichloro-3,3,3-trifluoropropene" );
standardThermochemistry
{
    dHf_298   -626380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-559400.0
}
