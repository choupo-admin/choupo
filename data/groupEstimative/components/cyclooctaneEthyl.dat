/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctane, ethyl-  (C10H20, CAS 13152-02-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctaneEthyl;
formula     C10H20;
CAS         13152-02-8;
InChIKey    FBGUQAGGWLRXTP-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          669.44;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.3062;      // -   [origin=predictive method=lee-kesler]
Tb          456.49;      // K   [origin=predictive method=joback]
HvapTb      38627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.049 1.05672 -0.0005084 5.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethylcyclooctane" );
standardThermochemistry
{
    dHf_298   -207730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33570.0
}
