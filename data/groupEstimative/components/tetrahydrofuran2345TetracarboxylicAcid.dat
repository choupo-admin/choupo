/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrofuran-2,3,4,5-tetracarboxylic acid  (C8H8O9, CAS 26106-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrofuran2345TetracarboxylicAcid;
formula     C8H8O9;
CAS         26106-63-8;
InChIKey    UFOIOXZLTXNHQH-UHFFFAOYSA-N;
MW          248.143;      // g/mol [origin=calculated method=formula-sum]
Tc          1233.03;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       2.0009;      // -   [origin=predictive method=lee-kesler]
Tb          992.90;      // K   [origin=predictive method=joback]
HvapTb      105898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.33 1.0162 -0.0006491 1.422e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group CH-O; count 1; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group O_ring; count 1; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxolane-2,3,4,5-tetracarboxylic acid" "2,5-anhydro-3,4-dicarboxy-3,4-dideoxyhexaric acid" "agn-pc-00hrda" "furantetracarboxylic acid, tetrahydro-" "2,3,4,5-furantetracarboxylicacid, tetrahydro-" "tetrahydrofuran-2,3,4,5-tetracarboxylic acid, mixed isomers" );
gibbsFormation
{
    dHf_298   -1742070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1431860.0
    phase     gas;
}
