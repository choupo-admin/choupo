/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromobutane-1,4-diol  (C4H8Br2O2, CAS 1947-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dibromobutane14Diol;
formula     C4H8Br2O2;
CAS         1947-58-6;
InChIKey    OXYNQEOLHRWEPE-UHFFFAOYSA-N;
MW          247.914;      // g/mol [origin=calculated method=formula-sum]
Tc          797.96;      // K   [origin=predictive method=joback]
Pc          62.590;      // bar [origin=predictive method=joback]
omega       1.5105;      // -   [origin=predictive method=lee-kesler]
Tb          606.92;      // K   [origin=predictive method=joback]
HvapTb      69950.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.852 0.54 -0.0004038 1.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group OH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group Br; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)butane-1,4-diol" "2,3-dibromo-1,4-butanediol" "dl-2,3-dibromo-1,4-butanediol" "1,4-butanediol, d,l-2,3-dibromo-" "(r*,r*)-(1)-2,3-dibromobutane-1,4-diol" "1,4-butanediol, 2,3-dibromo-, (+,-)-" "1,4-butanediol, 2,3-dibromo-, (r*,r*)-(.+/-.)-" "1,4-butanediol, 2,3-dibromo-" "l028" "1,4-butanediol,2,3-dibromo-, (2r,3r)-rel-" "( inverted exclamation marka)-2,3-dibromo-1,4-butanediol" "1,4-butanediol,2,3-dibromo-, (r*,r*)- (9ci);2,3-dibromo-2,3-dideoxy-dl-threitol;rac-2,3-dibromobutane-1,4-diol;" );
standardThermochemistry
{
    dHf_298   -388250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267080.0
}
