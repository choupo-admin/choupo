  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentacyclo1822291204150617Hexacosa46179111520222325Nonane;
formula     C26H26;
CAS         35117-21-6;
InChIKey    REXZNBNRGIQZSK-UHFFFAOYSA-N;
MW          338.494;      // g/mol [origin=calculated method=formula-sum]
Tc          1202.05;      // K   [origin=predictive method=joback]
Pc          17.075;      // bar [origin=predictive method=joback]
omega       0.8476;      // -   [origin=predictive method=lee-kesler]
Tb          930.78;      // K   [origin=predictive method=joback]
HvapTb      84396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-173.57 2.2752 -0.0016074 4.454e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH2; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dCH_ring; count 10; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentacyclo[18.2.2.2(9,12).0(4,15).0(6,17)]hexacosa-4,6(17),9,11,15,20,22,23,25-nonane" "pentacyclo[19.2.2.19,13.04,16.06,18]hexacosa-1(23),4(16),5,9(26),10,12,17,21,24-nonaene" );
gibbsFormation
{
    dHf_298   246230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=569840.0
    phase     gas;
}
