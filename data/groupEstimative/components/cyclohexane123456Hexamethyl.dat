/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, 1,2,3,4,5,6-hexamethyl  (C12H24, CAS 1795-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane123456Hexamethyl;
formula     C12H24;
CAS         1795-13-7;
InChIKey    CRZVDNMIWUHMQA-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          661.20;      // K   [origin=predictive method=joback]
Pc          18.420;      // bar [origin=predictive method=joback]
omega       0.3331;      // -   [origin=predictive method=lee-kesler]
Tb          470.36;      // K   [origin=predictive method=joback]
HvapTb      41190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.93 1.13352 -0.000433 2e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6-hexamethylcyclohexane" "cyclohexane, 1,2,3,4,5,6-hexamethyl-" );
gibbsFormation
{
    dHf_298   -338390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36060.0
    phase     gas;
}
