/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-diacetylresorcinol  (C10H10O4, CAS 2161-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Diacetylresorcinol;
formula     C10H10O4;
CAS         2161-85-5;
InChIKey    GEYCQLIOGQPPFM-UHFFFAOYSA-N;
MW          194.186;      // g/mol [origin=calculated method=formula-sum]
Tc          970.87;      // K   [origin=predictive method=joback]
Pc          48.360;      // bar [origin=predictive method=joback]
omega       1.2182;      // -   [origin=predictive method=lee-kesler]
Tb          729.04;      // K   [origin=predictive method=joback]
HvapTb      80312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.93 1.06864 -0.00095968 3.5652e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 2; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[5-ethanoyl-2,4-bis(oxidanyl)phenyl]ethanone" "1-(5-acetyl-2,4-dihydroxyphenyl)ethan-1-one" "1-(5-acetyl-2,4-dihydroxyphenyl)ethanone" "1,1'-(4,6-dihydroxy-1,3-phenylene)bisethanone" "ethanone, 1,1'-(4,6-dihydroxy-1,3-phenylene)bis-" "1,3-diacetyl-4,6-dihydroxybenzene" "resodiacetophenone" "4',6'-diacetylresorcinol" "4,6-diacetyl-1,3-benzenediol" "1,1'-(4,6-dihydroxybenzene-1,3-diyl)diethanone" "1,1'-(4,6-dihydroxy-1,3-phenylene)-bis-ethanone" "ethanone,1,1'-(4,6-dihydroxy-1,3-phenylene)bis-" );
standardThermochemistry
{
    dHf_298   -604450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-430980.0
}
