/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[1.1.0]butane  (C4H6, CAS 157-33-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo110Butane;
formula     C4H6;
CAS         157-33-5;
InChIKey    LASLVGACQUUOEB-UHFFFAOYSA-N;
MW          54.092;      // g/mol [origin=calculated method=formula-sum]
Tc          473.79;      // K   [origin=predictive method=joback]
Pc          51.609;      // bar [origin=predictive method=joback]
omega       0.2054;      // -   [origin=predictive method=lee-kesler]
Tb          296.06;      // K   [origin=predictive method=joback]
HvapTb      23980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.99 0.7048 -0.000727 2.948e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[1,0,1]butan" "bicyclo(1.1.0)butane" "bicyclo[1.1.0]butan" "bicyclobutadiene;bicyclobutane" );
gibbsFormation
{
    dHf_298   32030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     91.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128500.0
    phase     gas;
}
