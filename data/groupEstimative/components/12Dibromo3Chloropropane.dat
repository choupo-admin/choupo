/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromo-3-chloropropane  (C3H5Br2Cl, CAS 96-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromo3Chloropropane;
formula     C3H5Br2Cl;
CAS         96-12-8;
InChIKey    WBEJYOJJBDISQU-UHFFFAOYSA-N;
MW          236.331;      // g/mol [origin=calculated method=formula-sum]
Tc          659.19;      // K   [origin=predictive method=joback]
Pc          51.240;      // bar [origin=predictive method=joback]
omega       0.4280;      // -   [origin=predictive method=lee-kesler]
Tb          437.55;      // K   [origin=predictive method=joback]
HvapTb      39139.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.752 0.3779 -0.0003058 1.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2Cl; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-3-chloranyl-propane" "dbcp" "fumazone" "dibromochloropropane" "nemagon" "3-chloro-1,2-dibromopropane" "fumagon" "nemabrom" "nemafume" "nemanax" "nemapaz" "nemaset" );
standardThermochemistry
{
    dHf_298   -73610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11350.0
}
