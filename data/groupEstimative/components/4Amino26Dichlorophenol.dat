/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-amino-2,6-dichlorophenol  (C6H5Cl2NO, CAS 5930-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Amino26Dichlorophenol;
formula     C6H5Cl2NO;
CAS         5930-28-9;
InChIKey    KGEXISHTCZHGFT-UHFFFAOYSA-N;
MW          178.012;      // g/mol [origin=calculated method=formula-sum]
Tc          857.52;      // K   [origin=predictive method=joback]
Pc          53.986;      // bar [origin=predictive method=joback]
omega       0.7398;      // -   [origin=predictive method=lee-kesler]
Tb          601.53;      // K   [origin=predictive method=joback]
HvapTb      64975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.48 0.606 -0.00054028 1.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACOH; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-2,6-bis(chloranyl)phenol" "phenol, 4-amino-2,6-dichloro-" "2,6-dichloro-p-aminophenol" "2,6-dichloro-4-aminophenol" "3,5-dichloro-4-hydroxyaniline" "4-amino-2,6-dichloro-phenol" );
standardThermochemistry
{
    dHf_298   -128580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19240.0
}
