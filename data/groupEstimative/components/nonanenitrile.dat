/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonanenitrile  (C9H17N, CAS 2243-27-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonanenitrile;
formula     C9H17N;
CAS         2243-27-8;
InChIKey    PLZZPPHAMDJOSR-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          690.87;      // K   [origin=predictive method=joback]
Pc          22.525;      // bar [origin=predictive method=joback]
omega       0.6148;      // -   [origin=predictive method=lee-kesler]
Tb          507.60;      // K   [origin=predictive method=joback]
HvapTb      46106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.707 0.79362 -0.0004348 8.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-nonanenitrile" "pelargononitrile" "n-octyl cyanide" "nonanitrile" "pelargonitrile" "nonanonitrile" "n-nonanonitrile" "n-octylcyanide" "octyl cyanide" "1-cyanooctane" "n-octanenitrile" "1-octyl cyanide" );
standardThermochemistry
{
    dHf_298   -64210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158080.0
}
