/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradec-9-en-1-ol  (C14H28O, CAS 35153-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradec9En1Ol;
formula     C14H28O;
CAS         35153-15-2;
InChIKey    GSAAJQNJNPBBSX-UHFFFAOYSA-N;
MW          212.377;      // g/mol [origin=calculated method=formula-sum]
Tc          779.08;      // K   [origin=predictive method=joback]
Pc          17.104;      // bar [origin=predictive method=joback]
omega       1.0566;      // -   [origin=predictive method=lee-kesler]
Tb          616.26;      // K   [origin=predictive method=joback]
HvapTb      63395.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.729 1.38782 -0.000852 2.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-9-tetradecen-1-ol" "9-tetradecen-1-ol, (9e)-" "9-tetradecen-1-ol, (9z)-" "9-tetradecen-1-ol,(9z)-" "9-tetradecen-1-ol,(z)-; (z)-9-tetradecen-1-ol; (z)-9-tetradecenyl alcohol; 9-cis-tetradecenol;myristoleyl alcohol; cis-9-tetradecen-1-ol; cis-9-tetradecenol; cis-d9-tetradecenol; d9-cis-n-tetradecen-1-ol" );
standardThermochemistry
{
    dHf_298   -367300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     745.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10400.0
}
