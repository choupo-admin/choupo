/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butyl radical  (C4H9, CAS 2492-36-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        1ButylRadical;
formula     C4H9;
CAS         2492-36-6;
InChIKey    WPWHSFAFEBZWBB-UHFFFAOYSA-N;
role        radical;
MW          57.116;      // g/mol [origin=calculated method=formula-sum]
Tc          445.75;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.2095;      // -   [origin=predictive method=lee-kesler]
Tb          285.72;      // K   [origin=predictive method=joback]
HvapTb      23849.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.352 0.35382 -0.0001748 3.01e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane" "butan-1-yl" "n-c4h9" );
standardThermochemistry
{
    dHf_298   -59070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     310.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30530.0
}
