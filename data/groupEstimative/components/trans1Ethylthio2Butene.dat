/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1-(ethylthio)-2-butene  (C6H12S, CAS 113664-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans1Ethylthio2Butene;
formula     C6H12S;
CAS         113664-29-2;
InChIKey    BHFZHOGCQAPTLZ-HWKANZROSA-N;
MW          116.222;      // g/mol [origin=calculated method=formula-sum]
Tc          608.66;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.3360;      // -   [origin=predictive method=lee-kesler]
Tb          409.82;      // K   [origin=predictive method=joback]
HvapTb      35725.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.852 0.58823 -0.0003462 8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-ethylsulfanylbut-2-ene" );
standardThermochemistry
{
    dHf_298   -8080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112980.0
}
