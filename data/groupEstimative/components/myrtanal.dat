/*--------------------------------*- Choupo -*-----------------------*\
  Component: myrtanal  (C10H16O, CAS 4764-14-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myrtanal;
formula     C10H16O;
CAS         4764-14-1;
InChIKey    OOCLVMCVOWKECB-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          696.49;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.4455;      // -   [origin=predictive method=lee-kesler]
Tb          485.71;      // K   [origin=predictive method=joback]
HvapTb      42803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.52 1.45944 -0.001329 5.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 3; } { group C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,6-dimethylbicyclo[3.1.1]heptane-4-carbaldehyde" "6,6-dimethylbicyclo(3.1.1)heptane-2-carbaldehyde" "bicyclo[3.1.1]heptane-2-carboxaldehyde, 6,6-dimethyl-" "6,6-dimethylbicyclo[3.1.1]heptane-2-carbaldehyde" "agn-pc-00puf9" );
gibbsFormation
{
    dHf_298   -221310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22290.0
    phase     gas;
}
