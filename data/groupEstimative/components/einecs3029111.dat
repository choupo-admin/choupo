/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 302-911-1  (C25H44, CAS 94135-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs3029111;
formula     C25H44;
CAS         94135-41-8;
InChIKey    GZOSYOSHWZZRQK-UHFFFAOYSA-N;
MW          344.627;      // g/mol [origin=calculated method=formula-sum]
Tc          989.63;      // K   [origin=predictive method=joback]
Pc          9.172;      // bar [origin=predictive method=joback]
omega       0.8216;      // -   [origin=predictive method=lee-kesler]
Tb          803.26;      // K   [origin=predictive method=joback]
HvapTb      74182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.443 2.24044 -0.00130036 2.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-octadecyl-benzene" "1-methyl-4-octadecylbenzene" );
gibbsFormation
{
    dHf_298   -334270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1017.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=262400.0
    phase     gas;
}
