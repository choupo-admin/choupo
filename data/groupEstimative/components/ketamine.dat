/*--------------------------------*- Choupo -*-----------------------*\
  Component: ketamine  (C13H16ClNO, CAS 6740-88-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ketamine;
formula     C13H16ClNO;
CAS         6740-88-1;
InChIKey    YQEZLKZALYSWHR-UHFFFAOYSA-N;
MW          237.727;      // g/mol [origin=calculated method=formula-sum]
Tc          964.08;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.6880;      // -   [origin=predictive method=lee-kesler]
Tb          703.91;      // K   [origin=predictive method=joback]
HvapTb      61816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.02 1.42912 -0.00108616 3.582e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group CH3NH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chlorophenyl)-2-(methylamino)cyclohexan-1-one" "ketaject" "ketanest" "dl-ketamine" "ketalar" "ci 581 base" "ketolar" "(+-)-ketamine" "special k" "clsta 20" "calypsol" "cetamina" );
standardThermochemistry
{
    dHf_298   -117000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135190.0
}
