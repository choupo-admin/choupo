/*--------------------------------*- Choupo -*-----------------------*\
  Component: loprodiol  (C5H10Cl2O2, CAS 2209-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        loprodiol;
formula     C5H10Cl2O2;
CAS         2209-86-1;
InChIKey    YFESJHPTNWYOCO-UHFFFAOYSA-N;
MW          173.033;      // g/mol [origin=calculated method=formula-sum]
Tc          746.60;      // K   [origin=predictive method=joback]
Pc          40.621;      // bar [origin=predictive method=joback]
omega       1.2797;      // -   [origin=predictive method=lee-kesler]
Tb          569.99;      // K   [origin=predictive method=joback]
HvapTb      67556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.234 0.6862 -0.0005216 1.578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group C; count 1; } { group Cl; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloromethyl)propane-1,3-diol" "chlorpropandiol" "clorpropandiol" "dispranol" "loprodiolum [inn-latin]" "2,2-bis(chloromethyl)-1,3-propanediol" "1,3-propanediol, 2,2-bis(chloromethyl)-" "loprodiolum" "loprodiol [inn]" "1, 2,2-bis(chloromethyl)-" "1,3-propanediol, 2,2-bis(chloro-methyl)-" );
standardThermochemistry
{
    dHf_298   -491220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-303440.0
}
