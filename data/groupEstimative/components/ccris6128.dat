/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 6128  (C24H16O2, CAS 74340-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris6128;
formula     C24H16O2;
CAS         74340-04-8;
InChIKey    WMKAQRLDDZKBBR-URXFXBBRSA-N;
MW          336.39;      // g/mol [origin=calculated method=formula-sum]
Tc          1303.24;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       1.6834;      // -   [origin=predictive method=lee-kesler]
Tb          1058.38;      // K   [origin=predictive method=joback]
HvapTb      113954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.71 2.0946 -0.00179668 6.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 9; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 10; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-10,11-dihydrodibenz(a,e)aceanthrylene-10,11-diol" "dibenz(a,e)aceanthrylene-10,11-diol, 10,11-dihydro-, trans-" );
gibbsFormation
{
    dHf_298   158930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=433560.0
    phase     gas;
}
