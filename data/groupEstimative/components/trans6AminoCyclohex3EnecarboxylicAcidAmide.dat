/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-6-amino-cyclohex-3-enecarboxylic acid amide  (C7H12N2O, CAS 727411-24-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans6AminoCyclohex3EnecarboxylicAcidAmide;
formula     C7H12N2O;
CAS         727411-24-7;
InChIKey    JXMUPIBGRUPBHN-PHDIDXHHSA-N;
MW          140.186;      // g/mol [origin=calculated method=formula-sum]
Tc          812.94;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       0.6776;      // -   [origin=predictive method=lee-kesler]
Tb          572.73;      // K   [origin=predictive method=joback]
HvapTb      59616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.02 0.8042 -0.00043798 7.066e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CHNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,6r)-6-azanylcyclohex-3-ene-1-carboxamide" "(1r,6r)-6-aminocyclohex-3-ene-1-carboxamide" "aa081" "(1r,6r)-rel-6-aminocyclohex-3-enecarboxamide" "trans-2-amino-4-cyclohexene-1-carboxamide" );
standardThermochemistry
{
    dHf_298   -141050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58740.0
}
