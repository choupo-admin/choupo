/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl diphenylacetate  (C15H14O2, CAS 3469-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylDiphenylacetate;
formula     C15H14O2;
CAS         3469-00-9;
InChIKey    AORIUCNKPVHMTN-UHFFFAOYSA-N;
MW          226.275;      // g/mol [origin=calculated method=formula-sum]
Tc          894.85;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       0.6435;      // -   [origin=predictive method=lee-kesler]
Tb          653.94;      // K   [origin=predictive method=joback]
HvapTb      60555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.83 1.22212 -0.0007632 1.607e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2-diphenylethanoate" "methyl 2,2-diphenylacetate" "diphenylacetic acid, methyl ester" "acetic acid, diphenyl-, methyl ester" "benzeneacetic acid, .alpha.-phenyl-, methyl ester" "diphenylacetic acid methyl ester" "diphenyl-acetic acid methyl ester" "bim-0020402.p001" );
gibbsFormation
{
    dHf_298   -202430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12570.0
    phase     gas;
}
