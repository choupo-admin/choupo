/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,12,15-octadecatrienamide, n,n-bis(2-hydroxyethyl)-, (9z,12z,15z)-  (C22H39NO3, CAS 59846-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        91215OctadecatrienamideNNBis2Hydroxyethyl9z12z15z;
formula     C22H39NO3;
CAS         59846-11-6;
InChIKey    VHFVFDNVBQGNQX-UHFFFAOYSA-N;
MW          365.558;      // g/mol [origin=calculated method=formula-sum]
Tc          1191.37;      // K   [origin=predictive method=joback]
Pc          11.656;      // bar [origin=predictive method=joback]
omega       1.0210;      // -   [origin=predictive method=lee-kesler]
Tb          966.11;      // K   [origin=predictive method=joback]
HvapTb      106587.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.406 2.31772 -0.0015791 4.4076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH=CH; count 3; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH; count 6; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-hydroxyethyl)octadeca-9,12,15-trienamide" );
standardThermochemistry
{
    dHf_298   -495260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1137.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83240.0
}
