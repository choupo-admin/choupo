/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-5-iodobenzoic acid  (C7H6INO2, CAS 5326-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino5IodobenzoicAcid;
formula     C7H6INO2;
CAS         5326-47-6;
InChIKey    GOLGILSVWFKZRQ-UHFFFAOYSA-N;
MW          263.03;      // g/mol [origin=calculated method=formula-sum]
Tc          977.45;      // K   [origin=predictive method=joback]
Pc          46.593;      // bar [origin=predictive method=joback]
omega       0.8857;      // -   [origin=predictive method=lee-kesler]
Tb          707.58;      // K   [origin=predictive method=joback]
HvapTb      71954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.0 0.6226 -0.00045152 1.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-5-iodanyl-benzoic acid" "5-iodoanthranilic acid" "benzoic acid, 2-amino-5-iodo-" "5-iodoanthranil acid" "anthranilic acid, 5-iodo-" "2-amino-5-iodo-benzoic acid" "2-amino-5-iodo-benzoicacid" "benzoicacid, 2-amino-5-iodo-" "5-iodo anthranillic acid" "5-iodoanthranilic acid (p)" "anthranilic acid, 5-iodo- (8ci)" "l184" );
standardThermochemistry
{
    dHf_298   -213830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-118130.0
}
