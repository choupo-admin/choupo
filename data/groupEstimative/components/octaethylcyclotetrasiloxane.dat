/*--------------------------------*- Choupo -*-----------------------*\
  Component: octaethylcyclotetrasiloxane  (C16H40O4Si4, CAS 1451-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H40O4Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        octaethylcyclotetrasiloxane;
formula     C16H40O4Si4;
CAS         1451-99-6;
InChIKey    XOCOMEGNVMCRMP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          408.832;      // g/mol [origin=calculated method=formula-sum]
Tc          885.43;      // K   [origin=predictive method=joback]
Pc          10.528;      // bar [origin=predictive method=joback]
omega       0.6197;      // -   [origin=predictive method=lee-kesler]
Tb          694.76;      // K   [origin=predictive method=joback]
HvapTb      70820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (159.598 0.85496 0.000639 -6.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 8; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 8; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6,8,8-octaethyl-1,3,5,7,2,4,6,8-tetraoxatetrasilocane" "cyclotetrasiloxane, octaethyl-" "cyclotetrasiloxane,2,2,4,4,6,6,8,8-octaethyl-" "2,2,4,4,6,6,8,8-octaethyl-[1,3,5,7,2,4,6,8]tetroxatetasilocane" "cyclotetrasiloxane,octaethyl- (6ci,7ci,8ci,9ci); octaethylcyclotetrasiloxane" );
standardThermochemistry
{
    dHf_298   -1261070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1051.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-623320.0
}
