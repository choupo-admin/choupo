/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,7,9-cyclododecatetrayne,5,5,6,6,11,11,12,12-octamethyl-  (C20H24, CAS 61414-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1379Cyclododecatetrayne556611111212Octamethyl;
formula     C20H24;
CAS         61414-48-0;
InChIKey    RVMCMUQWYNWSOV-UHFFFAOYSA-N;
MW          264.412;      // g/mol [origin=calculated method=formula-sum]
Tc          982.73;      // K   [origin=predictive method=joback]
Pc          19.544;      // bar [origin=predictive method=joback]
omega       0.3065;      // -   [origin=predictive method=lee-kesler]
Tb          691.16;      // K   [origin=predictive method=joback]
HvapTb      63276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.57 2.53416 -0.00283364 1.31952e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group C; count 4; } { group C_C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group tC; count 8; } { group C_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,6,6,9,9,12,12-octamethylcyclododeca-1,4,7,10-tetrayne" );
gibbsFormation
{
    dHf_298   699650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     902.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=932280.0
    phase     gas;
}
