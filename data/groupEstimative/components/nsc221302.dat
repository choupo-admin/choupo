/*--------------------------------*- Choupo -*-----------------------*\
  Component: nsc 221302  (C10H16ClNO, CAS 1132-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nsc221302;
formula     C10H16ClNO;
CAS         1132-20-3;
InChIKey    OZKJSYJSHRYFEH-UHFFFAOYSA-N;
MW          201.694;      // g/mol [origin=calculated method=formula-sum]
Tc          771.45;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.6076;      // -   [origin=predictive method=lee-kesler]
Tb          554.16;      // K   [origin=predictive method=joback]
HvapTb      51198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.369 1.3391 -0.0009821 2.8396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2Cl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-azabicyclo[3.2.2]nonan-3-yl)-2-chloranyl-ethanone" "ketone, 3-azabicyclo(3.2.2)nonyl chloromethyl" "ketone, 3-azabicyclo[3.2.2]nonyl chloromethyl" "3-azabicyclo(3.2.2)nonane, 3-(chloroacetyl)-" "n-(chloroacetyl)-3-azabicyclo[3.2.1]nonane" "3-azabicyclo[3.2.2]nonane, 3-(chloroacetyl)-" "1-(3-azabicyclo[3.2.2]nonan-3-yl)-2-chloroethanone" );
standardThermochemistry
{
    dHf_298   -177240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100550.0
}
