/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-mentha-3,8-diene  (C10H16, CAS 586-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMentha38Diene;
formula     C10H16;
CAS         586-67-4;
InChIKey    AJSJXSBFZDIRIS-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          657.45;      // K   [origin=predictive method=joback]
Pc          27.556;      // bar [origin=predictive method=joback]
omega       0.3167;      // -   [origin=predictive method=lee-kesler]
Tb          448.65;      // K   [origin=predictive method=joback]
HvapTb      38647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.41 0.94034 -0.00054664 1.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1-prop-1-en-2-yl-cyclohexene" "cyclohexene, 4-methyl-1-(1-methylethenyl)-" "4-methyl-1-prop-1-en-2-ylcyclohexene" );
gibbsFormation
{
    dHf_298   -33460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157390.0
    phase     gas;
}
