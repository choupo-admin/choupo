/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pentyn-2-ol, 2-methyl-5-(2-piperidinoethoxy)-  (C13H23NO2, CAS 16489-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pentyn2Ol2Methyl52Piperidinoethoxy;
formula     C13H23NO2;
CAS         16489-00-2;
InChIKey    XYMITAJAHUGUOX-UHFFFAOYSA-N;
MW          225.332;      // g/mol [origin=calculated method=formula-sum]
Tc          850.17;      // K   [origin=predictive method=joback]
Pc          24.975;      // bar [origin=predictive method=joback]
omega       0.9811;      // -   [origin=predictive method=lee-kesler]
Tb          649.80;      // K   [origin=predictive method=joback]
HvapTb      67086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.167 1.46774 -0.00097786 2.5448e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group tC; count 2; } { group CH2_ring; count 5; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-(2-piperidin-1-ylethoxy)pent-3-yn-2-ol" "3-pentyn-2-ol, 2-methyl-5-(2-piperidinoethoxy)-," "2-methyl-5-[2-(piperidin-1-yl)ethoxy]pent-3-yn-2-ol" );
standardThermochemistry
{
    dHf_298   -184200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177440.0
}
