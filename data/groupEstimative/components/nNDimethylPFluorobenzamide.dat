/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl p-fluorobenzamide  (C9H10FNO, CAS 24167-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylPFluorobenzamide;
formula     C9H10FNO;
CAS         24167-56-4;
InChIKey    NUOGEPIJFRZXIN-UHFFFAOYSA-N;
MW          167.183;      // g/mol [origin=calculated method=formula-sum]
Tc          708.17;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.5868;      // -   [origin=predictive method=lee-kesler]
Tb          502.76;      // K   [origin=predictive method=joback]
HvapTb      46538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.14 0.82814 -0.00054026 1.3046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-fluoranyl-n,n-dimethyl-benzamide" "4-fluoro-n,n-dimethylbenzamide" "n,n-dimethyl 4-fluorobenzamide" "n,n-dimethyl-4-fluorobenzamide" "benzamide,4-fluoro-n,n-dimethyl-" "benzamide,p-fluoro-n,n-dimethyl- (8ci); 4-fluoro-n,n-dimethylbenzamide;n,n-dimethyl-4-fluorobenzamide; p-fluoro-n,n-dimethylbenzamide" );
standardThermochemistry
{
    dHf_298   -245190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85270.0
}
