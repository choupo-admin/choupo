/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanamide  (C12H25NO, CAS 1120-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanamide;
formula     C12H25NO;
CAS         1120-16-7;
InChIKey    ILRSCQWREDREME-UHFFFAOYSA-N;
MW          199.338;      // g/mol [origin=calculated method=formula-sum]
Tc          780.28;      // K   [origin=predictive method=joback]
Pc          19.753;      // bar [origin=predictive method=joback]
omega       0.8917;      // -   [origin=predictive method=lee-kesler]
Tb          600.56;      // K   [origin=predictive method=joback]
HvapTb      59693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.83 1.17772 -0.0006537 1.3356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "lauramide" "lauric amide" "dodecylamide" "dodecamide" "lauryl amide" "amide kk" "lauric acid amide" "dodecanoic acid amide" );
standardThermochemistry
{
    dHf_298   -369800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12310.0
}
