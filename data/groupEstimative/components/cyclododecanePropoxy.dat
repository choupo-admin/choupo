/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclododecane, propoxy-  (C15H30O, CAS 67845-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclododecanePropoxy;
formula     C15H30O;
CAS         67845-47-0;
InChIKey    DZWPQZGRFUZEDL-UHFFFAOYSA-N;
MW          226.404;      // g/mol [origin=calculated method=formula-sum]
Tc          834.12;      // K   [origin=predictive method=joback]
Pc          18.579;      // bar [origin=predictive method=joback]
omega       0.4882;      // -   [origin=predictive method=lee-kesler]
Tb          610.39;      // K   [origin=predictive method=joback]
HvapTb      52855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.578 1.43012 -0.0004838 -5.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 11; } { group CH_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propoxycyclododecane" "cyclododecyl propyl ether" );
gibbsFormation
{
    dHf_298   -467790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     840.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77730.0
    phase     gas;
}
