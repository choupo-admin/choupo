/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-thiodiacetamide  (C4H8N2O2S, CAS 14618-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Thiodiacetamide;
formula     C4H8N2O2S;
CAS         14618-65-6;
InChIKey    KQNFZEVUCSXNTH-UHFFFAOYSA-N;
MW          148.18;      // g/mol [origin=calculated method=formula-sum]
Tc          848.83;      // K   [origin=predictive method=joback]
Pc          55.278;      // bar [origin=predictive method=joback]
omega       0.9488;      // -   [origin=predictive method=lee-kesler]
Tb          612.70;      // K   [origin=predictive method=joback]
HvapTb      66089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.552 0.44599 -0.000203 1.272e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CONH2; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CdO; count 2; } { group NH2; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-azanyl-2-oxidanylidene-ethyl)sulfanylethanamide" "thiodiacetamide" "2,2'-thiobisacetamide" "thiobisacetamide" "thiodiglycolamide" "2,2'-thio-bis-acetamide" "2-(carbamoylmethylthio)acetamide" "acetamide,2'-thiobis-" "2,2'-thiobis(acetamide)" "acetamide,2,2'-thiobis-" "2,2`-thiodiacetamide" "2-carbamoylmethylsulfanyl-acetamide" );
standardThermochemistry
{
    dHf_298   -241600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-109020.0
}
