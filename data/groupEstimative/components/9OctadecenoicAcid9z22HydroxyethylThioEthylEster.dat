/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenoic acid (9z)-, 2-[(2-hydroxyethyl)thio]ethyl ester  (C22H42O3S, CAS 72230-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenoicAcid9z22HydroxyethylThioEthylEster;
formula     C22H42O3S;
CAS         72230-96-7;
InChIKey    ZPPAZDWGCQOHEM-UHFFFAOYSA-N;
MW          386.635;      // g/mol [origin=calculated method=formula-sum]
Tc          1135.45;      // K   [origin=predictive method=joback]
Pc          9.989;      // bar [origin=predictive method=joback]
omega       0.9531;      // -   [origin=predictive method=lee-kesler]
Tb          926.30;      // K   [origin=predictive method=joback]
HvapTb      95427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.008 2.08741 -0.0011524 2.231e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH=CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH; count 2; } { group OH; count 1; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethylsulfanyl)ethyl octadec-9-enoate" "2-(2-hydroxyethylsulfanyl)ethyl (z)-octadec-9-enoate" );
gibbsFormation
{
    dHf_298   -807830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1169.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199490.0
    phase     gas;
}
