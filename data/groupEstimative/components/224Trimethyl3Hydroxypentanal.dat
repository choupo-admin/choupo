/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-3-hydroxypentanal  (C8H16O2, CAS 918-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl3Hydroxypentanal;
formula     C8H16O2;
CAS         918-79-6;
InChIKey    OZMMQWRIAMEIJS-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          700.53;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.8598;      // -   [origin=predictive method=lee-kesler]
Tb          519.37;      // K   [origin=predictive method=joback]
HvapTb      54729.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.53 0.90998 -0.000613 1.626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4-trimethyl-3-oxidanyl-pentanal" );
gibbsFormation
{
    dHf_298   -465570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-221900.0
    phase     gas;
}
