/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bi-1,3-dithiolane  (C6H10S4, CAS 6784-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bi13Dithiolane;
formula     C6H10S4;
CAS         6784-47-0;
InChIKey    HXIAGSFCPDWWFY-UHFFFAOYSA-N;
MW          210.386;      // g/mol [origin=calculated method=formula-sum]
Tc          861.89;      // K   [origin=predictive method=joback]
Pc          47.042;      // bar [origin=predictive method=joback]
omega       0.3032;      // -   [origin=predictive method=lee-kesler]
Tb          558.76;      // K   [origin=predictive method=joback]
HvapTb      52712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.25 0.89484 -0.0006322 1.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH2S; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group S_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1,3-dithiolan-2-yl)-1,3-dithiolane" );
standardThermochemistry
{
    dHf_298   134830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232180.0
}
