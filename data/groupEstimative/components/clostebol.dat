/*--------------------------------*- Choupo -*-----------------------*\
  Component: clostebol  (C19H27ClO2, CAS 1093-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clostebol;
formula     C19H27ClO2;
CAS         1093-58-9;
InChIKey    KCZCIYZKSLLNNH-FBPKJDBXSA-N;
MW          322.873;      // g/mol [origin=calculated method=formula-sum]
Tc          1119.99;      // K   [origin=predictive method=joback]
Pc          19.287;      // bar [origin=predictive method=joback]
omega       1.0790;      // -   [origin=predictive method=lee-kesler]
Tb          880.32;      // K   [origin=predictive method=joback]
HvapTb      82407.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-238.07 2.59274 -0.002273 8.624e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 4; } { group C; count 2; } { group OH; count 1; } { group CH2CO; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17s)-4-chloranyl-10,13-dimethyl-17-oxidanyl-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-3-one" "4-chlorotestosterone" "clostebolum" "clostebol[inn]" "clostebol (inn)" "4-chlor-testosteron" "clostebolum [inn-latin]" "4-chloro-17beta-hydroxyandrost-4-en-3-one" "(8r,9s,10r,13s,14s,17s)-4-chloro-17-hydroxy-10,13-dimethyl-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-3-one" );
standardThermochemistry
{
    dHf_298   -456120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4560.0
}
