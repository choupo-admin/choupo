/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromocyclopentane  (C5H8Br2, CAS 10230-26-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromocyclopentane;
formula     C5H8Br2;
CAS         10230-26-9;
InChIKey    LJCGLSZQABMYGU-UHFFFAOYSA-N;
MW          227.927;      // g/mol [origin=calculated method=formula-sum]
Tc          696.96;      // K   [origin=predictive method=joback]
Pc          50.086;      // bar [origin=predictive method=joback]
omega       0.3677;      // -   [origin=predictive method=lee-kesler]
Tb          456.93;      // K   [origin=predictive method=joback]
HvapTb      39542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.82 0.6604 -0.000463 1.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)cyclopentane" "trans-1,2-dibromocyclopentane" "cyclopentane, 1,2-dibromo-, cis-" "cyclopentane, 1,2-dibromo-cis-" "cyclopentane, 1,2-dibromo,trans-" "cyclopentane, 1,2-dibromo-, trans-" "cyclopentane,1,2-dibromo-, (1r,2r)-rel-" );
standardThermochemistry
{
    dHf_298   -53730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48700.0
}
