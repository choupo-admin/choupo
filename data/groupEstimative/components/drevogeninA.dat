/*--------------------------------*- Choupo -*-----------------------*\
  Component: drevogenin a  (C28H42O7, CAS 10163-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        drevogeninA;
formula     C28H42O7;
CAS         10163-83-4;
InChIKey    VZYFPJYRFFDDKS-GJULNNQYSA-N;
MW          490.637;      // g/mol [origin=calculated method=formula-sum]
Tc          1513.25;      // K   [origin=predictive method=joback]
Pc          11.074;      // bar [origin=predictive method=joback]
omega       0.9504;      // -   [origin=predictive method=lee-kesler]
Tb          1224.29;      // K   [origin=predictive method=joback]
HvapTb      128920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-280.259 3.78352 -0.00324534 1.19786e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 7; } { group C; count 3; } { group CH=C; count 1; } { group OH; count 2; } { group CH3CO; count 1; } { group CH3COO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 6; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8r,9s,10r,11s,12s,13s,14s,17s)-11-acetyloxy-17-ethanoyl-10,13-dimethyl-3,14-bis(oxidanyl)-1,2,3,4,7,8,9,11,12,15,16,17-dodecahydrocyclopenta[a]phenanthren-12-yl] 3-methylbutanoate" "14-beta-pregn-5-en-20-one, 3-beta,11-alpha,12-beta,14-tetrahydroxy-, 11-acetate 12-isovalerate" "pregn-5-en-20-one, 11-(acetyloxy)-3,14-dihydroxy-12-(3-methyl-1-oxobutoxy)-, (3-beta,11-alpha,12-beta,14-beta)-" "[(3s,8r,9s,10r,11s,12s,13s,14s,17s)-17-acetyl-11-acetyloxy-3,14-dihydroxy-10,13-dimethyl-1,2,3,4,7,8,9,11,12,15,16,17-dodecahydrocyclopenta[a]phenanthren-12-yl] 3-methylbutanoate" );
standardThermochemistry
{
    dHf_298   -1427400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1159.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-693050.0
}
