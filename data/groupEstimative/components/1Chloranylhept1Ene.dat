/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloranylhept-1-ene  (C7H13Cl, CAS 53268-66-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloranylhept1Ene;
formula     C7H13Cl;
CAS         53268-66-9;
InChIKey    CLFJXJXGJWCBSU-UHFFFAOYSA-N;
MW          132.631;      // g/mol [origin=calculated method=formula-sum]
Tc          581.91;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.3767;      // -   [origin=predictive method=lee-kesler]
Tb          401.35;      // K   [origin=predictive method=joback]
HvapTb      35519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.766 0.69562 -0.0004612 1.285e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-heptene, 1-chloro-, (z)-" );
gibbsFormation
{
    dHf_298   -86330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76350.0
    phase     gas;
}
