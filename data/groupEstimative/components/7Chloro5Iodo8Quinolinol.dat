/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-chloro-5-iodo-8-quinolinol  (C9H5ClINO, CAS 35048-13-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Chloro5Iodo8Quinolinol;
formula     C9H5ClINO;
CAS         35048-13-6;
InChIKey    JBTWPGVHNYETNF-UHFFFAOYSA-N;
MW          305.495;      // g/mol [origin=calculated method=formula-sum]
Tc          1024.08;      // K   [origin=predictive method=joback]
Pc          47.892;      // bar [origin=predictive method=joback]
omega       0.7539;      // -   [origin=predictive method=lee-kesler]
Tb          726.03;      // K   [origin=predictive method=joback]
HvapTb      73850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.32 0.89136 -0.00086706 3.365e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group ACOH; count 1; } { group C5H3N; count 1; } { group ACCl; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 5; } { group Cl; count 1; } { group I; count 1; } { group OH_phenol; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-chloranyl-5-iodanyl-quinolin-8-ol" "7-chloro-5-iodoquinolin-8-ol" "8-quinolinol,7-chloro-5-iodo-" "7-chloro-5-iodo-8-hydroxyquinoline" "5-iodo-7-chloro-8-hydroxyquinoline;5-iodo-7-chloro-8-quinolinol" );
standardThermochemistry
{
    dHf_298   92180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193320.0
}
