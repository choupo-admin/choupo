/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethene, tetrabromo-  (C2Br4, CAS 79-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etheneTetrabromo;
formula     C2Br4;
CAS         79-28-7;
InChIKey    OVRRJBSHBOXFQE-UHFFFAOYSA-N;
MW          343.638;      // g/mol [origin=calculated method=formula-sum]
Tc          788.16;      // K   [origin=predictive method=joback]
Pc          87.018;      // bar [origin=predictive method=joback]
omega       0.5293;      // -   [origin=predictive method=lee-kesler]
Tb          513.92;      // K   [origin=predictive method=joback]
HvapTb      45904.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.27 0.3664 -0.000459 2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(bromanyl)ethene" "tetrabromoethylene" "ethylene, tetrabromo-" "tetrabromoethene" "ethene, 1,1,2,2-tetrabromo-" "1,1,2,2-tetrabromoethene" "ethylene, tetrabromo- (8ci)" "ethene,1,1,2,2-tetrabromo-" );
standardThermochemistry
{
    dHf_298   118350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86360.0
}
