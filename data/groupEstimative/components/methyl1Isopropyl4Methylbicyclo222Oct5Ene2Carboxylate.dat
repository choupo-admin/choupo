/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1-isopropyl-4-methylbicyclo[2.2.2]oct-5-ene-2-carboxylate  (C14H22O2, CAS 68514-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1Isopropyl4Methylbicyclo222Oct5Ene2Carboxylate;
formula     C14H22O2;
CAS         68514-40-9;
InChIKey    WGPDTCIMQPMEHS-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          814.62;      // K   [origin=predictive method=joback]
Pc          21.714;      // bar [origin=predictive method=joback]
omega       0.5548;      // -   [origin=predictive method=lee-kesler]
Tb          594.69;      // K   [origin=predictive method=joback]
HvapTb      51628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-183.1 2.06888 -0.00199108 8.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group C; count 2; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 1-methyl-4-propan-2-yl-bicyclo[2.2.2]oct-2-ene-5-carboxylate" "bicyclo(2.2.2)oct-5-ene-2-carboxylic acid, 4-methyl-1-(1-methylethyl)-, methyl ester" "bicyclo[2.2.2]oct-5-ene-2-carboxylic acid, 4-methyl-1-(1-methylethyl)-, methyl ester" "methyl 1-methyl-4-(1-methylethyl)bicyclo(2.2.2)oct-2-ene-5-carboxylate" "methyl 1-methyl-4-propan-2-ylbicyclo[2.2.2]oct-2-ene-5-carboxylate" );
gibbsFormation
{
    dHf_298   -453650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137240.0
    phase     gas;
}
