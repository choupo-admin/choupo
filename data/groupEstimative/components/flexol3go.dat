/*--------------------------------*- Choupo -*-----------------------*\
  Component: flexol 3go  (C22H42O6, CAS 94-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        flexol3go;
formula     C22H42O6;
CAS         94-28-0;
InChIKey    FRQDZJMEHSJOPU-UHFFFAOYSA-N;
MW          402.572;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.00;      // K   [origin=predictive method=joback]
Pc          8.975;      // bar [origin=predictive method=joback]
omega       0.8699;      // -   [origin=predictive method=lee-kesler]
Tb          863.36;      // K   [origin=predictive method=joback]
HvapTb      83424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (81.344 1.86968 -0.0007682 2.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 14; } { group CH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-(2-ethylhexanoyloxy)ethoxy]ethoxy]ethyl 2-ethylhexanoate" "flexol plasticizer 3go" "teg(eh)" "triethylene glycol bis(2-ethylhexanoate)" "ethane-1,2-diylbis(oxyethane-2,1-diyl) bis(2-ethylhexanoate)" "hexanoic acid, 2-ethyl-, 1,2-ethanediylbis(oxy-2,1-ethanediyl) ester" "triethylene glycol di(2-ethylhexoate)" "hexanoic acid, 2-ethyl-, diester with triethylene glycol" "triethylene glycol, bis(2-ethylhexanoate)" "tri(ethylene glycol) bis(2-ethylhexanoate)" "2,2'-ethylenedioxydiethyl bis(2-ethylhexanoate)" "hexanoic acid, ethyl-, diester with triethylene glycol" );
standardThermochemistry
{
    dHf_298   -1406970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1119.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-701260.0
}
