/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-thiodipropionitrile  (C6H8N2S, CAS 111-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Thiodipropionitrile;
formula     C6H8N2S;
CAS         111-97-7;
InChIKey    NDVLTZFQVDXFAN-UHFFFAOYSA-N;
MW          140.204;      // g/mol [origin=calculated method=formula-sum]
Tc          836.16;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.7148;      // -   [origin=predictive method=lee-kesler]
Tb          609.82;      // K   [origin=predictive method=joback]
HvapTb      56723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.034 0.43779 -0.0002004 2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CN; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CN; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-cyanoethylsulfanyl)propanenitrile" "propanenitrile, 3,3'-thiobis-" "dicyanoethyl sulfide" "2-cyanoethyl sulfide" "di(2-cyanoethyl)sulfide" "bis(2-cyanoethyl) sulfide" "usaf ha-5" "sulfide, bis(2-cyanoethyl)" "propionitrile, 3,3'-thiodi-" "3,3'-thiodipropiononitrile" "beta,beta'-thiodipropionitrile" "beta,beta'-dicyanodiethyl sulfide" );
standardThermochemistry
{
    dHf_298   204460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=299120.0
}
