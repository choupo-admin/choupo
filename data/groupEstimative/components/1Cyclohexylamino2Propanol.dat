/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexylamino-2-propanol  (C9H19NO, CAS 103-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexylamino2Propanol;
formula     C9H19NO;
CAS         103-00-4;
InChIKey    HFHPBMVMXFZJNO-UHFFFAOYSA-N;
MW          157.257;      // g/mol [origin=calculated method=formula-sum]
Tc          760.68;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.9156;      // -   [origin=predictive method=lee-kesler]
Tb          566.98;      // K   [origin=predictive method=joback]
HvapTb      58784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.499 1.09702 -0.000629 1.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(cyclohexylamino)propan-2-ol" "2-propanol, 1-(cyclohexylamino)-" "cyclohexylamine, n-propoxylated" "usaf do-19" "1-cyclohexylaminopropan-2-ol" "1-(cyclohexylamino)-propan-2-ol" );
standardThermochemistry
{
    dHf_298   -278810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520.0
}
