/*--------------------------------*- Choupo -*-----------------------*\
  Component: triphenylmethanol  (C19H16O, CAS 76-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triphenylmethanol;
formula     C19H16O;
CAS         76-84-6;
InChIKey    LZTRCELOJRDYMQ-UHFFFAOYSA-N;
MW          260.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.31;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.9844;      // -   [origin=predictive method=lee-kesler]
Tb          803.31;      // K   [origin=predictive method=joback]
HvapTb      80099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.28 1.7319 -0.0013056 3.731e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trityl alcohol" "triphenylcarbinol" "tritanol" "methanol, triphenyl-" "triphenyl-methanol" "triphenylmethyl alcohol" "benzenemethanol, .alpha.,.alpha.-diphenyl-" "triphenylmethan-1-ol" "triphenyl methanol" "tri(phenyl)methanol" "methanol, triphenyl- (8ci)" "lztrcelojrdymq-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   113120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=312350.0
    phase     gas;
}
