/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-(2,2-dimethoxyethoxy)xylene  (C12H18O3, CAS 72138-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        m22DimethoxyethoxyXylene;
formula     C12H18O3;
CAS         72138-91-1;
InChIKey    FYQURTMVHVDCSH-UHFFFAOYSA-N;
MW          210.273;      // g/mol [origin=calculated method=formula-sum]
Tc          778.12;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       0.6821;      // -   [origin=predictive method=lee-kesler]
Tb          577.62;      // K   [origin=predictive method=joback]
HvapTb      52748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.491 0.76228 -0.00019632 -5.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH3O; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,2-dimethoxyethoxy)-1,3-dimethyl-benzene" "benzene, 2-(2,2-dimethoxyethoxy)-1,3-dimethyl-" "(2,6-dimethylphenoxy)acetaldehyde dimethyl acetal" "2-(2,2-dimethoxyethoxy)-1,3-dimethylbenzene" );
standardThermochemistry
{
    dHf_298   -479360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174130.0
}
