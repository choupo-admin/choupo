/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-bis(trifluoromethyl)toluene  (C9H6F6, CAS 75462-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35BisTrifluoromethylToluene;
formula     C9H6F6;
CAS         75462-61-2;
InChIKey    WGUXTQDCAZNJIF-UHFFFAOYSA-N;
MW          228.135;      // g/mol [origin=calculated method=formula-sum]
Tc          604.23;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       0.4875;      // -   [origin=predictive method=lee-kesler]
Tb          431.32;      // K   [origin=predictive method=joback]
HvapTb      31734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.0 0.98332 -0.00080492 2.49e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3,5-bis(trifluoromethyl)benzene" "3,5-bis(trifluoromethyl)-toluene" "3,5-ditrifluoromethylbenzyl" "dtfmbzbr" "3,5-bis-(trifluoromethyl)-toluene" "3,5-ditrifluoromethylbenzyl bromide" "1,3-bis(trifluoromethyl)-5-methylbenzene" "1-methyl-3,5-bis-trifluoromethyl-benzene" "benzene,1-methyl-3,5-bis(trifluoromethyl)-" "benzene, 1-methyl-3,5-bis(trifluoromethyl)-" "1-methyl-3,5-bis(trifluoromethyl)benzene;3,5-bis(trifluoromethyl)toluene;" );
gibbsFormation
{
    dHf_298   -1209660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1045130.0
    phase     gas;
}
