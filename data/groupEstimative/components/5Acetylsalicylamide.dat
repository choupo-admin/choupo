/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-acetylsalicylamide  (C9H9NO3, CAS 40187-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Acetylsalicylamide;
formula     C9H9NO3;
CAS         40187-51-7;
InChIKey    LWAQTCWTCCNHJR-UHFFFAOYSA-N;
MW          179.175;      // g/mol [origin=calculated method=formula-sum]
Tc          942.96;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       1.0893;      // -   [origin=predictive method=lee-kesler]
Tb          698.07;      // K   [origin=predictive method=joback]
HvapTb      75713.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.61 0.88092 -0.00069232 2.2252e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group CdO; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethanoyl-2-oxidanyl-benzamide" "5-acetyl-2-hydroxybenzamide" "benzamide, 5-acetyl-2-hydroxy-" "5-acetyl salicylamide" "5-acetyl-2-hydroxy-benzamide;benzamide, 5-acetyl-2-hydroxy-;" );
standardThermochemistry
{
    dHf_298   -372710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-218330.0
}
