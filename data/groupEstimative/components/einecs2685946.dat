name        einecs2685946;
formula     C37H68O8;
CAS         68130-51-8;
InChIKey    HEOVQHQGCAUONE-UHFFFAOYSA-N;
MW          640.943;      // g/mol [origin=calculated method=formula-sum]
Tc          1747.46;      // K   [origin=predictive method=joback]
Pc          4.483;      // bar [origin=predictive method=joback]
omega       -0.2624;      // -   [origin=predictive method=lee-kesler]
Tb          1275.37;      // K   [origin=predictive method=joback]
HvapTb      125900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.736 3.4314 -0.0017856 2.721e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 22; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 26; } { group CH; count 1; } { group C; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(heptanoyloxymethyl)-2-(3-methylbutanoyloxymethyl)-3-octanoyloxy-propyl] dodecanoate" "decanoic acid, mixed esters with heptanoic acid, isovaleric acid, octanoic acid and pentaerythritol" "decanoic acid mixed esters with heptanoic acid isovaleric acid octanoic acid and pentaerythritol" "[2-(heptanoyloxymethyl)-2-(3-methylbutanoyloxymethyl)-3-octanoyloxypropyl] dodecanoate" );
standardThermochemistry
{
    dHf_298   -2090160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1753.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-980420.0
}
