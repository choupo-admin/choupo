/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanecarboxylic acid, 4-pentyl-, 4-(pentyloxy)phenyl ester  (C23H36O3, CAS 67679-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanecarboxylicAcid4Pentyl4PentyloxyPhenylEster;
formula     C23H36O3;
CAS         67679-66-7;
InChIKey    NWXQRUYEAUDZIV-UHFFFAOYSA-N;
MW          360.538;      // g/mol [origin=calculated method=formula-sum]
Tc          1060.74;      // K   [origin=predictive method=joback]
Pc          11.491;      // bar [origin=predictive method=joback]
omega       0.9162;      // -   [origin=predictive method=lee-kesler]
Tb          853.02;      // K   [origin=predictive method=joback]
HvapTb      79667.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.382 2.02804 -0.00101156 1.326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-pentoxyphenyl) 4-pentylcyclohexane-1-carboxylate" "4-(pentyloxy)phenyl 4-pentylcyclohexanecarboxylate" "cyclohexanecarboxylic acid, 4-pentyl-, 4-(pentyloxy)phenyl ester, trans-" );
standardThermochemistry
{
    dHf_298   -708510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153070.0
}
