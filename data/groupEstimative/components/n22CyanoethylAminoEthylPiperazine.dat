/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-((2-cyanoethyl)amino)ethyl)piperazine  (C9H18N4, CAS 68310-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n22CyanoethylAminoEthylPiperazine;
formula     C9H18N4;
CAS         68310-66-7;
InChIKey    NSYHEQFRUDHVBP-UHFFFAOYSA-N;
MW          182.271;      // g/mol [origin=calculated method=formula-sum]
Tc          851.28;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.9102;      // -   [origin=predictive method=lee-kesler]
Tb          638.71;      // K   [origin=predictive method=joback]
HvapTb      61909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.696 1.1385 -0.0007182 1.723e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH; count 2; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group NH; count 1; } { group NH_ring; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-piperazin-1-ylethylamino)propanenitrile" "propanenitrile, 3-((2-(1-piperazinyl)ethyl)amino)-" "propanenitrile, 3-[[2-(1-piperazinyl)ethyl]amino]-" "3-{[2-(piperazin-1-yl)ethyl]amino}propanenitrile" "3-((2-(piperazin-1-yl)ethyl)amino)propiononitrile" );
standardThermochemistry
{
    dHf_298   175420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=490220.0
}
