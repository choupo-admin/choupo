/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethylethyl dichloroacetate  (C6H10Cl2O2, CAS 49653-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11DimethylethylDichloroacetate;
formula     C6H10Cl2O2;
CAS         49653-47-6;
InChIKey    FOLRKRMAFDGZRR-UHFFFAOYSA-N;
MW          185.044;      // g/mol [origin=calculated method=formula-sum]
Tc          670.24;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.4355;      // -   [origin=predictive method=lee-kesler]
Tb          466.29;      // K   [origin=predictive method=joback]
HvapTb      43443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.47 0.66436 -0.0004238 9.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl 2,2-bis(chloranyl)ethanoate" "tert-butyl 2,2-dichloroacetate" "acetic acid, dichloro-, 1,1-dimethylethyl ester" );
standardThermochemistry
{
    dHf_298   -529960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-334190.0
}
