/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethoxy-3-phenylacetone  (C13H18O3, CAS 19256-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diethoxy3Phenylacetone;
formula     C13H18O3;
CAS         19256-31-6;
InChIKey    LFYMGSKZVOVUKZ-UHFFFAOYSA-N;
MW          222.284;      // g/mol [origin=calculated method=formula-sum]
Tc          826.96;      // K   [origin=predictive method=joback]
Pc          22.719;      // bar [origin=predictive method=joback]
omega       0.7870;      // -   [origin=predictive method=lee-kesler]
Tb          621.99;      // K   [origin=predictive method=joback]
HvapTb      57986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.843 1.01144 -0.0004771 4.986e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxy-3-phenyl-propan-2-one" "1,1-diethoxy-3-phenylpropan-2-one" "2-propanone, 1,1-diethoxy-3-phenyl-" );
standardThermochemistry
{
    dHf_298   -457420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170370.0
}
