/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroform  (CHCl3, CAS 67-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroform;
formula     CHCl3;
CAS         67-66-3;
InChIKey    HEDRZPFGACZZDS-UHFFFAOYSA-N;
MW          119.369;      // g/mol [origin=calculated method=formula-sum]
Tc          532.43;      // K   [origin=predictive method=joback]
Pc          49.804;      // bar [origin=predictive method=joback]
omega       0.2105;      // -   [origin=predictive method=lee-kesler]
Tb          334.33;      // K   [origin=predictive method=joback]
HvapTb      30587.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.97 0.1251 -9.5e-05 2.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(chloranyl)methane" "trichloromethane" "formyl trichloride" "trichloroform" "methenyl trichloride" "methane, trichloro-" "methyl trichloride" "methane trichloride" "chloroforme" "trichlormethan" "freon 20" "cloroformio" );
gibbsFormation
{
    dHf_298   -116470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     285.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80690.0
    phase     gas;
}
