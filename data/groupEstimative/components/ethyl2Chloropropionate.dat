/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-chloropropionate  (C5H9ClO2, CAS 535-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Chloropropionate;
formula     C5H9ClO2;
CAS         535-13-7;
InChIKey    JEAVBVKAYUCPAQ-UHFFFAOYSA-N;
MW          136.575;      // g/mol [origin=calculated method=formula-sum]
Tc          595.72;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.4268;      // -   [origin=predictive method=lee-kesler]
Tb          409.21;      // K   [origin=predictive method=joback]
HvapTb      38128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.961 0.43674 -0.0001772 -3e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-chloranylpropanoate" "ethyl 2-chloropropanoate" "2-chloropropionic acid ethyl ester" "propanoic acid, 2-chloro-, ethyl ester" "ethyl-2-chloropropionate" "2-chloropropionic acid, ethyl ester" "propionic acid, 2-chloro-, ethyl ester" "ethyl .alpha.-chloropropionate" "ethyl alpha-chloropropionate" "ethyl (s)-2-chloro propionate" "alpha -chloropropionic acid, ethyl ester" "s744" );
standardThermochemistry
{
    dHf_298   -484830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-333520.0
}
