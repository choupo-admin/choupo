/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-(dodecyloxy)propan-2-ol  (C15H31ClO2, CAS 17677-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro3DodecyloxyPropan2Ol;
formula     C15H31ClO2;
CAS         17677-15-5;
InChIKey    BYAAUZDTUKVBDS-UHFFFAOYSA-N;
MW          278.861;      // g/mol [origin=calculated method=formula-sum]
Tc          861.74;      // K   [origin=predictive method=joback]
Pc          14.657;      // bar [origin=predictive method=joback]
omega       1.1427;      // -   [origin=predictive method=lee-kesler]
Tb          694.39;      // K   [origin=predictive method=joback]
HvapTb      72070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.253 1.41232 -0.0007352 1.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2Cl; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-dodecoxy-propan-2-ol" "2-propanol, 1-chloro-3-(dodecyloxy)-" "1-chloro-3-dodecoxypropan-2-ol" );
gibbsFormation
{
    dHf_298   -658400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     826.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180770.0
    phase     gas;
}
