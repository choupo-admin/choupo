/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedimethanol  (C8H10O2, CAS 626-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Benzenedimethanol;
formula     C8H10O2;
CAS         626-18-6;
InChIKey    YWMLORGQOFONNT-UHFFFAOYSA-N;
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          786.12;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       1.3217;      // -   [origin=predictive method=lee-kesler]
Tb          598.66;      // K   [origin=predictive method=joback]
HvapTb      69698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.408 0.6934 -0.00043636 1.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(hydroxymethyl)phenyl]methanol" "m-xylene-alpha,alpha'-diol" "[3-(hydroxymethyl)phenyl]methan-1-ol" "m-xylene glycol" "m-xylylene glycol" "1,3-phenylenedimethanol" "alpha,alpha'-dihydroxy-m-xylene" "m-xylene-" "a," "a inverted exclamation marka-diol" "m-xylene-a,a'-diol (6ci,7ci,8ci);(3-hydroxymethylphenyl)methanol;1,3-bis(hydroxymethyl)benzene;1,3-di(hydroxymethyl)benzene;1,3-phenylenedimethanol;2,6-bis(hydroxymethyl)benzene;isophthalyl alcohol;m-(hydroxymethyl)phenylmethanol;m-benzenedimethanol;m-bis(hydroxymethyl)benzene;m-xylylene glycol;m-xylylenediol;" );
standardThermochemistry
{
    dHf_298   -287850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154380.0
}
