/*--------------------------------*- Choupo -*-----------------------*\
  Component: crystal violet lactone  (C26H29N3O2, CAS 1552-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        crystalVioletLactone;
formula     C26H29N3O2;
CAS         1552-42-7;
InChIKey    IPAJDLMMTVZVPP-UHFFFAOYSA-N;
MW          415.537;      // g/mol [origin=calculated method=formula-sum]
Tc          1226.53;      // K   [origin=predictive method=joback]
Pc          14.165;      // bar [origin=predictive method=joback]
omega       1.1149;      // -   [origin=predictive method=lee-kesler]
Tb          988.42;      // K   [origin=predictive method=joback]
HvapTb      94900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-161.92 2.77812 -0.00230484 7.873e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 11; } { group AC; count 7; } { group CH3N; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C_ring; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group COO; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(dimethylamino)-3,3-bis[4-(dimethylamino)phenyl]-2-benzofuran-1-one" "3,3-bis(p-dimethylaminophenyl)-6-dimethylaminophthalide" "3,3-bis(4-dimethylaminophenyl)-6-dimethylaminophthalide" "3,3-bis(p-dimethylaminophenyl)-6-dimethylaminophthalate" "6-(dimethylamino)-3,3-bis(4-(dimethylamino)phenyl)phthalide" "1(3h)-isobenzofuranone, 6-(dimethylamino)-3,3-bis[4-(dimethylamino)phenyl]-" "6-dimethylamino-3,3-bis(4-dimethylaminophenyl)phthalide" "cvl 3,3-bis-4-dimethylaminophenyl7-6-dimethylaminophthalide" "phthalide, 6-(dimethylamino)-3,3-bis(p-(dimethylamino)phenyl)-" "phthalide, 6-(dimethylamino)-3,3-bis[p-(dimethylamino)phenyl]-" "1(3h)-isobenzofuranone, 6-(dimethylamino)-3,3-bis(4-(dimethylamino)phenyl)-" "phthalide,3-bis[p-(dimethylamino)phenyl]-" );
standardThermochemistry
{
    dHf_298   69410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=568180.0
}
