/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-4-vinylphenol  (C9H10O2, CAS 7786-61-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy4Vinylphenol;
formula     C9H10O2;
CAS         7786-61-0;
InChIKey    YOMSJEATGXXYPX-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          762.67;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.6230;      // -   [origin=predictive method=lee-kesler]
Tb          536.90;      // K   [origin=predictive method=joback]
HvapTb      53320.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.31 0.79182 -0.00059822 1.922e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethenyl-2-methoxy-phenol" "4-vinylguaiacol" "4-hydroxy-3-methoxystyrene" "p-vinylguaiacol" "phenol, 4-ethenyl-2-methoxy-" "4-ethenyl-2-methoxyphenol" "2-methoxy-4-vinyl-phenol" "p-vinyl guaiacol" "4-hydroxy-3-methoxyvinylbenzene" "guaiacol, 4-vinyl-" "phenol, 2-methoxy-4-vinyl-" "vinylcatechol-o-methyl ether, p-" );
standardThermochemistry
{
    dHf_298   -188130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-44100.0
}
