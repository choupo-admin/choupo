/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butoxy-3-tert-butyl-2-propanol  (C11H24O3, CAS 42910-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butoxy3TertButyl2Propanol;
formula     C11H24O3;
CAS         42910-65-6;
InChIKey    SBMPTNFAOZJPPI-UHFFFAOYSA-N;
MW          204.31;      // g/mol [origin=calculated method=formula-sum]
Tc          752.92;      // K   [origin=predictive method=joback]
Pc          20.869;      // bar [origin=predictive method=joback]
omega       1.0112;      // -   [origin=predictive method=lee-kesler]
Tb          584.63;      // K   [origin=predictive method=joback]
HvapTb      59895.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.025 1.08818 -0.000558 9.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butoxy-3-[(2-methylpropan-2-yl)oxy]propan-2-ol" );
standardThermochemistry
{
    dHf_298   -701070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304680.0
}
