/*--------------------------------*- Choupo -*-----------------------*\
  Component: cortexal  (C11H14O, CAS 4395-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cortexal;
formula     C11H14O;
CAS         4395-92-0;
InChIKey    FSKGFRBHGXIDSA-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          743.30;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.5601;      // -   [origin=predictive method=lee-kesler]
Tb          531.16;      // K   [origin=predictive method=joback]
HvapTb      49350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.999 0.89084 -0.00053496 1.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-propan-2-ylphenyl)ethanal" "cumyl acetaldehyde" "cuminic acetaldehyde" "4-isopropyl phenylacetaldehyde" "benzeneacetaldehyde, 4-(1-methylethyl)-" "4-isopropylphenylacetaldehyde" "p-cymene-7-carboxaldehyde" "p-isopropylphenylacetaldehyde" "isopropylphenylacetaldehyde, p-" "acetaldehyde, (p-isopropylphenyl)-" "4-(1-methylethyl)benzeneacetaldehyde" "(4-isopropylphenyl)acetaldehyde" );
gibbsFormation
{
    dHf_298   -136170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42560.0
    phase     gas;
}
