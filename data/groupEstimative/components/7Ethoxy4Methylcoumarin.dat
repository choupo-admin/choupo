/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-ethoxy-4-methylcoumarin  (C12H12O3, CAS 87-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Ethoxy4Methylcoumarin;
formula     C12H12O3;
CAS         87-05-8;
InChIKey    NKRISXMDKXBVRJ-UHFFFAOYSA-N;
MW          204.225;      // g/mol [origin=calculated method=formula-sum]
Tc          816.55;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.7454;      // -   [origin=predictive method=lee-kesler]
Tb          602.72;      // K   [origin=predictive method=joback]
HvapTb      56727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.601 0.89944 -0.00056276 1.321e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-ethoxy-4-methyl-chromen-2-one" "4-methyl-7-ethoxycoumarin" "7-ethoxy-4-methylchromen-2-one" "2h-1-benzopyran-2-one, 7-ethoxy-4-methyl-" "7-ethoxy-4-methyl-2h-chromen-2-one" "coumarin, 7-ethoxy-4-methyl-" "ethyl 4-methylumbelliferyl ether" "7-ethoxy-4-methyl coumarin" "7-ethoxy-4-methyl-2-oxo-2h-chromene" "coumarin, 7-ethoxy-4-methyl- (8ci)" "q053" "2h-1-benzopyran-2-one,7-ethoxy-4-methyl-" );
gibbsFormation
{
    dHf_298   -381310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171170.0
    phase     gas;
}
