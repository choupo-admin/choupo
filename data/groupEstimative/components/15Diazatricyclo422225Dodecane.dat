/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diazatricyclo[4.2.2.22,5]dodecane  (C10H18N2, CAS 100098-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diazatricyclo422225Dodecane;
formula     C10H18N2;
CAS         100098-23-5;
InChIKey    DWJNJMOHBKOYPQ-UHFFFAOYSA-N;
MW          166.268;      // g/mol [origin=calculated method=formula-sum]
Tc          690.91;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.5030;      // -   [origin=predictive method=lee-kesler]
Tb          482.44;      // K   [origin=predictive method=joback]
HvapTb      42160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-189.37 1.6712 -0.001415 4.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-diazatricyclo[4.2.2.22,5]dodecane(9ci)" "1,5-diazatricyclo(4.2.2.22,5)dodecane" );
standardThermochemistry
{
    dHf_298   117910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=432740.0
}
