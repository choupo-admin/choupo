/*--------------------------------*- Choupo -*-----------------------*\
  Component: roseofungin  (C39H62O10, CAS 12687-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        roseofungin;
formula     C39H62O10;
CAS         12687-98-8;
InChIKey    YHVUXVJMFMUNKX-YQMHJARZSA-N;
MW          690.915;      // g/mol [origin=calculated method=formula-sum]
Tc          3171.07;      // K   [origin=predictive method=joback]
Pc          8.377;      // bar [origin=predictive method=joback]
omega       -0.3360;      // -   [origin=predictive method=lee-kesler]
Tb          1950.29;      // K   [origin=predictive method=joback]
HvapTb      223508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.39 2.88216 -1.956e-05 -7.726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 8; } { group CH=CH; count 4; } { group CH=C; count 1; } { group OH; count 6; } { group CH2CO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 15; } { group CH_ring; count 7; } { group dCH_ring; count 9; } { group dC_ring; count 1; } { group OH; count 6; } { group CdO_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,5e,7e,9e,11e)-3-methyl-14,16,18,20,24,26-hexakis(oxidanyl)-36-propan-2-yl-1-oxacyclohexatriaconta-3,5,7,9,11-pentaene-2,22,28-trione" "rozeofungin" "dermostatin a, 16,34-didemethyl-21,27,29,31-tetradeoxy-12,13,32,33-tetrahydro-13-hydroxy-2-methyl-21,27-dioxo-" "(3e,5e,7e,9e,11e)-14,16,18,20,24,26-hexahydroxy-3-methyl-36-propan-2-yl-1-oxacyclohexatriaconta-3,5,7,9,11-pentaene-2,22,28-trione" );
gibbsFormation
{
    dHf_298   -2322400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1944.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1321850.0
    phase     gas;
}
