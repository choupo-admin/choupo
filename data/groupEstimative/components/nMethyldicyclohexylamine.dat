/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyldicyclohexylamine  (C13H25N, CAS 7560-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyldicyclohexylamine;
formula     C13H25N;
CAS         7560-83-0;
InChIKey    GSCCALZHGUWNJW-UHFFFAOYSA-N;
MW          195.35;      // g/mol [origin=calculated method=formula-sum]
Tc          772.85;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.4367;      // -   [origin=predictive method=lee-kesler]
Tb          548.58;      // K   [origin=predictive method=joback]
HvapTb      47433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.83 1.60692 -0.000958 2.001e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-cyclohexyl-n-methyl-cyclohexanamine" "n,n-dicyclohexylmethylamine" "n-cyclohexyl-n-methylcyclohexanamine" "cyclohexanamine, n-cyclohexyl-n-methyl-" "dicyclohexylamine, n-methyl-" "n-methyl dicyclohexylamine" "n-cyclohexyl-n-methylcyclohexylamine" "dicyclohexylmethylamine" "nn-dicyclohexylmethylamine" "gsccalzhguwnjw-uhfffaoysa-" "m772" );
gibbsFormation
{
    dHf_298   -135480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218260.0
    phase     gas;
}
