/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(isopropylamino)ethanol  (C5H13NO, CAS 109-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IsopropylaminoEthanol;
formula     C5H13NO;
CAS         109-56-8;
InChIKey    RILLZYSZSDGYGV-UHFFFAOYSA-N;
MW          103.165;      // g/mol [origin=calculated method=formula-sum]
Tc          625.48;      // K   [origin=predictive method=joback]
Pc          39.805;      // bar [origin=predictive method=joback]
omega       0.8570;      // -   [origin=predictive method=lee-kesler]
Tb          455.91;      // K   [origin=predictive method=joback]
HvapTb      49451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.742 0.59494 -0.0003304 6.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(propan-2-ylamino)ethanol" "n-isopropylethanolamine" "ethanolisopropylamine" "2-isopropylaminoethanol" "isopropylaminoethanol" "n-isopropylaminoethanol" "ethanol, 2-(isopropylamino)-" "ethanol, 2-[(1-methylethyl)amino]-" "monoisopropylaminoethanol" "(n-hydroxyethyl)isopropylamine" "2-isopropylamino ethanol" "2-((1-methylethyl)amino)ethanol" );
gibbsFormation
{
    dHf_298   -250570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58650.0
    phase     gas;
}
