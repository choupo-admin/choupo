/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 223-214-8  (C20H26O2, CAS 3772-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2232148;
formula     C20H26O2;
CAS         3772-23-4;
InChIKey    WIDWYXNFFSBCFM-UHFFFAOYSA-N;
MW          298.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1124.93;      // K   [origin=predictive method=joback]
Pc          19.965;      // bar [origin=predictive method=joback]
omega       1.1984;      // -   [origin=predictive method=lee-kesler]
Tb          891.72;      // K   [origin=predictive method=joback]
HvapTb      93342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.746 1.81728 -0.00137116 4.444e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group ACCH3; count 4; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(3,5-dimethyl-2-oxidanyl-phenyl)butyl]-4,6-dimethyl-phenol" "6,6'-butylidenebis(2,4-xylenol)" "2,4-xylenol, 6,6'-butylidenebis-" "2,2'-butane-1,4-diylbis(4,6-dimethylphenol)" "phenol,2,2'-butylidenebis[4,6-dimethyl-" "2-[4-(2-hydroxy-3,5-dimethylphenyl)butyl]-4,6-dimethylphenol" "2,4-xylenol,6,6'-butylidenedi- (6ci,7ci,8ci); 1,1-bis[3,5-dimethyl-2-hydroxyphenyl]butane" );
gibbsFormation
{
    dHf_298   -383570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     750.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5420.0
    phase     gas;
}
