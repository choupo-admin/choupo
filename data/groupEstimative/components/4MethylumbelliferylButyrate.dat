/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylumbelliferyl butyrate  (C14H14O4, CAS 17695-46-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylumbelliferylButyrate;
formula     C14H14O4;
CAS         17695-46-4;
InChIKey    WKPUJZVCZXWKCK-UHFFFAOYSA-N;
MW          246.262;      // g/mol [origin=calculated method=formula-sum]
Tc          895.93;      // K   [origin=predictive method=joback]
Pc          22.849;      // bar [origin=predictive method=joback]
omega       0.9179;      // -   [origin=predictive method=lee-kesler]
Tb          684.28;      // K   [origin=predictive method=joback]
HvapTb      66176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.692 1.09784 -0.00068796 1.536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methyl-2-oxidanylidene-chromen-7-yl) butanoate" "4-methylcoumarin-7-yl butyrate" "4-methyl-2-oxo-2h-chromen-7-yl butyrate" "butyryl 4-methylumbelliferone" "4-methylumbelliferone butyrate" "4-methyl-2-oxochromen-7-yl butanoate" "mu-bu" "butanoic acid, 4-methyl-2-oxo-2h-1-benzopyran-7-yl ester" "butyric acid, ester with 7-hydroxy-4-methylcoumarin" "(4-methyl-2-oxochromen-7-yl) butanoate" "4-methyl-2-oxo-2h-1-benzopyran-7-yl butyrate" );
gibbsFormation
{
    dHf_298   -607650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-359700.0
    phase     gas;
}
