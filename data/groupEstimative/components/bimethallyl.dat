/*--------------------------------*- Choupo -*-----------------------*\
  Component: bimethallyl  (C8H14, CAS 627-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bimethallyl;
formula     C8H14;
CAS         627-58-7;
InChIKey    DSAYAFZWRDYBQY-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          552.97;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       0.3043;      // -   [origin=predictive method=lee-kesler]
Tb          375.76;      // K   [origin=predictive method=joback]
HvapTb      32222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.748 0.72364 -0.0004618 1.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethylhexa-1,5-diene" "dimethallyl" "2,5-dimethyl-1,5-hexadiene" "1,5-hexadiene, 2,5-dimethyl-" "2,5-hexadiene" "2,5-diene" "1, 2,5-dimethyl-" "2,5-dimethyl-hexa-1,5-diene" "1,5-hexadiene,2,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   22830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175060.0
}
