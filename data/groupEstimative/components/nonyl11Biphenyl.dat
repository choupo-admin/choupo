/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonyl-1,1'-biphenyl  (C21H28, CAS 69856-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonyl11Biphenyl;
formula     C21H28;
CAS         69856-11-7;
InChIKey    XASYKPXGYFMPJK-UHFFFAOYSA-N;
MW          280.455;      // g/mol [origin=calculated method=formula-sum]
Tc          950.83;      // K   [origin=predictive method=joback]
Pc          14.942;      // bar [origin=predictive method=joback]
omega       0.7818;      // -   [origin=predictive method=lee-kesler]
Tb          738.42;      // K   [origin=predictive method=joback]
HvapTb      67554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.712 1.78152 -0.00111396 2.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-nonyl-2-phenyl-benzene" "biphenyl,nonyl- (7ci)" "agn-pc-01wgn2" );
standardThermochemistry
{
    dHf_298   -15180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     754.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341130.0
}
