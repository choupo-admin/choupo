/*--------------------------------*- Choupo -*-----------------------*\
  Component: 15-crown-5  (C10H20O5, CAS 33100-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Crown5;
formula     C10H20O5;
CAS         33100-27-5;
InChIKey    VFTFKUDGYRBSAL-UHFFFAOYSA-N;
MW          220.265;      // g/mol [origin=calculated method=formula-sum]
Tc          886.92;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.5465;      // -   [origin=predictive method=lee-kesler]
Tb          625.80;      // K   [origin=predictive method=joback]
HvapTb      62690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.23 1.001 -0.0001695 -1.67e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group FCH2O; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group O_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,10,13-pentaoxacyclopentadecane" "15-crown-5 ether" "1,4,10,13-pentaoxacyclopentadecane" "15-crown 5-ether" "1,4,7,10,13pentaoxa-cyclopentadecane" "10caf7bc-91ec-44df-a9eb-501ea2c83e15" "15-crown-5(1,4,7,10,13-pentaoxacyclopentadecane)" );
standardThermochemistry
{
    dHf_298   -890510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-474020.0
}
