/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-thiaadamantane  (C9H14S, CAS 281-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Thiaadamantane;
formula     C9H14S;
CAS         281-25-4;
InChIKey    NOBCRSKNBOQNEL-UHFFFAOYSA-N;
MW          154.271;      // g/mol [origin=calculated method=formula-sum]
Tc          705.13;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.3301;      // -   [origin=predictive method=lee-kesler]
Tb          473.17;      // K   [origin=predictive method=joback]
HvapTb      41042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.38 1.28981 -0.0010433 3.445e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 3; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 4; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-thiatricyclo(3.3.1.1(3,7))decane" "2-thiatricyclo[3.3.1.1(3,7)]decane" "2-thiatricyclo[3.3.1.13,7]decane" "2-thiatricyclo[3.3.1.1~3,7~]decane" );
standardThermochemistry
{
    dHf_298   8070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227200.0
}
