/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, pentyl-  (C8H16, CAS 2511-91-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropanePentyl;
formula     C8H16;
CAS         2511-91-3;
InChIKey    SUBUEDOPXXGMKP-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          566.97;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.3655;      // -   [origin=predictive method=lee-kesler]
Tb          389.38;      // K   [origin=predictive method=joback]
HvapTb      33315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.626 0.91472 -0.0006316 1.833e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentylcyclopropane" "1-cyclopropylpentane" "pentane, 1-cyclopropyl-" "pentane,1-cyclopropyl- (6ci,7ci,8ci); 1-cyclopropylpentane; pentylcyclopropane" );
gibbsFormation
{
    dHf_298   -135650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77230.0
    phase     gas;
}
