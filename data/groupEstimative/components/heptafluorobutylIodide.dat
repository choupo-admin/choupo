/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptafluorobutyl iodide  (C4H2F7I, CAS 374-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptafluorobutylIodide;
formula     C4H2F7I;
CAS         374-98-1;
InChIKey    AFHPVXVEXINDFS-UHFFFAOYSA-N;
MW          309.946;      // g/mol [origin=calculated method=formula-sum]
Tc          537.06;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.3618;      // -   [origin=predictive method=lee-kesler]
Tb          369.46;      // K   [origin=predictive method=joback]
HvapTb      24264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.839 0.8828 -0.0009054 3.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group I; count 1; } { group CF3; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 3; } { group F; count 7; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2,3,3-heptakis(fluoranyl)-4-iodanyl-butane" "1,1,1,2,2,3,3-heptafluoro-4-iodobutane" "butane, 1,1,1,2,2,3,3-heptafluoro-4-iodo-" "1h,1h-heptafluorobutyl iodide" "1h,1h-heptafluoro-1-iodobutane" "2,2,3,3,4,4,4-heptafluoro-1-iodobutane" "butane,1,1,1,2,2,3,3-heptafluoro-4-iodo-" );
gibbsFormation
{
    dHf_298   -1448040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1314230.0
    phase     gas;
}
