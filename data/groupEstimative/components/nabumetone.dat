/*--------------------------------*- Choupo -*-----------------------*\
  Component: nabumetone  (C15H16O2, CAS 42924-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nabumetone;
formula     C15H16O2;
CAS         42924-53-8;
InChIKey    BLXXJMDCKKHMKV-UHFFFAOYSA-N;
MW          228.291;      // g/mol [origin=calculated method=formula-sum]
Tc          897.66;      // K   [origin=predictive method=joback]
Pc          23.428;      // bar [origin=predictive method=joback]
omega       0.7998;      // -   [origin=predictive method=lee-kesler]
Tb          674.71;      // K   [origin=predictive method=joback]
HvapTb      63380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.638 1.13604 -0.00069634 1.6026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(6-methoxynaphthalen-2-yl)butan-2-one" "relafen" "listran" "relifex" "arthaxan" "nabumetona" "mebutan" "relifen" "relif" "dolsinal" "balmox" "nabumeton" );
standardThermochemistry
{
    dHf_298   -193070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41300.0
}
