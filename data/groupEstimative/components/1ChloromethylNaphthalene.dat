/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(chloromethyl)naphthalene  (C11H9Cl, CAS 86-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1ChloromethylNaphthalene;
formula     C11H9Cl;
CAS         86-52-2;
InChIKey    XMWGTKZEDLCVIG-UHFFFAOYSA-N;
MW          176.643;      // g/mol [origin=calculated method=formula-sum]
Tc          779.03;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.4518;      // -   [origin=predictive method=lee-kesler]
Tb          539.35;      // K   [origin=predictive method=joback]
HvapTb      49043.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.269 0.9135 -0.00069588 2.104e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloromethyl naphthalene" "naphthalene, 1-(chloromethyl)-" "1-naphthylmethyl chloride" "1-menaphthyl chloride" "1-chloromethylnaphthalene" "naphthalene, 1-chloromethyl-" ".alpha.-(chloromethyl)naphthalene" "(chloromethyl)naphthalene" "alpha-naphthylmethyl chloride" "alpha-(chloromethyl)naphthalene" "naphthalene, alpha-chloromethyl-" "1-(chlormethyl)naftalen" );
standardThermochemistry
{
    dHf_298   130020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=239240.0
}
