/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanoic acid, 2-chloro-3-methyl-, ethyl ester  (C7H13ClO2, CAS 91913-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanoicAcid2Chloro3MethylEthylEster;
formula     C7H13ClO2;
CAS         91913-99-4;
InChIKey    NBFKEXJJXICYDE-UHFFFAOYSA-N;
MW          164.629;      // g/mol [origin=calculated method=formula-sum]
Tc          642.02;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       0.4931;      // -   [origin=predictive method=lee-kesler]
Tb          454.53;      // K   [origin=predictive method=joback]
HvapTb      42192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.461 0.63266 -0.0002892 2.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-chloranyl-3-methyl-butanoate" "agn-pc-00mboj" );
standardThermochemistry
{
    dHf_298   -531390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319120.0
}
