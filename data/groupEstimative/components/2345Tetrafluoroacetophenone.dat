/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',3',4',5'-tetrafluoroacetophenone  (C8H4F4O, CAS 66286-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2345Tetrafluoroacetophenone;
formula     C8H4F4O;
CAS         66286-21-3;
InChIKey    JYKCLBMVRLLJCI-UHFFFAOYSA-N;
MW          192.111;      // g/mol [origin=calculated method=formula-sum]
Tc          664.18;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.6544;      // -   [origin=predictive method=lee-kesler]
Tb          480.19;      // K   [origin=predictive method=joback]
HvapTb      41804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.63 0.46612 -0.00022134 2.326e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group CH3CO; count 1; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,3,4,5-tetrakis(fluoranyl)phenyl]ethanone" "1-(2,3,4,5-tetrafluorophenyl)ethanone" "2',3',4',5'-tertafluoroacetophenone" "2',3',4',5'- tertafluoroacetophenone" "1-(2,3,4,5-tetrafluorophenyl)ethan-1-one" "2' 3' 4' 5'-tetrafluoroacetophenone" "1-acetyl-2,3,4,5-tetrafluorobenzene" "2',3',4',5',-tetrafluoroacetophenone" "2,3,4,5-tetrafluoroacetophenone" "ethanone,1-(2,3,4,5-tetrafluorophenyl)-" "ethanone, 1-(2,3,4,5-tetrafluorophenyl)-" );
standardThermochemistry
{
    dHf_298   -914820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-817790.0
}
