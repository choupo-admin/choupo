/*--------------------------------*- Choupo -*-----------------------*\
  Component: eugenol propionate  (C13H16O3, CAS 7504-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eugenolPropionate;
formula     C13H16O3;
CAS         7504-66-7;
InChIKey    GZKIAPLXSBWPRY-UHFFFAOYSA-N;
MW          220.268;      // g/mol [origin=calculated method=formula-sum]
Tc          815.47;      // K   [origin=predictive method=joback]
Pc          21.938;      // bar [origin=predictive method=joback]
omega       0.7371;      // -   [origin=predictive method=lee-kesler]
Tb          611.00;      // K   [origin=predictive method=joback]
HvapTb      57279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.682 0.90294 -0.00039782 2.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methoxy-4-prop-2-enyl-phenyl) propanoate" "eugenyl propionate" "4-allyl-2-methoxyphenyl propionate" "phenol, 2-methoxy-4-(2-propenyl)-, propanoate" "phenol, 2-methoxy-4-(2-propen-1-yl)-, 1-propanoate" "(2-methoxy-4-prop-2-enylphenyl) propanoate" "2-methoxy-4-(prop-2-en-1-yl)phenyl propanoate" "phenol, 4-allyl-2-methoxy-, propionate (8ci)" );
standardThermochemistry
{
    dHf_298   -422130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-175800.0
}
