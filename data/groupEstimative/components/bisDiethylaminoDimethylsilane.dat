/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(diethylamino)dimethylsilane  (C10H26N2Si, CAS 4669-59-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H26N2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisDiethylaminoDimethylsilane;
formula     C10H26N2Si;
CAS         4669-59-4;
InChIKey    XIFOKLGEKUNZTI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          202.417;      // g/mol [origin=calculated method=formula-sum]
Tc          619.81;      // K   [origin=predictive method=joback]
Pc          18.871;      // bar [origin=predictive method=joback]
omega       0.5111;      // -   [origin=predictive method=lee-kesler]
Tb          454.68;      // K   [origin=predictive method=joback]
HvapTb      42234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.234 0.99552 -0.0003306 -3.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH2N; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[diethylamino(dimethyl)silyl]-n-ethyl-ethanamine" "n,n,n',n'-tetraethyl-1,1-dimethylsilanediamine" "silanediamine, n,n,n',n'-tetraethyl-1,1-dimethyl-" "bis(n,n-diethylamino)dimethylsilane" "bis(n,n-diethylamino)-dimethylsilane" "n-[diethylamino(dimethyl)silyl]-n-ethylethanamine" "silanediamine,n,n,n',n'-tetraethyl-1,1-dimethyl-" );
standardThermochemistry
{
    dHf_298   -226290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150120.0
}
