/*--------------------------------*- Choupo -*-----------------------*\
  Component: triiodosilyl  (I3Si, CAS 74912-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula I3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triiodosilyl;
formula     I3Si;
CAS         74912-20-2;
InChIKey    BWOVOXIQSOKSAH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          408.785;      // g/mol [origin=calculated method=formula-sum]
Tc          795.20;      // K   [origin=predictive method=joback]
Pc          54.066;      // bar [origin=predictive method=joback]
omega       0.1167;      // -   [origin=predictive method=lee-kesler]
Tb          479.72;      // K   [origin=predictive method=joback]
HvapTb      43860.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.37 0.0177 -1.3e-05 -1e-10);
    Trange        (200 1000);
}
groups
{
    joback ( { group I; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(iodanyl)silicon" "sii3" "triiodosilicon" );
standardThermochemistry
{
    dHf_298   131470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71100.0
}
