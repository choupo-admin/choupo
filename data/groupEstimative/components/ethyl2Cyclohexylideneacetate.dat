/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-cyclohexylideneacetate  (C10H16O2, CAS 1552-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Cyclohexylideneacetate;
formula     C10H16O2;
CAS         1552-92-7;
InChIKey    MCWDXHYYYNGYGK-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          727.10;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       0.5220;      // -   [origin=predictive method=lee-kesler]
Tb          517.48;      // K   [origin=predictive method=joback]
HvapTb      46786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.239 0.97012 -0.0005305 8.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-cyclohexylideneethanoate" "ethyl cyclohexylideneacetate" "ethyl 2-cyclohexylidenacetate" "acetic acid, cyclohexylidene-, ethyl ester" ".delta.1,.alpha.-cyclohexaneacetic acid, ethyl ester" "ethylcyclohexylidenacetate" ".delta.1, ethyl ester" "2-cyclohexylideneacetic acid ethyl ester" "acetic acid,2-cyclohexylidene-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -416320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199430.0
}
