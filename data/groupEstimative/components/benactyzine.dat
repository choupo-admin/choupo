/*--------------------------------*- Choupo -*-----------------------*\
  Component: benactyzine  (C20H25NO3, CAS 302-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benactyzine;
formula     C20H25NO3;
CAS         302-40-9;
InChIKey    IVQOFBKHQCTVQV-UHFFFAOYSA-N;
MW          327.424;      // g/mol [origin=calculated method=formula-sum]
Tc          1085.20;      // K   [origin=predictive method=joback]
Pc          17.924;      // bar [origin=predictive method=joback]
omega       1.2499;      // -   [origin=predictive method=lee-kesler]
Tb          870.17;      // K   [origin=predictive method=joback]
HvapTb      89499.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.566 1.97494 -0.0013468 3.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 2-oxidanyl-2,2-diphenyl-ethanoate" "benzactyzine" "benactyzin" "benactizina [dcit]" "benzilic acid, 2-(diethylamino)ethyl ester" "diethylaminoethyl benzilate" "benactyzinum [inn-latin]" "2-(diethylamino)ethyl benzilate" "2-(diethylamino)ethyl diphenylglycolate" "benzilic acid beta-diethylaminoethyl ester" "diphenylglycolic acid 2-(diethylamino)ethyl ester" "amizyl" );
gibbsFormation
{
    dHf_298   -393800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8770.0
    phase     gas;
}
