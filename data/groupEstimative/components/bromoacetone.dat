/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromoacetone  (C3H5BrO, CAS 598-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromoacetone;
formula     C3H5BrO;
CAS         598-31-2;
InChIKey    VQFAIAKCILWQPZ-UHFFFAOYSA-N;
MW          136.976;      // g/mol [origin=calculated method=formula-sum]
Tc          589.86;      // K   [origin=predictive method=joback]
Pc          52.970;      // bar [origin=predictive method=joback]
omega       0.4035;      // -   [origin=predictive method=lee-kesler]
Tb          388.27;      // K   [origin=predictive method=joback]
HvapTb      35453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.711 0.29902 -0.0001921 4.956e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylpropan-2-one" "martonite" "monobromoacetone" "acetonyl bromide" "1-bromopropan-2-one" "1-bromo-2-propanone" "2-propanone, 1-bromo-" "1-bromoacetone" "bromomethyl methyl ketone" "bromo-2-propanone" "acetyl methyl bromide" "b-stoff" );
standardThermochemistry
{
    dHf_298   -191500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-140220.0
}
