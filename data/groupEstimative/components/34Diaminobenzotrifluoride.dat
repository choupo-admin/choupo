/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-diaminobenzotrifluoride  (C7H7F3N2, CAS 368-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Diaminobenzotrifluoride;
formula     C7H7F3N2;
CAS         368-71-8;
InChIKey    RQWJHUJJBYMJMN-UHFFFAOYSA-N;
MW          176.141;      // g/mol [origin=calculated method=formula-sum]
Tc          754.70;      // K   [origin=predictive method=joback]
Pc          39.506;      // bar [origin=predictive method=joback]
omega       0.6773;      // -   [origin=predictive method=lee-kesler]
Tb          536.04;      // K   [origin=predictive method=joback]
HvapTb      52311.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.0 0.7559 -0.00056192 1.585e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACNH2; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(trifluoromethyl)benzene-1,2-diamine" "4-(trifluoromethyl)-o-phenylenediamine" "1,2-benzenediamine, 4-(trifluoromethyl)-" "4-(trifluoromethyl)-1,2-phenylenediamine" "3,4-diamino-benzotrifluoride" "4-trifluoromethyl-1,2-phenylenediamine" "3,4-diaminotrifluoromethylbenzene" "4-(trifluoromethyl)-1,2-benzenediamine" "trifluoromethylbenzene, 3,4-diamine-" "2-amino-4-(trifluoromethyl)phenylamine" "4-tfmpd" "buttpark 51\01-88" );
gibbsFormation
{
    dHf_298   -503720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-347480.0
    phase     gas;
}
