/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-bis(chloranyl)propan-1-ol;ethanoic acid  (C5H10Cl2O3, CAS 589-96-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23BisChloranylPropan1OlEthanoicAcid;
formula     C5H10Cl2O3;
CAS         589-96-8;
InChIKey    WMWZECPKRKCUDL-UHFFFAOYSA-N;
MW          189.032;      // g/mol [origin=calculated method=formula-sum]
Tc          826.53;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       1.1443;      // -   [origin=predictive method=lee-kesler]
Tb          627.51;      // K   [origin=predictive method=joback]
HvapTb      69243.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.152 0.37692 1.96e-05 -1.136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group OH; count 1; } { group COOH; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -797410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-620570.0
    phase     gas;
}
