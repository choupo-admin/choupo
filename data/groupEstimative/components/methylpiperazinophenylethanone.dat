/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylpiperazinophenylethanone  (C13H18N2O, CAS 26586-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylpiperazinophenylethanone;
formula     C13H18N2O;
CAS         26586-55-0;
InChIKey    IRIZGAMYKHTLKS-UHFFFAOYSA-N;
MW          218.3;      // g/mol [origin=calculated method=formula-sum]
Tc          844.59;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       0.7529;      // -   [origin=predictive method=lee-kesler]
Tb          623.13;      // K   [origin=predictive method=joback]
HvapTb      58696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.86 1.48804 -0.00108326 3.0746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(4-methylpiperazin-1-yl)phenyl]ethanone" "p-(4-methylpiperazino)-acetophenone" "1-[4-(4-methylpiperazino)phenyl]-1-ethanone" "1-(4-(4-methylpiperazin-1-yl)phenyl)ethan-1-one" "1-[4-(4-methylpiperazin-1-yl)phenyl]ethan-1-one" "ethanone, 1-[4-(4-methyl-1-piperazinyl)phenyl]-" "1-acetyl-4-(4-methylpiperazinyl)benzene" "1-(4-(4-methylpiperazin-1-yl)phenyl)ethanone" "ethanone, 1-(4-(4-methyl-1-piperazinyl)phenyl)-" "1-[4-(4-methyl-1-piperazinyl)phenyl]ethanone" "ethanone,1-[4-(4-methyl-1-piperazinyl)phenyl]-" "ethanone, 1-(4-(4-methyl-1-piperazinyl)phenyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   22870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310360.0
}
