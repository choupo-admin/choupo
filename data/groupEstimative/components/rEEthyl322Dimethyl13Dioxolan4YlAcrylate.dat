/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r,e)-ethyl 3-(2,2-dimethyl-1,3-dioxolan-4-yl)acrylate  (C10H16O4, CAS 104321-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rEEthyl322Dimethyl13Dioxolan4YlAcrylate;
formula     C10H16O4;
CAS         104321-62-2;
InChIKey    GZVXALXOWVXZLH-HQZHTGGTSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          765.23;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.6196;      // -   [origin=predictive method=lee-kesler]
Tb          555.53;      // K   [origin=predictive method=joback]
HvapTb      53036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.869 1.31016 -0.0010862 3.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (e)-3-[(4r)-2,2-dimethyl-1,3-dioxolan-4-yl]prop-2-enoate" "ethyl (r)-trans-3-(2,2-dimethyl-1,3-dioxolan-4-yl)propenoate" "ethyl (r)-(-)-3-(2,2-dimethyl-1,3-dioxolan-4-yl)-trans-2-propenoate" "ethyl (r)-trans-4,5-o-isopropylidene-4,5-dihydroxy-2-pentenoate" "ethyl (r)-(?)-3-(2,2-dimethyl-1,3-dioxolan-4-yl)-trans-2-propenoate" "ethyl (2e)-3-[(4r)-2,2-dimethyl-1,3-dioxolan-4-yl]prop-2-enoate" );
gibbsFormation
{
    dHf_298   -658410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-345720.0
    phase     gas;
}
