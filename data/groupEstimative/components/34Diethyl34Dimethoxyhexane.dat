/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-diethyl-3,4-dimethoxyhexane  (C12H26O2, CAS 125379-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Diethyl34Dimethoxyhexane;
formula     C12H26O2;
CAS         125379-19-3;
InChIKey    KGFJBMIBGUJGSB-UHFFFAOYSA-N;
MW          202.338;      // g/mol [origin=calculated method=formula-sum]
Tc          691.67;      // K   [origin=predictive method=joback]
Pc          17.864;      // bar [origin=predictive method=joback]
omega       0.5441;      // -   [origin=predictive method=lee-kesler]
Tb          512.54;      // K   [origin=predictive method=joback]
HvapTb      44534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.966 1.26912 -0.0007506 1.658e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group C; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-diethyl-3,4-dimethoxy-hexane" );
gibbsFormation
{
    dHf_298   -572950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154160.0
    phase     gas;
}
