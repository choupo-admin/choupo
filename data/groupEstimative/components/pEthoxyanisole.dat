/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-ethoxyanisole  (C9H12O2, CAS 5076-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pEthoxyanisole;
formula     C9H12O2;
CAS         5076-72-2;
InChIKey    FTFNFGIOGXKJSP-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          687.68;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.4908;      // -   [origin=predictive method=lee-kesler]
Tb          482.02;      // K   [origin=predictive method=joback]
HvapTb      43386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.101 0.59404 -0.00020796 -1.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-4-methoxy-benzene" "1-ethoxy-4-methoxybenzene" "benzene, 1-ethoxy-4-methoxy-" "p-methoxyphenetole" );
standardThermochemistry
{
    dHf_298   -268470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82320.0
}
