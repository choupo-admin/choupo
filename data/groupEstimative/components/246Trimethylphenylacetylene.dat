/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethylphenylacetylene  (C11H12, CAS 769-26-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethylphenylacetylene;
formula     C11H12;
CAS         769-26-6;
InChIKey    VBEPMNWLWNKUGJ-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          704.28;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.3662;      // -   [origin=predictive method=lee-kesler]
Tb          483.02;      // K   [origin=predictive method=joback]
HvapTb      44200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.66 0.69756 -0.00040061 8.889e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethynyl-1,3,5-trimethyl-benzene" "1-ethynyl-2,4,6-trimethylbenzene" "2-ethynyl-1,3,5-trimethylbenzene" "benzene, 2-ethynyl-1,3,5-trimethyl-" );
standardThermochemistry
{
    dHf_298   223650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348330.0
}
