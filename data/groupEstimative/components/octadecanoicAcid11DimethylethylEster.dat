/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanoic acid, 1,1-dimethylethyl ester  (C22H44O2, CAS 31158-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanoicAcid11DimethylethylEster;
formula     C22H44O2;
CAS         31158-92-6;
InChIKey    NVVOIJGOEFSXRM-UHFFFAOYSA-N;
MW          340.592;      // g/mol [origin=calculated method=formula-sum]
Tc          933.37;      // K   [origin=predictive method=joback]
Pc          9.149;      // bar [origin=predictive method=joback]
omega       0.8243;      // -   [origin=predictive method=lee-kesler]
Tb          757.95;      // K   [origin=predictive method=joback]
HvapTb      70677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.174 2.16488 -0.0012502 2.654e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 15; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 16; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl octadecanoate" );
gibbsFormation
{
    dHf_298   -823440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1025.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-173170.0
    phase     gas;
}
