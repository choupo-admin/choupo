/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-Methylbicyclo[2.2.1]hept-2-ene  (C8H12, CAS 694-92-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylbicyclo221Hept2Ene;
formula     C8H12;
CAS         694-92-8;
InChIKey    HTENSGOZPYEMCG-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          609.66;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.2959;      // -   [origin=predictive method=lee-kesler]
Tb          404.53;      // K   [origin=predictive method=joback]
HvapTb      34354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.91 0.94052 -0.00072564 2.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-norbornene" "2-methylnorbornene" "2-norbornene, 2-methyl-" "bicyclo[2.2.1]hept-2-ene, 2-methyl-" "Bicyclo(2.2.1)hept-2-ene, 2-methyl-" "2-Methylbicyclo(2.2.1)heptene" "2-methylbicyclo[2.2.1]heptene" "2-methylnorborn-2-ene" "NSC135006" "DB-217492" );
standardThermochemistry
{
    dHf_298   -22700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146210.0
}
