/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[4-(trifluoromethyl)phenyl]prop-2-enoic acid  (C10H7F3O2, CAS 16642-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34TrifluoromethylPhenylProp2EnoicAcid;
formula     C10H7F3O2;
CAS         16642-92-5;
InChIKey    ANRMAUMHJREENI-UHFFFAOYSA-N;
MW          216.158;      // g/mol [origin=calculated method=formula-sum]
Tc          816.06;      // K   [origin=predictive method=joback]
Pc          29.633;      // bar [origin=predictive method=joback]
omega       0.8189;      // -   [origin=predictive method=lee-kesler]
Tb          604.31;      // K   [origin=predictive method=joback]
HvapTb      54167.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.59 1.0474 -0.00086176 2.725e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00bzl3" "trans-4-(trifluoromethyl)cinnamic acid;3-(4-trifluoromethylphenyl)acrylyc acid" );
standardThermochemistry
{
    dHf_298   -854800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-709180.0
}
