/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylanisole  (C9H12O, CAS 14804-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylanisole;
formula     C9H12O;
CAS         14804-32-1;
InChIKey    NIEHEMAZEULEKB-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          666.85;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.4144;      // -   [origin=predictive method=lee-kesler]
Tb          459.60;      // K   [origin=predictive method=joback]
HvapTb      40976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.601 0.65724 -0.00031896 4.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-2-methoxy-benzene" "1-ethyl-2-methoxybenzene" "benzene, 1-ethyl-2-methoxy-" "2-ethylmethoxybenzene" "o-ethylanisole" "benzene, ethylmethoxy-" "agn-pc-0clate" "benzene,1-ethyl-2-methoxy-" "ambap14804-32-1" "anisole,o-ethyl- (6ci,7ci,8ci);1-ethyl-2-methoxybenzene;1-methoxy-2-ethylbenzene;2-ethylanisole;methyl o-ethylphenyl ether;o-ethylanisole;o-ethylmethoxybenzene;o-methoxyethylbenzene;" );
standardThermochemistry
{
    dHf_298   -136250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22680.0
}
