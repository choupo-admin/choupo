/*--------------------------------*- Choupo -*-----------------------*\
  Component: aziridine, 1-(3-(bis(2-chloroethyl)amino-p-toluoyl)-  (C14H18Cl2N2O, CAS 21447-86-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aziridine13Bis2ChloroethylAminoPToluoyl;
formula     C14H18Cl2N2O;
CAS         21447-86-9;
InChIKey    VTYLNSUQSLUEGV-UHFFFAOYSA-N;
MW          301.211;      // g/mol [origin=calculated method=formula-sum]
Tc          929.58;      // K   [origin=predictive method=joback]
Pc          21.877;      // bar [origin=predictive method=joback]
omega       0.9832;      // -   [origin=predictive method=lee-kesler]
Tb          717.31;      // K   [origin=predictive method=joback]
HvapTb      70010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.446 1.55632 -0.00120422 3.7226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aziridin-1-yl-[3-[bis(2-chloroethyl)amino]-4-methyl-phenyl]methanone" "1-(3-(bis(2-chloroethyl)amino-4-methylbenzoyl)aziridine)" "ketone, 1-aziridinyl 3-(bis(2-chloroethyl)amino)-p-tolyl" "aziridin-1-yl-[3-[bis(2-chloroethyl)amino]-4-methylphenyl]methanone" );
standardThermochemistry
{
    dHf_298   -28400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=309490.0
}
