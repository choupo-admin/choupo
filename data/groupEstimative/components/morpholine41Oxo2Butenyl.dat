/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpholine,4-(1-oxo-2-butenyl)-  (C8H13NO2, CAS 51944-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpholine41Oxo2Butenyl;
formula     C8H13NO2;
CAS         51944-66-2;
InChIKey    QAVGKCMDOKZSBK-NSCUHMNNSA-N;
MW          155.197;      // g/mol [origin=calculated method=formula-sum]
Tc          711.63;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.5702;      // -   [origin=predictive method=lee-kesler]
Tb          500.01;      // K   [origin=predictive method=joback]
HvapTb      47225.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.0 1.03492 -0.000758 2.1876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group FCH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-morpholin-4-ylbut-2-en-1-one" "morpholine, 4-(1-oxo-2-butenyl)-" );
gibbsFormation
{
    dHf_298   -187460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36700.0
    phase     gas;
}
