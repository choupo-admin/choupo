/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropoxybenzaldehyde  (C10H12O2, CAS 18962-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H12O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Isopropoxybenzaldehyde;
formula     C10H12O2;
CAS         18962-05-5;
InChIKey    WDANSDASCKBVKH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          666.93;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.3825;      // -   [origin=predictive method=lee-kesler]
Tb          458.46;      // K   [origin=predictive method=joback]
HvapTb      40441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.49 0.76624 -0.00052956 1.498e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-yloxybenzaldehyde" "4-(propan-2-yloxy)benzaldehyde" "4-isopropoxy-1-formylbenzene" "4-(methylethoxy)benzaldehyde" "buttpark 32\08-27" "4-(propan-2-yl-oxy)benzaldehyde" "q026" );
gibbsFormation
{
    dHf_298   -85720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72620.0
    phase     gas;
}
