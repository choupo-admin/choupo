/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tribromo-3,5-dimethylphenol  (C8H7Br3O, CAS 56759-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Tribromo35Dimethylphenol;
formula     C8H7Br3O;
CAS         56759-60-5;
InChIKey    OXUOISZCFYHEAT-UHFFFAOYSA-N;
MW          358.855;      // g/mol [origin=calculated method=formula-sum]
Tc          978.34;      // K   [origin=predictive method=joback]
Pc          54.145;      // bar [origin=predictive method=joback]
omega       0.9620;      // -   [origin=predictive method=lee-kesler]
Tb          708.34;      // K   [origin=predictive method=joback]
HvapTb      70645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.56 0.71614 -0.000645 2.453e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 3; } { group ACCH3; count 2; } { group ACOH; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC_ring; count 6; } { group Br; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(bromanyl)-3,5-dimethyl-phenol" "tribromodimethylphenol" "phenol, tribromodimethyl-" "2,4,6-tribromo-3,5-dimethyl-phenol" );
standardThermochemistry
{
    dHf_298   -116120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21290.0
}
