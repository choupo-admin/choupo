/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-chloro-3,5-dimethylphenoxy)ethanol  (C10H13ClO2, CAS 5825-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Chloro35DimethylphenoxyEthanol;
formula     C10H13ClO2;
CAS         5825-79-6;
InChIKey    UZXFXOSXXYLVMI-UHFFFAOYSA-N;
MW          200.662;      // g/mol [origin=calculated method=formula-sum]
Tc          820.12;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       1.0070;      // -   [origin=predictive method=lee-kesler]
Tb          622.05;      // K   [origin=predictive method=joback]
HvapTb      65590.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.472 0.67404 -0.00029008 2.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCl; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranyl-3,5-dimethyl-phenoxy)ethanol" "2-(4-chloro-3,5-xylyloxy)ethanol" "4-(4-chloro-3,5-xylyloxy)ethanol" "4-chloro-3,5-dimethylphenoxyethanol" "2-(4-chloro-3,5-xylyloxy)-ethanol" "(4-chloro-3,5-dimethylphenoxy)ethanol" "ethanol, 2-((4-chloro-3,5-xylyl)oxy)-" "ethanol, 2-(4-chloro-3,5-dimethylphenoxy)-" "ethanol, 2-(4-chloro-3,5-dimethylphenoxy)- (9ci)" "ethanol,5-xylyl)oxy]-" "2-(4-chloro-3,5-dimethylphenoxy)ethan-1-ol" "2-(4'-chloro-3',5'-dimethyl-phenoxy)ethanol" );
gibbsFormation
{
    dHf_298   -347800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136910.0
    phase     gas;
}
