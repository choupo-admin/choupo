/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzotrichloride  (C7H5Cl3, CAS 98-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzotrichloride;
formula     C7H5Cl3;
CAS         98-07-7;
InChIKey    XEMRAKSQROQPBR-UHFFFAOYSA-N;
MW          195.467;      // g/mol [origin=calculated method=formula-sum]
Tc          744.57;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.3200;      // -   [origin=predictive method=lee-kesler]
Tb          495.50;      // K   [origin=predictive method=joback]
HvapTb      45311.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.18 0.7361 -0.0006212 1.965e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trichloromethylbenzene" "(trichloromethyl)benzene" "benzene, (trichloromethyl)-" "phenylchloroform" "alpha,alpha,alpha-trichlorotoluene" "toluene trichloride" "trichlorotoluene" "phenyl chloroform" "benzyl trichloride" "benzenyl trichloride" "benzylidyne chloride" "phenyltrichloromethane" );
standardThermochemistry
{
    dHf_298   -7250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87520.0
}
