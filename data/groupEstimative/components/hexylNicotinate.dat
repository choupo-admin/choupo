/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl nicotinate  (C12H17NO2, CAS 23597-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylNicotinate;
formula     C12H17NO2;
CAS         23597-82-2;
InChIKey    RVYGVBZGSFLJKH-UHFFFAOYSA-N;
MW          207.273;      // g/mol [origin=calculated method=formula-sum]
Tc          823.83;      // K   [origin=predictive method=joback]
Pc          24.195;      // bar [origin=predictive method=joback]
omega       0.7389;      // -   [origin=predictive method=lee-kesler]
Tb          612.76;      // K   [origin=predictive method=joback]
HvapTb      58199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.455 1.04388 -0.00057486 1.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl pyridine-3-carboxylate" "hexyl nicotinoate" "3-pyridinecarboxylic acid, hexyl ester" "nicotherm" "nicotinic acid, hexyl ester" "n-hexyl nicotinoate" "auxiliary substrate, 1a" "nicotinsaeure-n-hexylester" "nicotinic acid hexyl ester" "hexyl 3-pyridinecarboxylate" "nicotinic acid n-hexyl ester" "rvygvbzgsfljkh-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -338970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70750.0
}
