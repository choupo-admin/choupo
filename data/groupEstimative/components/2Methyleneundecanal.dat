/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyleneundecanal  (C12H22O, CAS 22414-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyleneundecanal;
formula     C12H22O;
CAS         22414-68-2;
InChIKey    PVDIIWUJHVIZTK-UHFFFAOYSA-N;
MW          182.307;      // g/mol [origin=calculated method=formula-sum]
Tc          691.48;      // K   [origin=predictive method=joback]
Pc          19.771;      // bar [origin=predictive method=joback]
omega       0.6947;      // -   [origin=predictive method=lee-kesler]
Tb          519.38;      // K   [origin=predictive method=joback]
HvapTb      48436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.698 1.09822 -0.0006472 1.487e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH2=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH2; count 1; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylideneundecanal" "undecanal, 2-methylene-" );
standardThermochemistry
{
    dHf_298   -260950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29930.0
}
