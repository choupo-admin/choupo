/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptonic acid  (C7H14O8, CAS 23351-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptonicAcid;
formula     C7H14O8;
CAS         23351-51-1;
InChIKey    KWMLJOLKUYYJFJ-UHFFFAOYSA-N;
MW          226.181;      // g/mol [origin=calculated method=formula-sum]
Tc          1325.80;      // K   [origin=predictive method=joback]
Pc          68.414;      // bar [origin=predictive method=joback]
omega       2.2294;      // -   [origin=predictive method=lee-kesler]
Tb          1056.15;      // K   [origin=predictive method=joback]
HvapTb      146474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.461 0.9531 -0.000628 1.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 5; } { group OH; count 6; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 5; } { group OH; count 6; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5,6,7-hexakis(oxidanyl)heptanoic acid" "d-glycero-d-ido-heptonic acid" "2,3,4,5,6,7-hexahydroxyheptanoic acid" "(2xi)-d-gluco-heptonic acid" "d-gluco-heptonic acid, (2.xi.)-" "agn-pc-02lsxu" "689fed97-182b-494e-929c-dbdc1c0bca99" );
gibbsFormation
{
    dHf_298   -1477860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     739.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1168970.0
    phase     gas;
}
