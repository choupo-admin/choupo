/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-Stilbene  (C14H12, CAS 645-49-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisStilbene;
formula     C14H12;
CAS         645-49-8;
InChIKey    PJANXHGTPQOBST-QXMHVHEDSA-N;
MW          180.25;      // g/mol [origin=calculated method=formula-sum]
Tc          828.44;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.4393;      // -   [origin=predictive method=lee-kesler]
Tb          577.44;      // K   [origin=predictive method=joback]
HvapTb      51268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.83 1.196 -0.000884 2.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(Z)-stilbene" "(Z)-1,2-Diphenylethene" "(Z)-1,2-Diphenylethylene" "1,1′-(1Z)-1,2-Ethenediylbis[benzene]" "Benzene, 1,1′-(1,2-ethenediyl)bis-, (Z)-" "Benzene, 1,1′-(1Z)-1,2-ethenediylbis-" "isostilbene" "Stilbene, (Z)-" "stilbene, cis-" "cis-1,2-diphenylethene" "cis-1,2-diphenylethylene" "cis-diphenylethene" );
gibbsFormation
{
    dHf_298   257990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=372040.0
    phase     gas;
}
