/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 3-hydroxy-3-methylglutarate  (C8H14O5, CAS 56652-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl3Hydroxy3Methylglutarate;
formula     C8H14O5;
CAS         56652-39-2;
InChIKey    ANEMYUYZEOZEJW-UHFFFAOYSA-N;
MW          190.195;      // g/mol [origin=calculated method=formula-sum]
Tc          767.66;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       1.0923;      // -   [origin=predictive method=lee-kesler]
Tb          588.03;      // K   [origin=predictive method=joback]
HvapTb      63599.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.252 0.81406 -0.0004244 5.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 3-methyl-3-oxidanyl-pentanedioate" "dimethyl 3-hydroxy-3-methylpentanedioate" "pentanedioic acid,3-hydroxy-3-methyl-, 1,5-dimethyl ester" "glutaricacid, 3-hydroxy-3-methyl-, dimethyl ester (6ci); pentanedioic acid,3-hydroxy-3-methyl-, dimethyl ester (9ci); dimethyl b-hydroxy-b-methylglutarate" );
standardThermochemistry
{
    dHf_298   -1003990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-738240.0
}
