/*--------------------------------*- Choupo -*-----------------------*\
  Component: tmndga  (C22H30O4, CAS 5701-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tmndga;
formula     C22H30O4;
CAS         5701-82-6;
InChIKey    ORQFDHFZSMXRLM-UHFFFAOYSA-N;
MW          358.478;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.74;      // K   [origin=predictive method=joback]
Pc          12.939;      // bar [origin=predictive method=joback]
omega       0.9738;      // -   [origin=predictive method=lee-kesler]
Tb          865.04;      // K   [origin=predictive method=joback]
HvapTb      80630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.912 1.45712 -0.00052964 -1.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group ACH; count 6; } { group AC; count 4; } { group ACCH2; count 2; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4-(3,4-dimethoxyphenyl)-2,3-dimethyl-butyl]-1,2-dimethoxy-benzene" "tetra-o-methyl-ndga" "tetramethoxynordihydroguaiaretic acid" "tetra-o-methylnordihydroguaiaretic acid" "tetra-o-methyl nordihydroguaiaretic acid" "1,1'-(2,3-dimethylbutane-1,4-diyl)bis(3,4-dimethoxybenzene)" "4,4'-(2,3-dimethyl-1,4-butanediyl)bis-1,2-dimethoxybenzene" "meso-1,4-bis(3,4-dimethoxyphenyl)dimethylbutane" "1,1'-(2,3-dimethyl-1,4-butanediyl)bis(3,4-dimethoxybenzene)" "benzene, 1,1'-(2,3-dimethyl-1,4-butanediyl)bis(3,4-dimethoxy-" "terameprocol (inn/usan)" "tetramethyl nordihydroguaiaretic acid" );
gibbsFormation
{
    dHf_298   -609670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104220.0
    phase     gas;
}
