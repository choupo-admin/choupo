/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-ethylquinoline  (C11H11N, CAS 19655-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Ethylquinoline;
formula     C11H11N;
CAS         19655-60-8;
InChIKey    VDOYSQQOKJDYDR-UHFFFAOYSA-N;
MW          157.216;      // g/mol [origin=calculated method=formula-sum]
Tc          799.37;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.4901;      // -   [origin=predictive method=lee-kesler]
Tb          555.62;      // K   [origin=predictive method=joback]
HvapTb      50868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.099 0.94048 -0.00068474 2.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "quinoline, 6-ethyl-" );
standardThermochemistry
{
    dHf_298   178550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328220.0
}
