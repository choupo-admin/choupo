/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl marasmate  (C16H20O4, CAS 2213-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylMarasmate;
formula     C16H20O4;
CAS         2213-00-5;
InChIKey    WWEGKHYWESCXOK-CCZPAOOHSA-N;
MW          276.332;      // g/mol [origin=calculated method=formula-sum]
Tc          968.46;      // K   [origin=predictive method=joback]
Pc          22.762;      // bar [origin=predictive method=joback]
omega       0.9340;      // -   [origin=predictive method=lee-kesler]
Tb          741.23;      // K   [origin=predictive method=joback]
HvapTb      68851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-235.31 2.56836 -0.00275944 1.2028e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 3; } { group CH=C; count 1; } { group CHO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (1ar,3as,6as)-1a,2-dimethanoyl-5,5-dimethyl-3a,4,6,6a-tetrahydro-1h-cyclopropa[e]indene-6b-carboxylate" "marasmic acid methyl ester" "cycloprop(e)indene-6b(1h)-carboxylic acid, 1a,2-diformyl-1a,3a,4,5,6,6a-hexahydro-5,5-dimethyl-, methyl ester, (1as-(1a-alpha,3a-beta,6a-beta,6b-alpha))-" "methyl (1ar,3as,6as)-1a,2-diformyl-5,5-dimethyl-3a,4,6,6a-tetrahydro-1h-cyclopropa[e]indene-6b-carboxylate" );
gibbsFormation
{
    dHf_298   -598420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266980.0
    phase     gas;
}
