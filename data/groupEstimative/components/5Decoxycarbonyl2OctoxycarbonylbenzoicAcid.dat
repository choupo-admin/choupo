/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-decoxycarbonyl-2-octoxycarbonylbenzoic acid  (C27H42O6, CAS 34870-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Decoxycarbonyl2OctoxycarbonylbenzoicAcid;
formula     C27H42O6;
CAS         34870-88-7;
InChIKey    SPJSLCOGEQKNOP-UHFFFAOYSA-N;
MW          462.627;      // g/mol [origin=calculated method=formula-sum]
Tc          1380.20;      // K   [origin=predictive method=joback]
Pc          8.600;      // bar [origin=predictive method=joback]
omega       0.7266;      // -   [origin=predictive method=lee-kesler]
Tb          1115.95;      // K   [origin=predictive method=joback]
HvapTb      111274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.456 2.31214 -0.00122552 1.996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group ACH; count 3; } { group AC; count 3; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-decoxycarbonyl-2-octoxycarbonyl-benzoic acid" "1,2,4-benzenetricarboxylic acid, monodecyl monooctyl ester" "5-[(decyloxy)carbonyl]-2-[(octyloxy)carbonyl]benzoic acid" "decyl octyl hydrogen benzene-1,2,4-tricarboxylate" );
gibbsFormation
{
    dHf_298   -1371850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1244.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-695040.0
    phase     gas;
}
