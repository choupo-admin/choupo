/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tri-neopentylbenzene  (C21H36, CAS 21411-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135TriNeopentylbenzene;
formula     C21H36;
CAS         21411-39-2;
InChIKey    ZWSGJJOEFPCZLS-UHFFFAOYSA-N;
MW          288.519;      // g/mol [origin=calculated method=formula-sum]
Tc          915.65;      // K   [origin=predictive method=joback]
Pc          12.090;      // bar [origin=predictive method=joback]
omega       0.5911;      // -   [origin=predictive method=lee-kesler]
Tb          707.03;      // K   [origin=predictive method=joback]
HvapTb      62052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.927 2.17848 -0.00153112 4.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group C; count 3; } { group ACH; count 3; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH2; count 3; } { group C; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(2,2-dimethylpropyl)benzene" );
gibbsFormation
{
    dHf_298   -289430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     738.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227610.0
    phase     gas;
}
