/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pyridineacrylic acid, methyl ester  (C9H9NO2, CAS 61859-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PyridineacrylicAcidMethylEster;
formula     C9H9NO2;
CAS         61859-84-5;
InChIKey    APCQGKVIYRVRKN-SNAWJCMRSA-N;
MW          163.176;      // g/mol [origin=calculated method=formula-sum]
Tc          781.08;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.5523;      // -   [origin=predictive method=lee-kesler]
Tb          548.28;      // K   [origin=predictive method=joback]
HvapTb      51479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.91 0.77888 -0.00049546 1.135e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (e)-3-pyridin-3-ylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -159830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15790.0
}
