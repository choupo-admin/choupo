/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-dihydroxydiethyl ether, m-phthalic acid polymer  (C12H16O7, CAS 60135-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DihydroxydiethylEtherMPhthalicAcidPolymer;
formula     C12H16O7;
CAS         60135-93-5;
InChIKey    KFGCQOLKVDHXJP-UHFFFAOYSA-N;
MW          272.253;      // g/mol [origin=calculated method=formula-sum]
Tc          1231.18;      // K   [origin=predictive method=joback]
Pc          30.967;      // bar [origin=predictive method=joback]
omega       1.9865;      // -   [origin=predictive method=lee-kesler]
Tb          1005.02;      // K   [origin=predictive method=joback]
HvapTb      115634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.474 0.9056 -0.00027336 -6.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group COOH; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;2-(2-hydroxyethyloxy)ethanol" "benzene-1,3-dicarboxylic acid; 2-(2-hydroxyethoxy)ethanol" "1,3-benzenedicarboxylic acid, polymer with 2,2'-oxybis(ethanol)" );
gibbsFormation
{
    dHf_298   -1314790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     837.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1018280.0
    phase     gas;
}
