/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(3-methylhept-3-ene)  (C16H32, CAS 7300-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis3Methylhept3Ene;
formula     C16H32;
CAS         7300-03-0;
InChIKey    ITIHWLPWCGGMIR-ONYUMSKCSA-N;
MW          224.432;      // g/mol [origin=calculated method=formula-sum]
Tc          755.36;      // K   [origin=predictive method=joback]
Pc          13.437;      // bar [origin=predictive method=joback]
omega       0.5582;      // -   [origin=predictive method=lee-kesler]
Tb          575.16;      // K   [origin=predictive method=joback]
HvapTb      51580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.416 1.35752 -0.000604 6.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group dCH; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-methylhept-3-ene" );
standardThermochemistry
{
    dHf_298   -270330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122420.0
}
