/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-disilaoct-4-ene, 2,2,7,7-tetramethyl-, (e)-  (C10H24Si2, CAS 16054-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H24Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        27Disilaoct4Ene2277TetramethylE;
formula     C10H24Si2;
CAS         16054-35-6;
InChIKey    DHTZZPHEAHKIBY-BQYQJAHWSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          200.472;      // g/mol [origin=calculated method=formula-sum]
Tc          617.49;      // K   [origin=predictive method=joback]
Pc          17.864;      // bar [origin=predictive method=joback]
omega       0.2777;      // -   [origin=predictive method=lee-kesler]
Tb          435.36;      // K   [origin=predictive method=joback]
HvapTb      38400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.252 0.56152 0.0002256 -2.792e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH=CH; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[(e)-4-trimethylsilylbut-2-enyl]silane" "silane, 2-butene-1,4-diylbis[trimethyl-" "trimethyl[(2e)-4-(trimethylsilyl)-2-butenyl]silane" );
standardThermochemistry
{
    dHf_298   -355750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95980.0
}
