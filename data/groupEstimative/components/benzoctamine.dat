/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoctamine  (C18H19N, CAS 17243-39-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoctamine;
formula     C18H19N;
CAS         17243-39-9;
InChIKey    GNRXCIONJWKSEA-UHFFFAOYSA-N;
MW          249.357;      // g/mol [origin=calculated method=formula-sum]
Tc          975.05;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       0.7818;      // -   [origin=predictive method=lee-kesler]
Tb          730.11;      // K   [origin=predictive method=joback]
HvapTb      66305.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.129 2.12612 -0.00199812 7.711e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoktamina [polish]" "benzoctamine [inn:ban]" "benzoctaminum [inn-latin]" "ethanoanthracene-9(10h)-methylamine, n-methyl-" "9,10-ethanoanthracene-9(10h)-methylamine, n-methyl- (7ci,8ci)" "9,10-ethanoanthracene-9(10h)-methylamine, n-methyl-, 9,10-dihydro" "benzoctamina" "benzoctaminum" "benzoktamina" "10085-81-1 (hydrochloride)" "74401-28-8 (methanesulfonate)" "n-methyl-9,10-ethanoanthracene-9(10h)-methanamine" );
gibbsFormation
{
    dHf_298   261900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=535840.0
    phase     gas;
}
