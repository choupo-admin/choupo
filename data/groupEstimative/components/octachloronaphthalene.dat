/*--------------------------------*- Choupo -*-----------------------*\
  Component: octachloronaphthalene  (C10Cl8, CAS 2234-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octachloronaphthalene;
formula     C10Cl8;
CAS         2234-13-1;
InChIKey    RTNLUFLDZOAXIC-UHFFFAOYSA-N;
MW          403.71;      // g/mol [origin=calculated method=formula-sum]
Tc          1082.25;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       0.8265;      // -   [origin=predictive method=lee-kesler]
Tb          813.34;      // K   [origin=predictive method=joback]
HvapTb      82146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (145.97 0.4496 -0.000315 8.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 2; } { group ACCl; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 10; } { group Cl; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6,7,8-octakis(chloranyl)naphthalene" "perna" "perchloronaphthalene" "naphthalene, octachloro-" "octachloro naphthalene" "1,2,3,4,5,6,7,8-octachloronaphthalene" "naphthalene, 1,2,3,4,5,6,7,8-octachloro-" "1,3,4,5,6,7,8-octachloronaphthalene" "p860" );
gibbsFormation
{
    dHf_298   -39810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79900.0
    phase     gas;
}
