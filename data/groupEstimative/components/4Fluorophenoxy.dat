/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorophenoxy  (C6H4FO, CAS 2145-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H4FO (delta O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Fluorophenoxy;
formula     C6H4FO;
CAS         2145-21-3;
InChIKey    QDKWLJJOYIFEBS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          111.095;      // g/mol [origin=calculated method=formula-sum]
Tc          565.91;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.2823;      // -   [origin=predictive method=lee-kesler]
Tb          367.11;      // K   [origin=predictive method=joback]
HvapTb      30924.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.49 0.5503 -0.00049056 1.75e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-4-$l^{1}-oxidanyl-benzene" "4-f-phenoxy" "1-fluoro-4-" "(4-fluorophenyl)oxidanyl" );
standardThermochemistry
{
    dHf_298   -82410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40010.0
}
