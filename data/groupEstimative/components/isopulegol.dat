/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-isopulegol  (C10H18O, CAS 104870-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopulegol;
formula     C10H18O;
CAS         104870-56-6;
InChIKey    ZYTMANIQRDEHIO-AEJSXWLSSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          720.07;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.7026;      // -   [origin=predictive method=lee-kesler]
Tb          527.35;      // K   [origin=predictive method=joback]
HvapTb      53754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.32 1.03684 -0.000546 9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 3; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2r,5s)-5-methyl-2-prop-1-en-2-yl-cyclohexan-1-ol" "(1s,3s,4r)-p-menth-8-en-3-ol" "(1s,2r,5s)-2-isopropenyl-5-methylcyclohexanol" "d-isopulegol" "isopulegol, (+)-" "(1s,2r,5s)-(+)-isopulegol" "(1s,2r,5s)-5-methyl-2-prop-1-en-2-ylcyclohexan-1-ol" "cyclohexanol, 5-methyl-2-(1-methylethenyl)-, (1s,2r,5s)-" "cyclohexanol, 5-methyl-2-(1-methylethenyl)-, [1s-(1alpha,2beta,5alpha)]-" );
standardThermochemistry
{
    dHf_298   -272680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15180.0
}
