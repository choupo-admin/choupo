/*--------------------------------*- Choupo -*-----------------------*\
  Component: malondialdehyde  (C3H4O2, CAS 542-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        malondialdehyde;
formula     C3H4O2;
CAS         542-78-9;
InChIKey    WSMYVTOQOOLQHP-UHFFFAOYSA-N;
MW          72.063;      // g/mol [origin=calculated method=formula-sum]
Tc          548.55;      // K   [origin=predictive method=joback]
Pc          54.225;      // bar [origin=predictive method=joback]
omega       0.4660;      // -   [origin=predictive method=lee-kesler]
Tb          365.56;      // K   [origin=predictive method=joback]
HvapTb      35712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.961 0.2378 -0.0001254 2.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group OdCH_al; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanedial" "malonaldehyde" "malonyldialdehyde" "malonodialdehyde" "malonic aldehyde" "malonic dialdehyde" "1,3-propanedial" "1,3-propanedione" "1,3-propanedialdehyde" "mdd" "propanedial (9ci)" "malonaldehyde(6ci,8ci); 1,3-propanedialdehyde; diformylmethane; mda; malondialdehyde;malonic aldehyde; malonic dialdehyde; malonodialdehyde; malonyldialdehyde" );
standardThermochemistry
{
    dHf_298   -276410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     310.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224660.0
}
