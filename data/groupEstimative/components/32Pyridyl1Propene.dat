/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-pyridyl)-1-propene  (C8H9N, CAS 2835-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32Pyridyl1Propene;
formula     C8H9N;
CAS         2835-33-8;
InChIKey    LIPRUDRQZVPYCL-UHFFFAOYSA-N;
MW          119.167;      // g/mol [origin=calculated method=formula-sum]
Tc          686.63;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       0.3621;      // -   [origin=predictive method=lee-kesler]
Tb          459.70;      // K   [origin=predictive method=joback]
HvapTb      41218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.219 0.69866 -0.00047476 1.287e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enylpyridine" "2-allyl-pyridine" "ethenylmethylpyridine" "pyridine, ethenylmethyl-" "pyridine, 2-(2-propenyl)-" );
gibbsFormation
{
    dHf_298   186300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=293780.0
    phase     gas;
}
