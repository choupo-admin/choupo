/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-4-methylcinnamaldehyde  (C10H10O, CAS 1504-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans4Methylcinnamaldehyde;
formula     C10H10O;
CAS         1504-75-2;
InChIKey    DKOUYOVAEBQFHU-UHFFFAOYSA-N;
MW          146.189;      // g/mol [origin=calculated method=formula-sum]
Tc          733.78;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.5072;      // -   [origin=predictive method=lee-kesler]
Tb          512.88;      // K   [origin=predictive method=joback]
HvapTb      47470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.59 0.80992 -0.00056116 1.537e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-methylphenyl)prop-2-enal" "3-(4-methylphenyl)-2-propenal" "2-propenal,3-(4-methylphenyl)-" "cinnamaldehyde,p-methyl- (6ci,7ci,8ci); 3-(p-tolyl)propenal; 4-methylcinnamaldehyde;p-methylcinnamaldehyde" );
gibbsFormation
{
    dHf_298   6970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116800.0
    phase     gas;
}
