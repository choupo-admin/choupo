/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(4-methylphenyl)hexafluoropropane  (C17H14F6, CAS 1095-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis4MethylphenylHexafluoropropane;
formula     C17H14F6;
CAS         1095-77-8;
InChIKey    OWEIAGSMFHSSES-UHFFFAOYSA-N;
MW          332.287;      // g/mol [origin=calculated method=formula-sum]
Tc          842.68;      // K   [origin=predictive method=joback]
Pc          16.921;      // bar [origin=predictive method=joback]
omega       0.6576;      // -   [origin=predictive method=lee-kesler]
Tb          637.81;      // K   [origin=predictive method=joback]
HvapTb      50522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.65 1.79024 -0.00144312 4.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[1,1,1,3,3,3-hexakis(fluoranyl)-2-(4-methylphenyl)propan-2-yl]-4-methyl-benzene" "1-[1,1,1,3,3,3-hexafluoro-2-(4-methylphenyl)propan-2-yl]-4-methylbenzene" "4,4'-(hexafluoroisopropylidene)ditoluene" "2,2-bis(4-methylphenyl)hexafluoropropane 98%" "4,4'-(perfluoropropane-2,2-diyl)bis(methylbenzene)" "benzene,1,1'-[2,2,2-trifluoro-1-(trifluoromethyl)ethylidene]bis[4-methyl-" "1-methyl-4-[2,2,2-trifluoro-1-(4-methylphenyl)-1-(trifluoromethyl)ethyl]benzene" "propane,1,1,1,3,3,3-hexafluoro-2,2-di-p-tolyl- (7ci); propane, hexafluoro-2,2-di-p-tolyl-(8ci); 2,2-bis(4-methylphenyl)hexafluoropropane;2,2-bis(p-tolyl)hexafluoropropane" );
standardThermochemistry
{
    dHf_298   -1147000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-862520.0
}
