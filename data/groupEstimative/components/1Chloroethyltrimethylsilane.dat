/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloroethyltrimethylsilane  (C5H13ClSi, CAS 7787-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H13ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Chloroethyltrimethylsilane;
formula     C5H13ClSi;
CAS         7787-87-3;
InChIKey    UWJVDEZZIPJQRF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          136.694;      // g/mol [origin=calculated method=formula-sum]
Tc          536.00;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.1960;      // -   [origin=predictive method=lee-kesler]
Tb          352.39;      // K   [origin=predictive method=joback]
HvapTb      31015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.37 0.28538 0.000143 -1.604e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CHCl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloroethyl(trimethyl)silane" "(1-chloroethyl)trimethylsilane" "(1-chloroethyl)(trimethyl)silane" ".alpha.-chloroethyltrimethylsilane" "silane, (1-chloroethyl)trimethyl-" "1-chloroethyl-trimethylsilane" "1-chloroethyl trimethylsilane" );
standardThermochemistry
{
    dHf_298   -279170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127910.0
}
