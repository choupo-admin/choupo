/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,8-dimethyl-4,9-decadien-1-ol  (C12H22O, CAS 72928-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        48Dimethyl49Decadien1Ol;
formula     C12H22O;
CAS         72928-27-9;
InChIKey    PSFAZLXAAWYFEH-UHFFFAOYSA-N;
MW          182.307;      // g/mol [origin=calculated method=formula-sum]
Tc          737.61;      // K   [origin=predictive method=joback]
Pc          21.217;      // bar [origin=predictive method=joback]
omega       0.9214;      // -   [origin=predictive method=lee-kesler]
Tb          566.62;      // K   [origin=predictive method=joback]
HvapTb      57965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.275 1.18364 -0.0007716 2.075e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,8-dimethyldeca-4,9-dien-1-ol" "4,9-decadien-1-ol, 4,8-dimethyl-" "4,9-decadien-1-ol,4,8-dimethyl-" );
standardThermochemistry
{
    dHf_298   -215660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70410.0
}
