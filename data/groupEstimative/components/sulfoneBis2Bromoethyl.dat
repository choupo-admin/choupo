/*--------------------------------*- Choupo -*-----------------------*\
  Component: sulfone, bis(2-bromoethyl)  (C4H8Br2O2S, CAS 7617-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H8Br2O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        sulfoneBis2Bromoethyl;
formula     C4H8Br2O2S;
CAS         7617-67-6;
InChIKey    JASUZIAETLGSCB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          279.974;      // g/mol [origin=calculated method=formula-sum]
Tc          580.63;      // K   [origin=predictive method=joback]
Pc          54.225;      // bar [origin=predictive method=joback]
omega       0.6691;      // -   [origin=predictive method=lee-kesler]
Tb          402.44;      // K   [origin=predictive method=joback]
HvapTb      49186.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.274 0.4994 -0.0003112 6.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group Br; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Br; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-(2-bromoethylsulfonyl)ethane" "1-bromo-2-(2-bromoethylsulfonyl)ethane" );
gibbsFormation
{
    dHf_298   -568450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-490220.0
    phase     gas;
}
