/*--------------------------------*- Choupo -*-----------------------*\
  Component: tribromochloromethane  (CBr3Cl, CAS 594-15-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tribromochloromethane;
formula     CBr3Cl;
CAS         594-15-0;
InChIKey    GKXZMEXQUWZGJK-UHFFFAOYSA-N;
MW          287.173;      // g/mol [origin=calculated method=formula-sum]
Tc          715.84;      // K   [origin=predictive method=joback]
Pc          79.012;      // bar [origin=predictive method=joback]
omega       0.3920;      // -   [origin=predictive method=lee-kesler]
Tb          455.16;      // K   [origin=predictive method=joback]
HvapTb      40214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.97 0.346 -0.000437 1.839e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group C; count 1; } { group Cl; count 1; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(bromanyl)-chloranyl-methane" "tribromo(chloro)methane" "methane, tribromochloro-" "chlorotribromomethane" "chlorotribromomethane;tribromochloromethane" "methane,tribromochloro- (6ci,7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   -9470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8590.0
    phase     gas;
}
