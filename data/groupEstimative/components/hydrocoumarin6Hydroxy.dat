/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydrocoumarin, 6-hydroxy-  (C9H8O3, CAS 2669-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydrocoumarin6Hydroxy;
formula     C9H8O3;
CAS         2669-94-5;
InChIKey    ZCNZNVIRVHJXKV-UHFFFAOYSA-N;
MW          164.16;      // g/mol [origin=calculated method=formula-sum]
Tc          818.42;      // K   [origin=predictive method=joback]
Pc          46.026;      // bar [origin=predictive method=joback]
omega       0.7687;      // -   [origin=predictive method=lee-kesler]
Tb          583.16;      // K   [origin=predictive method=joback]
HvapTb      59037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.47 1.0072 -0.00091372 3.299e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-oxidanyl-3,4-dihydrochromen-2-one" "3,4-dihydro-6-hydroxycoumarin" "6-hydroxy-3,4-dihydrocoumarin" "2h-1-benzopyran-2-one, 3,4-dihydro-6-hydroxy-" "2,5-dihydroxyhydrocinnamic acid lactone" "3,4-dihydro-6-hydroxy-2h-1-benzopyran-2-one" "6-hydroxy-3,4-dihydrochromen-2-one" "2h-1-benzopyran-2-one,4-dihydro-6-hydroxy-" );
gibbsFormation
{
    dHf_298   -399320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-256750.0
    phase     gas;
}
