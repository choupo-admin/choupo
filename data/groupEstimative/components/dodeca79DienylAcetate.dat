/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodeca-7,9-dienyl acetate  (C14H24O2, CAS 54364-62-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodeca79DienylAcetate;
formula     C14H24O2;
CAS         54364-62-4;
InChIKey    LLRZUAWETKPZJO-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          764.23;      // K   [origin=predictive method=joback]
Pc          16.619;      // bar [origin=predictive method=joback]
omega       0.7530;      // -   [origin=predictive method=lee-kesler]
Tb          586.46;      // K   [origin=predictive method=joback]
HvapTb      54081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.793 1.31904 -0.0008108 1.931e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=CH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodeca-7,9-dienyl ethanoate" "(7e,9z)-dodeca-7,9-dien-1-yl acetate" "7,9-dodecadien-1-ol, 1-acetate, (7e,9z)-" "(7e,9e)-dodeca-7,9-dien-1-yl acetate" );
standardThermochemistry
{
    dHf_298   -415130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     739.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82930.0
}
