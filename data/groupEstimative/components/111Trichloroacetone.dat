/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trichloroacetone  (C3H3Cl3O, CAS 918-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trichloroacetone;
formula     C3H3Cl3O;
CAS         918-00-3;
InChIKey    SMZHKGXSEAGRTI-UHFFFAOYSA-N;
MW          161.406;      // g/mol [origin=calculated method=formula-sum]
Tc          650.35;      // K   [origin=predictive method=joback]
Pc          42.441;      // bar [origin=predictive method=joback]
omega       0.3563;      // -   [origin=predictive method=lee-kesler]
Tb          431.17;      // K   [origin=predictive method=joback]
HvapTb      40877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.72 0.40702 -0.0003537 1.1436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group Cl; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(chloranyl)propan-2-one" "1,1,1-trichloropropanone" "2-propanone, 1,1,1-trichloro-" "1,1,1-trichloro-2-propanone" "2-propanone, trichloro-" "1,1,1-trichloropropan-2-one" "alpha,alpha,alpha-trichloroacetone" ".alpha.,.alpha.,.alpha.-trichloroacetone" "trichloroacetone" "1,1-trichloroacetone" "1,1-trichloropropanone" "1,1-trichloro-2-propanone" );
gibbsFormation
{
    dHf_298   -273800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187490.0
    phase     gas;
}
