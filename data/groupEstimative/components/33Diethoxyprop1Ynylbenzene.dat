/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-diethoxyprop-1-ynylbenzene  (C13H16O2, CAS 6142-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Diethoxyprop1Ynylbenzene;
formula     C13H16O2;
CAS         6142-95-6;
InChIKey    DTEGZYXCDQFSBZ-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          798.85;      // K   [origin=predictive method=joback]
Pc          24.975;      // bar [origin=predictive method=joback]
omega       0.5622;      // -   [origin=predictive method=lee-kesler]
Tb          577.12;      // K   [origin=predictive method=joback]
HvapTb      53392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.042 0.88964 -0.00040366 3.788e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylpropiolaldehyde diethyl acetal" "phenylpropargyl aldehyde diethyl acetal" "(3,3-diethoxyprop-1-yn-1-yl)benzene" "phenylpropiolic aldehyde diethyl acetal" "benzene, (3,3-diethoxy-1-propynyl)-" "propiolaldehyde, phenyl-, diethyl acetal" "1,1-diethoxy-3-phenylprop-2-yne" "3-phenylpropynal diethyl acetal" "propiolaldehyde, diethyl acetal" "benzene,3-diethoxy-1-propynyl)-" "dehydrocinnamaldehyde-diethylacetal" "(3,3-diethoxy-1-propynyl)benzene" );
standardThermochemistry
{
    dHf_298   -72540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161350.0
}
