/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-dodecene  (C13H26, CAS 16435-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Dodecene;
formula     C13H26;
CAS         16435-49-7;
InChIKey    PWRBDKMPAZFCSV-UHFFFAOYSA-N;
MW          182.351;      // g/mol [origin=calculated method=formula-sum]
Tc          659.38;      // K   [origin=predictive method=joback]
Pc          17.089;      // bar [origin=predictive method=joback]
omega       0.5857;      // -   [origin=predictive method=lee-kesler]
Tb          493.60;      // K   [origin=predictive method=joback]
HvapTb      43942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.611 1.21874 -0.0007086 1.627e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyldodec-1-ene" "2-methyl-dodec-1-ene" "1-dodecene, 2-methyl-" "2-methyl-1-dodecene;2-methyl-dodec-1-ene;" );
standardThermochemistry
{
    dHf_298   -196010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137870.0
}
