/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopenten-1-amine,n,n-dimethyl-  (C7H13N, CAS 13044-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopenten1AmineNNDimethyl;
formula     C7H13N;
CAS         13044-51-4;
InChIKey    DDWGOYIQAOAERW-UHFFFAOYSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          580.85;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.3101;      // -   [origin=predictive method=lee-kesler]
Tb          386.64;      // K   [origin=predictive method=joback]
HvapTb      33768.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.87 0.86844 -0.00058428 1.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylcyclopent-2-en-1-amine" "2-cyclopenten-1-amine, n,n-dimethyl-" );
gibbsFormation
{
    dHf_298   -2020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185350.0
    phase     gas;
}
