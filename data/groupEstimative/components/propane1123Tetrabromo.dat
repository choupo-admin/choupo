/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 1,1,2,3-tetrabromo-  (C3H4Br4, CAS 34581-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane1123Tetrabromo;
formula     C3H4Br4;
CAS         34581-76-5;
InChIKey    FCMPIAVBSFMMDT-UHFFFAOYSA-N;
MW          359.681;      // g/mol [origin=calculated method=formula-sum]
Tc          789.05;      // K   [origin=predictive method=joback]
Pc          67.852;      // bar [origin=predictive method=joback]
omega       0.6054;      // -   [origin=predictive method=lee-kesler]
Tb          532.00;      // K   [origin=predictive method=joback]
HvapTb      47236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.561 0.4534 -0.0004314 1.599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 2; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,3-tetrakis(bromanyl)propane" "agn-pc-00mmli" );
standardThermochemistry
{
    dHf_298   -10490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26780.0
}
