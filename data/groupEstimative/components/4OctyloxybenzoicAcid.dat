/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-octyloxybenzoic acid  (C15H22O3, CAS 2493-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4OctyloxybenzoicAcid;
formula     C15H22O3;
CAS         2493-84-7;
InChIKey    IALWCYFULVHLEC-UHFFFAOYSA-N;
MW          250.338;      // g/mol [origin=calculated method=formula-sum]
Tc          945.92;      // K   [origin=predictive method=joback]
Pc          19.407;      // bar [origin=predictive method=joback]
omega       1.0678;      // -   [origin=predictive method=lee-kesler]
Tb          742.39;      // K   [origin=predictive method=joback]
HvapTb      71496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.253 1.27802 -0.00071796 1.411e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-octoxybenzoic acid" "4-n-octyloxybenzoic acid" "p-(octyloxy)benzoic acid" "p-octoxybenzoic acid" "p-octyloxybenzoic acid" "benzoic acid, 4-(octyloxy)-" "p-n-octyloxybenzoic acid" "4-(octyloxy)benzoic acid" "p-(n-octyloxy)benzoic acid" "benzoic acid, p-(octyloxy)-" "benzoic acid,4-(octyloxy)-" "benzoic acid, p-(octyloxy)- (8ci)" );
standardThermochemistry
{
    dHf_298   -610360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270710.0
}
