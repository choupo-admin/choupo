/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl ethyl(isopropyl)malonate  (C12H22O4, CAS 2049-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylEthylIsopropylMalonate;
formula     C12H22O4;
CAS         2049-66-3;
InChIKey    KRUDPAOHEFAZDK-UHFFFAOYSA-N;
MW          230.304;      // g/mol [origin=calculated method=formula-sum]
Tc          771.15;      // K   [origin=predictive method=joback]
Pc          18.373;      // bar [origin=predictive method=joback]
omega       0.7510;      // -   [origin=predictive method=lee-kesler]
Tb          586.93;      // K   [origin=predictive method=joback]
HvapTb      55436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.643 1.166 -0.0006148 8.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-ethyl-2-propan-2-yl-propanedioate" "diethyl ethyl(propan-2-yl)propanedioate" "diethyl 2-ethyl-2-propan-2-ylpropanedioate" );
standardThermochemistry
{
    dHf_298   -939600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     677.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-570180.0
}
