/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromo-1,1,1-trifluoropropane  (C3H3Br2F3, CAS 431-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dibromo111Trifluoropropane;
formula     C3H3Br2F3;
CAS         431-21-0;
InChIKey    XFOCTDPLVDZSGA-UHFFFAOYSA-N;
MW          255.859;      // g/mol [origin=calculated method=formula-sum]
Tc          587.39;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       0.4431;      // -   [origin=predictive method=lee-kesler]
Tb          394.70;      // K   [origin=predictive method=joback]
HvapTb      31007.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.661 0.5323 -0.0005064 1.809e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group Br; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)-1,1,1-tris(fluoranyl)propane" "xfoctdplvdzsga-uhfffaoysa-" "2,3-dibromo-1,1,1-trifluoropropane;" "propane,2,3-dibromo-1,1,1-trifluoro-" );
gibbsFormation
{
    dHf_298   -654950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-581010.0
    phase     gas;
}
