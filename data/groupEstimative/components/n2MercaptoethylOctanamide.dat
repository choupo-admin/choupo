/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-mercaptoethyl) octanamide  (C10H21NOS, CAS 56630-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2MercaptoethylOctanamide;
formula     C10H21NOS;
CAS         56630-30-9;
InChIKey    JLZORHOCSVVPHT-UHFFFAOYSA-N;
MW          203.344;      // g/mol [origin=calculated method=formula-sum]
Tc          787.44;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.8629;      // -   [origin=predictive method=lee-kesler]
Tb          595.30;      // K   [origin=predictive method=joback]
HvapTb      57773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.838 1.02932 -0.0005725 1.1486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2SH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CdO; count 1; } { group NH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-sulfanylethyl)octanamide" "octanamide, n-(2-mercaptoethyl)-" );
gibbsFormation
{
    dHf_298   -270360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23180.0
    phase     gas;
}
