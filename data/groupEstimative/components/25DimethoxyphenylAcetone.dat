/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,5-dimethoxyphenyl)acetone  (C11H14O3, CAS 14293-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DimethoxyphenylAcetone;
formula     C11H14O3;
CAS         14293-24-4;
InChIKey    RUCPISZJMCQMPY-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          795.79;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.7238;      // -   [origin=predictive method=lee-kesler]
Tb          586.63;      // K   [origin=predictive method=joback]
HvapTb      55246.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.941 0.69656 -0.00023102 -2.324e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,5-dimethoxyphenyl)propan-2-one" "2-propanone, (2,5-dimethoxy)phenyl-" "2,5-dimethoxyphenylacetone" "ambap14293-24-4" "2-propanone,1-(2,5-dimethoxyphenyl)-" );
gibbsFormation
{
    dHf_298   -433800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204030.0
    phase     gas;
}
