/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4r,5r)-4,5-di(dimethylaminocarbonyl)-2,2-dimethyldioxolane  (C11H20N2O4, CAS 111828-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4r5r45DiDimethylaminocarbonyl22Dimethyldioxolane;
formula     C11H20N2O4;
CAS         111828-49-0;
InChIKey    VCLVBIPTRZNCGF-UHFFFAOYSA-N;
MW          244.291;      // g/mol [origin=calculated method=formula-sum]
Tc          848.17;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.9157;      // -   [origin=predictive method=lee-kesler]
Tb          643.98;      // K   [origin=predictive method=joback]
HvapTb      65166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.73 1.60532 -0.0012838 4.4012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH-O; count 2; } { group CON_CH3_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n4,n4,n5,n5,2,2-hexamethyl-1,3-dioxolane-4,5-dicarboxamide" "1,3-dioxolane-4,5-dicarboxamide, n,n,n',n',2,2-hexamethyl-, (4s,5s)-" "1,3-dioxolane-4,5-dicarboxamide, n,n,n',n',2,2-hexamethyl-" "n,n,n',n',2,2-hexamethyl-1,3-dioxolane-4,5-dicarboxamide" "4-n,4-n,5-n,5-n,2,2-hexamethyl-1,3-dioxolane-4,5-dicarboxamide" );
gibbsFormation
{
    dHf_298   -589430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-151140.0
    phase     gas;
}
