/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,3r)-2,3-dimethylthiolane  (C6H12S, CAS 5161-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s3r23Dimethylthiolane;
formula     C6H12S;
CAS         5161-78-4;
InChIKey    PQAQKWCWCGKBDS-RITPCOANSA-N;
MW          116.222;      // g/mol [origin=calculated method=formula-sum]
Tc          607.86;      // K   [origin=predictive method=joback]
Pc          36.598;      // bar [origin=predictive method=joback]
omega       0.2325;      // -   [origin=predictive method=lee-kesler]
Tb          395.32;      // K   [origin=predictive method=joback]
HvapTb      34710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.29 0.69345 -0.0003933 8.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -81770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68340.0
    phase     gas;
}
