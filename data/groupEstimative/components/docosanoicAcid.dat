/*--------------------------------*- Choupo -*-----------------------*\
  Component: docosanoic acid  (C22H44O2, CAS 112-85-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        docosanoicAcid;
formula     C22H44O2;
CAS         112-85-6;
InChIKey    UKMSUNONTOPOIO-UHFFFAOYSA-N;
MW          340.592;      // g/mol [origin=calculated method=formula-sum]
Tc          1038.93;      // K   [origin=predictive method=joback]
Pc          9.520;      // bar [origin=predictive method=joback]
omega       0.9218;      // -   [origin=predictive method=lee-kesler]
Tb          848.47;      // K   [origin=predictive method=joback]
HvapTb      81730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.51 2.14462 -0.0012456 2.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "behenic acid" "1-docosanoic acid" "n-docosanoic acid" "docosoic acid" "glycon b-70" "behensaeure" "docosansaeure" "dokosansaeure" "docosanic acid" "n-docosanoate" "1-docosanoate" "glycon b 70" );
standardThermochemistry
{
    dHf_298   -847680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1066.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209550.0
}
