/*--------------------------------*- Choupo -*-----------------------*\
  Component: arecaidine  (C7H11NO2, CAS 499-04-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        arecaidine;
formula     C7H11NO2;
CAS         499-04-7;
InChIKey    DNJFTXKSFAMXQF-UHFFFAOYSA-N;
MW          141.17;      // g/mol [origin=calculated method=formula-sum]
Tc          758.32;      // K   [origin=predictive method=joback]
Pc          40.621;      // bar [origin=predictive method=joback]
omega       0.7278;      // -   [origin=predictive method=lee-kesler]
Tb          541.80;      // K   [origin=predictive method=joback]
HvapTb      51903.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.91 0.88622 -0.00064524 1.845e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3,6-dihydro-2h-pyridine-5-carboxylic acid" "methylguvacine" "arecaine" "n-methylguvacine" "1,2,5,6-tetrahydro-1-methylnicotinic acid" "1,2,5,6-tetrahydro-1-methyl-3-pyridinecarboxylic acid" "1-methyl-1,2,5,6-tetrahydropyridine-3-carboxylic acid" "nicotinic acid, 1,2,5,6-tetrahydro-1-methyl-" "hydroquinone o-" "a-d-glucopyranoside" "4-hydroxyphenyl-" "a-d-glucopyranoside" "nicotinic acid,2,5,6-tetrahydro-1-methyl-" "3-pyridinecarboxylic acid,2,5,6-tetrahydro-1-methyl-" );
standardThermochemistry
{
    dHf_298   -343420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-160480.0
}
