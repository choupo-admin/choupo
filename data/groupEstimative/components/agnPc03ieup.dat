/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-03ieup  (C8H19N, CAS 500003-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc03ieup;
formula     C8H19N;
CAS         500003-01-0;
InChIKey    KTJILDWKDVCFOT-UHFFFAOYSA-N;
MW          129.247;      // g/mol [origin=calculated method=formula-sum]
Tc          560.69;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.4282;      // -   [origin=predictive method=lee-kesler]
Tb          394.64;      // K   [origin=predictive method=joback]
HvapTb      35057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.757 0.89368 -0.0005272 1.209e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n,3-dimethyl-butan-1-amine" "ethylmethylisoamylamine" "n-ethyl-n,3-dimethylbutan-1-amine" );
gibbsFormation
{
    dHf_298   -146200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124820.0
    phase     gas;
}
