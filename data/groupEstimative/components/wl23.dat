/*--------------------------------*- Choupo -*-----------------------*\
  Component: wl 23  (C17H22N2, CAS 2598-76-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        wl23;
formula     C17H22N2;
CAS         2598-76-7;
InChIKey    ZVSDASZFAVCWIM-UHFFFAOYSA-N;
MW          254.377;      // g/mol [origin=calculated method=formula-sum]
Tc          968.60;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.9046;      // -   [origin=predictive method=lee-kesler]
Tb          741.82;      // K   [origin=predictive method=joback]
HvapTb      70472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.477 1.61932 -0.0010638 2.626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH2NH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-phenylethyl)-2-(1-phenylpropan-2-yl)diazane" "1-(alpha-methylphenethyl)-2-phenethylhydrazine" "hydrazine, 1-(alpha-methylphenethyl)-2-phenethyl-" "1-phenethyl-2-(1-phenylpropan-2-yl)hydrazine" );
standardThermochemistry
{
    dHf_298   180510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     677.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=493420.0
}
