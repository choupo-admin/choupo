/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 5-acetylsalicylate  (C10H10O4, CAS 16475-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl5Acetylsalicylate;
formula     C10H10O4;
CAS         16475-90-4;
InChIKey    XLSMGNNWSRNTIQ-UHFFFAOYSA-N;
MW          194.186;      // g/mol [origin=calculated method=formula-sum]
Tc          881.83;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.9376;      // -   [origin=predictive method=lee-kesler]
Tb          652.77;      // K   [origin=predictive method=joback]
HvapTb      67959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.96 0.88724 -0.00062742 1.7536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 5-ethanoyl-2-oxidanyl-benzoate" "methyl 5-acetyl-2-hydroxybenzoate" "methyl 5-acethylsalicylate" "5-acetyl methyl salicylate" "5-acetylsalicylic acid methyl ester" "i710" "5-acetyl-2-hydroxybenzoic acid methyl ester" "benzoic acid,5-acetyl-2-hydroxy-, methyl ester" "benzoic acid, 5-acetyl-2-hydroxy-, methyl ester" );
standardThermochemistry
{
    dHf_298   -631840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-457810.0
}
