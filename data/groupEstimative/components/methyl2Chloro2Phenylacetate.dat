/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-chloro-2-phenylacetate  (C9H9ClO2, CAS 7476-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Chloro2Phenylacetate;
formula     C9H9ClO2;
CAS         7476-66-6;
InChIKey    XOIOYHPJZJLTGK-UHFFFAOYSA-N;
MW          184.619;      // g/mol [origin=calculated method=formula-sum]
Tc          750.77;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       0.5149;      // -   [origin=predictive method=lee-kesler]
Tb          527.41;      // K   [origin=predictive method=joback]
HvapTb      49308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.58 0.73782 -0.000426 7.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-chloranyl-2-phenyl-ethanoate" "methyl chloro(phenyl)acetate" "methyl alpha-chlorophenylacetate" "methyl .alpha.-chlorophenylacetate" "methyl 2-chloro-2-phenylacetate," "methyl (2r)-chloro(phenyl)ethanoate" "2-chloro-2-phenylacetic acid methyl ester" );
gibbsFormation
{
    dHf_298   -330860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187430.0
    phase     gas;
}
