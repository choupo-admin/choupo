/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-iodocinnamic acid  (C9H7IO2, CAS 1643-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IodocinnamicAcid;
formula     C9H7IO2;
CAS         1643-34-1;
InChIKey    SBCFNNJYIXFMFS-UHFFFAOYSA-N;
MW          274.053;      // g/mol [origin=calculated method=formula-sum]
Tc          943.02;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.7421;      // -   [origin=predictive method=lee-kesler]
Tb          679.99;      // K   [origin=predictive method=joback]
HvapTb      65061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.79 0.8302 -0.00066776 2.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-iodanylphenyl)prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -160210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77890.0
    phase     gas;
}
