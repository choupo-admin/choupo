/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-thiopheneacetonitrile  (C6H5NS, CAS 13781-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Thiopheneacetonitrile;
formula     C6H5NS;
CAS         13781-53-8;
InChIKey    GWZCLMWEJWPFFA-UHFFFAOYSA-N;
MW          123.173;      // g/mol [origin=calculated method=formula-sum]
Tc          752.80;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.4421;      // -   [origin=predictive method=lee-kesler]
Tb          510.04;      // K   [origin=predictive method=joback]
HvapTb      47052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.309 0.50971 -0.00038062 1.139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2CN; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CN; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-thiophen-3-ylethanenitrile" "thiophene-3-acetonitrile" "3-thienylacetonitrile" "3-thiophene acetonitrile" "3-cyanomethylthiophene" "2-(thiophen-3-yl)acetonitrile" "2-(3-thienyl)ethanenitrile" "thien-3-ylacetonitrile" "3-(cyanomethyl)thiophene" "2-thiophen-3-ylacetonitrile" "thiophen-3-acetonitrile" "(thien-3-yl)acetonitrile" );
gibbsFormation
{
    dHf_298   227880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267230.0
    phase     gas;
}
