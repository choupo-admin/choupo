/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetophenone, 4'-(dodecyloxy)-  (C20H32O2, CAS 2175-80-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetophenone4Dodecyloxy;
formula     C20H32O2;
CAS         2175-80-6;
InChIKey    KOWOOZSAKAPHCW-UHFFFAOYSA-N;
MW          304.474;      // g/mol [origin=calculated method=formula-sum]
Tc          956.61;      // K   [origin=predictive method=joback]
Pc          12.977;      // bar [origin=predictive method=joback]
omega       0.9587;      // -   [origin=predictive method=lee-kesler]
Tb          765.15;      // K   [origin=predictive method=joback]
HvapTb      72208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.039 1.67424 -0.00089866 1.6356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-dodecoxyphenyl)ethanone" "4'-(dodecyloxy)acetophenone" "1-(4-(dodecyloxy)phenyl)ethanone" "1-acetyl-4-dodecyloxybenzene" "4'-dodecyloxyacetophenone" "ethanone, 1-(4-dodecyloxyphenyl)-" "ethanone,1-[4-(dodecyloxy)phenyl]-" "1-[4-(dodecyloxy)phenyl]ethan-1-one" "ethanone, 1-(4-(dodecyloxy)phenyl)-" "ethanone, 1-(4-(dodecyloxy)phenyl)- (9ci)" "acetophenone,4'-(dodecyloxy)- (7ci,8ci); 4-dodecyloxyacetophenone;4'-(dodecyloxy)acetophenone; p-dodecyloxyacetophenone" );
standardThermochemistry
{
    dHf_298   -475870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     860.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-13620.0
}
