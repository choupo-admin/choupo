/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethoxycinnamic acid  (C11H12O4, CAS 2316-26-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DimethoxycinnamicAcid;
formula     C11H12O4;
CAS         2316-26-9;
InChIKey    HJBWJAPEBGSQPR-GQCTYLIASA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          903.70;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.9601;      // -   [origin=predictive method=lee-kesler]
Tb          682.43;      // K   [origin=predictive method=joback]
HvapTb      65622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.0 0.79534 -0.00040612 6.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-(3,4-dimethoxyphenyl)prop-2-enoic acid" "caffeic acid dimethyl ether" "dimethyl caffeic acid" "dimethylcaffeic acid" "3,4-dimethoxy cinnamic acid" "(2e)-3-(3,4-dimethoxyphenyl)acrylic acid" "3-(3,4-dimethoxyphenyl)acrylic acid" "trans-3,4-dimethoxycinnamic acid" "(2e)-3-(3,4-dimethoxyphenyl)prop-2-enoic acid" "3-(3,4-dimethoxyphenyl)propenoic acid" "cinnamic acid,4-dimethoxy-" "(e)-3-(3,4-dimethoxyphenyl)-2-propenoic acid" );
standardThermochemistry
{
    dHf_298   -554270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-338800.0
}
