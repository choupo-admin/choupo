/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzyldimethylsilane  (C16H20Si, CAS 17964-30-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dibenzyldimethylsilane;
formula     C16H20Si;
CAS         17964-30-6;
InChIKey    PHSNFACJRATEMO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          240.421;      // g/mol [origin=calculated method=formula-sum]
Tc          857.87;      // K   [origin=predictive method=joback]
Pc          20.438;      // bar [origin=predictive method=joback]
omega       0.4691;      // -   [origin=predictive method=lee-kesler]
Tb          620.44;      // K   [origin=predictive method=joback]
HvapTb      56056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.648 1.15984 -0.0004942 1.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 10; } { group ACCH2; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl-bis(phenylmethyl)silane" "silane, dimethylbis(phenylmethyl)-" "benzene, 1,1'-((dimethylsilylene)bis(methylene))bis-" "benzene, 1,1'-[(dimethylsilylene)bis(methylene)]bis-" "dibenzyl(dimethyl)silane" "dibenzyl dimethyl silane" "benzene,1,1'-[(dimethylsilylene)bis(methylene)]bis-" "silane,dibenzyldimethyl- (7ci,8ci); silane, dimethylbis(phenylmethyl)- (9ci);dibenzyldimethylsilane" );
gibbsFormation
{
    dHf_298   -12130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203900.0
    phase     gas;
}
