/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-diethenylnaphthalene  (C14H12, CAS 17935-66-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Diethenylnaphthalene;
formula     C14H12;
CAS         17935-66-9;
InChIKey    FTUDIUREWUBVKL-UHFFFAOYSA-N;
MW          180.25;      // g/mol [origin=calculated method=formula-sum]
Tc          801.92;      // K   [origin=predictive method=joback]
Pc          26.791;      // bar [origin=predictive method=joback]
omega       0.4918;      // -   [origin=predictive method=lee-kesler]
Tb          568.90;      // K   [origin=predictive method=joback]
HvapTb      50658.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.57 1.0922 -0.00081744 2.47e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group ACH; count 6; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-bis(ethenyl)naphthalene" "naphthalene, 1,8-diethenyl-" "1,8-divinylnaphthalene" );
gibbsFormation
{
    dHf_298   323230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=442480.0
    phase     gas;
}
