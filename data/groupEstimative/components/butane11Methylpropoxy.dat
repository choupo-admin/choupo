/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, 1-(1-methylpropoxy)-  (C8H18O, CAS 999-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane11Methylpropoxy;
formula     C8H18O;
CAS         999-65-5;
InChIKey    LPVMPBNUHJKNHA-UHFFFAOYSA-N;
MW          130.231;      // g/mol [origin=calculated method=formula-sum]
Tc          572.32;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.4443;      // -   [origin=predictive method=lee-kesler]
Tb          404.62;      // K   [origin=predictive method=joback]
HvapTb      35424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.434 0.70656 -0.0003036 2.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butan-2-yloxybutane" "1-sec-butoxybutane" );
gibbsFormation
{
    dHf_298   -345950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90960.0
    phase     gas;
}
