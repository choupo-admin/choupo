/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-cyclodecanedione  (C10H16O2, CAS 38734-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Cyclodecanedione;
formula     C10H16O2;
CAS         38734-05-3;
InChIKey    KBSGQTAYVRWUEO-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          868.12;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.4782;      // -   [origin=predictive method=lee-kesler]
Tb          605.34;      // K   [origin=predictive method=joback]
HvapTb      47774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.37 0.7274 1.7e-05 -2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclodecane-1,6-dione" );
standardThermochemistry
{
    dHf_298   -475110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228100.0
}
