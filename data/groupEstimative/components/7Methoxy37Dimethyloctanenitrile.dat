/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methoxy-3,7-dimethyloctanenitrile  (C11H21NO, CAS 69300-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methoxy37Dimethyloctanenitrile;
formula     C11H21NO;
CAS         69300-17-0;
InChIKey    IUVOEDXVVOJVDB-UHFFFAOYSA-N;
MW          183.295;      // g/mol [origin=calculated method=formula-sum]
Tc          764.15;      // K   [origin=predictive method=joback]
Pc          19.086;      // bar [origin=predictive method=joback]
omega       0.6507;      // -   [origin=predictive method=lee-kesler]
Tb          572.11;      // K   [origin=predictive method=joback]
HvapTb      51284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.234 1.05218 -0.0006076 1.3e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH3O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methoxy-3,7-dimethyl-octanenitrile" "octanenitrile, 7-methoxy-3,7-dimethyl-" "3,7-dimethyl-7-methoxyoctanonitrile" "octanenitrile,7-methoxy-3,7-dimethyl-" );
gibbsFormation
{
    dHf_298   -251740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70320.0
    phase     gas;
}
