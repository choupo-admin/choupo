/*--------------------------------*- Choupo -*-----------------------*\
  Component: aroclor 5460  (C18H5Cl9, CAS 11126-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aroclor5460;
formula     C18H5Cl9;
CAS         11126-42-4;
InChIKey    PPBRFJLRPRQPEC-UHFFFAOYSA-N;
MW          540.288;      // g/mol [origin=calculated method=formula-sum]
Tc          1363.27;      // K   [origin=predictive method=joback]
Pc          16.852;      // bar [origin=predictive method=joback]
omega       1.0432;      // -   [origin=predictive method=lee-kesler]
Tb          1078.15;      // K   [origin=predictive method=joback]
HvapTb      108575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (143.82 0.9433 -0.0005622 1.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 4; } { group ACCl; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 13; } { group Cl; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,4-tris(chloranyl)-5-[2,3,5-tris(chloranyl)phenyl]-2-[3,4,5-tris(chloranyl)phenyl]benzene" "1,3,4-trichloro-5-(2,3,5-trichlorophenyl)-2-(3,4,5-trichlorophenyl)benzene" );
gibbsFormation
{
    dHf_298   38380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     776.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=234240.0
    phase     gas;
}
