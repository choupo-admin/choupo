/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,4-dihydroxyphenyl)-2-phenylethanone  (C14H12O3, CAS 3669-41-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124Dihydroxyphenyl2Phenylethanone;
formula     C14H12O3;
CAS         3669-41-8;
InChIKey    VFQKAJVKZKHVPD-UHFFFAOYSA-N;
MW          228.247;      // g/mol [origin=calculated method=formula-sum]
Tc          1048.55;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       1.1506;      // -   [origin=predictive method=lee-kesler]
Tb          788.39;      // K   [origin=predictive method=joback]
HvapTb      84084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.129 1.4572 -0.00129422 4.6356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,4-bis(oxidanyl)phenyl]-2-phenyl-ethanone" "benzyl 2,4-dihydroxyphenyl ketone" "2',4'-dihydroxy-2-phenylacetophenone" "2,4-dihydroxyphenylbenzyl ketone" "1-(2,4-dihydroxyphenyl)-2-phenylethan-1-one" "bim-0026207.p001" "ethanone,1-(2,4-dihydroxyphenyl)-2-phenyl-" );
standardThermochemistry
{
    dHf_298   -326430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146340.0
}
