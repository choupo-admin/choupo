/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylene-2,6-heptanedione  (C8H12O2, CAS 22289-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylene26Heptanedione;
formula     C8H12O2;
CAS         22289-05-0;
InChIKey    FFPAMXZGKPTNDP-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          680.08;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.6041;      // -   [origin=predictive method=lee-kesler]
Tb          486.94;      // K   [origin=predictive method=joback]
HvapTb      46304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.652 0.68774 -0.0003992 8.512e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 1; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylideneheptane-2,6-dione" "2,6-heptanedione,3-methylene-" );
standardThermochemistry
{
    dHf_298   -317970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162070.0
}
