/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenepropanal,2-methyl-  (C10H12O, CAS 19564-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenepropanal2Methyl;
formula     C10H12O;
CAS         19564-40-0;
InChIKey    CIHMXRXLWPQFTH-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          719.50;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.5438;      // -   [origin=predictive method=lee-kesler]
Tb          508.72;      // K   [origin=predictive method=joback]
HvapTb      47512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.408 0.78992 -0.00047736 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylphenyl)propanal" "3-(2-methylphenyl)propionaldehyde" "3-o-tolylpropanal" "3-o-tolyl-propionaldehyde" "hydrocinnamaldehyde,o-methyl- (6ci,7ci,8ci)" );
standardThermochemistry
{
    dHf_298   -110250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36580.0
}
