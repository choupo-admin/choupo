/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethylpyrrolidine  (C6H13N, CAS 3437-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethylpyrrolidine;
formula     C6H13N;
CAS         3437-30-7;
InChIKey    XBQNZPDIRJPFAI-UHFFFAOYSA-N;
MW          99.177;      // g/mol [origin=calculated method=formula-sum]
Tc          615.83;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.2815;      // -   [origin=predictive method=lee-kesler]
Tb          400.95;      // K   [origin=predictive method=joback]
HvapTb      34814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.12 0.98404 -0.000902 3.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrrolidine, 3,3-dimethyl-" "3,3-dimethyl-pyrrolidine" );
gibbsFormation
{
    dHf_298   -53640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118410.0
    phase     gas;
}
