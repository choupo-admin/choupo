/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-nonyloxyaniline  (C15H25NO, CAS 50262-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pNonyloxyaniline;
formula     C15H25NO;
CAS         50262-67-4;
InChIKey    JQLBBFVOAHUASD-UHFFFAOYSA-N;
MW          235.371;      // g/mol [origin=calculated method=formula-sum]
Tc          868.56;      // K   [origin=predictive method=joback]
Pc          18.871;      // bar [origin=predictive method=joback]
omega       0.8734;      // -   [origin=predictive method=lee-kesler]
Tb          669.41;      // K   [origin=predictive method=joback]
HvapTb      64973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.638 1.28912 -0.00068876 1.241e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-nonoxyaniline" "4-n-nonyloxyaniline" "4-nonyloxyphenylamine" "4-nonyloxyaniline" "benzenamine,4-(nonyloxy)-" "4-n-nonyloxyaniline, 98%" "4-(nonyloxy)aniline;p-nonyloxyaniline;" );
gibbsFormation
{
    dHf_298   -226300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139650.0
    phase     gas;
}
