/*--------------------------------*- Choupo -*-----------------------*\
  Component: disilane,1,1,2,2-tetramethyl-1,2-di-1-naphthalenyl-  (C24H26Si2, CAS 38446-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H26Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        disilane1122Tetramethyl12Di1Naphthalenyl;
formula     C24H26Si2;
CAS         38446-41-2;
InChIKey    RLWPPMCLXCJLGQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          370.642;      // g/mol [origin=calculated method=formula-sum]
Tc          1113.38;      // K   [origin=predictive method=joback]
Pc          14.348;      // bar [origin=predictive method=joback]
omega       0.6430;      // -   [origin=predictive method=lee-kesler]
Tb          852.80;      // K   [origin=predictive method=joback]
HvapTb      78762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.39 1.58728 -0.00065396 3.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 14; } { group AC; count 6; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 14; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[dimethyl(naphthalen-1-yl)silyl]-dimethyl-naphthalen-1-yl-silane" "1,1,2,2-tetramethyl-1,2-di(naphthalen-1-yl)disilane" "[dimethyl(naphthalen-1-yl)silyl]-dimethyl-naphthalen-1-ylsilane" );
standardThermochemistry
{
    dHf_298   70330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     900.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360540.0
}
