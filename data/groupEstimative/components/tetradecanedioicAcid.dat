/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecanedioic acid  (C14H26O4, CAS 821-38-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecanedioicAcid;
formula     C14H26O4;
CAS         821-38-5;
InChIKey    HQHCYKULIHKCEB-UHFFFAOYSA-N;
MW          258.358;      // g/mol [origin=calculated method=formula-sum]
Tc          1004.51;      // K   [origin=predictive method=joback]
Pc          17.595;      // bar [origin=predictive method=joback]
omega       1.3205;      // -   [origin=predictive method=lee-kesler]
Tb          810.94;      // K   [origin=predictive method=joback]
HvapTb      81086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.638 1.4354 -0.000883 2.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,12-dodecanedicarboxylic acid" "tetradecane-1,14-dioic acid" "1,14-tetradecanedioic acid" "dodecanedicarboxylic acid" "1,12-dodecanedicarboxylicacid" "dodecamethylenedicarboxylic acid" "tetradecanedicarboxylate" "1,14-tetradecanedioate" "tetradecane-1,14-dioate" "dodecamethylenedicarboxylate" "tetradecanedicarboxylic acid" "1,12-dodecanedicarboxylate" );
standardThermochemistry
{
    dHf_298   -1032830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     807.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-620820.0
}
