/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-diethyl-3-heptene  (C11H22, CAS 50787-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Diethyl3Heptene;
formula     C11H22;
CAS         50787-14-9;
InChIKey    FJWPLVKSMFSXFQ-UHFFFAOYSA-N;
MW          154.297;      // g/mol [origin=calculated method=formula-sum]
Tc          630.63;      // K   [origin=predictive method=joback]
Pc          20.438;      // bar [origin=predictive method=joback]
omega       0.4582;      // -   [origin=predictive method=lee-kesler]
Tb          455.20;      // K   [origin=predictive method=joback]
HvapTb      40198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.675 1.06868 -0.000663 1.707e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-diethylhept-3-ene" "c2h5ch2c(c2h5)=c(c2h5)2" );
gibbsFormation
{
    dHf_298   -172730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104860.0
    phase     gas;
}
