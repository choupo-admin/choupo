/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl 4-aminobenzoate  (C19H31NO2, CAS 20043-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecyl4Aminobenzoate;
formula     C19H31NO2;
CAS         20043-94-1;
InChIKey    IXYYMEVNJZMVBN-UHFFFAOYSA-N;
MW          305.462;      // g/mol [origin=calculated method=formula-sum]
Tc          994.98;      // K   [origin=predictive method=joback]
Pc          14.091;      // bar [origin=predictive method=joback]
omega       1.0376;      // -   [origin=predictive method=lee-kesler]
Tb          796.73;      // K   [origin=predictive method=joback]
HvapTb      78874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.089 1.67752 -0.00092276 1.694e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl 4-azanylbenzoate" "dodecyl-p-aminobenzoate" "benzoic acid, 4-amino-, dodecyl ester" );
gibbsFormation
{
    dHf_298   -493920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     886.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32040.0
    phase     gas;
}
