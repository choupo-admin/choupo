/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5,6,7,8-octahydrophenanthrene  (C14H18, CAS 5325-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12345678Octahydrophenanthrene;
formula     C14H18;
CAS         5325-97-3;
InChIKey    YSZLFGZFQTTZIQ-UHFFFAOYSA-N;
MW          186.298;      // g/mol [origin=calculated method=formula-sum]
Tc          836.68;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.5010;      // -   [origin=predictive method=lee-kesler]
Tb          592.90;      // K   [origin=predictive method=joback]
HvapTb      51808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.45 1.412 -0.00102628 3.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 2; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenanthrene, 1,2,3,4,5,6,7,8-octahydro-" "1,3,4,5,6,7,8-octahydrophenanthrene" "phenanthrene,2,3,4,5,6,7,8-octahydro-" );
gibbsFormation
{
    dHf_298   43790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263240.0
    phase     gas;
}
