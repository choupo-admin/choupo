/*--------------------------------*- Choupo -*-----------------------*\
  Component: aldimorph  (C18H37NO, CAS 106788-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aldimorph;
formula     C18H37NO;
CAS         106788-55-0;
InChIKey    SBUKOHLFHYSZNG-UHFFFAOYSA-N;
MW          283.5;      // g/mol [origin=calculated method=formula-sum]
Tc          836.40;      // K   [origin=predictive method=joback]
Pc          12.664;      // bar [origin=predictive method=joback]
omega       0.8258;      // -   [origin=predictive method=lee-kesler]
Tb          661.44;      // K   [origin=predictive method=joback]
HvapTb      62163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.389 1.93996 -0.0011261 2.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group CH-O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 11; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-dodecyl-2,6-dimethyl-morpholine" "aldimorph [iso]" "4-dodecyl-2,6-dimethylmorpholine" "morpholine, 4-dodecyl-2,6-dimethyl-" "agn-pc-00kqyw" "morpholine,4-dodecyl-2,6-dimethyl-, (2r,6s)-rel-" );
gibbsFormation
{
    dHf_298   -439180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     729.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154180.0
    phase     gas;
}
