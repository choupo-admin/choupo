/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)acetamide  (C4H9NO2, CAS 142-26-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxyethylAcetamide;
formula     C4H9NO2;
CAS         142-26-7;
InChIKey    PVCJKHHOXFKFRP-UHFFFAOYSA-N;
MW          103.121;      // g/mol [origin=calculated method=formula-sum]
Tc          664.60;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       1.0083;      // -   [origin=predictive method=lee-kesler]
Tb          487.34;      // K   [origin=predictive method=joback]
HvapTb      54359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.692 0.46602 -0.0002541 4.766e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group OH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)ethanamide" "n-acetylethanolamine" "2-acetamidoethanol" "acetamide, n-(2-hydroxyethyl)-" "acetylcolamine" "n-ethanolacetamide" "2-acetylaminoethanol" "n-acetyl-2-aminoethanol" "n-2-hydroxyethylacetamide" "acetamide mea" ".beta.-hydroxyethylacetamide" "hydroxyethyl acetamide" );
gibbsFormation
{
    dHf_298   -337230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193550.0
    phase     gas;
}
