/*--------------------------------*- Choupo -*-----------------------*\
  Component: sulfonyldiacetic acid  (C4H6O6S, CAS 123-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H6O6S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        sulfonyldiaceticAcid;
formula     C4H6O6S;
CAS         123-45-5;
InChIKey    WDYRPTWUNMHTJL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.146;      // g/mol [origin=calculated method=formula-sum]
Tc          747.89;      // K   [origin=predictive method=joback]
Pc          57.566;      // bar [origin=predictive method=joback]
omega       1.3122;      // -   [origin=predictive method=lee-kesler]
Tb          561.14;      // K   [origin=predictive method=joback]
HvapTb      70644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.092 0.5246 -0.0003136 5.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxy-2-oxoethylsulfonyl)ethanoic acid" "carboxymethanesulfonyl-acetic acid" "acetic acid, sulfonyldi-" "bis(carboxymethyl) sulfone" "2,2'-sulfonyldiacetic acid" "sulfonediacetic acid" "sulfonyldiacetic acid [mi]" "acetic acid,2'-sulfonylbis-" "acetic acid,2,2'-sulfonylbis-" "acetic acid, 2,2'-sulfonylbis-" "2-(carboxymethylsulfonyl)acetic acid" "2-[(carboxymethyl)sulfonyl]acetic acid" );
gibbsFormation
{
    dHf_298   -1321650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     676.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1206680.0
    phase     gas;
}
