/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl camphorate  (C12H20O4, CAS 15797-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylCamphorate;
formula     C12H20O4;
CAS         15797-21-4;
InChIKey    JTQKJWYDOXYYBH-UHFFFAOYSA-N;
MW          228.288;      // g/mol [origin=calculated method=formula-sum]
Tc          805.62;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       0.6474;      // -   [origin=predictive method=lee-kesler]
Tb          597.02;      // K   [origin=predictive method=joback]
HvapTb      54457.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.79 1.6968 -0.0015216 5.965e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 1,2,2-trimethylcyclopentane-1,3-dicarboxylate" "camphoric acid, dimethyl ester" "methyl 3-(methoxycarbonyl)-2,2,3-trimethylcyclopentanecarboxylate" "1,3-dimethyl 1,2,2-trimethylcyclopentane-1,3-dicarboxylate" "1,3-cyclopentanedicarboxylic acid, 1,2,2-trimethyl-, dimethyl ester" );
gibbsFormation
{
    dHf_298   -875290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     729.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-560430.0
    phase     gas;
}
