/*--------------------------------*- Choupo -*-----------------------*\
  Component: silacyclopent-3-ene,1,1-dimethyl-  (C6H12Si, CAS 16054-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H12Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silacyclopent3Ene11Dimethyl;
formula     C6H12Si;
CAS         16054-12-9;
InChIKey    PBYZVYQHXMJOLS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          112.247;      // g/mol [origin=calculated method=formula-sum]
Tc          549.89;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.1757;      // -   [origin=predictive method=lee-kesler]
Tb          353.12;      // K   [origin=predictive method=joback]
HvapTb      29930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.27 0.47944 -0.00010428 -5.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethyl-2,5-dihydrosilole" "1,1-dimethyl-1-silacyclo-3-pentene" "silacyclopent-2-ene,1,1-dimethyl-" "silacyclopent-2-ene, 1,1-dimethyl-" "1,1-dimethyl-1-silacyclo-3-pentene;1,1-dimethyl-1-silacyclopentene-3; 1,1-dimethyl-3-silacyclopentene" );
standardThermochemistry
{
    dHf_298   -134030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18800.0
}
