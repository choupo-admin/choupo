/*--------------------------------*- Choupo -*-----------------------*\
  Component: 18-pentatriacontanone  (C35H70O, CAS 504-53-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Pentatriacontanone;
formula     C35H70O;
CAS         504-53-0;
InChIKey    DMCJFWXGXUEHFD-UHFFFAOYSA-N;
MW          506.944;      // g/mol [origin=calculated method=formula-sum]
Tc          1349.42;      // K   [origin=predictive method=joback]
Pc          4.906;      // bar [origin=predictive method=joback]
omega       0.0411;      // -   [origin=predictive method=lee-kesler]
Tb          1054.27;      // K   [origin=predictive method=joback]
HvapTb      100250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.568 3.30084 -0.0018615 3.9626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 31; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 32; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentatriacontan-18-one" "stearone" "di-n-heptadecyl ketone" "heptadecyl ketone" "diheptadecyl ketone" );
gibbsFormation
{
    dHf_298   -878310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1546.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114900.0
    phase     gas;
}
