/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-chloro-4-fluorophenyl)cyclohexanecarboxylic acid  (C13H14ClFO2, CAS 214263-02-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Chloro4FluorophenylCyclohexanecarboxylicAcid;
formula     C13H14ClFO2;
CAS         214263-02-2;
InChIKey    LASDSPQVVMYXNX-UHFFFAOYSA-N;
MW          256.701;      // g/mol [origin=calculated method=formula-sum]
Tc          982.01;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       0.8668;      // -   [origin=predictive method=lee-kesler]
Tb          735.68;      // K   [origin=predictive method=joback]
HvapTb      68142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.25 1.5243 -0.00130352 4.694e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chloranyl-4-fluoranyl-phenyl)cyclohexane-1-carboxylic acid" "1-(2-chloro-4-fluorophenyl)cyclohexanecarboxylic acid;" "cyclohexanecarboxylicacid, 1-(2-chloro-4-fluorophenyl)-" "1-(2-chloro-4-fluorophenyl)cyclohexane-1-carboxylic acid" );
gibbsFormation
{
    dHf_298   -590620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-379960.0
    phase     gas;
}
