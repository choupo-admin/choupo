/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-allyl-2-methylbenzene  (C10H12, CAS 1587-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Allyl2Methylbenzene;
formula     C10H12;
CAS         1587-04-8;
InChIKey    SVIHJJUMPAUQNO-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          667.37;      // K   [origin=predictive method=joback]
Pc          30.190;      // bar [origin=predictive method=joback]
omega       0.3654;      // -   [origin=predictive method=lee-kesler]
Tb          456.74;      // K   [origin=predictive method=joback]
HvapTb      40122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.799 0.79542 -0.00050726 1.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2-prop-2-enyl-benzene" "toluene, o-allyl-" "benzene, 1-methyl-2-(2-propenyl)-" "2-allyltoluene" "2-(allyl)toluene" "o-allyltoluene" "2-allyl-1-methylbenzene" "benzene, methyl(2-propenyl)-" "1-methyl-2-prop-2-enylbenzene" "3-(2-methylphenyl)-1-propene" "1-methyl-2-(2-propenyl)benzene" "1-methyl-2-(prop-2-en-1-yl)benzene" );
standardThermochemistry
{
    dHf_298   100760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223940.0
}
