/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzyl succinate  (C18H18O4, CAS 103-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzylSuccinate;
formula     C18H18O4;
CAS         103-43-5;
InChIKey    ODBOBZHTGBGYCK-UHFFFAOYSA-N;
MW          298.338;      // g/mol [origin=calculated method=formula-sum]
Tc          1005.76;      // K   [origin=predictive method=joback]
Pc          19.338;      // bar [origin=predictive method=joback]
omega       0.9620;      // -   [origin=predictive method=lee-kesler]
Tb          781.24;      // K   [origin=predictive method=joback]
HvapTb      75028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.466 1.4464 -0.0008286 1.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH2; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(phenylmethyl) butanedioate" "dibenzyl butanedioate" "butanedioic acid, bis(phenylmethyl) ester" "diphenylmethyl butane-1,4-dioate" "spasmine" "succinic acid, dibenzyl ester" "benzyl succinate" "dibenzyl-succinate" "succinic acid dibenzyl ester" "odbobzhtgbgyck-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -576350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295240.0
}
