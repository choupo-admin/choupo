/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-(trans-4-propylcyclohexyl)-, trans-4-propylcyclohexyl ester  (C25H38O2, CAS 72983-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Trans4PropylcyclohexylTrans4PropylcyclohexylEste;
formula     C25H38O2;
CAS         72983-69-8;
InChIKey    DABPIGVWYIYREQ-UHFFFAOYSA-N;
MW          370.577;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.11;      // K   [origin=predictive method=joback]
Pc          11.468;      // bar [origin=predictive method=joback]
omega       0.8247;      // -   [origin=predictive method=lee-kesler]
Tb          891.24;      // K   [origin=predictive method=joback]
HvapTb      81829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.366 2.37684 -0.00125696 1.926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-propylcyclohexyl) 4-(4-propylcyclohexyl)benzoate" "4-(4-propyl-cyclohexyl)-benzoic acid 4-propyl-cyclohexyl ester" "trans-4-propylcyclohexyl 4-trans-(4-propylcyclohexyl)benzoate" "4-propylcyclohexyl (trans(trans))-4-(4-propylcyclohexyl)benzoate" );
gibbsFormation
{
    dHf_298   -583590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     922.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14490.0
    phase     gas;
}
