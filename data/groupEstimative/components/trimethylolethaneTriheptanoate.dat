/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolethane triheptanoate  (C26H48O6, CAS 23336-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolethaneTriheptanoate;
formula     C26H48O6;
CAS         23336-49-4;
InChIKey    ZMAZJSDJZUMVHX-UHFFFAOYSA-N;
MW          456.664;      // g/mol [origin=calculated method=formula-sum]
Tc          1188.71;      // K   [origin=predictive method=joback]
Pc          7.384;      // bar [origin=predictive method=joback]
omega       0.6417;      // -   [origin=predictive method=lee-kesler]
Tb          965.91;      // K   [origin=predictive method=joback]
HvapTb      94395.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.008 2.43528 -0.0012786 1.988e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 15; } { group C; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 18; } { group C; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-heptanoyloxy-2-(heptanoyloxymethyl)-2-methyl-propyl] heptanoate" "3-(heptanoyloxy)-2-[(heptanoyloxy)methyl]-2-methylpropyl heptanoate" "heptanoic acid, 1,1'-(2-methyl-2-(((1-oxoheptyl)oxy)methyl)-1,3-propanediyl) ester" "heptanoic acid, 1,1'-[2-methyl-2-[[(1-oxoheptyl)oxy]methyl]-1,3-propanediyl] ester" "[3-heptanoyloxy-2-(heptanoyloxymethyl)-2-methylpropyl] heptanoate" "heptanoic acid [2-methyl-3-(1-oxoheptoxy)-2-(1-oxoheptoxymethyl)propyl] ester" "heptanoic acid, 2-methyl-2-(((1-oxoheptyl)oxy)methyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -1540560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1283.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-760230.0
    phase     gas;
}
