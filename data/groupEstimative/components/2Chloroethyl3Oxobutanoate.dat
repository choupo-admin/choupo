/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethyl 3-oxobutanoate  (C6H9ClO3, CAS 54527-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloroethyl3Oxobutanoate;
formula     C6H9ClO3;
CAS         54527-68-3;
InChIKey    JAEUQHNZRROYID-UHFFFAOYSA-N;
MW          164.585;      // g/mol [origin=calculated method=formula-sum]
Tc          677.89;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.6439;      // -   [origin=predictive method=lee-kesler]
Tb          486.40;      // K   [origin=predictive method=joback]
HvapTb      47488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.093 0.49782 -0.0002097 3.06e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group Cl; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloroethyl 3-oxidanylidenebutanoate" "2-chloroethyl acetoacetate" "butanoic acid, 3-oxo-, 2-chloroethyl ester" "3-oxobutyric acid, 2-chloroethyl ester" "3-oxo-butyric acid 2-chloro-ethyl ester" );
standardThermochemistry
{
    dHf_298   -612770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-451580.0
}
