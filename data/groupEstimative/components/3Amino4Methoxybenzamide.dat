/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-4-methoxybenzamide  (C8H10N2O2, CAS 17481-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino4Methoxybenzamide;
formula     C8H10N2O2;
CAS         17481-27-5;
InChIKey    INCJNDAQNPWMPZ-UHFFFAOYSA-N;
MW          166.18;      // g/mol [origin=calculated method=formula-sum]
Tc          879.62;      // K   [origin=predictive method=joback]
Pc          42.999;      // bar [origin=predictive method=joback]
omega       0.8905;      // -   [origin=predictive method=lee-kesler]
Tb          640.63;      // K   [origin=predictive method=joback]
HvapTb      67440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.15 0.59852 -0.00026562 1.786e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 1; } { group ACNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-4-methoxy-benzamide" "3-amino-p-anisamide" "3-amino-4-methoxy-benzamide" "benzamide, 3-amino-4-methoxy-" "incjndaqnpwmpz-uhfffaoysa-" "sdccgmls-0006111.p002" "i273" "p-anisamide,3-amino- (6ci,8ci);(3-amino-4-methoxybenzoyl)amine;3-amino-4-methoxybenzoic acid amide;benzamide, 3-amino-4-methoxy-;" );
standardThermochemistry
{
    dHf_298   -172080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8610.0
}
