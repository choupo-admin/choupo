/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4,6-difluoroaniline  (C6H4BrF2N, CAS 444-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo46Difluoroaniline;
formula     C6H4BrF2N;
CAS         444-14-4;
InChIKey    WUJKFVGKLTWVSQ-UHFFFAOYSA-N;
MW          208.005;      // g/mol [origin=calculated method=formula-sum]
Tc          742.13;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       0.6165;      // -   [origin=predictive method=lee-kesler]
Tb          515.73;      // K   [origin=predictive method=joback]
HvapTb      48654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.29 0.4401 -0.00028028 6.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACNH2; count 1; } { group Br; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 2; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4,6-bis(fluoranyl)aniline" "2,4-difluoro-6-bromoaniline" "2-bromo-4,6-difluoro-phenylamine" "2-bromo-4,6-difluorobenzenamine" "6-bromo-2,4-difluoroaniline" "2-bromo-4,6-difluorophenylamine" "444-14-4 2-bromo-4,6-difluoroaniline" "wujkfvgkltwvsq-uhfffaoysa-" "wt448" "benzenamine, 2-bromo-4,6-difluoro-" "n638" "6-bromo-2,4-difluoroaniline;2,4-difluoro-6-bromoaniline;2-bromo-4,6-difluorobenzenamine;" );
gibbsFormation
{
    dHf_298   -297150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-225690.0
    phase     gas;
}
