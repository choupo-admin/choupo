/*--------------------------------*- Choupo -*-----------------------*\
  Component: isodecyl 3-mercaptopropionate  (C13H26O2S, CAS 68908-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isodecyl3Mercaptopropionate;
formula     C13H26O2S;
CAS         68908-14-5;
InChIKey    QIKRYNCEAIKQEH-UHFFFAOYSA-N;
MW          246.409;      // g/mol [origin=calculated method=formula-sum]
Tc          802.30;      // K   [origin=predictive method=joback]
Pc          17.521;      // bar [origin=predictive method=joback]
omega       0.8149;      // -   [origin=predictive method=lee-kesler]
Tb          617.68;      // K   [origin=predictive method=joback]
HvapTb      58288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.689 1.21724 -0.0006144 9.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methylnonyl 3-sulfanylpropanoate" "propanoic acid, 3-mercapto-, isodecyl ester" "isodecyl beta-mercaptopropionate" );
standardThermochemistry
{
    dHf_298   -595730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     766.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224840.0
}
