/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,3,5,5,5-heptamethyl-3-phenyltrisiloxane  (C13H26O2Si3, CAS 546-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H26O2Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1113555Heptamethyl3Phenyltrisiloxane;
formula     C13H26O2Si3;
CAS         546-44-1;
InChIKey    FNATTZRLLOIKNY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          298.604;      // g/mol [origin=calculated method=formula-sum]
Tc          784.77;      // K   [origin=predictive method=joback]
Pc          15.635;      // bar [origin=predictive method=joback]
omega       0.3835;      // -   [origin=predictive method=lee-kesler]
Tb          572.76;      // K   [origin=predictive method=joback]
HvapTb      52510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (130.62 0.41504 0.0007518 -5.922e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group ACH; count 5; } { group AC; count 1; } { group Si; count 1; } { group SiO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-(methyl-phenyl-trimethylsilyloxy-silyl)oxy-silane" "trimethyl-(methyl-phenyl-trimethylsilyloxysilyl)oxysilane" );
standardThermochemistry
{
    dHf_298   -674420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     957.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-353290.0
}
