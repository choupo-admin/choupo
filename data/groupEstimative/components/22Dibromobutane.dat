/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dibromobutane  (C4H8Br2, CAS 50341-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dibromobutane;
formula     C4H8Br2;
CAS         50341-35-0;
InChIKey    XWDSASBQVXXTNE-UHFFFAOYSA-N;
MW          215.916;      // g/mol [origin=calculated method=formula-sum]
Tc          641.42;      // K   [origin=predictive method=joback]
Pc          47.892;      // bar [origin=predictive method=joback]
omega       0.3496;      // -   [origin=predictive method=lee-kesler]
Tb          420.21;      // K   [origin=predictive method=joback]
HvapTb      36072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.839 0.58604 -0.0005084 1.765e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(bromanyl)butane" "butane, 2,2-dibromo-" );
standardThermochemistry
{
    dHf_298   -81980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14280.0
}
