/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-diamino-9-hydroxy-11-oxa-1,14-bis(trimethoxysilyl)tetradecane  (C17H42N2O8Si2, CAS 125252-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C17H42N2O8Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        47Diamino9Hydroxy11Oxa114BisTrimethoxysilylTetradecane;
formula     C17H42N2O8Si2;
CAS         125252-55-3;
InChIKey    FJBBHCYRBVQYFF-QGZVFWFLSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          458.699;      // g/mol [origin=calculated method=formula-sum]
Tc          1156.08;      // K   [origin=predictive method=joback]
Pc          10.521;      // bar [origin=predictive method=joback]
omega       0.9661;      // -   [origin=predictive method=lee-kesler]
Tb          940.38;      // K   [origin=predictive method=joback]
HvapTb      100057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (248.76 0.95642 0.0005748 -5.966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH3O; count 6; } { group CH2NH; count 2; } { group Si; count 2; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 10; } { group CH; count 1; } { group OH; count 1; } { group O; count 7; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-1-(3-trimethoxysilylpropoxy)-3-[2-(3-trimethoxysilylpropylamino)ethylamino]propan-2-ol" "2,7,19-trioxa-11,14-diaza-3,18-disilaeicosan-9-ol, 3,3,18,18-tetramethoxy-" );
gibbsFormation
{
    dHf_298   -1593560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1272.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-812740.0
    phase     gas;
}
