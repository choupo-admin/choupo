/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexene, 6-phenyl-  (C12H16, CAS 23086-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexene6Phenyl;
formula     C12H16;
CAS         23086-43-3;
InChIKey    ORKBJNQAFQMOGC-NSCUHMNNSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          713.77;      // K   [origin=predictive method=joback]
Pc          25.328;      // bar [origin=predictive method=joback]
omega       0.4518;      // -   [origin=predictive method=lee-kesler]
Tb          505.00;      // K   [origin=predictive method=joback]
HvapTb      44540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.107 1.08492 -0.000744 2.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-hex-4-enyl]benzene" "benzene, 4-hexenyl-" "trans-6-phenyl-2-hexene" "[(e)-hex-4-enyl]-benzene" );
standardThermochemistry
{
    dHf_298   62740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242790.0
}
