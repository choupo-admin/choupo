/*--------------------------------*- Choupo -*-----------------------*\
  Component: butacaine  (C18H30N2O2, CAS 149-16-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butacaine;
formula     C18H30N2O2;
CAS         149-16-6;
InChIKey    HQFWVSGBVLEQGA-UHFFFAOYSA-N;
MW          306.45;      // g/mol [origin=calculated method=formula-sum]
Tc          984.11;      // K   [origin=predictive method=joback]
Pc          15.140;      // bar [origin=predictive method=joback]
omega       1.0710;      // -   [origin=predictive method=lee-kesler]
Tb          786.29;      // K   [origin=predictive method=joback]
HvapTb      78691.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.871 1.70644 -0.00098096 1.949e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dibutylamino)propyl 4-azanylbenzoate" "1-propanol, 3-(dibutylamino)-, 4-aminobenzoate (ester)" "butacaine [inn:ban]" "butacainum [inn-latin]" "3-(dibutylamino)propyl 4-aminobenzoate" "p-aminobenzoyldibutylaminopropanol" "3-dibutylaminopropyl p-aminobenzoate" "3-(dibutylamino)-1-propanol p-aminobenzoate" "3-(p-aminobenzoxy)-1-di-n-butylaminopropane" "1-propanol, 3-(dibutylamino)-, p-aminobenzoate (ester)" "butacainum" "butacaina" );
gibbsFormation
{
    dHf_298   -405750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70320.0
    phase     gas;
}
