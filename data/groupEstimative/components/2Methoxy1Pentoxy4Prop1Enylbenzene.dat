/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-1-pentoxy-4-prop-1-enylbenzene  (C15H22O2, CAS 10484-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy1Pentoxy4Prop1Enylbenzene;
formula     C15H22O2;
CAS         10484-36-3;
InChIKey    IKJFIKIKJWLIQS-UHFFFAOYSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          826.56;      // K   [origin=predictive method=joback]
Pc          18.278;      // bar [origin=predictive method=joback]
omega       0.7394;      // -   [origin=predictive method=lee-kesler]
Tb          628.44;      // K   [origin=predictive method=joback]
HvapTb      57362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.764 1.12456 -0.00055112 8.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-1-pentoxy-4-prop-1-enyl-benzene" "benzene, 2-methoxy-1-(pentyloxy)-4-(1-propen-1-yl)-" "2-methoxy-1-pentoxy-4-[(z)-prop-1-enyl]benzene" "benzene,2-methoxy-1-(pentyloxy)-4-(1-propen-1-yl)-" "benzene,2-methoxy-1-(pentyloxy)-4-(1-propenyl)- (9ci); benzene,2-methoxy-1-(pentyloxy)-4-propenyl- (8ci); 2-pentyloxy-5-prop-1-enylanisole;amyloxyisoeugenol" );
standardThermochemistry
{
    dHf_298   -286560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38790.0
}
