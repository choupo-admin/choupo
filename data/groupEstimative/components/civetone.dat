/*--------------------------------*- Choupo -*-----------------------*\
  Component: civetone  (C17H30O, CAS 74244-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        civetone;
formula     C17H30O;
CAS         74244-64-7;
InChIKey    ZKVZSBSZTMPBQR-UPHRSURJSA-N;
MW          250.426;      // g/mol [origin=calculated method=formula-sum]
Tc          998.01;      // K   [origin=predictive method=joback]
Pc          19.475;      // bar [origin=predictive method=joback]
omega       0.4838;      // -   [origin=predictive method=lee-kesler]
Tb          726.73;      // K   [origin=predictive method=joback]
HvapTb      60605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.23 1.4375 -0.00027028 -2.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 13; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 14; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(9z)-cycloheptadec-9-en-1-one" "cis-civetone" "9-cycloheptadecen-1-one, (z)-" "civettone, alpha-trans-" "(z)-9-cycloheptadecen-1-one" "9-cycloheptadecen-1-one, cis-" "9-cycloheptadecen-1-one, (9z)-" "cycloheptadec-9-en-1-one" "cycloheptadeca-9-en-1-one" );
standardThermochemistry
{
    dHf_298   -467230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     933.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101310.0
}
