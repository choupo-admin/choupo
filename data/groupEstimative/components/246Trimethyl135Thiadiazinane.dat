/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethyl-1,3,5-thiadiazinane  (C6H14N2S, CAS 53897-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethyl135Thiadiazinane;
formula     C6H14N2S;
CAS         53897-63-5;
InChIKey    PLCVUJTXVJDGBN-UHFFFAOYSA-N;
MW          146.252;      // g/mol [origin=calculated method=formula-sum]
Tc          728.21;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.4025;      // -   [origin=predictive method=lee-kesler]
Tb          492.02;      // K   [origin=predictive method=joback]
HvapTb      48089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.63 0.63057 -0.0001703 -4.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CHNH; count 2; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 3; } { group NH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-thiadiazine, perhydro, 2,4,6-trimethyl, #2" "1,3,5-thiadiazine, perhydro, 2,4,6-trimethyl, #1" "3,4,5,6-tetrahydro-2,4,6-trimethyl-2h-1,3,5-thiadiazine" "2h-1,3,5-thiadiazine, tetrahydro-2,4,6-trimethyl-" "tetrahydro-2,4,6-trimethyl-1,3,5(2h)-thiadiazine" );
standardThermochemistry
{
    dHf_298   -32650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     312.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223950.0
}
