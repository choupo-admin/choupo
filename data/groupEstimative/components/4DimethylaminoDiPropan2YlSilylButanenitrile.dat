/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[dimethylamino-di(propan-2-yl)silyl]butanenitrile  (C12H26N2Si, CAS 163794-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H26N2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4DimethylaminoDiPropan2YlSilylButanenitrile;
formula     C12H26N2Si;
CAS         163794-91-0;
InChIKey    ZMWNPLZNYQLBOE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          226.439;      // g/mol [origin=calculated method=formula-sum]
Tc          777.01;      // K   [origin=predictive method=joback]
Pc          15.987;      // bar [origin=predictive method=joback]
omega       0.6365;      // -   [origin=predictive method=lee-kesler]
Tb          589.20;      // K   [origin=predictive method=joback]
HvapTb      54345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.743 1.00822 -0.0003022 -5.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group CH3N; count 1; } { group CH2CN; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanenitrile, 4-((dimethylamino)bis(1-methylethyl)silyl)-" "butanenitrile, 4-[(dimethylamino)bis(1-methylethyl)silyl]-" "butanenitrile,4-[(dimethylamino)bis(1-methylethyl)silyl]-" "cyano propyl diisopropyl (dimethyl amino) silane;3-cyanopropyl(diisopropyl)dimethylaminosilane" );
gibbsFormation
{
    dHf_298   -180780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184480.0
    phase     gas;
}
