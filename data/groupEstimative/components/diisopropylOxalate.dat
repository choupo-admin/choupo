/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyl oxalate  (C8H14O4, CAS 615-81-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopropylOxalate;
formula     C8H14O4;
CAS         615-81-6;
InChIKey    ITHNIFCFNUZYLQ-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          683.84;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.6355;      // -   [origin=predictive method=lee-kesler]
Tb          498.20;      // K   [origin=predictive method=joback]
HvapTb      47440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.07 0.66608 -0.0002286 -3.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl ethanedioate" "ethanedioic acid, bis(1-methylethyl) ester" "dipropan-2-yl oxalate" "dipropan-2-yl oxalate;diisopropyl oxalate;" );
standardThermochemistry
{
    dHf_298   -853570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-609140.0
}
