/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyimipramine  (C19H24N2O, CAS 303-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxyimipramine;
formula     C19H24N2O;
CAS         303-70-8;
InChIKey    ROTCPJFWLNDKHU-UHFFFAOYSA-N;
MW          296.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1038.34;      // K   [origin=predictive method=joback]
Pc          22.104;      // bar [origin=predictive method=joback]
omega       1.1017;      // -   [origin=predictive method=lee-kesler]
Tb          810.28;      // K   [origin=predictive method=joback]
HvapTb      80914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.957 2.12144 -0.00174168 5.814e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 2; } { group ACOH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-[3-(dimethylamino)propyl]-5,6-dihydrobenzo[b][1]benzazepin-3-ol" "hydroxyimipramine" "2-hydroxy imipramine" "2-oh-ip" "5-(3-(dimethylamino)propyl)-2-hydroxy-10,11-dihydro-5h-dibenz(b,f)azepine" "5h-dibenz(b,f)azepin-2-ol, 10,11-dihydro-5-(3-(dimethylamino)propyl)-" "5-(3-(dimethylamino)propyl)-10,11-dihydro-5h-dibenz(b,f)azepin-2-ol" "5-[3-(dimethylamino)propyl]-10,11-dihydro-5h-dibenz[b,f]azepin-2-ol" "brd-k19653414-001-01-8" "5-[3-(dimethylamino)propyl]-10,11-dihydro-5h-dibenzo[b,f]azepin-2-ol" );
standardThermochemistry
{
    dHf_298   71680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=462160.0
}
