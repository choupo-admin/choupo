\*---------------------------------------------------------------------------*/

name        agnPc01vr36;
formula     C12F22;
CAS         54471-59-9;
InChIKey    PGVLJTPBGVZPPG-UHFFFAOYSA-N;
MW          562.088;      // g/mol [origin=calculated method=formula-sum]
Tc          570.93;      // K   [origin=predictive method=joback]
Pc          12.977;      // bar [origin=predictive method=joback]
omega       0.7574;      // -   [origin=predictive method=lee-kesler]
Tb          447.24;      // K   [origin=predictive method=joback]
HvapTb      8272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-496.33 4.6254 -0.006471 3.232e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CF3; count 2; } { group CF2; count 7; } { group CF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group C_ring; count 10; } { group F; count 22; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,3,4,4,4a,5,5,6,6,7,7,8a-hexadecakis(fluoranyl)-8,8-bis(trifluoromethyl)naphthalene" "perfluorodimethyldecahydronaphthalene" "naphthalene, hexadecafluorodecahydrobis(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -4512290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1498.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4273460.0
}
