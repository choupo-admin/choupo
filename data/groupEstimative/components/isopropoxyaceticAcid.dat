/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropoxyacetic acid  (C5H10O3, CAS 33445-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropoxyaceticAcid;
formula     C5H10O3;
CAS         33445-07-7;
InChIKey    OAIRTVZAAFZBMR-UHFFFAOYSA-N;
MW          118.132;      // g/mol [origin=calculated method=formula-sum]
Tc          675.86;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.6805;      // -   [origin=predictive method=lee-kesler]
Tb          481.49;      // K   [origin=predictive method=joback]
HvapTb      45910.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.761 0.47234 -0.000213 2.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-yloxyethanoic acid" "2-propan-2-yloxyacetic acid" "acetic acid, (1-methylethoxy)-" "2-isopropoxyacetic acid" "iso-propoxy acetic acid" "agn-pc-0d8b4n" "(propan-2-yloxy)acetic acid" "2-(propan-2-yloxy)acetic acid" );
standardThermochemistry
{
    dHf_298   -634300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-460130.0
}
