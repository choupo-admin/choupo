/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxypropiophenone  (C9H10O2, CAS 5650-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxypropiophenone;
formula     C9H10O2;
CAS         5650-41-9;
InChIKey    PQCFUZMQHVIOSM-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          781.51;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.9671;      // -   [origin=predictive method=lee-kesler]
Tb          578.25;      // K   [origin=predictive method=joback]
HvapTb      61329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.548 0.7859 -0.0005087 1.2216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanyl-1-phenyl-propan-1-one" "3-hydroxy-1-phenylpropan-1-one" "3-hydroxy propiophenone" "3-hydroxy-1-phenyl-1-propanone" "1-propanone, 3-hydroxy-1-phenyl-" "1-propanone, 1-phenyl-, monohydroxy deriv." );
gibbsFormation
{
    dHf_298   -257370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-128430.0
    phase     gas;
}
