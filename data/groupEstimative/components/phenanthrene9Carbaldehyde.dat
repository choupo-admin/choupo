/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenanthrene-9-carbaldehyde  (C15H10O, CAS 4707-71-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H10O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        phenanthrene9Carbaldehyde;
formula     C15H10O;
CAS         4707-71-5;
InChIKey    QECIGCMPORCORE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          206.244;      // g/mol [origin=calculated method=formula-sum]
Tc          844.57;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.4959;      // -   [origin=predictive method=lee-kesler]
Tb          593.82;      // K   [origin=predictive method=joback]
HvapTb      53491.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.44 1.2316 -0.00111576 4.019e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 5; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-phenanthrenecarboxaldehyde" "9-phenanthrenecarbaldehyde" "phenanthrene-9-carboxaldehyde" "9-phenanthrencarbaldehyd" "phenanthrene-9-aldehyde" "9-phenanthraldehyde" "9-formylphenanthrene" "9-phenanthrenaldehyde" );
standardThermochemistry
{
    dHf_298   319250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=425830.0
}
