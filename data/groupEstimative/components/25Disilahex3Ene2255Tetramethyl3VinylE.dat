/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-disilahex-3-ene, 2,2,5,5-tetramethyl-3-vinyl-, (e)-  (C10H22Si2, CAS 18081-31-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H22Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        25Disilahex3Ene2255Tetramethyl3VinylE;
formula     C10H22Si2;
CAS         18081-31-7;
InChIKey    NXKKWMIBFUFCRO-MDZDMXLPSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          198.456;      // g/mol [origin=calculated method=formula-sum]
Tc          621.53;      // K   [origin=predictive method=joback]
Pc          18.595;      // bar [origin=predictive method=joback]
omega       0.2330;      // -   [origin=predictive method=lee-kesler]
Tb          431.92;      // K   [origin=predictive method=joback]
HvapTb      37810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.57 0.54142 0.0002004 -2.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[(1e)-1-trimethylsilylbuta-1,3-dien-2-yl]silane" );
standardThermochemistry
{
    dHf_298   -240110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     783.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16690.0
}
