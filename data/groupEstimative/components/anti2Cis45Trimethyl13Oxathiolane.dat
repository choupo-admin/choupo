/*--------------------------------*- Choupo -*-----------------------*\
  Component: anti-2-cis-4,5-trimethyl-1,3-oxathiolane  (C6H12OS, CAS 63393-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anti2Cis45Trimethyl13Oxathiolane;
formula     C6H12OS;
CAS         63393-28-2;
InChIKey    IWKQZSONTQWRJT-UHFFFAOYSA-N;
MW          132.221;      // g/mol [origin=calculated method=formula-sum]
Tc          629.65;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.2878;      // -   [origin=predictive method=lee-kesler]
Tb          417.60;      // K   [origin=predictive method=joback]
HvapTb      38911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.03 0.66397 -0.000324 4.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH-O; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 3; } { group O_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,5-trimethyl-1,3-oxathiolane" );
gibbsFormation
{
    dHf_298   -234110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     253.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25490.0
    phase     gas;
}
