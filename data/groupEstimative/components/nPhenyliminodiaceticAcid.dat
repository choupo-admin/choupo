/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-phenyliminodiacetic acid  (C10H11NO4, CAS 1137-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPhenyliminodiaceticAcid;
formula     C10H11NO4;
CAS         1137-73-1;
InChIKey    GQBWTAGIANQVGB-UHFFFAOYSA-N;
MW          209.201;      // g/mol [origin=calculated method=formula-sum]
Tc          983.99;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       1.3022;      // -   [origin=predictive method=lee-kesler]
Tb          758.54;      // K   [origin=predictive method=joback]
HvapTb      76501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.598 1.1004 -0.0008092 2.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxy-2-oxoethyl(phenyl)amino]ethanoic acid" "acetic acid,1-phenyliminodi-" "n-(carboxymethyl)-n-phenylglycine" "glycine, n-(carboxymethyl)-n-phenyl-" "2-[(carboxymethyl)phenylamino]acetic acid" "n,n-phenylaminodiacetic acid" "2,2'-(phenylimino)diacetic acid" "[(carboxymethyl)anilino]acetic acid" "glycine,n-(carboxymethyl)-n-phenyl-" "n-phenyliminodiacetic acid (anhydride)" "2-[n-(carboxymethyl)anilino]acetic acid" );
gibbsFormation
{
    dHf_298   -646210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-431310.0
    phase     gas;
}
