/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1-methylcyclopropyl ketone  (C6H10O, CAS 1567-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1MethylcyclopropylKetone;
formula     C6H10O;
CAS         1567-75-5;
InChIKey    OQBCJXUAQQMTRW-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          599.84;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       0.3472;      // -   [origin=predictive method=lee-kesler]
Tb          397.73;      // K   [origin=predictive method=joback]
HvapTb      34458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.44 0.98864 -0.0010367 4.4846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-methylcyclopropyl)ethanone" "ethanone, 1-(1-methylcyclopropyl)-" "methyl1-methylcyclopropylketone" "1-(1-methyl-cyclopropyl)-ethanone" "1-acetyl-1-methylcyclopropane" "methyl 1-methyl cyclopropyl ketone" "ethanone,1-(1-methylcyclopropyl)-" );
gibbsFormation
{
    dHf_298   -191710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74020.0
    phase     gas;
}
