/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3,3,3-trichloro-1-propenyl)benzene  (C9H7Cl3, CAS 60504-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Trichloro1PropenylBenzene;
formula     C9H7Cl3;
CAS         60504-00-9;
InChIKey    NUDSHVLUIKPZLF-UHFFFAOYSA-N;
MW          221.505;      // g/mol [origin=calculated method=formula-sum]
Tc          796.36;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.3816;      // -   [origin=predictive method=lee-kesler]
Tb          545.42;      // K   [origin=predictive method=joback]
HvapTb      49721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.18 0.9461 -0.0008138 2.677e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(chloranyl)prop-1-enylbenzene" "(3,3,3-trichloroprop-1-enyl)benzene" "benzene, (3,3,3-trichloro-1-propen-1-yl)-" "benzene, (3,3,3-trichloro-1-propenyl)-" "3,3,3-trichloroprop-1-enylbenzene" "1,1,1-trichloro-3-phenyl-2-propene" "benzene,(3,3,3-trichloro-1-propen-1-yl)-" "benzene,(3,3,3-trichloro-1-propenyl)- (9ci); benzene, (3,3,3-trichloropropenyl)- (6ci)" );
standardThermochemistry
{
    dHf_298   68690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184580.0
}
