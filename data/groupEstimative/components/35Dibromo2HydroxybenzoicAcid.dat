/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dibromo-2-hydroxybenzoic acid  (C7H4Br2O3, CAS 3147-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dibromo2HydroxybenzoicAcid;
formula     C7H4Br2O3;
CAS         3147-55-5;
InChIKey    BFBZHSOXKROMBG-UHFFFAOYSA-N;
MW          295.914;      // g/mol [origin=calculated method=formula-sum]
Tc          1021.65;      // K   [origin=predictive method=joback]
Pc          67.964;      // bar [origin=predictive method=joback]
omega       1.2550;      // -   [origin=predictive method=lee-kesler]
Tb          754.85;      // K   [origin=predictive method=joback]
HvapTb      77824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.28 0.7527 -0.00072588 2.771e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group COOH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-bis(bromanyl)-2-oxidanyl-benzoic acid" "3,5-dibromosalicylic acid" "benzoic acid, 3,5-dibromo-2-hydroxy-" "2-hydroxy-3,5-dibromobenzoic acid" "salicylic acid, 3,5-dibromo-" "salicylic acid,5-dibromo-" "benzoic acid,5-dibromo-2-hydroxy-" "salicylic acid, 3,5-dibromo- (8ci)" "benzoic acid,3,5-dibromo,2-hydroxy" );
gibbsFormation
{
    dHf_298   -449140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368680.0
    phase     gas;
}
