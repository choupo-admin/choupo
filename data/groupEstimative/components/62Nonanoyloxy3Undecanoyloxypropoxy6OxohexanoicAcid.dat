/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(2-nonanoyloxy-3-undecanoyloxypropoxy)-6-oxohexanoic acid  (C29H52O8, CAS 71549-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        62Nonanoyloxy3Undecanoyloxypropoxy6OxohexanoicAcid;
formula     C29H52O8;
CAS         71549-83-2;
InChIKey    MEOIVHFTKURYFI-UHFFFAOYSA-N;
MW          528.727;      // g/mol [origin=calculated method=formula-sum]
Tc          1523.73;      // K   [origin=predictive method=joback]
Pc          6.608;      // bar [origin=predictive method=joback]
omega       0.2154;      // -   [origin=predictive method=lee-kesler]
Tb          1182.85;      // K   [origin=predictive method=joback]
HvapTb      119145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.672 2.65114 -0.0013458 1.901e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group CH; count 1; } { group CH2COO; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group CH; count 1; } { group COOH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(2-nonanoyloxy-3-undecanoyloxy-propoxy)-6-oxidanylidene-hexanoic acid" "hexanedioic acid mixed esters with nonanoic acid trimethylolpropane and undecanoic acid" "trimethylolpropane ester of nonanoic, undecanoic and hexanedioic acids" );
gibbsFormation
{
    dHf_298   -1949280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1483.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1084160.0
    phase     gas;
}
