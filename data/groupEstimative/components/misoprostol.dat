/*--------------------------------*- Choupo -*-----------------------*\
  Component: misoprostol  (C22H38O5, CAS 59122-46-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        misoprostol;
formula     C22H38O5;
CAS         59122-46-2;
InChIKey    OJLOPKGSLYJEMD-URPKTTJQSA-N;
MW          382.541;      // g/mol [origin=calculated method=formula-sum]
Tc          1253.29;      // K   [origin=predictive method=joback]
Pc          11.720;      // bar [origin=predictive method=joback]
omega       1.0712;      // -   [origin=predictive method=lee-kesler]
Tb          1020.23;      // K   [origin=predictive method=joback]
HvapTb      107879.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.95 2.16326 -0.0011674 2.025e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 2; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group C; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group OH; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 7-[(1r,2r,3r)-2-[(e)-4-methyl-4-oxidanyl-oct-1-enyl]-3-oxidanyl-5-oxidanylidene-cyclopentyl]heptanoate" "cytotec" "misoprostolum" "isprelor" "misopess" "misotol" "gymiso" "misoprostolum [inn-latin]" "cytotec (tn)" "misoprostol (jan/usan/inn)" "xp-16j" "ambap103601-27-0" );
gibbsFormation
{
    dHf_298   -1128580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     906.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-468050.0
    phase     gas;
}
