/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-4-propylmorpholine  (C9H19NO, CAS 70289-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl4Propylmorpholine;
formula     C9H19NO;
CAS         70289-40-6;
InChIKey    QOXQMYWIODKZRE-UHFFFAOYSA-N;
MW          157.257;      // g/mol [origin=calculated method=formula-sum]
Tc          644.26;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.4672;      // -   [origin=predictive method=lee-kesler]
Tb          455.52;      // K   [origin=predictive method=joback]
HvapTb      42129.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.208 1.08496 -0.0006365 1.359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH-O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyl-4-propyl-morpholine" "morpholine, 2,6-dimethyl-4-propyl-" "morpholine, 2,6-dimethyl-4-propyl-," );
gibbsFormation
{
    dHf_298   -253420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78400.0
    phase     gas;
}
