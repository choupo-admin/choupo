/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroacetaldehyde dimethyl acetal  (C4H9ClO2, CAS 97-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroacetaldehydeDimethylAcetal;
formula     C4H9ClO2;
CAS         97-97-2;
InChIKey    CRZJPEIBPQWDGJ-UHFFFAOYSA-N;
MW          124.564;      // g/mol [origin=calculated method=formula-sum]
Tc          551.49;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.3814;      // -   [origin=predictive method=lee-kesler]
Tb          372.95;      // K   [origin=predictive method=joback]
HvapTb      33315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.461 0.27014 4.6e-06 -6.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH3O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,1-dimethoxy-ethane" "2-chloro-1,1-dimethoxyethane" "dimethyl chloroacetal" "2-chloro-1,1-dimethoxy-ethane" "dimethylchloroacetal" "dimethyl chloracetal" "ethane, 2-chloro-1,1-dimethoxy-" "chloroacetaldehyde, dimethyl acetal" "2-chloroacetaldehyde, dimethyl acetal" "cadma" "acetaldehyde, chloro-, dimethyl acetal" "methyl chloroacetal" );
gibbsFormation
{
    dHf_298   -411350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-241570.0
    phase     gas;
}
