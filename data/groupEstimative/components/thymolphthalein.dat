/*--------------------------------*- Choupo -*-----------------------*\
  Component: thymolphthalein  (C28H30O4, CAS 125-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thymolphthalein;
formula     C28H30O4;
CAS         125-20-2;
InChIKey    LDKDGDIWEUUXSH-UHFFFAOYSA-N;
MW          430.544;      // g/mol [origin=calculated method=formula-sum]
Tc          1428.38;      // K   [origin=predictive method=joback]
Pc          15.451;      // bar [origin=predictive method=joback]
omega       1.3113;      // -   [origin=predictive method=lee-kesler]
Tb          1162.20;      // K   [origin=predictive method=joback]
HvapTb      119137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.57 2.85792 -0.00252792 9.392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group ACCH3; count 2; } { group ACCH; count 2; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 2; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 10; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(2-methyl-4-oxidanyl-5-propan-2-yl-phenyl)-2-benzofuran-1-one" "thymophthalein" "5',5''-diisopropyl-2',2''-dimethylphenolphthalein" "3,3-bis[4-hydroxy-2-methyl-5-(propan-2-yl)phenyl]-2-benzofuran-1(3h)-one" "1(3h)-isobenzofuranone, 3,3-bis(4-hydroxy-2-methyl-5-(1-methylethyl)phenyl)-" "1(3h)-isobenzofuranone, 3,3-bis[4-hydroxy-2-methyl-5-(1-methylethyl)phenyl]-" "3,3-bis[4-hydroxy-2-methyl-5-(methylethyl)phenyl]-3-hydroisobenzofuran-1-one" "thymolphthalein, acs" "3,3-bis(4-hydroxy-5-isopropyl-o-tolyl)phthalide" "phenolphthalein,5''-diisopropyl-2',2''-dimethyl-" "5',5''-diisopropyl-2',2''-dimethyl-phenolphthalein" "5',5''-diisopropyl-2',2''-dimethyl- phenolphthalein" );
standardThermochemistry
{
    dHf_298   -551110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     921.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71070.0
}
