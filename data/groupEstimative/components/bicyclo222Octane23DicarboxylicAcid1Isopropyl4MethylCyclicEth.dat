/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(2.2.2)octane-2,3-dicarboxylic acid, 1-isopropyl-4-methyl-, cyclic ethylene ester  (C16H24O4, CAS 71130-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Octane23DicarboxylicAcid1Isopropyl4MethylCyclicEth;
formula     C16H24O4;
CAS         71130-13-7;
InChIKey    YGYYNOXSKZRUPZ-UHFFFAOYSA-N;
MW          280.364;      // g/mol [origin=calculated method=formula-sum]
Tc          921.63;      // K   [origin=predictive method=joback]
Pc          19.510;      // bar [origin=predictive method=joback]
omega       0.7946;      // -   [origin=predictive method=lee-kesler]
Tb          701.98;      // K   [origin=predictive method=joback]
HvapTb      62936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-212.41 2.42056 -0.0022846 9.003e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 3; } { group C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -791030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-387880.0
    phase     gas;
}
