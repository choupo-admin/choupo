/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2-methyl-2-propanol  (C4H9ClO, CAS 558-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro2Methyl2Propanol;
formula     C4H9ClO;
CAS         558-42-9;
InChIKey    JNOZGFXJZQXOSU-UHFFFAOYSA-N;
MW          108.565;      // g/mol [origin=calculated method=formula-sum]
Tc          597.79;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.6129;      // -   [origin=predictive method=lee-kesler]
Tb          417.50;      // K   [origin=predictive method=joback]
HvapTb      44266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.039 0.55044 -0.0004164 1.271e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-methyl-propan-2-ol" "1-chloro-2-methylpropan-2-ol" "chloro-tert-butanol" "1-chloro-tert-butyl alcohol" "chloro-tert-butyl alcohol" "2-(chloromethyl)isopropanol" "2-chloro-tert-butyl alcohol" "jnozgfxjzqxosu-uhfffaoysa-" "2-propanol, 1-chloro-2-methyl-" "1-chloro-2-methylpropanol-2-ol" );
gibbsFormation
{
    dHf_298   -302610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163110.0
    phase     gas;
}
