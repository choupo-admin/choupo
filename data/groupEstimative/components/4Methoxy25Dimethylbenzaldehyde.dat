/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-2,5-dimethylbenzaldehyde  (C10H12O2, CAS 6745-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H12O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Methoxy25Dimethylbenzaldehyde;
formula     C10H12O2;
CAS         6745-75-1;
InChIKey    KYHULTSMPDXSLR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          675.16;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.4134;      // -   [origin=predictive method=lee-kesler]
Tb          468.86;      // K   [origin=predictive method=joback]
HvapTb      42153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.79 0.64136 -0.00039228 1.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CHO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-2,5-dimethyl-benzaldehyde" "2,5-dimethyl-4-methoxybenzaldehyde" "2,5-dimethyl-para-anisaldehyde" "2,5-dimethyl-p-anisaldehyde" "2,5-dimethyl-4-anisaldehyde" "benzaldehyde,4-methoxy-2,5-dimethyl-" "benzaldehyde, 4-methoxy-2,5-dimethyl-" "p-anisaldehyde,2,5-dimethyl- (7ci,8ci);2,5-dimethyl-4-methoxybenzaldehyde;2,5-dimethylanisaldehyde;4-methoxy-2,5-dimethylbenzaldehyde;4-methoxyisoxylaldehyde;" );
standardThermochemistry
{
    dHf_298   -103380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55800.0
}
