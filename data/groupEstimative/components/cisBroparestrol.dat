/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-broparestrol  (C22H19Br, CAS 22393-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisBroparestrol;
formula     C22H19Br;
CAS         22393-63-1;
InChIKey    OQCYTSHIQNPJIC-DQRAZIAOSA-N;
MW          363.298;      // g/mol [origin=calculated method=formula-sum]
Tc          1130.78;      // K   [origin=predictive method=joback]
Pc          20.272;      // bar [origin=predictive method=joback]
omega       0.7881;      // -   [origin=predictive method=lee-kesler]
Tb          858.06;      // K   [origin=predictive method=joback]
HvapTb      78609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.899 1.85562 -0.00135936 3.873e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 14; } { group AC; count 3; } { group ACCH2; count 1; } { group Br; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dC; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(z)-2-bromanyl-1,2-diphenyl-ethenyl]-4-ethyl-benzene" "broparestrol" "(z)-1-(2-bromo-1,2-diphenylethenyl)-4-ethylbenzene" "(z)-1-bromo-1,2-diphenyl-2-(p-ethylphenyl)ethylene" "bromo-1 (p-ethylphenyl)-2 diphenyl-1,2 ethylene (z) [french]" "ethylene, 1-bromo-1,2-diphenyl-2-(p-ethylphenyl)-, (z)-" "broparoestrol, (cis)-isomer" "1-[(z)-2-bromo-1,2-diphenylethenyl]-4-ethylbenzene" "bromo-1 (p-ethylphenyl)-2 diphenyl-1,2 ethylene (z)" "benzene, 1-(2-bromo-1,2-diphenylethenyl)-4-ethyl-, (z)-" "benzene, 1-(2-bromo-1,2-diphenylethenyl)-4-ethyl-, (z)- (9ci)" );
standardThermochemistry
{
    dHf_298   324680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=539400.0
}
