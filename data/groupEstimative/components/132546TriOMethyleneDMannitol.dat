/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3:2,5:4,6-tri-o-methylene-d-mannitol  (C9H14O6, CAS 5434-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        132546TriOMethyleneDMannitol;
formula     C9H14O6;
CAS         5434-31-1;
InChIKey    QQQVHHWRMWBKNS-UHFFFAOYSA-N;
MW          218.205;      // g/mol [origin=calculated method=formula-sum]
Tc          855.39;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.6640;      // -   [origin=predictive method=lee-kesler]
Tb          608.39;      // K   [origin=predictive method=joback]
HvapTb      63150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.88 1.2094 -0.0007092 1.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group CH-O; count 1; } { group FCH2O; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 4; } { group O_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4a,7a,8,11a,11b-hexahydrodi[1,3]dioxino[3,4-a:3',4'-d][1,3]dioxepine" "d-mannitol, 1,3:2,5:4,6-tri-o-methylene-" "hexahydrobis[1,3]dioxino[5,4-d:4',5'-f][1,3]dioxepine (non-preferred name)" );
gibbsFormation
{
    dHf_298   -859990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     5.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-389880.0
    phase     gas;
}
