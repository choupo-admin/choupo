/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-78585  (C19H30N2, CAS 71173-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG78585;
formula     C19H30N2;
CAS         71173-16-5;
InChIKey    GDBVAHARPFXDPL-UHFFFAOYSA-N;
MW          286.463;      // g/mol [origin=calculated method=formula-sum]
Tc          961.95;      // K   [origin=predictive method=joback]
Pc          16.233;      // bar [origin=predictive method=joback]
omega       0.8858;      // -   [origin=predictive method=lee-kesler]
Tb          750.89;      // K   [origin=predictive method=joback]
HvapTb      70632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.045 2.49458 -0.00236222 9.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 2; } { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3-tetraethyl-2-prop-2-enyl-isoindol-5-amine" "isoindoline, 2-allyl-5-amino-1,1,3,3-tetraethyl-" "1,1,3,3-tetraethyl-2-prop-2-enylisoindol-5-amine" "isoindoline, 2-allyl-5-amino-1,1,3,3-tetraethyl-," "1h-isoindol-5-amine,1,1,3,3-tetraethyl-2,3-dihydro-2-(2-propen-1-yl)-" "1h-isoindol-5-amine,1,1,3,3-tetraethyl-2,3-dihydro-2-(2-propenyl)- (9ci); isoindoline, 2-allyl-5-amino-1,1,3,3-tetraethyl-(7ci)" );
gibbsFormation
{
    dHf_298   93950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     826.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=521480.0
    phase     gas;
}
