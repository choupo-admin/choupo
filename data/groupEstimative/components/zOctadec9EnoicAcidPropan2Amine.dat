/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-octadec-9-enoic acid; propan-2-amine  (C21H43NO2, CAS 68650-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zOctadec9EnoicAcidPropan2Amine;
formula     C21H43NO2;
CAS         68650-93-1;
InChIKey    LOTPPNZMKIOSBW-UHFFFAOYSA-N;
MW          341.58;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.04;      // K   [origin=predictive method=joback]
Pc          10.299;      // bar [origin=predictive method=joback]
omega       0.9823;      // -   [origin=predictive method=lee-kesler]
Tb          903.24;      // K   [origin=predictive method=joback]
HvapTb      90009.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.844 1.93126 -0.0009068 1.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 14; } { group CH=CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group dCH; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadec-9-enoic acid;propan-2-amine" );
gibbsFormation
{
    dHf_298   -792930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1170.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-178500.0
    phase     gas;
}
