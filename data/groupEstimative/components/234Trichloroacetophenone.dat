/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',3',4'-trichloroacetophenone  (C8H5Cl3O, CAS 13608-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Trichloroacetophenone;
formula     C8H5Cl3O;
CAS         13608-87-2;
InChIKey    BXJZZJYNVIDEKG-UHFFFAOYSA-N;
MW          223.477;      // g/mol [origin=calculated method=formula-sum]
Tc          830.42;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.5965;      // -   [origin=predictive method=lee-kesler]
Tb          590.42;      // K   [origin=predictive method=joback]
HvapTb      57565.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.64 0.49882 -0.00028398 5.276e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH3CO; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,3,4-tris(chloranyl)phenyl]ethanone" "1-(2,3,4-trichlorophenyl)ethanone" "ethanone, 1-(2,3,4-trichlorophenyl)-" "acetophenone, 2',3',4'-trichloro-" "1-acetyl-2,3,4-trichlorobenzene" "bxjzzjynvidekg-uhfffaoysa-" "am731" "ethanone,1-(2,3,4-trichlorophenyl)-" "2 inverted exclamation marka,3 inverted exclamation marka,4 inverted exclamation marka-trichloroacetophenone" );
standardThermochemistry
{
    dHf_298   -166130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64710.0
}
