/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylhydroquinone, di(p-butylbenzoate)  (C29H32O4, CAS 64835-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylhydroquinoneDiPButylbenzoate;
formula     C29H32O4;
CAS         64835-62-7;
InChIKey    NYWMWXDEVFKTJK-UHFFFAOYSA-N;
MW          444.571;      // g/mol [origin=calculated method=formula-sum]
Tc          1324.27;      // K   [origin=predictive method=joback]
Pc          10.687;      // bar [origin=predictive method=joback]
omega       1.0052;      // -   [origin=predictive method=lee-kesler]
Tb          1079.52;      // K   [origin=predictive method=joback]
HvapTb      104438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.174 2.17456 -0.00119004 1.966e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 11; } { group AC; count 4; } { group ACCH3; count 1; } { group ACCH2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(4-butylphenyl)carbonyloxy-3-methyl-phenyl] 4-butylbenzoate" "benzoic acid, 4-butyl-, 2-methyl-1,4-phenylene ester" "benzoic acid, 4-butyl-, 1,1'-(2-methyl-1,4-phenylene) ester" "2-methyl-1,4-phenylene 4-butylbenzoate" "[4-(4-butylbenzoyl)oxy-3-methylphenyl] 4-butylbenzoate" );
standardThermochemistry
{
    dHf_298   -612740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1044.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-128730.0
}
