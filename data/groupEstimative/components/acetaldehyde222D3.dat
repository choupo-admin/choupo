/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetaldehyde-2,2,2-d3  (C2HD3O, CAS 19901-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2HD3O (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        acetaldehyde222D3;
formula     C2HD3O;
CAS         19901-15-6;
InChIKey    IKHGUXGNUITLKF-FIBGUPNXSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          47.071;      // g/mol [origin=calculated method=formula-sum]
Tc          465.61;      // K   [origin=predictive method=joback]
Pc          56.026;      // bar [origin=predictive method=joback]
omega       0.2637;      // -   [origin=predictive method=lee-kesler]
Tb          294.02;      // K   [origin=predictive method=joback]
HvapTb      26766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.47 0.16832 -7.8e-05 1.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-trideuterioethanal" "(2,2,2-2h3)acetaldehyde" "2,2,2-trideuterioacetaldehyde" );
standardThermochemistry
{
    dHf_298   -170190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     252.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133560.0
}
