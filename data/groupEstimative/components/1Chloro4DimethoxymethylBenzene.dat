/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-4-dimethoxymethyl-benzene  (C9H11ClO2, CAS 3395-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro4DimethoxymethylBenzene;
formula     C9H11ClO2;
CAS         3395-81-1;
InChIKey    YRNBYTFFWMWTGG-UHFFFAOYSA-N;
MW          186.635;      // g/mol [origin=calculated method=formula-sum]
Tc          734.81;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.5176;      // -   [origin=predictive method=lee-kesler]
Tb          519.01;      // K   [origin=predictive method=joback]
HvapTb      47383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.31 0.60674 -0.00023156 -4.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH; count 1; } { group CH3O; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-(dimethoxymethyl)benzene" "4-chlorobenzaldehyde dimethyl acetal" "1-chloro-4-(dimethoxymethyl)benzene" "benzene, 4-chloro-1-(dimethoxymethyl)-" "1-chloro-4-(dimethoxy-methyl)-benzene" "benzene,1-chloro-4-(dimethoxymethyl)-" );
standardThermochemistry
{
    dHf_298   -289490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96690.0
}
