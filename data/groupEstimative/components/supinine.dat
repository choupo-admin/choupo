/*--------------------------------*- Choupo -*-----------------------*\
  Component: supinine  (C15H25NO4, CAS 551-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        supinine;
formula     C15H25NO4;
CAS         551-58-6;
InChIKey    DRVWTOSBCBKXOR-ZLDLUXBVSA-N;
MW          283.368;      // g/mol [origin=calculated method=formula-sum]
Tc          1015.20;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       1.5509;      // -   [origin=predictive method=lee-kesler]
Tb          820.27;      // K   [origin=predictive method=joback]
HvapTb      90981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.749 1.90676 -0.00141884 4.143e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 2; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8s)-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl (2s)-3-methyl-2-oxidanyl-2-[(1r)-1-oxidanylethyl]butanoate" "supinin" "butanoic acid, 2,3-dihydroxy-2-(1-methylethyl)-, (2,3,5,7a-tetrahydro-1h-pyrrolizin-7-yl)methyl ester, (7as-(7(2r*,3s*),7ar*))-" "butanoic acid, 2,3-dihydroxy-2-(1-methylethyl)-, ((7as)-2,3,5,7a-tetrahydro-1h-pyrrolizin-7-yl)methyl ester, (2s,3r)-" "[(8s)-5,6,7,8-tetrahydro-3h-pyrrolizin-1-yl]methyl (2s)-2-hydroxy-2-[(1r)-1-hydroxyethyl]-3-methylbutanoate" );
gibbsFormation
{
    dHf_298   -720360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262410.0
    phase     gas;
}
