/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2821940  (C23H31NO3, CAS 3215-85-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2821940;
formula     C23H31NO3;
CAS         3215-85-8;
InChIKey    FOSJLBPSXNUTKY-UHFFFAOYSA-N;
MW          369.505;      // g/mol [origin=calculated method=formula-sum]
Tc          1119.39;      // K   [origin=predictive method=joback]
Pc          13.320;      // bar [origin=predictive method=joback]
omega       0.9954;      // -   [origin=predictive method=lee-kesler]
Tb          896.64;      // K   [origin=predictive method=joback]
HvapTb      84593.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.718 2.01332 -0.00120262 2.5386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH2CO; count 1; } { group CH3O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(dimethylamino)-1,5-bis(2-methoxyphenyl)-4,4-dimethyl-pentan-1-one" "ketone, 3,3-dimethyl-4-(dimethylamino)-4-(o-methoxyphenyl)butyl o-methoxyphenyl" "5-(dimethylamino)-1,5-bis(2-methoxyphenyl)-4,4-dimethylpentan-1-one" "3,3-dimethyl-4-(dimethylamino)-4-(o-methoxyphenyl)butyl o-methoxy-phenyl ketone" );
gibbsFormation
{
    dHf_298   -391450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     843.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120600.0
    phase     gas;
}
