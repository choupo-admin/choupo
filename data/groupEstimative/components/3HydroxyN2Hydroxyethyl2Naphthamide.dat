/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-n-(2-hydroxyethyl)-2-naphthamide  (C13H13NO3, CAS 92-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3HydroxyN2Hydroxyethyl2Naphthamide;
formula     C13H13NO3;
CAS         92-80-8;
InChIKey    VYHNSPUVKZPCDZ-UHFFFAOYSA-N;
MW          231.251;      // g/mol [origin=calculated method=formula-sum]
Tc          1047.70;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       1.6256;      // -   [origin=predictive method=lee-kesler]
Tb          824.52;      // K   [origin=predictive method=joback]
HvapTb      91985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.458 1.3335 -0.00110094 3.6956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 3; } { group OH; count 1; } { group ACOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)-3-oxidanyl-naphthalene-2-carboxamide" "3-hydroxy-n-(2-hydroxyethyl)naphthalene-2-carboxamide" "2-naphthalenecarboxamide, 3-hydroxy-n-(2-hydroxyethyl)-" "3-hydroxy-2-naphthoic acid, ethanolamide" "2-hydroxy-3-[(2-hydroxyethyl)carbamoyl]naphthalene" "(3-hydroxy(2-naphthyl))-n-(2-hydroxyethyl)carboxamide" "sdccgmls-0010467.p002" "beta-(2-hydroxy-3-naphthoyl)aminoethanol" ".beta.-(2-hydroxy-3-naphthoyl)aminoethanol" "2-naphthamide, 3-hydroxy-n-(2-hydroxyethyl)-" "2-naphthamide, 3-hydroxy-n-(2-hydroxyethyl)- (8ci)" "2-hydroxy-3-(beta-hydroxyethylamidocarbonyl)naphthalene" );
gibbsFormation
{
    dHf_298   -284170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62960.0
    phase     gas;
}
