/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzo(a,e)cyclooctene, 5,6-didehydro-  (C16H10, CAS 53397-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzoAECyclooctene56Didehydro;
formula     C16H10;
CAS         53397-66-3;
InChIKey    GVOYLOQRZIUYOL-UHFFFAOYSA-N;
MW          202.256;      // g/mol [origin=calculated method=formula-sum]
Tc          918.22;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.5022;      // -   [origin=predictive method=lee-kesler]
Tb          644.30;      // K   [origin=predictive method=joback]
HvapTb      59580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.59 1.2282 -0.00099206 3.2098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,6-didehydrodibenzo[2,1-a:2',1'-f][8]annulene" "dibenzo[a,e]cyclooctene,5,6-didehydro-" );
standardThermochemistry
{
    dHf_298   505930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=602720.0
}
