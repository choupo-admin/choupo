/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-butylnon-4-ene  (C13H26, CAS 7367-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Butylnon4Ene;
formula     C13H26;
CAS         7367-38-6;
InChIKey    UKAAUKLRJKBIDI-UHFFFAOYSA-N;
MW          182.351;      // g/mol [origin=calculated method=formula-sum]
Tc          670.88;      // K   [origin=predictive method=joback]
Pc          17.232;      // bar [origin=predictive method=joback]
omega       0.5754;      // -   [origin=predictive method=lee-kesler]
Tb          501.08;      // K   [origin=predictive method=joback]
HvapTb      44570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.802 1.25876 -0.0007695 1.927e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-n-butyl-4-nonene" "4-nonene, 5-butyl-" "5-butyl-non-4-ene" );
standardThermochemistry
{
    dHf_298   -204220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130250.0
}
