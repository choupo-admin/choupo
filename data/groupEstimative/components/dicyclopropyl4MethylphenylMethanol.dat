/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclopropyl(4-methylphenyl)methanol  (C14H18O, CAS 71172-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclopropyl4MethylphenylMethanol;
formula     C14H18O;
CAS         71172-47-9;
InChIKey    ZLDYBMZGEIJXHG-UHFFFAOYSA-N;
MW          202.297;      // g/mol [origin=calculated method=formula-sum]
Tc          874.03;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.8774;      // -   [origin=predictive method=lee-kesler]
Tb          654.01;      // K   [origin=predictive method=joback]
HvapTb      64905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.11 1.65702 -0.00134456 4.363e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclopropyl-(4-methylphenyl)methanol" "dicyclopropyl(4-methylphenyl)methan-1-ol" "benzenemethanol, a,a-dicyclopropyl-4-methyl-" "alpha,alpha-dicyclopropyl-4-methylbenzyl alcohol" "alpha,alpha-dicyclopropyl-4-methylbenzenemethanol;alpha,alpha-dicyclopropyl-p-methylbenzyl alcohol;dicyclopropyl-(4-methylphenyl)-methanol;alpha,alpha-dicyclopropyl-4-methylbenzyl alcohol" );
gibbsFormation
{
    dHf_298   -122610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157300.0
    phase     gas;
}
