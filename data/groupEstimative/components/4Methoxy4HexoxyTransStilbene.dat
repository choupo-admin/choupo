/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-4'-hexoxy-trans-stilbene  (C21H26O2, CAS 35135-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy4HexoxyTransStilbene;
formula     C21H26O2;
CAS         35135-44-5;
InChIKey    MWDBDMGQXOYWJG-UHFFFAOYSA-N;
MW          310.437;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.09;      // K   [origin=predictive method=joback]
Pc          14.977;      // bar [origin=predictive method=joback]
omega       0.8839;      // -   [origin=predictive method=lee-kesler]
Tb          792.40;      // K   [origin=predictive method=joback]
HvapTb      72994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.595 1.61564 -0.00090872 1.777e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-hexoxy-4-[2-(4-methoxyphenyl)ethenyl]benzene" );
standardThermochemistry
{
    dHf_298   -173870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201720.0
}
