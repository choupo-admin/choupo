/*--------------------------------*- Choupo -*-----------------------*\
  Component: buclizine  (C28H33ClN2, CAS 82-95-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buclizine;
formula     C28H33ClN2;
CAS         82-95-1;
InChIKey    MOYGZHXDRJNJEP-UHFFFAOYSA-N;
MW          433.036;      // g/mol [origin=calculated method=formula-sum]
Tc          1258.27;      // K   [origin=predictive method=joback]
Pc          13.042;      // bar [origin=predictive method=joback]
omega       0.9432;      // -   [origin=predictive method=lee-kesler]
Tb          1004.56;      // K   [origin=predictive method=joback]
HvapTb      93255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-191.629 2.86226 -0.00210872 6.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 13; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2N; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group Cl; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(4-tert-butylphenyl)methyl]-4-[(4-chlorophenyl)-phenyl-methyl]piperazine" "bucladin" "vibazine" "histabuticine" "histabutizine" "histabutyzine" "buclifen" "buclizina" "buclizinum" "aphilan-r base" "buclodin" "buclizinum [inn-latin]" );
gibbsFormation
{
    dHf_298   257670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     904.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=769240.0
    phase     gas;
}
