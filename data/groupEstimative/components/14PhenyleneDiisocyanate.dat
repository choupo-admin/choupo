/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-phenylene diisocyanate  (C8H4N2O2, CAS 104-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14PhenyleneDiisocyanate;
formula     C8H4N2O2;
CAS         104-49-4;
InChIKey    ALQLPWJFHRMHIU-UHFFFAOYSA-N;
MW          160.132;      // g/mol [origin=calculated method=formula-sum]
Tc          778.22;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.6607;      // -   [origin=predictive method=lee-kesler]
Tb          547.64;      // K   [origin=predictive method=joback]
HvapTb      55404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group dCd; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diisocyanatobenzene" "p-phenylene diisocyanate" "benzene, 1,4-diisocyanato-" "p-phenylene isocyanate" "isocyanic acid, p-phenylene ester" "1,4-phenylene diisocyanate [diisocyanates]" "benzene-1,4-diisocyanate" "isocyanic acid, p-phenylene ester (6ci,7ci,8ci)" "benzene,4-diisocyanato-" "4,4'-phenyl isocyanate" "1,4-diisocyanato-benzene" "benzene 1,4-diisocyanate" );
