/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2332148  (C11H16O5, CAS 27318-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2332148;
formula     C11H16O5;
CAS         27318-87-2;
InChIKey    ZSCBAJZMNJWRTI-UHFFFAOYSA-N;
MW          228.244;      // g/mol [origin=calculated method=formula-sum]
Tc          925.20;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       1.6121;      // -   [origin=predictive method=lee-kesler]
Tb          739.10;      // K   [origin=predictive method=joback]
HvapTb      83880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (72.982 0.73524 -0.00020272 -4.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 3; } { group OH; count 1; } { group CH3O; count 2; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,5-dimethoxyphenoxy)propane-1,2-diol" "1,2-propanediol, 3-(3,5-dimethoxyphenoxy)-" );
gibbsFormation
{
    dHf_298   -763180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-456190.0
    phase     gas;
}
