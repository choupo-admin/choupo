/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-(chloromethyl)phenyltrimethoxysilane  (C10H15ClO3Si, CAS 24413-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H15ClO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pChloromethylPhenyltrimethoxysilane;
formula     C10H15ClO3Si;
CAS         24413-04-5;
InChIKey    ZXOFHTCCTUEJQJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          246.762;      // g/mol [origin=calculated method=formula-sum]
Tc          778.31;      // K   [origin=predictive method=joback]
Pc          23.338;      // bar [origin=predictive method=joback]
omega       0.5698;      // -   [origin=predictive method=lee-kesler]
Tb          566.15;      // K   [origin=predictive method=joback]
HvapTb      52701.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (104.401 0.42646 0.00024304 -2.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 3; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(chloromethyl)phenyl]-trimethoxy-silane" "silane, [4-(chloromethyl)phenyl]trimethoxy-" "benzene, 1-(chloromethyl)-4-(trimethoxysilyl)-" "silane, (4-(chloromethyl)phenyl)trimethoxy-" "4-(chloromethyl)phenyltrimethoxysilane" "(p-(chloromethyl)phenyl)trimethoxysilane" "[4-(chloromethyl)phenyl]-trimethoxysilane" "4-chloromethylphenyltrimethoxysilane" );
standardThermochemistry
{
    dHf_298   -548690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295590.0
}
