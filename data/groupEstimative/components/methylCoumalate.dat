/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl coumalate  (C7H6O4, CAS 6018-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylCoumalate;
formula     C7H6O4;
CAS         6018-41-3;
InChIKey    HHWWWZQYHPFCBY-UHFFFAOYSA-N;
MW          154.121;      // g/mol [origin=calculated method=formula-sum]
Tc          701.67;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.6137;      // -   [origin=predictive method=lee-kesler]
Tb          495.18;      // K   [origin=predictive method=joback]
HvapTb      47630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.9 0.55552 -0.00030452 3.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 6-oxidanylidenepyran-3-carboxylate" "methyl 2-oxo-2h-pyran-5-carboxylate" "5-(carbomethoxy)-2-pyrone" "coumalic acid, methyl ester" "2h-pyran-5-carboxylic acid, 2-oxo-, methyl ester" "methyl 2-pyrone-5-carboxylate" "methyl 6-oxopyran-3-carboxylate" "methyl 2-oxopyran-5-carboxylate" "2h-pyran-5-carboxylic acid, methyl ester" "coumalic acid methyl ester" "methyl 6-oxo-6h-pyran-3-carboxylate" "methyl 2h-pyran-2-oxo-5-carboxylate" );
gibbsFormation
{
    dHf_298   -631300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-506030.0
    phase     gas;
}
