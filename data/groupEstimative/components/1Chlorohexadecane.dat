/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorohexadecane  (C16H33Cl, CAS 4860-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorohexadecane;
formula     C16H33Cl;
CAS         4860-03-1;
InChIKey    CLWAXFZCVYJLLM-UHFFFAOYSA-N;
MW          260.89;      // g/mol [origin=calculated method=formula-sum]
Tc          766.93;      // K   [origin=predictive method=joback]
Pc          12.838;      // bar [origin=predictive method=joback]
omega       0.7841;      // -   [origin=predictive method=lee-kesler]
Tb          603.11;      // K   [origin=predictive method=joback]
HvapTb      55595.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.235 1.53062 -0.000867 1.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylhexadecane" "cetyl chloride" "hexadecane, 1-chloro-" "hexadecyl chloride" "n-hexadecyl chloride" "chlorohexadecane" "1-chloro-hexadecane" );
standardThermochemistry
{
    dHf_298   -389310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     812.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71910.0
}
