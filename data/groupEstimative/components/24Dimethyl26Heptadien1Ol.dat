/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyl-2,6-heptadien-1-ol  (C9H16O, CAS 80192-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyl26Heptadien1Ol;
formula     C9H16O;
CAS         80192-56-9;
InChIKey    YBRHBMHQQIEOOL-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          672.98;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.7860;      // -   [origin=predictive method=lee-kesler]
Tb          497.98;      // K   [origin=predictive method=joback]
HvapTb      51287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.548 0.89864 -0.0006084 1.718e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethylhepta-2,6-dien-1-ol" );
gibbsFormation
{
    dHf_298   -153740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45150.0
    phase     gas;
}
