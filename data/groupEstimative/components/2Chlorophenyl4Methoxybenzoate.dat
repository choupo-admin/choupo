/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorophenyl 4-methoxybenzoate  (C14H11ClO3, CAS 7465-89-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorophenyl4Methoxybenzoate;
formula     C14H11ClO3;
CAS         7465-89-6;
InChIKey    GQOTVEHMQKIPGS-UHFFFAOYSA-N;
MW          262.689;      // g/mol [origin=calculated method=formula-sum]
Tc          942.88;      // K   [origin=predictive method=joback]
Pc          25.533;      // bar [origin=predictive method=joback]
omega       0.7692;      // -   [origin=predictive method=lee-kesler]
Tb          701.31;      // K   [origin=predictive method=joback]
HvapTb      66836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.75 0.94582 -0.00048092 5.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group CH3O; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-chlorophenyl) 4-methoxybenzoate" "p-methoxybenzoic acid, 2-chlorophenyl ester" "(2-chlorophenyl)4-methoxybenzoate" "p-anisic aid, o-chlorophenyl ester" "p-anisic acid, o-chlorophenyl ester" "benzoic acid, 4-methoxy-, 2-chlorophenyl ester" );
standardThermochemistry
{
    dHf_298   -347410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154740.0
}
