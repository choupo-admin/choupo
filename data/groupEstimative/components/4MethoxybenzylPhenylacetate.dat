/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxybenzyl phenylacetate  (C16H16O3, CAS 102-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethoxybenzylPhenylacetate;
formula     C16H16O3;
CAS         102-17-0;
InChIKey    VCYWCSZLXMMLLE-UHFFFAOYSA-N;
MW          256.301;      // g/mol [origin=calculated method=formula-sum]
Tc          933.57;      // K   [origin=predictive method=joback]
Pc          22.271;      // bar [origin=predictive method=joback]
omega       0.8030;      // -   [origin=predictive method=lee-kesler]
Tb          704.66;      // K   [origin=predictive method=joback]
HvapTb      66241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.258 1.18852 -0.00063636 9.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxyphenyl)methyl 2-phenylethanoate" "anisyl phenylacetate" "anisyl alpha-toluate" "benzeneacetic acid, (4-methoxyphenyl)methyl ester" "phenylacetic acid, p-methoxybenzyl ester" "p-methoxybenzyl phenylacetate" "(4-methoxyphenyl)methyl benzeneacetate" "(4-methoxyphenyl)methyl 2-phenylacetate" "benzeneacetic acid,(4-methoxyphenyl)methyl ester" "aceticacid, phenyl-, p-methoxybenzyl ester (8ci); benzyl alcohol, p-methoxy-,phenylacetate; 4-methoxybenzyl phenylacetate; anisyl phenylacetate;phenylacetic acid, p-methoxybenzyl ester; p-methoxybenzyl phenylacetate" );
standardThermochemistry
{
    dHf_298   -361480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116340.0
}
