/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl-n,2,3-trimethylbutyramide  (C10H21NO, CAS 51115-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IsopropylN23Trimethylbutyramide;
formula     C10H21NO;
CAS         51115-67-4;
InChIKey    RWAXQWRDVUOOGG-UHFFFAOYSA-N;
MW          171.284;      // g/mol [origin=calculated method=formula-sum]
Tc          721.58;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.6126;      // -   [origin=predictive method=lee-kesler]
Tb          528.33;      // K   [origin=predictive method=joback]
HvapTb      48964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.89 1.13972 -0.0007283 1.8016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 2; } { group C; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 2; } { group C; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,2,3-trimethyl-2-propan-2-yl-butanamide" "n,2,3-trimethyl-2-isopropylbutamide" "2-isopropyl-n,2,3-trimethylbutanamide" "n,2,3-trimethyl-2-propan-2-ylbutanamide" "trimethyl isopropyl butanamide" "methyl diisopropyl propionamide" "ws-23" "n,2,3-trimethyl-2-isopropylbutanamide" "2-isopropyl-2,3,n-trimethyl-butyramide" "n,2,3-trimethyl-2-(1-methylethyl)butanamide" "butanamide, n,2,3-trimethyl-2-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -328150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8250.0
    phase     gas;
}
