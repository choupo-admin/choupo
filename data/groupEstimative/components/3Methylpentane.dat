/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylpentane  (C6H14, CAS 96-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylpentane;
formula     C6H14;
CAS         96-14-0;
InChIKey    PFEOZHBOMNWTJB-UHFFFAOYSA-N;
MW          86.178;      // g/mol [origin=calculated method=formula-sum]
Tc          503.80;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.2772;      // -   [origin=predictive method=lee-kesler]
Tb          336.44;      // K   [origin=predictive method=joback]
HvapTb      28562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.248 0.57976 -0.0003058 5.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane, 3-methyl-" "3-methyl-pentane" "diethylmethylmethane" "agn-pc-0ciw5l" );
standardThermochemistry
{
    dHf_298   -172450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2800.0
}
