/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethoxyphenyl 4-propylcyclohexanecarboxylate  (C18H26O3, CAS 67589-39-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethoxyphenyl4Propylcyclohexanecarboxylate;
formula     C18H26O3;
CAS         67589-39-3;
InChIKey    DCCOHKNJQHHEHV-UHFFFAOYSA-N;
MW          290.403;      // g/mol [origin=calculated method=formula-sum]
Tc          954.29;      // K   [origin=predictive method=joback]
Pc          16.391;      // bar [origin=predictive method=joback]
omega       0.8161;      // -   [origin=predictive method=lee-kesler]
Tb          738.62;      // K   [origin=predictive method=joback]
HvapTb      68537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.837 1.55304 -0.00073956 7.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-ethoxyphenyl) 4-propylcyclohexane-1-carboxylate" "4-ethoxyphenyl trans-4-propylcyclohexanecarboxylate" "cyclohexanecarboxylic acid, 4-propyl-, 4-ethoxyphenyl ester, trans-" "trans-4-ethoxy-phenyl 4-propylcyclohexanecarboxylate" "cyclohexanecarboxylic acid,4-propyl-,4-ethoxyphenyl ester,trans-" );
gibbsFormation
{
    dHf_298   -605310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-195170.0
    phase     gas;
}
