/*--------------------------------*- Choupo -*-----------------------*\
  Component: icosanal  (C20H40O, CAS 2400-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        icosanal;
formula     C20H40O;
CAS         2400-66-0;
InChIKey    FWBUWJHWAKTPHI-UHFFFAOYSA-N;
MW          296.539;      // g/mol [origin=calculated method=formula-sum]
Tc          872.88;      // K   [origin=predictive method=joback]
Pc          10.652;      // bar [origin=predictive method=joback]
omega       0.9116;      // -   [origin=predictive method=lee-kesler]
Tb          705.86;      // K   [origin=predictive method=joback]
HvapTb      66834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.892 1.87832 -0.0010572 2.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "eicosanal" "icosanal;" );
standardThermochemistry
{
    dHf_298   -541710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     953.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18000.0
}
