/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl linolenate  (C20H34O2, CAS 1191-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylLinolenate;
formula     C20H34O2;
CAS         1191-41-9;
InChIKey    JYYFMIOPGOFNPK-UHFFFAOYSA-N;
MW          306.49;      // g/mol [origin=calculated method=formula-sum]
Tc          907.39;      // K   [origin=predictive method=joback]
Pc          11.283;      // bar [origin=predictive method=joback]
omega       0.8754;      // -   [origin=predictive method=lee-kesler]
Tb          727.90;      // K   [origin=predictive method=joback]
HvapTb      67395.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.429 1.90904 -0.001221 3.119e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH=CH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group dCH; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl octadeca-9,12,15-trienoate" "linolenic acid ethyl ester" "9,12,15-octadecatrienoic acid, ethyl ester, (9z,12z,15z)-" "ethyl linolenate, 80-85%" );
gibbsFormation
{
    dHf_298   -421750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     966.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47810.0
    phase     gas;
}
