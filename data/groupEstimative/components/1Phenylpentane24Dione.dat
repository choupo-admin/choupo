/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylpentane-2,4-dione  (C11H12O2, CAS 3318-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylpentane24Dione;
formula     C11H12O2;
CAS         3318-61-4;
InChIKey    NROOHYGFTHTDFF-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          805.39;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       0.7010;      // -   [origin=predictive method=lee-kesler]
Tb          585.70;      // K   [origin=predictive method=joback]
HvapTb      55848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.298 0.91392 -0.0005684 1.2712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-2,4-pentanedione" "2,4-pentanedione, 1-phenyl-" "1-phenyl-pentane-2,4-dione" "2,4-pentanedione,1-phenyl-" "(phenylacetyl)acetone;1-benzyl-1,3-butanedione;1-phenyl-2,4-pentanedione;" );
gibbsFormation
{
    dHf_298   -259000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103690.0
    phase     gas;
}
