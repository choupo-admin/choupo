/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptyl-1,3-dioxolane  (C10H20O2, CAS 4359-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptyl13Dioxolane;
formula     C10H20O2;
CAS         4359-57-3;
InChIKey    LWJBQKKNODYJEI-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          686.43;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       0.5752;      // -   [origin=predictive method=lee-kesler]
Tb          497.58;      // K   [origin=predictive method=joback]
HvapTb      47131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.044 1.07952 -0.0006198 1.299e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-heptyl-" "octanal glycolacetal" );
standardThermochemistry
{
    dHf_298   -453250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102370.0
}
