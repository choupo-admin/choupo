/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyanacure  (C14H16N2S2, CAS 52411-33-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyanacure;
formula     C14H16N2S2;
CAS         52411-33-3;
InChIKey    BSYVFGQQLJNJJG-UHFFFAOYSA-N;
MW          276.416;      // g/mol [origin=calculated method=formula-sum]
Tc          1147.51;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       1.0085;      // -   [origin=predictive method=lee-kesler]
Tb          865.86;      // K   [origin=predictive method=joback]
HvapTb      87550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.132 1.16958 -0.00067252 1.234e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACNH2; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-aminophenyl)sulfanylethylsulfanyl]aniline" "cynacure" "2-({2-[(2-aminophenyl)thio]ethyl}thio)aniline" "bis(o-aminophenylthio)ethane" "2,2'-(ethylenedithio)dianiline" "2,2'-(1,2-ethanediylbis(thio))bisbenzenamine" "2,2'-(ethane-1,2-diyldisulfanediyl)dianiline" "benzenamine, 2,2'-(1,2-ethanediylbis(thio))bis-" "2-[2-(2-aminophenylthio)ethylthio]phenylamine" "benzenamine, 2,2'-[1,2-ethanediylbis(thio)]bis-" "2-({2-[(2-aminophenyl)sulfanyl]ethyl}sulfanyl)aniline" );
gibbsFormation
{
    dHf_298   269150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     702.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=471700.0
    phase     gas;
}
