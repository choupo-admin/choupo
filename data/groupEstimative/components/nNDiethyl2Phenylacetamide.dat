/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-2-phenylacetamide  (C12H17NO, CAS 2431-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl2Phenylacetamide;
formula     C12H17NO;
CAS         2431-96-1;
InChIKey    UXDAWVUDZLBBAM-UHFFFAOYSA-N;
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          772.47;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.6773;      // -   [origin=predictive method=lee-kesler]
Tb          567.15;      // K   [origin=predictive method=joback]
HvapTb      53371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.257 1.16084 -0.0007541 1.8546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-2-phenyl-ethanamide" "n,n-diethyl phenylacetamide" "n,n-diethylphenylacetamide" "phenyl-n,n-diethylacetamide" "n,n-diethylbenzeneacetamide" "benzeneacetamide,n-diethyl-" "benzeneacetamide,n,n-diethyl-" "acetamide,n-diethyl-2-phenyl-" "benzeneacetamide, n,n-diethyl-" "n,n-diethyl-2-phenyl-acetamide" "benzeneacetamide, n,n-diethyl- (9ci)" );
gibbsFormation
{
    dHf_298   -99530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144430.0
    phase     gas;
}
