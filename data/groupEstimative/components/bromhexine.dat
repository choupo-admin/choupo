/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromhexine  (C14H20Br2N2, CAS 3572-43-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromhexine;
formula     C14H20Br2N2;
CAS         3572-43-8;
InChIKey    OJGDCBLYJGHCIH-UHFFFAOYSA-N;
MW          376.136;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.58;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.9660;      // -   [origin=predictive method=lee-kesler]
Tb          798.38;      // K   [origin=predictive method=joback]
HvapTb      77003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.269 1.46072 -0.00094768 2.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(bromanyl)-6-[[cyclohexyl(methyl)amino]methyl]aniline" "bromhexina" "bromhexinum" "benzenemethanamine, 2-amino-3,5-dibromo-n-cyclohexyl-n-methyl-" "bromhexine [inn:ban]" "bromhexinum [inn-latin]" "2,4-dibromo-6-{[cyclohexyl(methyl)amino]methyl}aniline" "n-cyclohexyl-n-methyl-(2-amino-3,5-dibrombenzyl)amin" "2,4-dibromo-6-((cyclohexyl(methyl)amino)methyl)aniline" "flegamin" "3,5-dibromo-nalpha-cyclohexyl-nalpha-methyltoluene-alpha-2-diamine" "toluene-.alpha.,2-diamine, 3,5-dibromo-n.alpha.-cyclohexyl-n.alpha.-methyl-" );
gibbsFormation
{
    dHf_298   78130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380840.0
    phase     gas;
}
