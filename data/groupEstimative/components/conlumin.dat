/*--------------------------------*- Choupo -*-----------------------*\
  Component: conlumin  (C41H52O4, CAS 8015-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        conlumin;
formula     C41H52O4;
CAS         8015-29-0;
InChIKey    HFFGOURGAIOQBU-FOWHCLFSSA-N;
MW          608.863;      // g/mol [origin=calculated method=formula-sum]
Tc          1849.49;      // K   [origin=predictive method=joback]
Pc          9.244;      // bar [origin=predictive method=joback]
omega       0.7795;      // -   [origin=predictive method=lee-kesler]
Tb          1494.05;      // K   [origin=predictive method=joback]
HvapTb      146194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-440.47 5.07866 -0.00443222 1.66808e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 6; } { group C; count 4; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } { group CH2CO; count 1; } { group CH3O; count 1; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tCH; count 2; } { group tC; count 2; } { group CH2_ring; count 14; } { group CH_ring; count 7; } { group C_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 2; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,13s,14s,17r)-17-ethynyl-3-methoxy-13-methyl-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthren-17-ol;(8r,9s,10r,13s,14s,17r)-17-ethynyl-13-methyl-17-oxidanyl-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-one" "conlunett" "conluten" "sophia" "maya" "ortho-novin" "otho-novinn" "norluten d" "ortho-novum sq" "norinyl-1" "norethindrone-mestranol" "norinyl 1/50" );
gibbsFormation
{
    dHf_298   -285790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1287.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=535720.0
    phase     gas;
}
