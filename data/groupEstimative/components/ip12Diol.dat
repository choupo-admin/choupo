/*--------------------------------*- Choupo -*-----------------------*\
  Component: ip-1,2-diol  (C22H14O2, CAS 102420-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ip12Diol;
formula     C22H14O2;
CAS         102420-56-4;
InChIKey    ZAYJHYHOTQVNOB-FGZHOGPDSA-N;
MW          310.352;      // g/mol [origin=calculated method=formula-sum]
Tc          1241.26;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       1.7288;      // -   [origin=predictive method=lee-kesler]
Tb          1004.92;      // K   [origin=predictive method=joback]
HvapTb      108866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.43 1.9798 -0.0017934 6.522e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=C; count 1; } { group ACH; count 9; } { group AC; count 6; } { group ACCH; count 1; } { group OH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 10; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-1,2-dihydro-1,2-dihydroxyindeno(1,2,3-cd)pyrene" "indeno(1,2,3-cd)pyrene-1,2-diol, 1,2-dihydro-, trans-" "trans-1,2-dihydro-1,2-dihydroxyindeno(1,2-cd)pyrene" );
standardThermochemistry
{
    dHf_298   154750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=410960.0
}
