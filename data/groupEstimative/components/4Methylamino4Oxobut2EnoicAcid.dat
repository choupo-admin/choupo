/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(methylamino)-4-oxobut-2-enoic acid  (C5H7NO3, CAS 6936-48-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylamino4Oxobut2EnoicAcid;
formula     C5H7NO3;
CAS         6936-48-7;
InChIKey    DFQUBYCHLQAFOW-UHFFFAOYSA-N;
MW          129.115;      // g/mol [origin=calculated method=formula-sum]
Tc          778.55;      // K   [origin=predictive method=joback]
Pc          45.592;      // bar [origin=predictive method=joback]
omega       0.9300;      // -   [origin=predictive method=lee-kesler]
Tb          567.71;      // K   [origin=predictive method=joback]
HvapTb      57028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.09 0.59782 -0.0004345 1.2516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group COOH; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(methylamino)-4-oxidanylidene-but-2-enoic acid" "n-methylmaleic acid monoamide" "n-methyl maleamate" "2-butenoic acid,4-(methylamino)-4-oxo-, (2z)-" "2-butenoicacid, 4-(methylamino)-4-oxo-, (z)-; maleamic acid, n-methyl- (6ci,7ci,8ci);n-methylmaleamic acid" );
standardThermochemistry
{
    dHf_298   -438690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312000.0
}
