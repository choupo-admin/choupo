/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-4'-isopropylbutyrophenone  (C13H17ClO, CAS 70289-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro4Isopropylbutyrophenone;
formula     C13H17ClO;
CAS         70289-38-2;
InChIKey    BGOQEVLEIPPQID-UHFFFAOYSA-N;
MW          224.728;      // g/mol [origin=calculated method=formula-sum]
Tc          833.64;      // K   [origin=predictive method=joback]
Pc          22.334;      // bar [origin=predictive method=joback]
omega       0.6882;      // -   [origin=predictive method=lee-kesler]
Tb          619.56;      // K   [origin=predictive method=joback]
HvapTb      58213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.967 1.08514 -0.00065246 1.4356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-1-(4-propan-2-ylphenyl)butan-1-one" "4-chloro-1-(4-isopropylphenyl)butan-1-one" "4-chloro-1-[4-(1-methylethyl)phenyl]-1-butanone" "4-chloro-1-(4-propan-2-ylphenyl)butan-1-one" "1-butanone,4-chloro-1-[4-(1-methylethyl)phenyl]-" "1-butanone, 4-chloro-1-[4-(1-methylethyl)phenyl]-" );
gibbsFormation
{
    dHf_298   -220190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18070.0
    phase     gas;
}
