/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthaleneacetic acid, 2-methyl-  (C13H12O2, CAS 85-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1NaphthaleneaceticAcid2Methyl;
formula     C13H12O2;
CAS         85-08-5;
InChIKey    GQHUFHPHBHEKSX-UHFFFAOYSA-N;
MW          200.237;      // g/mol [origin=calculated method=formula-sum]
Tc          934.49;      // K   [origin=predictive method=joback]
Pc          29.828;      // bar [origin=predictive method=joback]
omega       0.8922;      // -   [origin=predictive method=lee-kesler]
Tb          698.17;      // K   [origin=predictive method=joback]
HvapTb      66936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.079 1.08802 -0.00078984 2.283e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methylnaphthalen-1-yl)ethanoic acid" "2-methyl-1-naphthylacetic acid" "2-methyl-1-naphthaleneacetic acid" "(2-methyl-1-naphthyl)acetic acid" "1-naphthaleneaceticacid, 2-methyl-" "(2-methylnaphthalen-1-yl)acetic acid" "2-(2-methylnaphthalen-1-yl)acetic acid" );
standardThermochemistry
{
    dHf_298   -257260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85530.0
}
