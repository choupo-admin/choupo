/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzo[b]chrysene  (C22H14, CAS 214-17-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoBChrysene;
formula     C22H14;
CAS         214-17-5;
InChIKey    YYGRIGYJXSQDQB-UHFFFAOYSA-N;
MW          278.354;      // g/mol [origin=calculated method=formula-sum]
Tc          1090.15;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.8117;      // -   [origin=predictive method=lee-kesler]
Tb          820.50;      // K   [origin=predictive method=joback]
HvapTb      75388.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.89 1.8216 -0.00154996 5.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 14; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo[c]tetraphene" "2,3-benzochrysene" "3,4-benzotetracene" "3,4-benztetraphene" "3,4-benzotetraphene" "benzo(b)chrysene" "benzo(c)tetraphene" "1,2:6,7-dibenzophenanthrene" "naphth(2,1-a)anthracene" "2,3:7,8-dibenzophenanthrene" "1,7-dibenzophenanthrene" "2,8-dibenzophenanthrene" );
gibbsFormation
{
    dHf_298   468990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=644480.0
    phase     gas;
}
