/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyloctahydroazocine  (C8H17N, CAS 19719-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyloctahydroazocine;
formula     C8H17N;
CAS         19719-81-4;
InChIKey    CAROGVXIVVOPKA-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          631.00;      // K   [origin=predictive method=joback]
Pc          33.606;      // bar [origin=predictive method=joback]
omega       0.3233;      // -   [origin=predictive method=lee-kesler]
Tb          423.57;      // K   [origin=predictive method=joback]
HvapTb      36355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.74 1.02672 -0.000614 1.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylazocane" );
gibbsFormation
{
    dHf_298   -72420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147320.0
    phase     gas;
}
