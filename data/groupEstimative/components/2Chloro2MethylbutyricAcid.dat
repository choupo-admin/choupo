/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-2-methylbutyric acid  (C5H9ClO2, CAS 73758-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro2MethylbutyricAcid;
formula     C5H9ClO2;
CAS         73758-54-0;
InChIKey    NZZYVDKRZFWNRJ-UHFFFAOYSA-N;
MW          136.575;      // g/mol [origin=calculated method=formula-sum]
Tc          703.47;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.5861;      // -   [origin=predictive method=lee-kesler]
Tb          493.71;      // K   [origin=predictive method=joback]
HvapTb      46977.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.639 0.66224 -0.000513 1.572e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-2-methyl-butanoic acid" "butyric acid, 2-chloro-2-methyl-" "2-chloro-2-methylbutanoic acid" );
gibbsFormation
{
    dHf_298   -521290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361780.0
    phase     gas;
}
