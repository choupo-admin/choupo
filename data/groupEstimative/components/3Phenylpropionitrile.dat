/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylpropionitrile  (C9H9N, CAS 645-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylpropionitrile;
formula     C9H9N;
CAS         645-59-0;
InChIKey    ACRWYXSKEHUQDB-UHFFFAOYSA-N;
MW          131.178;      // g/mol [origin=calculated method=formula-sum]
Tc          761.80;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.5056;      // -   [origin=predictive method=lee-kesler]
Tb          534.28;      // K   [origin=predictive method=joback]
HvapTb      48382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.198 0.7147 -0.000466 1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropanenitrile" "benzenepropanenitrile" "hydrocinnamonitrile" "benzenepropionitrile" "2-phenylethyl cyanide" "(2-cyanoethyl)benzene" "phenethyl cyanide" "phenylpropionitrile" "3-phenylpropiononitrile" "hydrocinnamique nitrile [french]" "benzylacetonitrile" "dihydrocinnamonitrile" );
standardThermochemistry
{
    dHf_298   172320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270490.0
}
