/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2,3,6-trimethyl-, polymer with 2,6-dimethylphenol  (C17H22O2, CAS 58295-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol236TrimethylPolymerWith26Dimethylphenol;
formula     C17H22O2;
CAS         58295-79-7;
InChIKey    KMLUZJQTMWDZLI-UHFFFAOYSA-N;
MW          258.361;      // g/mol [origin=calculated method=formula-sum]
Tc          1068.28;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       1.0008;      // -   [origin=predictive method=lee-kesler]
Tb          819.50;      // K   [origin=predictive method=joback]
HvapTb      86296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.5 1.3856 -0.0008602 2.164e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH3; count 5; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylphenol;2,3,6-trimethylphenol" "2,6-dimethylphenol; 2,3,6-trimethylphenol" "2,6-dimethylphenol, 2,3,6-trimethylphenol polymer" );
gibbsFormation
{
    dHf_298   -421800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125810.0
    phase     gas;
}
