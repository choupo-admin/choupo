/*--------------------------------*- Choupo -*-----------------------*\
  Component: linalyl benzoate  (C17H22O2, CAS 126-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        linalylBenzoate;
formula     C17H22O2;
CAS         126-64-7;
InChIKey    BTJXBZZBBNNTOV-UHFFFAOYSA-N;
MW          258.361;      // g/mol [origin=calculated method=formula-sum]
Tc          885.73;      // K   [origin=predictive method=joback]
Pc          17.419;      // bar [origin=predictive method=joback]
omega       0.6815;      // -   [origin=predictive method=lee-kesler]
Tb          670.95;      // K   [origin=predictive method=joback]
HvapTb      61191.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.398 1.61086 -0.0011184 2.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylocta-1,6-dien-3-yl benzoate" "linalol benzoate" "linalool, benzoate" "benzoic acid linalool ester" "benzoic acid, linalyl ester" "1,6-octadien-3-ol, 3,7-dimethyl-, benzoate" "1,5-dimethyl-1-vinyl-4-hexen-1-yl benzoate" "3,7-dimethyl-1,6-octadien-3-yl benzoate" "1,6-octadien-3-ol, 3,7-dimethyl-, 3-benzoate" "4-hexen-1-ol, 1,5-dimethyl-1-vinyl-, benzoate" "linalylbenzoate" "3,6-octadien-3-yl benzoate" );
gibbsFormation
{
    dHf_298   -250850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56650.0
    phase     gas;
}
