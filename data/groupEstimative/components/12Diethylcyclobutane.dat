/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-diethylcyclobutane  (C8H16, CAS 61141-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Diethylcyclobutane;
formula     C8H16;
CAS         61141-83-1;
InChIKey    SXWCZDYKTCYCIC-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          573.42;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.3085;      // -   [origin=predictive method=lee-kesler]
Tb          388.98;      // K   [origin=predictive method=joback]
HvapTb      33178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.808 0.87864 -0.0005298 1.252e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutane, 1,2-diethyl-" "cyclobutane, 1,2-diethyl-, trans-" "cyclobutane, 1,2-diethyl-, cis-" "agn-pc-0cqxm7" );
gibbsFormation
{
    dHf_298   -162150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57420.0
    phase     gas;
}
