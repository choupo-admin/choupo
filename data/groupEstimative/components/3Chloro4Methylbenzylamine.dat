/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-methylbenzylamine  (C8H10ClN, CAS 67952-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4Methylbenzylamine;
formula     C8H10ClN;
CAS         67952-93-6;
InChIKey    MXIGALIASISPNU-UHFFFAOYSA-N;
MW          155.625;      // g/mol [origin=calculated method=formula-sum]
Tc          760.12;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.5226;      // -   [origin=predictive method=lee-kesler]
Tb          529.24;      // K   [origin=predictive method=joback]
HvapTb      52028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.691 0.63462 -0.00037232 7.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2NH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-chloranyl-4-methyl-phenyl)methanamine" "(3-chloro-4-methylphenyl)methanamine" "1-(3-chloro-4-methylphenyl)methanamine" "3-chloro-4-methyl benzylamine" "benzenemethanamine, 3-chloro-4-methyl-" "(3-chloro-4-methylphenyl)methylamine" "4-(aminomethyl)-2-chlorotoluene" "benzenemethanamine,3-chloro-4-methyl-" "3-chloro-4-methylbenzylamine;[(3-chloro-4-methylphenyl)methyl]amine;" );
gibbsFormation
{
    dHf_298   23190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164150.0
    phase     gas;
}
