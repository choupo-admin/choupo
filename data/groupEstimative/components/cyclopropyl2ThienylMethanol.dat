/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropyl(2-thienyl)methanol  (C8H10OS, CAS 60942-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropyl2ThienylMethanol;
formula     C8H10OS;
CAS         60942-21-4;
InChIKey    PEZSCBMHDXNXQL-UHFFFAOYSA-N;
MW          154.227;      // g/mol [origin=calculated method=formula-sum]
Tc          772.26;      // K   [origin=predictive method=joback]
Pc          44.922;      // bar [origin=predictive method=joback]
omega       0.7808;      // -   [origin=predictive method=lee-kesler]
Tb          552.20;      // K   [origin=predictive method=joback]
HvapTb      57230.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.76 0.95571 -0.00077422 2.526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropyl(thiophen-2-yl)methanol" "2-thiophenemethanol, a-cyclopropyl-" "alpha-cyclopropyl-2-thiophenemethanol" "alpha-cyclopropylthiophene-2-methanol" );
gibbsFormation
{
    dHf_298   -62990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72380.0
    phase     gas;
}
