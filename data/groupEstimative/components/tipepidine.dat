/*--------------------------------*- Choupo -*-----------------------*\
  Component: tipepidine  (C15H17NS2, CAS 5169-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tipepidine;
formula     C15H17NS2;
CAS         5169-78-8;
InChIKey    JWIXXNLOKOAAQT-UHFFFAOYSA-N;
MW          275.428;      // g/mol [origin=calculated method=formula-sum]
Tc          999.20;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.6389;      // -   [origin=predictive method=lee-kesler]
Tb          723.87;      // K   [origin=predictive method=joback]
HvapTb      67708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.94 1.63554 -0.00127644 3.951e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3N; count 1; } { group C=C; count 1; } { group C4H3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 3; } { group N; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dithiophen-2-ylmethylidene)-1-methyl-piperidine" "asverin" "bitiodin" "tipedine" "tipepidine [inn:dcf]" "tipepidinum [inn-latin]" "cr/662" "3-(di-2-thienylmethylene)-1-methylpiperidine" "1-methyl-3-piperidylidenedi(2-thienyl)methane" "3-(di-2-thienylmethylene)-1-methyl-piperidine" "piperidine, 3-(di-2-thienylmethyle)-1-methyl-" "piperidine, 3-(di-2-thienylmethylene)-1-methyl-" );
standardThermochemistry
{
    dHf_298   322000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=536190.0
}
