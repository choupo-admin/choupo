/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluoroanisole  (C7H3F5O, CAS 389-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentafluoroanisole;
formula     C7H3F5O;
CAS         389-40-2;
InChIKey    ZRQUIRABLIQJRI-UHFFFAOYSA-N;
MW          198.09;      // g/mol [origin=calculated method=formula-sum]
Tc          596.94;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.6095;      // -   [origin=predictive method=lee-kesler]
Tb          430.11;      // K   [origin=predictive method=joback]
HvapTb      35087.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (90.07 0.28822 -2.4e-05 -5.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group CH3O; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC_ring; count 6; } { group F; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(fluoranyl)-6-methoxy-benzene" "2,3,4,5,6-pentafluoroanisole" "benzene, pentafluoromethoxy-" "pentafluorophenyl methyl ether" "pentafluoromethoxybenzene" "methyl pentafluorophenyl ether" "benzene, 1,2,3,4,5-pentafluoro-6-methoxy-" "1,2,3,4,6-pentafluoro-5-methoxybenzene" "methoxypentafluorobenzene" "2,4,5,6-pentafluoroanisole" "anisole,3,4,5,6-pentafluoro-" "zrquirabliqjri-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -1121400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1006730.0
    phase     gas;
}
