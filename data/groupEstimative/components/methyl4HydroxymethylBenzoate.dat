/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-(hydroxymethyl)benzoate  (C9H10O3, CAS 6908-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4HydroxymethylBenzoate;
formula     C9H10O3;
CAS         6908-41-4;
InChIKey    VBWFYEFYHJRJER-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          787.53;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.9870;      // -   [origin=predictive method=lee-kesler]
Tb          587.58;      // K   [origin=predictive method=joback]
HvapTb      62652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.801 0.69962 -0.00036576 4.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-carbomethoxybenzyl alcohol" "benzoic acid, 4-(hydroxymethyl)-, methyl ester" "4-(hydroxymethyl)benzoic acid methyl ester" "methyl p-(hydroxymethyl)benzoate" "p-toluicacid, a-hydroxy-, methyl ester(6ci,7ci,8ci);4-(carbomethoxy)benzyl alcohol;4-(methoxycarbonyl)benzyl alcohol;4-hydroxymethylbenzoic acid methyl ester;methyl 4-(hydroxymethyl)benzoate;methyl p-(hydroxymethyl)benzoate;p-(methoxycarbonyl)benzyl alcohol;" );
gibbsFormation
{
    dHf_298   -473540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319510.0
    phase     gas;
}
