/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-2-(hydroxymethyl)propanal  (C4H8O3, CAS 40364-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy2HydroxymethylPropanal;
formula     C4H8O3;
CAS         40364-80-5;
InChIKey    SHAAIYJHUTYDST-UHFFFAOYSA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          690.76;      // K   [origin=predictive method=joback]
Pc          56.026;      // bar [origin=predictive method=joback]
omega       1.4057;      // -   [origin=predictive method=lee-kesler]
Tb          523.70;      // K   [origin=predictive method=joback]
HvapTb      64188.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.552 0.4322 -0.0002508 5.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hydroxymethyl)-3-oxidanyl-propanal" "propanal, 3-hydroxy-2-(hydroxymethyl)-" "3-hydroxy-2-(hydroxymethyl)propionaldehyde" );
gibbsFormation
{
    dHf_298   -521210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-392800.0
    phase     gas;
}
