/*--------------------------------*- Choupo -*-----------------------*\
  Component: o,p'-ddt  (C14H9Cl5, CAS 789-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oPDdt;
formula     C14H9Cl5;
CAS         789-02-6;
InChIKey    CVUGPAFCQJIYDT-UHFFFAOYSA-N;
MW          354.476;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.61;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.6368;      // -   [origin=predictive method=lee-kesler]
Tb          766.72;      // K   [origin=predictive method=joback]
HvapTb      72875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.75 1.2227 -0.00094312 2.73e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group CCl3; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-[2,2,2-tris(chloranyl)-1-(4-chlorophenyl)ethyl]benzene" "2,4'-ddt" "ortho,para'-ddt" "ddt, o,p'-" "2-(2-chlorophenyl)-2-(4-chlorophenyl)-1,1,1-trichloroethane" "1,1,1-trichloro-2-(o-chlorophenyl)-2-(p-chlorophenyl)ethane" "2,2,2,o,p'-pentachloroethylidenebisbenzene" "benzene, 1-chloro-2-[2,2,2-trichloro-1-(4-chlorophenyl)ethyl]-" "(-)-o,p'-ddt" "2,2-bis(o,p-chlorophenyl)-1,1,1-trichloroethane" "1-chloro-2-(2,2,2-trichloro-1-(4-chlorophenyl)ethyl)benzene" "1-chloro-2-[2,2,2-trichloro-1-(4-chlorophenyl)ethyl]benzene" );
gibbsFormation
{
    dHf_298   25100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213310.0
    phase     gas;
}
