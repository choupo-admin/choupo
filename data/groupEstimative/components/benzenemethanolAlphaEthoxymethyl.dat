/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenemethanol, .alpha.-(ethoxymethyl)-  (C10H14O2, CAS 22383-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenemethanolAlphaEthoxymethyl;
formula     C10H14O2;
CAS         22383-53-5;
InChIKey    XSBXONDDSWGYMG-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          764.10;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.9115;      // -   [origin=predictive method=lee-kesler]
Tb          569.24;      // K   [origin=predictive method=joback]
HvapTb      58831.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.998 0.85162 -0.000474 8.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-1-phenyl-ethanol" ".alpha.-(ethoxymethyl)benzyl alcohol" "a-(ethoxymethyl)benzyl alcohol" "alpha-(ethoxymethyl)benzyl alcohol" "2-ethoxy-1-phenylethanol" "alpha-(ethoxymethyl)benzenemethanol" "benzenemethanol, a-(ethoxymethyl)-" ".alpha.-(ethoxymethyl)benzenemethanol" "benzenemethanol, alpha-(ethoxymethyl)-" );
standardThermochemistry
{
    dHf_298   -302930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98530.0
}
