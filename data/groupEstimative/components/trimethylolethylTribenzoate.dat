/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolethyl tribenzoate  (C26H24O6, CAS 4196-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolethylTribenzoate;
formula     C26H24O6;
CAS         4196-87-6;
InChIKey    PJLLCGNQPWXWGL-UHFFFAOYSA-N;
MW          432.472;      // g/mol [origin=calculated method=formula-sum]
Tc          1294.78;      // K   [origin=predictive method=joback]
Pc          13.850;      // bar [origin=predictive method=joback]
omega       1.1247;      // -   [origin=predictive method=lee-kesler]
Tb          1045.95;      // K   [origin=predictive method=joback]
HvapTb      101223.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.707 2.19852 -0.0013722 2.753e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-methyl-3-(phenylcarbonyloxy)-2-(phenylcarbonyloxymethyl)propyl] benzoate" "trimethylolethane tribenzoate" "2-((benzoyloxy)methyl)-2-methylpropane-1,3-diyl dibenzoate" "2-((benzoyloxy)methyl)-2-methyldibenzoate-1,3-propanediol" "1,3-propanediol, 2-(hydroxymethyl)-2-methyl-, tribenzoate" "2-((benzoyloxy)methyl)-2-methyl-1,3-propanediol dibenzoate" "1,3-propanediol, 2-((benzoyloxy)methyl)-2-methyl-, dibenzoate" "2-[(benzoyloxy)methyl]-2-methylpropane-1,3-diyl dibenzoate" "1,3-propanediol, 2-((benzoyloxy)methyl)-2-methyl-, 1,3-dibenzoate" "1,3-propanediol, 2-[(benzoyloxy)methyl]-2-methyl-, 1,3-dibenzoate" "1, 2-(hydroxymethyl)-2-methyl-, tribenzoate" "1, 2-[(benzoyloxy)methyl]-2-methyl-, dibenzoate" );
standardThermochemistry
{
    dHf_298   -830970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     964.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-423000.0
}
