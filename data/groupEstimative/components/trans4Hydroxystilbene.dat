/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-4-hydroxystilbene  (C14H12O, CAS 6554-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans4Hydroxystilbene;
formula     C14H12O;
CAS         6554-98-9;
InChIKey    QVLMUEOXQBUPAH-VOTSOKGWSA-N;
MW          196.249;      // g/mol [origin=calculated method=formula-sum]
Tc          917.86;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       0.6744;      // -   [origin=predictive method=lee-kesler]
Tb          658.06;      // K   [origin=predictive method=joback]
HvapTb      64282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.75 1.3506 -0.00114036 3.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(e)-2-phenylethenyl]phenol" "4-hydroxystilbene" "4-stilbenol" "4-(2-phenylethenyl)phenol" "(e)-4-stilbenol" "4-(2-phenylvinyl)phenol" "hydroxystlbene,4-" "4-[(e)-2-phenylvinyl]phenol" "phenol, 4-(2-phenylethenyl)-" "4-hydroxyphenylstilbene" "4-((1e)-2-phenylvinyl)phenol" "stilben-4-ol" );
gibbsFormation
{
    dHf_298   80680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217420.0
    phase     gas;
}
