/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-diiodo-3,4-dimethylphenol  (C8H8I2O, CAS 62778-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Diiodo34Dimethylphenol;
formula     C8H8I2O;
CAS         62778-18-1;
InChIKey    KCDDWJSZNYLVEK-UHFFFAOYSA-N;
MW          373.951;      // g/mol [origin=calculated method=formula-sum]
Tc          982.83;      // K   [origin=predictive method=joback]
Pc          39.308;      // bar [origin=predictive method=joback]
omega       0.6152;      // -   [origin=predictive method=lee-kesler]
Tb          691.16;      // K   [origin=predictive method=joback]
HvapTb      69424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.07 0.73904 -0.00066064 2.477e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 2; } { group ACOH; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group I; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(iodanyl)-3,4-dimethyl-phenol" "phenol, 2,6-diiodo-3,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -29900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61620.0
    phase     gas;
}
