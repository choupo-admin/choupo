/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-bromo-4-(1-propenyl)-  (C9H9Br, CAS 4489-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1Bromo41Propenyl;
formula     C9H9Br;
CAS         4489-23-0;
InChIKey    KZNLLGVHMGYUAX-NSCUHMNNSA-N;
MW          197.075;      // g/mol [origin=calculated method=formula-sum]
Tc          744.73;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.4255;      // -   [origin=predictive method=lee-kesler]
Tb          507.50;      // K   [origin=predictive method=joback]
HvapTb      44959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.89 0.77862 -0.00058516 1.78e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-[(e)-prop-1-enyl]benzene" "1-bromo-4-[(e)-prop-1-enyl]benzene" );
standardThermochemistry
{
    dHf_298   139520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222220.0
}
