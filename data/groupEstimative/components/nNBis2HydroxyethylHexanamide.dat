/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)hexanamide  (C10H21NO3, CAS 29752-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxyethylHexanamide;
formula     C10H21NO3;
CAS         29752-80-5;
InChIKey    JTLQQZSDVWPHLD-UHFFFAOYSA-N;
MW          203.282;      // g/mol [origin=calculated method=formula-sum]
Tc          844.84;      // K   [origin=predictive method=joback]
Pc          26.763;      // bar [origin=predictive method=joback]
omega       1.6127;      // -   [origin=predictive method=lee-kesler]
Tb          679.07;      // K   [origin=predictive method=joback]
HvapTb      80001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.048 1.11772 -0.0006749 1.5576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanamide, n,n-bis(2-hydroxyethyl)-" "caproic diethanolamide" "amides, c6-12, n,n-bis(hydroxyethyl)" "hexanoic acid, diethanolamide" "hexanamide,n,n-bis(2-hydroxyethyl)-" "caproicacid diethanolamide; caproic diethanolamide; n,n-bis(2-hydroxyethyl)caproamide" );
gibbsFormation
{
    dHf_298   -599240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258460.0
    phase     gas;
}
