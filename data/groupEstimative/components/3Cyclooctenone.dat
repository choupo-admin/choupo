/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclooctenone  (C8H12O, CAS 4734-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclooctenone;
formula     C8H12O;
CAS         4734-90-1;
InChIKey    GYVYFOJMRQAKGY-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          723.76;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.3366;      // -   [origin=predictive method=lee-kesler]
Tb          482.38;      // K   [origin=predictive method=joback]
HvapTb      39023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.96 0.6689 -0.00019828 -4.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclooct-3-en-1-one" );
standardThermochemistry
{
    dHf_298   -226030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68190.0
}
