/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(ethenyl)benzene;1-(chloromethyl)-2-ethenyl-benzene;n,n-dimethylmethanamine  (C22H28ClN, CAS 63453-89-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisEthenylBenzene1Chloromethyl2EthenylBenzeneNNDimethylmet;
formula     C22H28ClN;
CAS         63453-89-4;
InChIKey    YLJCBBSUFMHBBX-UHFFFAOYSA-N;
MW          341.923;      // g/mol [origin=calculated method=formula-sum]
Tc          1040.63;      // K   [origin=predictive method=joback]
Pc          12.874;      // bar [origin=predictive method=joback]
omega       0.6872;      // -   [origin=predictive method=lee-kesler]
Tb          808.99;      // K   [origin=predictive method=joback]
HvapTb      75448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.541 1.47536 -0.00047342 -8.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 3; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methanamine, n,n-dimethyl-, compd. with (chloromethyl)ethenylbenzene polymer with diethenylbenzene" "1,2-bis(ethenyl)benzene; 1-(chloromethyl)-2-ethenylbenzene; n,n-dimethylmethanamine" );
standardThermochemistry
{
    dHf_298   157550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1038.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=492770.0
}
