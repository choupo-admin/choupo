/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-2-naphthoic acid  (C11H9NO2, CAS 5959-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino2NaphthoicAcid;
formula     C11H9NO2;
CAS         5959-52-4;
InChIKey    XFXOLBNQYFRSLQ-UHFFFAOYSA-N;
MW          187.198;      // g/mol [origin=calculated method=formula-sum]
Tc          976.43;      // K   [origin=predictive method=joback]
Pc          39.956;      // bar [origin=predictive method=joback]
omega       1.0055;      // -   [origin=predictive method=lee-kesler]
Tb          724.94;      // K   [origin=predictive method=joback]
HvapTb      73125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.77 0.9599 -0.00072444 2.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanylnaphthalene-2-carboxylic acid" "3-aminoisonaphthoic acid" "2-naphthalenecarboxylic acid, 3-amino-" "2-amino-3-naphthoic acid" "2-amino-3-carboxynaphthalene" "2-naphthoic acid, 3-amino-" "3-aminonaphthalene-2-carboxylic acid" "3-amino-2-naphthalenecarboxylic acid" "3-amino-2-naphthoic" "3-amino-naphthalene-2-carboxylic acid" );
gibbsFormation
{
    dHf_298   -182190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35920.0
    phase     gas;
}
