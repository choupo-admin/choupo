/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5-trimethylnonane  (C12H26, CAS 62184-57-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        235Trimethylnonane;
formula     C12H26;
CAS         62184-57-0;
InChIKey    IESSJVKAXJWJFD-UHFFFAOYSA-N;
MW          170.34;      // g/mol [origin=calculated method=formula-sum]
Tc          643.91;      // K   [origin=predictive method=joback]
Pc          18.170;      // bar [origin=predictive method=joback]
omega       0.4971;      // -   [origin=predictive method=lee-kesler]
Tb          472.84;      // K   [origin=predictive method=joback]
HvapTb      41142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.066 1.1616 -0.0006386 1.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -306850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42840.0
    phase     gas;
}
