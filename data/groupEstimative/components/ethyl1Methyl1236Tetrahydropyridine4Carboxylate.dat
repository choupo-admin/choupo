/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 1-methyl-1,2,3,6-tetrahydropyridine-4-carboxylate  (C9H15NO2, CAS 40175-06-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl1Methyl1236Tetrahydropyridine4Carboxylate;
formula     C9H15NO2;
CAS         40175-06-2;
InChIKey    GKMQAGZRPQBLHG-UHFFFAOYSA-N;
MW          169.224;      // g/mol [origin=calculated method=formula-sum]
Tc          698.95;      // K   [origin=predictive method=joback]
Pc          29.377;      // bar [origin=predictive method=joback]
omega       0.5853;      // -   [origin=predictive method=lee-kesler]
Tb          500.27;      // K   [origin=predictive method=joback]
HvapTb      46598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.919 0.97064 -0.00058684 1.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=C; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-methyl-3,6-dihydro-2h-pyridine-4-carboxylate" "gkmqagzrpqblhg-uhfffaoysa-" "ethyl 1-methyl-1,2,3,6-tetrahydro-4-pyridinecarboxylate" );
gibbsFormation
{
    dHf_298   -351710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-110100.0
    phase     gas;
}
