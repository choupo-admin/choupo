/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexaphenol  (C21H18O6, CAS 1506-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexaphenol;
formula     C21H18O6;
CAS         1506-76-9;
InChIKey    OOBDZXQTZWOBBQ-UHFFFAOYSA-N;
MW          366.369;      // g/mol [origin=calculated method=formula-sum]
Tc          1569.85;      // K   [origin=predictive method=joback]
Pc          66.206;      // bar [origin=predictive method=joback]
omega       2.4917;      // -   [origin=predictive method=lee-kesler]
Tb          1270.19;      // K   [origin=predictive method=joback]
HvapTb      149460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-184.72 2.6886 -0.00282484 1.1666e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 3; } { group ACOH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 12; } { group OH_phenol; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,10,15-trihydrotribenzo[a,d,g][9]annulene-2,3,7,8,12,13-hexaol" "tetracyclo[15.4.0.0^{3,8}.0^{10,15}]henicosa-1(17),3,5,7,10,12,14,18,20-nonaene-5,6,12,13,19,20-hexol" );
gibbsFormation
{
    dHf_298   -772310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-424980.0
    phase     gas;
}
