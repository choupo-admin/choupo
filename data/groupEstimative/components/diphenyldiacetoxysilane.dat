/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenyldiacetoxysilane  (C16H16O4Si, CAS 2565-07-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H16O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diphenyldiacetoxysilane;
formula     C16H16O4Si;
CAS         2565-07-3;
InChIKey    CNOSLBKTVBFPBB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          300.385;      // g/mol [origin=calculated method=formula-sum]
Tc          975.29;      // K   [origin=predictive method=joback]
Pc          20.624;      // bar [origin=predictive method=joback]
omega       0.7644;      // -   [origin=predictive method=lee-kesler]
Tb          736.88;      // K   [origin=predictive method=joback]
HvapTb      70870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.17 1.05024 -0.000305 -1.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH3COO; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[acetyloxy(diphenyl)silyl] ethanoate" "diacetoxydiphenylsilane" "silanediol, diphenyl-, diacetate" "silanediol, 1,1-diphenyl-, 1,1-diacetate" "(acetyloxy)diphenylsilyl acetate" "[acetyloxy(diphenyl)silyl] acetate" "silanediol, diphenyl-, diacetate;(acetyloxy-diphenyl-silyl) acetate;diphenyldiacetoxysilane;" );
gibbsFormation
{
    dHf_298   -646690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416840.0
    phase     gas;
}
