/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-5-acetoxypyridine  (C8H9NO2, CAS 4842-89-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl5Acetoxypyridine;
formula     C8H9NO2;
CAS         4842-89-1;
InChIKey    WXLRJJLUBRXUPX-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          753.76;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.5374;      // -   [origin=predictive method=lee-kesler]
Tb          526.22;      // K   [origin=predictive method=joback]
HvapTb      49957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.48 0.6044 -0.00029022 2.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3COO; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6-methylpyridin-3-yl) ethanoate" "3-pyridinol, 6-methyl-, acetate (ester)" "(6-methylpyridin-3-yl) acetate" "acetic acid 6-methyl-3-pyridyl ester" );
standardThermochemistry
{
    dHf_298   -267880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114060.0
}
