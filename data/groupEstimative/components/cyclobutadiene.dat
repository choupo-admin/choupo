/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutadiene  (C4H4, CAS 1120-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutadiene;
formula     C4H4;
CAS         1120-53-2;
InChIKey    HWEQKSVYKBUIIK-UHFFFAOYSA-N;
MW          52.076;      // g/mol [origin=calculated method=formula-sum]
Tc          496.47;      // K   [origin=predictive method=joback]
Pc          55.526;      // bar [origin=predictive method=joback]
omega       0.1754;      // -   [origin=predictive method=lee-kesler]
Tb          305.12;      // K   [origin=predictive method=joback]
HvapTb      25476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.49 0.4396 -0.00039756 1.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4]annulene" "1,3-cyclobutadiene" "cyclobuta-1,3-diene" "cyclobutadiene(6ci); [4]annulene" );
standardThermochemistry
{
    dHf_298   76650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     209.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99080.0
}
