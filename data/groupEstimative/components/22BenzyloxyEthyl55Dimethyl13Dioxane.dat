/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(benzyloxy)ethyl]-5,5-dimethyl-1,3-dioxane  (C15H22O3, CAS 116376-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BenzyloxyEthyl55Dimethyl13Dioxane;
formula     C15H22O3;
CAS         116376-29-5;
InChIKey    JIQSXGPAPCVQSI-UHFFFAOYSA-N;
MW          250.338;      // g/mol [origin=calculated method=formula-sum]
Tc          888.12;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.6822;      // -   [origin=predictive method=lee-kesler]
Tb          660.92;      // K   [origin=predictive method=joback]
HvapTb      61659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.167 1.66824 -0.0012428 4e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-2-(2-phenylmethoxyethyl)-1,3-dioxane" "1,3-dioxane,5,5-dimethyl-2-[2-(phenylmethoxy)ethyl]-" );
standardThermochemistry
{
    dHf_298   -463400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78160.0
}
