/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetin  (C5H10O4, CAS 26446-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetin;
formula     C5H10O4;
CAS         26446-35-5;
InChIKey    KMZHZAAOEWVPSE-UHFFFAOYSA-N;
MW          134.131;      // g/mol [origin=calculated method=formula-sum]
Tc          722.89;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       1.4217;      // -   [origin=predictive method=lee-kesler]
Tb          556.14;      // K   [origin=predictive method=joback]
HvapTb      67101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.652 0.49792 -0.0002176 1.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl ethanoate" "monoacetin" "2,3-dihydroxypropyl acetate" "glycerol monoacetate" "glyceryl monoacetate" "acetin, mono-" "monacetin" "glyceryl acetate" "1-monoacetin" "monoacetyl glycerine" "1,2,3-propanetriol, monoacetate" "glycerol 1-monoacetate" );
gibbsFormation
{
    dHf_298   -773550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-595230.0
    phase     gas;
}
