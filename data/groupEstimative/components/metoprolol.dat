/*--------------------------------*- Choupo -*-----------------------*\
  Component: metoprolol  (C15H25NO3, CAS 51384-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        metoprolol;
formula     C15H25NO3;
CAS         51384-51-1;
InChIKey    IUBSYMUCCVWXPE-UHFFFAOYSA-N;
MW          267.369;      // g/mol [origin=calculated method=formula-sum]
Tc          952.08;      // K   [origin=predictive method=joback]
Pc          19.666;      // bar [origin=predictive method=joback]
omega       1.2822;      // -   [origin=predictive method=lee-kesler]
Tb          760.77;      // K   [origin=predictive method=joback]
HvapTb      79081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.364 1.28606 -0.00061976 7.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(2-methoxyethyl)phenoxy]-3-(propan-2-ylamino)propan-2-ol" "lopressor" "(rs)-metoprolol" "betaloc" "seloken" "spesicor" "toprol-xl" "beatrolol" "lopresor" "presolol" "preblok" "dl-metoprolol" );
standardThermochemistry
{
    dHf_298   -501630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84110.0
}
