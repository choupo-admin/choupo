/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dehydro-l-proline  (C5H7NO2, CAS 4043-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DehydroLProline;
formula     C5H7NO2;
CAS         4043-88-3;
InChIKey    OMGHIGVFLOPEHJ-BYPYZUCNSA-N;
MW          113.116;      // g/mol [origin=calculated method=formula-sum]
Tc          753.92;      // K   [origin=predictive method=joback]
Pc          53.435;      // bar [origin=predictive method=joback]
omega       0.6624;      // -   [origin=predictive method=lee-kesler]
Tb          522.50;      // K   [origin=predictive method=joback]
HvapTb      51195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.84 0.5919 -0.00037488 8.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2,5-dihydro-1h-pyrrole-2-carboxylic acid" "l-3,4-dehydroproline" "(s)-3-pyrroline-2-carboxylic acid" "(s)-2,5-dihydro-1h-pyrrole-2-carboxylic acid" "1h-pyrrole-2-carboxylic acid, 2,5-dihydro-, (s)-" "l-3-pyrroline-2-carboxylic acid" "3,4-didehydro-l-proline" "3-pyrroline-2-carboxylic acid, l-" "3-pyrroline-2-carboxylic acid, l- (8ci)" "(s)-2,5-dihydro-1h-pyrrole-2-carboxylicacid" "1h-pyrrole-2-carboxylic acid,2,5-dihydro-,(2s)-" "1h-pyrrole-2-carboxylicacid, 2,5-dihydro-, (2s)-" );
standardThermochemistry
{
    dHf_298   -340730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198470.0
}
