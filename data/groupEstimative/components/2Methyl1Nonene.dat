/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-nonene  (C10H20, CAS 2980-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Nonene;
formula     C10H20;
CAS         2980-71-4;
InChIKey    YLZQHQUVNZVGOK-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          593.73;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       0.4482;      // -   [origin=predictive method=lee-kesler]
Tb          424.96;      // K   [origin=predictive method=joback]
HvapTb      37264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.884 0.93374 -0.0005454 1.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylnon-1-ene" "1-nonene, 2-methyl-" );
standardThermochemistry
{
    dHf_298   -134090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112610.0
}
