/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-pentadiene, 3-vinyl-  (C7H10, CAS 26456-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Pentadiene3Vinyl;
formula     C7H10;
CAS         26456-63-3;
InChIKey    HEKRPWJODWSOQV-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          527.76;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.2557;      // -   [origin=predictive method=lee-kesler]
Tb          349.36;      // K   [origin=predictive method=joback]
HvapTb      28778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.13 0.6147 -0.0004289 1.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethenylpenta-1,4-diene" "1,4-pentadiene, 3-ethenyl-" );
standardThermochemistry
{
    dHf_298   183200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=269140.0
}
