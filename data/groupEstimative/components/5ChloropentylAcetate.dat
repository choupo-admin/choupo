/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloropentyl acetate  (C7H13ClO2, CAS 20395-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5ChloropentylAcetate;
formula     C7H13ClO2;
CAS         20395-28-2;
InChIKey    ZCYVIAZIVJNAMO-UHFFFAOYSA-N;
MW          164.629;      // g/mol [origin=calculated method=formula-sum]
Tc          634.81;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.5598;      // -   [origin=predictive method=lee-kesler]
Tb          455.41;      // K   [origin=predictive method=joback]
HvapTb      42968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.825 0.62082 -0.0002828 2.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranylpentyl ethanoate" "5-chloro-n-amyl acetate" "1-pentanol, 5-chloro-, acetate" "1-acetoxy-5-chloropentane" "5-chloro-1-pentanol acetate" "5-chloro-1-amyl acetate" "5-chloro-1-acetoxypentane" "5-chloro-1-pentyl acetate" "acetic acid 5-chloro-pentyl ester" "1-pentanol, 5-chloro-, 1-acetate" "5-chloroamyl acetate" "5-chloro-1-pentylacetate" );
standardThermochemistry
{
    dHf_298   -520830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-314240.0
}
