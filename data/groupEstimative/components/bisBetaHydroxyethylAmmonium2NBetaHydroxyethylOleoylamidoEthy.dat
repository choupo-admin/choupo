/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(beta-hydroxyethyl)ammonium 2-(n-(beta-hydroxyethyl)oleoylamido)ethyl) maleate  (C30H56N2O8, CAS 67953-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisBetaHydroxyethylAmmonium2NBetaHydroxyethylOleoylamidoEthy;
formula     C30H56N2O8;
CAS         67953-29-1;
InChIKey    BNSFOQZSPNNYCJ-IYCIPDHXSA-N;
MW          572.784;      // g/mol [origin=calculated method=formula-sum]
Tc          2371.24;      // K   [origin=predictive method=joback]
Pc          7.556;      // bar [origin=predictive method=joback]
omega       -0.3353;      // -   [origin=predictive method=lee-kesler]
Tb          1492.47;      // K   [origin=predictive method=joback]
HvapTb      172417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.412 2.95772 -0.0015727 2.6256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group CH=CH; count 2; } { group OH; count 3; } { group CH2NH; count 1; } { group COOH; count 1; } { group COO; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 22; } { group dCH; count 4; } { group OH; count 3; } { group CdO; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethylamino)ethanol;(z)-4-[2-[2-hydroxyethyl-[(e)-octadec-9-enoyl]amino]ethoxy]-4-oxidanylidene-but-2-enoic acid" "2-butenedioic acid (2z)-, mono(2-((2-hydroxyethyl)((9z)-1-oxo-9-octadecenyl)amino)ethyl) ester, compd. with 2,2'-iminobis(ethanol) (1:1)" "2-(2-hydroxyethylamino)ethanol; (z)-4-[2-[2-hydroxyethyl-[(e)-octadec-9-enoyl]amino]ethoxy]-4-oxobut-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1655530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1759.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-736090.0
    phase     gas;
}
