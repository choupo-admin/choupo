  Component: 2-propenoic acid, 2-hydroxyethyl ester, reaction products with tdi  (C14H20N2O5, CAS 68479-07-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2HydroxyethylEsterReactionProductsWithTdi;
formula     C14H20N2O5;
CAS         68479-07-2;
InChIKey    WYSBEIFYDZESRX-UHFFFAOYSA-N;
MW          296.323;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.75;      // K   [origin=predictive method=joback]
Pc          21.714;      // bar [origin=predictive method=joback]
omega       1.3190;      // -   [origin=predictive method=lee-kesler]
Tb          816.86;      // K   [origin=predictive method=joback]
HvapTb      88501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCd; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diisocyanato-1-methyl-cyclohexane;2-hydroxyethyl prop-2-enoate" "reaction products of 2-hydroxyethyl acrylate with toluene diisocyanate" "toluene-2,4-diisocyanate, hydroxyethyl acrylate urethane" "1,3-diisocyanato-1-methylcyclohexane; 2-hydroxyethyl prop-2-enoate" );
