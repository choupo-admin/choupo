/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-carene  (C10H16, CAS 13466-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Carene;
formula     C10H16;
CAS         13466-78-9;
InChIKey    BQOFWKZOCNGFEC-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          655.13;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.3239;      // -   [origin=predictive method=lee-kesler]
Tb          445.86;      // K   [origin=predictive method=joback]
HvapTb      37346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.78 1.39596 -0.00131164 5.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7,7-trimethylbicyclo[4.1.0]hept-3-ene" "carene" "3,7,7-trimethylbicyclo[4.1.0]hept-3-ene" "s-3-carene" "bicyclo[4.1.0]hept-3-ene, 3,7,7-trimethyl-" "delta(sup 3)-carene" "(+-)-delta3-carene" "(+)car-3-ene" "(+-)-3-carene" "3-norcarene, 3,7,7-trimethyl-" "3,7,7-trimethylbicyclo(4.1.0)hept-3-ene" "bicyclo(4.1.0)hept-3-ene, 3,7,7-trimethyl-" );
gibbsFormation
{
    dHf_298   -69080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149850.0
    phase     gas;
}
