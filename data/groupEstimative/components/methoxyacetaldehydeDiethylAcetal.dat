/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxyacetaldehyde diethyl acetal  (C7H16O3, CAS 4819-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxyacetaldehydeDiethylAcetal;
formula     C7H16O3;
CAS         4819-75-4;
InChIKey    PCYADPMXIILFTP-UHFFFAOYSA-N;
MW          148.202;      // g/mol [origin=calculated method=formula-sum]
Tc          595.36;      // K   [origin=predictive method=joback]
Pc          26.763;      // bar [origin=predictive method=joback]
omega       0.5471;      // -   [origin=predictive method=lee-kesler]
Tb          426.58;      // K   [origin=predictive method=joback]
HvapTb      38018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.343 0.48516 -2.72e-05 -9.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxy-2-methoxy-ethane" "1,1-diethoxy-2-methoxyethane" "ethane, 1,1-diethoxy-2-methoxy-" "methoxyacetaldehyde-diethylacetal" "pcyadpmxiilftp-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -589750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-309380.0
}
