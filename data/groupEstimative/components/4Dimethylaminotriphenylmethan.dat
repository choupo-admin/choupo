/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-dimethylaminotriphenylmethan  (C21H21N, CAS 13865-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Dimethylaminotriphenylmethan;
formula     C21H21N;
CAS         13865-57-1;
InChIKey    CMWPUDHQIUJSCD-UHFFFAOYSA-N;
MW          287.406;      // g/mol [origin=calculated method=formula-sum]
Tc          1029.54;      // K   [origin=predictive method=joback]
Pc          19.753;      // bar [origin=predictive method=joback]
omega       0.7308;      // -   [origin=predictive method=lee-kesler]
Tb          777.10;      // K   [origin=predictive method=joback]
HvapTb      71485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.99 1.83244 -0.00126096 3.272e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 14; } { group AC; count 3; } { group ACCH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(diphenylmethyl)-n,n-dimethyl-aniline" "4-dimethylaminotriphenylmethane" "4-dimethylaminotriphenylmethan [german]" "n,n-dimethyl-4-(diphenylmethyl)aniline" "(4-benzhydrylphenyl)-dimethylamine" "aniline, n,n-dimethyl-4-(diphenylmethyl)-" "4-(dimethylamino)triphenylmethane" "4-benzhydryl-n,n-dimethylaniline" "aniline,n-dimethyl-4-(diphenylmethyl)-" "benzenamine,4-(diphenylmethyl)-n,n-dimethyl-" "benzenamine, 4-(diphenylmethyl)-n,n-dimethyl-" "n,n-dimethyl-alpha, alpha-diphenyl-p-toluidine" );
gibbsFormation
{
    dHf_298   283600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=561880.0
    phase     gas;
}
