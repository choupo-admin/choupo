/*--------------------------------*- Choupo -*-----------------------*\
  Component: dispiro[2.0.2.6]dodecane  (C12H20, CAS 64601-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dispiro2026Dodecane;
formula     C12H20;
CAS         64601-40-7;
InChIKey    YRJUSPHJSULFNE-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          756.94;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.3336;      // -   [origin=predictive method=lee-kesler]
Tb          512.34;      // K   [origin=predictive method=joback]
HvapTb      40568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-280.03 2.178 -0.002271 9.64e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dispiro[2.0.2^{4}.6^{3}]dodecane" "dispiro(2.0.2.6)dodecane" );
standardThermochemistry
{
    dHf_298   -40270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192840.0
}
