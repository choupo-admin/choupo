/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanoic acid, 1,4-butanediyl ester  (C28H54O4, CAS 624-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanoicAcid14ButanediylEster;
formula     C28H54O4;
CAS         624-07-7;
InChIKey    QILMKHPBHSTXSI-UHFFFAOYSA-N;
MW          454.736;      // g/mol [origin=calculated method=formula-sum]
Tc          1184.47;      // K   [origin=predictive method=joback]
Pc          6.588;      // bar [origin=predictive method=joback]
omega       0.4890;      // -   [origin=predictive method=lee-kesler]
Tb          956.68;      // K   [origin=predictive method=joback]
HvapTb      92736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.254 2.55424 -0.0013102 2.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 22; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 24; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-dodecanoyloxybutyl dodecanoate" "butane-1,4-diyl didodecanoate" "dodecanoic acid, 1,1'-(1,4-butanediyl) ester" "dodecanoic acid,1,1'-(1,4-butanediyl) ester" "dodecanoicacid, 1,4-butanediyl ester (9ci); lauric acid, tetramethylene ester(6ci,7ci,8ci); 1,4-butanediol, dilaurate (8ci); 1,4-butanediyl dilaurate;lauric acid, diester with 1,4-butanediol" );
standardThermochemistry
{
    dHf_298   -1255810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1349.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-435860.0
}
