/*--------------------------------*- Choupo -*-----------------------*\
  Component: isosorbide dimethyl ether  (C8H14O4, CAS 5306-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isosorbideDimethylEther;
formula     C8H14O4;
CAS         5306-85-4;
InChIKey    MEJYDZQQVZJMPP-ULAWRXDQSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          699.42;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.5356;      // -   [origin=predictive method=lee-kesler]
Tb          494.06;      // K   [origin=predictive method=joback]
HvapTb      46794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.59 0.86104 -0.0003984 3.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group CH3O; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group O; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,3ar,6r,6ar)-3,6-dimethoxy-2,3,3a,5,6,6a-hexahydrofuro[3,2-b]furan" "dimethyl isosorbide" "1,4:3,6-dianhydro-2,5-di-o-methyl-d-glucitol" "2,5-di-o-methyl-1,4:3,6-dianhydro-d-glucitol" "(3r,3ar,6s,6ar)-3,6-dimethoxyhexahydrofuro[3,2-b]furan" "dimethyl isosorbide ether" "1,4:3,6-dianhydrosorbitol 2,5-dimethyl ether" "arlasolve dmi" "2,5-dimethylisosorbide" "isosorbide, dimethyl ether" "sorbitol, 1,4:3,6-dianhydro-2,5-di-o-methyl-" "d-glucitol, 1,4:3,6-dianhydro-2,5-di-o-methyl" );
standardThermochemistry
{
    dHf_298   -644290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     162.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-283880.0
}
