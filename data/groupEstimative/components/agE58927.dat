  Component: ag-e-58927  (C14H30N2O6, CAS 21697-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agE58927;
formula     C14H30N2O6;
CAS         21697-94-9;
InChIKey    GXYRPXAYFVYAAT-UHFFFAOYSA-N;
MW          322.402;      // g/mol [origin=calculated method=formula-sum]
Tc          1227.37;      // K   [origin=predictive method=joback]
Pc          17.477;      // bar [origin=predictive method=joback]
omega       1.4724;      // -   [origin=predictive method=lee-kesler]
Tb          1002.24;      // K   [origin=predictive method=joback]
HvapTb      107482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (104.162 1.2266 -0.000333 -9.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2O; count 2; } { group CH2NH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group O; count 2; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(3-azanylpropoxy)ethoxy]propan-1-amine;hexanedioic acid" "hexanedioic acid- 3,3'-[ethane-1,2-diylbis(oxy)]dipropan-1-amine(1:1)" "hexanedioic acid compd. with 3,3'-[1,2-ethanediylbis(oxy)]bis[1-propanamine] (1:1)" "3,3'-(ethylenedioxy)bispropylammonium adipate" "3,3'-(ethylenedioxy)bis(propylammonium) adipate" "3-[2-(3-aminopropoxy)ethoxy]propan-1-amine; hexanedioic acid" );
standardThermochemistry
{
    dHf_298   -1341310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1041.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-802680.0
}
