/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-ethylbenz(a)anthracene  (C20H16, CAS 56961-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8EthylbenzAAnthracene;
formula     C20H16;
CAS         56961-62-7;
InChIKey    BQKRLUQCYVLAAO-UHFFFAOYSA-N;
MW          256.348;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.19;      // K   [origin=predictive method=joback]
Pc          22.313;      // bar [origin=predictive method=joback]
omega       0.7506;      // -   [origin=predictive method=lee-kesler]
Tb          755.76;      // K   [origin=predictive method=joback]
HvapTb      69296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.629 1.63532 -0.00130444 4.209e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 11; } { group AC; count 6; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-ethylbenzo[a]anthracene" "5-ethyl-1,2-benzanthracene" "benz(a)anthracene, 8-ethyl-" "benz[a]anthracene, 8-ethyl-" "8-ethyltetraphene" );
gibbsFormation
{
    dHf_298   319200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=520990.0
    phase     gas;
}
