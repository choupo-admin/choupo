/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-dms-diacetate  (C20H20O4, CAS 70244-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transDmsDiacetate;
formula     C20H20O4;
CAS         70244-12-1;
InChIKey    DEZMXODPBGGPOX-BUHFOSPRSA-N;
MW          324.376;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.84;      // K   [origin=predictive method=joback]
Pc          16.879;      // bar [origin=predictive method=joback]
omega       0.9438;      // -   [origin=predictive method=lee-kesler]
Tb          840.88;      // K   [origin=predictive method=joback]
HvapTb      80922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.25 1.53728 -0.00089172 1.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH3COO; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[(e)-3-(4-acetyloxyphenyl)but-2-en-2-yl]phenyl] ethanoate" "trans-dimethylstilbestrol diacetate" "trans-dimethylstilboestrol diacetate" "4,4'-stilbenediol, alpha,alpha'-dimethyl-, diacetate (ester), (e)-" "[4-[(e)-3-(4-acetyloxyphenyl)but-2-en-2-yl]phenyl] acetate" );
gibbsFormation
{
    dHf_298   -542930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     797.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-234540.0
    phase     gas;
}
