/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]heptane-2-carbaldehyde  (C8H12O, CAS 19396-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Heptane2Carbaldehyde;
formula     C8H12O;
CAS         19396-83-9;
InChIKey    UAQYREPFSVCDHT-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          652.17;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.4179;      // -   [origin=predictive method=lee-kesler]
Tb          444.38;      // K   [origin=predictive method=joback]
HvapTb      39811.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.65 1.004 -0.000743 2.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 3; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]heptane-3-carbaldehyde" "2-norbornyl ketone" "bicyclo[2.2.1]heptane-2-carboxaldehyde" "bicyclo(2.2.1)heptane-2-carbaldehyde" "endo-norbornane-2-carboxaldehyde" "2-norbornanecarboxaldehyde, exo-" "bicyclo[2,2,1]heptane-2-carboxaldehyde" "bicyclo[2.2.1]heptane-2-carboxaldehyde, exo-" "2-norbornanecarboxaldehyde(6ci,7ci,8ci);2-formylbicyclo[2.2.1]heptane;2-norbornanecarbaldehyde;" );
gibbsFormation
{
    dHf_298   -174930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     283.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18650.0
    phase     gas;
}
