/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromodecane  (C10H21Br, CAS 112-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromodecane;
formula     C10H21Br;
CAS         112-29-8;
InChIKey    MYMSJFSOOQERIO-UHFFFAOYSA-N;
MW          221.182;      // g/mol [origin=calculated method=formula-sum]
Tc          672.34;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.6215;      // -   [origin=predictive method=lee-kesler]
Tb          494.56;      // K   [origin=predictive method=joback]
HvapTb      44289.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.989 0.99202 -0.0005916 1.419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyldecane" "decyl bromide" "n-decyl bromide" "decane, 1-bromo-" "1-decyl bromide" "decylbromide" "bromodecane" "1-bromo decane" "decane, bromo-" "i867" );
standardThermochemistry
{
    dHf_298   -223400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47640.0
}
