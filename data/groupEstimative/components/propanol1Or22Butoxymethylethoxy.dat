/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanol, 1(or 2)-(2-butoxymethylethoxy)-  (C10H22O3, CAS 35884-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanol1Or22Butoxymethylethoxy;
formula     C10H22O3;
CAS         35884-42-5;
InChIKey    LNFLHXZJCVGTSO-UHFFFAOYSA-N;
MW          190.283;      // g/mol [origin=calculated method=formula-sum]
Tc          726.53;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       1.0757;      // -   [origin=predictive method=lee-kesler]
Tb          564.98;      // K   [origin=predictive method=joback]
HvapTb      58965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.407 0.86734 -0.0003318 7.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-butoxypropoxy)propan-1-ol" );
gibbsFormation
{
    dHf_298   -671680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-315940.0
    phase     gas;
}
