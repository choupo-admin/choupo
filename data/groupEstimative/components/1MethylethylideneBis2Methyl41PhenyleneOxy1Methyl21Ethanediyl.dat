/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-methylethylidene)bis((2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)) bismethacrylate  (C31H40O6, CAS 70146-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylethylideneBis2Methyl41PhenyleneOxy1Methyl21Ethanediyl;
formula     C31H40O6;
CAS         70146-06-4;
InChIKey    CUUNNZSQCNASCH-UHFFFAOYSA-N;
MW          508.655;      // g/mol [origin=calculated method=formula-sum]
Tc          1387.01;      // K   [origin=predictive method=joback]
Pc          8.224;      // bar [origin=predictive method=joback]
omega       0.7860;      // -   [origin=predictive method=lee-kesler]
Tb          1132.45;      // K   [origin=predictive method=joback]
HvapTb      108182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.712 2.41456 -0.00127424 1.946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 2; } { group ACH; count 6; } { group AC; count 4; } { group ACCH3; count 2; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-methyl-4-[2-[3-methyl-4-[2-(2-methylprop-2-enoyloxy)propoxy]phenyl]propan-2-yl]phenoxy]propan-2-yl 2-methylprop-2-enoate" "(1-methylethylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)] bismethacrylate" "2-propenoic acid, 2-methyl-, (1-methylethylidene)bis((2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)) ester" "2-propenoic acid, 2-methyl-, (1-methylethylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)] ester" "2-propenoic acid, 2-methyl-, 1,1'-((1-methylethylidene)bis((2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl))) ester" "2-propenoic acid, 2-methyl-, 1,1'-[(1-methylethylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)]] ester" "2-propenoic acid,2-methyl-,1,1'-[(1-methylethylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)]]ester" "2-propenoicacid, 2-methyl-, (1-methylethylidene)bis[(2-methyl-4,1-phenylene)oxy(1-methyl-2,1-ethanediyl)]ester (9ci)" );
gibbsFormation
{
    dHf_298   -943020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1175.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277760.0
    phase     gas;
}
