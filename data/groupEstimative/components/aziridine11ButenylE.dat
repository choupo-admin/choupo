/*--------------------------------*- Choupo -*-----------------------*\
  Component: aziridine, 1-(1-butenyl)-, (e)-  (C6H11N, CAS 80839-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aziridine11ButenylE;
formula     C6H11N;
CAS         80839-92-5;
InChIKey    ZOJXHLVIYWZLQK-ONEGZZNKSA-N;
MW          97.161;      // g/mol [origin=calculated method=formula-sum]
Tc          540.50;      // K   [origin=predictive method=joback]
Pc          38.771;      // bar [origin=predictive method=joback]
omega       0.3503;      // -   [origin=predictive method=lee-kesler]
Tb          360.62;      // K   [origin=predictive method=joback]
HvapTb      31001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.499 0.90472 -0.000821 3.024e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(e)-but-1-enyl]aziridine" "(e)-1-(1-butenyl)aziridine" );
standardThermochemistry
{
    dHf_298   116880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=271200.0
}
