/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(5-bromo-2-pentyloxybenzyloxy)triethylamine  (C18H30BrNO2, CAS 109965-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Bromo2PentyloxybenzyloxyTriethylamine;
formula     C18H30BrNO2;
CAS         109965-82-4;
InChIKey    OKLNKVUJLBLOSU-UHFFFAOYSA-N;
MW          372.347;      // g/mol [origin=calculated method=formula-sum]
Tc          967.37;      // K   [origin=predictive method=joback]
Pc          14.657;      // bar [origin=predictive method=joback]
omega       1.0252;      // -   [origin=predictive method=lee-kesler]
Tb          771.52;      // K   [origin=predictive method=joback]
HvapTb      72560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.719 1.55166 -0.00081452 1.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2O; count 2; } { group CH2N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(5-bromanyl-2-pentoxy-phenyl)methoxy]-n,n-diethyl-ethanamine" "triethylamine, 2-(5-bromo-2-pentyloxybenzyloxy)-" "2-[(5-bromo-2-pentoxyphenyl)methoxy]-n,n-diethylethanamine" );
gibbsFormation
{
    dHf_298   -371840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108930.0
    phase     gas;
}
