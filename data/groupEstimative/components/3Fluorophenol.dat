/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluorophenol  (C6H5FO, CAS 372-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Fluorophenol;
formula     C6H5FO;
CAS         372-20-3;
InChIKey    SJTBRFHBXDZMPS-UHFFFAOYSA-N;
MW          112.103;      // g/mol [origin=calculated method=formula-sum]
Tc          664.04;      // K   [origin=predictive method=joback]
Pc          54.145;      // bar [origin=predictive method=joback]
omega       0.4751;      // -   [origin=predictive method=lee-kesler]
Tb          443.45;      // K   [origin=predictive method=joback]
HvapTb      43423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.3 0.6613 -0.00060656 2.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-fluoranylphenol" "m-fluorophenol" "phenol, 3-fluoro-" "phenol, m-fluoro-" "3-fluoro-phenol" "phenol, m-fluoro- (8ci)" "phenol, 3-fluoro- (9ci)" "f135" "phenol, 3-fluoro- (9ci);phenol, m-fluoro-;m-fluorophenol;phenol, m-fluoro- (8ci);" );
standardThermochemistry
{
    dHf_298   -304060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237380.0
}
