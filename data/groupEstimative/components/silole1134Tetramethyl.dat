/*--------------------------------*- Choupo -*-----------------------*\
  Component: silole, 1,1,3,4-tetramethyl-  (C8H14Si, CAS 82763-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H14Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silole1134Tetramethyl;
formula     C8H14Si;
CAS         82763-95-9;
InChIKey    DGINLBZBKTXQBR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          138.285;      // g/mol [origin=calculated method=formula-sum]
Tc          607.53;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.2631;      // -   [origin=predictive method=lee-kesler]
Tb          408.00;      // K   [origin=predictive method=joback]
HvapTb      35998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.29 0.49448 -6.628e-05 -7.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH=C; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,4-tetramethylsilole" );
standardThermochemistry
{
    dHf_298   -140470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8740.0
}
