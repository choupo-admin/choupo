/*--------------------------------*- Choupo -*-----------------------*\
  Component: asclepiadin  (C31H42O10, CAS 36573-63-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        asclepiadin;
formula     C31H42O10;
CAS         36573-63-4;
InChIKey    OXKMZIABKYHLAR-UHFFFAOYSA-N;
MW          574.667;      // g/mol [origin=calculated method=formula-sum]
Tc          1736.76;      // K   [origin=predictive method=joback]
Pc          12.183;      // bar [origin=predictive method=joback]
omega       0.9393;      // -   [origin=predictive method=lee-kesler]
Tb          1393.34;      // K   [origin=predictive method=joback]
HvapTb      148113.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-430.32 4.75496 -0.00442034 1.7228e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 6; } { group C; count 4; } { group CH=C; count 1; } { group OH; count 2; } { group CHO; count 1; } { group CH3COO; count 1; } { group CH-O; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 10; } { group CH_ring; count 9; } { group C_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } { group O_ring; count 3; } { group OdCH_al; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3'-o-acetylcalotropin" "calotropin, 3'-o-acetyl-" "asclepin" "(2alpha(2s,3s,4s,6r),3beta,5alpha)-2,3-((4-acetoxytetrahydro-3-hydroxy-6-methyl-2h-pyran-3,2-diyl)bis(oxy))-14-hydroxy-19-oxocard-20(22)-enolide" "(2alpha,3beta,5alpha)-3-((3-o-acetyl-4,6-dideoxy-d-erythro-hexopyranos-2-ulos-1-yl)oxy) card-20(22)-enolide" "13a-formyl-3a,11a-dihydroxy-9,15a-dimethyl-1-(5-oxo-2,5-dihydrofuran-3-yl)icosahydro-1h,7ah-cyclopenta[7,8]phenanthro[2,3-b]pyrano[3,2-e][1,4]dioxin-11-yl acetate" );
standardThermochemistry
{
    dHf_298   -1652060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     920.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-749460.0
}
