/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylcyclooctatetraene  (C9H10, CAS 2570-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylcyclooctatetraene;
formula     C9H10;
CAS         2570-12-9;
InChIKey    WGRJXUSSGKUCDU-UHFFFAOYSA-N;
MW          118.179;      // g/mol [origin=calculated method=formula-sum]
Tc          667.09;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.2783;      // -   [origin=predictive method=lee-kesler]
Tb          439.90;      // K   [origin=predictive method=joback]
HvapTb      38540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.66 0.70472 -0.00039148 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   52900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143070.0
}
