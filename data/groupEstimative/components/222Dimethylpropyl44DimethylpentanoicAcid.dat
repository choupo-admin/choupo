/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,2-dimethylpropyl)-4,4-dimethylpentanoic acid  (C12H24O2, CAS 30667-81-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Dimethylpropyl44DimethylpentanoicAcid;
formula     C12H24O2;
CAS         30667-81-3;
InChIKey    PQKYLIYFBFVIOW-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          813.01;      // K   [origin=predictive method=joback]
Pc          20.019;      // bar [origin=predictive method=joback]
omega       0.7277;      // -   [origin=predictive method=lee-kesler]
Tb          612.77;      // K   [origin=predictive method=joback]
HvapTb      56490.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.048 1.45222 -0.0010484 3.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,2-dimethylpropyl)-4,4-dimethyl-pentanoic acid" "pentanoic acid,2-(2,2-dimethylpropyl)-4,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -664060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-290510.0
    phase     gas;
}
