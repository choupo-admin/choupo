/*--------------------------------*- Choupo -*-----------------------*\
  Component: octane, 3,6-diphenyl-  (C20H26, CAS 21411-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octane36Diphenyl;
formula     C20H26;
CAS         21411-33-6;
InChIKey    DYCDLRHYBKZTGO-UHFFFAOYSA-N;
MW          266.428;      // g/mol [origin=calculated method=formula-sum]
Tc          932.02;      // K   [origin=predictive method=joback]
Pc          16.525;      // bar [origin=predictive method=joback]
omega       0.6879;      // -   [origin=predictive method=lee-kesler]
Tb          709.68;      // K   [origin=predictive method=joback]
HvapTb      63890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.466 1.75784 -0.001133 2.768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 10; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-phenyloctan-3-ylbenzene" "octane, 3,6-diphenyl-," "1,1'-octane-3,6-diyldibenzene" );
standardThermochemistry
{
    dHf_298   6370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=337460.0
}
