/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diethoxy-4-morpholinoaniline  (C14H22N2O3, CAS 51963-82-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Diethoxy4Morpholinoaniline;
formula     C14H22N2O3;
CAS         51963-82-7;
InChIKey    DDCBPJKVWMBNCC-UHFFFAOYSA-N;
MW          266.341;      // g/mol [origin=calculated method=formula-sum]
Tc          959.82;      // K   [origin=predictive method=joback]
Pc          23.772;      // bar [origin=predictive method=joback]
omega       1.0077;      // -   [origin=predictive method=lee-kesler]
Tb          738.25;      // K   [origin=predictive method=joback]
HvapTb      73600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.148 1.29104 -0.00067078 1.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 2; } { group AC; count 3; } { group CH2O; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group O_ring; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-diethoxy-4-morpholin-4-yl-aniline" "2,5-diethoxy-4-(morpholin-4-yl)aniline" "n-(4-amino-2,5-diethoxyphenyl)morpholine" "2,5-diethoxy-4-morpholino aniline" "2,5-diethoxy-4-morpholinyl aniline" "benzenamine, 2,5-diethoxy-4-(4-morpholinyl)-" "2,5-diethoxy-4-morpholin-4-ylaniline" "2,5-diethoxy-4-(4-morpholinyl)aniline" "bim-0038422.p001" "2,5-diethoxy-4-(4-morpholinyl)benzenamine" "benzenamine,5-diethoxy-4-(4-morpholinyl)-" "benzenamine,2,5-diethoxy-4-(4-morpholinyl)-" );
standardThermochemistry
{
    dHf_298   -344470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75890.0
}
