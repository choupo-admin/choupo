/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloro-8-hydroxyquinoline  (C9H6ClNO, CAS 130-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Chloro8Hydroxyquinoline;
formula     C9H6ClNO;
CAS         130-16-5;
InChIKey    CTQMJYWDVABFRZ-UHFFFAOYSA-N;
MW          179.603;      // g/mol [origin=calculated method=formula-sum]
Tc          896.60;      // K   [origin=predictive method=joback]
Pc          50.442;      // bar [origin=predictive method=joback]
omega       0.6999;      // -   [origin=predictive method=lee-kesler]
Tb          627.91;      // K   [origin=predictive method=joback]
HvapTb      63815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.31 0.91186 -0.0008527 3.215e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACOH; count 1; } { group C5H3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH_phenol; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranylquinolin-8-ol" "cloxyquin" "5-chloro-8-quinolinol" "cloxiquine" "8-quinolinol, 5-chloro-" "5-chloroquinolin-8-ol" "dermofongin" "5-chlorooxine" "chlorisept" "chloroxychinolin" "dermofongin a" "monochlorohydroxyquinoline" );
gibbsFormation
{
    dHf_298   26780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144830.0
    phase     gas;
}
