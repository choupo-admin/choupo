/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 1,8-octanediol, diacetate  (C18H32O8, CAS 67989-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith18OctanediolDiacetate;
formula     C18H32O8;
CAS         67989-19-9;
InChIKey    ZECNZTKSYNJDSE-UHFFFAOYSA-N;
MW          376.446;      // g/mol [origin=calculated method=formula-sum]
Tc          1250.24;      // K   [origin=predictive method=joback]
Pc          12.346;      // bar [origin=predictive method=joback]
omega       1.1489;      // -   [origin=predictive method=lee-kesler]
Tb          1020.30;      // K   [origin=predictive method=joback]
HvapTb      105098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (87.362 1.49964 -0.0004966 -7.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH3COO; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-acetyloxyoctyl ethanoate;hexanedioic acid" "8-acetyloxyoctyl acetate; hexanedioic acid" "1,8-octylene glycol adipate polymer, diacetate" );
standardThermochemistry
{
    dHf_298   -1861570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1173.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1312640.0
}
