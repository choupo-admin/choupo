/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichlorophloroglucinol  (C6H3Cl3O3, CAS 56961-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichlorophloroglucinol;
formula     C6H3Cl3O3;
CAS         56961-23-0;
InChIKey    MHKCQYLJFGNSQZ-UHFFFAOYSA-N;
MW          229.437;      // g/mol [origin=calculated method=formula-sum]
Tc          995.66;      // K   [origin=predictive method=joback]
Pc          74.702;      // bar [origin=predictive method=joback]
omega       1.2045;      // -   [origin=predictive method=lee-kesler]
Tb          727.67;      // K   [origin=predictive method=joback]
HvapTb      84747.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.04 0.8601 -0.00103 4.622e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACOH; count 3; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group Cl; count 3; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(chloranyl)benzene-1,3,5-triol" "trichloro-1,3,5-trihydroxybenzene" "phloroglucinol, trichloro-" "2,4,6-trichlorobenzene-1,3,5-triol" );
standardThermochemistry
{
    dHf_298   -532730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-406860.0
}
