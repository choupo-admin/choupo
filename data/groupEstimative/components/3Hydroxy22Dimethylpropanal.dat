/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-2,2-dimethylpropanal  (C5H10O2, CAS 597-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy22Dimethylpropanal;
formula     C5H10O2;
CAS         597-31-9;
InChIKey    JJMOMMLADQPZNY-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          630.29;      // K   [origin=predictive method=joback]
Pc          43.684;      // bar [origin=predictive method=joback]
omega       0.7813;      // -   [origin=predictive method=lee-kesler]
Tb          451.61;      // K   [origin=predictive method=joback]
HvapTb      48827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.439 0.61314 -0.0004434 1.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-3-oxidanyl-propanal" "pentaldol" "3-hydroxypivalaldehyde" "pentaaldol" "hydroxypivaldehyde" "hydroxypivalaldehyde" "propanal, 3-hydroxy-2,2-dimethyl-" "2,2-dimethyl-3-hydroxypropionaldehyde" "2,2-dimethyl-3-hydroxypropanal" "3-hydroxy-2,2-dimethylpropionaldehyde" "hydracrylaldehyde, 2,2-dimethyl-" "2-(hyroxymethyl)-2-methylpropanal" );
standardThermochemistry
{
    dHf_298   -393090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242280.0
}
