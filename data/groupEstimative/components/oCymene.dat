/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-cymene  (C10H14, CAS 527-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oCymene;
formula     C10H14;
CAS         527-84-4;
InChIKey    WWRCMNKATXZARA-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          670.52;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       0.3578;      // -   [origin=predictive method=lee-kesler]
Tb          459.62;      // K   [origin=predictive method=joback]
HvapTb      40404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.49 0.82136 -0.00048756 1.079e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2-propan-2-yl-benzene" "2-isopropyltoluene" "1-isopropyl-2-methylbenzene" "o-cymol" "o-isopropyltoluene" "benzene, 1-methyl-2-(1-methylethyl)-" "cymene, ortho" "1-methyl-2-isopropylbenzene" "1-methyl-2-isopropylbenzol" "benzene, methyl(1-methylethyl)-" "1-methyl-2-(1-methylethyl)benzene" "methylisopropylbenzene" );
gibbsFormation
{
    dHf_298   -29950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133660.0
    phase     gas;
}
