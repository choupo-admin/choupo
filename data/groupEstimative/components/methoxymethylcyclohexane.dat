/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxymethylcyclohexane  (C8H16O, CAS 19752-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methoxymethylcyclohexane;
formula     C8H16O;
CAS         19752-94-4;
InChIKey    UXXIFJBQPUDTNK-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          624.85;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.3437;      // -   [origin=predictive method=lee-kesler]
Tb          424.61;      // K   [origin=predictive method=joback]
HvapTb      36241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.489 0.82272 -0.0003814 3.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(methoxymethyl)cyclohexane" );
gibbsFormation
{
    dHf_298   -286350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64070.0
    phase     gas;
}
