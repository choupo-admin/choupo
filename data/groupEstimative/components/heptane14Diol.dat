/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptane-1,4-diol  (C7H16O2, CAS 113611-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptane14Diol;
formula     C7H16O2;
CAS         113611-45-3;
InChIKey    OGRCRHSHBFQRKO-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          703.34;      // K   [origin=predictive method=joback]
Pc          34.684;      // bar [origin=predictive method=joback]
omega       1.3110;      // -   [origin=predictive method=lee-kesler]
Tb          543.68;      // K   [origin=predictive method=joback]
HvapTb      64146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.425 0.74272 -0.000421 9.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-heptanediol, (r)-" "1,4-heptanediol" );
gibbsFormation
{
    dHf_298   -497550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268020.0
    phase     gas;
}
