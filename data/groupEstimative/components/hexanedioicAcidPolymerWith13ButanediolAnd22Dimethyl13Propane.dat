/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 1,3-butanediol and 2,2-dimethyl-1,3-propanediol  (C15H32O8, CAS 103849-43-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith13ButanediolAnd22Dimethyl13Propane;
formula     C15H32O8;
CAS         103849-43-0;
InChIKey    GRNJNLZNWQLNCI-UHFFFAOYSA-N;
MW          340.413;      // g/mol [origin=calculated method=formula-sum]
Tc          1538.24;      // K   [origin=predictive method=joback]
Pc          19.561;      // bar [origin=predictive method=joback]
omega       1.0259;      // -   [origin=predictive method=lee-kesler]
Tb          1201.67;      // K   [origin=predictive method=joback]
HvapTb      148932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.098 1.38576 -0.0004044 -1.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,3-diol;2,2-dimethylpropane-1,3-diol;hexanedioic acid" );
standardThermochemistry
{
    dHf_298   -1899660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1217.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1368800.0
}
