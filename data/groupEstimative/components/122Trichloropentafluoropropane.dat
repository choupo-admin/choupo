/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,2-trichloropentafluoropropane  (C3Cl3F5, CAS 1599-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122Trichloropentafluoropropane;
formula     C3Cl3F5;
CAS         1599-41-3;
InChIKey    SFCFZNZZFJRHSD-UHFFFAOYSA-N;
MW          237.373;      // g/mol [origin=calculated method=formula-sum]
Tc          543.28;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.3263;      // -   [origin=predictive method=lee-kesler]
Tb          367.19;      // K   [origin=predictive method=joback]
HvapTb      27454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.13 0.7456 -0.000798 2.952e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 1; } { group CF3; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 5; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2-tris(chloranyl)-1,1,3,3,3-pentakis(fluoranyl)propane" "propane, 1,2,2-trichloropentafluoro-" "1,2,2-trichloro-1,1,3,3,3-pentafluoropropane" "pentafluoro-1,2,2-trichloropropane" "propane, pentafluoro-1,2,2-trichloro-" "propane, 1,2,2-trichloro-1,1,3,3,3-pentafluoro-" "propane,1,2,2-trichloro-1,1,3,3,3-pentafluoro-" );
gibbsFormation
{
    dHf_298   -1159270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1026940.0
    phase     gas;
}
