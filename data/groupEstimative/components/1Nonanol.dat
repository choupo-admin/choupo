/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonanol  (C9H20O, CAS 143-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonanol;
formula     C9H20O;
CAS         143-08-8;
InChIKey    ZWRUINPWMLAQRD-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          656.85;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.9110;      // -   [origin=predictive method=lee-kesler]
Tb          497.70;      // K   [origin=predictive method=joback]
HvapTb      52307.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.002 0.89282 -0.0004962 1.057e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonan-1-ol" "nonanol" "nonyl alcohol" "n-nonyl alcohol" "pelargonic alcohol" "nonalol" "octyl carbinol" "1-hydroxynonane" "alcohol c-9" "n-nonan-1-ol" "n-nonanol" "c9 alcohol" );
standardThermochemistry
{
    dHf_298   -381320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111920.0
}
