/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trifluoroethyl methacrylate  (C6H7F3O2, CAS 352-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222TrifluoroethylMethacrylate;
formula     C6H7F3O2;
CAS         352-87-4;
InChIKey    QTKPMCIBUROOGY-UHFFFAOYSA-N;
MW          168.114;      // g/mol [origin=calculated method=formula-sum]
Tc          549.97;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.4731;      // -   [origin=predictive method=lee-kesler]
Tb          386.24;      // K   [origin=predictive method=joback]
HvapTb      32020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.961 0.66012 -0.0004542 1.11e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)ethyl 2-methylprop-2-enoate" "trifluoroethyl methacrylate" "2,2,2-trifluoroethyl 2-methylprop-2-enoate" "methacrylic acid 2,2,2-trifluoroethyl ester" "2-propenoic acid, 2-methyl-, 2,2,2-trifluoroethyl ester" "2,2,2-trifluoroethyl es" "2,2-trifluoroethyl methacrylate" "2-propenoic acid, 2-methyl-, 2,2,2-trifluoroethyl ester, homopolymer" "2-methyl-acrylic acid 2,2,2-trifluo" "2,2,2-trifluoroethyl methacrylate 99%" "methacrylic acid,2,2-trifluoroethyl ester" "methacrylic acid, 2,2,2-trifluoroethyl ester" );
gibbsFormation
{
    dHf_298   -965890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-813030.0
    phase     gas;
}
