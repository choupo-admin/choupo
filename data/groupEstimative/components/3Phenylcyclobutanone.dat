/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylcyclobutanone  (C10H10O, CAS 52784-31-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylcyclobutanone;
formula     C10H10O;
CAS         52784-31-3;
InChIKey    BVQSFCUGCAZOJQ-UHFFFAOYSA-N;
MW          146.189;      // g/mol [origin=calculated method=formula-sum]
Tc          782.39;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.4264;      // -   [origin=predictive method=lee-kesler]
Tb          533.91;      // K   [origin=predictive method=joback]
HvapTb      44462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.04 0.8479 -0.0004812 8.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylcyclobutan-1-one" "1-oxo-3-phenylcyclobutane" "3-phenyl-cyclobutan-1-one" "3-phenylcyclobutan-1-one;" "3-phenyl-cyclobutane-1-one" );
gibbsFormation
{
    dHf_298   -84260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71790.0
    phase     gas;
}
