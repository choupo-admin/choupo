/*--------------------------------*- Choupo -*-----------------------*\
  Component: s-2-bromopropionic acid  (C3H5BrO2, CAS 32644-15-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s2BromopropionicAcid;
formula     C3H5BrO2;
CAS         32644-15-8;
InChIKey    MONMFXREYOKQTI-REOHCLBHSA-N;
MW          152.975;      // g/mol [origin=calculated method=formula-sum]
Tc          697.42;      // K   [origin=predictive method=joback]
Pc          55.692;      // bar [origin=predictive method=joback]
omega       0.6337;      // -   [origin=predictive method=lee-kesler]
Tb          479.47;      // K   [origin=predictive method=joback]
HvapTb      45483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.27 0.38372 -0.0002866 8.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-bromanylpropanoic acid" "(s)-(-)-2-bromopropionic acid" "(s)-2-bromopropanoic acid" "(2s)-2-bromopropanoic acid" "l-2-bromopropionic acid" "(s)-2-bromopropionic acid" "(2s)-(-)-2-bromopropionic acid" "sgphcqbilusrx@" "l-" "a-bromopropionic acid" "(s)-" "a-bromopropionic acid" "(-)-" "a-bromopropanoic acid" "l-alpha-bromopropionic acid" );
gibbsFormation
{
    dHf_298   -434470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     367.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-357650.0
    phase     gas;
}
