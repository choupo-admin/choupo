/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl formate  (C7H14O2, CAS 629-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H14O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexylFormate;
formula     C7H14O2;
CAS         629-33-4;
InChIKey    OUGPMNMLWKSBRI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          496.57;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.2946;      // -   [origin=predictive method=lee-kesler]
Tb          336.18;      // K   [origin=predictive method=joback]
HvapTb      28803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.975 0.67692 -0.00051 1.688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl methanoate" "n-hexyl formate" "formic acid, hexyl ester" "n-hexyl methanoate" "formic acid hexyl ester" );
gibbsFormation
{
    dHf_298   -111360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52020.0
    phase     gas;
}
