/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-benzotricyclo(4.1.0.01,3)hept-4-ene  (C11H10, CAS 74410-87-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45Benzotricyclo410013Hept4Ene;
formula     C11H10;
CAS         74410-87-0;
InChIKey    AMKTWDDHZREJTB-UHFFFAOYSA-N;
MW          142.201;      // g/mol [origin=calculated method=formula-sum]
Tc          717.23;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       0.4128;      // -   [origin=predictive method=lee-kesler]
Tb          486.32;      // K   [origin=predictive method=joback]
HvapTb      40918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-206.95 1.6934 -0.00191756 8.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-benzotricyclo[4.1.0.01,3]hept-4-ene" "1,2,2a,6b-tetrahydrodicyclopropa[a,b]indene" );
gibbsFormation
{
    dHf_298   212970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     190.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=369680.0
    phase     gas;
}
