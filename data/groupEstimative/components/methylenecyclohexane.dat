/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenecyclohexane  (C7H12, CAS 1192-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenecyclohexane;
formula     C7H12;
CAS         1192-37-6;
InChIKey    YULMNMJFAZWLLN-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          588.33;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.2454;      // -   [origin=predictive method=lee-kesler]
Tb          383.14;      // K   [origin=predictive method=joback]
HvapTb      32073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.73 0.6999 -0.000401 8.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylidenecyclohexane" "cyclohexane, methylene-" "1-methylenecyclohexane" "cyclohexylmethyl" "methylcyclohexyl" "1-methylcyclohexyl" "methylene-cyclohexane" "agn-pc-03f28r" );
standardThermochemistry
{
    dHf_298   -28910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93300.0
}
