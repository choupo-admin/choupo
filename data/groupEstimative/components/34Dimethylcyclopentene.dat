/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethylcyclopentene  (C7H12, CAS 56039-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethylcyclopentene;
formula     C7H12;
CAS         56039-55-5;
InChIKey    JOVGLRSLWFSVNB-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          565.04;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.2309;      // -   [origin=predictive method=lee-kesler]
Tb          369.53;      // K   [origin=predictive method=joback]
HvapTb      31416.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.24 0.71804 -0.00041628 8.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-3,4-dimethylcyclopentene" "trans-3,4-dimethylcyclopentene" "(3r,4r)-3,4-dimethylcyclopentene" );
standardThermochemistry
{
    dHf_298   -89890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     298.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66860.0
}
