/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxymethyl  (C2H5O, CAS 16520-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        methoxymethyl;
formula     C2H5O;
CAS         16520-04-0;
InChIKey    AFGPRWUFPLEMTF-UHFFFAOYSA-N;
role        radical;
MW          45.061;      // g/mol [origin=calculated method=formula-sum]
Tc          421.19;      // K   [origin=predictive method=joback]
Pc          50.228;      // bar [origin=predictive method=joback]
omega       0.1881;      // -   [origin=predictive method=lee-kesler]
Tb          262.38;      // K   [origin=predictive method=joback]
HvapTb      21807.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.67 0.10062 4.5e-05 -4.85e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxymethane" "methyl, methoxy-" "methyl radical, methoxy-" );
standardThermochemistry
{
    dHf_298   -150010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     243.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91310.0
}
