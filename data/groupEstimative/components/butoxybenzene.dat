/*--------------------------------*- Choupo -*-----------------------*\
  Component: butoxybenzene  (C10H14O, CAS 1126-79-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butoxybenzene;
formula     C10H14O;
CAS         1126-79-0;
InChIKey    YFNONBGXNFCTMM-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          680.71;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       0.4642;      // -   [origin=predictive method=lee-kesler]
Tb          477.50;      // K   [origin=predictive method=joback]
HvapTb      42540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.607 0.81172 -0.0004404 7.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl phenyl ether" "n-butyl phenyl ether" "benzene, butoxy-" "ether, butyl phenyl" "butoxyphenyl" "phenyl butyl ether" "n-butoxybenzene" "(butyloxy)benzene" "butoxy-benzene" );
gibbsFormation
{
    dHf_298   -145420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40730.0
    phase     gas;
}
