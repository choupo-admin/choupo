/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 2-hydroxy-, polymer with 1-piperazineethanamine  (C13H21N3O3, CAS 82783-89-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid2HydroxyPolymerWith1Piperazineethanamine;
formula     C13H21N3O3;
CAS         82783-89-9;
InChIKey    ZCFOCZVKWCWCBT-UHFFFAOYSA-N;
MW          267.329;      // g/mol [origin=calculated method=formula-sum]
Tc          1156.62;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       1.4547;      // -   [origin=predictive method=lee-kesler]
Tb          904.72;      // K   [origin=predictive method=joback]
HvapTb      97288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.038 1.4897 -0.00090696 1.961e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylbenzoic acid;2-piperazin-1-ylethanamine" "amino ethyl piperazine, salicylic acid polymer" "salicylic acid, compound with piperazine-1-ethylamine" );
standardThermochemistry
{
    dHf_298   -494370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     796.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123100.0
}
