/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diisopropyl-2-methylbenzene  (C13H20, CAS 58502-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diisopropyl2Methylbenzene;
formula     C13H20;
CAS         58502-85-5;
InChIKey    BRXCOIOOGGCKPZ-UHFFFAOYSA-N;
MW          176.303;      // g/mol [origin=calculated method=formula-sum]
Tc          740.36;      // K   [origin=predictive method=joback]
Pc          21.653;      // bar [origin=predictive method=joback]
omega       0.4698;      // -   [origin=predictive method=lee-kesler]
Tb          532.80;      // K   [origin=predictive method=joback]
HvapTb      47356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.6 1.0528 -0.00058692 1.182e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1,4-di(propan-2-yl)benzene" "benzene, 2-methyl-1,4-bis(1-methylethyl)-" "benzene,2-methyl-1,4-bis(1-methylethyl)-" "toluene,2,5-diisopropyl- (6ci); 2,5-diisopropyltoluene" );
gibbsFormation
{
    dHf_298   -108620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146850.0
    phase     gas;
}
