/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromopropane  (C3H7Br, CAS 75-26-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromopropane;
formula     C3H7Br;
CAS         75-26-3;
InChIKey    NAMYKGVDVNBCFQ-UHFFFAOYSA-N;
MW          122.993;      // g/mol [origin=calculated method=formula-sum]
Tc          524.66;      // K   [origin=predictive method=joback]
Pc          48.971;      // bar [origin=predictive method=joback]
omega       0.2503;      // -   [origin=predictive method=lee-kesler]
Tb          333.96;      // K   [origin=predictive method=joback]
HvapTb      28319.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.67 0.33294 -0.000214 5.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylpropane" "isopropyl bromide" "propane, 2-bromo-" "2-bromo-propane" "isopropylbromide" "agn-pc-00pz0h" "isopropyl bromide;propane, 2-bromo-;" );
gibbsFormation
{
    dHf_298   -84200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-13740.0
    phase     gas;
}
