/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetraphenyl-1,3-cyclopentadiene  (C29H22, CAS 15570-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetraphenyl13Cyclopentadiene;
formula     C29H22;
CAS         15570-45-3;
InChIKey    JCXLYAWYOTYWKM-UHFFFAOYSA-N;
MW          370.495;      // g/mol [origin=calculated method=formula-sum]
Tc          1293.79;      // K   [origin=predictive method=joback]
Pc          16.619;      // bar [origin=predictive method=joback]
omega       0.8850;      // -   [origin=predictive method=lee-kesler]
Tb          1008.03;      // K   [origin=predictive method=joback]
HvapTb      93050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.76 2.2514 -0.0015678 4.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 20; } { group AC; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 20; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3,4-triphenylcyclopenta-1,3-dien-1-yl)benzene" "1,2,3,4-tetraphenylcyclopentadiene" "tetraphenylcyclopentadiene" "1, 1,2,3,4-tetraphenyl-" "1,3,4-tetraphenylcyclopentadiene" "1,3,4-tetraphenyl-1,3-cyclopentadiene" "1,2,3,4-tetraphenylcyclopenta-1,3-diene" "(2,4,5-triphenylcyclopenta-1,4-dien-1-yl)benzene" "1,3-cyclopentadiene, 1,2,3,4-tetraphenyl- (8ci)" "benzene, 1,1',1'',1'''-(1,3-cyclopentadiene-1,2,3,4-tetrayl)tetrakis-" "benzene,1',1'',1'''-(1,3-cyclopentadiene-1,2,3,4-tetrayl)tetrakis-" "benzene,1,1',1'',1'''-(1,3-cyclopentadiene-1,2,3,4-tetrayl)tetrakis-" );
standardThermochemistry
{
    dHf_298   454730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=708600.0
}
