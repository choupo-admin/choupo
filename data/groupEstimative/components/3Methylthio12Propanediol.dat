/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(methylthio)-1,2-propanediol  (C4H10O2S, CAS 22551-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylthio12Propanediol;
formula     C4H10O2S;
CAS         22551-26-4;
InChIKey    FXIHXPKPLPKPJH-UHFFFAOYSA-N;
MW          122.182;      // g/mol [origin=calculated method=formula-sum]
Tc          722.93;      // K   [origin=predictive method=joback]
Pc          51.534;      // bar [origin=predictive method=joback]
omega       1.2732;      // -   [origin=predictive method=lee-kesler]
Tb          543.82;      // K   [origin=predictive method=joback]
HvapTb      64285.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.752 0.45211 -0.0002176 2.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylsulfanylpropane-1,2-diol" "3-methylthiopropane-1,2-diol" "fxihxpkplpkpjh-uhfffaoysa-" "1,2-propanediol,3-(methylthio)-" "1,2-propanediol, 3-(methylthio)-" "3-(methylsulfanyl)propane-1,2-diol" "3-methylthio-1,2-propanediol" "3-(methylthio)-1,2-propanediol;3-(methylsulfanyl)propane-1,2-diol;3-(methylsulfanyl)-1,2-propanediol;" );
standardThermochemistry
{
    dHf_298   -393760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260160.0
}
