/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-amino-5-chloro-2-methoxybenzoic acid  (C8H8ClNO3, CAS 7206-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Amino5Chloro2MethoxybenzoicAcid;
formula     C8H8ClNO3;
CAS         7206-70-4;
InChIKey    RVEATKYEARPWRE-UHFFFAOYSA-N;
MW          201.606;      // g/mol [origin=calculated method=formula-sum]
Tc          939.89;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       1.0407;      // -   [origin=predictive method=lee-kesler]
Tb          702.15;      // K   [origin=predictive method=joback]
HvapTb      72264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.09 0.56272 -0.00026688 2.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-5-chloranyl-2-methoxy-benzoic acid" "4-amino-5-chloro-o-anisic acid" "5-chloro-4-amino-2-methoxybenzoic acid" "4-amino-5-chloro-2-methoxyl-benzoic acid" "benzoic acid, 4-amino-5-chloro-2-methoxy-" "brd-k18838510-001-01-9" );
gibbsFormation
{
    dHf_298   -470770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-294390.0
    phase     gas;
}
