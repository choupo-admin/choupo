/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(1,1,3,3-tetramethylbutyl)phenyl salicylate  (C21H26O3, CAS 2553-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        41133TetramethylbutylPhenylSalicylate;
formula     C21H26O3;
CAS         2553-08-4;
InChIKey    IIHJDDQNGRKRIC-UHFFFAOYSA-N;
MW          326.436;      // g/mol [origin=calculated method=formula-sum]
Tc          1112.62;      // K   [origin=predictive method=joback]
Pc          17.434;      // bar [origin=predictive method=joback]
omega       0.9620;      // -   [origin=predictive method=lee-kesler]
Tb          870.80;      // K   [origin=predictive method=joback]
HvapTb      85383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.169 2.133 -0.00161932 4.846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2,4,4-trimethylpentan-2-yl)phenyl] 2-oxidanylbenzoate" "4-(2,4,4-trimethylpentan-2-yl)phenyl salicylate" "benzoic acid, 2-hydroxy-, 4-(1,1,3,3-tetramethylbutyl)phenyl ester" "4-(2,4,4-trimethylpentan-2-yl)phenyl 2-hydroxybenzoate" "[4-(2,4,4-trimethylpentan-2-yl)phenyl] 2-hydroxybenzoate" );
gibbsFormation
{
    dHf_298   -527270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-118180.0
    phase     gas;
}
