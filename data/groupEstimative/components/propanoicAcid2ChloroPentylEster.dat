/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 2-chloro-, pentyl ester  (C8H15ClO2, CAS 86711-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid2ChloroPentylEster;
formula     C8H15ClO2;
CAS         86711-71-9;
InChIKey    ASYLXRAVZWKEBQ-UHFFFAOYSA-N;
MW          178.656;      // g/mol [origin=calculated method=formula-sum]
Tc          659.49;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.5756;      // -   [origin=predictive method=lee-kesler]
Tb          477.85;      // K   [origin=predictive method=joback]
HvapTb      44806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.234 0.72174 -0.0003404 3.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentyl 2-chloranylpropanoate" "propionic acid, 2-chloro-, pentyl ester" "pentyl 2-chloropropanoate" );
standardThermochemistry
{
    dHf_298   -546750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-308260.0
}
