/*--------------------------------*- Choupo -*-----------------------*\
  Component: linoleic acid fumaric acid modified  (C22H36O6, CAS 68037-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        linoleicAcidFumaricAcidModified;
formula     C22H36O6;
CAS         68037-30-9;
InChIKey    HYZXPRRHBQXSCM-SUSXBYIYSA-N;
MW          396.524;      // g/mol [origin=calculated method=formula-sum]
Tc          1421.35;      // K   [origin=predictive method=joback]
Pc          11.148;      // bar [origin=predictive method=joback]
omega       0.9897;      // -   [origin=predictive method=lee-kesler]
Tb          1153.37;      // K   [origin=predictive method=joback]
HvapTb      116226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.038 2.10002 -0.0012274 2.596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH=CH; count 3; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group dCH; count 6; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;(9z,12z)-octadeca-9,12-dienoic acid" "2-butenedioic acid (2e)-, reaction products with linoleic acid" "(e)-but-2-enedioic acid; (9z,12z)-octadeca-9,12-dienoic acid" );
gibbsFormation
{
    dHf_298   -1308180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1260.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-761470.0
    phase     gas;
}
