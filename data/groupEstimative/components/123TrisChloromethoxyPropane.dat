/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-tris(chloromethoxy)propane  (C6H11Cl3O3, CAS 38571-73-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123TrisChloromethoxyPropane;
formula     C6H11Cl3O3;
CAS         38571-73-2;
InChIKey    SWXSJBPKOPJPJL-UHFFFAOYSA-N;
MW          237.501;      // g/mol [origin=calculated method=formula-sum]
Tc          704.06;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.6812;      // -   [origin=predictive method=lee-kesler]
Tb          515.99;      // K   [origin=predictive method=joback]
HvapTb      48947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (110.925 0.4105 -3.4e-05 -7.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2O; count 2; } { group CH-O; count 1; } { group CH2Cl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH; count 1; } { group Cl; count 3; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(chloromethyloxy)propane" "glycerol(tri(chloromethyl))ether" "tris-1,2,3-(chloromethoxy)propane" "1,2,3-tris[(chloromethyl)oxy]propane" "propane, 1,2,3-tris(chloromethoxy)-" "propane,1,2,3-tris(chloromethoxy)-" "1,2,3-tris(chloromethoxy)propane;glycerin tris(chloromethyl) ether; glycerol tri(chloromethyl) ether" );
gibbsFormation
{
    dHf_298   -616330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-353590.0
    phase     gas;
}
