/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichloropropane  (C3H6Cl2, CAS 594-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichloropropane;
formula     C3H6Cl2;
CAS         594-20-7;
InChIKey    ZEOVXNVKXIPWMS-UHFFFAOYSA-N;
MW          112.981;      // g/mol [origin=calculated method=formula-sum]
Tc          535.38;      // K   [origin=predictive method=joback]
Pc          41.039;      // bar [origin=predictive method=joback]
omega       0.1878;      // -   [origin=predictive method=lee-kesler]
Tb          339.87;      // K   [origin=predictive method=joback]
HvapTb      29746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.47 0.42824 -0.000352 1.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)propane" "propane, 2,2-dichloro-" "dimethyldichloromethane" "dichlorodimethylmethane" "isopropylidene dichloride" "acetone dichloride" "isopropylidene chloride" "2,2-dichloro-propane" );
gibbsFormation
{
    dHf_298   -145480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     300.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46640.0
    phase     gas;
}
