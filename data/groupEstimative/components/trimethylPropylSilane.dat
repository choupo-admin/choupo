/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl(propyl)silane  (C6H16Si, CAS 3510-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylPropylSilane;
formula     C6H16Si;
CAS         3510-70-1;
InChIKey    WNWMJFBAIXMNOF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          116.279;      // g/mol [origin=calculated method=formula-sum]
Tc          507.91;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.2172;      // -   [origin=predictive method=lee-kesler]
Tb          338.28;      // K   [origin=predictive method=joback]
HvapTb      29244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.252 0.36768 0.0001122 -1.57e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane, trimethylpropyl-" "silane, n-propyl-trimethyl-," "silane,trimethylpropyl-" "agn-pc-03vgcu" );
gibbsFormation
{
    dHf_298   -278790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105120.0
    phase     gas;
}
