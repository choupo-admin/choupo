/*--------------------------------*- Choupo -*-----------------------*\
  Component: tulipane  (C5H6O2, CAS 547-65-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tulipane;
formula     C5H6O2;
CAS         547-65-9;
InChIKey    GSLDEZOOOSBFGP-UHFFFAOYSA-N;
MW          98.101;      // g/mol [origin=calculated method=formula-sum]
Tc          575.07;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.3843;      // -   [origin=predictive method=lee-kesler]
Tb          382.79;      // K   [origin=predictive method=joback]
HvapTb      34512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.14 0.4839 -0.0003368 8.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 2; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylideneoxolan-2-one" "alpha-methylene-gamma-butyrolactone" "3-methylenedihydro-2(3h)-furanone" "tulipalin a" "2(3h)-furanone, dihydro-3-methylene-" "2-methylenebutyrolactone" "alpha-methylene butyrolactone" "dihydro-3-methylene-2(3h)-furanone" ".alpha.-methylene butyrolactone" "alpha-methylene gamma-butyrolactone" "3-methylenedihydrofuran-2(3h)-one" "a-methylen-r-butyrolactone" );
standardThermochemistry
{
    dHf_298   -286430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197610.0
}
