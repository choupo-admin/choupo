/*--------------------------------*- Choupo -*-----------------------*\
  Component: ddms  (C14H11Cl3, CAS 2642-80-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ddms;
formula     C14H11Cl3;
CAS         2642-80-0;
InChIKey    CHBOSHOWERDCMH-UHFFFAOYSA-N;
MW          285.592;      // g/mol [origin=calculated method=formula-sum]
Tc          950.85;      // K   [origin=predictive method=joback]
Pc          24.195;      // bar [origin=predictive method=joback]
omega       0.6196;      // -   [origin=predictive method=lee-kesler]
Tb          695.09;      // K   [origin=predictive method=joback]
HvapTb      65401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.059 1.0833 -0.00073052 1.831e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group CH2Cl; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-[2-chloranyl-1-(4-chlorophenyl)ethyl]benzene" "p,p'-ddms" "1-chloro-2,2-bis(p-chlorophenyl)ethane" "1,1-bis(p-chlorophenyl)-2-chloroethane" "1-chloro-4-[2-chloro-1-(4-chlorophenyl)ethyl]benzene" "1-chloro-2,2-bis(4'-chlorophenyl)ethane" "2,2-bis(p-chlorophenyl)-1-monochloroethane" "ethane, 2,2-bis(p-chlorophenyl)-1-chloro-" "ethane, 2-chloro-1,1-bis(p-chlorophenyl)-" "benzene, 1,1'-(2-chloroethylidene)bis(4-chloro-" "benzene, 1,1'-(2-chloroethylidene)bis-4-chloro-" "benzene, 1,1'-(2-chloroethylidene)bis(4-chloro)-" );
gibbsFormation
{
    dHf_298   65330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=234330.0
    phase     gas;
}
