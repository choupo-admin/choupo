/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethyloctane  (C10H22, CAS 15869-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethyloctane;
formula     C10H22;
CAS         15869-89-3;
InChIKey    HOAAQUNESXYFDT-UHFFFAOYSA-N;
MW          142.286;      // g/mol [origin=calculated method=formula-sum]
Tc          597.20;      // K   [origin=predictive method=joback]
Pc          21.394;      // bar [origin=predictive method=joback]
omega       0.4354;      // -   [origin=predictive method=lee-kesler]
Tb          427.52;      // K   [origin=predictive method=joback]
HvapTb      37078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.566 0.96568 -0.0005266 1.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane, 2,5-dimethyl-" "1,3-dioxolo[4,5-g]isoquinolinium,6-(7,8-dihydro-5-hydroxy-4-methoxy-1,3-dioxolo[4,5-g]isoquinolin-6(5h)-yl)-7,8-dihydro-4-methoxy-,chloride (8ci,9ci)" "6-(7,8-dihydro-5-hydroxy-4-methoxy-1,3-dioxolo[4,5-g]isoquinolin-6(5h)yl)-7,8-dihydro-4-methoxy-1,3-dioxolo[4,5-g]isoquinoliniumchloride (7ci);" );
gibbsFormation
{
    dHf_298   -260290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28440.0
    phase     gas;
}
