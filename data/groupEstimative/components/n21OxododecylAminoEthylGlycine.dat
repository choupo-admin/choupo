/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-((1-oxododecyl)amino)ethyl)glycine  (C16H32N2O3, CAS 73772-42-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n21OxododecylAminoEthylGlycine;
formula     C16H32N2O3;
CAS         73772-42-6;
InChIKey    VOSXYJCXYDUALE-UHFFFAOYSA-N;
MW          300.443;      // g/mol [origin=calculated method=formula-sum]
Tc          1062.32;      // K   [origin=predictive method=joback]
Pc          15.070;      // bar [origin=predictive method=joback]
omega       1.3053;      // -   [origin=predictive method=lee-kesler]
Tb          865.40;      // K   [origin=predictive method=joback]
HvapTb      87992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.117 1.69902 -0.0009977 2.1916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2NH; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(dodecanoylamino)ethylamino]ethanoic acid" "n-[2-[(1-oxododecyl)amino]ethyl]glycine" "glycine, n-(2-((1-oxododecyl)amino)ethyl)-" "glycine, n-[2-[(1-oxododecyl)amino]ethyl]-" "glycine,n-[2-[(1-oxododecyl)amino]ethyl]-" "2-[2-(dodecanoylamino)ethylamino]acetic acid" );
gibbsFormation
{
    dHf_298   -729480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     940.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210210.0
    phase     gas;
}
