/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenylacetaldehyde  (C14H12O, CAS 947-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenylacetaldehyde;
formula     C14H12O;
CAS         947-91-1;
InChIKey    HLLGFGBLKOIZOM-UHFFFAOYSA-N;
MW          196.249;      // g/mol [origin=calculated method=formula-sum]
Tc          868.09;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.6010;      // -   [origin=predictive method=lee-kesler]
Tb          621.50;      // K   [origin=predictive method=joback]
HvapTb      57642.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.93 1.1564 -0.0007964 2.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diphenylethanal" "diphenylketen" "acetaldehyde, diphenyl-" "2,2-diphenylacetaldehyde" "benzeneacetaldehyde, .alpha.-phenyl-" "alpha-phenylbenzeneacetaldehyde" "diphenyl-acetaldehyd" "2,2-diphenyl-acetaldehyde" "diphenyl acetaldehyde" "diphenyl-acetaldehyde" "2,2-di(phenyl)acetaldehyde" "benzeneacetaldehyde, " "a-phenyl-" );
standardThermochemistry
{
    dHf_298   49910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189860.0
}
