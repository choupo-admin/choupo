/*--------------------------------*- Choupo -*-----------------------*\
  Component: carcinolipin  (C44H78O2, CAS 19477-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carcinolipin;
formula     C44H78O2;
CAS         19477-24-8;
InChIKey    ILZPADCYIWUDSX-UHFFFAOYSA-N;
MW          639.106;      // g/mol [origin=calculated method=formula-sum]
Tc          1666.13;      // K   [origin=predictive method=joback]
Pc          4.421;      // bar [origin=predictive method=joback]
omega       -0.0315;      // -   [origin=predictive method=lee-kesler]
Tb          1302.14;      // K   [origin=predictive method=joback]
HvapTb      118018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-303.404 5.09124 -0.00375284 1.1922e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 23; } { group CH; count 8; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 16; } { group CH; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] 14-methylhexadecanoate" "cholest-5-en-3-yl 14-methylhexadecanoate" "cholesteryl 14-methylpalmitate" "cholesteryl-14-methylhexadecanoate" "cholesterol, 14-methylhexadecanoate" "cholest-5-en-3beta-ol-14-methylhexadecanoate" "cholest-5-en-3-beta-ol, 14-methylhexadecanoate" "3-beta-14-methylhexadecanoate-cholest-5-en-3-ol" "cholest-5-en-3-ol(3-beta), 14-methylhexadecanoate" "cholest-5-en-3-ol(3-beta), 14-methylhexadecanoate (9ci)" "[(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] 14-methylhexadecanoate" );
standardThermochemistry
{
    dHf_298   -1008440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1599.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170630.0
}
