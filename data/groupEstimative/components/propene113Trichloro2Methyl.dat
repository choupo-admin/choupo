/*--------------------------------*- Choupo -*-----------------------*\
  Component: propene, 1,1,3-trichloro-2-methyl-  (C4H5Cl3, CAS 31702-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propene113Trichloro2Methyl;
formula     C4H5Cl3;
CAS         31702-33-7;
InChIKey    GVFGURPOQVIHNM-UHFFFAOYSA-N;
MW          159.434;      // g/mol [origin=calculated method=formula-sum]
Tc          616.14;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.2938;      // -   [origin=predictive method=lee-kesler]
Tb          407.33;      // K   [origin=predictive method=joback]
HvapTb      37771.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.361 0.42402 -0.0003434 1.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2Cl; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dC; count 2; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3-tris(chloranyl)-2-methyl-prop-1-ene" "1-propene, 1,1,3-trichloro-2-methyl-" "1,1,3-trichloro-2-methylprop-1-ene" "1,1,3-trichloro-2-methyl-1-propene" );
gibbsFormation
{
    dHf_298   -75470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10130.0
    phase     gas;
}
