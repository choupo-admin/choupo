/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4-chlorophenol  (C6H4BrClO, CAS 695-96-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo4Chlorophenol;
formula     C6H4BrClO;
CAS         695-96-5;
InChIKey    ZIYRDJLAJYTELF-UHFFFAOYSA-N;
MW          207.451;      // g/mol [origin=calculated method=formula-sum]
Tc          810.52;      // K   [origin=predictive method=joback]
Pc          59.446;      // bar [origin=predictive method=joback]
omega       0.6154;      // -   [origin=predictive method=lee-kesler]
Tb          552.75;      // K   [origin=predictive method=joback]
HvapTb      55722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.01 0.635 -0.00061492 2.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group Br; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4-chloranyl-phenol" "phenol, 2-bromo-4-chloro-" "4-chloro-2-bromophenol" "k163" "phenol, 2-bromo-4-chloro- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -108830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49810.0
    phase     gas;
}
