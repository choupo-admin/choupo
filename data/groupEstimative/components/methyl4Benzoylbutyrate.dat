/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-benzoylbutyrate  (C12H14O3, CAS 1501-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Benzoylbutyrate;
formula     C12H14O3;
CAS         1501-04-8;
InChIKey    GRIWFUFDJOESIC-UHFFFAOYSA-N;
MW          206.241;      // g/mol [origin=calculated method=formula-sum]
Tc          824.11;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.7732;      // -   [origin=predictive method=lee-kesler]
Tb          612.93;      // K   [origin=predictive method=joback]
HvapTb      58735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.157 0.98212 -0.0005469 9.096e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 5-oxidanylidene-5-phenyl-pentanoate" "methyl 5-oxo-5-phenylpentanoate" "benzenepentanoic acid, .delta.-oxo-, methyl ester" "5-oxo-5-phenylpentanoic acid methyl ester" "5-oxo-5-phenyl-pentanoic acid methyl ester" "benzenepentanoic acid, d-oxo-, methyl ester" "butyricacid, 4-benzoyl-, methyl ester (6ci,7ci,8ci); 4-carbomethoxybutyrophenone;methyl 4-benzoylbutyrate; methyl 5-oxo-5-phenylpentanoate; g-carbomethoxybutyrophenone; d-oxobenzenepentanoic acid methylester" );
standardThermochemistry
{
    dHf_298   -484340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276720.0
}
