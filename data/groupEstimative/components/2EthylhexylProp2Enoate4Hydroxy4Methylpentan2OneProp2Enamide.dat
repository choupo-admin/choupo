/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl prop-2-enoate; 4-hydroxy-4-methylpentan-2-one; prop-2-enamide  (C20H37NO5, CAS 63450-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylProp2Enoate4Hydroxy4Methylpentan2OneProp2Enamide;
formula     C20H37NO5;
CAS         63450-23-7;
InChIKey    UIVRGNOOAMIHJD-UHFFFAOYSA-N;
MW          371.518;      // g/mol [origin=calculated method=formula-sum]
Tc          1200.27;      // K   [origin=predictive method=joback]
Pc          11.704;      // bar [origin=predictive method=joback]
omega       1.1113;      // -   [origin=predictive method=lee-kesler]
Tb          980.36;      // K   [origin=predictive method=joback]
HvapTb      105897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (86.116 1.5683 -0.0003972 -1.5578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 2; } { group OH; count 1; } { group CH3CO; count 1; } { group COO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 1; } { group CdO; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl prop-2-enoate;4-methyl-4-oxidanyl-pentan-2-one;prop-2-enamide" );
gibbsFormation
{
    dHf_298   -1103420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1299.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-554500.0
    phase     gas;
}
