/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5-trimethylheptane  (C10H22, CAS 20278-85-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        235Trimethylheptane;
formula     C10H22;
CAS         20278-85-7;
InChIKey    YKPNYFKOKKKGNM-UHFFFAOYSA-N;
MW          142.286;      // g/mol [origin=calculated method=formula-sum]
Tc          600.52;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       0.4046;      // -   [origin=predictive method=lee-kesler]
Tb          427.08;      // K   [origin=predictive method=joback]
HvapTb      36690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.248 0.9716 -0.0005298 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptane, 2,3,5-trimethyl-" "agn-pc-0d624s" );
gibbsFormation
{
    dHf_298   -265570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26000.0
    phase     gas;
}
