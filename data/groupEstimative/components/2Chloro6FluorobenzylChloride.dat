/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-6-fluorobenzyl chloride  (C7H5Cl2F, CAS 55117-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro6FluorobenzylChloride;
formula     C7H5Cl2F;
CAS         55117-15-2;
InChIKey    MJGOLNNLNQQIHR-UHFFFAOYSA-N;
MW          179.015;      // g/mol [origin=calculated method=formula-sum]
Tc          687.60;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.4154;      // -   [origin=predictive method=lee-kesler]
Tb          470.53;      // K   [origin=predictive method=joback]
HvapTb      42729.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.091 0.4963 -0.00031132 7.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH2Cl; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-(chloromethyl)-3-fluoranyl-benzene" "1-chloro-2-(chloromethyl)-3-fluorobenzene" "benzene, 1-chloro-2-(chloromethyl)-3-fluoro-" "1-chloro-2-chloromethyl-3-fluoro-benzene" "2,alpha-dichloro-6-fluorotoluene" "alpha,2-dichloro-6-fluorotoluene" "3-chloro-2-(chloromethyl)-1-fluorobenzene" "oxcl1" "a-chloro-o-xylene" "2-chloro-6-fluorobenzylchloride" "mjgolnnlnqqihr-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -201810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117460.0
    phase     gas;
}
