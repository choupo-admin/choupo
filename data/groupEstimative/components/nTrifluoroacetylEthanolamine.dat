/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-trifluoroacetyl-ethanolamine  (C4H6F3NO2, CAS 6974-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nTrifluoroacetylEthanolamine;
formula     C4H6F3NO2;
CAS         6974-29-4;
InChIKey    NPSVCXHBJVBBAD-UHFFFAOYSA-N;
MW          157.091;      // g/mol [origin=calculated method=formula-sum]
Tc          644.64;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       1.0892;      // -   [origin=predictive method=lee-kesler]
Tb          481.92;      // K   [origin=predictive method=joback]
HvapTb      50612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.492 0.6272 -0.0004751 1.3636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CF3; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group F; count 3; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)-n-(2-hydroxyethyl)ethanamide" "n-(2-hydroxyethyl)trifluoroacetamide" "2,2,2-trifluoro-n-(2-hydroxyethyl)acetamide" "n-(trifluoroacetyl)ethanolamine" "n-(2-hydroxyethyl)-2,2,2-trifluoroacetamide" "n-trifluoroacetyl-2-aminoethanol" "npsvcxhbjvbbad-uhfffaoysa-" "acetamide,2,2,2-trifluoro-n-(2-hydroxyethyl)-" );
gibbsFormation
{
    dHf_298   -934310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-775140.0
    phase     gas;
}
