/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibenzoylbutane  (C18H18O2, CAS 3375-38-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibenzoylbutane;
formula     C18H18O2;
CAS         3375-38-0;
InChIKey    VRBLNWVVFVBNRK-UHFFFAOYSA-N;
MW          266.34;      // g/mol [origin=calculated method=formula-sum]
Tc          1005.55;      // K   [origin=predictive method=joback]
Pc          21.473;      // bar [origin=predictive method=joback]
omega       0.9303;      // -   [origin=predictive method=lee-kesler]
Tb          772.54;      // K   [origin=predictive method=joback]
HvapTb      73706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.566 1.5 -0.0009804 2.3592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-diphenylhexane-1,6-dione" "butane, 1,4-dibenzoyl-" "1,6-diphenyl-1,6-hexanedione" "1,6-hexanedione, 1,6-diphenyl-" "1,6-hexanedione" "butane,4-dibenzoyl-" "1, 1,6-diphenyl-" "1,6-diphenyl-hexane-1,6-dione" "1,6-hexanedione,1,6-diphenyl-" "1,6-hexanedione,1,6-diphenyl   1,4-dibenzoxylbutane" );
standardThermochemistry
{
    dHf_298   -166950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67660.0
}
