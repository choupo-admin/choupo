/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisotridecyl adipate  (C32H62O4, CAS 26401-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisotridecylAdipate;
formula     C32H62O4;
CAS         26401-35-4;
InChIKey    WPUKZOKYKHYASK-UHFFFAOYSA-N;
MW          510.844;      // g/mol [origin=calculated method=formula-sum]
Tc          1321.85;      // K   [origin=predictive method=joback]
Pc          5.500;      // bar [origin=predictive method=joback]
omega       0.2041;      // -   [origin=predictive method=lee-kesler]
Tb          1047.32;      // K   [origin=predictive method=joback]
HvapTb      100864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.254 2.94608 -0.0015342 2.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 22; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 24; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(11-methyldodecyl) hexanedioate" "bis(11-methyldodecyl) adipate" "hexanedioic acid, 1,6-diisotridecyl ester" "hexanedioic acid, diisotridecyl ester" "hexanedioic acid,1,6-diisotridecyl ester" "adipicacid, diisotridecyl ester (8ci);hexanedioic acid, diisotridecyl ester (9ci);isotridecyl alcohol, adipate (2:1) (8ci);diisotridecyl adipate;" );
standardThermochemistry
{
    dHf_298   -1348930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1485.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407060.0
}
