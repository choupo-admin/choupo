/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-tridecyne  (C13H24, CAS 42371-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Tridecyne;
formula     C13H24;
CAS         42371-66-4;
InChIKey    DFZSEVCTTZHGAS-UHFFFAOYSA-N;
MW          180.335;      // g/mol [origin=calculated method=formula-sum]
Tc          685.42;      // K   [origin=predictive method=joback]
Pc          18.805;      // bar [origin=predictive method=joback]
omega       0.5489;      // -   [origin=predictive method=lee-kesler]
Tb          506.04;      // K   [origin=predictive method=joback]
HvapTb      46684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.629 1.08904 -0.00059126 1.2248e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridec-6-yne" "6-c13h24" "6-tridecane" );
gibbsFormation
{
    dHf_298   -39350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=261380.0
    phase     gas;
}
