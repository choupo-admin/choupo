/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-benzyl-4-piperidone  (C12H15NO, CAS 3612-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Benzyl4Piperidone;
formula     C12H15NO;
CAS         3612-20-2;
InChIKey    SJZKULRDWHPHGG-UHFFFAOYSA-N;
MW          189.258;      // g/mol [origin=calculated method=formula-sum]
Tc          843.61;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.5852;      // -   [origin=predictive method=lee-kesler]
Tb          601.05;      // K   [origin=predictive method=joback]
HvapTb      51438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.609 1.1787 -0.0007116 1.492e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(phenylmethyl)piperidin-4-one" "1-benzylpiperidin-4-one" "n-benzyl-4-piperidone" "1-benzyl-4-oxopiperidine" "4-piperidinone, 1-(phenylmethyl)-" "1-benzylpiperidone" "n-benzyl-4-piperidine" "1-benzyl-4-piperidinone" "1-benzyl-piperidin-4-one" "n-benzylpiperidone" "benzylpiperidone-4" "benzyl-4-piperidone" );
standardThermochemistry
{
    dHf_298   -43830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195020.0
}
