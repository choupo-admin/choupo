/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2',5,5'-tetrachlorobenzidine  (C12H8Cl4N2, CAS 15721-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2255Tetrachlorobenzidine;
formula     C12H8Cl4N2;
CAS         15721-02-5;
InChIKey    UXOXUHMFQZEAFR-UHFFFAOYSA-N;
MW          322.01;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.84;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       1.0031;      // -   [origin=predictive method=lee-kesler]
Tb          852.18;      // K   [origin=predictive method=joback]
HvapTb      89652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.51 0.78 -0.00045756 9.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group ACNH2; count 2; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Cl; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4-azanyl-2,5-bis(chloranyl)phenyl]-2,5-bis(chloranyl)aniline" "3,3',6,6'-tetrachlorobenzidine" "benzidine, 2,2',5,5'-tetrachloro-" "2,2',5,5'-tetrachloro-4,4'-diaminodiphenyl" "2,2',5,5'-tetrachlorobiphenyl-4,4'-diamine" "2,2',5,5'-tetrachloro(1,1'-biphenyl)-4,4'-diamine" "2,2',5,5'-tetrachloro-(1,1'-biphenyl)-4,4'-diamine" "(1,1'-biphenyl)-4,4'-diamine, 2,2',5,5'-tetrachloro-" "[1,1'-biphenyl]-4,4'-diamine, 2,2',5,5'-tetrachloro-" "4-(4-amino-2,5-dichlorophenyl)-2,5-dichlorophenylamine" "uxoxuhmfqzeafr-uhfffaoysa-" "p290" );
standardThermochemistry
{
    dHf_298   117850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=302380.0
}
