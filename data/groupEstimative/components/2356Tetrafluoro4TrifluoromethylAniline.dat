/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetrafluoro-4-(trifluoromethyl)aniline  (C7H2F7N, CAS 651-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356Tetrafluoro4TrifluoromethylAniline;
formula     C7H2F7N;
CAS         651-83-2;
InChIKey    FJOACTZFMHZHSC-UHFFFAOYSA-N;
MW          233.086;      // g/mol [origin=calculated method=formula-sum]
Tc          647.98;      // K   [origin=predictive method=joback]
Pc          28.505;      // bar [origin=predictive method=joback]
omega       0.7319;      // -   [origin=predictive method=lee-kesler]
Tb          475.53;      // K   [origin=predictive method=joback]
HvapTb      40388.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.77 0.5627 -0.000383 9.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group ACNH2; count 1; } { group ACF; count 4; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dC_ring; count 6; } { group F; count 7; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5,6-tetrakis(fluoranyl)-4-(trifluoromethyl)aniline" "4-aminotetrafluorobenzotrifluoride" "4-amino-heptafluorotoluene" "4-aminoheptafluorotoluene" "2,3,5,6-tetrafluoro-4-aminobenzotrifluoride" "4-amino-2,3,5,6-tetrafluorobenzotrifluoride" "2,3,5,6,alpha,alpha,alpha-heptafluoro-p-toluidine" "2,3,5,6-tetrafluoro-4-(trifluoromethyl)phenylamine" "4-aminotetrafluorobenzotrifluoride;2,3,5,6-tetrafluoro-4-aminobenzotrifluoride;4-amino-2,3,5,6-tetrafluorobenzotrifluoride;" );
standardThermochemistry
{
    dHf_298   -1356360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1222060.0
}
