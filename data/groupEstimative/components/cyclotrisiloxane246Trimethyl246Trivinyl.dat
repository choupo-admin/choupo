  Component: cyclotrisiloxane, 2,4,6-trimethyl-2,4,6-trivinyl-  (C9H18O3Si3, CAS 3901-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H18O3Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        cyclotrisiloxane246Trimethyl246Trivinyl;
formula     C9H18O3Si3;
CAS         3901-77-7;
InChIKey    BVTLTBONLZSBJC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          258.495;      // g/mol [origin=calculated method=formula-sum]
Tc          700.46;      // K   [origin=predictive method=joback]
Pc          21.042;      // bar [origin=predictive method=joback]
omega       0.3333;      // -   [origin=predictive method=lee-kesler]
Tb          492.02;      // K   [origin=predictive method=joback]
HvapTb      48252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (103.97 0.34866 0.000476 -4.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=CH; count 3; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 3; } { group dCH; count 3; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(ethenyl)-2,4,6-trimethyl-1,3,5,2,4,6-trioxatrisilinane" "cyclotrisiloxane, 2,4,6-triethenyl-2,4,6-trimethyl-" "methylvinylsiloxane cyclic trimer" "2,4,6-trimethyl-2,4,6-trivinylcyclotrisiloxane" "cyclosiloxanes, me vinyl" "1,5-trimethyl-1,3,5-trivinylcyclotrisiloxane" "1,5-trivinyl-1,3,5-trimethylcyclotrisiloxane" "2,6-trimethyl-2,4,6-trivinylcyclotrisiloxane" "1,3,5-trimethyl-1,3,5-trivinylcyclotrisiloxane" "1,3,5-trivinyl-1,3,5-trimethylcyclotrisiloxane" "cyclotrisiloxane,4,6-trimethyl-2,4,6-trivinyl-" "cyclotrisiloxane,4,6-triethenyl-2,4,6-trimethyl-" );
gibbsFormation
{
    dHf_298   -490520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215760.0
    phase     gas;
}
