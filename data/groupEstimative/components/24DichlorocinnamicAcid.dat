/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichlorocinnamic acid  (C9H6Cl2O2, CAS 20595-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DichlorocinnamicAcid;
formula     C9H6Cl2O2;
CAS         20595-45-3;
InChIKey    MEBWABJHRAYGFW-DUXPYHPUSA-N;
MW          217.045;      // g/mol [origin=calculated method=formula-sum]
Tc          909.25;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.8195;      // -   [origin=predictive method=lee-kesler]
Tb          666.69;      // K   [origin=predictive method=joback]
HvapTb      65120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.6 0.7453 -0.00056012 1.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-(2,4-dichlorophenyl)prop-2-enoic acid" "trans-2,4-dichlorocinnamic acid" "(e)-3-(2,4-dichlorophenyl)acrylic acid" "2-propenoic acid, 3-(2,4-dichlorophenyl)-" "3-(2,4-dichlorophenyl)-2-propenoic acid" "3-(2,4-dichlorophenyl)prop-2-enoic acid" "cinnamic acid, 2,4-dichloro-" "(2e)-3-(2,4-dichlorophenyl)prop-2-enoic acid" "cinnamic acid, 2,4-dichloro-, (e)-" "(2e)-3-(2,4-dichlorophenyl)acrylic acid" "2-propenoic acid, 3-(2,4-dichlorophenyl)-, (e)-" "2-propenoic acid, 3-(2,4-dichlorophenyl)-, (2e)-" );
gibbsFormation
{
    dHf_298   -280030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169500.0
    phase     gas;
}
