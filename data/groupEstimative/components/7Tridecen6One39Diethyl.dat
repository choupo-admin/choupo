/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-tridecen-6-one, 3,9-diethyl-  (C17H32O, CAS 99148-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Tridecen6One39Diethyl;
formula     C17H32O;
CAS         99148-56-8;
InChIKey    JGDGJCODFVJCLV-UHFFFAOYSA-N;
MW          252.442;      // g/mol [origin=calculated method=formula-sum]
Tc          822.54;      // K   [origin=predictive method=joback]
Pc          13.526;      // bar [origin=predictive method=joback]
omega       0.8065;      // -   [origin=predictive method=lee-kesler]
Tb          645.71;      // K   [origin=predictive method=joback]
HvapTb      59364.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.752 1.62268 -0.0009725 2.2846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 2; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,9-diethyltridec-7-en-6-one" "(e)-3,9-diethyltridec-7-en-6-one" );
gibbsFormation
{
    dHf_298   -400130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     819.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38680.0
    phase     gas;
}
