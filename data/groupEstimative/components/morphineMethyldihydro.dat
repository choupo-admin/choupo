/*--------------------------------*- Choupo -*-----------------------*\
  Component: morphine, methyldihydro-  (C18H23NO3, CAS 509-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morphineMethyldihydro;
formula     C18H23NO3;
CAS         509-56-8;
InChIKey    NBKVWIJQJMEQLE-NGTWOADLSA-N;
MW          301.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.08;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       1.4516;      // -   [origin=predictive method=lee-kesler]
Tb          878.77;      // K   [origin=predictive method=joback]
HvapTb      92377.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-305.67 2.99594 -0.00317498 1.3452e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4ar,7s,7ar,12bs)-3,7-dimethyl-1,2,4,4a,5,6,7a,13-octahydro-4,12-methanobenzofuro[3,2-e]isoquinoline-7,9-diol" "metildiidromorfina [dcit]" "morphine, dihydro-6-methyl-" "methyldihydromorphine [inn:dcf]" "methyldihydromorphinum [inn-latin]" "3,6-dihydroxy-6,n-dimethyl-4,5-epoxymorphinan" "4,5alpha-epoxy-6,n-dimethyl-3,6-morphinandiol" "morphinan-3,6-alpha-diol, 6-beta,17-dimethyl-4,5-alpha-epoxy-" "morphinan-3,6-diol, 4,5-epoxy-6,17-dimethyl-, (5alpha,6alpha)-" "metildiidromorfina" "metildihidromorfina" "methyldihydromorphinum" );
standardThermochemistry
{
    dHf_298   -287770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163460.0
}
