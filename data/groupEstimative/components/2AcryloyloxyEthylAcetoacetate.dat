/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(acryloyloxy)ethyl acetoacetate  (C9H12O5, CAS 21282-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AcryloyloxyEthylAcetoacetate;
formula     C9H12O5;
CAS         21282-96-2;
InChIKey    YHSYGCXKWUUKIK-UHFFFAOYSA-N;
MW          200.19;      // g/mol [origin=calculated method=formula-sum]
Tc          760.66;      // K   [origin=predictive method=joback]
Pc          25.846;      // bar [origin=predictive method=joback]
omega       0.8688;      // -   [origin=predictive method=lee-kesler]
Tb          572.51;      // K   [origin=predictive method=joback]
HvapTb      56518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.893 0.70122 -0.0002808 -9.94e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enoyloxyethyl 3-oxidanylidenebutanoate" "2-prop-2-enoyloxyethyl 3-oxobutanoate" "butanoic acid, 3-oxo-,2-[(1-oxo-2-propen-1-yl)oxy]ethyl ester" "acetoaceticacid, 2-hydroxyethyl ester acrylate (8ci); butanoic acid, 3-oxo-,2-[(1-oxo-2-propenyl)oxy]ethyl ester (9ci); 2-(acryloyloxy)ethyl acetoacetate;2-acetoacetoxyethyl acrylate; ethylene glycol acetoacetate acrylate" );
gibbsFormation
{
    dHf_298   -850800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-636920.0
    phase     gas;
}
