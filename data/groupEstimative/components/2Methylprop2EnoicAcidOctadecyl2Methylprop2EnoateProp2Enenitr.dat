/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylprop-2-enoic acid;octadecyl 2-methylprop-2-enoate;prop-2-enenitrile  (C29H51NO4, CAS 67953-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylprop2EnoicAcidOctadecyl2Methylprop2EnoateProp2Enenitr;
formula     C29H51NO4;
CAS         67953-86-0;
InChIKey    LGBRZMATMMXBOT-UHFFFAOYSA-N;
MW          477.73;      // g/mol [origin=calculated method=formula-sum]
Tc          1451.19;      // K   [origin=predictive method=joback]
Pc          6.335;      // bar [origin=predictive method=joback]
omega       0.3848;      // -   [origin=predictive method=lee-kesler]
Tb          1161.53;      // K   [origin=predictive method=joback]
HvapTb      113935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (96.817 2.21706 -0.0007445 -8.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 17; } { group CH2=C; count 2; } { group COOH; count 1; } { group ACRY; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group COOH; count 1; } { group COO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, polymer with octadecyl 2-methyl-2-propenoate and 2-propenenitrile" "2-methylprop-2-enoic acid; octadecyl 2-methylprop-2-enoate; prop-2-enenitrile" );
gibbsFormation
{
    dHf_298   -1011090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1589.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-290900.0
    phase     gas;
}
