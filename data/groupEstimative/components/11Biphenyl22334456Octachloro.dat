/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-biphenyl, 2,2',3,3',4,4',5,6-octachloro-  (C12H2Cl8, CAS 52663-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Biphenyl22334456Octachloro;
formula     C12H2Cl8;
CAS         52663-78-2;
InChIKey    JAHJITLFJSDRCG-UHFFFAOYSA-N;
MW          429.748;      // g/mol [origin=calculated method=formula-sum]
Tc          1141.07;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.8522;      // -   [origin=predictive method=lee-kesler]
Tb          866.80;      // K   [origin=predictive method=joback]
HvapTb      87234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (141.69 0.5644 -0.00031828 5.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCl; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 10; } { group Cl; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(chloranyl)-6-[2,3,4-tris(chloranyl)phenyl]benzene" "2,2',3,3',4,4',5,6-octachlorobiphenyl" "2,2',3,3',4,4',5,6-octachloro-1,1'-biphenyl" "tetrachloro(tetrachlorophenyl)benzene" "1,1'-biphenyl,2,2',3,3',4,4',5,6-octachloro-" "1,2,3,4,5-pentachloro-6-(2,3,4-trichlorophenyl)benzene" "2,2',3,3',4,4',5,6-octachlorobiphenyl;2,3,4,2',3',4',5',6'-octachlorobiphenyl;2,3,4,5,6,2',3',4'-octachlorobiphenyl;pcb 195;" );
gibbsFormation
{
    dHf_298   -35630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102500.0
    phase     gas;
}
