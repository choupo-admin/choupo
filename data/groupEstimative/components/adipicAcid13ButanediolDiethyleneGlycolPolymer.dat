/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipic acid, 1,3-butanediol, diethylene glycol polymer  (C14H30O9, CAS 72162-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipicAcid13ButanediolDiethyleneGlycolPolymer;
formula     C14H30O9;
CAS         72162-43-7;
InChIKey    BPBKJAJEPPBWJX-UHFFFAOYSA-N;
MW          342.385;      // g/mol [origin=calculated method=formula-sum]
Tc          1557.38;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       0.9652;      // -   [origin=predictive method=lee-kesler]
Tb          1204.44;      // K   [origin=predictive method=joback]
HvapTb      150412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (125.98 1.10172 -6.72e-05 -2.391e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group OH; count 3; } { group COOH; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group OH; count 4; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,3-diol;hexanedioic acid;2-(2-hydroxyethyloxy)ethanol" "hexanedioic acid, polymer with 1,3-butanediol and 2,2'-oxybis(ethanol)" );
standardThermochemistry
{
    dHf_298   -2002490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1228.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1485060.0
}
