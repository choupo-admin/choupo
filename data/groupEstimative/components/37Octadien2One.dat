/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-octadien-2-one  (C8H12O, CAS 25172-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Octadien2One;
formula     C8H12O;
CAS         25172-06-9;
InChIKey    WDIFTBWPYIVZNY-SREVYHEPSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          625.29;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       0.4657;      // -   [origin=predictive method=lee-kesler]
Tb          437.35;      // K   [origin=predictive method=joback]
HvapTb      39436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.198 0.73582 -0.0004994 1.3976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3z)-octa-3,7-dien-2-one" );
standardThermochemistry
{
    dHf_298   -78380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55620.0
}
