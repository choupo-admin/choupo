/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethoxylated tetrabromobisphenol a  (C19H20Br4O4, CAS 4162-45-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethoxylatedTetrabromobisphenolA;
formula     C19H20Br4O4;
CAS         4162-45-2;
InChIKey    RVHUMFJSCJBNGS-UHFFFAOYSA-N;
MW          631.981;      // g/mol [origin=calculated method=formula-sum]
Tc          1479.33;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       1.7777;      // -   [origin=predictive method=lee-kesler]
Tb          1208.17;      // K   [origin=predictive method=joback]
HvapTb      129034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.474 1.51424 -0.00096616 2.348e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 8; } { group Br; count 4; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Br; count 4; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[2-[3,5-bis(bromanyl)-4-(2-hydroxyethyloxy)phenyl]propan-2-yl]-2,6-bis(bromanyl)phenoxy]ethanol" "4,4'-isopropylidenebis[2-(2,6-dibromophenoxy)ethanol]" "tetrabromobisphenol a bis(2-hydroxyethyl) ether" "ethanol, 2,2'-((1-methylethylidene)bis((2,6-dibromo-4,1-phenylene)oxy))bis-" "2,2'-{propane-2,2-diylbis[(2,6-dibromobenzene-4,1-diyl)oxy]}diethanol" "ethanol, 2,2'-[(1-methylethylidene)bis[(2,6-dibromo-4,1-phenylene)oxy]]bis-" "2,2-bis(3,5-dibromo-4-(2-hydroxyethoxy)phenyl)propane" "2,2-bis[3,5-dibromo-4-(2-hydroxyethoxy)phenyl]propane" "4,4'-isopropylidenebis(2-(2,6-dibromophenoxy)ethanol)" "4,4'-isopropylidenebis(2-[2,6-dibromophenoxy]ethanol)" "2-(4-{1-[3,5-dibromo-4-(2-hydroxyethoxy)phenyl]-isopropyl}-2,6-dibromophenoxy) ethan-1-ol" "tetrabromobisphenol a bis(ethoxylate)" );
gibbsFormation
{
    dHf_298   -503580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     935.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147380.0
    phase     gas;
}
