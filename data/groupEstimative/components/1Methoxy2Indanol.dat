/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-2-indanol  (C10H12O2, CAS 56175-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy2Indanol;
formula     C10H12O2;
CAS         56175-44-1;
InChIKey    ZHWPZRVYPHGXSF-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          782.06;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.8781;      // -   [origin=predictive method=lee-kesler]
Tb          576.73;      // K   [origin=predictive method=joback]
HvapTb      59485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.32 0.91062 -0.00056856 1.345e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2,3-dihydro-1h-inden-2-ol" "1-methoxyindan-2-ol" "1h-inden-2-ol, 2,3-dihydro-1-methoxy-, cis-" "zhwpzrvyphgxsf-uhfffaoysa-" "1h-inden-2-ol, 2,3-dihydro-1-methoxy-" "1h-inden-2-ol,2,3-dihydro-1-methoxy-, (1r,2s)-rel-" "1h-inden-2-ol,2,3-dihydro-1-methoxy-, cis- (9ci); cis-1-methoxyindan-2-ol" );
gibbsFormation
{
    dHf_298   -256660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52680.0
    phase     gas;
}
