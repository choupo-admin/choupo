/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-coumaranone  (C8H6O2, CAS 553-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Coumaranone;
formula     C8H6O2;
CAS         553-86-6;
InChIKey    ACZGCWSMSTYWDQ-UHFFFAOYSA-N;
MW          134.134;      // g/mol [origin=calculated method=formula-sum]
Tc          693.96;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       0.4968;      // -   [origin=predictive method=lee-kesler]
Tb          475.39;      // K   [origin=predictive method=joback]
HvapTb      43625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.52 0.7672 -0.00064936 2.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3h-1-benzofuran-2-one" "2(3h)-benzofuranone" "benzofuran-2(3h)-one" "benzofuranone" "1-benzofuran-2(3h)-one" "isocoumaranone" "2-coumarotioiie" "2-coumaronone" "3h-benzofuran-2-one" "(3h)-benzofuran-2-one" "3-hydrobenzo[b]furan-2-one" "2,3-dihydrobenzo[b]furan-2-one" );
standardThermochemistry
{
    dHf_298   -195210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98450.0
}
