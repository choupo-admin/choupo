/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1-hydroxy-4-(1-hydroxy-3-oxo-1h,3h-naphtho(1,8-cd)pyran-1-yl)-2-naphthoate  (C24H16O6, CAS 43000-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1Hydroxy41Hydroxy3Oxo1h3hNaphtho18CdPyran1Yl2Naphthoat;
formula     C24H16O6;
CAS         43000-19-7;
InChIKey    QJYUGFCUWYOCDJ-UHFFFAOYSA-N;
MW          400.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1409.52;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       1.7028;      // -   [origin=predictive method=lee-kesler]
Tb          1147.64;      // K   [origin=predictive method=joback]
HvapTb      122423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.23 2.42162 -0.00229264 8.738e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 11; } { group AC; count 8; } { group OH; count 1; } { group ACOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C_ring; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 9; } { group OH; count 1; } { group OH_phenol; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-naphthalenecarboxylic acid, 1-hydroxy-4-(1-hydroxy-3-oxo-1h,3h-naphtho(1,8-cd)pyran-1-yl)-, methyl ester" "2-naphthalenecarboxylic acid, 1-hydroxy-4-(1-hydroxy-3-oxo-1h,3h-naphtho[1,8-cd]pyran-1-yl)-, methyl ester" );
gibbsFormation
{
    dHf_298   -593110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     754.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281920.0
    phase     gas;
}
