/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptatriene  (C7H8, CAS 544-25-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptatriene;
formula     C7H8;
CAS         544-25-2;
InChIKey    CHVJITGCYZJHLR-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          604.95;      // K   [origin=predictive method=joback]
Pc          43.340;      // bar [origin=predictive method=joback]
omega       0.2188;      // -   [origin=predictive method=lee-kesler]
Tb          385.73;      // K   [origin=predictive method=joback]
HvapTb      32962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.8 0.6398 -0.00040884 9.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohepta-1,3,5-triene" "tropilidene" "tropilidine" "tropiliden" "cycloheptatrien" "tropyliden" "zykloheptatrien" "1h-[7]annulene" "cycloheptatriene;tropiliden; tropilidene" );
gibbsFormation
{
    dHf_298   54030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118000.0
    phase     gas;
}
