/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethylpentanal  (C7H14O, CAS 19353-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethylpentanal;
formula     C7H14O;
CAS         19353-21-0;
InChIKey    SZBNDYYJXRXQHA-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          587.33;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.4393;      // -   [origin=predictive method=lee-kesler]
Tb          407.54;      // K   [origin=predictive method=joback]
HvapTb      37120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.561 0.65516 -0.0003564 6.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethylvaleraldehyde" "pentanal, 3,4-dimethyl-" "valeraldehyde,3,4-dimethyl- (8ci); 3,4-dimethylpentanal; 3,4-dimethylvaleraldehyde" );
standardThermochemistry
{
    dHf_298   -283950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96340.0
}
