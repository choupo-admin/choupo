/*--------------------------------*- Choupo -*-----------------------*\
  Component: glaucine  (C21H25NO4, CAS 475-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glaucine;
formula     C21H25NO4;
CAS         475-81-0;
InChIKey    RUZIUYOSRDWYQF-HNNXBMFYSA-N;
MW          355.434;      // g/mol [origin=calculated method=formula-sum]
Tc          1101.03;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       1.1170;      // -   [origin=predictive method=lee-kesler]
Tb          880.03;      // K   [origin=predictive method=joback]
HvapTb      83000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.21 1.6432 -0.00096892 2.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 6; } { group ACCH2; count 2; } { group ACCH; count 1; } { group CH3O; count 4; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 9; } { group O; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6as)-1,2,9,10-tetramethoxy-6-methyl-5,6,6a,7-tetrahydro-4h-dibenzo[de,g]quinoline" "bromcholitin" "d-glaucine" "glauvent" "boldine dimethyl ether" "s-(+)-glaucine" "(+)-glaucine" "glaucine fumarate" "1,2,9,10-tetramethoxy-6a-alpha-aporphine" "6a-alpha-aporphine, 1,2,9,10-tetramethoxy-" "(s)-1,2,9,10-tetramethoxy-6-methyl-5,6,6a,7-tetrahydro-4h-dibenzo[de,g]quinoline" "(s)-5,6,6a,7-tetrahydro-1,2,9,10-tetramethoxy-6-methyl-4h-dibenzo(de,g)quinoline" );
standardThermochemistry
{
    dHf_298   -367090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127540.0
}
