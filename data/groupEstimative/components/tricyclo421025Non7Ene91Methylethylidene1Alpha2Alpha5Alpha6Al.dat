/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.2.1.02,5]non-7-ene,9-(1-methylethylidene)-,(1.alpha.,2.alpha.,5.alpha.,6.alpha.)-  (C12H16, CAS 53848-19-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo421025Non7Ene91Methylethylidene1Alpha2Alpha5Alpha6Al;
formula     C12H16;
CAS         53848-19-4;
InChIKey    VDJITTYGCWZCNW-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          708.62;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.4109;      // -   [origin=predictive method=lee-kesler]
Tb          495.39;      // K   [origin=predictive method=joback]
HvapTb      42895.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.62 1.43644 -0.00119228 4.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   31070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     240.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291570.0
}
