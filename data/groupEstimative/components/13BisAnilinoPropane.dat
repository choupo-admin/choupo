/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(anilino)propane  (C15H18N2, CAS 104-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisAnilinoPropane;
formula     C15H18N2;
CAS         104-69-8;
InChIKey    JQMRSZJEVQNIPB-UHFFFAOYSA-N;
MW          226.323;      // g/mol [origin=calculated method=formula-sum]
Tc          927.22;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.8510;      // -   [origin=predictive method=lee-kesler]
Tb          696.50;      // K   [origin=predictive method=joback]
HvapTb      66408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.977 1.4234 -0.0009518 2.393e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-diphenylpropane-1,3-diamine" "1,3-propanediamine, n,n'-diphenyl-" "1,3-propanediamine, n1,n3-diphenyl-" "(3-anilinopropyl)phenylamine" "n,n'-diphenyl-1,3-propanediamine" "1,3-propanediamine,n1,n3-diphenyl-" "1,3-propanediamine,n,n'-diphenyl- (6ci,7ci,8ci,9ci); 1,3-dianilinopropane; benzenamine,n,n'-1,3-propanediylbis-; n,n'-diphenyl-1,3-propanediamine;n,n'-trimethylenedianiline; warcoat gfc" );
standardThermochemistry
{
    dHf_298   227070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=479020.0
}
