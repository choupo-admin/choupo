/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(6-methoxy-2-naphthyl)ethanol  (C13H14O2, CAS 77301-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Methoxy2NaphthylEthanol;
formula     C13H14O2;
CAS         77301-42-9;
InChIKey    OUVJWFRUESFCCY-UHFFFAOYSA-N;
MW          202.253;      // g/mol [origin=calculated method=formula-sum]
Tc          878.65;      // K   [origin=predictive method=joback]
Pc          29.633;      // bar [origin=predictive method=joback]
omega       1.0236;      // -   [origin=predictive method=lee-kesler]
Tb          666.82;      // K   [origin=predictive method=joback]
HvapTb      68473.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.57 1.01394 -0.00063984 1.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(6-methoxynaphthalen-2-yl)ethanol" "2-(1-hydroxyethyl)-6-methoxynaphthalene" "1-(6'-methoxy-2-naphthyl)ethanol" "(+/-)-1-(6-methoxynaphthyl)ethanol" "6-methoxy-alpha-methyl-2-naphthalenemethanol" "1-(6-methoxy-2-naphthyl)ethan-1-ol" "naproxen impurity k" "a-(6-methoxy-2-naphthyl)ethanol" "ethanol, 1-(6-methoxy-2-naphthyl)-" "1-(6-methoxynaphthalen-2-yl)ethan-1-ol" "6-methoxy-" "a-methyl-2-naphthalenemethanol" "alpha-(6-methoxy-2-naphthyl)ethyl alcohol" );
standardThermochemistry
{
    dHf_298   -196720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14120.0
}
