/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butanol,2-amino-1-phenyl  (C10H15NO, CAS 5897-76-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butanol2Amino1Phenyl;
formula     C10H15NO;
CAS         5897-76-7;
InChIKey    UOZNVPFVNBRISY-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          827.82;      // K   [origin=predictive method=joback]
Pc          35.347;      // bar [origin=predictive method=joback]
omega       0.9957;      // -   [origin=predictive method=lee-kesler]
Tb          618.91;      // K   [origin=predictive method=joback]
HvapTb      66674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.689 0.98262 -0.0006316 1.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-1-phenyl-butan-1-ol" "usaf cs-7" "2-amino-1-phenyl-1-butanol" "1-butanol, 2-amino-1-phenyl-" "2-amino-1-phenyl-butanol" "beta-amino-alpha-phenylbutyl alcohol" "alpha-(1-aminopropyl)benzenemethanol" "1-phenyl-1-hydroxy-2-amino-n-butane" "alpha-(alpha-aminopropyl)benzyl alcohol" "benzenemethanol, alpha-(1-aminopropyl)-" "benzyl alcohol, alpha-(1-aminopropyl)-" "agn-pc-02yobl" );
standardThermochemistry
{
    dHf_298   -142200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70480.0
}
