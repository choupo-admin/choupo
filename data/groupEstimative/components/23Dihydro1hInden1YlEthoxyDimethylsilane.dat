/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydro-1h-inden-1-yl(ethoxy)dimethylsilane  (C13H20OSi, CAS 41273-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H20OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        23Dihydro1hInden1YlEthoxyDimethylsilane;
formula     C13H20OSi;
CAS         41273-53-4;
InChIKey    PJUIFNVDMDKVJC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          220.387;      // g/mol [origin=calculated method=formula-sum]
Tc          776.59;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.4700;      // -   [origin=predictive method=lee-kesler]
Tb          559.26;      // K   [origin=predictive method=joback]
HvapTb      50087.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.459 0.98196 -0.00034196 -2.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-inden-1-yl-ethoxy-dimethyl-silane" "silane,(2,3-dihydro-1h-inden-1-yl)ethoxydimethyl-" "2,3-dihydro-1h-inden-1-yl-ethoxy-dimethylsilane" "silane, (2,3-dihydro-1h-inden-1-yl)ethoxydimethyl-" );
standardThermochemistry
{
    dHf_298   -257630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12350.0
}
