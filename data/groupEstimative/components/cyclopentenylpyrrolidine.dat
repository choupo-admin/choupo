/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentenylpyrrolidine  (C9H15N, CAS 7148-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentenylpyrrolidine;
formula     C9H15N;
CAS         7148-07-4;
InChIKey    KOFSFYBXUYHNJL-UHFFFAOYSA-N;
MW          137.226;      // g/mol [origin=calculated method=formula-sum]
Tc          675.51;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.3917;      // -   [origin=predictive method=lee-kesler]
Tb          457.73;      // K   [origin=predictive method=joback]
HvapTb      39585.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.63 1.1932 -0.00091064 2.779e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(cyclopenten-1-yl)pyrrolidine" "1-pyrrolidino-1-cyclopentene" "pyrrolidine, 1-(1-cyclopenten-1-yl)-" "1-cyclopentenylpyrrolidine" "1-(1-cyclopenten-1-yl)pyrrolidine" "1-pyrrolidinocyclopentene" "1-(cyclopent-1-en-1-yl)pyrrolidine" "1-(1-pyrrolidino)cyclopentene" "1-(1-pyrrolidinyl)cyclopentene" "1-(cyclopent-1'-enyl)pyrrolidine" "n-(1-cyclopenten-1-yl)pyrrolidine" "1-(1-pyrrolidinyl)-1-cyclopentene" );
gibbsFormation
{
    dHf_298   52550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=256630.0
    phase     gas;
}
