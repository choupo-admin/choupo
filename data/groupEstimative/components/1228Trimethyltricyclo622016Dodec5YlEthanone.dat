/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,2,8-trimethyltricyclo[6.2.2.01,6]dodec-5-yl)ethanone  (C17H28O, CAS 6874-80-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1228Trimethyltricyclo622016Dodec5YlEthanone;
formula     C17H28O;
CAS         6874-80-2;
InChIKey    RVDZMZCRDXUENU-UHFFFAOYSA-N;
MW          248.41;      // g/mol [origin=calculated method=formula-sum]
Tc          903.84;      // K   [origin=predictive method=joback]
Pc          19.701;      // bar [origin=predictive method=joback]
omega       0.5698;      // -   [origin=predictive method=lee-kesler]
Tb          666.84;      // K   [origin=predictive method=joback]
HvapTb      56366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-309.39 2.83748 -0.0028907 1.22786e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 2; } { group C; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanone, 1-(octahydro-2,5,5-trimethyl-2h-2,4a-ethanonaphthalen-8-yl)-" "1-(2,5,5-trimethyloctahydro-2h-2,4a-ethanonaphthalen-8-yl)ethanone" );
standardThermochemistry
{
    dHf_298   -301830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77400.0
}
