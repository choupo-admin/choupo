/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylethyl methacrylate  (C12H14O2, CAS 3683-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylethylMethacrylate;
formula     C12H14O2;
CAS         3683-12-3;
InChIKey    ILZXXGLGJZQLTR-UHFFFAOYSA-N;
MW          190.242;      // g/mol [origin=calculated method=formula-sum]
Tc          767.15;      // K   [origin=predictive method=joback]
Pc          25.328;      // bar [origin=predictive method=joback]
omega       0.5846;      // -   [origin=predictive method=lee-kesler]
Tb          555.62;      // K   [origin=predictive method=joback]
HvapTb      51399.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.198 0.99002 -0.0005908 1.192e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethyl 2-methylprop-2-enoate" "phenethyl methacrylate" "phenylethyl methacrylate" "2-propenoic acid, 2-methyl-, 2-phenylethyl ester" "beta-phenylethyl methacrylate" ".beta.-phenylethyl methacrylate" "beta-phenylethyl 2-methylpropenate" "phenylethyl 2-methyl-2-propenoate" "methacrylic acid, phenethyl ester (7ci,8ci)" "phenethyl 2-methylprop-2-enoate" "2-propenoic acid,2-methyl-, 2-phenylethyl ester" "methacrylicacid, phenethyl ester (7ci,8ci); 2-phenylethyl methacrylate; phenethylmethacrylate; b-phenylethylmethacrylate" );
gibbsFormation
{
    dHf_298   -256120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68510.0
    phase     gas;
}
