/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 2-chloro-4-hydroxy-, 4-octylphenyl ester  (C21H25ClO3, CAS 50687-74-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid2Chloro4Hydroxy4OctylphenylEster;
formula     C21H25ClO3;
CAS         50687-74-6;
InChIKey    NDURWBNONNSWNY-UHFFFAOYSA-N;
MW          360.878;      // g/mol [origin=calculated method=formula-sum]
Tc          1147.75;      // K   [origin=predictive method=joback]
Pc          16.194;      // bar [origin=predictive method=joback]
omega       1.1584;      // -   [origin=predictive method=lee-kesler]
Tb          919.67;      // K   [origin=predictive method=joback]
HvapTb      93022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.033 1.82862 -0.00122908 3.249e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 1; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-octylphenyl) 2-chloranyl-4-oxidanyl-benzoate" "4-octylphenyl 2-chloro-4-hydroxybenzoate" "(4-octylphenyl) 2-chloro-4-hydroxybenzoate" );
standardThermochemistry
{
    dHf_298   -536980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     859.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145420.0
}
