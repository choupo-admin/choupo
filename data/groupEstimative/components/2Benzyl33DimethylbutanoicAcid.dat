/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzyl-3,3-dimethylbutanoic acid  (C13H18O2, CAS 53483-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Benzyl33DimethylbutanoicAcid;
formula     C13H18O2;
CAS         53483-12-8;
InChIKey    UKWWMMXKMDNJEM-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          890.72;      // K   [origin=predictive method=joback]
Pc          24.532;      // bar [origin=predictive method=joback]
omega       0.7811;      // -   [origin=predictive method=lee-kesler]
Tb          665.56;      // K   [origin=predictive method=joback]
HvapTb      62288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.389 1.34246 -0.0009622 2.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethyl-2-(phenylmethyl)butanoic acid" "alpha-(tert-butyl)hydrocinnamic acid" "a-(tert-butyl)hydrocinnamic acid" ".alpha.-(tert-butyl)hydrocinnamic acid" "benzenepropanoic acid, .alpha.-(1,1-dimethylethyl)-" );
standardThermochemistry
{
    dHf_298   -439420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-172520.0
}
