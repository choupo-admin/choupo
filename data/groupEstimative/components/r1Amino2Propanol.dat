/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(-)-1-amino-2-propanol  (C3H9NO, CAS 2799-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r1Amino2Propanol;
formula     C3H9NO;
CAS         2799-16-8;
InChIKey    HXKKHQJGJAFBHI-GSVOUGTGSA-N;
MW          75.111;      // g/mol [origin=calculated method=formula-sum]
Tc          613.68;      // K   [origin=predictive method=joback]
Pc          54.951;      // bar [origin=predictive method=joback]
omega       0.7776;      // -   [origin=predictive method=lee-kesler]
Tb          432.51;      // K   [origin=predictive method=joback]
HvapTb      49204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.261 0.39062 -0.0002164 4.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-1-azanylpropan-2-ol" "(r)-1-aminopropan-2-ol" "(r)-1-amino-2-propanol" "(-)-isopropanolamine" "(2r)-1-aminopropan-2-ol" "(r)-(-)-1-aminopropan-2-ol" "d-(-)-alaninol" "(r)-(-)-isopropanolamine" "(2r)-(-)-hydroxypropylamine" "(2r)-(-)-2-hydroxypropylamine" );
standardThermochemistry
{
    dHf_298   -228970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98430.0
}
