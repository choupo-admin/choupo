/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(dimethylamino)ethoxy]pyridine  (C9H14N2O, CAS 29450-09-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DimethylaminoEthoxyPyridine;
formula     C9H14N2O;
CAS         29450-09-7;
InChIKey    YULRZMYHLLQZEI-UHFFFAOYSA-N;
MW          166.224;      // g/mol [origin=calculated method=formula-sum]
Tc          733.73;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.5753;      // -   [origin=predictive method=lee-kesler]
Tb          520.76;      // K   [origin=predictive method=joback]
HvapTb      48567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.328 0.8744 -0.00050786 1.058e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-pyridin-2-yloxy-ethanamine" "2-(2-pyridyloxy)ethyl(dimethyl)amine" "n,n-dimethyl-2-pyridin-2-yloxyethanamine" "ethanamine,n,n-dimethyl-2-(2-pyridinyloxy)-" );
gibbsFormation
{
    dHf_298   -24460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=220140.0
    phase     gas;
}
