/*--------------------------------*- Choupo -*-----------------------*\
  Component: nornicotine  (C9H12N2, CAS 5746-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nornicotine;
formula     C9H12N2;
CAS         5746-86-1;
InChIKey    MYKUKUCHPMASKF-UHFFFAOYSA-N;
MW          148.209;      // g/mol [origin=calculated method=formula-sum]
Tc          810.04;      // K   [origin=predictive method=joback]
Pc          41.893;      // bar [origin=predictive method=joback]
omega       0.4547;      // -   [origin=predictive method=lee-kesler]
Tb          549.73;      // K   [origin=predictive method=joback]
HvapTb      51129.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.7 0.93196 -0.00057306 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2NH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pyrrolidin-2-ylpyridine" "3-(pyrrolidin-2-yl)pyridine" "3-(2-pyrrolidinyl)pyridine" "(r,s)-nornicotine" "2-(3-pyridyl)pyrrolidine" "(+-)-nornicotine" "(+/-)-nornicotine" "(r)-3-(pyrrolidin-2-yl)pyridine" "3-pyrrolidin-2-yl-pyridine" "(+-)-1'-demethylnicotine" "(+-)-3-(2-pyrrolidinyl)pyridine" "l-nornicotine hydrochloride" );
standardThermochemistry
{
    dHf_298   138520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=338620.0
}
