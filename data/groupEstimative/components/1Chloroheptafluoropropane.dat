/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloroheptafluoropropane  (C3ClF7, CAS 422-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloroheptafluoropropane;
formula     C3ClF7;
CAS         422-86-6;
InChIKey    XXSZLFRJEKKBDJ-UHFFFAOYSA-N;
MW          204.469;      // g/mol [origin=calculated method=formula-sum]
Tc          429.78;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.3251;      // -   [origin=predictive method=lee-kesler]
Tb          290.87;      // K   [origin=predictive method=joback]
HvapTb      17050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.73 0.7556 -0.00079 2.884e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF3; count 1; } { group CF2; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 7; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-1,1,2,2,3,3,3-heptakis(fluoranyl)propane" "1-chloro-1,1,2,2,3,3,3-heptafluoropropane" "heptafluoropropyl chloride" );
gibbsFormation
{
    dHf_298   -1520010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1392700.0
    phase     gas;
}
