/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentanedioic acid, 2-bromo-, diethyl ester  (C9H15BrO4, CAS 7209-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentanedioicAcid2BromoDiethylEster;
formula     C9H15BrO4;
CAS         7209-00-9;
InChIKey    OXJSWZSWGJACGU-UHFFFAOYSA-N;
MW          267.119;      // g/mol [origin=calculated method=formula-sum]
Tc          780.56;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.8548;      // -   [origin=predictive method=lee-kesler]
Tb          587.68;      // K   [origin=predictive method=joback]
HvapTb      56489.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.034 0.79334 -0.0003512 1.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2COO; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group Br; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-bromanylpentanedioate" "diethyl 2-bromopentanedioate" );
standardThermochemistry
{
    dHf_298   -842600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-583960.0
}
