/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycerol triacrylate  (C12H14O6, CAS 5459-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycerolTriacrylate;
formula     C12H14O6;
CAS         5459-38-1;
InChIKey    PUGOMSLRUSTQGV-UHFFFAOYSA-N;
MW          254.238;      // g/mol [origin=calculated method=formula-sum]
Tc          826.84;      // K   [origin=predictive method=joback]
Pc          20.272;      // bar [origin=predictive method=joback]
omega       0.9378;      // -   [origin=predictive method=lee-kesler]
Tb          638.42;      // K   [origin=predictive method=joback]
HvapTb      62129.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.552 0.9253 -0.0004171 1.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-di(prop-2-enoyloxy)propyl prop-2-enoate" "glyceryl triacrylate" "acrylin, tri-" "1,2,3-propanetriyl triacrylate" "2-propenoic acid, 1,1',1''-(1,2,3-propanetriyl) ester" "2-propenoic acid,2,3-propanetriyl ester" );
gibbsFormation
{
    dHf_298   -871840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-619870.0
    phase     gas;
}
