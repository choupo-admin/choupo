/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-tert-butyl-dl-alanine  (C7H15NO2, CAS 106247-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TertButylDlAlanine;
formula     C7H15NO2;
CAS         106247-35-2;
InChIKey    LPBSHGLDBQBSPI-UHFFFAOYSA-N;
MW          145.202;      // g/mol [origin=calculated method=formula-sum]
Tc          786.59;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.7846;      // -   [origin=predictive method=lee-kesler]
Tb          574.13;      // K   [origin=predictive method=joback]
HvapTb      57297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.539 0.91326 -0.000648 1.825e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4,4-dimethyl-pentanoic acid" "2-amino-4,4-dimethylpentanoic acid" "neopentylglycine" "4-methyl-leucine" "2-amino-3-tert-butylpropionic acid" "dl-neopentylglycine" "a-methyl-dl-leucine" "dl-" "a-neopentylglycine" "dl-alpha-neopentylglycine" "3-tert-butyl dl-alanine" "a-tert-butyl-dl-alanine" "dl-2-amino-4,4-dimethyl pentanoic acid" );
gibbsFormation
{
    dHf_298   -518320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269000.0
    phase     gas;
}
