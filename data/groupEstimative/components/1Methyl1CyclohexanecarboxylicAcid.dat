/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-1-cyclohexanecarboxylic acid  (C8H14O2, CAS 1123-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl1CyclohexanecarboxylicAcid;
formula     C8H14O2;
CAS         1123-25-7;
InChIKey    REHQLKUNRPCYEW-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          777.76;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.5972;      // -   [origin=predictive method=lee-kesler]
Tb          547.94;      // K   [origin=predictive method=joback]
HvapTb      49844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.38 1.22862 -0.0010976 4.196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylcyclohexane-1-carboxylic acid" "1-methylcyclohexanecarboxylic acid" "1-methylcyclohexylcarboxylic acid" "1-methylcyclohexanoic acid" "1-methyl-1-cyclohexanoic acid" "cyclohexanecarboxylic acid, 1-methyl-" "1-carboxy-1-methylcyclohexane" "cyclohexanecarboxylicacid, 1-methyl-" "1-methyl-cyclohexane-1-carboxylic acid" );
gibbsFormation
{
    dHf_298   -489160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-308470.0
    phase     gas;
}
