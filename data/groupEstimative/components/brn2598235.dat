/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2598235  (C26H16O, CAS 63040-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C26H16O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        brn2598235;
formula     C26H16O;
CAS         63040-56-2;
InChIKey    MCGBHWDYRPGANM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          344.413;      // g/mol [origin=calculated method=formula-sum]
Tc          1176.50;      // K   [origin=predictive method=joback]
Pc          19.069;      // bar [origin=predictive method=joback]
omega       0.9606;      // -   [origin=predictive method=lee-kesler]
Tb          914.66;      // K   [origin=predictive method=joback]
HvapTb      84909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.11 2.10272 -0.00196168 7.321e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 11; } { group ACCH3; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methylbenzo(rst)pentaphene-5-carboxaldehyde" "benzo(rst)pentaphene-5-carboxaldehyde, 8-methyl-" "8-methylbenzo[rst]pentaphene-5-carbaldehyde" );
gibbsFormation
{
    dHf_298   574080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=794120.0
    phase     gas;
}
