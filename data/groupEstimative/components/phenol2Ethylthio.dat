/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2-(ethylthio)-  (C8H10OS, CAS 29549-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol2Ethylthio;
formula     C8H10OS;
CAS         29549-60-8;
InChIKey    CSJBSYKCAKKLKG-UHFFFAOYSA-N;
MW          154.227;      // g/mol [origin=calculated method=formula-sum]
Tc          806.51;      // K   [origin=predictive method=joback]
Pc          45.104;      // bar [origin=predictive method=joback]
omega       0.5894;      // -   [origin=predictive method=lee-kesler]
Tb          558.72;      // K   [origin=predictive method=joback]
HvapTb      55509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.609 0.83391 -0.00065876 2.15e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylsulfanylphenol" "phenol, o-(ethylthio)-" "2-(ethylthio)phenol" "2-(ethylsulfanyl)phenol" "phenol,o-(ethylthio)- (6ci,7ci,8ci); 2-(ethylthio)phenol; 2-ethylsulfanylphenol" );
standardThermochemistry
{
    dHf_298   -107360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7390.0
}
