/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanone, 1,1-dihydroxy-  (C3H6O3, CAS 1186-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanone11Dihydroxy;
formula     C3H6O3;
CAS         1186-47-6;
InChIKey    UOQFZGVGGMHGEE-UHFFFAOYSA-N;
MW          90.078;      // g/mol [origin=calculated method=formula-sum]
Tc          678.18;      // K   [origin=predictive method=joback]
Pc          63.898;      // bar [origin=predictive method=joback]
omega       1.3166;      // -   [origin=predictive method=lee-kesler]
Tb          506.03;      // K   [origin=predictive method=joback]
HvapTb      61988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.42 0.33472 -0.0001847 3.456e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(oxidanyl)propan-2-one" "1,1-dihydroxyacetone" "agn-pc-00lbgg" "1,1-dihydroxy-2-propanone" );
gibbsFormation
{
    dHf_298   -527570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-430620.0
    phase     gas;
}
