/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctacosane  (C28H56, CAS 297-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctacosane;
formula     C28H56;
CAS         297-24-5;
InChIKey    UWXTYOJKSPHFNG-UHFFFAOYSA-N;
MW          392.756;      // g/mol [origin=calculated method=formula-sum]
Tc          1235.37;      // K   [origin=predictive method=joback]
Pc          10.286;      // bar [origin=predictive method=joback]
omega       0.5161;      // -   [origin=predictive method=lee-kesler]
Tb          958.40;      // K   [origin=predictive method=joback]
HvapTb      82444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-206.77 2.6012 -0.000615 -2.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 28; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 28; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -682110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1696.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49160.0
}
