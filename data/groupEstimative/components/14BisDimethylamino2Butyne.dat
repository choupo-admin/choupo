/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(dimethylamino)-2-butyne  (C8H16N2, CAS 111-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BisDimethylamino2Butyne;
formula     C8H16N2;
CAS         111-53-5;
InChIKey    FFDFQBBNDKGBGI-UHFFFAOYSA-N;
MW          140.23;      // g/mol [origin=calculated method=formula-sum]
Tc          600.21;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.4259;      // -   [origin=predictive method=lee-kesler]
Tb          416.52;      // K   [origin=predictive method=joback]
HvapTb      39640.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.208 0.86188 -0.00054446 1.3778e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH3N; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group tC; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetramethylbut-2-yne-1,4-diamine" "2-butyne-1,4-diamine, n,n,n',n'-tetramethyl-" "n,n,n',n'-tetramethylbut-2-ynylenediamine" "n,n,n',n'-tetramethyl-2-butyne-1,4-diamine" "2-butyne-1,4-diamine, n1,n1,n4,n4-tetramethyl-" "2-butyne-1, n,n,n',n'-tetramethyl-" "4-dimethylaminobut-2-ynyl-dimethyl-amine" "[4-(dimethylamino)but-2-yn-1-yl]dimethylamine" );
gibbsFormation
{
    dHf_298   198910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=440840.0
    phase     gas;
}
