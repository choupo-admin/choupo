/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromotridecane  (C13H27Br, CAS 59157-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromotridecane;
formula     C13H27Br;
CAS         59157-17-4;
InChIKey    XNCUZDYTCKIDEJ-UHFFFAOYSA-N;
MW          263.263;      // g/mol [origin=calculated method=formula-sum]
Tc          739.21;      // K   [origin=predictive method=joback]
Pc          17.521;      // bar [origin=predictive method=joback]
omega       0.7232;      // -   [origin=predictive method=lee-kesler]
Tb          562.76;      // K   [origin=predictive method=joback]
HvapTb      50579.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.42 1.28294 -0.000758 1.771e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyltridecane" "tridecane, 2-bromo-" );
gibbsFormation
{
    dHf_298   -290600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     703.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70460.0
    phase     gas;
}
