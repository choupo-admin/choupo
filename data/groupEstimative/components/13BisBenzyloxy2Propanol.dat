/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(benzyloxy)-2-propanol  (C17H20O3, CAS 6972-79-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisBenzyloxy2Propanol;
formula     C17H20O3;
CAS         6972-79-8;
InChIKey    ARLSYSVVBAMYKA-UHFFFAOYSA-N;
MW          272.344;      // g/mol [origin=calculated method=formula-sum]
Tc          989.01;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       1.1990;      // -   [origin=predictive method=lee-kesler]
Tb          778.50;      // K   [origin=predictive method=joback]
HvapTb      79099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.766 1.3745 -0.000775 1.418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH2; count 2; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(phenylmethoxy)propan-2-ol" "1,3-dibenzyloxy-2-propanol" "1,3-bis(benzyloxy)propan-2-ol" "1,3-di-o-benzylglycerol" "2-propanol, 1,3-bis(phenylmethoxy)-" "1,3-dibenzylglycerin" "1,3-dibenzyl glycerol" "1,3-benzyloxy-2-propanol" "1,3-dibenzyloxy-2-hydroxypropane" "1,3-bis(phenylmethoxy)-2-propanol" "2-propanol,1,3-bis(phenylmethoxy)-" "1,3-dibenzyloxy-2-hydroxypropane;1,3-bis(benzyloxy)propan-2-ol" );
standardThermochemistry
{
    dHf_298   -343100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32180.0
}
