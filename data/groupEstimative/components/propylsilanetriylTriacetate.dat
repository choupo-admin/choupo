/*--------------------------------*- Choupo -*-----------------------*\
  Component: propylsilanetriyl triacetate  (C9H16O6Si, CAS 17865-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H16O6Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        propylsilanetriylTriacetate;
formula     C9H16O6Si;
CAS         17865-07-5;
InChIKey    DKGZKEKMWBGTIB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.306;      // g/mol [origin=calculated method=formula-sum]
Tc          768.00;      // K   [origin=predictive method=joback]
Pc          20.908;      // bar [origin=predictive method=joback]
omega       0.7907;      // -   [origin=predictive method=lee-kesler]
Tb          581.58;      // K   [origin=predictive method=joback]
HvapTb      58143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (111.752 0.48828 0.0002328 -2.926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH3COO; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[diacetyloxy(propyl)silyl] ethanoate" "n-propyltriacetoxysilane" "silanetriol, propyl-, triacetate" "silanetriol, 1-propyl-, 1,1,1-triacetate" "propyltriacetoxysilane" "[diacetyloxy(propyl)silyl] acetate" );
gibbsFormation
{
    dHf_298   -1292550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     786.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1010970.0
    phase     gas;
}
