/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 12-acetyloxyoctadec-9-enoate  (C21H38O4, CAS 140-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl12Acetyloxyoctadec9Enoate;
formula     C21H38O4;
CAS         140-03-4;
InChIKey    CMOYPQWMTBSLJK-UHFFFAOYSA-N;
MW          354.531;      // g/mol [origin=calculated method=formula-sum]
Tc          983.51;      // K   [origin=predictive method=joback]
Pc          9.989;      // bar [origin=predictive method=joback]
omega       0.9234;      // -   [origin=predictive method=lee-kesler]
Tb          800.24;      // K   [origin=predictive method=joback]
HvapTb      76724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.753 1.91516 -0.0010164 1.714e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3COO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -999390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1060.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-417020.0
}
