/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-spirobi(1h-indene)  (C17H12, CAS 165-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Spirobi1hIndene;
formula     C17H12;
CAS         165-42-4;
InChIKey    HTJGPQTUUZKORI-UHFFFAOYSA-N;
MW          216.283;      // g/mol [origin=calculated method=formula-sum]
Tc          932.16;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.5662;      // -   [origin=predictive method=lee-kesler]
Tb          664.32;      // K   [origin=predictive method=joback]
HvapTb      58708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-187.51 1.8598 -0.00187868 7.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH=CH; count 2; } { group ACH; count 8; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1'-spirobi[indene]" "1,1'-spirobi[1h-indene]" );
gibbsFormation
{
    dHf_298   358810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=493560.0
    phase     gas;
}
