/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoethanol formate  (C3H9NO3, CAS 53226-35-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H9NO3 (delta H+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2AminoethanolFormate;
formula     C3H9NO3;
CAS         53226-35-0;
InChIKey    IKAHFTWDTODWID-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          107.109;      // g/mol [origin=calculated method=formula-sum]
Tc          776.97;      // K   [origin=predictive method=joback]
Pc          55.361;      // bar [origin=predictive method=joback]
omega       1.2251;      // -   [origin=predictive method=lee-kesler]
Tb          579.16;      // K   [origin=predictive method=joback]
HvapTb      66903.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.952 0.3324 -7.84e-05 -3.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group HCOOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylethanol;methanoic acid" "2-aminoethanol, formate" "2-aminoethanol; formic acid" "formic acid, compd. with 2-aminoethanol (1:1)" "formic acid, compound with 2-aminoethanol (1:1)" "2-hydroxyethylammonium formate" "formic acid - 2-aminoethanol (1:1)" );
standardThermochemistry
{
    dHf_298   -629770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-492280.0
}
