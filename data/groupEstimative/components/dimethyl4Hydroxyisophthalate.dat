/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 4-hydroxyisophthalate  (C10H10O5, CAS 5985-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl4Hydroxyisophthalate;
formula     C10H10O5;
CAS         5985-24-0;
InChIKey    ALBUJVBOIXVVLS-UHFFFAOYSA-N;
MW          210.185;      // g/mol [origin=calculated method=formula-sum]
Tc          881.18;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.9598;      // -   [origin=predictive method=lee-kesler]
Tb          657.12;      // K   [origin=predictive method=joback]
HvapTb      68620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.09 0.86044 -0.00055152 1.273e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 4-oxidanylbenzene-1,3-dicarboxylate" "4-hydroxyisophthalic acid dimethyl ester" "4-hydroxy-isophthalic acid dimethyl ester" "1,3-benzenedicarboxylic acid, 4-hydroxy-, dimethyl ester" "1,3-benzenedicarboxylic acid, 4-hydroxy-, 1,3-dimethyl ester" "dimethyl4-hydroxyisophthalate" "1, 4-hydroxy-, dimethyl ester" "dimethyl 4-hydroxybenzene-1,3-dicarboxylate" "isophthalic acid, 4-hydroxy-, dimethyl ester (8ci)" "1,3-benzenedicarboxylicacid, 4-hydroxy-, 1,3-dimethyl ester" );
standardThermochemistry
{
    dHf_298   -836540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-639260.0
}
