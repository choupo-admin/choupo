/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropa[b]anthracene, 1,1-difluoro-  (C15H8F2, CAS 78239-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropaBAnthracene11Difluoro;
formula     C15H8F2;
CAS         78239-34-6;
InChIKey    LUFVSGWZFKCBPL-UHFFFAOYSA-N;
MW          226.225;      // g/mol [origin=calculated method=formula-sum]
Tc          855.51;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.6550;      // -   [origin=predictive method=lee-kesler]
Tb          619.36;      // K   [origin=predictive method=joback]
HvapTb      53310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.45 1.6496 -0.00177412 7.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 6; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 6; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropa(b)anthracene, 1,1-difluoro-" "1,1-difluoro-1h-cyclopropa[b]anthracene" );
gibbsFormation
{
    dHf_298   -60530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62080.0
    phase     gas;
}
