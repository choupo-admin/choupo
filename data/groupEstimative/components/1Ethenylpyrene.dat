/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethenylpyrene  (C18H12, CAS 17088-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethenylpyrene;
formula     C18H12;
CAS         17088-21-0;
InChIKey    WPMHMYHJGDAHKX-UHFFFAOYSA-N;
MW          228.294;      // g/mol [origin=calculated method=formula-sum]
Tc          949.80;      // K   [origin=predictive method=joback]
Pc          25.793;      // bar [origin=predictive method=joback]
omega       0.6982;      // -   [origin=predictive method=lee-kesler]
Tb          698.98;      // K   [origin=predictive method=joback]
HvapTb      63538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.34 1.5005 -0.00132406 4.701e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 9; } { group AC; count 7; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-vinylpyrene" "3-vinylpyrene" "pyrene, 3-vinyl-" "pyrene, 1-ethenyl-" "pyrene, 1-ethenyl- (9ci)" "pyrene,3-vinyl- (8ci); 1-ethenylpyrene; 1-vinylpyrene; 3-vinylpyrene" );
gibbsFormation
{
    dHf_298   440450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=586230.0
    phase     gas;
}
