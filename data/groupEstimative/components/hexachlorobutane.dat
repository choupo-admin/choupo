/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexachlorobutane  (C4H4Cl6, CAS 26523-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexachlorobutane;
formula     C4H4Cl6;
CAS         26523-63-7;
InChIKey    MINPZZUPSSVGJN-UHFFFAOYSA-N;
MW          264.776;      // g/mol [origin=calculated method=formula-sum]
Tc          747.61;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.3593;      // -   [origin=predictive method=lee-kesler]
Tb          509.24;      // K   [origin=predictive method=joback]
HvapTb      48216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.652 0.6762 -0.0006598 2.342e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CCl3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 2; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,4,4,4-hexakis(chloranyl)butane" "pcb2" "butane, hexachloro-" "1,1,1,4,4,4-hexachlorobutane" );
standardThermochemistry
{
    dHf_298   -237830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83100.0
}
