/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8,11-epithio-5,14-ethenobenzocyclododecene,6,7,12,13-tetrahydro-  (C18H16S, CAS 53539-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        811Epithio514Ethenobenzocyclododecene671213Tetrahydro;
formula     C18H16S;
CAS         53539-29-0;
InChIKey    LIUZQALEWGMVSB-UHFFFAOYSA-N;
MW          264.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.96;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.6758;      // -   [origin=predictive method=lee-kesler]
Tb          758.80;      // K   [origin=predictive method=joback]
HvapTb      69582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.97 1.62161 -0.00126042 3.925e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 6; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8,11-epithio-5,14-ethenobenzocyclododecene, 6,7,12,13-tetrahydro-" "6,7,12,13-tetrahydro-8,11-epithio-5,14-(ethanediylidene)benzo[12]annulene" );
gibbsFormation
{
    dHf_298   295490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=481620.0
    phase     gas;
}
