/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3,4-dichlorophenyl)propanoic acid  (C9H8Cl2O2, CAS 25173-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        334DichlorophenylPropanoicAcid;
formula     C9H8Cl2O2;
CAS         25173-68-6;
InChIKey    NHYJRLYFKZYPMO-UHFFFAOYSA-N;
MW          219.061;      // g/mol [origin=calculated method=formula-sum]
Tc          895.28;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.8571;      // -   [origin=predictive method=lee-kesler]
Tb          662.53;      // K   [origin=predictive method=joback]
HvapTb      65162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.782 0.7253 -0.00047632 1.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,4-dichlorophenyl)propionic acid" "benzenepropanoic acid, 3,4-dichloro-" "3-(3',4'-dichlorophenyl)propionic acid" "hydrocinnamicacid, 3,4-dichloro- (6ci,7ci,8ci);3,4-dichloro-b-phenylpropionic acid;3-(3,4-dichlorophenyl)propanoicacid;3-(3,4-dichlorophenyl)propionic acid;b-(3,4-dichlorophenyl)propionic acid;" );
gibbsFormation
{
    dHf_298   -397250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-249720.0
    phase     gas;
}
