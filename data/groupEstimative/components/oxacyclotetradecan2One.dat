/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxacyclotetradecan-2-one  (C13H24O2, CAS 1725-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxacyclotetradecan2One;
formula     C13H24O2;
CAS         1725-04-8;
InChIKey    IUDIJIVSWGWJNV-UHFFFAOYSA-N;
MW          212.333;      // g/mol [origin=calculated method=formula-sum]
Tc          842.81;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.4916;      // -   [origin=predictive method=lee-kesler]
Tb          605.10;      // K   [origin=predictive method=joback]
HvapTb      53709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.79 1.275 -0.0004468 -5.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-oxacyclotetradecan-2-one" "tridecanoic acid, 13-hydroxy-, .mu.-lactone" "tridecanoic acid,13-hydroxy-, m-lactone(6ci,7ci); 1,13-tridecanolide; 13-tridecanolide; cyclotridecanolide;tridecanolactone; tridecanolide" );
standardThermochemistry
{
    dHf_298   -591230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     845.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292230.0
}
