/*--------------------------------*- Choupo -*-----------------------*\
  Component: desmotroposantonine, acetate  (C17H20O4, CAS 14794-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        desmotroposantonineAcetate;
formula     C17H20O4;
CAS         14794-69-5;
InChIKey    ZWPKGSNVVQTUMS-UHFFFAOYSA-N;
MW          288.343;      // g/mol [origin=calculated method=formula-sum]
Tc          970.25;      // K   [origin=predictive method=joback]
Pc          17.849;      // bar [origin=predictive method=joback]
omega       0.9375;      // -   [origin=predictive method=lee-kesler]
Tb          756.14;      // K   [origin=predictive method=joback]
HvapTb      72519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.88 1.47728 -0.00090624 2.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group ACH; count 1; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,6,9-trimethyl-2-oxidanylidene-3a,4,5,9b-tetrahydro-3h-benzo[g][1]benzofuran-8-yl) ethanoate" "(+)-beta-desmotroposantonin acetate" "(-)-alpha-desmotroposantonin acetate" "(+).beta.-desmotroposantonin acetate" "(-).alpha.-desmotroposantonin acetate" "(3,6,9-trimethyl-2-oxo-3a,4,5,9b-tetrahydro-3h-benzo[g][1]benzofuran-8-yl) acetate" "3,6,9-trimethyl-2-oxo-2,3,3a,4,5,9b-hexahydronaphtho[1,2-b]furan-8-yl acetate" );
gibbsFormation
{
    dHf_298   -706700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-328700.0
    phase     gas;
}
