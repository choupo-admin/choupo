/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipentylacetic acid  (C12H24O2, CAS 5422-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipentylaceticAcid;
formula     C12H24O2;
CAS         5422-52-6;
InChIKey    PLVOWOHSFJLXOR-UHFFFAOYSA-N;
MW          200.322;      // g/mol [origin=calculated method=formula-sum]
Tc          800.34;      // K   [origin=predictive method=joback]
Pc          19.355;      // bar [origin=predictive method=joback]
omega       0.9256;      // -   [origin=predictive method=lee-kesler]
Tb          619.23;      // K   [origin=predictive method=joback]
HvapTb      59082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.102 1.20054 -0.0007048 1.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentylheptanoic acid" "di-n-amylacetic acid" "heptanoic acid,2-pentyl-" "heptanoic acid, 2-pentyl-" "diamylacetic acid;dipentylacetic acid;" );
standardThermochemistry
{
    dHf_298   -646560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296190.0
}
