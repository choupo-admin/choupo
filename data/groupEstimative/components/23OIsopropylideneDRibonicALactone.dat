/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-o-isopropylidene-d-ribonic |a-lactone  (C8H12O5, CAS 30725-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23OIsopropylideneDRibonicALactone;
formula     C8H12O5;
CAS         30725-00-9;
InChIKey    NHHKFJCWLPPNCN-HSUXUTPPSA-N;
MW          188.179;      // g/mol [origin=calculated method=formula-sum]
Tc          785.39;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       1.0677;      // -   [origin=predictive method=lee-kesler]
Tb          591.32;      // K   [origin=predictive method=joback]
HvapTb      64565.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.639 1.27774 -0.0011816 4.595e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH-O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3ar,6r,6ar)-6-(hydroxymethyl)-2,2-dimethyl-6,6a-dihydro-3ah-furo[3,4-d][1,3]dioxol-4-one" "2,3-o-isopropylidene-d-ribono-1,4-lactone" "(3ar,6r,6ar)-6-(hydroxymethyl)-2,2-dimethyldihydrofuro[3,4-d][1,3]dioxol-4(3ah)-one" "nhhkfjcwlppncn-hsuxutppsa-" "2,3-o-isopropylidene-d-ribonic-gamma-lactone" "(5s,1r,4r)-4-(hydroxymethyl)-7,7-dimethyl-3,6,8-trioxabicyclo[3.3.0]octan-2-on e" );
gibbsFormation
{
    dHf_298   -821800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     271.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-502360.0
    phase     gas;
}
