/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-m-tolylaminoethanol  (C9H13NO, CAS 102-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MTolylaminoethanol;
formula     C9H13NO;
CAS         102-41-0;
InChIKey    GZCPEUOCUUNCLZ-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          776.58;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.9943;      // -   [origin=predictive method=lee-kesler]
Tb          579.53;      // K   [origin=predictive method=joback]
HvapTb      61681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.818 0.83062 -0.00050896 1.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(3-methylphenyl)amino]ethanol" "m-tolylethanolamine" "2-m-toluidinoethanol" "2-(m-toluidino)ethanol" "hydroxyethyl-3-toluidine" "ethanol, 2-[(3-methylphenyl)amino]-" "ethanol, 2-((3-methylphenyl)amino)-" "ethanol, 2-m-toluidino-" "n-hydroxyethyl-m-toluidine" "2-(3-methylanilino)ethanol" "n-(2-hydroxyethyl)-m-toluidine" "ethanol, 2-m-toluidino- (8ci)" );
gibbsFormation
{
    dHf_298   -102790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80250.0
    phase     gas;
}
