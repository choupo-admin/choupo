/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylhexa-1,4-diene  (C7H12, CAS 1116-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylhexa14Diene;
formula     C7H12;
CAS         1116-90-1;
InChIKey    JBVMSEMQJGGOFR-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          540.17;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.2725;      // -   [origin=predictive method=lee-kesler]
Tb          360.48;      // K   [origin=predictive method=joback]
HvapTb      30544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.339 0.66874 -0.000466 1.387e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-4-methyl-1,4-hexadiene" "1,4-hexadiene,4-methyl-" );
gibbsFormation
{
    dHf_298   45050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167570.0
    phase     gas;
}
