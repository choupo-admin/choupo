/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenedinaphthalene  (C21H16, CAS 28515-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenedinaphthalene;
formula     C21H16;
CAS         28515-57-3;
InChIKey    ZMESHQOXZMOOQQ-UHFFFAOYSA-N;
MW          268.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.11;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       0.7335;      // -   [origin=predictive method=lee-kesler]
Tb          781.36;      // K   [origin=predictive method=joback]
HvapTb      71496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.299 1.7146 -0.00132036 4.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(naphthalen-1-ylmethyl)naphthalene" "1-(1-naphthylmethyl)naphthalene" "naphthalene, 1,1'-methylenebis-" );
standardThermochemistry
{
    dHf_298   355490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=544800.0
}
