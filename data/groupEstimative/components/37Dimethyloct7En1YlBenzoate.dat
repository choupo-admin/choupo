/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyloct-7-en-1-yl benzoate  (C17H24O2, CAS 10486-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyloct7En1YlBenzoate;
formula     C17H24O2;
CAS         10486-12-1;
InChIKey    WAMANGVSGOBEEJ-UHFFFAOYSA-N;
MW          260.377;      // g/mol [origin=calculated method=formula-sum]
Tc          869.90;      // K   [origin=predictive method=joback]
Pc          16.538;      // bar [origin=predictive method=joback]
omega       0.7748;      // -   [origin=predictive method=lee-kesler]
Tb          669.58;      // K   [origin=predictive method=joback]
HvapTb      62141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.425 1.47094 -0.000866 1.782e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-7-enyl benzoate" "7-octen-1-ol, 3,7-dimethyl-, benzoate, (-)-" "7-octen-1-ol, 3,7-dimethyl-, 1-benzoate, (-)-" "(-)-3,7-dimethyloct-7-enyl benzoate" );
standardThermochemistry
{
    dHf_298   -364600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     744.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28850.0
}
