/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)cyclobutanecarboxylic acid  (C11H11ClO2, CAS 50921-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ChlorophenylCyclobutanecarboxylicAcid;
formula     C11H11ClO2;
CAS         50921-39-6;
InChIKey    XYSRHOKREWGGFE-UHFFFAOYSA-N;
MW          210.657;      // g/mol [origin=calculated method=formula-sum]
Tc          929.59;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.7767;      // -   [origin=predictive method=lee-kesler]
Tb          677.13;      // K   [origin=predictive method=joback]
HvapTb      63501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.58 1.4012 -0.00133816 5.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)cyclobutane-1-carboxylic acid" "1-(4-chlorophenyl)-1-cyclobutanecarboxylic acid" "cyclobutanecarboxylic acid, 1-(4-chlorophenyl)-" "1-(p-chlorophenyl)cyclobutanecarboxylic acid" "cyclobutanecarboxylicacid, 1-(4-chlorophenyl)-" "1-(4-chlorophenyl)-1-cyclobutane- carboxylic acid" "1-(4-chlorophenyl)-1-cyclobutanecarboxylicacid;1-(4-chlorophenyl)cyclobutanecarboxylic acid;1-(p-chlorophenyl)cyclobutanecarboxylic acid;" );
standardThermochemistry
{
    dHf_298   -329440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168160.0
}
