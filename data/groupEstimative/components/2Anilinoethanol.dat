/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-anilinoethanol  (C8H11NO, CAS 122-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Anilinoethanol;
formula     C8H11NO;
CAS         122-98-5;
InChIKey    MWGATWIBSKHFMR-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          750.44;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.9461;      // -   [origin=predictive method=lee-kesler]
Tb          551.67;      // K   [origin=predictive method=joback]
HvapTb      58793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.208 0.7951 -0.0005216 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylazanylethanol" "2-(phenylamino)ethanol" "n-phenylethanolamine" "n-(2-hydroxyethyl)aniline" "ethanol, 2-(phenylamino)-" "ethanol, 2-anilino-" "beta-anilinoethanol" "2-(phenylamino)ethan-1-ol" "phenyl ethanolamine" "n-(2-hydroxyethyl)phenylamine" "aniline, n-(2-hydroxyethyl)-" "n-hydroxyethyl aniline" );
standardThermochemistry
{
    dHf_298   -70680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81460.0
}
