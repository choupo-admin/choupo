/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diethyl-2,6,7-trioxabicyclo[2.2.2]octane  (C9H16O3, CAS 4177-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diethyl267Trioxabicyclo222Octane;
formula     C9H16O3;
CAS         4177-72-4;
InChIKey    VYRWKGJBKMJWMF-UHFFFAOYSA-N;
MW          172.224;      // g/mol [origin=calculated method=formula-sum]
Tc          731.96;      // K   [origin=predictive method=joback]
Pc          34.239;      // bar [origin=predictive method=joback]
omega       0.4926;      // -   [origin=predictive method=lee-kesler]
Tb          508.87;      // K   [origin=predictive method=joback]
HvapTb      47026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.038 1.71624 -0.0018369 8.046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 2; } { group FCH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 3; } { group C_ring; count 2; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diethyl-3,5,8-trioxabicyclo[2.2.2]octane" "1,4-diethyl-2,6,7-trioxabicyclo(2.2.2)octane" "3,6-diethyl-1,5,7-trioxabicyclo(2.2.2)octane" "2,6,7-trioxabicyclo(2.2.2)octane, 1,4-diethyl-" "2,6,7-trioxabicyclo[2.2.2]octane, 1,4-diethyl-" );
gibbsFormation
{
    dHf_298   -461330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147140.0
    phase     gas;
}
