/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 3,5-hexadienyl-  (C12H14, CAS 39669-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene35Hexadienyl;
formula     C12H14;
CAS         39669-95-9;
InChIKey    IXBHYZXSUSMOPF-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          715.04;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       0.4279;      // -   [origin=predictive method=lee-kesler]
Tb          501.68;      // K   [origin=predictive method=joback]
HvapTb      43870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.098 1.0649 -0.0007669 2.219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-3,5-dienylbenzene" "benzene, (3e)-3,5-hexadienyl-" "benzene, (3z)-3,5-hexadienyl-" );
standardThermochemistry
{
    dHf_298   188170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330630.0
}
