/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-2,2-dimethyl-1-propanol  (C5H11BrO, CAS 40894-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo22Dimethyl1Propanol;
formula     C5H11BrO;
CAS         40894-00-6;
InChIKey    KQOQXYPZBYTICM-UHFFFAOYSA-N;
MW          167.046;      // g/mol [origin=calculated method=formula-sum]
Tc          658.06;      // K   [origin=predictive method=joback]
Pc          43.397;      // bar [origin=predictive method=joback]
omega       0.7442;      // -   [origin=predictive method=lee-kesler]
Tb          469.11;      // K   [origin=predictive method=joback]
HvapTb      48542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.648 0.67684 -0.0005218 1.641e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-2,2-dimethyl-propan-1-ol" "3-bromo-2,2-dimethylpropan-1-ol" "1-propanol,3-bromo-2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -281180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-128440.0
    phase     gas;
}
