/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2,4-pentanediol  (C6H14O2, CAS 5683-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl24Pentanediol;
formula     C6H14O2;
CAS         5683-44-3;
InChIKey    RBQLGIKHSXQZTB-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          686.04;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       1.1911;      // -   [origin=predictive method=lee-kesler]
Tb          519.92;      // K   [origin=predictive method=joback]
HvapTb      61144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.97 0.65956 -0.000373 7.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 3; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 3; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpentane-2,4-diol" "2,4-pentanediol, 3-methyl-" "agn-pc-00jzjf" "(2s,4s)-3-methylpentane-2,4-diol" );
gibbsFormation
{
    dHf_298   -487470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281320.0
    phase     gas;
}
