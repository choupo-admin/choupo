/*--------------------------------*- Choupo -*-----------------------*\
  Component: b-octylglucoside  (C14H28O6, CAS 29836-26-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bOctylglucoside;
formula     C14H28O6;
CAS         29836-26-8;
InChIKey    HEGSGKPQLMEBJL-RKQHYHRCSA-N;
MW          292.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1155.77;      // K   [origin=predictive method=joback]
Pc          21.694;      // bar [origin=predictive method=joback]
omega       1.5890;      // -   [origin=predictive method=lee-kesler]
Tb          938.88;      // K   [origin=predictive method=joback]
HvapTb      119587.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.298 1.41972 -0.0005939 2.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 4; } { group OH; count 4; } { group CH2O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH_ring; count 5; } { group OH; count 4; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3s,4s,5r,6r)-2-(hydroxymethyl)-6-octoxy-oxane-3,4,5-triol" "octyl-beta-d-glucopyranoside" "octyl beta-d-glucoside" "n-octyl glucoside" "octyl beta-d-glucopyranoside" "octyl-beta-d-glucopyranose" "beta-d-glucopyranoside, octyl" "octyl glucoside" "n-octyl beta-d-glucopyranoside" "glc-(1-1)oct" "1-o-octyl-beta-d-glucopyranoside" "1-o-n-octyl-beta-d-glucopyranoside" );
standardThermochemistry
{
    dHf_298   -1232470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     664.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-677790.0
}
