/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylphenol  (C10H14O, CAS 98-54-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylphenol;
formula     C10H14O;
CAS         98-54-4;
InChIKey    QHPQWRBYOIRBIT-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          765.45;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.5107;      // -   [origin=predictive method=lee-kesler]
Tb          532.47;      // K   [origin=predictive method=joback]
HvapTb      51848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.5 1.15536 -0.00097956 3.383e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butylphen" "p-tert-butylphenol" "ptbp" "4-(1,1-dimethylethyl)phenol" "4-(tert-butyl)phenol" "phenol, p-tert-butyl-" "p-t-butyl phenol" "phenol, 4-(1,1-dimethylethyl)-" "para-tertiary-butylphenol" "4-t-butylphenol" "p-terc.butylfenol" "phenol, p-(tert-butyl)-" );
standardThermochemistry
{
    dHf_298   -199260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6050.0
}
