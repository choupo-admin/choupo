/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanoic acid;2-methylprop-1-en-1-ol  (C6H12O3, CAS 14478-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanoicAcid2Methylprop1En1Ol;
formula     C6H12O3;
CAS         14478-14-9;
InChIKey    UWCKJKIMNPQZBQ-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          775.46;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       1.0257;      // -   [origin=predictive method=lee-kesler]
Tb          580.01;      // K   [origin=predictive method=joback]
HvapTb      63125.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.27 0.47236 -7.69e-05 -7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=C; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -673860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-514180.0
}
