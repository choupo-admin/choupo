/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2,2-dimethylpropanamide  (C5H10ClNO, CAS 41461-75-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro22Dimethylpropanamide;
formula     C5H10ClNO;
CAS         41461-75-0;
InChIKey    CCFNEVMWSYAQKL-UHFFFAOYSA-N;
MW          135.591;      // g/mol [origin=calculated method=formula-sum]
Tc          687.69;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.5118;      // -   [origin=predictive method=lee-kesler]
Tb          474.60;      // K   [origin=predictive method=joback]
HvapTb      47200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.611 0.64534 -0.0004651 1.3116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2Cl; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2,2-dimethyl-propanamide" "propanamide, 3-chloro-2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -249810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80340.0
    phase     gas;
}
