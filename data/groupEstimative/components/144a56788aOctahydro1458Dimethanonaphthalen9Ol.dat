/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,4a,5,6,7,8,8a-octahydro-1,4:5,8-dimethanonaphthalen-9-ol  (C12H16O, CAS 28068-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        144a56788aOctahydro1458Dimethanonaphthalen9Ol;
formula     C12H16O;
CAS         28068-45-3;
InChIKey    NGFZLQIRULRVPV-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          781.37;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.8262;      // -   [origin=predictive method=lee-kesler]
Tb          578.45;      // K   [origin=predictive method=joback]
HvapTb      58002.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-178.1 1.6459 -0.00136128 4.582e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 7; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 7; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4:5,8-dimethanonaphthalen-9-ol, 1,4,4a,5,6,7,8,8a-octahydro-" "tetracyclo(6.2.1.1(3,6).0(2,7))dodec-4-ene-11-ol, stereoisomer" "1,4:5,8-dimethanonaphthalen-9-ol, 1,4,4a,5,6,7,8,8a-octahydro-, anti-endo,exo-" "1,4:5,8-dimethanonaphthalen-9-ol, 1,4,4a,5,6,7,8,8a-octahydro-, stereoisomer" );
gibbsFormation
{
    dHf_298   -155280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     148.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163170.0
    phase     gas;
}
