/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1-phenyl-2-pentanol  (C12H18O, CAS 7779-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl1Phenyl2Pentanol;
formula     C12H18O;
CAS         7779-78-4;
InChIKey    IUADYGVMSDKSMB-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          787.28;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.8852;      // -   [origin=predictive method=lee-kesler]
Tb          592.14;      // K   [origin=predictive method=joback]
HvapTb      60485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.998 1.11074 -0.000697 1.659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1-phenyl-pentan-2-ol" "benzylisoamyl alcohol" "isobutylbenzylcarbinol" "alpha-isobutylphenethyl alcohol" "4-methyl-1-phenylpentan-2-ol" "isobutyl benzyl carbinol" "iso-butyl benzyl carbinol" "2-methylpropyl benzyl carbinol" "benzeneethanol, .alpha.-(2-methylpropyl)-" "phenethyl alcohol, alpha-isobutyl-" "alpha-(2-methylpropyl)benzeneethanol" "benzeneethanol, alpha-(2-methylpropyl)-" );
gibbsFormation
{
    dHf_298   -217270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20870.0
    phase     gas;
}
