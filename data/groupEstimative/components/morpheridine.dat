/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpheridine  (C20H30N2O3, CAS 469-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpheridine;
formula     C20H30N2O3;
CAS         469-81-8;
InChIKey    JDEDMCKQPKGSAX-UHFFFAOYSA-N;
MW          346.471;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.60;      // K   [origin=predictive method=joback]
Pc          17.699;      // bar [origin=predictive method=joback]
omega       0.9928;      // -   [origin=predictive method=lee-kesler]
Tb          829.40;      // K   [origin=predictive method=joback]
HvapTb      78065.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-204.747 2.59672 -0.0020549 6.665e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group FCH2O; count 1; } { group CH2N; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 8; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-(2-morpholin-4-ylethyl)-4-phenyl-piperidine-4-carboxylate" "ta 1" "4-piperidinecarboxylic acid, 1-[2-(4-morpholinyl)ethyl]-4-phenyl-, ethyl ester" "morferidina" "morpheridinum" "4-piperidinecarboxylic acid, 1-(2-(4-morpholinyl)ethyl)-4-phenyl-, ethyl ester" "morpholinoethylnorpethidin" "morpheridine dihydrochloride" "morpheridinum [inn-latin]" "morpheridine [inn:ban:dcf]" "ethyl 1-(2-morpholinoethyl)-4-phenyl-4-piperidylcarboxylat" "1-(2-morpholinoethyl)-4-phenylpiperidin-4-carbonsaeureethylester" );
standardThermochemistry
{
    dHf_298   -377280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     871.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130320.0
}
