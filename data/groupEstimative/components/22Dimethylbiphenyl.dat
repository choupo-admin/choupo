/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-dimethylbiphenyl  (C14H14, CAS 605-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylbiphenyl;
formula     C14H14;
CAS         605-39-0;
InChIKey    ABMKWMASVFVTMD-UHFFFAOYSA-N;
MW          182.266;      // g/mol [origin=calculated method=formula-sum]
Tc          825.05;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       0.4737;      // -   [origin=predictive method=lee-kesler]
Tb          583.24;      // K   [origin=predictive method=joback]
HvapTb      52634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.05 1.05704 -0.00066612 1.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2-(2-methylphenyl)benzene" "1,1'-biphenyl, 2,2'-dimethyl-" "o,o'-bitolyl" "2,2'-ditolyl" "1-methyl-2-(2'-methylphenyl)benzene" "o,o'-bitoluene" "2,2'-bitolyl" "2,2'-dimethyl biphenyl" "o,o'-bitolyl (8ci)" "agn-pc-03ec4b" "abmkwmasvfvtmd-uhfffaoysa-" "2,2'-dimethyl-1,1'-biphenyl" );
gibbsFormation
{
    dHf_298   117830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272560.0
    phase     gas;
}
