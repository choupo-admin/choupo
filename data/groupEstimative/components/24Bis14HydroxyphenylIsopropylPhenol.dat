/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-bis(1-(4-hydroxyphenyl)isopropyl)phenol  (C24H26O3, CAS 2300-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Bis14HydroxyphenylIsopropylPhenol;
formula     C24H26O3;
CAS         2300-15-4;
InChIKey    VPVTXVHUJHGOCM-UHFFFAOYSA-N;
MW          362.469;      // g/mol [origin=calculated method=formula-sum]
Tc          1346.21;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       1.3499;      // -   [origin=predictive method=lee-kesler]
Tb          1069.14;      // K   [origin=predictive method=joback]
HvapTb      112958.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.05 2.70308 -0.00242104 8.691e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group ACH; count 11; } { group AC; count 4; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis[2-(4-hydroxyphenyl)propan-2-yl]phenol" "phenol, 2,4-bis(1-(4-hydroxyphenyl)-1-methylethyl)-" "phenol, 2,4-bis[1-(4-hydroxyphenyl)-1-methylethyl]-" "2,4-bis(p-hydroxy-alpha,alpha-dimethylbenzyl)phenol" "2,4-bis(p-hydroxy-.alpha.,.alpha.-dimethylbenzyl)phenol" "2,4-bis[1-(4-hydroxyphenyl)-1-methylethyl]phenol" );
gibbsFormation
{
    dHf_298   -390000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20620.0
    phase     gas;
}
