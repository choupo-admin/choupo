/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chlorovanillic acid  (C8H7ClO4, CAS 62936-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5ChlorovanillicAcid;
formula     C8H7ClO4;
CAS         62936-23-6;
InChIKey    XBRYEHVBBMSSCG-UHFFFAOYSA-N;
MW          202.59;      // g/mol [origin=calculated method=formula-sum]
Tc          944.25;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       1.1177;      // -   [origin=predictive method=lee-kesler]
Tb          705.26;      // K   [origin=predictive method=joback]
HvapTb      73975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.38 0.71492 -0.00054688 1.75e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH_phenol; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-5-methoxy-4-oxidanyl-benzoic acid" "3-chloro-4-hydroxy-5-methoxybenzoic acid" "5-chloro-4-hydroxy-3-methoxybenzoic acid" "3-chloro-4-hydroxy-5-methoxy-benzoic acid" "chloro-4-hydroxy-3-methoxybenzoic acid" );
standardThermochemistry
{
    dHf_298   -670400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-505830.0
}
