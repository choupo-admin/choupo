/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadec-9-enylammonium acetate  (C20H41NO2, CAS 3811-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadec9EnylammoniumAcetate;
formula     C20H41NO2;
CAS         3811-68-5;
InChIKey    NLGOTHQMVKZTBP-UHFFFAOYSA-N;
MW          327.553;      // g/mol [origin=calculated method=formula-sum]
Tc          1080.64;      // K   [origin=predictive method=joback]
Pc          10.907;      // bar [origin=predictive method=joback]
omega       1.0220;      // -   [origin=predictive method=lee-kesler]
Tb          880.80;      // K   [origin=predictive method=joback]
HvapTb      88171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.435 1.83034 -0.0008492 9.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH=CH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group dCH; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;octadec-9-en-1-amine" "acetic acid; (e)-octadec-9-en-1-amine" );
standardThermochemistry
{
    dHf_298   -767010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1140.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184480.0
}
