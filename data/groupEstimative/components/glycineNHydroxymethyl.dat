/*--------------------------------*- Choupo -*-----------------------*\
  Component: glycine, n-(hydroxymethyl)-  (C3H7NO3, CAS 15874-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycineNHydroxymethyl;
formula     C3H7NO3;
CAS         15874-34-7;
InChIKey    WBTIFBJEYFLFFW-UHFFFAOYSA-N;
MW          105.093;      // g/mol [origin=calculated method=formula-sum]
Tc          743.29;      // K   [origin=predictive method=joback]
Pc          58.094;      // bar [origin=predictive method=joback]
omega       1.2888;      // -   [origin=predictive method=lee-kesler]
Tb          556.10;      // K   [origin=predictive method=joback]
HvapTb      62551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.842 0.4498 -0.000291 7.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hydroxymethylamino)ethanoic acid" "monomethylolglycine" "hydroxymethylglycine" "hydroxymethylglycinate" "hydroxymethylaminoacetic acid" "2-(hydroxymethylamino)acetic acid" );
gibbsFormation
{
    dHf_298   -554280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416960.0
    phase     gas;
}
