name        cyclotetrasiloxane2468Tetramethyl2468Tetrakis3Acryloxypropyl;
formula     C28H48O12Si4;
CAS         71550-64-6;
InChIKey    CUHKVBVNLQPDQC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          689.02;      // g/mol [origin=calculated method=formula-sum]
Tc          1485.89;      // K   [origin=predictive method=joback]
Pc          6.109;      // bar [origin=predictive method=joback]
omega       0.3529;      // -   [origin=predictive method=lee-kesler]
Tb          1188.92;      // K   [origin=predictive method=joback]
HvapTb      124480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (238.362 1.69568 0.000273 -6.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH2=CH; count 4; } { group COO; count 4; } { group SiO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group dCH2; count 4; } { group dCH; count 4; } { group O_ring; count 4; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
