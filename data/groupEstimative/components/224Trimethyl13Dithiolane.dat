/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-1,3-dithiolane  (C6H12S2, CAS 5862-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl13Dithiolane;
formula     C6H12S2;
CAS         5862-53-3;
InChIKey    CRVLTUAGMFKJEA-UHFFFAOYSA-N;
MW          148.282;      // g/mol [origin=calculated method=formula-sum]
Tc          683.50;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.2393;      // -   [origin=predictive method=lee-kesler]
Tb          443.39;      // K   [origin=predictive method=joback]
HvapTb      39371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.46 0.99978 -0.0009446 3.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2S; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dithiolane, 2,2,4-trimethyl-" );
standardThermochemistry
{
    dHf_298   -21270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102710.0
}
