/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dithiaheptane  (C5H12S2, CAS 4396-19-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dithiaheptane;
formula     C5H12S2;
CAS         4396-19-4;
InChIKey    RJQVVQDWHKZIHU-UHFFFAOYSA-N;
MW          136.271;      // g/mol [origin=calculated method=formula-sum]
Tc          666.92;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.3873;      // -   [origin=predictive method=lee-kesler]
Tb          451.56;      // K   [origin=predictive method=joback]
HvapTb      40358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.543 0.46762 -0.0001678 -6.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethylsulfanylmethylsulfanylethane" "bis(ethylthio)methane" "methane, bis(ethylthio)-" "formaldehyde diethyl mercaptal" "ethane, 1,1'-[methylenebis(thio)]bis-" "di(ethylthio)methane" "methylenebis[ethyl sulfide]" "formaldehyde diethyl dithioacetal" "ethane,1'-[methylenebis(thio)]bis-" "1,1'-[methylenebis(thio)]bis-ethane" "{[(ethylsulfanyl)methyl]sulfanyl}ethane" );
standardThermochemistry
{
    dHf_298   -62790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57460.0
}
