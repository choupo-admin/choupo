/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodoundecane  (C11H23I, CAS 4282-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodoundecane;
formula     C11H23I;
CAS         4282-44-4;
InChIKey    FKUQOQPBCHJHAP-UHFFFAOYSA-N;
MW          282.205;      // g/mol [origin=calculated method=formula-sum]
Tc          733.23;      // K   [origin=predictive method=joback]
Pc          18.970;      // bar [origin=predictive method=joback]
omega       0.5904;      // -   [origin=predictive method=lee-kesler]
Tb          544.42;      // K   [origin=predictive method=joback]
HvapTb      49453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.58 1.08782 -0.000656 1.596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylundecane" "iodoundecane" "1-iodo-undecane" "1-iodoundecane;undecyl iodide;" );
standardThermochemistry
{
    dHf_298   -193500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99860.0
}
