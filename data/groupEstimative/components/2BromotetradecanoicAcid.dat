/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromotetradecanoic acid  (C14H27BrO2, CAS 10520-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromotetradecanoicAcid;
formula     C14H27BrO2;
CAS         10520-81-7;
InChIKey    GBBKJNDQLLKTCX-UHFFFAOYSA-N;
MW          307.272;      // g/mol [origin=calculated method=formula-sum]
Tc          921.08;      // K   [origin=predictive method=joback]
Pc          17.419;      // bar [origin=predictive method=joback]
omega       1.1089;      // -   [origin=predictive method=lee-kesler]
Tb          731.15;      // K   [origin=predictive method=joback]
HvapTb      69969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.271 1.42872 -0.000885 2.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyltetradecanoic acid" "tetradecanoic acid, 2-bromo-" "alpha-bromomyristic acid" "2-bromomyristic acid" ".alpha.-bromomyristic acid" "alpha-bromomyristic acid, 90%" );
standardThermochemistry
{
    dHf_298   -661510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-265030.0
}
