/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyheptyl propionate  (C10H20O3, CAS 67845-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyheptylPropionate;
formula     C10H20O3;
CAS         67845-56-1;
InChIKey    SPSUSSKQSQLWFK-UHFFFAOYSA-N;
MW          188.267;      // g/mol [origin=calculated method=formula-sum]
Tc          745.42;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       1.0785;      // -   [origin=predictive method=lee-kesler]
Tb          578.36;      // K   [origin=predictive method=joback]
HvapTb      61552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.816 0.93894 -0.0004592 6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylheptyl propanoate" "2-hydroxyheptyl propanoate" "1,2-heptanediol, 1-propanoate" );
standardThermochemistry
{
    dHf_298   -724520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416310.0
}
