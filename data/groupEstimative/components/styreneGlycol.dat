/*--------------------------------*- Choupo -*-----------------------*\
  Component: styrene glycol  (C8H10O2, CAS 93-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        styreneGlycol;
formula     C8H10O2;
CAS         93-56-1;
InChIKey    PWMWNFMRSKOCEY-UHFFFAOYSA-N;
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          783.24;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       1.2841;      // -   [origin=predictive method=lee-kesler]
Tb          593.24;      // K   [origin=predictive method=joback]
HvapTb      68648.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.389 0.7588 -0.0005066 1.286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylethane-1,2-diol" "1-phenyl-1,2-ethanediol" "phenylethanediol" "phenylethylene glycol" "1,2-ethanediol, 1-phenyl-" "phenyl glycol" "styrolyl alcohol" "phenyl-1,2-ethanediol" "phenyl glycol ether" "1,2-dihydroxy-1-phenylethane" "1-phenylethylene glycol" "phenylethane-1,2-diol" );
gibbsFormation
{
    dHf_298   -281660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147190.0
    phase     gas;
}
