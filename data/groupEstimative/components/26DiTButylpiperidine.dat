/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-di-t-butylpiperidine  (C13H27N, CAS 66922-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiTButylpiperidine;
formula     C13H27N;
CAS         66922-18-7;
InChIKey    ZOYHTWUFFGGARK-UHFFFAOYSA-N;
MW          197.366;      // g/mol [origin=calculated method=formula-sum]
Tc          773.48;      // K   [origin=predictive method=joback]
Pc          20.091;      // bar [origin=predictive method=joback]
omega       0.4083;      // -   [origin=predictive method=lee-kesler]
Tb          554.01;      // K   [origin=predictive method=joback]
HvapTb      48818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.62 1.57272 -0.000992 2.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butylpiperidine" "2,6-di-tert-butylpiperidine" );
standardThermochemistry
{
    dHf_298   -257360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168710.0
}
