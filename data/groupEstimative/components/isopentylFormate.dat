/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopentyl formate  (C6H12O2, CAS 110-45-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H12O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        isopentylFormate;
formula     C6H12O2;
CAS         110-45-2;
InChIKey    XKYICAQFSCFURC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          476.39;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.2197;      // -   [origin=predictive method=lee-kesler]
Tb          312.86;      // K   [origin=predictive method=joback]
HvapTb      26189.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.748 0.58784 -0.0004588 1.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl methanoate" "isoamyl formate" "3-methylbutyl formate" "isoamyl methanoate" "isopentyl alcohol, formate" "isopentyl methanoate" "1-butanol, 3-methyl-, formate" "formic acid, isopentyl ester" "1-butanol, formate" "formic acid isoamyl ester" "o774" "we(4:1(2)(3me)/1:0)" );
gibbsFormation
{
    dHf_298   -96000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41160.0
    phase     gas;
}
