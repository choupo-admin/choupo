/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexen-3-ol, 4-methyl-6-(2,2,3-trimethyl-3-cyclopenten-1-yl)-  (C15H26O, CAS 67801-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexen3Ol4Methyl6223Trimethyl3Cyclopenten1Yl;
formula     C15H26O;
CAS         67801-25-6;
InChIKey    VMTWNGOLSSRRNR-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          846.10;      // K   [origin=predictive method=joback]
Pc          19.153;      // bar [origin=predictive method=joback]
omega       0.8991;      // -   [origin=predictive method=lee-kesler]
Tb          653.25;      // K   [origin=predictive method=joback]
HvapTb      64596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.459 1.7763 -0.00143764 5.121e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-6-(2,2,3-trimethylcyclopent-3-en-1-yl)hex-5-en-3-ol" );
standardThermochemistry
{
    dHf_298   -296810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     698.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57620.0
}
