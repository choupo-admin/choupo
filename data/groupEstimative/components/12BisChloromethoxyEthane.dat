/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(chloromethoxy)ethane  (C4H8Cl2O2, CAS 13483-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisChloromethoxyEthane;
formula     C4H8Cl2O2;
CAS         13483-18-6;
InChIKey    IDFLGSYEBJNWMK-UHFFFAOYSA-N;
MW          159.006;      // g/mol [origin=calculated method=formula-sum]
Tc          593.08;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.4736;      // -   [origin=predictive method=lee-kesler]
Tb          410.82;      // K   [origin=predictive method=joback]
HvapTb      38088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.034 0.271 -1.26e-05 -5.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2O; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloromethyloxy)ethane" "bis-1,2-(chloromethoxy)ethane" "ethane, 1,2-bis(chloromethoxy)-" "ethylene glycol bis(chloromethyl)ether" "ethylene glycol bis(chloromethyl) ether" "1,2-bis[(chloromethyl)oxy]ethane" "ethane,2-bis(chloromethoxy)-" );
standardThermochemistry
{
    dHf_298   -421810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251060.0
}
