/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-3-heptene  (C8H16, CAS 22768-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl3Heptene;
formula     C8H16;
CAS         22768-18-9;
InChIKey    AAUHUDBDDBJONC-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          562.04;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.3422;      // -   [origin=predictive method=lee-kesler]
Tb          386.68;      // K   [origin=predictive method=joback]
HvapTb      33440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.257 0.78376 -0.0004975 1.332e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylhept-3-ene" "3-heptene, 3-methyl-, (3e)-" "2-ethyl-2-hexene;3-methyl-3-heptene" );
gibbsFormation
{
    dHf_298   -101020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88150.0
    phase     gas;
}
