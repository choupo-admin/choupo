/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-benzyloxyphenylacetonitrile  (C15H13NO, CAS 20967-96-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Benzyloxyphenylacetonitrile;
formula     C15H13NO;
CAS         20967-96-8;
InChIKey    CKZFVIPFANUBDW-UHFFFAOYSA-N;
MW          223.275;      // g/mol [origin=calculated method=formula-sum]
Tc          969.63;      // K   [origin=predictive method=joback]
Pc          23.726;      // bar [origin=predictive method=joback]
omega       0.7736;      // -   [origin=predictive method=lee-kesler]
Tb          725.64;      // K   [origin=predictive method=joback]
HvapTb      67086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.758 1.0831 -0.00064556 1.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-phenylmethoxyphenyl)ethanenitrile" "3-(phenylmethoxy)-benzenemethanol" "2-(3-phenylmethoxyphenyl)acetonitrile" "2-(3-(benzyloxy)phenyl)acetonitrile" "2-[3-(benzyloxy)phenyl]acetonitrile" "2-[3-(phenylmethoxy)phenyl]ethanenitrile" "3-benzyloxy-phenyl acetonitrile" "acetonitrile,[m-(benzyloxy)phenyl]- (8ci); 3'-benzyloxyphenylacetonitrile;[3-(benzyloxy)phenyl]acetonitrile; [m-(benzyloxy)phenyl]acetonitrile" );
gibbsFormation
{
    dHf_298   141320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=318790.0
    phase     gas;
}
