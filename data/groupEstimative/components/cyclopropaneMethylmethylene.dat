/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropane, methylmethylene-  (C5H8, CAS 18631-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropaneMethylmethylene;
formula     C5H8;
CAS         18631-84-0;
InChIKey    PKCSMQZDZICOIA-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          499.92;      // K   [origin=predictive method=joback]
Pc          41.677;      // bar [origin=predictive method=joback]
omega       0.2186;      // -   [origin=predictive method=lee-kesler]
Tb          319.90;      // K   [origin=predictive method=joback]
HvapTb      26796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.61 0.51222 -0.000376 1.185e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2-methylidene-cyclopropane" "1-methyl-2-methylenecyclopropane" "1-methyl-2-methylidenecyclopropane" );
standardThermochemistry
{
    dHf_298   10510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     234.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105050.0
}
