/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyldimethyl(2-propynyloxy)silane  (C9H18OSi, CAS 76782-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H18OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tertButyldimethyl2PropynyloxySilane;
formula     C9H18OSi;
CAS         76782-82-6;
InChIKey    ZYDKYFIXEYSNPO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          170.327;      // g/mol [origin=calculated method=formula-sum]
Tc          608.83;      // K   [origin=predictive method=joback]
Pc          23.749;      // bar [origin=predictive method=joback]
omega       0.2657;      // -   [origin=predictive method=lee-kesler]
Tb          416.23;      // K   [origin=predictive method=joback]
HvapTb      36894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.331 0.6214 -0.00010773 -8.581e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 1; } { group CH2O; count 1; } { group CH_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl-dimethyl-prop-2-ynoxy-silane" "tert-butyl-dimethyl-prop-2-ynoxysilane" "tert-butyldimethyl(prop-2-ynyloxy)silane" "ghl.pd_mitscher_leg0.449" "upcmld00wv-88" "zydkyfixeysnpo-uhfffaoysa-" "silane,(1,1-dimethylethyl)dimethyl(2-propyn-1-yloxy)-" "tert-butyldimethyl(2-propynyloxy)silane;tert-butyldimethyl(prop-2-ynyloxy)silane" );
gibbsFormation
{
    dHf_298   -189780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41050.0
    phase     gas;
}
