/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-decanol  (C10H22O, CAS 112-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Decanol;
formula     C10H22O;
CAS         112-30-1;
InChIKey    MWKFXSUHUHTGQN-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          679.13;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       0.9540;      // -   [origin=predictive method=lee-kesler]
Tb          520.58;      // K   [origin=predictive method=joback]
HvapTb      54533.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.911 0.98782 -0.0005506 1.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decan-1-ol" "decyl alcohol" "n-decyl alcohol" "decanol" "n-decanol" "capric alcohol" "nonylcarbinol" "antak" "caprinic alcohol" "royaltac" "n-decan-1-ol" "n-decatyl alcohol" );
standardThermochemistry
{
    dHf_298   -401960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103500.0
}
