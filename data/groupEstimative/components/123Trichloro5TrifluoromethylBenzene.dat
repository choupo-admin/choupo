/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trichloro-5-(trifluoromethyl)benzene  (C7H2Cl3F3, CAS 50594-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Trichloro5TrifluoromethylBenzene;
formula     C7H2Cl3F3;
CAS         50594-82-6;
InChIKey    FBKFIAIRSQOXJR-UHFFFAOYSA-N;
MW          249.437;      // g/mol [origin=calculated method=formula-sum]
Tc          723.01;      // K   [origin=predictive method=joback]
Pc          29.828;      // bar [origin=predictive method=joback]
omega       0.4911;      // -   [origin=predictive method=lee-kesler]
Tb          508.25;      // K   [origin=predictive method=joback]
HvapTb      44846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.99 0.593 -0.00046928 1.386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCl; count 3; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(chloranyl)-5-(trifluoromethyl)benzene" "3,4,5-trichlorobenzotrifluoride" "3,4,5-trichlorotrifluoromethylbenzene" "3,4,5-trichloro-a,a,a-trifluorotoluene" "3,4,5-trichlorotrifluorotoluene" "t109" "3,4,5-trichloro-alpha,alpha,alpha-trifluorotoluene" );
gibbsFormation
{
    dHf_298   -629990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-525800.0
    phase     gas;
}
