/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholestane  (C27H48, CAS 481-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholestane;
formula     C27H48;
CAS         481-21-0;
InChIKey    XIIAYQZJNBULGD-UHFFFAOYSA-N;
MW          372.681;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.97;      // K   [origin=predictive method=joback]
Pc          10.027;      // bar [origin=predictive method=joback]
omega       0.6763;      // -   [origin=predictive method=lee-kesler]
Tb          851.26;      // K   [origin=predictive method=joback]
HvapTb      72203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-333.757 3.6406 -0.0029992 1.0682e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 13; } { group CH; count 7; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 10; } { group CH_ring; count 5; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthrene" "cholestane, (5.alpha.)-" "coprostane" "5alpha-cholestane" "alpha-cholestane" "5" "a-cholestane" "5-alpha-cholestane" "(5alpha)-cholestane" "cholestane (van)" "cholestane, (5.beta.)-" ".alpha.-cholestane" "cholestane (van8c" );
gibbsFormation
{
    dHf_298   -381310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     939.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=319970.0
    phase     gas;
}
