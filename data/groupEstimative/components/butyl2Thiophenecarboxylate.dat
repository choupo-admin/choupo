/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-thiophenecarboxylate  (C9H12O2S, CAS 56053-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2Thiophenecarboxylate;
formula     C9H12O2S;
CAS         56053-84-0;
InChIKey    VUSZPSYSKPXZQL-UHFFFAOYSA-N;
MW          184.253;      // g/mol [origin=calculated method=formula-sum]
Tc          750.51;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.5759;      // -   [origin=predictive method=lee-kesler]
Tb          534.82;      // K   [origin=predictive method=joback]
HvapTb      50659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.373 0.80513 -0.00048022 9.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group COO; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COO; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl thiophene-2-carboxylate" "butyl 2-thenoate" "butyl2-thiophenecarboxylate" "2-thiophenecarboxylicacid, butyl ester" "2-thiophenecarboxylic acid, butyl ester" );
gibbsFormation
{
    dHf_298   -316200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-151060.0
    phase     gas;
}
