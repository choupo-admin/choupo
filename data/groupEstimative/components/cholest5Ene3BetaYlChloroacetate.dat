/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholest-5-ene-3-beta-yl chloroacetate  (C29H47ClO2, CAS 3464-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholest5Ene3BetaYlChloroacetate;
formula     C29H47ClO2;
CAS         3464-50-4;
InChIKey    XUXXPLDKUZSGKH-OHPSOFBHSA-N;
MW          463.143;      // g/mol [origin=calculated method=formula-sum]
Tc          1228.41;      // K   [origin=predictive method=joback]
Pc          8.852;      // bar [origin=predictive method=joback]
omega       0.7877;      // -   [origin=predictive method=lee-kesler]
Tb          996.81;      // K   [origin=predictive method=joback]
HvapTb      89401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-275.196 3.6671 -0.00295404 1.0232e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] 2-chloranylethanoate" "(1s,2r,5s,10s,11s,14r,15r)-2,15-dimethyl-14-[(2r)-6-methylheptan-2-yl]tetracyclo[8.7.0.0^{2,7}.0^{11,15}]heptadec-7-en-5-yl 2-chloroacetate" "(1s,2r,5s,10s,11s,14r,15r)-2,15-dimethyl-14-[(2r)-6-methylheptan-2-yl]tetracyclo[8.7.0.02,7.011,15]heptadec-7-en-5-yl 2-chloroacetate" "[(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] 2-chloroacetate" );
standardThermochemistry
{
    dHf_298   -709300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1058.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34840.0
}
