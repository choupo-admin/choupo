/*--------------------------------*- Choupo -*-----------------------*\
  Component: silacycloprop-2-ene, 1,1-dimethyl-  (C4H8Si, CAS 67617-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H8Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silacycloprop2Ene11Dimethyl;
formula     C4H8Si;
CAS         67617-01-0;
InChIKey    VGDGNEUJZVXKBA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          84.193;      // g/mol [origin=calculated method=formula-sum]
Tc          478.07;      // K   [origin=predictive method=joback]
Pc          41.731;      // bar [origin=predictive method=joback]
omega       0.1454;      // -   [origin=predictive method=lee-kesler]
Tb          298.82;      // K   [origin=predictive method=joback]
HvapTb      25134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.21 0.30864 -8.828e-05 -1.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethylsilirene" "agn-pc-00gqe9" );
gibbsFormation
{
    dHf_298   -80430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11440.0
    phase     gas;
}
