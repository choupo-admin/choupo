/*--------------------------------*- Choupo -*-----------------------*\
  Component: pent-2-enamide  (C5H9NO, CAS 15856-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pent2Enamide;
formula     C5H9NO;
CAS         15856-96-9;
InChIKey    MZDYAVCNKNXCIS-UHFFFAOYSA-N;
MW          99.133;      // g/mol [origin=calculated method=formula-sum]
Tc          647.86;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       0.5189;      // -   [origin=predictive method=lee-kesler]
Tb          444.56;      // K   [origin=predictive method=joback]
HvapTb      44069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.989 0.53272 -0.0003567 9.766e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentenamide" "2-pentenamide, (2e)-" );
standardThermochemistry
{
    dHf_298   -108100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8970.0
}
