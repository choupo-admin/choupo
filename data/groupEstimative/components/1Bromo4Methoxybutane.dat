/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-methoxybutane  (C5H11BrO, CAS 4457-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Methoxybutane;
formula     C5H11BrO;
CAS         4457-67-4;
InChIKey    ALOQTNHQNMYBDE-UHFFFAOYSA-N;
MW          167.046;      // g/mol [origin=calculated method=formula-sum]
Tc          587.49;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.4514;      // -   [origin=predictive method=lee-kesler]
Tb          402.58;      // K   [origin=predictive method=joback]
HvapTb      35569.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.034 0.45382 -0.0002086 2.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-methoxy-butane" "ether, 4-bromobutyl methyl" "1-methoxy-4-bromobutane" "butane, 1-bromo-4-methoxy-" "u269" "ether,4-bromobutyl methyl (6ci,7ci,8ci);1-bromo-4-methoxybutane;1-methoxy-4-bromobutane;4-bromobutyl methyl ether;4-methoxybutyl bromide;methyl 4-bromobutyl ether;w-bromobutyl methyl ether;" );
gibbsFormation
{
    dHf_298   -252420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99460.0
    phase     gas;
}
