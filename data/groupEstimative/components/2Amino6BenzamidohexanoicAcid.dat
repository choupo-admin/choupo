/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-6-benzamidohexanoic acid  (C13H18N2O3, CAS 5107-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino6BenzamidohexanoicAcid;
formula     C13H18N2O3;
CAS         5107-18-6;
InChIKey    KODLJWKGAKBGOB-UHFFFAOYSA-N;
MW          250.298;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.33;      // K   [origin=predictive method=joback]
Pc          27.556;      // bar [origin=predictive method=joback]
omega       1.4002;      // -   [origin=predictive method=lee-kesler]
Tb          845.36;      // K   [origin=predictive method=joback]
HvapTb      87407.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.276 1.3267 -0.0008637 2.0896e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-6-benzamido-hexanoic acid" "2-amino-6-(benzoylamino)hexanoic acid" "n~6~-(phenylcarbonyl)lysine" "2-amino-6-(phenylcarbonylamino)hexanoic acid" "n-l-benzoyl lysine" "n6-benzoyl-d-lysine" "nepsilon-benzoyllysine" "2-amino-6-benzamido-hexanoic acid" "2-amino-6-(phenylformamido)hexanoic acid" "n6-benzoyllysine;2-amino-6-(benzoylamino)hexanoic acid;2-amino-6-benzamidohexanoic acid;n6-(phenylcarbonyl)lysine;nepsilon-benzoyllysine;n6-benzoyl-dl-lysine;" );
standardThermochemistry
{
    dHf_298   -455990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148440.0
}
