/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, decylmethyl-, branched and linear  (C17H28, CAS 72162-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneDecylmethylBranchedAndLinear;
formula     C17H28;
CAS         72162-10-8;
InChIKey    AFCQSOSAIBQVOU-CVEARBPZSA-N;
MW          232.411;      // g/mol [origin=calculated method=formula-sum]
Tc          808.55;      // K   [origin=predictive method=joback]
Pc          15.962;      // bar [origin=predictive method=joback]
omega       0.6504;      // -   [origin=predictive method=lee-kesler]
Tb          614.36;      // K   [origin=predictive method=joback]
HvapTb      54936.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.834 1.55176 -0.0009386 2.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2r,5s)-5-ethyl-2-methyl-octyl]benzene" "[(2r,5s)-5-ethyl-2-methyloctyl]benzene" );
standardThermochemistry
{
    dHf_298   -168240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199790.0
}
