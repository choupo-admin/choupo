/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxy-1,1,2,2,2-pentafluoroethane  (C4H5F5O, CAS 22052-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxy11222Pentafluoroethane;
formula     C4H5F5O;
CAS         22052-81-9;
InChIKey    CRJVPUWOURIOCW-UHFFFAOYSA-N;
MW          164.073;      // g/mol [origin=calculated method=formula-sum]
Tc          443.32;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.3720;      // -   [origin=predictive method=lee-kesler]
Tb          303.43;      // K   [origin=predictive method=joback]
HvapTb      20231.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.261 0.63122 -0.0005084 1.534e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2O; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 2; } { group F; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-1,1,2,2,2-pentakis(fluoranyl)ethane" "ethyl pentafluoroethyl ether" "pentafluoroethyl ethyl ether" );
gibbsFormation
{
    dHf_298   -1256160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1090570.0
    phase     gas;
}
