/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetoxybenzoic acid  (C9H8O4, CAS 2345-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4AcetoxybenzoicAcid;
formula     C9H8O4;
CAS         2345-34-8;
InChIKey    GDBUZIKSJGRBJP-UHFFFAOYSA-N;
MW          180.159;      // g/mol [origin=calculated method=formula-sum]
Tc          867.83;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.9010;      // -   [origin=predictive method=lee-kesler]
Tb          640.91;      // K   [origin=predictive method=joback]
HvapTb      63137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.11 0.71642 -0.00040796 6.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-acetyloxybenzoic acid" "benzoic acid, 4-(acetyloxy)-" "p-acetoxybenzoic acid" "4-carboxyphenyl acetate" "p-hydroxybenzoic acid acetate" "p-acetyloxybenzoic acid" "p-carboxyphenyl acetate" "benzoic acid, p-hydroxy-, acetate" "benzoic acid, acetate" "4-acetoxy benzoic acid" "4-acetoxy-benzoic acid" "4-(acetyloxy)benzoic acid" );
gibbsFormation
{
    dHf_298   -671580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-526600.0
    phase     gas;
}
