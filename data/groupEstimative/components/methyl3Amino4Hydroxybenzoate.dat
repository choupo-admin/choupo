/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-amino-4-hydroxybenzoate  (C8H9NO3, CAS 536-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Amino4Hydroxybenzoate;
formula     C8H9NO3;
CAS         536-25-4;
InChIKey    VNQABZCSYCTZMS-UHFFFAOYSA-N;
MW          167.164;      // g/mol [origin=calculated method=formula-sum]
Tc          864.08;      // K   [origin=predictive method=joback]
Pc          46.977;      // bar [origin=predictive method=joback]
omega       0.8917;      // -   [origin=predictive method=lee-kesler]
Tb          625.67;      // K   [origin=predictive method=joback]
HvapTb      67402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.01 0.78712 -0.00058072 1.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-azanyl-4-oxidanyl-benzoate" "orthoform" "orthocaine" "aminobenz" "orthoderm" "3-amino-4-hydroxybenzoic acid methyl ester" "benzoic acid, 3-amino-4-hydroxy-, methyl ester" "methyl m-amino-p-hydroxybenzoate" "methyl 4-hydroxy-3-aminobenzoate" "methyl 3-amino-4-hydroxybenzenecarboxylate" "methyl-3-amino-4-hydroxybenzoate" "2-amino-4-(methoxycarbonyl)phenol" );
gibbsFormation
{
    dHf_298   -444190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279280.0
    phase     gas;
}
