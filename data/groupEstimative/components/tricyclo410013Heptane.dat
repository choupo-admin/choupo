/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.1.0.01,3]heptane  (C7H10, CAS 174-73-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo410013Heptane;
formula     C7H10;
CAS         174-73-2;
InChIKey    JEATYLXCUMDKCF-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          575.81;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       0.2668;      // -   [origin=predictive method=lee-kesler]
Tb          371.68;      // K   [origin=predictive method=joback]
HvapTb      29420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-193.95 1.4326 -0.001643 7.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(4.1.0.01,3)heptane" );
standardThermochemistry
{
    dHf_298   58150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     187.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209020.0
}
