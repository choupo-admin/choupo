/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-[(1e)-1,2-diethyl-1,2-ethenediyl]bisphenol  (C24H28O4, CAS 130-80-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        441e12Diethyl12EthenediylBisphenol;
formula     C24H28O4;
CAS         130-80-3;
InChIKey    VZMLEMYJUIIHNF-UHFFFAOYSA-N;
MW          380.484;      // g/mol [origin=calculated method=formula-sum]
Tc          1158.09;      // K   [origin=predictive method=joback]
Pc          12.593;      // bar [origin=predictive method=joback]
omega       1.0054;      // -   [origin=predictive method=lee-kesler]
Tb          932.40;      // K   [origin=predictive method=joback]
HvapTb      89826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.886 1.91728 -0.00110932 2.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-propanoyloxyphenyl)hex-3-en-3-yl]phenyl] propanoate" "phenol,4,4'-[(1e)-1,2-diethyl-1,2-ethenediyl]bis-, 1,1'-propanoate" );
gibbsFormation
{
    dHf_298   -625490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     953.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200860.0
    phase     gas;
}
