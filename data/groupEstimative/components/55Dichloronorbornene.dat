/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dichloronorbornene  (C7H8Cl2, CAS 4634-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dichloronorbornene;
formula     C7H8Cl2;
CAS         4634-77-9;
InChIKey    LZAIJFHJQZYVLF-UHFFFAOYSA-N;
MW          163.041;      // g/mol [origin=calculated method=formula-sum]
Tc          677.84;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.2935;      // -   [origin=predictive method=lee-kesler]
Tb          447.10;      // K   [origin=predictive method=joback]
HvapTb      38776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.57 1.184 -0.00125628 5.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-bis(chloranyl)bicyclo[2.2.1]hept-2-ene" "5,5-dichlorobicyclo(2.2.1)hept-2-ene" "5,5-dichlorobicyclo[2.2.1]hept-2-ene" "bicyclo(2.2.1)hept-2-ene, 5,5-dichloro-" "bicyclo[2.2.1]hept-2-ene, 5,5-dichloro-" "agn-pc-00kjd5" "(1r,4r)-5,5-dichlorobicyclo[2.2.1]hept-2-ene" );
standardThermochemistry
{
    dHf_298   -27170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110360.0
}
