/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-mercaptopropionic acid  (C3H6O2S, CAS 107-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MercaptopropionicAcid;
formula     C3H6O2S;
CAS         107-96-0;
InChIKey    DKIDEFUBRARXTE-UHFFFAOYSA-N;
MW          106.139;      // g/mol [origin=calculated method=formula-sum]
Tc          695.37;      // K   [origin=predictive method=joback]
Pc          54.627;      // bar [origin=predictive method=joback]
omega       0.6091;      // -   [origin=predictive method=lee-kesler]
Tb          476.61;      // K   [origin=predictive method=joback]
HvapTb      46173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.652 0.3669 -0.0002344 5.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group COOH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group COOH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-sulfanylpropanoic acid" "3-mercaptopropanoic acid" "propanoic acid, 3-mercapto-" "mercaptopropionic acid" "3-thiopropionic acid" "beta-mercaptopropionic acid" "3-thiopropanoic acid" "beta-thiopropionic acid" "hydracrylic acid, 3-thio-" "propionic acid, 3-mercapto-" "2-mercaptoethanecarboxylic acid" "3-mercaptopropionate" );
gibbsFormation
{
    dHf_298   -417040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-340140.0
    phase     gas;
}
