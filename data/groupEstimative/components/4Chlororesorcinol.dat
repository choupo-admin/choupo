/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlororesorcinol  (C6H5ClO2, CAS 95-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlororesorcinol;
formula     C6H5ClO2;
CAS         95-88-5;
InChIKey    JQVAPEJNIZULEK-UHFFFAOYSA-N;
MW          144.554;      // g/mol [origin=calculated method=formula-sum]
Tc          815.16;      // K   [origin=predictive method=joback]
Pc          69.214;      // bar [origin=predictive method=joback]
omega       0.7409;      // -   [origin=predictive method=lee-kesler]
Tb          562.23;      // K   [origin=predictive method=joback]
HvapTb      61639.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.42 0.8109 -0.00086692 3.609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACOH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbenzene-1,3-diol" "resorcinol, 4-chloro-" "1,3-benzenediol, 4-chloro-" "4-chlorobenzene-1,3-diol" "p-chlororesorcinol" "4-chlororesorcin" "4-chloro-1,3-benzenediol" "6-chlororesorcinol" "1,3-dihydroxy-4-chlorobenzene" "4-chloro-1,3-dihydroxybenzene" "2,4-dihydroxychlorobenzene" "agn-pc-00jg6u" );
gibbsFormation
{
    dHf_298   -301000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209120.0
    phase     gas;
}
