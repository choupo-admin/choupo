/*--------------------------------*- Choupo -*-----------------------*\
  Component: himbacine  (C22H35NO2, CAS 6879-74-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        himbacine;
formula     C22H35NO2;
CAS         6879-74-9;
InChIKey    FMPNFDSPHNUFOS-DEPSAMCGSA-N;
MW          345.527;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.13;      // K   [origin=predictive method=joback]
Pc          12.874;      // bar [origin=predictive method=joback]
omega       0.7966;      // -   [origin=predictive method=lee-kesler]
Tb          803.14;      // K   [origin=predictive method=joback]
HvapTb      73078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-214.27 2.64216 -0.0017484 4.431e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 8; } { group CH=CH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 8; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,3ar,4r,4as,8ar,9as)-4-[2-[(2r,6s)-1,6-dimethylpiperidin-2-yl]ethenyl]-3-methyl-3a,4,4a,5,6,7,8,8a,9,9a-decahydro-3h-benzo[f][2]benzofuran-1-one" );
gibbsFormation
{
    dHf_298   -444740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178750.0
    phase     gas;
}
