/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(10-methylundecoxycarbonyl)benzoic acid  (C20H30O4, CAS 68515-55-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        210MethylundecoxycarbonylBenzoicAcid;
formula     C20H30O4;
CAS         68515-55-9;
InChIKey    WMPOQIAJNPLCFA-UHFFFAOYSA-N;
MW          334.456;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.69;      // K   [origin=predictive method=joback]
Pc          13.516;      // bar [origin=predictive method=joback]
omega       1.1443;      // -   [origin=predictive method=lee-kesler]
Tb          892.15;      // K   [origin=predictive method=joback]
HvapTb      87235.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.571 1.76734 -0.00100956 1.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-benzenedicarboxylic acid, mono-c11-14-branched alkyl esters, c13-rich" "2-{[(10-methylundecyl)oxy]carbonyl}benzoic acid" );
gibbsFormation
{
    dHf_298   -903900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     917.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-436420.0
    phase     gas;
}
