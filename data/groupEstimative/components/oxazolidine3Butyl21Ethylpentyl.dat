/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxazolidine, 3-butyl-2-(1-ethylpentyl)-  (C14H29NO, CAS 165101-57-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxazolidine3Butyl21Ethylpentyl;
formula     C14H29NO;
CAS         165101-57-5;
InChIKey    CYMHAQCMKNVHPA-UHFFFAOYSA-N;
MW          227.392;      // g/mol [origin=calculated method=formula-sum]
Tc          747.18;      // K   [origin=predictive method=joback]
Pc          17.217;      // bar [origin=predictive method=joback]
omega       0.7266;      // -   [origin=predictive method=lee-kesler]
Tb          569.88;      // K   [origin=predictive method=joback]
HvapTb      53008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.253 1.60196 -0.0010135 2.53e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butyl-2-heptan-3-yl-1,3-oxazolidine" "3-butyl-2-(1-ethylpentyl)oxazolidine" );
gibbsFormation
{
    dHf_298   -335400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137870.0
    phase     gas;
}
