/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethyl-3-hydroxy-4-methyl-2(5h)-furanone  (C7H10O3, CAS 698-10-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Ethyl3Hydroxy4Methyl25hFuranone;
formula     C7H10O3;
CAS         698-10-2;
InChIKey    IUFQZPBIRYFPFD-UHFFFAOYSA-N;
MW          142.154;      // g/mol [origin=calculated method=formula-sum]
Tc          708.34;      // K   [origin=predictive method=joback]
Pc          36.421;      // bar [origin=predictive method=joback]
omega       0.9556;      // -   [origin=predictive method=lee-kesler]
Tb          526.02;      // K   [origin=predictive method=joback]
HvapTb      56791.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.361 0.62394 -0.0003662 7.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-3-methyl-4-oxidanyl-2h-furan-5-one" "2(5h)-furanone, 5-ethyl-3-hydroxy-4-methyl-" "5-ethyl-3-hydroxy-4-methylfuran-2(5h)-one" "4-methyl-5-ethyl-3-hydroxyfuranone" "5-ethyl-3-hydroxy-4-methyl-2(5h)furanone" "2-hydroxy-3-methyl-gamma-2-hexenolactone" "2(5h)-furanone, 5-ethyl-3-hyroxy-4-methyl-" "2,4-dihydroxy-3-methyl-2-hexenoic acid gamma-lactone" "2-ethyl-3-methyl-4-hydroxydihydro-(2,5)-furan-5-one" "2-hexenoic acid, 2,4-dihydroxy-3-methyl-, gamma-lactone" "maple furanone" "ethyl fenugreek lactone" );
gibbsFormation
{
    dHf_298   -549680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367680.0
    phase     gas;
}
