/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4:5,8:9,10-trimethanoanthracene, 1,2,3,4,4a,5,8,8a,9,9a,10,10a-dodecahydro-(1alpha,4alpha,4abeta,5beta,8beta,8abeta,9alpha,9abeta,10alpha,10abeta)-  (C17H22, CAS 87424-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458910Trimethanoanthracene12344a588a99a1010aDodecahydro1alp;
formula     C17H22;
CAS         87424-91-7;
InChIKey    FUCGLOJSPSEIKX-UHFFFAOYSA-N;
MW          226.363;      // g/mol [origin=calculated method=formula-sum]
Tc          828.70;      // K   [origin=predictive method=joback]
Pc          20.831;      // bar [origin=predictive method=joback]
omega       0.5358;      // -   [origin=predictive method=lee-kesler]
Tb          605.21;      // K   [origin=predictive method=joback]
HvapTb      51798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-277.36 2.3718 -0.00203428 7.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 10; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 10; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4:5,8:9,10-trimethanoanthracene, 1,2,3,4,4a,5,8,8a,9,9a,10,10a-dodecahydro-(1.alpha.,4.alpha.,4a.alpha.,5.beta.,8.beta.8a.alpha.,9.beta,9a.alpha.,10.beta.,10a.alpha.)-" "1,4:5,8:9,10-trimethanoanthracene, 1,2,3,4,4a,5,8,8a,9,9a,10,10a-dodecahydro-(1.alpha.,4.alpha.,4a.beta.,5.beta.,8.beta.,8a.beta.,9.alpha.,9a.beta.,10.alpha.,10a.beta.)-" "1,4:5,8:9,10-trimethanoanthracene, 1,2,3,4,4a,5,8,8a,9,9a,10,10a-dodecahydro-(1alpha,4alpha,4aalpha,5alpha,8alpha,8aalpha,9beta,9aalpha,10beta,10aalpha)-" "1,4:5,8:9,10-trimethanoanthracene, 1,2,3,4,4a,5,8,8a,9,9a,10,10a-dodecahydro-(1alpha,4alpha,4aalpha,5beta,8beta,8aalpha,9beta,9aalpha,10beta,10aalpha)-" );
gibbsFormation
{
    dHf_298   25170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     49.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=467980.0
    phase     gas;
}
