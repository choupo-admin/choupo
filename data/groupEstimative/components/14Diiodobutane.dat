/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diiodobutane  (C4H8I2, CAS 628-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diiodobutane;
formula     C4H8I2;
CAS         628-21-7;
InChIKey    ROUYUBHVBIKMQO-UHFFFAOYSA-N;
MW          309.908;      // g/mol [origin=calculated method=formula-sum]
Tc          721.02;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.3020;      // -   [origin=predictive method=lee-kesler]
Tb          477.40;      // K   [origin=predictive method=joback]
HvapTb      43244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.634 0.4618 -0.0003566 1.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(iodanyl)butane" "tetramethylene iodide" "tetramethylene diiodide" "butane, 1,4-diiodo-" "1,4-diodobutane" "butane,4-diiodo-" "1,4-diiodo-butane" );
standardThermochemistry
{
    dHf_298   27850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99040.0
}
