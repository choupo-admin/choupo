/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzylbiphenyl  (C19H16, CAS 613-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzylbiphenyl;
formula     C19H16;
CAS         613-42-3;
InChIKey    AGPLQTQFIZBOLI-UHFFFAOYSA-N;
MW          244.337;      // g/mol [origin=calculated method=formula-sum]
Tc          983.01;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.6105;      // -   [origin=predictive method=lee-kesler]
Tb          719.34;      // K   [origin=predictive method=joback]
HvapTb      65378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.799 1.5126 -0.00103636 2.665e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 3; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-4-(phenylmethyl)benzene" "benzylbiphenyl" "1,1'-biphenyl, 4-(phenylmethyl)-" "4-benzyl-biphenyl" "4-phenyldiphenylmethane" "1-benzyl-4-phenylbenzene" "1-phenyl-4-benzylbenzene" "1, 4-(phenylmethyl)-" "agplqtqfizboli-uhfffaoysa-" "4-(phenylmethyl)-1,1'-biphenyl" );
gibbsFormation
{
    dHf_298   262630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=436700.0
    phase     gas;
}
