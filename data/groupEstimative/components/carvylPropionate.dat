/*--------------------------------*- Choupo -*-----------------------*\
  Component: carvyl propionate  (C13H20O2, CAS 97-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carvylPropionate;
formula     C13H20O2;
CAS         97-45-0;
InChIKey    DFVXNZOMAOGTBL-UHFFFAOYSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          775.02;      // K   [origin=predictive method=joback]
Pc          20.272;      // bar [origin=predictive method=joback]
omega       0.5744;      // -   [origin=predictive method=lee-kesler]
Tb          570.84;      // K   [origin=predictive method=joback]
HvapTb      52423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.789 1.14406 -0.00055984 6.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-5-prop-1-en-2-yl-cyclohex-2-en-1-yl) propanoate" "(-)-carvyl propionate" "carveol propionate" "l-carvyl propionate" "p-mentha-6,8-dien-2-ol, propionate" "2-cyclohexen-1-ol, 2-methyl-5-(1-methylethenyl)-, propanoate" "p-mentha-6,8-dien-2-yl propionate" "p-mentha-1(6),8-dien-2-yl propionate" "l-p-mentha-6,8(9)-dien-2-yl propionate" "2-methyl-5-(1-methylethenyl)-2-cyclohexenyl propanoate" "2-cyclohexen-1-ol, 2-methyl-5-(1-methylethenyl)-, 1-propanoate" "2-cyclohexen-1-ol, 2-methyl-5-(1-methylethenyl)-, propionate" );
standardThermochemistry
{
    dHf_298   -433000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135430.0
}
