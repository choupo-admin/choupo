/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-nonen-3-yne  (C10H16, CAS 70058-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Nonen3Yne;
formula     C10H16;
CAS         70058-00-3;
InChIKey    GSFPEKGMYODGNK-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          626.10;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.3580;      // -   [origin=predictive method=lee-kesler]
Tb          433.96;      // K   [origin=predictive method=joback]
HvapTb      39416.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.674 0.78394 -0.00045326 1.0598e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2=C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylnon-1-en-3-yne" "2-methyl-1-nonene-3-yne" );
standardThermochemistry
{
    dHf_298   138210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=315410.0
}
