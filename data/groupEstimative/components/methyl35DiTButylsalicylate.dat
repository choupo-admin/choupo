/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,5-di-t-butylsalicylate  (C16H24O3, CAS 15018-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl35DiTButylsalicylate;
formula     C16H24O3;
CAS         15018-03-8;
InChIKey    QSGONIQEKLJPGV-UHFFFAOYSA-N;
MW          264.365;      // g/mol [origin=calculated method=formula-sum]
Tc          958.74;      // K   [origin=predictive method=joback]
Pc          19.561;      // bar [origin=predictive method=joback]
omega       0.8471;      // -   [origin=predictive method=lee-kesler]
Tb          734.70;      // K   [origin=predictive method=joback]
HvapTb      72639.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.42 1.67744 -0.00124908 3.747e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,5-ditert-butyl-2-oxidanyl-benzoate" "methyl 3,5-di-tert-butylsalicylate" "methyl 3,5-ditert-butyl-2-hydroxybenzoate" "methyl 3,5-bis(tert-butyl)-2-hydroxybenzoate" "benzoic acid,3,5-bis(1,1-dimethylethyl)-2-hydroxy-, methyl ester" "salicylicacid, 3,5-di-tert-butyl-, methyl ester (8ci); methyl3,5-di-tert-butyl-2-hydroxybenzoate; methyl 3,5-di-tert-butylsalicylate" );
gibbsFormation
{
    dHf_298   -672070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-282320.0
    phase     gas;
}
