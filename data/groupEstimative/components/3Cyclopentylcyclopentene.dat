/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclopentylcyclopentene  (C10H16, CAS 2690-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclopentylcyclopentene;
formula     C10H16;
CAS         2690-17-7;
InChIKey    UWHATVBKIRLRTB-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          682.63;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.2984;      // -   [origin=predictive method=lee-kesler]
Tb          458.12;      // K   [origin=predictive method=joback]
HvapTb      38660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.39 1.1612 -0.00076228 1.91e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclopentyl-1-cyclopentene" "cyclopentene,3-cyclopentyl-" );
gibbsFormation
{
    dHf_298   -70990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136380.0
    phase     gas;
}
