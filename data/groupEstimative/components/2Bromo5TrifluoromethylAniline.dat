/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-5-(trifluoromethyl)aniline  (C7H5BrF3N, CAS 454-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo5TrifluoromethylAniline;
formula     C7H5BrF3N;
CAS         454-79-5;
InChIKey    PZDVFXUBTKPFSG-UHFFFAOYSA-N;
MW          240.022;      // g/mol [origin=calculated method=formula-sum]
Tc          753.48;      // K   [origin=predictive method=joback]
Pc          40.108;      // bar [origin=predictive method=joback]
omega       0.6219;      // -   [origin=predictive method=lee-kesler]
Tb          529.67;      // K   [origin=predictive method=joback]
HvapTb      48105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.3 0.7322 -0.00058992 1.816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-5-(trifluoromethyl)aniline" "3-amino-4-bromobenzotrifluoride" "2-bromo-5-trifluoromethylaniline" "2-amino-4-trifluoromethylbromobenzene" "3-amino-4-bromo(trifluoromethyl)benzene" "2-amino-1-bromo-4-trifluoromethylbenzene" "2-bromo-5-trifluoromethylphenylamine" "2-bromo-5-trifluoromethyl-phenylamine" "2-bromo-5-(trifluoromethyl)benzenamine" "6-bromo-.alpha.,.alpha.,.alpha.-trifluoro-m-toluidine" "2-bromo-5-(trifluoromethyl)phenylamine" "zr be exfff" );
gibbsFormation
{
    dHf_298   -511180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399610.0
    phase     gas;
}
