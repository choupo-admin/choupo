/*--------------------------------*- Choupo -*-----------------------*\
  Component: .alpha.-myrcene  (C10H16, CAS 1686-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaMyrcene;
formula     C10H16;
CAS         1686-30-2;
InChIKey    VYBREYKSZAROCT-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          597.27;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       0.3754;      // -   [origin=predictive method=lee-kesler]
Tb          418.20;      // K   [origin=predictive method=joback]
HvapTb      36004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.557 0.89362 -0.0005935 1.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-6-methylidene-octa-1,7-diene" "1,7-octadiene, 2-methyl-6-methylene-" "2-methyl-6-methylene-1,7-octadiene" "2-methyl-6-methylideneocta-1,7-diene" );
standardThermochemistry
{
    dHf_298   106980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=279740.0
}
