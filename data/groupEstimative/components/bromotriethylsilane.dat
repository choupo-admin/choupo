/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromotriethylsilane  (C6H15BrSi, CAS 1112-48-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H15BrSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bromotriethylsilane;
formula     C6H15BrSi;
CAS         1112-48-7;
InChIKey    UCKORWKZRPKRQE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          195.175;      // g/mol [origin=calculated method=formula-sum]
Tc          594.98;      // K   [origin=predictive method=joback]
Pc          29.377;      // bar [origin=predictive method=joback]
omega       0.3251;      // -   [origin=predictive method=lee-kesler]
Tb          404.44;      // K   [origin=predictive method=joback]
HvapTb      35679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.443 0.40586 4.08e-05 -1.229e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group Br; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanyl(triethyl)silane" "triethylbromosilane" "silane, bromotriethyl-" "bromo(triethyl)silane" "bromotriethyl silane" );
gibbsFormation
{
    dHf_298   -252460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90800.0
    phase     gas;
}
