/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-tert-leucinol  (C6H15NO, CAS 112245-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sTertLeucinol;
formula     C6H15NO;
CAS         112245-13-3;
InChIKey    JBULSURVMXPBNA-RXMQYKEDSA-N;
MW          117.192;      // g/mol [origin=calculated method=formula-sum]
Tc          684.97;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.8162;      // -   [origin=predictive method=lee-kesler]
Tb          497.92;      // K   [origin=predictive method=joback]
HvapTb      54586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.939 0.80146 -0.0005514 1.524e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3,3-dimethyl-butan-1-ol" "l-tert-leucinol" "(s)-2-amino-3,3-dimethylbutanol" "(2s)-2-amino-3,3-dimethylbutan-1-ol" "d-tert-leucinol" "(s)-2-amino-3,3-dimethyl-1-butanol" "2s-tert-leucinol" "(l)-tert-leucinol" "(2s)-2-amino-3,3-dimethyl-butan-1-ol" "(2r)-2-amino-3,3-dimethyl-1-hydroxybutane" "1-butanol,2-amino-3,3-dimethyl-, (s)-;(2s)-2-amino-3,3-dimethyl-1-butanol;(s)-(+)-2-amino-3,3-dimethylbutanol;(s)-(+)-tert-leucinol;(s)-2-amino-3,3-dimethyl-1-butanol;(s)-2-amino-3,3-dimethylbutanol;l-tert-leucinol;" );
gibbsFormation
{
    dHf_298   -299640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70330.0
    phase     gas;
}
