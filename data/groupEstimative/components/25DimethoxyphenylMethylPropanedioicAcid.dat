/*--------------------------------*- Choupo -*-----------------------*\
  Component: ((2,5-dimethoxyphenyl)methyl)propanedioic acid  (C12H14O6, CAS 72018-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DimethoxyphenylMethylPropanedioicAcid;
formula     C12H14O6;
CAS         72018-08-7;
InChIKey    HSUUQNZJIBIZOS-UHFFFAOYSA-N;
MW          254.238;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.40;      // K   [origin=predictive method=joback]
Pc          27.212;      // bar [origin=predictive method=joback]
omega       1.4143;      // -   [origin=predictive method=lee-kesler]
Tb          846.22;      // K   [origin=predictive method=joback]
HvapTb      84666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.191 0.92704 -0.00045252 5.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2,5-dimethoxyphenyl)methyl]propanedioic acid" "propanedioic acid, ((2,5-dimethoxyphenyl)methyl)-" "propanedioic acid, [(2,5-dimethoxyphenyl)methyl]-" "propanedioic acid, 2-((2,5-dimethoxyphenyl)methyl)-" "propanedioic acid, 2-[(2,5-dimethoxyphenyl)methyl]-" );
standardThermochemistry
{
    dHf_298   -1047680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-756950.0
}
