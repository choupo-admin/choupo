/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-4-methylenecyclohexane  (C11H20, CAS 13294-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl4Methylenecyclohexane;
formula     C11H20;
CAS         13294-73-0;
InChIKey    IHNUKBZLLPOGDS-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          676.19;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       0.3148;      // -   [origin=predictive method=lee-kesler]
Tb          466.76;      // K   [origin=predictive method=joback]
HvapTb      39372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.9 1.17926 -0.000735 1.721e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-methylidene-cyclohexane" "1-tert-butyl-4-methylidenecyclohexane" "cyclohexane, 1-(1,1-dimethylethyl)-4-methylene-" "1-methylidene-4-tert-butyl-cyclohexane" "cyclohexane,1-(1,1-dimethylethyl)-4-methylene" );
gibbsFormation
{
    dHf_298   -140560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122110.0
    phase     gas;
}
