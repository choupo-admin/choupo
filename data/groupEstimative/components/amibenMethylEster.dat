/*--------------------------------*- Choupo -*-----------------------*\
  Component: amiben, methyl ester  (C8H7Cl2NO2, CAS 7286-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amibenMethylEster;
formula     C8H7Cl2NO2;
CAS         7286-84-2;
InChIKey    DTSSCQVCVYZGSI-UHFFFAOYSA-N;
MW          220.049;      // g/mol [origin=calculated method=formula-sum]
Tc          867.63;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.7496;      // -   [origin=predictive method=lee-kesler]
Tb          629.87;      // K   [origin=predictive method=joback]
HvapTb      64482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.29 0.52712 -0.00023108 6.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-azanyl-2,5-bis(chloranyl)benzoate" "chloramben-methyl" "chloramben methyl" "methyl chloramben" "methyl 3-amino-2,5-dichlorobenzoate" "amchem 65-81-b" "chloramben, methyl ester" "benzoic acid, 3-amino-2,5-dichloro-, methyl ester" "chloramben methyl ester" "chloramben-methyl [iso]" "3-amino-2,5-dichlorobenzoic acid methyl ester" "2,5-dichloro-3-aminobenzoic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -321300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167780.0
}
