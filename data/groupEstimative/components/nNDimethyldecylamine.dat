/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyldecylamine  (C12H27N, CAS 1120-24-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyldecylamine;
formula     C12H27N;
CAS         1120-24-7;
InChIKey    YWWNNLPSZSEZNZ-UHFFFAOYSA-N;
MW          185.355;      // g/mol [origin=calculated method=formula-sum]
Tc          646.48;      // K   [origin=predictive method=joback]
Pc          17.773;      // bar [origin=predictive method=joback]
omega       0.6469;      // -   [origin=predictive method=lee-kesler]
Tb          486.60;      // K   [origin=predictive method=joback]
HvapTb      44349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.711 1.26776 -0.0007416 1.69e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyldecan-1-amine" "decyldimethylamine" "dimethyl-n-decylamine" "1-decanamine, n,n-dimethyl-" "1-(dimethylamino)decane" "n,n-dimethyl-n-decylamine" "decylamine, n,n-dimethyl-" "decyl dimethyl amine" "decylamine,n-dimethyl-" "n-decyldimethylamine" "1-decanamine,n-dimethyl-" "1-decanamine,n,n-dimethyl-" );
gibbsFormation
{
    dHf_298   -223480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160940.0
    phase     gas;
}
