/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-isopropenylchlorobenzene  (C9H9Cl, CAS 1712-71-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mIsopropenylchlorobenzene;
formula     C9H9Cl;
CAS         1712-71-6;
InChIKey    KECZPSPBNNGWDJ-UHFFFAOYSA-N;
MW          152.621;      // g/mol [origin=calculated method=formula-sum]
Tc          695.66;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.3477;      // -   [origin=predictive method=lee-kesler]
Tb          471.17;      // K   [origin=predictive method=joback]
HvapTb      42361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.69 0.70712 -0.00047556 1.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-prop-1-en-2-yl-benzene" "1-chloro-3-isopropenylbenzene" "benzene, 1-chloro-3-(1-methylethenyl)-" "1-chloro-3-prop-1-en-2-ylbenzene" "benzene,1-chloro-3-(1-methylethenyl)-" "styrene,m-chloro-a-methyl- (6ci,7ci,8ci);1-chloro-3-isopropenylbenzene; 3-chloro-a-methylstyrene; m-chloro-a-methylstyrene; m-isopropenylchlorobenzene; a-methyl-m-chlorostyrene" );
gibbsFormation
{
    dHf_298   95870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195040.0
    phase     gas;
}
