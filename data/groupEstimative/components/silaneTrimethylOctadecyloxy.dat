/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, trimethyl(octadecyloxy)-  (C21H46OSi, CAS 18748-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C21H46OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTrimethylOctadecyloxy;
formula     C21H46OSi;
CAS         18748-98-6;
InChIKey    GVPDNFYOFKBFEN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          342.683;      // g/mol [origin=calculated method=formula-sum]
Tc          870.02;      // K   [origin=predictive method=joback]
Pc          8.800;      // bar [origin=predictive method=joback]
omega       0.7527;      // -   [origin=predictive method=lee-kesler]
Tb          703.90;      // K   [origin=predictive method=joback]
HvapTb      65044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.117 1.72948 -0.0005928 -3.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 16; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 17; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(octadecoxy)silane" "trimethyl(octadecyloxy)silane" "1-trimethylsilyloxyoctadecane" "silane,trimethyl(octadecyloxy)-" "1-(trimethylsilyloxy)octadecane;1-octadecyl trimethylsilyl ether; silcare 1m71; stearyloxytrimethylsilane;trimethyl(stearyloxy)silane" );
gibbsFormation
{
    dHf_298   -720610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1111.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83820.0
    phase     gas;
}
