/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1'-acetonaphthone  (C12H10O, CAS 941-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acetonaphthone;
formula     C12H10O;
CAS         941-98-0;
InChIKey    QQLIGMASAVJVON-UHFFFAOYSA-N;
MW          170.211;      // g/mol [origin=calculated method=formula-sum]
Tc          817.51;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.5717;      // -   [origin=predictive method=lee-kesler]
Tb          578.67;      // K   [origin=predictive method=joback]
HvapTb      53630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.71 0.97372 -0.00071118 2.0426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-naphthalen-1-ylethanone" "1-acetylnaphthalene" "1-acetonaphthone" "ethanone, 1-(1-naphthalenyl)-" "methyl 1-naphthyl ketone" "1-acetonaphthalene" "1-(1-naphthalenyl)ethanone" "1-naphthyl methyl ketone" "alpha-naphthyl methyl ketone" "alpha-acetonaphthone" "alpha-acetylnaphthalene" "methyl alpha-naphthyl ketone" );
standardThermochemistry
{
    dHf_298   12540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130670.0
}
