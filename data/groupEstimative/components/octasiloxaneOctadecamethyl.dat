/*--------------------------------*- Choupo -*-----------------------*\
  Component: octasiloxane, octadecamethyl-  (C18H54O7Si8, CAS 556-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H54O7Si8 (delta Si+8; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        octasiloxaneOctadecamethyl;
formula     C18H54O7Si8;
CAS         556-69-4;
InChIKey    VWGDPBQTSZDFMX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          607.303;      // g/mol [origin=calculated method=formula-sum]
Tc          969.07;      // K   [origin=predictive method=joback]
Pc          6.173;      // bar [origin=predictive method=joback]
omega       0.4019;      // -   [origin=predictive method=lee-kesler]
Tb          779.58;      // K   [origin=predictive method=joback]
HvapTb      74884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (491.57 -0.37784 0.00314 -1.9182e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 18; } { group Si; count 1; } { group SiO; count 7; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 18; } { group O; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[dimethyl(trimethylsilyloxy)silyl]oxy-[[[[dimethyl(trimethylsilyloxy)silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silane" "octadecamethyloctasiloxane" "octasiloxane, 1,1,1,3,3,5,5,7,7,9,9,11,11,13,13,15,15,15-octadecamethyl-" "[dimethyl(trimethylsilyloxy)silyl]oxy-[[[[dimethyl(trimethylsilyloxy)silyl]oxy-dimethylsilyl]oxy-dimethylsilyl]oxy-dimethylsilyl]oxy-dimethylsilane" );
standardThermochemistry
{
    dHf_298   -2233350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1947.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1472400.0
}
