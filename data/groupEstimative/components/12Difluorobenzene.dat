/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-difluorobenzene  (C6H4F2, CAS 367-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Difluorobenzene;
formula     C6H4F2;
CAS         367-11-3;
InChIKey    GOYDNIKZWGIXJT-UHFFFAOYSA-N;
MW          114.094;      // g/mol [origin=calculated method=formula-sum]
Tc          558.14;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.3094;      // -   [origin=predictive method=lee-kesler]
Tb          367.08;      // K   [origin=predictive method=joback]
HvapTb      30254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.99 0.459 -0.00029956 7.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(fluoranyl)benzene" "o-difluorobenzene" "benzene, 1,2-difluoro-" "benzene, o-difluoro-" "o-difluoro benzene" "ortho-difluorobenzene" "1,2-difluoro-benzene" "benzene, difluoro-" "1,2-difluorbenzol" "1 2-difluorobenzene" "benzene,2-difluoro-" "1,2-difluoro benzene" );
gibbsFormation
{
    dHf_298   -334330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287200.0
    phase     gas;
}
