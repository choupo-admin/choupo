/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-methylenebis[4,6-bis(2-phenylpropan-2-yl)phenol]  (C49H52O2, CAS 71113-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Methylenebis46Bis2Phenylpropan2YlPhenol;
formula     C49H52O2;
CAS         71113-23-0;
InChIKey    BDZGHYNUCXZCMQ-UHFFFAOYSA-N;
MW          672.953;      // g/mol [origin=calculated method=formula-sum]
Tc          2040.21;      // K   [origin=predictive method=joback]
Pc          7.623;      // bar [origin=predictive method=joback]
omega       0.6199;      // -   [origin=predictive method=lee-kesler]
Tb          1649.04;      // K   [origin=predictive method=joback]
HvapTb      161816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-303.619 4.75996 -0.00376076 1.1791e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group C; count 4; } { group ACH; count 24; } { group AC; count 9; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 1; } { group C; count 4; } { group dCH_ring; count 24; } { group dC_ring; count 12; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2-oxidanyl-3,5-bis(2-phenylpropan-2-yl)phenyl]methyl]-4,6-bis(2-phenylpropan-2-yl)phenol" "2,2'-methylenebis[4,6-bis(1-methyl-1-phenylethyl)phenol]" "2,2'-methylenebis(4,6-bis(1-methyl-1-phenylethyl)phenol)" "phenol, 2,2'-methylenebis(4,6-bis(1-methyl-1-phenylethyl)-" "phenol, 2,2'-methylenebis[4,6-bis(1-methyl-1-phenylethyl)-" "phenol,2,2'-methylenebis[4,6-bis(1-methyl-1-phenylethyl)-" "2,2a'a inverted exclamation marka'a -methylenebis[4,6-bis(1-methyl-1-phenylethyl)phenol]" "2-[[2-hydroxy-3,5-bis(2-phenylpropan-2-yl)phenyl]methyl]-4,6-bis(2-phenylpropan-2-yl)phenol" );
standardThermochemistry
{
    dHf_298   -71010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1298.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=699760.0
}
