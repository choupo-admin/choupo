/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-n,n-diisopropylbenzylamine  (C13H20BrN, CAS 98816-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromoNNDiisopropylbenzylamine;
formula     C13H20BrN;
CAS         98816-61-6;
InChIKey    SNGBVBNOXIPZGP-UHFFFAOYSA-N;
MW          270.214;      // g/mol [origin=calculated method=formula-sum]
Tc          823.01;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.6544;      // -   [origin=predictive method=lee-kesler]
Tb          606.42;      // K   [origin=predictive method=joback]
HvapTb      55172.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.399 1.27438 -0.00083796 2.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[(4-bromophenyl)methyl]-n-propan-2-yl-propan-2-amine" "n-(4-bromobenzyl)-n-isopropylpropan-2-amine" "(4-bromobenzyl)-diisopropylamine" "bis(methylethyl)[(4-bromophenyl)methyl]amine" "n-(4-bromobenzyl)-n-isopropyl-2-propanamine" "[(4-bromophenyl)methyl]bis(propan-2-yl))amine" "n-[(4-bromophenyl)methyl]-n-propan-2-ylpropan-2-amine" );
standardThermochemistry
{
    dHf_298   -3290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=281580.0
}
