/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(4-butyrylphenyl)ethane  (C22H26O2, CAS 17302-71-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis4ButyrylphenylEthane;
formula     C22H26O2;
CAS         17302-71-5;
InChIKey    LFSJWEZPAHCXES-UHFFFAOYSA-N;
MW          322.448;      // g/mol [origin=calculated method=formula-sum]
Tc          1097.17;      // K   [origin=predictive method=joback]
Pc          15.117;      // bar [origin=predictive method=joback]
omega       1.0370;      // -   [origin=predictive method=lee-kesler]
Tb          874.02;      // K   [origin=predictive method=joback]
HvapTb      83934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.604 1.76104 -0.00106392 2.3372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-[2-(4-butanoylphenyl)ethyl]phenyl]butan-1-one" );
gibbsFormation
{
    dHf_298   -272450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82080.0
    phase     gas;
}
