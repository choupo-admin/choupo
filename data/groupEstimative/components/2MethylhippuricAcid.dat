/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylhippuric acid  (C10H11NO3, CAS 42013-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylhippuricAcid;
formula     C10H11NO3;
CAS         42013-20-7;
InChIKey    YOEBAVRJHRCKRE-UHFFFAOYSA-N;
MW          193.202;      // g/mol [origin=calculated method=formula-sum]
Tc          935.56;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       1.1160;      // -   [origin=predictive method=lee-kesler]
Tb          709.61;      // K   [origin=predictive method=joback]
HvapTb      71138.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.059 0.91442 -0.00058686 1.3786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-methylphenyl)carbonylamino]ethanoic acid" "o-toluric acid" "n-(2-methylbenzoyl)glycine" "n-(o-toluoyl)glycine" "o-methylhippuric acid" "n-(o-toluoyl)-glycine" "glycine, n-(2-methylbenzoyl)-" "2-methyl hippuric acid" "n-(methylbenzoyl)glycine" "n-(methylbenzoyl)-glycine" "glycine, n-(methylbenzoyl)-" "n-(2-methylbenzoyl)-glycine" );
standardThermochemistry
{
    dHf_298   -434050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-247340.0
}
