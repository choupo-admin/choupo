/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoallyl alcohol  (C3H5BrO, CAS 598-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromoallylAlcohol;
formula     C3H5BrO;
CAS         598-19-6;
InChIKey    MDFFZNIQPLKQSG-UHFFFAOYSA-N;
MW          136.976;      // g/mol [origin=calculated method=formula-sum]
Tc          611.42;      // K   [origin=predictive method=joback]
Pc          59.354;      // bar [origin=predictive method=joback]
omega       0.6978;      // -   [origin=predictive method=lee-kesler]
Tb          423.14;      // K   [origin=predictive method=joback]
HvapTb      44796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.961 0.3409 -0.0002664 8.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylprop-2-en-1-ol" "2-bromoprop-2-en-1-ol" "2-bromo-2-propene-1-ol" "2-bromo-2-propen-1-ol" "2-bromo-2-propylene-1-ol" );
gibbsFormation
{
    dHf_298   -115510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68830.0
    phase     gas;
}
