/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-tridecanone  (C14H28O, CAS 40239-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3Tridecanone;
formula     C14H28O;
CAS         40239-35-8;
InChIKey    WPOGLKZZPSTJRU-UHFFFAOYSA-N;
MW          212.377;      // g/mol [origin=calculated method=formula-sum]
Tc          744.34;      // K   [origin=predictive method=joback]
Pc          16.116;      // bar [origin=predictive method=joback]
omega       0.7637;      // -   [origin=predictive method=lee-kesler]
Tb          573.35;      // K   [origin=predictive method=joback]
HvapTb      53116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.161 1.31176 -0.0007223 1.4586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyltridecan-3-one" "3-tridecanone, 2-methyl-" "agn-pc-02u2lr" );
standardThermochemistry
{
    dHf_298   -450150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64360.0
}
