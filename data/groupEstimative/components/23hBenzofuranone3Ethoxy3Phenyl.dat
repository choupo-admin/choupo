/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-benzofuranone,3-ethoxy-3-phenyl-  (C16H14O3, CAS 62231-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hBenzofuranone3Ethoxy3Phenyl;
formula     C16H14O3;
CAS         62231-08-7;
InChIKey    DOHHPBAKMKBODF-UHFFFAOYSA-N;
MW          254.285;      // g/mol [origin=calculated method=formula-sum]
Tc          940.89;      // K   [origin=predictive method=joback]
Pc          25.151;      // bar [origin=predictive method=joback]
omega       0.7959;      // -   [origin=predictive method=lee-kesler]
Tb          703.10;      // K   [origin=predictive method=joback]
HvapTb      64659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.249 1.65052 -0.00148196 5.505e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxy-3-phenyl-1-benzofuran-2-one" "2(3h)-benzofuranone, 3-ethoxy-3-phenyl-" );
gibbsFormation
{
    dHf_298   -261120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36880.0
    phase     gas;
}
