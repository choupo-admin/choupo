/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-difluorobutane  (C4H8F2, CAS 353-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Difluorobutane;
formula     C4H8F2;
CAS         353-81-1;
InChIKey    IIADOUMJKYSCPM-UHFFFAOYSA-N;
MW          94.104;      // g/mol [origin=calculated method=formula-sum]
Tc          439.60;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.2312;      // -   [origin=predictive method=lee-kesler]
Tb          286.43;      // K   [origin=predictive method=joback]
HvapTb      21568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.039 0.53324 -0.0003984 1.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(fluoranyl)butane" "butane, 2,2-difluoro-" );
gibbsFormation
{
    dHf_298   -526860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     336.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403980.0
    phase     gas;
}
