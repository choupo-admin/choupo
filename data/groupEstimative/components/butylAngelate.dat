/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl angelate  (C9H16O2, CAS 7785-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylAngelate;
formula     C9H16O2;
CAS         7785-64-0;
InChIKey    RBGFLIOXJWFKKX-YVMONPNESA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          649.51;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.5346;      // -   [origin=predictive method=lee-kesler]
Tb          467.78;      // K   [origin=predictive method=joback]
HvapTb      43073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.243 0.82396 -0.0004573 8.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl (z)-2-methylbut-2-enoate" "2-butenoic acid, 2-methyl-, butyl ester, (z)-" "n-butyl tiglate" "n-butyl angelate" "2-butenoic acid, 2-methyl-, butyl ester, (2z)-" "butyl 2-methylcrotonate (z)-" "butyl (2z)-2-methyl-2-butenoate" );
gibbsFormation
{
    dHf_298   -438940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-213800.0
    phase     gas;
}
