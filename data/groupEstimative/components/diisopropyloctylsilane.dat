/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopropyloctylsilane  (C14H31Si, CAS 129536-19-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H31Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diisopropyloctylsilane;
formula     C14H31Si;
CAS         129536-19-2;
InChIKey    WWMMCABWPRGHAH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          227.487;      // g/mol [origin=calculated method=formula-sum]
Tc          687.63;      // K   [origin=predictive method=joback]
Pc          14.546;      // bar [origin=predictive method=joback]
omega       0.5560;      // -   [origin=predictive method=lee-kesler]
Tb          519.74;      // K   [origin=predictive method=joback]
HvapTb      46129.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.207 1.2426 -0.0005368 4.58e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl-di(propan-2-yl)silicon" );
gibbsFormation
{
    dHf_298   -398660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     754.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9740.0
    phase     gas;
}
