/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-allothreonine  (C4H9NO3, CAS 28954-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lAllothreonine;
formula     C4H9NO3;
CAS         28954-12-3;
InChIKey    AYFVYJQAPQTCCC-HRFVKAFMSA-N;
MW          119.12;      // g/mol [origin=calculated method=formula-sum]
Tc          800.41;      // K   [origin=predictive method=joback]
Pc          55.033;      // bar [origin=predictive method=joback]
omega       1.2844;      // -   [origin=predictive method=lee-kesler]
Tb          600.46;      // K   [origin=predictive method=joback]
HvapTb      68206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.27 0.54232 -0.0003466 8.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3s)-2-azanyl-3-oxidanyl-butanoic acid" "l-allo-threonine" "l(+)-allo-threonine" "allo-l-threonine" "(2s,3s)-2-amino-3-hydroxybutanoic acid" "allo-threonine" "dl-allo-threonine" "(2s,3s)-2-amino-3-hydroxybutyric acid" "threonine, allo-" "h-allo-thr-oh" "allo-thr-oh" "l-(+)-allothreonine" );
gibbsFormation
{
    dHf_298   -605160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-436360.0
    phase     gas;
}
