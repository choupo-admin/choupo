/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(n-methylanilino)ethanol  (C9H13NO, CAS 93-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NMethylanilinoEthanol;
formula     C9H13NO;
CAS         93-90-3;
InChIKey    VIIZJXNVVJKISZ-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          729.40;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.8812;      // -   [origin=predictive method=lee-kesler]
Tb          536.82;      // K   [origin=predictive method=joback]
HvapTb      56626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.598 0.93782 -0.00064 1.686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[methyl(phenyl)amino]ethanol" "n-(2-hydroxyethyl)-n-methylaniline" "2-(methylphenylamino)ethanol" "phenylmethylethanolamine" "n-methyl-n-hydroxyethylaniline" "2-(n-methylaniline)ethanol" "ethanol, 2-(methylphenylamino)-" "ethanol, 2-(n-methylanilino)-" "2-(n-methyl-n-phenylamino)ethanol" "n-methyl-n-(2-hydroxyethyl)aniline" "phenylmethyl ethanol amine" "n-hydroxyethyl-n-methylaniline" );
gibbsFormation
{
    dHf_298   -77260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111270.0
    phase     gas;
}
