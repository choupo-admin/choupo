/*--------------------------------*- Choupo -*-----------------------*\
  Component: zoapatanolide a  (C20H26O6, CAS 84886-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zoapatanolideA;
formula     C20H26O6;
CAS         84886-38-4;
InChIKey    BXFQVBKJGJTIAT-CGSFVSGYSA-N;
MW          362.422;      // g/mol [origin=calculated method=formula-sum]
Tc          1212.76;      // K   [origin=predictive method=joback]
Pc          15.500;      // bar [origin=predictive method=joback]
omega       1.3632;      // -   [origin=predictive method=lee-kesler]
Tb          990.30;      // K   [origin=predictive method=joback]
HvapTb      110150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.59 1.70798 -0.00081218 7.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 5; } { group CH2=C; count 1; } { group CH=C; count 3; } { group OH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 5; } { group dCH_ring; count 2; } { group dC_ring; count 3; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3as,6z,10z)-6,10-dimethyl-3-methylidene-5,9-bis(oxidanyl)-2-oxidanylidene-3a,4,5,8,9,11a-hexahydrocyclodeca[b]furan-4-yl] (e)-2-methylbut-2-enoate" "2-butenoic acid, 2-methyl-, 2,3,3a,4,5,8,9,11a-octahydro-5,9-dihydroxy-6,10-dimethyl-3-methylene-2-oxocyclodeca(b)furan-4-yl ester, (3as-(3ar*,4s*(z),5s*,6e,9s*,10z,11as*))-" "[(3as,6z,10z)-5,9-dihydroxy-6,10-dimethyl-3-methylidene-2-oxo-3a,4,5,8,9,11a-hexahydrocyclodeca[b]furan-4-yl] (e)-2-methylbut-2-enoate" );
gibbsFormation
{
    dHf_298   -1057080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     807.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-573580.0
    phase     gas;
}
