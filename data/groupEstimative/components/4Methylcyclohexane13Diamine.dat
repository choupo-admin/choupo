/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylcyclohexane-1,3-diamine  (C7H16N2, CAS 13897-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylcyclohexane13Diamine;
formula     C7H16N2;
CAS         13897-55-7;
InChIKey    QTKDDPSHNLZGRO-UHFFFAOYSA-N;
MW          128.219;      // g/mol [origin=calculated method=formula-sum]
Tc          744.20;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       0.5052;      // -   [origin=predictive method=lee-kesler]
Tb          515.03;      // K   [origin=predictive method=joback]
HvapTb      52269.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.22 0.86172 -0.000414 4.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CHNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-diaminomethylcyclohexane" "2,4-diamino-1-methylcyclohexane" "4-methyl-1,3-cyclohexanediamine" "2,4-cyclohexanediamine, 1-methyl-" "1,3-cyclohexanediamine, 4-methyl- (8ci,9ci)" "1,3-diamino-4-methylcyclohexane;1-methyl-2,4-diaminocyclohexane; 2,4-diamino-1-methylcyclohexane;2,4-diaminomethylcyclohexane; 4-methyl-1,3-cyclohexanediamine" );
standardThermochemistry
{
    dHf_298   -106590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149990.0
}
