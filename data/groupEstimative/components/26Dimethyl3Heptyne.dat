/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-3-heptyne  (C9H16, CAS 19549-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl3Heptyne;
formula     C9H16;
CAS         19549-97-4;
InChIKey    PDZCESXHZWBABW-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          608.64;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       0.2990;      // -   [origin=predictive method=lee-kesler]
Tb          413.64;      // K   [origin=predictive method=joback]
HvapTb      37004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.901 0.72088 -0.00038006 7.388e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylhept-3-yne" "3-heptyne, 2,6-dimethyl-" );
gibbsFormation
{
    dHf_298   32650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222820.0
    phase     gas;
}
