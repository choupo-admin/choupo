/*--------------------------------*- Choupo -*-----------------------*\
  Component: antioxidant 80  (C31H40O3, CAS 90-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        antioxidant80;
formula     C31H40O3;
CAS         90-68-6;
InChIKey    LKALLEFLBKHPTQ-UHFFFAOYSA-N;
MW          460.658;      // g/mol [origin=calculated method=formula-sum]
Tc          1535.75;      // K   [origin=predictive method=joback]
Pc          12.701;      // bar [origin=predictive method=joback]
omega       1.1838;      // -   [origin=predictive method=lee-kesler]
Tb          1254.20;      // K   [origin=predictive method=joback]
HvapTb      131850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.918 3.07068 -0.00246664 8.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 6; } { group AC; count 4; } { group ACCH3; count 3; } { group ACCH2; count 2; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 12; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis[(3-tert-butyl-5-methyl-2-oxidanyl-phenyl)methyl]-4-methyl-phenol" "phenol, 2,6-bis((3-(1,1-dimethylethyl)-2-hydroxy-5-methylphenyl)methyl)-4-methyl-" "phenol, 2,6-bis[[3-(1,1-dimethylethyl)-2-hydroxy-5-methylphenyl]methyl]-4-methyl-" "mesitol,.alpha.6-bis(5-tert-butyl-6-hydroxy-m-tolyl)-" "phenol,6-bis[[3-(1,1-dimethylethyl)-2-hydroxy-5-methylphenyl]methyl]-4-methyl-" "ksc-261-77-2" "mesitol, alpha2,alpha6-bis(5-tert-butyl-6-hydroxy-m-tolyl)- (8ci)" "2,6-bis(3-tert-butyl-2-hydroxy-5-methylbenzyl)-4-methylphenol" "2,6-bis[(3-tert-butyl-2-hydroxy-5-methylphenyl)methyl]-4-methylphenol" );
standardThermochemistry
{
    dHf_298   -591830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1008.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31410.0
}
