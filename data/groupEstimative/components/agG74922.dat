/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-74922  (C8H19N, CAS 70419-10-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG74922;
formula     C8H19N;
CAS         70419-10-2;
InChIKey    QNIVIMYXGGFTAK-QMMMGPOBSA-N;
MW          129.247;      // g/mol [origin=calculated method=formula-sum]
Tc          639.60;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.5074;      // -   [origin=predictive method=lee-kesler]
Tb          454.29;      // K   [origin=predictive method=joback]
HvapTb      43267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.257 0.83756 -0.0004612 9.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-6-methylheptan-2-amine" "(s)-1,5-dimethylhexylamine" "(s)-2-amino-6-methyl heptane" "2-heptanamine,6-methyl-, (2s)-" "2-heptanamine,6-methyl-, (s)-;(+)-1,5-dimethylhexylamine;(+)-2-amino-6-methylheptane;(+)-6-methyl-2-heptanamine;(2s)-6-methyl-2-heptanamine;(s)-(+)-6-methyl-2-heptylamine;(s)-2-amino-6-methylheptane;" );
gibbsFormation
{
    dHf_298   -185220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78050.0
    phase     gas;
}
