/*--------------------------------*- Choupo -*-----------------------*\
  Component: [7-cyclopentyl-4-(3-cyclopentylpropyl)hept-3-en-1-yl]cyclopentane  (C25H44, CAS 66374-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Cyclopentyl43CyclopentylpropylHept3En1YlCyclopentane;
formula     C25H44;
CAS         66374-93-4;
InChIKey    CNULMYGHHREGAN-UHFFFAOYSA-N;
MW          344.627;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.25;      // K   [origin=predictive method=joback]
Pc          10.957;      // bar [origin=predictive method=joback]
omega       0.7554;      // -   [origin=predictive method=lee-kesler]
Tb          821.48;      // K   [origin=predictive method=joback]
HvapTb      72053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-215.162 2.7938 -0.0018045 4.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 20; } { group CH; count 3; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 12; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[7-cyclopentyl-4-(3-cyclopentylpropyl)hept-3-enyl]cyclopentane" "cyclopentane,1'-[4-(3-cyclopentylpropyl)-3-heptene-1,7-diyl]bis-" "cyclopentane,1,1'-[4-(3-cyclopentylpropyl)-3-heptene-1,7-diyl]bis- (9ci)" );
gibbsFormation
{
    dHf_298   -270460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     967.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340940.0
    phase     gas;
}
