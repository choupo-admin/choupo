/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenoxy-1-propanol  (C9H12O2, CAS 6180-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenoxy1Propanol;
formula     C9H12O2;
CAS         6180-61-6;
InChIKey    AWVDYRFLCAZENH-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          740.29;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.8996;      // -   [origin=predictive method=lee-kesler]
Tb          546.80;      // K   [origin=predictive method=joback]
HvapTb      56993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.407 0.7507 -0.0004164 7.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenoxypropan-1-ol" "1-propanol, 3-phenoxy-" "propoxylated phenol" "3-phenoxy-propan-1-ol" "ph 4p" "polypropylene glycol phenyl ether" "polypropylene glycol monophenyl ether" "poly(oxy(methyl-1,2-ethanediyl)), alpha-phenyl-omega-hydroxy-" );
standardThermochemistry
{
    dHf_298   -277010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104510.0
}
