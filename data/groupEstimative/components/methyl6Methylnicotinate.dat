/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 6-methylnicotinate  (C8H9NO2, CAS 5470-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl6Methylnicotinate;
formula     C8H9NO2;
CAS         5470-70-2;
InChIKey    VYPPZXZHYDSBSJ-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          753.76;      // K   [origin=predictive method=joback]
Pc          36.115;      // bar [origin=predictive method=joback]
omega       0.5374;      // -   [origin=predictive method=lee-kesler]
Tb          526.22;      // K   [origin=predictive method=joback]
HvapTb      49957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.48 0.6044 -0.00029022 2.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C5H3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 6-methylpyridine-3-carboxylate" "6-methylnicotinic acid methyl ester" "methyl 6-methyl nicotinate" "6-methylpyridine-3-carboxylic acid methyl ester" "6-methyl-nicotinic acid methyl ester" "3-pyridinecarboxylic acid, 6-methyl-, methyl ester" "agn-pc-0cupcr" "5-carbomethoxy-2-picoline" "methyl-6-methyl nicotinate" "6-methyl nicotinic acid methyl ester" "3-(methoxycarbonyl)-6-methylpyridine" "5-(methoxycarbonyl)-2-methylpyridine" );
gibbsFormation
{
    dHf_298   -267880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114060.0
    phase     gas;
}
