/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylcocaine  (C18H23NO4, CAS 529-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylcocaine;
formula     C18H23NO4;
CAS         529-38-4;
InChIKey    NMPOSNRHZIWLLL-XUWVNRHRSA-N;
MW          317.385;      // g/mol [origin=calculated method=formula-sum]
Tc          992.35;      // K   [origin=predictive method=joback]
Pc          17.536;      // bar [origin=predictive method=joback]
omega       0.9504;      // -   [origin=predictive method=lee-kesler]
Tb          775.41;      // K   [origin=predictive method=joback]
HvapTb      74175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.979 1.88844 -0.0011932 2.64e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (1s,3s,4r,5r)-8-methyl-3-(phenylcarbonyloxy)-8-azabicyclo[3.2.1]octane-4-carboxylate" "cocaethylene" "homococaine" "homocaine" "ethyl benzoylecgonine" "cocaethyline" "benzoylethylecgonin" "ecgonine ethyl ester benzoate (ester)" "benzoylecgonine ethyl ester" "cocethyline" "ecgonine ethyl ester benzoate" "ethylbenzoylecgonine" );
standardThermochemistry
{
    dHf_298   -646590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202890.0
}
