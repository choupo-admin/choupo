/*--------------------------------*- Choupo -*-----------------------*\
  Component: salicylamide, o-acetyl-  (C9H9NO3, CAS 5663-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        salicylamideOAcetyl;
formula     C9H9NO3;
CAS         5663-71-8;
InChIKey    KGHXFBVYXDFJGG-UHFFFAOYSA-N;
MW          179.175;      // g/mol [origin=calculated method=formula-sum]
Tc          853.14;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.8207;      // -   [origin=predictive method=lee-kesler]
Tb          621.80;      // K   [origin=predictive method=joback]
HvapTb      63360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.36 0.69952 -0.00036006 4.136e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3COO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-aminocarbonylphenyl) ethanoate" "influina" "2-(aminocarbonyl)phenyl acetate" "2-carbamoylphenyl acetate" "acetylsalicylamide" "benzamide, 2-(acetyloxy)-" "o-acetyl salicylamide" "benzamide,2-(acetyloxy)-" "(2-carbamoylphenyl) acetate" "salicylamide, acetate (ester)" "benzamide, 2-(acetyloxy)- (9ci)" "salicylamide, acetate (ester) (8ci)" );
gibbsFormation
{
    dHf_298   -400100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245160.0
    phase     gas;
}
