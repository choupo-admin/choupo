/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxytetrahydropyran  (C6H12O2, CAS 6581-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxytetrahydropyran;
formula     C6H12O2;
CAS         6581-66-4;
InChIKey    XTDKZSUYCXHXJM-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          610.21;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.3329;      // -   [origin=predictive method=lee-kesler]
Tb          405.80;      // K   [origin=predictive method=joback]
HvapTb      36299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.35 0.62972 -0.0002587 6.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH3O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyoxane" "2h-pyran, tetrahydro-2-methoxy-" "pyran, 2-methoxy-tetrahydro-" "tetrahydro-2-methoxy-2h-pyran" "2h-pyran,tetrahydro-2-methoxy-" "2h-pyran, tetrahydro-2-methoxy- (8ci)" );
gibbsFormation
{
    dHf_298   -377070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167030.0
    phase     gas;
}
