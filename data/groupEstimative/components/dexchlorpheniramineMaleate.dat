/*--------------------------------*- Choupo -*-----------------------*\
  Component: dexchlorpheniramine maleate  (C20H23ClN2O4, CAS 2438-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dexchlorpheniramineMaleate;
formula     C20H23ClN2O4;
CAS         2438-32-6;
InChIKey    DBAKFASWICGISY-DASCVMRKSA-N;
MW          390.864;      // g/mol [origin=calculated method=formula-sum]
Tc          1374.03;      // K   [origin=predictive method=joback]
Pc          17.669;      // bar [origin=predictive method=joback]
omega       1.3966;      // -   [origin=predictive method=lee-kesler]
Tb          1115.25;      // K   [origin=predictive method=joback]
HvapTb      112158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.388 1.7723 -0.00101922 1.868e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } { group COOH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Cl; count 1; } { group COOH; count 2; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-but-2-enedioic acid;(3s)-3-(4-chlorophenyl)-n,n-dimethyl-3-pyridin-2-yl-propan-1-amine" "(+)-chlorpheniramine maleate" "d-chlorpheniramine maleate" "dexchloropheniramine maleate" "polaramine" "dextrochlorpheniramine maleate" "s-(+)-chlorpheniramine maleate salt" "chlorpheniramine d-form maleate" "s-(+)-chlorpheniramine maleate" "polamin" "rescon jr" "rescon mx" );
standardThermochemistry
{
    dHf_298   -610180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     976.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206190.0
}
