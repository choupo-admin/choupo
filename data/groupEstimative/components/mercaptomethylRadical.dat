/*--------------------------------*- Choupo -*-----------------------*\
  Component: mercaptomethyl radical  (CH3S, CAS 17032-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        mercaptomethylRadical;
formula     CH3S;
CAS         17032-46-1;
InChIKey    YYOGAOHWUDJBLM-UHFFFAOYSA-N;
role        radical;
MW          47.095;      // g/mol [origin=calculated method=formula-sum]
Tc          468.37;      // K   [origin=predictive method=joback]
Pc          65.670;      // bar [origin=predictive method=joback]
omega       0.1409;      // -   [origin=predictive method=lee-kesler]
Tb          279.94;      // K   [origin=predictive method=joback]
HvapTb      23908.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.97 0.0961 -3.4e-05 0.0);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH2; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methanethiol" "sulfanylmethyl" );
gibbsFormation
{
    dHf_298   41330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     256.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34660.0
    phase     gas;
}
