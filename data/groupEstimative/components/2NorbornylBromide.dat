/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-norbornyl bromide  (C7H11Br, CAS 2534-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NorbornylBromide;
formula     C7H11Br;
CAS         2534-77-2;
InChIKey    QXYOAWHKJRWNID-UHFFFAOYSA-N;
MW          175.069;      // g/mol [origin=calculated method=formula-sum]
Tc          662.47;      // K   [origin=predictive method=joback]
Pc          40.621;      // bar [origin=predictive method=joback]
omega       0.3390;      // -   [origin=predictive method=lee-kesler]
Tb          439.00;      // K   [origin=predictive method=joback]
HvapTb      37300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.95 0.9727 -0.000767 2.467e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylbicyclo[2.2.1]heptane" "exo-2-bromonorbornane" "2-bromobicyclo[2.2.1]heptane" "exo-2-bromobicyclo[2.2.1]heptane" "agn-pc-02r79k" "3-bromobicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane, 2-bromo-" "3-bromobicyclo[2.2.1]hepta-1,3,5-triene" );
standardThermochemistry
{
    dHf_298   -42380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     276.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124070.0
}
