/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipic acid monoester of triethylene glycol  (C12H22O7, CAS 64114-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipicAcidMonoesterOfTriethyleneGlycol;
formula     C12H22O7;
CAS         64114-59-6;
InChIKey    ZJRNXLJWZAVCCB-UHFFFAOYSA-N;
MW          278.301;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.89;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       1.5503;      // -   [origin=predictive method=lee-kesler]
Tb          814.91;      // K   [origin=predictive method=joback]
HvapTb      88376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.28 1.0474 -0.0004154 2.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2COO; count 1; } { group CH2O; count 1; } { group COOH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group OH; count 1; } { group O; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-[2-[2-(2-hydroxyethyloxy)ethoxy]ethoxy]-6-oxidanylidene-hexanoic acid" "6-{2-[2-(2-hydroxyethoxy)ethoxy]ethoxy}-6-oxohexanoic acid" "6-[2-[2-(2-hydroxyethoxy)ethoxy]ethoxy]-6-oxohexanoic acid" "hexanedioic acid, 1-(2-(2-(2-hydroxyethoxy)ethoxy)ethyl) ester" "hexanedioic acid, 1-[2-[2-(2-hydroxyethoxy)ethoxy]ethyl] ester" "hexanedioic acid, mono(2-(2-(2-hydroxyethoxy)ethoxy)ethyl) ester" "hexanedioic acid, mono[2-[2-(2-hydroxyethoxy)ethoxy]ethyl] ester" "(2-(2-(2-hydroxyethoxy)ethoxy)ethyl) hydrogen adipate" "hexanedioic acid,1-[2-[2-(2-hydroxyethoxy)ethoxy]ethyl] ester" "hexanedioicacid, mono[2-[2-(2-hydroxyethoxy)ethoxy]ethyl] ester (9ci)" );
gibbsFormation
{
    dHf_298   -1375230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-950940.0
    phase     gas;
}
