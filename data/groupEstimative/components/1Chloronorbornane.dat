/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloronorbornane  (C7H11Cl, CAS 765-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloronorbornane;
formula     C7H11Cl;
CAS         765-67-3;
InChIKey    LKMFWORXBTXJNB-UHFFFAOYSA-N;
MW          130.615;      // g/mol [origin=calculated method=formula-sum]
Tc          636.49;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.2660;      // -   [origin=predictive method=lee-kesler]
Tb          415.18;      // K   [origin=predictive method=joback]
HvapTb      34408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.18 1.2597 -0.001304 5.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbicyclo[2.2.1]heptane" "1-chlorobicyclo[2.2.1]heptane" "norbornane, 1-chloro-" "bicyclo[2.2.1]heptane, 1-chloro-" "1-chlorobicyclo(2.2.1)heptane" "bicyclo(2.2.1)heptane, 1-chloro-" "norbornane, chloro-" "norcamphane hydrochloride" "norbornane, 1-chloro- (8ci)" "4-chlorobicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane,1-chloro-" );
standardThermochemistry
{
    dHf_298   -48870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100040.0
}
