/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, polymer with ethenyl acetate and ethenylbenzene  (C15H18O4, CAS 63870-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcidPolymerWithEthenylAcetateAndEthenylbenzene;
formula     C15H18O4;
CAS         63870-20-2;
InChIKey    FVRPPSYXTLVAKR-UHFFFAOYSA-N;
MW          262.305;      // g/mol [origin=calculated method=formula-sum]
Tc          993.18;      // K   [origin=predictive method=joback]
Pc          19.186;      // bar [origin=predictive method=joback]
omega       0.8914;      // -   [origin=predictive method=lee-kesler]
Tb          766.05;      // K   [origin=predictive method=joback]
HvapTb      74409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.02 0.87352 -4.05e-05 -2.185e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH3COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;ethenyl ethanoate;prop-2-enoic acid" "ethenyl acetate; prop-2-enoic acid; styrene" "styrene, acrylic acid, vinyl acetate polymer" );
standardThermochemistry
{
    dHf_298   -630900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     939.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-412450.0
}
