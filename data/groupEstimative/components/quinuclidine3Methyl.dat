/*--------------------------------*- Choupo -*-----------------------*\
  Component: quinuclidine, 3-methyl-  (C8H15N, CAS 695-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        quinuclidine3Methyl;
formula     C8H15N;
CAS         695-88-5;
InChIKey    MWBULQNPGVGHKO-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          611.96;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.3537;      // -   [origin=predictive method=lee-kesler]
Tb          412.83;      // K   [origin=predictive method=joback]
HvapTb      35443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.68 1.17992 -0.000918 2.901e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1-azabicyclo[2.2.2]octane" "3-methylquinuclidine" "1-azabicyclo[2.2.2]octane, 3-methyl-" "1-azabicyclo[2.2.2]octane,3-methyl-" "1-azabicyclo(2.2.2)-octane, 3-methyl-" "quinuclidine,3-methyl- (6ci,7ci,8ci); 3-methylquinuclidine" );
gibbsFormation
{
    dHf_298   -1480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236660.0
    phase     gas;
}
