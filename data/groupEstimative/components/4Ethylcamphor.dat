/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethylcamphor  (C12H20O, CAS 90547-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethylcamphor;
formula     C12H20O;
CAS         90547-83-4;
InChIKey    CKBXFJIWHMQXQW-UHFFFAOYSA-N;
MW          180.291;      // g/mol [origin=calculated method=formula-sum]
Tc          789.71;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.4422;      // -   [origin=predictive method=lee-kesler]
Tb          555.78;      // K   [origin=predictive method=joback]
HvapTb      42789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-221.229 2.11698 -0.0023214 1.0531e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 3; } { group C_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyl-1,7,7-trimethyl-bicyclo[2.2.1]heptan-2-one" "4-ethyl-1,7,7-trimethylbicyclo[2.2.1]heptan-2-one" );
gibbsFormation
{
    dHf_298   -263890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12790.0
    phase     gas;
}
