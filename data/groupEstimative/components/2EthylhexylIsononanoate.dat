/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl isononanoate  (C17H34O2, CAS 71566-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylIsononanoate;
formula     C17H34O2;
CAS         71566-49-9;
InChIKey    NAGVKZOTMXGCCA-UHFFFAOYSA-N;
MW          270.457;      // g/mol [origin=calculated method=formula-sum]
Tc          815.11;      // K   [origin=predictive method=joback]
Pc          12.495;      // bar [origin=predictive method=joback]
omega       0.8346;      // -   [origin=predictive method=lee-kesler]
Tb          645.90;      // K   [origin=predictive method=joback]
HvapTb      60067.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.48 1.57588 -0.0008128 1.33e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl 7-methyloctanoate" "octyl isononanoate" "isononanoic acid, 2-ethylhexyl ester" "isononanoic acid,2-ethylhexyl ester" "2-ethylhexylisononanoate;2-ethylhexyl isononate;2-ethylhexyl isopelargonate;dragoxat 89;" );
standardThermochemistry
{
    dHf_298   -722050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     850.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222990.0
}
