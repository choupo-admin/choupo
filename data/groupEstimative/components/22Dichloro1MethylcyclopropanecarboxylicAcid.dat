/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichloro-1-methylcyclopropanecarboxylic acid  (C5H6Cl2O2, CAS 1447-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichloro1MethylcyclopropanecarboxylicAcid;
formula     C5H6Cl2O2;
CAS         1447-14-9;
InChIKey    BIUUWIKPBYWKEQ-UHFFFAOYSA-N;
MW          169.001;      // g/mol [origin=calculated method=formula-sum]
Tc          773.24;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.5984;      // -   [origin=predictive method=lee-kesler]
Tb          536.92;      // K   [origin=predictive method=joback]
HvapTb      49960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.56 1.25142 -0.0015916 7.614e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group COOH; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group C_ring; count 2; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)-1-methyl-cyclopropane-1-carboxylic acid" "2,2-dichloro-1-methyl-cyclopropanecarboxylic acid" "2,2-dichloro-1-methyl-1-cyclopropanecarboxylic acid" "2,2-dichloro-1-methylcyclopropane-1-carboxylic acid" "cyclopropanecarboxylicacid, 2,2-dichloro-1-methyl-" );
gibbsFormation
{
    dHf_298   -445340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-334490.0
    phase     gas;
}
