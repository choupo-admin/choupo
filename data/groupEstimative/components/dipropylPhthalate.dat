/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipropyl phthalate  (C14H18O4, CAS 131-16-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipropylPhthalate;
formula     C14H18O4;
CAS         131-16-8;
InChIKey    MQHNKCZKNAJROC-UHFFFAOYSA-N;
MW          250.294;      // g/mol [origin=calculated method=formula-sum]
Tc          869.91;      // K   [origin=predictive method=joback]
Pc          20.001;      // bar [origin=predictive method=joback]
omega       0.8797;      // -   [origin=predictive method=lee-kesler]
Tb          668.02;      // K   [origin=predictive method=joback]
HvapTb      64510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.374 1.08584 -0.00051276 4.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropyl benzene-1,2-dicarboxylate" "di-n-propylphthalate" "di-n-propyl phthalate" "phthalic acid, dipropyl ester" "1,2-benzenedicarboxylic acid, dipropyl ester" "n-dipropyl phthalate" "phthalic acid dipropyl ester" "phthalic acid di-n-propyl ester" "1,2-benzenedicarboxylic acid dipropyl ester" "1,2-benzenedicarboxylic acid, 1,2-dipropyl ester" "propyl 2-(propoxycarbonyl)benzoate" "dipropyl ester" );
standardThermochemistry
{
    dHf_298   -741790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-450960.0
}
