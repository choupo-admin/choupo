/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(n-benzylamino)-l-alanine  (C10H14N2O2, CAS 119830-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3NBenzylaminoLAlanine;
formula     C10H14N2O2;
CAS         119830-32-9;
InChIKey    GBGMJYPWCZYLAW-VIFPVBQESA-N;
MW          194.234;      // g/mol [origin=calculated method=formula-sum]
Tc          952.17;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       1.1370;      // -   [origin=predictive method=lee-kesler]
Tb          722.85;      // K   [origin=predictive method=joback]
HvapTb      73983.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.908 1.0697 -0.0007192 1.823e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-[(phenylmethyl)amino]propanoic acid" "(2s)-2-amino-3-[benzylamino]propanoic acid" "(s)-2-amino-3-(benzylamino)propanoic acid" "(2s)-2-azaniumyl-3-benzylammonio-propanoate;(s)-2-amino-3-(benzylamino)propanoic acid;" );
gibbsFormation
{
    dHf_298   -281490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-44780.0
    phase     gas;
}
