/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluorothioanisole  (C7H7FS, CAS 655-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluorothioanisole;
formula     C7H7FS;
CAS         655-20-9;
InChIKey    AYTSELVZWGHUEE-UHFFFAOYSA-N;
MW          142.191;      // g/mol [origin=calculated method=formula-sum]
Tc          686.44;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.3657;      // -   [origin=predictive method=lee-kesler]
Tb          459.47;      // K   [origin=predictive method=joback]
HvapTb      40114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.61 0.53661 -0.00029736 5.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-2-methylsulfanyl-benzene" "2-fluoro thioanisole" "1-fluoro-2-(methylthio)benzene" "o-fluorothioanisole" "2-fluorophenyl methyl sulfide" "2-fluoro-1-methylthiobenzene" "2-fluorophenyl methyl sulphide" "1-fluoro-2-methylsulfanylbenzene" "l264" "sulfide,o-fluorophenyl methyl (6ci,7ci,8ci);2-fluorophenyl methyl sulfide;o-fluorophenyl methyl sulfide;" );
standardThermochemistry
{
    dHf_298   -116990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50850.0
}
