/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2,6-dibromoheptanedioate  (C9H14Br2O4, CAS 868-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl26Dibromoheptanedioate;
formula     C9H14Br2O4;
CAS         868-73-5;
InChIKey    AWWJYEJSCIDADZ-UHFFFAOYSA-N;
MW          346.015;      // g/mol [origin=calculated method=formula-sum]
Tc          861.73;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.9624;      // -   [origin=predictive method=lee-kesler]
Tb          653.40;      // K   [origin=predictive method=joback]
HvapTb      62536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.543 0.83744 -0.0004258 4.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2,6-bis(bromanyl)heptanedioate" "2,6-dibromoheptanedioic acid dimethyl ester" "agn-pc-0cw82h" "dimethyl (2r,6s)-2,6-dibromoheptanedioate" "heptanedioic acid,2,6-dibromo-, 1,7-dimethyl ester" );
standardThermochemistry
{
    dHf_298   -821550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-572080.0
}
