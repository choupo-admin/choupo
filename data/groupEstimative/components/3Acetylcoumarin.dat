/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetylcoumarin  (C11H8O3, CAS 3949-36-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetylcoumarin;
formula     C11H8O3;
CAS         3949-36-8;
InChIKey    CSPIFKKOBWYOEX-UHFFFAOYSA-N;
MW          188.182;      // g/mol [origin=calculated method=formula-sum]
Tc          833.11;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.7555;      // -   [origin=predictive method=lee-kesler]
Tb          606.31;      // K   [origin=predictive method=joback]
HvapTb      58175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.93 0.89912 -0.0006677 1.9086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethanoylchromen-2-one" "3-acetyl-2h-chromen-2-one" "2h-1-benzopyran-2-one, 3-acetyl-" "coumarin, 3-acetyl-" "3-acetylchromen-2-one" "3-acetyl-2-oxochromene" "2h-1-benzopyran-2-one,3-acetyl-" "2h-1-benzopyran-2-one, 3-acetyl- (9ci)" "brd-k26954192-001-03-5" );
standardThermochemistry
{
    dHf_298   -329560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193880.0
}
