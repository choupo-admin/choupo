/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropenyl methyl ketone  (C5H8O, CAS 814-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropenylMethylKetone;
formula     C5H8O;
CAS         814-78-8;
InChIKey    ZGHFDIIVVIFNPS-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          550.40;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       0.3272;      // -   [origin=predictive method=lee-kesler]
Tb          364.43;      // K   [origin=predictive method=joback]
HvapTb      32880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.02 0.43074 -0.0002547 5.846e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-3-en-2-one" "3-buten-2-one, 3-methyl-" "3-methyl-3-buten-2-one" "methyl isopropenyl ketone" "methyl butenone" "ketone, methyl isopropenyl" "2-methyl-1-buten-3-one" "3-methylene-2-butanone" "3-methyl-3-buten-2-on" "propen-2-yl methyl ketone" "2-methyl-1-butene-3-one" "3-methyl-3-butene-2-one" );
gibbsFormation
{
    dHf_298   -143470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58410.0
    phase     gas;
}
