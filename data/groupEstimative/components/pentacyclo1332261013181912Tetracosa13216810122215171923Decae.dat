/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentacyclo[13.3.2.26,10.13,18.19,12]tetracosa-1,3(21),6,8,10,12(22),15,17,19,23-decaene  (C24H20, CAS 73608-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentacyclo1332261013181912Tetracosa13216810122215171923Decae;
formula     C24H20;
CAS         73608-52-3;
InChIKey    SOJCCVPXRNRYQH-UHFFFAOYSA-N;
MW          308.424;      // g/mol [origin=calculated method=formula-sum]
Tc          1146.06;      // K   [origin=predictive method=joback]
Pc          19.894;      // bar [origin=predictive method=joback]
omega       0.8327;      // -   [origin=predictive method=lee-kesler]
Tb          875.64;      // K   [origin=predictive method=joback]
HvapTb      79892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-153.73 2.0484 -0.00157868 4.856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 4; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentacyclo(13.3.2.26,10.13,18.19,12)tetracosa-1,3(21),6,8,10,12(22),15,17,19,23-decaene" );
standardThermochemistry
{
    dHf_298   357610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=607160.0
}
