/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2877332  (C19H26O3, CAS 55620-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2877332;
formula     C19H26O3;
CAS         55620-97-8;
InChIKey    GFCXVQYCUDMWGX-UHFFFAOYSA-N;
MW          302.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1080.37;      // K   [origin=predictive method=joback]
Pc          16.893;      // bar [origin=predictive method=joback]
omega       1.0528;      // -   [origin=predictive method=lee-kesler]
Tb          855.04;      // K   [origin=predictive method=joback]
HvapTb      80726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.968 1.78258 -0.00119296 3.121e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(6-methoxy-3,4-dihydronaphthalen-2-yl)-2,2-dimethyl-hexanoic acid" "hexanoic acid, 2,2-dimethyl-3-(6-methoxy-3,4-dihydro-2-naphthyl)-" "2-naphthalenepropionic acid, 3,4-dihydro-alpha,alpha-dimethyl-6-methoxy-beta-propyl-" "3,4-dihydro-6-methoxy-alpha,alpha-dimethyl-beta-propyl-2-naphthalenepropanoic acid" "alpha,alpha-dimethyl-6-methoxy-beta-propyl-3,4-dihydro-2-naphthalenepropionic acid" "3-(6-methoxy-3,4-dihydronaphthalen-2-yl)-2,2-dimethylhexanoic acid" );
gibbsFormation
{
    dHf_298   -585130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169570.0
    phase     gas;
}
