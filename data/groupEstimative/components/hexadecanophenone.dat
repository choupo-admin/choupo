/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecanophenone  (C22H36O, CAS 6697-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecanophenone;
formula     C22H36O;
CAS         6697-12-7;
InChIKey    IIOLAWJMOGLOIB-UHFFFAOYSA-N;
MW          316.529;      // g/mol [origin=calculated method=formula-sum]
Tc          973.79;      // K   [origin=predictive method=joback]
Pc          11.601;      // bar [origin=predictive method=joback]
omega       0.9297;      // -   [origin=predictive method=lee-kesler]
Tb          783.51;      // K   [origin=predictive method=joback]
HvapTb      73588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.656 1.98692 -0.0011855 2.6706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylhexadecan-1-one" "pentadecyl phenyl ketone" "1-phenyl-1-hexadecanone" "palmitophenone" "1-hexadecanone, 1-phenyl-" );
standardThermochemistry
{
    dHf_298   -373460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     933.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117850.0
}
