/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipropyl oxalate  (C8H14O4, CAS 615-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipropylOxalate;
formula     C8H14O4;
CAS         615-98-5;
InChIKey    HZHMMLIMOUNKCK-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          677.18;      // K   [origin=predictive method=joback]
Pc          25.611;      // bar [origin=predictive method=joback]
omega       0.7046;      // -   [origin=predictive method=lee-kesler]
Tb          499.08;      // K   [origin=predictive method=joback]
HvapTb      48216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.434 0.65424 -0.0002222 -3.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropyl ethanedioate" "dipropyl ethane-1,2-dioate" "oxalic acid, dipropyl ester" "di-n-propyl oxalate" "oxalic acid dipropyl ester" "ethanedioic acid, dipropyl ester" "ethanedioic acid,1,2-dipropyl ester" );
standardThermochemistry
{
    dHf_298   -843010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-604260.0
}
