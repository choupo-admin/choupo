/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-13-octadecen-1-yl acetate  (C20H38O2, CAS 60037-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z13Octadecen1YlAcetate;
formula     C20H38O2;
CAS         60037-58-3;
InChIKey    PPNRRQMJESAXGJ-SREVYHEPSA-N;
MW          310.522;      // g/mol [origin=calculated method=formula-sum]
Tc          891.21;      // K   [origin=predictive method=joback]
Pc          10.535;      // bar [origin=predictive method=joback]
omega       0.8858;      // -   [origin=predictive method=lee-kesler]
Tb          719.58;      // K   [origin=predictive method=joback]
HvapTb      67479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.065 1.86904 -0.0010534 2.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(z)-octadec-13-enyl] ethanoate" "13-octadecen-1-ol, 1-acetate, (13z)-" "z-13-octadecen-1-ol acetate" "13z-octadecenyl acetate" "z-13-octadecen-1-yl acetate" "[(z)-octadec-13-enyl] acetate" "13-octadecen-1-ol, acetate, (13z)-" );
gibbsFormation
{
    dHf_298   -656190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     979.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112630.0
    phase     gas;
}
