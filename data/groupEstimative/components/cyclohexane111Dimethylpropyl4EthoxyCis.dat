/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, 1-(1,1-dimethylpropyl)-4-ethoxy-, cis-  (C13H26O, CAS 181258-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane111Dimethylpropyl4EthoxyCis;
formula     C13H26O;
CAS         181258-87-7;
InChIKey    KDPSHFVSTJYAJQ-UHFFFAOYSA-N;
MW          198.35;      // g/mol [origin=calculated method=formula-sum]
Tc          730.99;      // K   [origin=predictive method=joback]
Pc          19.036;      // bar [origin=predictive method=joback]
omega       0.4594;      // -   [origin=predictive method=lee-kesler]
Tb          531.11;      // K   [origin=predictive method=joback]
HvapTb      45766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.568 1.39708 -0.0007698 1.42e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-4-(2-methylbutan-2-yl)cyclohexane" "cyclohexane, 1-(1,1-dimethylpropyl)-4-ethoxy-, trans-" );
standardThermochemistry
{
    dHf_298   -418640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26840.0
}
