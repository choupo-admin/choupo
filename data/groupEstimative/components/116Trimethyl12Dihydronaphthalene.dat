/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,6-trimethyl-1,2-dihydronaphthalene  (C13H16, CAS 30364-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        116Trimethyl12Dihydronaphthalene;
formula     C13H16;
CAS         30364-38-6;
InChIKey    RTUMCNDCAVLXEP-UHFFFAOYSA-N;
MW          172.271;      // g/mol [origin=calculated method=formula-sum]
Tc          777.52;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.4220;      // -   [origin=predictive method=lee-kesler]
Tb          544.09;      // K   [origin=predictive method=joback]
HvapTb      47358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.81 1.41816 -0.0012742 4.908e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,6-trimethyl-2h-naphthalene" "naphthalene, 1,2-dihydro-1,1,6-trimethyl-" "dehydro-ar-ionene" "1,2-dihydro-1,1,6-trimethylnaphthalene" "1,1,6-trimethyl-1,2-dihydro-naphthalene" "naphthalene,1,2-dihydro-1,1,6-trimethyl-;1,2-dihydro-1,1,6-trimethylnaphthalene;dehydro-ar-ionene;" "tdn" );
gibbsFormation
{
    dHf_298   41600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224850.0
    phase     gas;
}
