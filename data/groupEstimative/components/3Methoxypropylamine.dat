/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxypropylamine  (C4H11NO, CAS 5332-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxypropylamine;
formula     C4H11NO;
CAS         5332-73-0;
InChIKey    FAXDZWQIWUSWJH-UHFFFAOYSA-N;
MW          89.138;      // g/mol [origin=calculated method=formula-sum]
Tc          568.20;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.4520;      // -   [origin=predictive method=lee-kesler]
Tb          386.07;      // K   [origin=predictive method=joback]
HvapTb      37549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.243 0.38252 -0.0001262 -7.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxypropan-1-amine" "1-propanamine, 3-methoxy-" "propylamine, 3-methoxy-" "1-amino-3-methoxypropane" "3-aminopropyl methyl ether" "3-methyoxypropylamine" "3-methoxy-n-propylamine" "3-methoxy-1-propanamine" "propanolamine methyl ether" "3-mpa" "gamma-methoxypropylamine" "3-methoxypropan-1-amin" );
standardThermochemistry
{
    dHf_298   -224320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55750.0
}
