/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethylpropyl 2-methylbutyrate  (C10H20O2, CAS 84696-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dimethylpropyl2Methylbutyrate;
formula     C10H20O2;
CAS         84696-83-3;
InChIKey    AVTPHFBHRSGVRP-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          665.42;      // K   [origin=predictive method=joback]
Pc          21.653;      // bar [origin=predictive method=joback]
omega       0.5474;      // -   [origin=predictive method=lee-kesler]
Tb          485.30;      // K   [origin=predictive method=joback]
HvapTb      44097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.161 0.9168 -0.0004352 4.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutan-2-yl 2-methylbutanoate" "butanoic acid,2-methyl-, 1,2-dimethylpropyl ester" );
gibbsFormation
{
    dHf_298   -582850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284370.0
    phase     gas;
}
