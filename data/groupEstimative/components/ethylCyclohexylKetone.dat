/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl cyclohexyl ketone  (C9H16O, CAS 1123-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylCyclohexylKetone;
formula     C9H16O;
CAS         1123-86-0;
InChIKey    AMHOPTNGSNYSBL-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          689.32;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       0.4392;      // -   [origin=predictive method=lee-kesler]
Tb          478.94;      // K   [origin=predictive method=joback]
HvapTb      42803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.539 0.95292 -0.0005281 9.646e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylpropan-1-one" "1-propanone, 1-cyclohexyl-" "cyclohexyl ethyl ketone" "cyclohexylethylketone" "ketone, cyclohexyl ethyl" "1-cyclohexyl-propan-1-one" );
gibbsFormation
{
    dHf_298   -287350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79570.0
    phase     gas;
}
