/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxyethene  (C4H8O2, CAS 922-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxyethene;
formula     C4H8O2;
CAS         922-69-0;
InChIKey    FJTRNRFAIZEJJJ-UHFFFAOYSA-N;
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          504.86;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.3059;      // -   [origin=predictive method=lee-kesler]
Tb          332.52;      // K   [origin=predictive method=joback]
HvapTb      28728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.57 0.23734 3e-06 -5.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethene, 1,1-dimethoxy-" "ketene dimethyl acetal" "1,1-dimethoxyethylene" "1,1-dimethoxy-ethene" );
standardThermochemistry
{
    dHf_298   -274690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     325.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147910.0
}
