/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butylbenzene-1,2-diamine  (C10H16N2, CAS 3663-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Butylbenzene12Diamine;
formula     C10H16N2;
CAS         3663-23-8;
InChIKey    WQEGHHLKDKIWKM-UHFFFAOYSA-N;
MW          164.252;      // g/mol [origin=calculated method=formula-sum]
Tc          836.41;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.7527;      // -   [origin=predictive method=lee-kesler]
Tb          610.10;      // K   [origin=predictive method=joback]
HvapTb      62736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.473 0.87972 -0.00050412 1.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-benzenediamine, 4-butyl-" "4-n-butyl-o-phenylenediamine" "o-phenylenediamine, 4-butyl-" "4-butyl-1,2-benzenediamine" );
gibbsFormation
{
    dHf_298   31440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259370.0
    phase     gas;
}
