/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16-hentriacontanone  (C31H62O, CAS 502-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Hentriacontanone;
formula     C31H62O;
CAS         502-73-8;
InChIKey    UNRFDARCMOHDBJ-UHFFFAOYSA-N;
MW          450.836;      // g/mol [origin=calculated method=formula-sum]
Tc          1197.36;      // K   [origin=predictive method=joback]
Pc          5.860;      // bar [origin=predictive method=joback]
omega       0.3548;      // -   [origin=predictive method=lee-kesler]
Tb          962.75;      // K   [origin=predictive method=joback]
HvapTb      91346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.932 2.92084 -0.0016439 3.4866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 27; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 28; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hentriacontan-16-one" "palmitone" "dipentadecyl ketone" "pentadecyl ketone" "hentricontan-16-one" "hebtriacontanone" "16-hebtriacontanone" );
gibbsFormation
{
    dHf_298   -795750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1390.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81220.0
    phase     gas;
}
