/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-bis(3-aminopropyl)-2-butene-1,4-diamine  (C10H24N4, CAS 110319-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis3Aminopropyl2Butene14Diamine;
formula     C10H24N4;
CAS         110319-68-1;
InChIKey    QIMQRAOUTRFLRN-UHFFFAOYSA-N;
MW          200.33;      // g/mol [origin=calculated method=formula-sum]
Tc          871.82;      // K   [origin=predictive method=joback]
Pc          25.354;      // bar [origin=predictive method=joback]
omega       1.1613;      // -   [origin=predictive method=lee-kesler]
Tb          677.96;      // K   [origin=predictive method=joback]
HvapTb      71966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.822 1.25 -0.000788 1.982e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=CH; count 1; } { group CH2NH2; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH; count 2; } { group NH2; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-bis(3-azanylpropyl)but-2-ene-1,4-diamine" "2-butene-1,4-diamine, n,n'-bis(3-aminopropyl)-" "2-butene-1,4-diamine, n1,n4-bis(3-aminopropyl)-" "n,n'-bis(3-aminopropyl)but-2-ene-1,4-diamine" );
standardThermochemistry
{
    dHf_298   42010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=425220.0
}
