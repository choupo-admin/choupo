/*--------------------------------*- Choupo -*-----------------------*\
  Component: decanedioic acid;dimethyl benzene-1,4-dicarboxylate;2,2-dimethylpropane-1,3-diol;ethane-1,2-diol  (C27H46O12, CAS 51382-28-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decanedioicAcidDimethylBenzene14Dicarboxylate22Dimethylpropa;
formula     C27H46O12;
CAS         51382-28-6;
InChIKey    QUVMYGGCQKXNSK-UHFFFAOYSA-N;
MW          562.653;      // g/mol [origin=calculated method=formula-sum]
Tc          2537.95;      // K   [origin=predictive method=joback]
Pc          9.870;      // bar [origin=predictive method=joback]
omega       -0.2265;      // -   [origin=predictive method=lee-kesler]
Tb          1626.17;      // K   [origin=predictive method=joback]
HvapTb      194078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (137.902 2.06568 -0.00041416 -2.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group COOH; count 2; } { group _CH2OH_2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 4; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-benzenedicarboxylic acid, dimethyl ester, polymer with decanedioic acid, 2,2-dimethyl-1,3-propanediol and 1,2-ethanediol" "decanedioic acid; dimethyl benzene-1,4-dicarboxylate; 2,2-dimethylpropane-1,3-diol; ethane-1,2-diol" );
gibbsFormation
{
    dHf_298   -2663180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1791.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1888040.0
    phase     gas;
}
