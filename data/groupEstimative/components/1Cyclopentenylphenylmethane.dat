/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclopentenylphenylmethane  (C12H14, CAS 15507-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopentenylphenylmethane;
formula     C12H14;
CAS         15507-35-4;
InChIKey    GSXCQGUOLCBELU-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          760.53;      // K   [origin=predictive method=joback]
Pc          30.693;      // bar [origin=predictive method=joback]
omega       0.4113;      // -   [origin=predictive method=lee-kesler]
Tb          524.93;      // K   [origin=predictive method=joback]
HvapTb      46102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.269 1.1076 -0.00076324 2.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenten-1-ylmethylbenzene" "(1-cyclopenten-1-ylmethyl)benzene" "1-cyclopentenyl phenylmethane" "benzene, [(cyclopent-1-en-3-yl)methyl]-" );
standardThermochemistry
{
    dHf_298   72650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227160.0
}
