/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl acrylate  (C11H20O2, CAS 103-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylAcrylate;
formula     C11H20O2;
CAS         103-11-7;
InChIKey    GOXQRTZXKQZDDN-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          680.39;      // K   [origin=predictive method=joback]
Pc          20.309;      // bar [origin=predictive method=joback]
omega       0.6360;      // -   [origin=predictive method=lee-kesler]
Tb          505.74;      // K   [origin=predictive method=joback]
HvapTb      46429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.625 0.97994 -0.0005061 7.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl prop-2-enoate" "2-propenoic acid, 2-ethylhexyl ester" "acrylic acid, 2-ethylhexyl ester" "2-ethyl-1-hexyl acrylate" "2-ethylhexyl 2-propenoate" "ethylhexyl acrylate" "mono(2-ethylhexyl) acrylate" "1-hexanol, 2-ethyl-, acrylate" "2-propenoic acid, 2-ethylhexyl ester, homopolymer" "(+/-)-acrylic acid 2-ethylhexyl ester" "2-ethylexyl acrylate" "1-hexanol, acrylate" );
standardThermochemistry
{
    dHf_298   -467500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183230.0
}
