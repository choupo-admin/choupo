/*--------------------------------*- Choupo -*-----------------------*\
  Component: parylene c  (C16H14Cl2, CAS 28804-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        paryleneC;
formula     C16H14Cl2;
CAS         28804-46-8;
InChIKey    VRBFTYUMFJWSJY-UHFFFAOYSA-N;
MW          277.188;      // g/mol [origin=calculated method=formula-sum]
Tc          972.62;      // K   [origin=predictive method=joback]
Pc          23.248;      // bar [origin=predictive method=joback]
omega       0.5917;      // -   [origin=predictive method=lee-kesler]
Tb          710.20;      // K   [origin=predictive method=joback]
HvapTb      65632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.51 1.3754 -0.00093412 2.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CHCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-03vusw" );
gibbsFormation
{
    dHf_298   91370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=306480.0
    phase     gas;
}
