/*--------------------------------*- Choupo -*-----------------------*\
  Component: mesitylacetonitrile  (C11H13N, CAS 34688-71-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mesitylacetonitrile;
formula     C11H13N;
CAS         34688-71-6;
InChIKey    SDKQOGSGNPGPRN-UHFFFAOYSA-N;
MW          159.232;      // g/mol [origin=calculated method=formula-sum]
Tc          817.34;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       0.6029;      // -   [origin=predictive method=lee-kesler]
Tb          594.98;      // K   [origin=predictive method=joback]
HvapTb      54820.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.881 0.72626 -0.00037368 6.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4,6-trimethylphenyl)ethanenitrile" "2,4,6-trimethylphenylacetonitrile" "2,4,6-trimethylbenzyl cyanide" "2-(2,4,6-trimethylphenyl)acetonitrile" "benzeneacetonitrile, 2,4,6-trimethyl-" "2-mesitylacetonitrile" "2,4,6-trimethyl benzyl cyanide" "sdkqogsgnpgprn-uhfffaoysa-" "(2,4,6-trimethylphenyl)acetonitrile" "i156" );
gibbsFormation
{
    dHf_298   96630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=258440.0
    phase     gas;
}
