/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]oct-2-en-1-ol  (C8H12O, CAS 68211-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Oct2En1Ol;
formula     C8H12O;
CAS         68211-36-9;
InChIKey    YTZYREKPCQTYTM-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          704.71;      // K   [origin=predictive method=joback]
Pc          44.267;      // bar [origin=predictive method=joback]
omega       0.6759;      // -   [origin=predictive method=lee-kesler]
Tb          496.24;      // K   [origin=predictive method=joback]
HvapTb      49392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.03 1.3163 -0.00130928 5.348e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.2]oct-2-en-4-ol" "bicyclo(2.2.2)oct-2-en-1-ol" "sdccgmls-0066188.p001" );
standardThermochemistry
{
    dHf_298   -154380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1430.0
}
