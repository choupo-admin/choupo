/*--------------------------------*- Choupo -*-----------------------*\
  Component: ether, methyl neopentyl  (C6H14O, CAS 1118-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etherMethylNeopentyl;
formula     C6H14O;
CAS         1118-00-9;
InChIKey    JILHZKWLEAKYRC-UHFFFAOYSA-N;
MW          102.177;      // g/mol [origin=calculated method=formula-sum]
Tc          531.78;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.2852;      // -   [origin=predictive method=lee-kesler]
Tb          356.07;      // K   [origin=predictive method=joback]
HvapTb      30064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.539 0.63648 -0.0003634 7.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2,2-dimethyl-propane" "propane, 1-methoxy-2,2-dimethyl-" "propane,1-methoxy-2,2-dimethyl-" "methyl 2,2-dimethylpropyl ether" "ether,methyl neopentyl (7ci,8ci); 1-methoxy-2,2-dimethylpropane;2,2-dimethyl-1-methoxypropane; 2,2-dimethylpropyl methyl ether; methylneopentyl ether" );
standardThermochemistry
{
    dHf_298   -308140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102520.0
}
