/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylcis-cyclopropane-1,2-dicarboxylate  (C9H14O4, CAS 710-43-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylcisCyclopropane12Dicarboxylate;
formula     C9H14O4;
CAS         710-43-0;
InChIKey    SXLDHZFJMXLFJU-KNVOCYPGSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          712.90;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.6869;      // -   [origin=predictive method=lee-kesler]
Tb          524.03;      // K   [origin=predictive method=joback]
HvapTb      50046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.222 0.87364 -0.0004414 5.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl (1r,2s)-cyclopropane-1,2-dicarboxylate" "cis-diethyl cyclopropane-1,2-dicarboxylate" "diethyl cis-cyclopropane-1,2-dicarboxylate" "diethyl-cis-cyclopropane-1,2-dicarboxylate" "diethyl (1s,2r)-cyclopropane-1,2-dicarboxylate" "(1r,2s)-1,2-diethylcyclopropane-1,2-dicarboxylate" "1,2-diethyl (1r,2s)-cyclopropane-1,2-dicarboxylate" "cis-cyclopropane-1,2-dicarboxylic acid diethyl ester" "1,2-cyclopropanedicarboxylic acid, diethyl ester, (1r,2s)-" "1,2-cyclopropanedicarboxylic acid, diethyl ester, (1r,2s)-rel-" "(meso)-(cis)-cyclopropane-1,2-dicarboxylic acid diethyl ester" );
gibbsFormation
{
    dHf_298   -811190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-542800.0
    phase     gas;
}
