/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene, 1,5-dimethoxy-  (C7H12O2, CAS 61860-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentene15Dimethoxy;
formula     C7H12O2;
CAS         61860-73-9;
InChIKey    AEEARSPWTPKKPQ-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          620.96;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.3986;      // -   [origin=predictive method=lee-kesler]
Tb          424.02;      // K   [origin=predictive method=joback]
HvapTb      37207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.12 0.55864 -0.00018264 -1.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-dimethoxycyclopentene" );
standardThermochemistry
{
    dHf_298   -345460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145060.0
}
