/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-mercapto-1-butanol  (C4H10OS, CAS 14970-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Mercapto1Butanol;
formula     C4H10OS;
CAS         14970-83-3;
InChIKey    NEJMTSWXTZREOC-UHFFFAOYSA-N;
MW          106.183;      // g/mol [origin=calculated method=formula-sum]
Tc          630.08;      // K   [origin=predictive method=joback]
Pc          47.826;      // bar [origin=predictive method=joback]
omega       0.7455;      // -   [origin=predictive method=lee-kesler]
Tb          446.16;      // K   [origin=predictive method=joback]
HvapTb      47914.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.434 0.4451 -0.0002466 5.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-sulfanylbutan-1-ol" "1-butanol, 4-mercapto-" "4-sulfanyl-1-butanol" "4-hydroxy-1-butanthiol;4-hydroxy-1-mercaptobutane; 4-hydroxybutanethiol; 4-mercapto-1-butanol;4-mercaptobutan-1-ol; 4-mercaptobutanol" );
standardThermochemistry
{
    dHf_298   -239640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124630.0
}
