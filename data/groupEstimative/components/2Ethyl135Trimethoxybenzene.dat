/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-1,3,5-trimethoxybenzene  (C11H16O3, CAS 67827-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl135Trimethoxybenzene;
formula     C11H16O3;
CAS         67827-55-8;
InChIKey    HXQYBITZEZXDJD-UHFFFAOYSA-N;
MW          196.246;      // g/mol [origin=calculated method=formula-sum]
Tc          760.46;      // K   [origin=predictive method=joback]
Pc          24.053;      // bar [origin=predictive method=joback]
omega       0.6670;      // -   [origin=predictive method=lee-kesler]
Tb          560.16;      // K   [origin=predictive method=joback]
HvapTb      51572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.381 0.60188 -7.168e-05 -9.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-1,3,5-trimethoxy-benzene" "benzene, 2-ethyl-1,3,5-trimethoxy-" "ethylphloroglucinol trimethyl ether" );
standardThermochemistry
{
    dHf_298   -464910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189740.0
}
