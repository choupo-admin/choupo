/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyl-4-methyl-1,3-dioxane  (C11H22O2, CAS 3080-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexyl4Methyl13Dioxane;
formula     C11H22O2;
CAS         3080-69-1;
InChIKey    WHAXQUXICKDLJD-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          713.09;      // K   [origin=predictive method=joback]
Pc          22.250;      // bar [origin=predictive method=joback]
omega       0.5615;      // -   [origin=predictive method=lee-kesler]
Tb          520.06;      // K   [origin=predictive method=joback]
HvapTb      49220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.135 1.13844 -0.0005724 8.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-hexyl-1,3-dioxane" "heptanal, cyclic trimethylene acetal" "m-dioxane, 2-hexyl-4-methyl-" "1,3-dioxane, 2-hexyl-4-methyl-" "heptaldehyde-1,3-butylene glycol acetal" "heptanal, cyclic 1-methyltrimethylene acetal" "heptanal,3-propanediyl acetal" "heptanal, cyclic 1,3-propanediyl acetal" );
gibbsFormation
{
    dHf_298   -500390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113760.0
    phase     gas;
}
