/*--------------------------------*- Choupo -*-----------------------*\
  Component: prenylamine  (C24H27N, CAS 390-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prenylamine;
formula     C24H27N;
CAS         390-64-7;
InChIKey    IFFPICMESYHZPQ-UHFFFAOYSA-N;
MW          329.487;      // g/mol [origin=calculated method=formula-sum]
Tc          1121.20;      // K   [origin=predictive method=joback]
Pc          16.000;      // bar [origin=predictive method=joback]
omega       0.9061;      // -   [origin=predictive method=lee-kesler]
Tb          878.05;      // K   [origin=predictive method=joback]
HvapTb      81506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.217 2.13512 -0.0014304 3.604e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 15; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-diphenyl-n-(1-phenylpropan-2-yl)propan-1-amine" "segontin" "bismethin" "falliocor" "hostaginan" "synadrin" "valecor" "corpax" "elecor" "dl-prenylamine" "corontin" "difril" );
standardThermochemistry
{
    dHf_298   213810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     793.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=572940.0
}
