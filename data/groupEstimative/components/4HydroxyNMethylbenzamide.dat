/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-n-methylbenzamide  (C8H9NO2, CAS 27642-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxyNMethylbenzamide;
formula     C8H9NO2;
CAS         27642-27-9;
InChIKey    VKDNYQKDAXLFIL-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          828.12;      // K   [origin=predictive method=joback]
Pc          48.902;      // bar [origin=predictive method=joback]
omega       0.8427;      // -   [origin=predictive method=lee-kesler]
Tb          593.98;      // K   [origin=predictive method=joback]
HvapTb      61874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.06 0.88772 -0.00072886 2.4406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-4-oxidanyl-benzamide" "benzamide, 4-hydroxy-n-methyl-" "n-methyl-4-hydroxybenzamide" "benzamide,4-hydroxy-n-methyl-" "benzamide,p-hydroxy-n-methyl- (7ci,8ci); 4-hydroxy-n-methylbenzamide;n-methyl-4-hydroxybenzamide; n-methyl-p-hydroxybenzamide; p-hydroxy-n-methylbenzamide" );
standardThermochemistry
{
    dHf_298   -208340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65260.0
}
