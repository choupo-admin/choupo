/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-but-2-enedioic acid;4-[2-(4-hydroxyphenyl)propan-2-yl]phenol  (C19H20O6, CAS 68083-66-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eBut2EnedioicAcid424HydroxyphenylPropan2YlPhenol;
formula     C19H20O6;
CAS         68083-66-9;
InChIKey    SESIYFLKYWKHJD-WLHGVMLRSA-N;
MW          344.363;      // g/mol [origin=calculated method=formula-sum]
Tc          1413.36;      // K   [origin=predictive method=joback]
Pc          27.099;      // bar [origin=predictive method=joback]
omega       1.7047;      // -   [origin=predictive method=lee-kesler]
Tb          1142.27;      // K   [origin=predictive method=joback]
HvapTb      121752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.67 2.00144 -0.00157092 4.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid; 4-[2-(4-hydroxyphenyl)propan-2-yl]phenol" "2-butenedioic acid, polymer with 4,4'-(1-methylethylidene)bis(phenol)" );
standardThermochemistry
{
    dHf_298   -1020740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     904.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-684840.0
}
