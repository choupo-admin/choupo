/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-4-propylbenzene  (C13H20, CAS 58567-80-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl4Propylbenzene;
formula     C13H20;
CAS         58567-80-9;
InChIKey    XLJCEWXIEVXDCP-UHFFFAOYSA-N;
MW          176.303;      // g/mol [origin=calculated method=formula-sum]
Tc          735.67;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       0.4372;      // -   [origin=predictive method=lee-kesler]
Tb          525.47;      // K   [origin=predictive method=joback]
HvapTb      46174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.008 1.22628 -0.00081936 2.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-propyl-benzene" "benzene, 1-(1,1-dimethylethyl)-4-propyl-" );
standardThermochemistry
{
    dHf_298   -95340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164200.0
}
