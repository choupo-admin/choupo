/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrahydro-1,5-dimethylnaphthalene  (C12H16, CAS 21564-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrahydro15Dimethylnaphthalene;
formula     C12H16;
CAS         21564-91-0;
InChIKey    BMADLDGHUBLVMQ-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          747.52;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.4166;      // -   [origin=predictive method=lee-kesler]
Tb          521.81;      // K   [origin=predictive method=joback]
HvapTb      45991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.69 1.08724 -0.00069992 1.767e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-dimethyl-1,2,3,4-tetrahydronaphthalene" "1,5-dimethyltetralin" "naphthalene, 1,2,3,4-tetrahydro-1,5-dimethyl-" "1,5-dmt" "1,5-dimethyl-1,2,3,4-tetrahydro-naphthalene" );
gibbsFormation
{
    dHf_298   -10780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191960.0
    phase     gas;
}
