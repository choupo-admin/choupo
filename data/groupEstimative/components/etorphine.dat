/*--------------------------------*- Choupo -*-----------------------*\
  Component: etorphine  (C25H33NO4, CAS 14521-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etorphine;
formula     C25H33NO4;
CAS         14521-96-1;
InChIKey    CAHCBJPUTCKATP-HBDRVVKHSA-N;
MW          411.542;      // g/mol [origin=calculated method=formula-sum]
Tc          1303.62;      // K   [origin=predictive method=joback]
Pc          18.154;      // bar [origin=predictive method=joback]
omega       1.4453;      // -   [origin=predictive method=lee-kesler]
Tb          1059.99;      // K   [origin=predictive method=joback]
HvapTb      107955.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-398.338 4.11998 -0.00440306 1.877e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } { group C; count 4; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group O; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-alpha-etorphine" "etorphinum" "etorphinum [inn-latin]" "etorfina [dcit]" "19-propylorvinol" "etorphine [inn:ban]" "m99 injection" "etorphine (except hydrochloride salt)" "etorphine hcl" "etorphine hydrochloride" "6,14-ethenomorphinan-7-methanol, 4,5-epoxy-3-hydroxy-6-methoxy-alpha,17-dimethyl-alpha-propyl-, (5alpha,7alpha(r))-" "m99" );
standardThermochemistry
{
    dHf_298   -421240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     663.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217560.0
}
