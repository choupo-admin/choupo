/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropa[b]anthracene  (C15H10, CAS 287-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropaBAnthracene;
formula     C15H10;
CAS         287-03-6;
InChIKey    IWKUATYDCVYMIP-UHFFFAOYSA-N;
MW          190.245;      // g/mol [origin=calculated method=formula-sum]
Tc          876.07;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.6080;      // -   [origin=predictive method=lee-kesler]
Tb          625.25;      // K   [origin=predictive method=joback]
HvapTb      56404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.58 1.3606 -0.00126412 4.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropa(b)anthracene" "1h-cycloprop[b]anthracene" );
gibbsFormation
{
    dHf_298   336790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=464900.0
    phase     gas;
}
