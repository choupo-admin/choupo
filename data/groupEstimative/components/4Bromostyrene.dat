/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromostyrene  (C8H7Br, CAS 2039-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromostyrene;
formula     C8H7Br;
CAS         2039-82-9;
InChIKey    WGGLDBIZIQMEGH-UHFFFAOYSA-N;
MW          183.048;      // g/mol [origin=calculated method=formula-sum]
Tc          712.51;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.3876;      // -   [origin=predictive method=lee-kesler]
Tb          477.14;      // K   [origin=predictive method=joback]
HvapTb      42105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.79 0.6436 -0.00046986 1.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-ethenyl-benzene" "p-bromostyrene" "1-bromo-4-vinylbenzene" "benzene, 1-bromo-4-ethenyl-" "styrene, p-bromo-" "1-bromo-4-ethenylbenzene" "1-(4-bromophenyl)ethylene" "p-bromo styrene" "4-bromo-1-vinylbenzene" "bromostyrene, 4-" "styrene, p-bromo- (8ci)" "benzene, 1-bromo-4-ethenyl- (9ci)" );
standardThermochemistry
{
    dHf_298   168370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221420.0
}
