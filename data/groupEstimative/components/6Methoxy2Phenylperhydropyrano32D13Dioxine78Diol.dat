/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methoxy-2-phenylperhydropyrano[3,2-d][1,3]dioxine-7,8-diol  (C14H18O6, CAS 3162-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methoxy2Phenylperhydropyrano32D13Dioxine78Diol;
formula     C14H18O6;
CAS         3162-96-7;
InChIKey    VVSWDMJYIDBTMV-UHFFFAOYSA-N;
MW          282.292;      // g/mol [origin=calculated method=formula-sum]
Tc          1059.70;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       1.5781;      // -   [origin=predictive method=lee-kesler]
Tb          846.11;      // K   [origin=predictive method=joback]
HvapTb      97610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.91 1.40812 -0.0007103 8.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 3; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 2; } { group CH3O; count 1; } { group CH-O; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } { group O; count 1; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methoxy-2-phenyl-4,4a,6,7,8,8a-hexahydropyrano[3,2-d][1,3]dioxine-7,8-diol" "methyl 4,6-o-benzylidene-alpha-d-glucopyranoside" "altropyranoside,6-o-benzylidene-, .alpha.-d-" ".alpha.-d-altropyranoside,6-o-(phenylmethylene)-" "6-methoxy-2-phenyl-4,4a,6,7,8,8a-hexahydropyrano[3,2-d][1,3]dioxin-7,8-diol" "methyl-4,6-o-benzylidene-a-d-galactopyranoside" "(+)-(4,6-o-benzylidene)methyl-alpha-d-glucopyranoside" "4,6-benzylidene-.alpha.-methyl-d-glucoside" "glucopyranoside,6-o-benzylidene-, .alpha.-d-" "mannopyranoside,6-o-benzylidene-, .alpha.-d-" "methyl-4,6-o-benzylidene-.alpha. d-glucoside" "methyl-4,6-o-benzylidene-b-d-galactopyranoside" );
standardThermochemistry
{
    dHf_298   -888840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     283.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-415330.0
}
