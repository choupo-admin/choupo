/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethylene glycol  (C6H14O4, CAS 112-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethyleneGlycol;
formula     C6H14O4;
CAS         112-27-6;
InChIKey    ZIBGPFATKBEMQZ-UHFFFAOYSA-N;
MW          150.174;      // g/mol [origin=calculated method=formula-sum]
Tc          724.14;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       1.4883;      // -   [origin=predictive method=lee-kesler]
Tb          566.08;      // K   [origin=predictive method=joback]
HvapTb      67128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.016 0.5154 -0.0001414 -2.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-hydroxyethyloxy)ethoxy]ethanol" "triglycol" "trigen" "2,2'-ethylenedioxydiethanol" "2,2'-(ethylenedioxy)diethanol" "triethylenglykol" "ethanol, 2,2'-[1,2-ethanediylbis(oxy)]bis-" "1,2-bis(2-hydroxyethoxy)ethane" "triethyleneglycol" "di-beta-hydroxyethoxyethane" "2,2'-ethylenedioxyethanol" "2,2'-[ethane-1,2-diylbis(oxy)]diethanol" );
gibbsFormation
{
    dHf_298   -736070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-484000.0
    phase     gas;
}
