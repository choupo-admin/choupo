/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophorone diisocyanate, polycaprolactone polymer  (C18H28N2O4, CAS 58675-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophoroneDiisocyanatePolycaprolactonePolymer;
formula     C18H28N2O4;
CAS         58675-12-0;
InChIKey    ZYXKGBNFYKDXJQ-UHFFFAOYSA-N;
MW          336.432;      // g/mol [origin=calculated method=formula-sum]
Tc          1068.46;      // K   [origin=predictive method=joback]
Pc          16.810;      // bar [origin=predictive method=joback]
omega       0.9221;      // -   [origin=predictive method=lee-kesler]
Tb          835.04;      // K   [origin=predictive method=joback]
HvapTb      80502.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group C; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCd; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 1; } { group C_ring; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-cyclohexane;oxepan-2-one" "2-oxepanone, polymer with 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane" "5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane; oxepan-2-one" "5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-cyclohexane; oxepan-2-one" );
// formation datum unavailable (element entropy missing): dHf_298=-729630.0 dGf_298=None
