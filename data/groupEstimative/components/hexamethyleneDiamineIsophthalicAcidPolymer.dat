/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethylene diamine, isophthalic acid polymer  (C14H22N2O4, CAS 25722-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethyleneDiamineIsophthalicAcidPolymer;
formula     C14H22N2O4;
CAS         25722-07-0;
InChIKey    FITNAOAKVDEJHB-UHFFFAOYSA-N;
MW          282.34;      // g/mol [origin=calculated method=formula-sum]
Tc          1226.17;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       1.5718;      // -   [origin=predictive method=lee-kesler]
Tb          989.06;      // K   [origin=predictive method=joback]
HvapTb      105600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.556 1.2146 -0.00051916 1.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH2; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;hexane-1,6-diamine" "1,3-benzenedicarboxylic acid, polymer with 1,6-hexanediamine" "benzene-1,3-dicarboxylic acid- hexane-1,6-diamine(1:1)" "benzene-1,3-dicarboxylic acid; hexane-1,6-diamine" "benzene-1,3-dicarboxylic acid - hexane-1,6-diamine (1:1)" "1,3-benzenedicarboxylic acid compd. with 1,6-hexanediamine (1:1)" );
standardThermochemistry
{
    dHf_298   -851810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     905.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-489900.0
}
