/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5,9-decatriene  (C10H16, CAS 13393-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        159Decatriene;
formula     C10H16;
CAS         13393-64-1;
InChIKey    GMGYODAMPOELNZ-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          603.19;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       0.4170;      // -   [origin=predictive method=lee-kesler]
Tb          425.92;      // K   [origin=predictive method=joback]
HvapTb      36472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.366 0.9338 -0.0006498 1.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "deca-1,5,9-triene" "1,5,9-decatriene, mixture of cis and trans" "1,5,9-decatriene, (z)-" );
standardThermochemistry
{
    dHf_298   118350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=289220.0
}
