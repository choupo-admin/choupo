/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-79963  (C20H22O4, CAS 71463-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG79963;
formula     C20H22O4;
CAS         71463-82-6;
InChIKey    ZRYUYMRIBIOSBD-UHFFFAOYSA-N;
MW          326.392;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.61;      // K   [origin=predictive method=joback]
Pc          16.351;      // bar [origin=predictive method=joback]
omega       0.9892;      // -   [origin=predictive method=lee-kesler]
Tb          831.54;      // K   [origin=predictive method=joback]
HvapTb      79754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.667 1.58284 -0.00087356 1.382e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-(2-methylbutyl) o1-(phenylmethyl) benzene-1,2-dicarboxylate" "2-methylbutyl benzyl phthalate" "1,2-benzenedicarboxylic acid, 1-(2-methylbutyl) 2-(phenylmethyl) ester" "1-o-benzyl 2-o-(2-methylbutyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid 2-methylbutyl benzyl ester" "1,2-benzenedicarboxylicacid, 1-(2-methylbutyl) 2-(phenylmethyl) ester" "1,2-benzenedicarboxylicacid, 2-methylbutyl phenylmethyl ester (9ci); 2-methylbutyl benzyl phthalate" );
standardThermochemistry
{
    dHf_298   -634380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     809.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-290470.0
}
