/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butylcyclohexane  (C10H20, CAS 3178-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylcyclohexane;
formula     C10H20;
CAS         3178-22-1;
InChIKey    XTVMZZBLCLWBPM-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          655.02;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.2758;      // -   [origin=predictive method=lee-kesler]
Tb          444.72;      // K   [origin=predictive method=joback]
HvapTb      36987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.28 1.20176 -0.000773 1.893e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, tert-butyl-" "cyclohexane, (1,1-dimethylethyl)-" "t-butylcyclohexane" "1-tert-butylcyclohexane" "(1,1-dimethylethyl)cyclohexane" "tert-butyl-cyclohexane" "cyclohexane,1-dimethylethyl)-" "cyclohexane, tert-butyl- (8ci)" );
gibbsFormation
{
    dHf_298   -204160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=60610.0
    phase     gas;
}
