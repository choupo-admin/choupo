/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-difluoro-cyclopropabenzene  (C7H4F2, CAS 18238-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11DifluoroCyclopropabenzene;
formula     C7H4F2;
CAS         18238-55-6;
InChIKey    QQESEAYTNOTARV-UHFFFAOYSA-N;
MW          126.105;      // g/mol [origin=calculated method=formula-sum]
Tc          587.58;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.3424;      // -   [origin=predictive method=lee-kesler]
Tb          388.40;      // K   [origin=predictive method=joback]
HvapTb      30898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.89 1.016 -0.00119956 5.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,7-bis(fluoranyl)bicyclo[4.1.0]hepta-1,3,5-triene" "7,7-difluorobicyclo[4.1.0]hepta-1,3,5-triene" "bicyclo(4.1.0)hepta-1,3,5-triene, 7,7-difluoro-" "bicyclo[4.1.0]hepta-1,3,5-triene, 7,7-difluoro-" "7,7-difluoro-bicyclo[4.1.0]hepta-1(6),2,4-triene" );
gibbsFormation
{
    dHf_298   -254610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199320.0
    phase     gas;
}
