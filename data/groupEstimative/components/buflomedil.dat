/*--------------------------------*- Choupo -*-----------------------*\
  Component: buflomedil  (C17H25NO4, CAS 55837-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buflomedil;
formula     C17H25NO4;
CAS         55837-25-7;
InChIKey    OWYLAEYXIQKAOL-UHFFFAOYSA-N;
MW          307.39;      // g/mol [origin=calculated method=formula-sum]
Tc          986.98;      // K   [origin=predictive method=joback]
Pc          17.864;      // bar [origin=predictive method=joback]
omega       1.0719;      // -   [origin=predictive method=lee-kesler]
Tb          779.43;      // K   [origin=predictive method=joback]
HvapTb      74111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.293 1.43556 -0.00072118 1.0346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 2; } { group AC; count 4; } { group CH2CO; count 1; } { group CH3O; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pyrrolidin-1-yl-1-(2,4,6-trimethoxyphenyl)butan-1-one" "buflomedilum [inn-latin]" "4-(1-pyrrolidinyl)-1-(2,4,6-trimethoxyphenyl)-1-butanone" "1-butanone, 4-(1-pyrrolidinyl)-1-(2,4,6-trimethoxyphenyl)-" "(2,4,6-trimethoxyphenyl)(3-pyrrolidinopropyl) ketone" "blufomedil" "bufomedil" "buflomedilum" "buflomedil (inn)" "buflomedil [inn:ban:dcf]" "2,4,6-trimethoxyphenyl-3-pyrrolidine propyl ketone" "35543-24-9 (hydrochloride)" );
standardThermochemistry
{
    dHf_298   -546820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101000.0
}
