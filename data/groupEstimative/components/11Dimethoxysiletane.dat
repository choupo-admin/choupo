/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxysiletane  (C5H12O2Si, CAS 33446-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H12O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11Dimethoxysiletane;
formula     C5H12O2Si;
CAS         33446-84-3;
InChIKey    GZUPUZMCIXFGMH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          132.234;      // g/mol [origin=calculated method=formula-sum]
Tc          559.58;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.2958;      // -   [origin=predictive method=lee-kesler]
Tb          371.65;      // K   [origin=predictive method=joback]
HvapTb      32060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.98 0.32364 0.000113 -1.51e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH3O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxysilacyclobutane" "silacyclobutane, 1,1-dimethoxy-" "1,1-dimethoxy-1-silacyclobutane;1,1-dimethoxysilacyclobutane" );
standardThermochemistry
{
    dHf_298   -429450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255080.0
}
