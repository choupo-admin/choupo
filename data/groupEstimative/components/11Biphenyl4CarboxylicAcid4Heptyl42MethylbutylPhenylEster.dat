/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,1'-biphenyl)-4-carboxylic acid, 4'-heptyl-, 4-(2-methylbutyl)phenyl ester  (C31H38O2, CAS 71990-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Biphenyl4CarboxylicAcid4Heptyl42MethylbutylPhenylEster;
formula     C31H38O2;
CAS         71990-00-6;
InChIKey    OFPKTMNHQRPVJW-UHFFFAOYSA-N;
MW          442.643;      // g/mol [origin=calculated method=formula-sum]
Tc          1302.33;      // K   [origin=predictive method=joback]
Pc          9.567;      // bar [origin=predictive method=joback]
omega       0.9056;      // -   [origin=predictive method=lee-kesler]
Tb          1061.64;      // K   [origin=predictive method=joback]
HvapTb      100433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.382 2.48476 -0.00146368 3.019e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 12; } { group AC; count 4; } { group ACCH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-methylbutyl)phenyl] 4-(4-heptylphenyl)benzoate" "(1,1'-biphenyl)-4-carboxylic acid, 4'-heptyl-, 4-((2s)-2-methylbutyl)phenyl ester" "[1,1'-biphenyl]-4-carboxylic acid, 4'-heptyl-, 4-(2-methylbutyl)phenyl ester" "[1,1'-biphenyl]-4-carboxylic acid, 4'-heptyl-, 4-[(2s)-2-methylbutyl]phenyl ester" "(s)-4-(2-methylbutyl)phenyl 4'-heptyl(1,1'-biphenyl)-4-carboxylate" "[4-[(2s)-2-methylbutyl]phenyl] 4-(4-heptylphenyl)benzoate" );
gibbsFormation
{
    dHf_298   -330550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1067.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205670.0
    phase     gas;
}
