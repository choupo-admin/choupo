/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexene-1-octanoic acid, 5(or 6)-carboxy-4-hexyl-, mono(2-ethylhexyl) ester  (C29H52O4, CAS 72258-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexene1OctanoicAcid5Or6Carboxy4HexylMono2EthylhexylEst;
formula     C29H52O4;
CAS         72258-28-7;
InChIKey    YEOXVAODLOHRBS-YAOOYPAMSA-N;
MW          464.731;      // g/mol [origin=calculated method=formula-sum]
Tc          1329.58;      // K   [origin=predictive method=joback]
Pc          7.207;      // bar [origin=predictive method=joback]
omega       0.5813;      // -   [origin=predictive method=lee-kesler]
Tb          1075.78;      // K   [origin=predictive method=joback]
HvapTb      104434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.093 2.77386 -0.00149248 2.617e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 4; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2r,5s)-5-[8-[(2s)-2-ethylhexoxy]-8-oxidanylidene-octyl]-2-hexyl-cyclohex-3-ene-1-carboxylic acid" "(1s,2r,5s)-5-[8-[(2s)-2-ethylhexoxy]-8-oxooctyl]-2-hexylcyclohex-3-ene-1-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -1243300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1227.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-424430.0
}
