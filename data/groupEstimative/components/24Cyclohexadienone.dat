/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-cyclohexadienone  (C6H6O, CAS 24599-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Cyclohexadienone;
formula     C6H6O;
CAS         24599-57-3;
InChIKey    WQPDQJCBHQPNCZ-UHFFFAOYSA-N;
MW          94.113;      // g/mol [origin=calculated method=formula-sum]
Tc          659.69;      // K   [origin=predictive method=joback]
Pc          47.628;      // bar [origin=predictive method=joback]
omega       0.3034;      // -   [origin=predictive method=lee-kesler]
Tb          427.24;      // K   [origin=predictive method=joback]
HvapTb      34519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.12 0.4421 -0.00016956 -6.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexa-2,4-dien-1-one" "2,4-cyclohexadien-1-one" );
gibbsFormation
{
    dHf_298   -114650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     248.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30870.0
    phase     gas;
}
