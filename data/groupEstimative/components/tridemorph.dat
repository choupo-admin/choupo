/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridemorph  (C19H39NO, CAS 24602-86-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridemorph;
formula     C19H39NO;
CAS         24602-86-6;
InChIKey    YTOPFCCWCSOHFV-UHFFFAOYSA-N;
MW          297.527;      // g/mol [origin=calculated method=formula-sum]
Tc          859.10;      // K   [origin=predictive method=joback]
Pc          11.842;      // bar [origin=predictive method=joback]
omega       0.8435;      // -   [origin=predictive method=lee-kesler]
Tb          684.32;      // K   [origin=predictive method=joback]
HvapTb      64389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.298 2.03496 -0.0011805 2.549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 13; } { group CH; count 1; } { group CH-O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyl-4-tridecyl-morpholine" "2,6-dimethyl-4-tridecylmorpholine" "calixin" "calixine" "tridemorphe" "tridemorpn" "kalinin" "kalixin" "f 220 (fungicide)" "tridemorph [iso]" "basf 220f" "morpholine, 2,6-dimethyl-4-tridecyl-" );
standardThermochemistry
{
    dHf_298   -459820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     768.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162600.0
}
