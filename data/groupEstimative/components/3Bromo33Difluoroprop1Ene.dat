/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-3,3-difluoroprop-1-ene  (C3H3BrF2, CAS 420-90-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo33Difluoroprop1Ene;
formula     C3H3BrF2;
CAS         420-90-6;
InChIKey    GDDNTTHUKVNJRA-UHFFFAOYSA-N;
MW          156.957;      // g/mol [origin=calculated method=formula-sum]
Tc          507.08;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.2734;      // -   [origin=predictive method=lee-kesler]
Tb          326.39;      // K   [origin=predictive method=joback]
HvapTb      25107.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.93 0.4564 -0.0004383 1.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group Br; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-3,3-bis(fluoranyl)prop-1-ene" "3-bromo-3,3-difluoropropene" "propene, 3-bromo-3,3-difluoro-" "3,3-difluoro-3-bromopropene" "3-bromo-3,3-difluoro-1-propene" "1-bromo-1,1-difluoropropene" "1-propene, 3-bromo-3,3-difluoro-" "1-bromo-1,1-difluoroprop-2-ene" "propene,3-bromo-3,3-difluoro- (6ci,7ci,8ci);1,1-difluoroallyl bromide;3-bromo-3,3-difluoro-1-propene;" );
gibbsFormation
{
    dHf_298   -354460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     343.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310240.0
    phase     gas;
}
