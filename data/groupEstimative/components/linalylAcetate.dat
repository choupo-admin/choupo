/*--------------------------------*- Choupo -*-----------------------*\
  Component: linalyl acetate  (C12H20O2, CAS 115-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        linalylAcetate;
formula     C12H20O2;
CAS         115-95-7;
InChIKey    UWKAYLJWKGQEPM-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          720.17;      // K   [origin=predictive method=joback]
Pc          19.806;      // bar [origin=predictive method=joback]
omega       0.5551;      // -   [origin=predictive method=lee-kesler]
Tb          529.87;      // K   [origin=predictive method=joback]
HvapTb      47785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.948 1.21478 -0.0008152 2.13e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylocta-1,6-dien-3-yl ethanoate" "linalool acetate" "bergamiol" "bergamol" "acetic acid linalool ester" "linalol acetate" "lynalyl acetate" "licareol acetate" "bergamot mint oil" "1,6-octadien-3-ol, 3,7-dimethyl-, acetate" "3,7-dimethyl-1,6-octadien-3-ol acetate" "3,7-dimethyl-1,6-octadien-3-yl acetate" );
standardThermochemistry
{
    dHf_298   -384180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97860.0
}
