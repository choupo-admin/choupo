/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl morpholinoacetate  (C7H13NO3, CAS 35855-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylMorpholinoacetate;
formula     C7H13NO3;
CAS         35855-10-8;
InChIKey    LTMOFXOWXXOMEZ-UHFFFAOYSA-N;
MW          159.185;      // g/mol [origin=calculated method=formula-sum]
Tc          677.26;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.5801;      // -   [origin=predictive method=lee-kesler]
Tb          477.32;      // K   [origin=predictive method=joback]
HvapTb      45702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.859 0.89312 -0.0005439 1.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2COO; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-morpholin-4-ylethanoate" "methyl 2-morpholin-4-ylacetate" "morpholin-4-yl-acetic acid, methyl ester" "methyl 2-morpholinoacetate" "methyl 2-(morpholin-4-yl)acetate" "4-morpholineacetic acid methyl ester" "morpholin-4-ylacetic acid methyl ester" "methyl2-(morpholin-4-yl)acetate; methyl morpholinoacetate; morpholin-4-ylacetic acidmethyl ester" );
gibbsFormation
{
    dHf_298   -488740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-233390.0
    phase     gas;
}
