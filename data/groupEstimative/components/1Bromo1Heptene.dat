/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-1-heptene  (C7H13Br, CAS 89942-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo1Heptene;
formula     C7H13Br;
CAS         89942-12-1;
InChIKey    XNCAEAZUROUZKT-UHFFFAOYSA-N;
MW          177.085;      // g/mol [origin=calculated method=formula-sum]
Tc          621.77;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.4383;      // -   [origin=predictive method=lee-kesler]
Tb          430.08;      // K   [origin=predictive method=joback]
HvapTb      37569.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.466 0.72702 -0.0005122 1.536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylhept-1-ene" "agn-pc-00mjj4" "1-heptene, 1-bromo-, (e)-" );
gibbsFormation
{
    dHf_298   -44260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102600.0
    phase     gas;
}
