/*--------------------------------*- Choupo -*-----------------------*\
  Component: isf 2508  (C18H27ClN2O5, CAS 63007-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isf2508;
formula     C18H27ClN2O5;
CAS         63007-70-5;
InChIKey    LVHPHUGYIYSFTN-ZSCHJXSPSA-N;
MW          386.873;      // g/mol [origin=calculated method=formula-sum]
Tc          1410.63;      // K   [origin=predictive method=joback]
Pc          18.000;      // bar [origin=predictive method=joback]
omega       1.4970;      // -   [origin=predictive method=lee-kesler]
Tb          1151.71;      // K   [origin=predictive method=joback]
HvapTb      121486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.686 1.6355 -0.00080252 9.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group CHNH2; count 1; } { group COOH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group COOH; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2,6-bis(azanyl)hexanoic acid;2-[3-chloranyl-4-(cyclopropylmethoxy)phenyl]ethanoic acid" "2-(3-chloro-4-cyclopropylmethoxyphenyl)acetic acid lysine salt (d,l)" "acetic acid, 2-(3-chloro-4-(cyclopropylmethoxy)phenyl)-, lysine salt (d,l)" "2-[3-chloro-4-(cyclopropylmethoxy)phenyl]acetic acid; (2s)-2,6-diaminohexanoic acid" );
gibbsFormation
{
    dHf_298   -1026280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1000.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-524470.0
    phase     gas;
}
