/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1,1,3,3-tetramethylbutyl)hydroquinone  (C14H22O2, CAS 719-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21133TetramethylbutylHydroquinone;
formula     C14H22O2;
CAS         719-03-9;
InChIKey    RDMIJQCFPQDYQN-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          938.92;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       0.8516;      // -   [origin=predictive method=lee-kesler]
Tb          701.38;      // K   [origin=predictive method=joback]
HvapTb      72470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.529 1.8158 -0.00162532 5.909e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4,4-trimethylpentan-2-yl)benzene-1,4-diol" "1,4-benzenediol, 2-(1,1,3,3-tetramethylbutyl)-" "1,4-benzenediol,2-(1,1-dimethylhexyl)-" );
gibbsFormation
{
    dHf_298   -467880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124150.0
    phase     gas;
}
