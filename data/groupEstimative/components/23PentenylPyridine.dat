/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-pentenyl)pyridine  (C10H13N, CAS 2057-43-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23PentenylPyridine;
formula     C10H13N;
CAS         2057-43-4;
InChIKey    SKHYVKHUYKQNJE-UHFFFAOYSA-N;
MW          147.221;      // g/mol [origin=calculated method=formula-sum]
Tc          738.19;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.4491;      // -   [origin=predictive method=lee-kesler]
Tb          512.94;      // K   [origin=predictive method=joback]
HvapTb      46298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.228 0.92868 -0.00064446 1.825e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pent-3-enylpyridine" "pyridine, 2-(3-penten-1-yl)-" "pyridine,2-(3-penten-1-yl)-" "pyridine,2-(3-pentenyl)- (6ci,7ci,9ci);2-(3-pentenyl)pyridine;" );
standardThermochemistry
{
    dHf_298   136810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=303000.0
}
