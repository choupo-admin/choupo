/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl pyromellitate  (C12H10O8, CAS 13011-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylPyromellitate;
formula     C12H10O8;
CAS         13011-95-5;
InChIKey    QUNAYECDJMFUKV-UHFFFAOYSA-N;
MW          282.204;      // g/mol [origin=calculated method=formula-sum]
Tc          1152.82;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       1.5921;      // -   [origin=predictive method=lee-kesler]
Tb          923.24;      // K   [origin=predictive method=joback]
HvapTb      95710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.99 0.87844 -0.00041508 2.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 4; } { group COOH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(methoxycarbonyl)terephthalic acid" "1,2,4,5-benzenetetracarboxylic acid, 1,4-dimethyl ester" "1,2,4,5-benzenetetracarboxylicacid, 1,4-dimethyl ester" "1,4-dimethylpyromellitate; 2,5-dicarbomethoxyterephthalic acid; p-dimethyl pyromellitate" );
standardThermochemistry
{
    dHf_298   -1423990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1174880.0
}
