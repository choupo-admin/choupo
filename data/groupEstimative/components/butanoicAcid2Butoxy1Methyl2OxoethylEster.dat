/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanoic acid, 2-butoxy-1-methyl-2-oxoethyl ester  (C11H20O4, CAS 7492-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanoicAcid2Butoxy1Methyl2OxoethylEster;
formula     C11H20O4;
CAS         7492-70-8;
InChIKey    NORZZKKLCYMBBF-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          744.00;      // K   [origin=predictive method=joback]
Pc          19.648;      // bar [origin=predictive method=joback]
omega       0.8076;      // -   [origin=predictive method=lee-kesler]
Tb          567.28;      // K   [origin=predictive method=joback]
HvapTb      54506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.025 0.94516 -0.0003886 5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-butoxy-1-oxidanylidene-propan-2-yl) butanoate" "butyric acid, ester with butyl lactate" "butyl butyrolactate" "butyl butyryl lactate" "butyl o-butyryllactate" "1-butoxy-1-oxopropan-2-yl butanoate" "butyl butyryl lactate (natural)" "lactic acid, butyl ester, butyrate" "1-butoxy-1-oxopropan-2-yl butyrate" "2-butoxy-1-methyl-2-oxoethyl butanoate" "(1-butoxy-1-oxopropan-2-yl) butanoate" );
gibbsFormation
{
    dHf_298   -910210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     677.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-581440.0
    phase     gas;
}
