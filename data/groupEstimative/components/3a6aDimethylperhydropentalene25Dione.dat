/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3a,6a-dimethylperhydropentalene-2,5-dione  (C10H14O2, CAS 21170-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3a6aDimethylperhydropentalene25Dione;
formula     C10H14O2;
CAS         21170-10-5;
InChIKey    KGZWVKASYOPUET-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          844.02;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.4910;      // -   [origin=predictive method=lee-kesler]
Tb          586.54;      // K   [origin=predictive method=joback]
HvapTb      44216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.05 1.48364 -0.001445 6.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3a,6a-dimethyl-1,3,4,6-tetrahydropentalene-2,5-dione" "cis-1,5-dimethylbicyclo[3.3.0]octane-3,7-dione" "3a,6a-dimethyltetrahydro-2,5(1h,3h)-pentalenedione" "cis-3a,6a-dimethyltetrahydropentalene-2,5(1h,3h)-dione" "u895" "(3as,6as)-3a,6a-dimethyl-tetrahydropentalene-2,5-dione" "2,5(1h,3h)-pentalenedione, tetrahydro-3a,6a-dimethyl-" "cis-tetrahydro-3a,6a-dimethylpentalene-2,5(1h,3h)-dione" "2,5(1h,3h)-pentalenedione,tetrahydro-3a,6a-dimethyl-, cis-" "3a,6a-dimethyl-1,3,4,6,3a,6a-hexahydropentalene-2,5-dione" );
standardThermochemistry
{
    dHf_298   -361370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125540.0
}
