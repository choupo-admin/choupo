/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-chloroethoxy)ethanol  (C4H9ClO2, CAS 628-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22ChloroethoxyEthanol;
formula     C4H9ClO2;
CAS         628-89-7;
InChIKey    LECMBPWEOVZHKN-UHFFFAOYSA-N;
MW          124.564;      // g/mol [origin=calculated method=formula-sum]
Tc          612.53;      // K   [origin=predictive method=joback]
Pc          40.881;      // bar [origin=predictive method=joback]
omega       0.8162;      // -   [origin=predictive method=lee-kesler]
Tb          443.15;      // K   [origin=predictive method=joback]
HvapTb      47972.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.934 0.3614 -0.0001336 4e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2Cl; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chloroethyloxy)ethanol" "diglycol chlorohydrin" "ethanol, 2-(2-chloroethoxy)-" "diglycol chlorhydrin" "monochloropolyoxyethylene" "2-chloroethyl 2-hydroxyethyl ether" "diethylene glycol monochlorohydrin" "2-(2-chloroethoxy)ethan-1-ol" "poly(oxy-1,2-ethanediyl), alpha-(2-chloroethyl)-omega-hydroxy-" "lecmbpweovzhkn-uhfffaoysa-" "1-chloro-2-(ethoxydiphenylmethyl)benzene" "ethylene glycol mono-2-chloroethyl ether" );
gibbsFormation
{
    dHf_298   -426080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270950.0
    phase     gas;
}
