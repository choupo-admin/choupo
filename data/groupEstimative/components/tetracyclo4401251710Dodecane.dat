/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetracyclo[4.4.0.1(2,5).1(7,10)]dodecane  (C12H18, CAS 15914-95-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetracyclo4401251710Dodecane;
formula     C12H18;
CAS         15914-95-1;
InChIKey    VSHDEZHNJCSDFY-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          707.81;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.3931;      // -   [origin=predictive method=lee-kesler]
Tb          491.78;      // K   [origin=predictive method=joback]
HvapTb      41340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-197.11 1.6944 -0.001399 4.724e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-03j2tq" "tetracyclo[4.4.0.1(2,5).1(7,10)]dodeca-3-ene" "1,4:5,8-dimethanonaphthalene, decahydro-, (1alpha,4alpha,4aalpha,5alpha,8alpha,8aalpha)-" "1,4:5,8-dimethanonaphthalene, decahydro-,(1alpha,4alpha,4aalpha,5beta,8beta,8aalpha)-" "1,4:5,8-dimethanonaphthalene,decahydro-,(1.alpha.,4.alpha.,4a,8.beta.,8a.alpha.)-" "1,4:5,8-dimethanonaphthalene, decahydro-, (1.alpha.,4.alpha.,4a.alpha.,5.alpha.,8.alpha.,8a.alpha.)-" "1,4:5,8-dimethanonaphthalene, decahydro-,(1.alpha.,4.alpha.,4a.alpha.,5.beta.,8.beta.,8a.alpha.)-" );
standardThermochemistry
{
    dHf_298   -40490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     177.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=277740.0
}
