/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-1-ethoxy-2-(ethylthio)ethene  (C6H12OS, CAS 53715-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e1Ethoxy2EthylthioEthene;
formula     C6H12OS;
CAS         53715-47-2;
InChIKey    PGFRDWXAZUFOAF-AATRIKPKSA-N;
MW          132.221;      // g/mol [origin=calculated method=formula-sum]
Tc          630.31;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.4096;      // -   [origin=predictive method=lee-kesler]
Tb          432.24;      // K   [origin=predictive method=joback]
HvapTb      38135.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.352 0.52503 -0.0002352 2.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group CH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-ethoxy-2-ethylsulfanyl-ethene" "(e) 1-ethoxy-2-(ethylthio)ethene" "(e)-1-ethoxy-2-ethylsulfanylethene" );
standardThermochemistry
{
    dHf_298   -140300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7980.0
}
