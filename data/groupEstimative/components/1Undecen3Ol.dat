/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-undecen-3-ol  (C11H22O, CAS 35329-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Undecen3Ol;
formula     C11H22O;
CAS         35329-42-1;
InChIKey    NAOMHUDQUVEWEF-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          702.93;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       0.9404;      // -   [origin=predictive method=lee-kesler]
Tb          539.70;      // K   [origin=predictive method=joback]
HvapTb      55701.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.493 1.06872 -0.0006311 1.464e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undec-1-en-3-ol" );
standardThermochemistry
{
    dHf_298   -302450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9680.0
}
