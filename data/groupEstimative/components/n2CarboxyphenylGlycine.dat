/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-carboxyphenyl)glycine  (C9H9NO4, CAS 612-42-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2CarboxyphenylGlycine;
formula     C9H9NO4;
CAS         612-42-0;
InChIKey    PJUXPMVQAZLJEX-UHFFFAOYSA-N;
MW          195.174;      // g/mol [origin=calculated method=formula-sum]
Tc          1009.83;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       1.3797;      // -   [origin=predictive method=lee-kesler]
Tb          778.37;      // K   [origin=predictive method=joback]
HvapTb      79330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.909 0.8982 -0.00062376 1.63e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2NH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxy-2-oxoethylamino)benzoic acid" "n-(carboxymethyl)anthranilic acid" "2-[(carboxymethyl)amino]benzoic acid" "phenylglycine-o-carboxylic acid" "benzoic acid, 2-[(carboxymethyl)amino]-" "glycine, n-(o-carboxyphenyl)-" "2-(carboxymethylamino)benzoic acid" "2-(carboxymethyl-amino)-benzoic acid" "2-((carboxymethyl)amino)benzoic acid" "benzoic acid, 2-((carboxymethyl)amino)-" "n-phenylglycine-o-carboxylic acid" "anthranilic acid, n-(carboxymethyl)-" );
gibbsFormation
{
    dHf_298   -651100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-470750.0
    phase     gas;
}
