/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(3.2.1.02,4)octan-8-ol  (C8H12O, CAS 16384-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo321024Octan8Ol;
formula     C8H12O;
CAS         16384-97-7;
InChIKey    KKIDVQSXZVWGTL-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          672.33;      // K   [origin=predictive method=joback]
Pc          39.308;      // bar [origin=predictive method=joback]
omega       0.7268;      // -   [origin=predictive method=lee-kesler]
Tb          481.43;      // K   [origin=predictive method=joback]
HvapTb      49030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.82 1.2071 -0.001038 3.652e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 5; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00l19y" "tricyclo[3.2.1.02,4]octan-8-ol," "tricyclo[3.2.1.02,4]octan-8-ol,exo-syn-" "tricyclo[3.2.1.02,4]octan-8-ol,endo-anti-" "tricyclo[3.2.1.02,4]octan-8-ol,endo-syn-" "tricyclo(3.2.1.02,4)octan-8-ol, endo-anti-" "tricyclo(3.2.1.02,4)octan-8-ol, endo-syn-" );
standardThermochemistry
{
    dHf_298   -176800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     143.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58590.0
}
