/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-binaphthalene  (C20H14, CAS 612-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Binaphthalene;
formula     C20H14;
CAS         612-78-2;
InChIKey    MSBVBOUOMVTWKE-UHFFFAOYSA-N;
MW          254.332;      // g/mol [origin=calculated method=formula-sum]
Tc          1028.67;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       0.6861;      // -   [origin=predictive method=lee-kesler]
Tb          758.48;      // K   [origin=predictive method=joback]
HvapTb      69270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.39 1.6196 -0.00126596 3.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 14; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-naphthalen-2-ylnaphthalene" "2,2'-binaphthyl" "2,2'-dinaphthyl" "beta,beta'-binaphthyl" "2-naphthalen-2-ylnaphthalin" ".beta.,.beta.'-binaphthyl" "2,2'-binaphthyl (8ci)" "2-(naphthalen-2-yl)naphthalene" );
standardThermochemistry
{
    dHf_298   376130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=536380.0
}
