/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,7,7-tetramethyltricyclo[6.2.1.01,6]undec-5-en-4-yl acetate  (C17H26O2, CAS 32213-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2277Tetramethyltricyclo621016Undec5En4YlAcetate;
formula     C17H26O2;
CAS         32213-88-0;
InChIKey    DMRSABXLZDPVFE-UHFFFAOYSA-N;
MW          262.393;      // g/mol [origin=calculated method=formula-sum]
Tc          898.46;      // K   [origin=predictive method=joback]
Pc          18.659;      // bar [origin=predictive method=joback]
omega       0.6210;      // -   [origin=predictive method=lee-kesler]
Tb          671.06;      // K   [origin=predictive method=joback]
HvapTb      57809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-264.14 2.7048 -0.00278144 1.189e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group C; count 3; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-2,4a-methanonaphthalen-7-ol, 1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-, 7-acetate" "2h-2,4a-methanonaphthalen-7-ol, 1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-, acetate" "1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-2h-2,4a-methanonaphthalen-7-yl acetate" );
standardThermochemistry
{
    dHf_298   -454060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71620.0
}
