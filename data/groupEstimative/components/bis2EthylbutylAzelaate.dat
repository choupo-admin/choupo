/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-ethylbutyl) azelaate  (C21H40O4, CAS 105-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2EthylbutylAzelaate;
formula     C21H40O4;
CAS         105-03-3;
InChIKey    HFEFYTCEBRSONX-UHFFFAOYSA-N;
MW          356.547;      // g/mol [origin=calculated method=formula-sum]
Tc          977.25;      // K   [origin=predictive method=joback]
Pc          9.717;      // bar [origin=predictive method=joback]
omega       0.9056;      // -   [origin=predictive method=lee-kesler]
Tb          795.64;      // K   [origin=predictive method=joback]
HvapTb      76378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.253 1.90108 -0.0009358 1.235e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 13; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-ethylbutyl) nonanedioate" "di-2-ethylbutyl azelate" "bis(2-ethylbutyl) azelate" "nonanedioic acid,1,9-bis(2-ethylbutyl) ester" );
standardThermochemistry
{
    dHf_298   -1121890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1057.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-499680.0
}
