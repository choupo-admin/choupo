/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, diethyl-, dimethyl ester  (C12H22O4, CAS 72779-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidDiethylDimethylEster;
formula     C12H22O4;
CAS         72779-08-9;
InChIKey    BRNIGUHHISONID-UWVGGRQHSA-N;
MW          230.304;      // g/mol [origin=calculated method=formula-sum]
Tc          768.12;      // K   [origin=predictive method=joback]
Pc          18.201;      // bar [origin=predictive method=joback]
omega       0.8161;      // -   [origin=predictive method=lee-kesler]
Tb          589.72;      // K   [origin=predictive method=joback]
HvapTb      56344.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.434 1.04608 -0.0004462 1.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl (3s,4s)-3,4-diethylhexanedioate" "diethylhexanedioic acid, dimethyl ester" "hexanedioic acid, ethyl-, 1,6-dimethyl ester" "hexanedioic acid, 3,4-diethyl-, 1,6-dimethyl ester, (3s,4s)-" );
standardThermochemistry
{
    dHf_298   -936130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-575460.0
}
