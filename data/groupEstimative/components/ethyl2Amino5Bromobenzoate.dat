/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-amino-5-bromobenzoate  (C9H10BrNO2, CAS 63243-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Amino5Bromobenzoate;
formula     C9H10BrNO2;
CAS         63243-76-5;
InChIKey    PKWFESSNWKEZDP-UHFFFAOYSA-N;
MW          244.088;      // g/mol [origin=calculated method=formula-sum]
Tc          876.62;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.8169;      // -   [origin=predictive method=lee-kesler]
Tb          639.07;      // K   [origin=predictive method=joback]
HvapTb      63711.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.491 0.70622 -0.00038312 5.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-azanyl-5-bromanyl-benzoate" "2-amino-5-bromo-benzoic acid ethyl ester" "2-amino-5-bromobenzoic acid ethyl ester" "benzoicacid, 2-amino-5-bromo-, ethyl ester" "benzoic acid, 2-amino-5-bromo-, ethyl ester" "2-amino-5-bromobenzoicacid ethyl ester;5-bromoanthranilic acid ethyl ester;ethyl 5-bromoanthranilate;ethyl 2-amino-5-bromobenzoate;" );
standardThermochemistry
{
    dHf_298   -272660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111550.0
}
