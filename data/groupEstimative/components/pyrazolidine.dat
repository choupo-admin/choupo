/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrazolidine  (C3H8N2, CAS 504-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrazolidine;
formula     C3H8N2;
CAS         504-70-1;
InChIKey    USPWKWBDZOARPV-UHFFFAOYSA-N;
MW          72.111;      // g/mol [origin=calculated method=formula-sum]
Tc          606.85;      // K   [origin=predictive method=joback]
Pc          64.723;      // bar [origin=predictive method=joback]
omega       0.3260;      // -   [origin=predictive method=lee-kesler]
Tb          385.29;      // K   [origin=predictive method=joback]
HvapTb      36354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.42 0.4202 -0.000201 2.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diazolidine" "tetrahydropyrazole" "1,2-diazacyclopentane" "1,2-diazacyclopentane;1h-pyrazole, tetrahydro-; tetrahydropyrazole" );
standardThermochemistry
{
    dHf_298   51190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     252.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194060.0
}
