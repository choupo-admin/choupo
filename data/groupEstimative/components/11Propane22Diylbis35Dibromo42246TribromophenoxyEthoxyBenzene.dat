/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-propane-2,2-diylbis{3,5-dibromo-4-[2-(2,4,6-tribromophenoxy)ethoxy]benzene}  (C31H22Br10O4, CAS 60413-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Propane22Diylbis35Dibromo42246TribromophenoxyEthoxyBenzene;
formula     C31H22Br10O4;
CAS         60413-57-2;
InChIKey    XDDZQNKKDAKUBQ-UHFFFAOYSA-N;
MW          1257.553;      // g/mol [origin=calculated method=formula-sum]
Tc          2274.22;      // K   [origin=predictive method=joback]
Pc          17.232;      // bar [origin=predictive method=joback]
omega       1.2166;      // -   [origin=predictive method=lee-kesler]
Tb          1823.41;      // K   [origin=predictive method=joback]
HvapTb      174342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (170.114 2.17424 -0.00142472 3.546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 16; } { group CH2O; count 4; } { group Br; count 10; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 16; } { group Br; count 10; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[4-[2-[3,5-bis(bromanyl)-4-[2-[2,4,6-tris(bromanyl)phenoxy]ethoxy]phenyl]propan-2-yl]-2,6-bis(bromanyl)phenoxy]ethoxy]-1,3,5-tris(bromanyl)benzene" "benzene, 1,1'-(1-methylethylidene)bis(3,5-dibromo-4-(2-(2,4,6-tribromophenoxy)ethoxy)-" "benzene, 1,1'-(1-methylethylidene)bis[3,5-dibromo-4-[2-(2,4,6-tribromophenoxy)ethoxy]-" "benzene, 1,1-(1-methylethylidene)bis(3,5-dibromo-4-(2-(2,4,6-tribromophenoxy)ethoxy)-" "1,3,5-tribromo-2-[2-[2,6-dibromo-4-[2-[3,5-dibromo-4-[2-(2,4,6-tribromophenoxy)ethoxy]phenyl]propan-2-yl]phenoxy]ethoxy]benzene" );
gibbsFormation
{
    dHf_298   -149020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1380.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270260.0
    phase     gas;
}
