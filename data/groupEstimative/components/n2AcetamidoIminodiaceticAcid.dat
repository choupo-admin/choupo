/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-acetamido)iminodiacetic acid  (C6H10N2O5, CAS 26239-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2AcetamidoIminodiaceticAcid;
formula     C6H10N2O5;
CAS         26239-55-4;
InChIKey    QZTKDVCDBIDYMD-UHFFFAOYSA-N;
MW          190.155;      // g/mol [origin=calculated method=formula-sum]
Tc          981.35;      // K   [origin=predictive method=joback]
Pc          44.563;      // bar [origin=predictive method=joback]
omega       1.6143;      // -   [origin=predictive method=lee-kesler]
Tb          766.74;      // K   [origin=predictive method=joback]
HvapTb      82708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.793 0.8332 -0.0005851 1.5556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2N; count 1; } { group COOH; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CdO; count 1; } { group COOH; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-azanyl-2-oxidanylidene-ethyl)-(2-hydroxy-2-oxoethyl)amino]ethanoic acid" "carbamoylmethylaminodiacetic acid" "ada" "n-(carbamoylmethyl)iminodiacetic acid" "2,2'-((2-amino-2-oxoethyl)azanediyl)diacetic acid" "2,2'-[(2-amino-2-oxoethyl)imino]diacetic acid" "n-carbamoylmethyliminodi(acetic acid)" "glycine, n-(2-amino-2-oxoethyl)-n-(carboxymethyl)-" "(carbamoylmethyl-carboxymethyl-amino)-acetic acid" "mha" "2-[(carbamoylmethyl)(carboxymethyl)amino]acetic acid" "n-[2-acetamido]-2-iminodiacetic acid" );
gibbsFormation
{
    dHf_298   -878970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-639870.0
    phase     gas;
}
