/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-leucylglycine  (C8H16N2O3, CAS 686-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lLeucylglycine;
formula     C8H16N2O3;
CAS         686-50-0;
InChIKey    LESXFEZIFXFIQR-LURJTMIESA-N;
MW          188.227;      // g/mol [origin=calculated method=formula-sum]
Tc          912.27;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       1.2511;      // -   [origin=predictive method=lee-kesler]
Tb          703.84;      // K   [origin=predictive method=joback]
HvapTb      73613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.492 0.93654 -0.0005637 1.2346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[(2s)-2-azanyl-4-methyl-pentanoyl]amino]ethanoic acid" "n-l-leucylglycine" "l-leu-gly" "(s)-2-(2-amino-4-methylpentanamido)acetic acid" "l-leucylglycin" "leucyl-glycine" "l-leucyl-glycine" "h-leu-gly-oh" "glycine, n-l-leucyl-" "glycine, leucyl- (9ci)" "2-[[(2s)-2-amino-4-methylpentanoyl]amino]acetic acid" "dl-leucylglycine;2-(2-amino-4-methylpentanoylamino)acetic acid;" );
gibbsFormation
{
    dHf_298   -594600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-305390.0
    phase     gas;
}
