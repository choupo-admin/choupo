/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethyleneimine  (C6H13N, CAS 111-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethyleneimine;
formula     C6H13N;
CAS         111-49-9;
InChIKey    ZSIQJIWKELUFRJ-UHFFFAOYSA-N;
MW          99.177;      // g/mol [origin=calculated method=formula-sum]
Tc          637.67;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       0.2867;      // -   [origin=predictive method=lee-kesler]
Tb          413.92;      // K   [origin=predictive method=joback]
HvapTb      36618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.31 0.6994 -0.000332 3.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "azepane" "1h-azepine, hexahydro-" "homopiperidine" "perhydroazepine" "hexahydroazepine" "hexahydro-1h-azepine" "hexamethylenimine" "azacycloheptane" "hexamethylene imine" "azepine, hexahydro-" "cyclohexamethylenimine" "azepan" );
standardThermochemistry
{
    dHf_298   -60860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107410.0
}
