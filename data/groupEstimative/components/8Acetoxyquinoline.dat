/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-acetoxyquinoline  (C11H9NO2, CAS 2598-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Acetoxyquinoline;
formula     C11H9NO2;
CAS         2598-29-0;
InChIKey    MZPCTRNDYNHZQE-UHFFFAOYSA-N;
MW          187.198;      // g/mol [origin=calculated method=formula-sum]
Tc          859.00;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.6493;      // -   [origin=predictive method=lee-kesler]
Tb          613.84;      // K   [origin=predictive method=joback]
HvapTb      58275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.69 0.88568 -0.00059014 1.461e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3COO; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 3; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "quinolin-8-yl ethanoate" "quinolin-8-yl acetate" "8-quinolyl acetate" "8-acetyloxyquinoline" "8-quinolinol, acetate" "8-quinolinol acetate" "8-quinolinol, acetate (ester)" "8-quinolinol, 8-acetate" "-quinoline-carboxylic acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -138730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17850.0
}
