/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylnorcamphor  (C8H12O, CAS 10218-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylnorcamphor;
formula     C8H12O;
CAS         10218-04-9;
InChIKey    ZYVCBPCUGIGFJA-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          699.54;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.3590;      // -   [origin=predictive method=lee-kesler]
Tb          468.45;      // K   [origin=predictive method=joback]
HvapTb      36496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.55 1.17962 -0.001094 4.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylbicyclo[2.2.1]heptan-3-one" "bicyclo[2.2.1]heptan-2-one, 1-methyl" "bicyclo[2.2.1]heptan-2-one, 1-methyl-" );
gibbsFormation
{
    dHf_298   -191470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     297.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2200.0
    phase     gas;
}
