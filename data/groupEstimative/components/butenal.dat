/*--------------------------------*- Choupo -*-----------------------*\
  Component: butenal  (C4H6O, CAS 15798-64-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butenal;
formula     C4H6O;
CAS         15798-64-8;
InChIKey    MLUCVPSAIODCQM-UHFFFAOYSA-N;
MW          70.091;      // g/mol [origin=calculated method=formula-sum]
Tc          526.69;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       0.3227;      // -   [origin=predictive method=lee-kesler]
Tb          343.94;      // K   [origin=predictive method=joback]
HvapTb      31176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.53 0.37832 -0.0002706 8.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-enal" "2-butenal, (2z)-" "agn-pc-0d5uh0" "2-butenal, (2z)- (9ci)" "2-butenal,(e)-;crotonaldehyde, (e)- (8ci);(2e)-2-butenal;(e)-2-butenal;(e)-crotonaldehyde;2(e)-butenal;topanel ca;trans-2-buten-1-al;trans-2-butenal;trans-crotonal;trans-crotonaldehyde;" "2-butenal,(z)-; crotonaldehyde, (z)- (8ci); (z)-2-butenal; (z)-crotonaldehyde; ethylene,1-formyl-2-methyl-, cis-; cis-2-butenal; cis-crotonal; cis-crotonaldehyde" );
gibbsFormation
{
    dHf_298   -94250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36500.0
    phase     gas;
}
