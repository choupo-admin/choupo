/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-dibutylethylenediamine  (C10H24N2, CAS 4013-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDibutylethylenediamine;
formula     C10H24N2;
CAS         4013-95-0;
InChIKey    YRGVKPIUZUOJSJ-UHFFFAOYSA-N;
MW          172.316;      // g/mol [origin=calculated method=formula-sum]
Tc          698.26;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.8099;      // -   [origin=predictive method=lee-kesler]
Tb          528.74;      // K   [origin=predictive method=joback]
HvapTb      50726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.622 1.10624 -0.0006174 1.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-dibutylethane-1,2-diamine" "1,2-ethanediamine, n,n'-dibutyl-" "1,2-ethanediamine, n1,n2-dibutyl-" "butyl[2-(butylamino)ethyl]amine" "n,n'-di-n-butyl-ethylenediamine" "n ,n'-dibutylethylenediamine" );
standardThermochemistry
{
    dHf_298   -142790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212100.0
}
