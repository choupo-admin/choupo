/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-((3-mercapto-1-oxopropoxy)methyl)-2-methylpropane-1,3-diyl bis(3-mercaptopropionate)  (C14H24O6S3, CAS 10312-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Mercapto1OxopropoxyMethyl2Methylpropane13DiylBis3Mercaptop;
formula     C14H24O6S3;
CAS         10312-58-0;
InChIKey    NNLQLBLYOHQHCV-UHFFFAOYSA-N;
MW          384.52;      // g/mol [origin=calculated method=formula-sum]
Tc          1103.00;      // K   [origin=predictive method=joback]
Pc          18.325;      // bar [origin=predictive method=joback]
omega       1.2060;      // -   [origin=predictive method=lee-kesler]
Tb          879.93;      // K   [origin=predictive method=joback]
HvapTb      87894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (86.589 1.37712 -0.000693 7.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group CH2COO; count 3; } { group CH2SH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group C; count 1; } { group COO; count 3; } { group SH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-methyl-3-(3-sulfanylpropanoyloxy)-2-(3-sulfanylpropanoyloxymethyl)propyl] 3-sulfanylpropanoate" "propanoic acid, 3-mercapto-, 1,1'-(2-((3-mercapto-1-oxopropoxy)methyl)-2-methyl-1,3-propanediyl) ester" "propanoic acid, 3-mercapto-, 1,1'-[2-[(3-mercapto-1-oxopropoxy)methyl]-2-methyl-1,3-propanediyl] ester" "propanoic acid, 3-mercapto-, 2-((3-mercapto-1-oxopropoxy)methyl)-2-methyl-1,3-propanediyl ester" "propanoic acid, 3-mercapto-, 2-[(3-mercapto-1-oxopropoxy)methyl]-2-methyl-1,3-propanediyl ester" "2-methyl-3-[(3-sulfanylpropanoyl)oxy]-2-{[(3-sulfanylpropanoyl)oxy]methyl}propyl 3-sulfanylpropanoate" );
gibbsFormation
{
    dHf_298   -1177440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1003.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-773100.0
    phase     gas;
}
