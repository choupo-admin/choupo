/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrabutoxysilane  (C16H36O4Si, CAS 4766-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H36O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetrabutoxysilane;
formula     C16H36O4Si;
CAS         4766-57-8;
InChIKey    UQMOLLPKNHFRAC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          320.545;      // g/mol [origin=calculated method=formula-sum]
Tc          821.61;      // K   [origin=predictive method=joback]
Pc          11.554;      // bar [origin=predictive method=joback]
omega       0.8587;      // -   [origin=predictive method=lee-kesler]
Tb          656.76;      // K   [origin=predictive method=joback]
HvapTb      61144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (131.162 1.06488 1.22e-05 -2.572e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH2O; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrabutyl silicate" "tetrabutyl orthosilicate" "silane, tetrabutoxy-" "butyl silicate ((buo)4si)" "silicic acid (h4sio4), tetrabutyl ester" "silicon tetrabutoxide" "tetra-n-butoxysilane" "butyl silicate" "butyl silicate ((c4h9o)4si)" "o197" );
standardThermochemistry
{
    dHf_298   -1014070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     950.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-440920.0
}
