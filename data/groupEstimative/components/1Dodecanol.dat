/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dodecanol  (C12H26O, CAS 112-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dodecanol;
formula     C12H26O;
CAS         112-53-8;
InChIKey    LQZZUXJYWNFBMV-UHFFFAOYSA-N;
MW          186.339;      // g/mol [origin=calculated method=formula-sum]
Tc          724.16;      // K   [origin=predictive method=joback]
Pc          19.270;      // bar [origin=predictive method=joback]
omega       1.0263;      // -   [origin=predictive method=lee-kesler]
Tb          566.34;      // K   [origin=predictive method=joback]
HvapTb      58985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.729 1.17782 -0.0006594 1.414e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecan-1-ol" "dodecyl alcohol" "lauryl alcohol" "dodecanol" "lauric alcohol" "laurinic alcohol" "undecyl carbinol" "n-dodecyl alcohol" "n-dodecan-1-ol" "pisol" "duodecyl alcohol" "1-hydroxydodecane" );
gibbsFormation
{
    dHf_298   -443240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86660.0
    phase     gas;
}
