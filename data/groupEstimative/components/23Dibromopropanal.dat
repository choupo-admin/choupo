/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromopropanal  (C3H4Br2O, CAS 5221-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dibromopropanal;
formula     C3H4Br2O;
CAS         5221-17-0;
InChIKey    ZMDDOWQHSDJXDW-UHFFFAOYSA-N;
MW          215.872;      // g/mol [origin=calculated method=formula-sum]
Tc          669.47;      // K   [origin=predictive method=joback]
Pc          60.467;      // bar [origin=predictive method=joback]
omega       0.5335;      // -   [origin=predictive method=lee-kesler]
Tb          448.78;      // K   [origin=predictive method=joback]
HvapTb      41474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.261 0.3456 -0.0002784 9.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CHO; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Br; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)propanal" "dibromopropanal" "propanal, 2,3-dibromo-" "2,3-dibromopropionaldehyde" "acrolein dibromide" "2,3-dibromopropional" "propionaldehyde, 2,3-dibromo-" "propanal,3-dibromo-" "propionaldehyde,3-dibromo-" "propanal, 2,3-dibromo- (9ci)" );
standardThermochemistry
{
    dHf_298   -143450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98940.0
}
