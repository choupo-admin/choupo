/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-bis(chloromethyl)-1,3,5-trimethylbenzene  (C11H14Cl2, CAS 1585-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24BisChloromethyl135Trimethylbenzene;
formula     C11H14Cl2;
CAS         1585-17-7;
InChIKey    JMNDJDCLOQRCJV-UHFFFAOYSA-N;
MW          217.133;      // g/mol [origin=calculated method=formula-sum]
Tc          789.13;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.5528;      // -   [origin=predictive method=lee-kesler]
Tb          572.74;      // K   [origin=predictive method=joback]
HvapTb      53774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.962 0.74556 -0.00037844 6.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 3; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloromethyl)-1,3,5-trimethyl-benzene" "2,4-bis(chloromethyl)mesitylene" "2,4-di(chloromethyl)-1,3,5-trimethylbenzene" "benzene, 2,4-bis(chloromethyl)-1,3,5-trimethyl-" "bis-(chloromethyl)-mesitylene" "2,4-bis(chloromethylmesitylene)" "jmndjdcloqrcjv-uhfffaoysa-" "benzene,4-bis(chloromethyl)-1,3,5-trimethyl-" "2,4-bis-(chloromethy6l)-1,3,5-trimethyl-benzene" );
standardThermochemistry
{
    dHf_298   -111200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91770.0
}
