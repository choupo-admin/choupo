/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolethane monononanoate  (C14H28O4, CAS 67953-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolethaneMonononanoate;
formula     C14H28O4;
CAS         67953-15-5;
InChIKey    FGFLOEFTQIRCEW-UHFFFAOYSA-N;
MW          260.374;      // g/mol [origin=calculated method=formula-sum]
Tc          934.00;      // K   [origin=predictive method=joback]
Pc          18.046;      // bar [origin=predictive method=joback]
omega       1.4368;      // -   [origin=predictive method=lee-kesler]
Tb          759.27;      // K   [origin=predictive method=joback]
HvapTb      86227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.68 1.47284 -0.0008758 1.898e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group C; count 1; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group C; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(hydroxymethyl)-2-methyl-3-oxidanyl-propyl] nonanoate" "nonanoic acid 3-hydroxy-2-(hydroxymethyl)-2-methylpropyl ester" "3-hydroxy-2-(hydroxymethyl)-2-methylpropyl nonanoate" "nonanoic acid, 3-hydroxy-2-(hydroxymethyl)-2-methylpropyl ester" "1,1,1-trimethylolethanemonopelargonate" "[3-hydroxy-2-(hydroxymethyl)-2-methylpropyl] nonanoate" );
standardThermochemistry
{
    dHf_298   -962780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     815.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-514170.0
}
