/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetylmorphine  (C19H21NO4, CAS 5140-28-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetylmorphine;
formula     C19H21NO4;
CAS         5140-28-3;
InChIKey    GMLREHXYJDLZOU-LEPYJNQMSA-N;
MW          327.38;      // g/mol [origin=calculated method=formula-sum]
Tc          1104.94;      // K   [origin=predictive method=joback]
Pc          22.104;      // bar [origin=predictive method=joback]
omega       1.3795;      // -   [origin=predictive method=lee-kesler]
Tb          883.15;      // K   [origin=predictive method=joback]
HvapTb      91101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-200.18 2.47414 -0.00226606 8.482e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3COO; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(4r,4ar,7s,7ar,12bs)-3-methyl-7-oxidanyl-2,4,4a,7,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-9-yl] ethanoate" "morphine, acetyl-" "morphine, monoacetyl-" "o(3)-monoacetylmorphine" "3-monoacetylmorphine" "morphinan-3,6-alpha-diol, 7,8-didehydro-4,5-alpha-epoxy-17-methyl-, acetate" );
gibbsFormation
{
    dHf_298   -417310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41950.0
    phase     gas;
}
