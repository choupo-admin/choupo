/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromomethyl methyl ether  (C2H5BrO, CAS 13057-17-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromomethylMethylEther;
formula     C2H5BrO;
CAS         13057-17-5;
InChIKey    JAMFGQBENKSWOF-UHFFFAOYSA-N;
MW          124.965;      // g/mol [origin=calculated method=formula-sum]
Tc          521.04;      // K   [origin=predictive method=joback]
Pc          54.225;      // bar [origin=predictive method=joback]
omega       0.3061;      // -   [origin=predictive method=lee-kesler]
Tb          333.94;      // K   [origin=predictive method=joback]
HvapTb      28891.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.761 0.16882 -4.54e-05 -8.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanyl(methoxy)methane" "methane, bromomethoxy-" "bromo(methoxy)methane" "ether, bromomethyl methyl" "methoxymethyl bromide" "bromomethylil methul ether" );
gibbsFormation
{
    dHf_298   -190500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     296.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124720.0
    phase     gas;
}
