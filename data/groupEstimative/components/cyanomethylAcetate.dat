/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyanomethyl acetate  (C4H5NO2, CAS 1001-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyanomethylAcetate;
formula     C4H5NO2;
CAS         1001-55-4;
InChIKey    AJEHNBIPLQJTNU-UHFFFAOYSA-N;
MW          99.089;      // g/mol [origin=calculated method=formula-sum]
Tc          651.36;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.5202;      // -   [origin=predictive method=lee-kesler]
Tb          451.42;      // K   [origin=predictive method=joback]
HvapTb      42383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.661 0.26382 -6.82e-05 -2.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3COO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group COO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyanomethyl ethanoate" "acetoxyacetonitrile" "glycolonitrile, acetate" "glycolonitrile, acetate (ester)" "acetonitrile, (acetyloxy)-" "acetyloxyacetonitrile" "2-acetoxyacetonitrile" "acetic acid cyanomethyl ester" "(acetyloxy)acetonitrile" "kyanmethylester kyseliny octove" "acetonitrile, (acetyloxy)- (9ci)" "glycolonitrile, acetate (ester) (8ci)" );
standardThermochemistry
{
    dHf_298   -278290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194390.0
}
