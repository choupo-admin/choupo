/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, p-bis(1-ethylpropyl)-  (C16H26, CAS 31173-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenePBis1Ethylpropyl;
formula     C16H26;
CAS         31173-90-7;
InChIKey    HBAMTXJBZXCUOV-UHFFFAOYSA-N;
MW          218.384;      // g/mol [origin=calculated method=formula-sum]
Tc          794.10;      // K   [origin=predictive method=joback]
Pc          17.047;      // bar [origin=predictive method=joback]
omega       0.6075;      // -   [origin=predictive method=lee-kesler]
Tb          596.46;      // K   [origin=predictive method=joback]
HvapTb      53372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.626 1.39728 -0.00081716 1.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-di(pentan-3-yl)benzene" "benzene, 1,4-bis(1-ethylpropyl)-" "1,4-bis(3-pentyl)benzene" );
standardThermochemistry
{
    dHf_298   -159070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181740.0
}
