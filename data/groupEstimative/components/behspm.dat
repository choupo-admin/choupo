/*--------------------------------*- Choupo -*-----------------------*\
  Component: behspm  (C16H38N4, CAS 119422-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        behspm;
formula     C16H38N4;
CAS         119422-08-1;
InChIKey    QXOCYGPVDXDFLC-UHFFFAOYSA-N;
MW          286.508;      // g/mol [origin=calculated method=formula-sum]
Tc          944.18;      // K   [origin=predictive method=joback]
Pc          13.697;      // bar [origin=predictive method=joback]
omega       1.1732;      // -   [origin=predictive method=lee-kesler]
Tb          766.36;      // K   [origin=predictive method=joback]
HvapTb      76954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.496 1.82864 -0.001041 2.212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2NH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group NH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n'-[4-[4-(ethylamino)butylamino]butyl]butane-1,4-diamine" "dehspm" "diethylhomospermine" "n(1),n(14)-bis(ethyl)homospermine" "be-4-4-4" "n1 n14-bis(ethyl)norspermine" "1,14-bis(ethylamino)-5,10-diazatetradecane" "n(sup 1),n(sup 14)-diethylhomospermine" "n(sup 1),n(sup 14)-bis(ethyl)homospermine" "n,n'-bis(4-(ethylamino)butyl)-1,4-butanediamine" "1,4-butanediamine, n,n'-bis(4-(ethylamino)butyl)-" "n(1),n(14)-diethylhomospermine" );
standardThermochemistry
{
    dHf_298   -159690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     941.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=441400.0
}
