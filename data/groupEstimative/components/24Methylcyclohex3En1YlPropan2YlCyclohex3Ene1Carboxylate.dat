/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-methylcyclohex-3-en-1-yl)propan-2-yl cyclohex-3-ene-1-carboxylate  (C17H26O2, CAS 207505-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Methylcyclohex3En1YlPropan2YlCyclohex3Ene1Carboxylate;
formula     C17H26O2;
CAS         207505-73-5;
InChIKey    BJTYRNANPWPOGC-UHFFFAOYSA-N;
MW          262.393;      // g/mol [origin=calculated method=formula-sum]
Tc          916.91;      // K   [origin=predictive method=joback]
Pc          17.970;      // bar [origin=predictive method=joback]
omega       0.6105;      // -   [origin=predictive method=lee-kesler]
Tb          685.95;      // K   [origin=predictive method=joback]
HvapTb      61651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.98 1.76256 -0.00104772 2.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclohexene-1-carboxylic acid 1-methyl-1-(4-methyl-3-cyclohexen-1-yl)ethyl ester" "agn-pc-02xawj" "3-cyclohexene-1-carboxylic acid, 1-methyl-1-(4-methyl-3-cyclohexen-1-yl)ethyl ester" );
standardThermochemistry
{
    dHf_298   -507510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116080.0
}
