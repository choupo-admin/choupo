/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloranylprop-1-enylbenzene  (C9H9Cl, CAS 35673-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloranylprop1Enylbenzene;
formula     C9H9Cl;
CAS         35673-03-1;
InChIKey    FCJBLLVHGCDVAG-UHFFFAOYSA-N;
MW          152.621;      // g/mol [origin=calculated method=formula-sum]
Tc          702.86;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.3372;      // -   [origin=predictive method=lee-kesler]
Tb          473.67;      // K   [origin=predictive method=joback]
HvapTb      42327.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.18 0.80662 -0.0006035 1.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   99130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197050.0
}
