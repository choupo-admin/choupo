/*--------------------------------*- Choupo -*-----------------------*\
  Component: nicotinic acid, 2-(1-adamantyl)ethyl ester  (C18H23NO2, CAS 64140-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nicotinicAcid21AdamantylEthylEster;
formula     C18H23NO2;
CAS         64140-39-2;
InChIKey    AVSOLGBUADYZAD-UHFFFAOYSA-N;
MW          285.387;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.48;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       0.8131;      // -   [origin=predictive method=lee-kesler]
Tb          770.10;      // K   [origin=predictive method=joback]
HvapTb      70006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-211.808 2.32236 -0.00199266 7.11e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 3; } { group C; count 1; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-adamantyl)ethyl pyridine-3-carboxylate" "1-admantylethyl nicotinate" "3-pyridinecarboxylic acid, 2-(1-admantyl)ethyl ester" "3-pyridinecarboxylic acid, 2-tricyclo(3.3.1.1(sup 3,7))dec-1-ylethyl ester" "2-(1-adamantyl)ethyl nicotinate" "3-pyridinecarboxylicacid, 2-tricyclo[3.3.1.13,7]dec-1-ylethyl ester" );
gibbsFormation
{
    dHf_298   -255670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136720.0
    phase     gas;
}
