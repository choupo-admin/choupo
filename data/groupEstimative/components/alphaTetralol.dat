/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-tetralol  (C10H12O, CAS 529-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaTetralol;
formula     C10H12O;
CAS         529-33-9;
InChIKey    JAAJQSRLGAYGKZ-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          778.07;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.7884;      // -   [origin=predictive method=lee-kesler]
Tb          563.25;      // K   [origin=predictive method=joback]
HvapTb      57556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.88 0.9907 -0.00068856 1.876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrahydronaphthalen-1-ol" "1,2,3,4-tetrahydro-1-naphthol" "1-tetralol" "tetralin-1-ol" "1-naphthalenol, 1,2,3,4-tetrahydro-" "1-hydroxytetralin" "1-naphthol, 1,2,3,4-tetrahydro-" "tetrahydro-1-naphthol (van)" "1,2,3,4-tetrahydro-alpha-naphthol" "1,2,3,4-tetrahydronaphthol" "ac-alpha-tetralol" ".alpha.-tetralol" );
standardThermochemistry
{
    dHf_298   -110260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47930.0
}
