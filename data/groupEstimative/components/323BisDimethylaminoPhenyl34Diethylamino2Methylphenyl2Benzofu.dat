/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[2,3-bis(dimethylamino)phenyl]-3-[4-(diethylamino)-2-methylphenyl]-2-benzofuran-1(3h)-one  (C29H35N3O2, CAS 52830-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        323BisDimethylaminoPhenyl34Diethylamino2Methylphenyl2Benzofu;
formula     C29H35N3O2;
CAS         52830-80-5;
InChIKey    AQZWDNQWFXEMFU-UHFFFAOYSA-N;
MW          457.618;      // g/mol [origin=calculated method=formula-sum]
Tc          1303.70;      // K   [origin=predictive method=joback]
Pc          11.413;      // bar [origin=predictive method=joback]
omega       1.0563;      // -   [origin=predictive method=lee-kesler]
Tb          1062.04;      // K   [origin=predictive method=joback]
HvapTb      102240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.348 3.00364 -0.002401 7.981e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 7; } { group ACCH3; count 1; } { group CH3N; count 2; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 2; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group COO; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2,3-bis(dimethylamino)phenyl]-3-[4-(diethylamino)-2-methyl-phenyl]-2-benzofuran-1-one" "1(3h)-isobenzofuranone, 3-(2,4-bis(dimethylamino)phenyl)-3-(4-(diethylamino)-2-methylphenyl)-" "1(3h)-isobenzofuranone, 3-[2,4-bis(dimethylamino)phenyl]-3-[4-(diethylamino)-2-methylphenyl]-" "3-(2,4-bis(dimethylamino)phenyl)-3-(4-(diethylamino)-o-tolyl)phthalide" "3-[2,3-bis(dimethylamino)phenyl]-3-[4-(diethylamino)-2-methylphenyl]-2-benzofuran-1-one" );
standardThermochemistry
{
    dHf_298   -3980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     974.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=583810.0
}
