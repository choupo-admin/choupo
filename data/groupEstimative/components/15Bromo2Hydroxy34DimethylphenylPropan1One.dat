/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(5-bromo-2-hydroxy-3,4-dimethylphenyl)propan-1-one  (C11H13BrO2, CAS 5384-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Bromo2Hydroxy34DimethylphenylPropan1One;
formula     C11H13BrO2;
CAS         5384-03-2;
InChIKey    LTINARLTQHMYIB-UHFFFAOYSA-N;
MW          257.127;      // g/mol [origin=calculated method=formula-sum]
Tc          929.83;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.9589;      // -   [origin=predictive method=lee-kesler]
Tb          693.55;      // K   [origin=predictive method=joback]
HvapTb      70537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.511 0.95626 -0.00071374 2.2866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 2; } { group ACOH; count 1; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Br; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5-bromanyl-3,4-dimethyl-2-oxidanyl-phenyl)propan-1-one" "propiophenone, 5-bromo-3,4-dimethyl-2-hydroxy-" "propiophenone, 5-bromo-3,4-dimethyl-2-hydroxy-," "propiophenone, 5'-bromo-2'-hydroxy-3',4'-dimethyl-" "1-(5-bromo-2-hydroxy-3,4-dimethyl-phenyl)propan-1-one" );
standardThermochemistry
{
    dHf_298   -331810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143960.0
}
