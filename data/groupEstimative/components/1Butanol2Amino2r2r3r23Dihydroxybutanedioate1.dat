/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butanol, 2-amino-, (2r)-, (2r,3r)-2,3-dihydroxybutanedioate (1:?)  (C8H17NO7, CAS 14621-07-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butanol2Amino2r2r3r23Dihydroxybutanedioate1;
formula     C8H17NO7;
CAS         14621-07-9;
InChIKey    ZMEGDKGDGOQGDK-SRRYXMDWSA-N;
MW          239.224;      // g/mol [origin=calculated method=formula-sum]
Tc          1253.05;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       2.2665;      // -   [origin=predictive method=lee-kesler]
Tb          1022.81;      // K   [origin=predictive method=joback]
HvapTb      127538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.952 0.84082 -0.000286 -3.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 3; } { group CHNH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 3; } { group OH; count 3; } { group COOH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanylbutan-1-ol;(2r,3r)-2,3-bis(oxidanyl)butanedioic acid" "1-butanol, 2-amino-, (2r)-, (2r,3r)-2,3-dihydroxybutanedioate (salt)" );
standardThermochemistry
{
    dHf_298   -1459350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     857.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1127430.0
}
