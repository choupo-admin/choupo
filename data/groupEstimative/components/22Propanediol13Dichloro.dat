/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-propanediol, 1,3-dichloro-  (C3H6Cl2O2, CAS 82598-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Propanediol13Dichloro;
formula     C3H6Cl2O2;
CAS         82598-72-9;
InChIKey    BJCFYPFSEIJWLQ-UHFFFAOYSA-N;
MW          144.979;      // g/mol [origin=calculated method=formula-sum]
Tc          704.09;      // K   [origin=predictive method=joback]
Pc          52.739;      // bar [origin=predictive method=joback]
omega       1.1867;      // -   [origin=predictive method=lee-kesler]
Tb          524.23;      // K   [origin=predictive method=joback]
HvapTb      63104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.052 0.4962 -0.0004128 1.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group OH; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group Cl; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)propane-2,2-diol" "1,3-dichloropropane-2,2-diol" );
standardThermochemistry
{
    dHf_298   -449940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-320280.0
}
