/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyltetradecylamine  (C15H33N, CAS 29369-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyltetradecylamine;
formula     C15H33N;
CAS         29369-63-9;
InChIKey    QWERMLCFPMTLTG-UHFFFAOYSA-N;
MW          227.436;      // g/mol [origin=calculated method=formula-sum]
Tc          755.64;      // K   [origin=predictive method=joback]
Pc          14.294;      // bar [origin=predictive method=joback]
omega       0.8435;      // -   [origin=predictive method=lee-kesler]
Tb          592.97;      // K   [origin=predictive method=joback]
HvapTb      55420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.957 1.50504 -0.0008408 1.778e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyltetradecan-1-amine" "methyl(tetradecyl)amine" "1-tetradecanamine,n-methyl-" "n-methyl tetradecylamine" "tetradecylamine,n-methyl- (7ci,8ci); n-methyltetradecanamine; n-methyltetradecylamine;n-n-tetradecylmethylamine; n-tetradecylmethylamine" );
gibbsFormation
{
    dHf_298   -299460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164810.0
    phase     gas;
}
