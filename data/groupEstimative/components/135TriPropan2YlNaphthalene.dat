/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tri(propan-2-yl)naphthalene  (C19H26, CAS 35860-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135TriPropan2YlNaphthalene;
formula     C19H26;
CAS         35860-37-8;
InChIKey    PTNBGJZNHOSDLZ-UHFFFAOYSA-N;
MW          254.417;      // g/mol [origin=calculated method=formula-sum]
Tc          911.41;      // K   [origin=predictive method=joback]
Pc          16.168;      // bar [origin=predictive method=joback]
omega       0.6700;      // -   [origin=predictive method=lee-kesler]
Tb          693.60;      // K   [origin=predictive method=joback]
HvapTb      62626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.88 1.56552 -0.0009862 2.453e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 5; } { group AC; count 2; } { group ACCH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triisopropylnaphthalene" "naphthalene, tris(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -58140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291950.0
}
