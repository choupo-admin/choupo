/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-silabicyclo[2.2.1]heptane  (C6H10Si, CAS 328-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H10Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        7Silabicyclo221Heptane;
formula     C6H10Si;
CAS         328-56-3;
InChIKey    TYGLYVFHLGRRAU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          110.231;      // g/mol [origin=calculated method=formula-sum]
Tc          545.73;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.2227;      // -   [origin=predictive method=lee-kesler]
Tb          350.36;      // K   [origin=predictive method=joback]
HvapTb      28776.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.05 0.8756 -0.000743 2.588e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7$l^{2}-silabicyclo[2.2.1]heptane" "7-silabicyclo(2.2.1)heptane" "7-silanorbornane" );
standardThermochemistry
{
    dHf_298   -21570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     228.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121140.0
}
