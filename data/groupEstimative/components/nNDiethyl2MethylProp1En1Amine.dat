/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-2-methyl-prop-1-en-1-amine  (C8H17N, CAS 16826-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl2MethylProp1En1Amine;
formula     C8H17N;
CAS         16826-16-7;
InChIKey    ZUUSZQFQQORMCE-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          573.01;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.3985;      // -   [origin=predictive method=lee-kesler]
Tb          399.12;      // K   [origin=predictive method=joback]
HvapTb      35483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.948 0.90768 -0.0006101 1.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -33490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198930.0
}
