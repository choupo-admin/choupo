/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzo-15-crown-5  (C18H20O5, CAS 14262-60-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzo15Crown5;
formula     C18H20O5;
CAS         14262-60-3;
InChIKey    QSBFECWPKSRWNM-UHFFFAOYSA-N;
MW          316.353;      // g/mol [origin=calculated method=formula-sum]
Tc          1134.12;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.8657;      // -   [origin=predictive method=lee-kesler]
Tb          855.08;      // K   [origin=predictive method=joback]
HvapTb      85686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.23 1.5226 -0.00071862 4.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 8; } { group AC; count 4; } { group FCH2O; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7,9,10,17,18-hexahydrodibenzo[b,h][1,4,7,10,13]pentaoxacyclopentadecine" "diabenzo-15-crown-5" "dibenzo-15-crown 5-ether" "5,6,7,8,9,10,11,16,17,18,19-undecahydrodibenzo[a,g][15]annulene" );
gibbsFormation
{
    dHf_298   -580870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152700.0
    phase     gas;
}
