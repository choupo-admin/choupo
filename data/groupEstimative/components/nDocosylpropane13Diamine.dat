/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-docosylpropane-1,3-diamine  (C25H54N2, CAS 15268-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nDocosylpropane13Diamine;
formula     C25H54N2;
CAS         15268-40-3;
InChIKey    BIWCZXIHIQDFSM-UHFFFAOYSA-N;
MW          382.721;      // g/mol [origin=calculated method=formula-sum]
Tc          1096.92;      // K   [origin=predictive method=joback]
Pc          7.944;      // bar [origin=predictive method=joback]
omega       0.7396;      // -   [origin=predictive method=lee-kesler]
Tb          894.30;      // K   [origin=predictive method=joback]
HvapTb      88321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.556 2.51692 -0.0014282 3.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 22; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 24; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-docosylpropane-1,3-diamine" "1,3-propanediamine, n-docosyl-" "1,3-propanediamine, n1-docosyl-" );
standardThermochemistry
{
    dHf_298   -472070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1222.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=315460.0
}
