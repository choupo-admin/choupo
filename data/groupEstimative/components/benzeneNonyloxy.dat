/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, (nonyloxy)-  (C15H24O, CAS 36588-31-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneNonyloxy;
formula     C15H24O;
CAS         36588-31-5;
InChIKey    GSGDTSDELPUTKU-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          782.18;      // K   [origin=predictive method=joback]
Pc          18.201;      // bar [origin=predictive method=joback]
omega       0.7006;      // -   [origin=predictive method=lee-kesler]
Tb          591.90;      // K   [origin=predictive method=joback]
HvapTb      53670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.152 1.28672 -0.0007124 1.38e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonoxybenzene" );
standardThermochemistry
{
    dHf_298   -248620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82830.0
}
