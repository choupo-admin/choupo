/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl 3-phenylpropanoate  (C12H14O2, CAS 15814-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allyl3Phenylpropanoate;
formula     C12H14O2;
CAS         15814-45-6;
InChIKey    XZZUAUYBSOXKLR-UHFFFAOYSA-N;
MW          190.242;      // g/mol [origin=calculated method=formula-sum]
Tc          763.50;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       0.6131;      // -   [origin=predictive method=lee-kesler]
Tb          555.74;      // K   [origin=predictive method=joback]
HvapTb      51319.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.507 0.9901 -0.0005885 1.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 3-phenylpropanoate" "allyl 3-phenylpropionate" "benzenepropanoic acid, 2-propenyl ester" "benzenepropanoic acid, 2-propen-1-yl ester" "hydrocinnamic acid, allyl ester" "3-phenyl-propionic acid allyl ester" );
standardThermochemistry
{
    dHf_298   -246330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59960.0
}
