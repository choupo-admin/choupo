/*--------------------------------*- Choupo -*-----------------------*\
  Component: sec-butyl methyl ether  (C5H12O, CAS 6795-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        secButylMethylEther;
formula     C5H12O;
CAS         6795-87-5;
InChIKey    FVNIMHIOIXPIQT-UHFFFAOYSA-N;
MW          88.15;      // g/mol [origin=calculated method=formula-sum]
Tc          504.33;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.3003;      // -   [origin=predictive method=lee-kesler]
Tb          335.98;      // K   [origin=predictive method=joback]
HvapTb      28746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.161 0.42156 -0.0001404 -7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxybutane" "butane, 2-methoxy-" "ether, sec-butyl methyl" "2-butyl methyl ether" "methyl sec-butyl ether" "methyl 1-methylpropyl ether" "s-butyl methyl ether" "agn-pc-0d67k4" "butane, 2-methoxy- (9ci)" "ether,sec-butyl methyl (6ci,7ci,8ci);butane, 2-methoxy- (9ci);2-butyl methyl ether;2-methoxybutane;methyl1-methylpropyl ether;methyl sec-butyl ether;sec-butyl methyl ether;" );
gibbsFormation
{
    dHf_298   -284030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116220.0
    phase     gas;
}
