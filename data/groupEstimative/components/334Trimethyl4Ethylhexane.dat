/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4-trimethyl-4-ethylhexane  (C11H24, CAS 61868-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        334Trimethyl4Ethylhexane;
formula     C11H24;
CAS         61868-84-6;
InChIKey    ADDYWUNUHVKQGT-UHFFFAOYSA-N;
MW          156.313;      // g/mol [origin=calculated method=formula-sum]
Tc          627.08;      // K   [origin=predictive method=joback]
Pc          20.001;      // bar [origin=predictive method=joback]
omega       0.3573;      // -   [origin=predictive method=lee-kesler]
Tb          444.82;      // K   [origin=predictive method=joback]
HvapTb      37488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.057 1.30052 -0.0009182 2.635e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group C; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-3,4,4-trimethyl-hexane" );
standardThermochemistry
{
    dHf_298   -287870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47420.0
}
