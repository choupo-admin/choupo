/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-2-methoxy-1-(o-methoxyphenyl)propene  (C11H14O2, CAS 101948-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e2Methoxy1OMethoxyphenylPropene;
formula     C11H14O2;
CAS         101948-74-7;
InChIKey    ALKYPQWSGHVGTC-CMDGGOBGSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          744.82;      // K   [origin=predictive method=joback]
Pc          26.708;      // bar [origin=predictive method=joback]
omega       0.5262;      // -   [origin=predictive method=lee-kesler]
Tb          531.82;      // K   [origin=predictive method=joback]
HvapTb      47876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.41 0.80396 -0.00040286 5.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-[(e)-2-methoxyprop-1-enyl]benzene" );
standardThermochemistry
{
    dHf_298   -202320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6190.0
}
