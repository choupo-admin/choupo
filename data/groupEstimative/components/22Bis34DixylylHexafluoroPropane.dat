/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(3,4-dixylyl)hexafluoro propane  (C19H18F6, CAS 65294-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis34DixylylHexafluoroPropane;
formula     C19H18F6;
CAS         65294-20-4;
InChIKey    GLFKFHJEFMLTOB-UHFFFAOYSA-N;
MW          360.341;      // g/mol [origin=calculated method=formula-sum]
Tc          894.85;      // K   [origin=predictive method=joback]
Pc          14.208;      // bar [origin=predictive method=joback]
omega       0.7299;      // -   [origin=predictive method=lee-kesler]
Tb          693.53;      // K   [origin=predictive method=joback]
HvapTb      56298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.87 1.86128 -0.00141784 4.156e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 4; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group F; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(3,4-dimethylphenyl)-1,1,1,3,3,3-hexakis(fluoranyl)propan-2-yl]-1,2-dimethyl-benzene" "2,2-bis(3,4-dimethylphenyl)hexafluoropropane" "1,1'-(1,1,1,3,3,3-hexafluoro-2,2-propanediyl)bis(3,4-dimethylbenzene)" "4-[2-(3,4-dimethylphenyl)-1,1,1,3,3,3-hexafluoropropan-2-yl]-1,2-dimethylbenzene" "benzene, 1,1'-[2,2,2-trifluoro-1-(trifluoromethyl)ethylidene]bis[3,4-dimethyl-" "hexafluoro-2,2-bis-(3,4-dimethylphenyl)-propane" "benzene, 1,1'-(2,2,2-trifluoro-1-(trifluoromethyl)ethylidene)bis(3,4-dimethyl-" "4,4'-(hexafluoroisopropylidene)di-o-xylene" "propane, hexafluoro-2,2-di(3,4-xylyl)-" "2,2-bis(3,4-dimethylphenyl)hexafluoropropane;" "2,2-bis-(3,4-dimethylphenyl)-hexafluoropropane" "4,4'-(perfluoropropane-2,2-diyl)bis(1,2-dimethylbenzene)" );
gibbsFormation
{
    dHf_298   -1211220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     732.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-864940.0
    phase     gas;
}
