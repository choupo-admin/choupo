/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl rubber  (C9H16, CAS 9010-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylRubber;
formula     C9H16;
CAS         9010-85-9;
InChIKey    VHOQXEIFYTTXJU-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          583.49;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.2505;      // -   [origin=predictive method=lee-kesler]
Tb          396.72;      // K   [origin=predictive method=joback]
HvapTb      34072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.17 0.59246 -0.0001243 -6.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbuta-1,3-diene;2-methylprop-1-ene" "poly(isobutylene-co-isoprene)" "isobutylene/isoprene copolymer" "1,3-butadiene, 2-methyl-, polymer with 2-methyl-1-propene" "2-methyl-1,3-butadiene polymer with 2-methyl-1-propene" "butyl rubber, brominated" "isobutylene-isoprene copolymer" "1,3-butadiene, 2-methyl-, polymer with 2-methyl-1-propene, brominated" "1,3-butadiene, 2-methyl-, polymer with 2-methyl-1-propene, chlorinated" "chlorinated isobutylene, isoprene polymer" "isobutylene, isoprene polymer, brominated" "isobutylene-isoprene copolymer, chlorinated" );
gibbsFormation
{
    dHf_298   16000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166560.0
    phase     gas;
}
