/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-(2-cyanoethoxy)ethyl)-n-(2-cyanoethyl)aniline  (C14H17N3O, CAS 27419-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n22CyanoethoxyEthylN2CyanoethylAniline;
formula     C14H17N3O;
CAS         27419-90-5;
InChIKey    AEMNOPYAEDEKIP-UHFFFAOYSA-N;
MW          243.31;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.96;      // K   [origin=predictive method=joback]
Pc          18.904;      // bar [origin=predictive method=joback]
omega       1.0387;      // -   [origin=predictive method=lee-kesler]
Tb          785.62;      // K   [origin=predictive method=joback]
HvapTb      74443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.066 1.1852 -0.0007086 1.509e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group N; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(2-cyanoethoxy)ethyl-phenyl-amino]propanenitrile" "3-[n-[2-(2-cyanoethoxy)ethyl]anilino]propanenitrile" "3-((2-(2-cyanoethoxy)ethyl)phenylamino)propiononitrile" "propanenitrile, 3-((2-(2-cyanoethoxy)ethyl)phenylamino)-" "propanenitrile, 3-[[2-(2-cyanoethoxy)ethyl]phenylamino]-" "3-[[2-(2-cyanoethoxy)ethyl]phenylamino]propiononitrile" "aniline, n-cyanoethyl-n-cyanoethoxyethyl-" "propanenitrile,3-[[2-(2-cyanoethoxy)ethyl]phenylamino]-" "propionitrile,3-[n-[2-(2-cyanoethoxy)ethyl]anilino]- (8ci)" );
gibbsFormation
{
    dHf_298   169310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=451550.0
    phase     gas;
}
