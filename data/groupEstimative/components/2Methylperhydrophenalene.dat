/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylperhydrophenalene  (C14H24, CAS 23217-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylperhydrophenalene;
formula     C14H24;
CAS         23217-98-3;
InChIKey    MDCAZZWXQKUJHE-UHFFFAOYSA-N;
MW          192.346;      // g/mol [origin=calculated method=formula-sum]
Tc          772.08;      // K   [origin=predictive method=joback]
Pc          21.877;      // bar [origin=predictive method=joback]
omega       0.4002;      // -   [origin=predictive method=lee-kesler]
Tb          547.88;      // K   [origin=predictive method=joback]
HvapTb      46567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-169.17 1.69512 -0.001102 2.773e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2,3,3a,4,5,6,6a,7,8,9,9a,9b-dodecahydro-1h-phenalene" );
standardThermochemistry
{
    dHf_298   -179210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185430.0
}
