/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 867  (C16H13Cl, CAS 25148-26-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris867;
formula     C16H13Cl;
CAS         25148-26-9;
InChIKey    UHHQJUJHFOQCQJ-UHFFFAOYSA-N;
MW          240.73;      // g/mol [origin=calculated method=formula-sum]
Tc          929.98;      // K   [origin=predictive method=joback]
Pc          24.629;      // bar [origin=predictive method=joback]
omega       0.6566;      // -   [origin=predictive method=lee-kesler]
Tb          682.69;      // K   [origin=predictive method=joback]
HvapTb      63137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.659 1.26582 -0.00097052 3.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 5; } { group ACCH3; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 6; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-(chloromethyl)-10-methyl-anthracene" "9-methyl-10-chloromethylanthracene" "10-(chloromethyl)-9-methylanthracene" "9-(chloromethyl)-10-methylanthracene" "anthracene, 10-chloromethyl-9-methyl-" );
gibbsFormation
{
    dHf_298   194950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368730.0
    phase     gas;
}
