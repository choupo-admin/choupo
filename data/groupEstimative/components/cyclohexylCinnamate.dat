/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl cinnamate  (C15H18O2, CAS 7779-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylCinnamate;
formula     C15H18O2;
CAS         7779-17-1;
InChIKey    GCFAUZGWPDYAJN-VAWYXSNFSA-N;
MW          230.307;      // g/mol [origin=calculated method=formula-sum]
Tc          889.82;      // K   [origin=predictive method=joback]
Pc          23.451;      // bar [origin=predictive method=joback]
omega       0.6126;      // -   [origin=predictive method=lee-kesler]
Tb          651.41;      // K   [origin=predictive method=joback]
HvapTb      59054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.03 1.4372 -0.0008936 1.927e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexyl (e)-3-phenylprop-2-enoate" "cinnamic acid, cyclohexyl ester" "cyclohexyl 3-phenylacrylate" "2-propenoic acid, 3-phenyl-, cyclohexyl ester" "cyclohexyl trans-cinnamate" "cyclohexyl cinnamate [fifh]" "cyclohexyl 3-phenylpropenoate" "cyclohexyl beta-phenylacrylate" "cyclohexyl 3-phenyl-2-propenoate" "2-propenoic acid, 3-phenyl-, cyclohexyl ester, (e)-" "2-propenoic acid, 3-phenyl-, cyclohexyl ester, (2e)-" );
gibbsFormation
{
    dHf_298   -262140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17870.0
    phase     gas;
}
