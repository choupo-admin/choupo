/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-isopropylidene-bis(2-t-butylphenol)  (C23H32O2, CAS 79-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44IsopropylideneBis2TButylphenol;
formula     C23H32O2;
CAS         79-96-9;
InChIKey    ZDRSNHRWLQQICP-UHFFFAOYSA-N;
MW          340.507;      // g/mol [origin=calculated method=formula-sum]
Tc          1192.20;      // K   [origin=predictive method=joback]
Pc          16.810;      // bar [origin=predictive method=joback]
omega       1.0174;      // -   [origin=predictive method=lee-kesler]
Tb          940.71;      // K   [origin=predictive method=joback]
HvapTb      94808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.49 2.59876 -0.00218384 7.456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group C; count 3; } { group ACH; count 6; } { group AC; count 4; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butyl-4-[2-(3-tert-butyl-4-oxidanyl-phenyl)propan-2-yl]phenol" "4,4'-isopropylidenebis(o-tert-butylphenol)" "phenol, 4,4'-isopropylidenebis(2-tert-butyl-" "4,4'-propane-2,2-diylbis(2-tert-butylphenol)" "phenol, (2,2'-di-tert-butyl-4,4'-isopropylene)di-" "phenol, 4,4'-(1-methylethylidene)bis(2-(1,1-dimethylethyl)-" "phenol, 4,4'-(1-methylethylidene)bis[2-(1,1-dimethylethyl)-" "phenol, 4,4'-isopropylidene bis(2-tert-butyl)-" "4,4'-isopropylidenebis(2-tert-butylphenol)" "phenol,4,4'-(1-methylethylidene)bis[2-(1,1-dimethylethyl)-" "2-tert-butyl-4-[2-(3-tert-butyl-4-hydroxyphenyl)propan-2-yl]phenol" "phenol,4,4'-isopropylidenebis[2-tert-butyl- (6ci,7ci,8ci);2,2-bis(4-hydroxy-3-tert-butylphenyl)propane;2,2'-di-tert-butyl-4,4'-isopropylidenebis[phenol]; 3,3'-di-tert-butyldian;4,4'-(1-methylethylidene)bis[2-(1,1-dimethylethyl)phenol];4,4'-isopropylidenebis(o-tert-butylphenol);4,4'-isopropylidenebis[2-tert-butylphenol]; tbd" );
gibbsFormation
{
    dHf_298   -448800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     763.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47620.0
    phase     gas;
}
