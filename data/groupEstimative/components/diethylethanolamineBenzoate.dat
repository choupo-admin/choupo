/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylethanolamine benzoate  (C13H21NO3, CAS 68052-36-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylethanolamineBenzoate;
formula     C13H21NO3;
CAS         68052-36-8;
InChIKey    HJCAIQANKIFKSW-UHFFFAOYSA-N;
MW          239.315;      // g/mol [origin=calculated method=formula-sum]
Tc          977.24;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       1.3475;      // -   [origin=predictive method=lee-kesler]
Tb          775.25;      // K   [origin=predictive method=joback]
HvapTb      82988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.816 1.16244 -0.0005154 2.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid;2-(diethylamino)ethanol" "benzoic acid, compound with 2-(diethylamino)ethanol (1:1)" "ethanol, 2-(diethylamino)-, benzoate (salt)" "ethanol, 2-(diethylamino)-, benzoate (1:1)" "benzoic acid; 2-(diethylamino)ethanol" "2-(diethylamino)ethanol benzoate (1:1)" );
standardThermochemistry
{
    dHf_298   -621710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     783.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-303720.0
}
