/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenehexacarboxylic acid  (C12H6O12, CAS 517-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenehexacarboxylicAcid;
formula     C12H6O12;
CAS         517-60-2;
InChIKey    YDSWCNNOKPMOTP-UHFFFAOYSA-N;
MW          342.168;      // g/mol [origin=calculated method=formula-sum]
Tc          1725.34;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       2.0942;      // -   [origin=predictive method=lee-kesler]
Tb          1398.80;      // K   [origin=predictive method=joback]
HvapTb      150876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.17 1.0722 -0.0007606 2.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 6; } { group COOH; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group COOH; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,2,3,4,5,6-hexacarboxylic acid" "mellitic acid" "mellic acid" "hexacarboxybenzene" "benzene hexacarboxylic acid" "1,2,3,4,5,6-benzenehexacarboxylic acid" "1,3,4,5,6-benzenehexacarboxylic acid" );
standardThermochemistry
{
    dHf_298   -2213450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     804.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1949040.0
}
