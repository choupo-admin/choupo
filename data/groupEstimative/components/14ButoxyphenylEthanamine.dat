/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-butoxyphenyl)ethanamine  (C12H19NO, CAS 91553-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ButoxyphenylEthanamine;
formula     C12H19NO;
CAS         91553-11-6;
InChIKey    ANOJLHQGMTVKNE-UHFFFAOYSA-N;
MW          193.29;      // g/mol [origin=calculated method=formula-sum]
Tc          812.21;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.7085;      // -   [origin=predictive method=lee-kesler]
Tb          600.33;      // K   [origin=predictive method=joback]
HvapTb      57907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.683 1.01004 -0.00052876 8.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-butoxy-alpha-methylbenzylamine" "benzylamine, p-butoxy-alpha-methyl-" "p-butoxy-.alpha.-methylbenzylamine" "benzylamine, p-butoxy-.alpha.-methyl-" );
standardThermochemistry
{
    dHf_298   -169660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111950.0
}
