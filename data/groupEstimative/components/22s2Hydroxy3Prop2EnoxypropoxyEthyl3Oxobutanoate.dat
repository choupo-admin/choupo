/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[(2s)-2-hydroxy-3-prop-2-enoxypropoxy]ethyl 3-oxobutanoate  (C12H20O6, CAS 72269-64-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22s2Hydroxy3Prop2EnoxypropoxyEthyl3Oxobutanoate;
formula     C12H20O6;
CAS         72269-64-8;
InChIKey    ZVQZFHJCJUADFI-NSHDSACASA-N;
MW          260.286;      // g/mol [origin=calculated method=formula-sum]
Tc          896.85;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       1.3775;      // -   [origin=predictive method=lee-kesler]
Tb          719.51;      // K   [origin=predictive method=joback]
HvapTb      76900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.366 0.95452 -0.0003502 -1.744e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group O; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2s)-2-oxidanyl-3-prop-2-enoxy-propoxy]ethyl 3-oxidanylidenebutanoate" );
standardThermochemistry
{
    dHf_298   -1017390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     760.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-650550.0
}
