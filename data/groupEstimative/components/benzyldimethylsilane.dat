/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyldimethylsilane  (C9H13Si, CAS 1631-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H13Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzyldimethylsilane;
formula     C9H13Si;
CAS         1631-70-5;
InChIKey    SKDKWDVYZOKBPL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          149.288;      // g/mol [origin=calculated method=formula-sum]
Tc          643.88;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.2872;      // -   [origin=predictive method=lee-kesler]
Tb          432.90;      // K   [origin=predictive method=joback]
HvapTb      38051.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.789 0.67684 -0.0002896 1.28e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl-(phenylmethyl)silicon" "dimethyl(phenylmethyl)silane" "benzyl(dimethyl)silane" "silane, dimethyl(phenylmethyl)-" "benzene, ((dimethylsilyl)methyl)-" "benzene, [(dimethylsilyl)methyl]-" "benzyldimethylsilyl" "benzyl(dimethyl)silicon" );
standardThermochemistry
{
    dHf_298   -48370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84930.0
}
