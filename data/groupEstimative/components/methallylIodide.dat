/*--------------------------------*- Choupo -*-----------------------*\
  Component: methallyl iodide  (C4H7I, CAS 3756-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methallylIodide;
formula     C4H7I;
CAS         3756-30-7;
InChIKey    HVSJHYFLAANPJS-UHFFFAOYSA-N;
MW          182.0;      // g/mol [origin=calculated method=formula-sum]
Tc          594.42;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.2114;      // -   [origin=predictive method=lee-kesler]
Tb          380.82;      // K   [origin=predictive method=joback]
HvapTb      33281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.261 0.40272 -0.0003004 9.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanyl-2-methyl-prop-1-ene" "methylallyl iodide" "3-iodo-2-methylpropene" "1-propene, 3-iodo-2-methyl-" "3-iodo-2-methyl-1-propene" );
standardThermochemistry
{
    dHf_298   66620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120210.0
}
