/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-iodobut-2-enoate  (C6H9IO2, CAS 34450-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Iodobut2Enoate;
formula     C6H9IO2;
CAS         34450-62-9;
InChIKey    LTFHTHBCTYXEAD-UHFFFAOYSA-N;
MW          240.036;      // g/mol [origin=calculated method=formula-sum]
Tc          713.30;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       0.4343;      // -   [origin=predictive method=lee-kesler]
Tb          492.28;      // K   [origin=predictive method=joback]
HvapTb      45768.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.661 0.57794 -0.0003755 9.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group I; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-iodanylbut-2-enoate" "ethyl cis-3-iodocrotonate" );
standardThermochemistry
{
    dHf_298   -300150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180940.0
}
