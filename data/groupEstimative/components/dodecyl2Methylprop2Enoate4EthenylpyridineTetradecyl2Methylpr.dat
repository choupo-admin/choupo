/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl 2-methylprop-2-enoate;4-ethenylpyridine;tetradecyl 2-methylprop-2-enoate  (C41H71NO4, CAS 125594-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecyl2Methylprop2Enoate4EthenylpyridineTetradecyl2Methylpr;
formula     C41H71NO4;
CAS         125594-58-3;
InChIKey    JATZTOJSXFKSMW-UHFFFAOYSA-N;
MW          642.022;      // g/mol [origin=calculated method=formula-sum]
Tc          1758.78;      // K   [origin=predictive method=joback]
Pc          4.248;      // bar [origin=predictive method=joback]
omega       -0.1953;      // -   [origin=predictive method=lee-kesler]
Tb          1327.10;      // K   [origin=predictive method=joback]
HvapTb      128898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.874 3.27154 -0.00130156 1.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 24; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group C5H4N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 24; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, dodecyl ester, polymer with 4-ethenylpyridine and tetradecyl 2-methyl-2-propenoate" );
gibbsFormation
{
    dHf_298   -1121340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1955.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100040.0
    phase     gas;
}
