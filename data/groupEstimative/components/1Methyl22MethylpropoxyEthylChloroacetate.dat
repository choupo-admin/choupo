/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-2-(2-methylpropoxy)ethyl chloroacetate  (C9H17ClO3, CAS 40137-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl22MethylpropoxyEthylChloroacetate;
formula     C9H17ClO3;
CAS         40137-60-8;
InChIKey    YKCNOWIHQSJPHL-UHFFFAOYSA-N;
MW          208.682;      // g/mol [origin=calculated method=formula-sum]
Tc          705.40;      // K   [origin=predictive method=joback]
Pc          22.355;      // bar [origin=predictive method=joback]
omega       0.6681;      // -   [origin=predictive method=lee-kesler]
Tb          522.71;      // K   [origin=predictive method=joback]
HvapTb      49054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.143 0.75946 -0.000287 -8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH2O; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group Cl; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylpropoxy)propan-2-yl 2-chloranylethanoate" "1-isobutoxypropan-2-yl chloroacetate" "acetic acid, 2-chloro-, 1-methyl-2-(2-methylpropoxy)ethyl ester" "acetic acid, chloro-, 1-methyl-2-(2-methylpropoxy)ethyl ester" "1-(2-methylpropoxy)propan-2-yl 2-chloroacetate" "acetic acid, 2-chloro-,1-methyl-2-(2-methylpropoxy)ethyl ester" "aceticacid, chloro-, 1-methyl-2-(2-methylpropoxy)ethyl ester (9ci);1-isobutoxy-2-propyl chloroacetate; 1-methyl-2-(2-methylpropoxy)ethylchloroacetate" );
gibbsFormation
{
    dHf_298   -704890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407280.0
    phase     gas;
}
