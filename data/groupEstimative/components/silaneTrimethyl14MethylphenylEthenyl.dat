/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, trimethyl[1-(4-methylphenyl)ethenyl]-  (C12H18Si, CAS 94397-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H18Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTrimethyl14MethylphenylEthenyl;
formula     C12H18Si;
CAS         94397-80-5;
InChIKey    OUQXBIMQCUSOGP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          190.361;      // g/mol [origin=calculated method=formula-sum]
Tc          719.64;      // K   [origin=predictive method=joback]
Pc          22.104;      // bar [origin=predictive method=joback]
omega       0.3391;      // -   [origin=predictive method=lee-kesler]
Tb          503.78;      // K   [origin=predictive method=joback]
HvapTb      44948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.51 0.77918 -0.00020356 -6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[1-(4-methylphenyl)ethenyl]silane" "4-ch3-c6h4-c(si(ch3)3)=ch2" );
standardThermochemistry
{
    dHf_298   -61930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127470.0
}
