/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonyl formate  (C10H20O2, CAS 5451-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H20O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nonylFormate;
formula     C10H20O2;
CAS         5451-92-3;
InChIKey    MOGJOLMSQWGXPA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          565.24;      // K   [origin=predictive method=joback]
Pc          21.315;      // bar [origin=predictive method=joback]
omega       0.4360;      // -   [origin=predictive method=lee-kesler]
Tb          404.82;      // K   [origin=predictive method=joback]
HvapTb      35481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.702 0.96192 -0.0006732 2.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonyl methanoate" "formic acid, nonylester" "formic acid, nonyl ester" );
gibbsFormation
{
    dHf_298   -173280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77280.0
    phase     gas;
}
