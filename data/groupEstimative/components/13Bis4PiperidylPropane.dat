/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(4-piperidyl)propane  (C13H26N2, CAS 16898-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Bis4PiperidylPropane;
formula     C13H26N2;
CAS         16898-52-5;
InChIKey    OXEZLYIDQPBCBB-UHFFFAOYSA-N;
MW          210.365;      // g/mol [origin=calculated method=formula-sum]
Tc          867.99;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.6205;      // -   [origin=predictive method=lee-kesler]
Tb          633.24;      // K   [origin=predictive method=joback]
HvapTb      58906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.297 1.4562 -0.0007242 9.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-piperidin-4-ylpropyl)piperidine" "1,3-di-4-piperidylpropane" "4,4'-trimethylenedipiperidine" "piperidine, 4,4'-(1,3-propanediyl)bis-" "di-pip" "1,3-di(4-piperidyl)propane" "piperidine, 4,4'-trimethylenedi-" "4-[3-(piperidin-4-yl)propyl]piperidine" "4-(3-(4-piperidyl)propyl)piperidine" "4-[3-(4-piperidyl)propyl]piperidine" "4,4'-trimethylenedipiperidine dithiocyanate" "4,3-propanediyl)bispiperidine" );
standardThermochemistry
{
    dHf_298   -127390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282900.0
}
