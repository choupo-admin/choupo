/*--------------------------------*- Choupo -*-----------------------*\
  Component: scoparone  (C11H10O4, CAS 120-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        scoparone;
formula     C11H10O4;
CAS         120-08-1;
InChIKey    GUAFOGOEJLSQBT-UHFFFAOYSA-N;
MW          206.197;      // g/mol [origin=calculated method=formula-sum]
Tc          817.24;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.7792;      // -   [origin=predictive method=lee-kesler]
Tb          602.26;      // K   [origin=predictive method=joback]
HvapTb      56911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.01 0.74124 -0.00039736 6.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7-dimethoxychromen-2-one" "6,7-dimethoxycoumarin" "6,7-dimethylesculetin" "escoparone" "scoparon" "aesculetin dimethyl ether" "coumarin, 6,7-dimethoxy-" "esculetin dimethyl ether" "6,7-dimethoxy-2h-1-benzopyran-2-one" "6,7-dimethoxy-2-benzopyrone" "6,7-dimethoxybenzopyran-2-one" "di-o-methyl-daphnetin" );
standardThermochemistry
{
    dHf_298   -492890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284590.0
}
