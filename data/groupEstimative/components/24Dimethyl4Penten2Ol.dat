/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyl-4-penten-2-ol  (C7H14O, CAS 19781-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyl4Penten2Ol;
formula     C7H14O;
CAS         19781-53-4;
InChIKey    YYWMKLMWCPTKDJ-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          621.89;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.6477;      // -   [origin=predictive method=lee-kesler]
Tb          445.27;      // K   [origin=predictive method=joback]
HvapTb      45969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.339 0.80856 -0.0005844 1.73e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethylpent-4-en-2-ol" "2,4-dimethyl-pent-4-en-2-ol" "4-penten-2-ol,2,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -233150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46630.0
    phase     gas;
}
