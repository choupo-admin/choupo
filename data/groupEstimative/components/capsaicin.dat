/*--------------------------------*- Choupo -*-----------------------*\
  Component: capsaicin  (C18H27NO3, CAS 404-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        capsaicin;
formula     C18H27NO3;
CAS         404-86-4;
InChIKey    YKPUWZUDDOIDPM-SOFGYWHQSA-N;
MW          305.418;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.71;      // K   [origin=predictive method=joback]
Pc          17.924;      // bar [origin=predictive method=joback]
omega       1.2293;      // -   [origin=predictive method=lee-kesler]
Tb          853.90;      // K   [origin=predictive method=joback]
HvapTb      86776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.215 1.74096 -0.00118182 3.3026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-n-[(3-methoxy-4-oxidanyl-phenyl)methyl]-8-methyl-non-6-enamide" "zostrix" "(e)-capsaicin" "styptysat" "axsain" "qutenza" "capsaicine" "transacin" "e-capsaicin" "isodecenoic acid vanillylamide" "capsaicin [usan]" "neurotoxic" );
standardThermochemistry
{
    dHf_298   -446490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     833.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17910.0
}
