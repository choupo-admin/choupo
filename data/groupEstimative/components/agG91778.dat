/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-91778  (C36H75NO2, CAS 73692-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG91778;
formula     C36H75NO2;
CAS         73692-68-9;
InChIKey    GIFASMIJBHVQRZ-UHFFFAOYSA-N;
MW          554.001;      // g/mol [origin=calculated method=formula-sum]
Tc          1573.96;      // K   [origin=predictive method=joback]
Pc          4.575;      // bar [origin=predictive method=joback]
omega       -0.1651;      // -   [origin=predictive method=lee-kesler]
Tb          1182.63;      // K   [origin=predictive method=joback]
HvapTb      115231.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.891 3.39238 -0.001705 2.654e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 31; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 31; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyloctadecan-1-amine;hexadecanoic acid" "hexadecanoic acid compd. with n,n-dimethyl-1-octadecanamine (1:1)" );
gibbsFormation
{
    dHf_298   -1180730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1735.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85650.0
    phase     gas;
}
