/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-2-methoxybenzoic acid  (C8H7ClO3, CAS 57479-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro2MethoxybenzoicAcid;
formula     C8H7ClO3;
CAS         57479-70-6;
InChIKey    UFEYMXHWIHFRBX-UHFFFAOYSA-N;
MW          186.591;      // g/mol [origin=calculated method=formula-sum]
Tc          855.58;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.8275;      // -   [origin=predictive method=lee-kesler]
Tb          624.64;      // K   [origin=predictive method=joback]
HvapTb      60961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.3 0.56032 -0.00029052 4.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2-methoxy-benzoic acid" "4-chloro-o-anisic acid" "4-chloro-ortho-anisic acid" "4-chloro-2-methoxybenzoicacid" "2-methoxy-4-chloro benzoic acid" "2-methoxy-4-chlorobenzoic acid" "benzoic acid, 4-chloro-2-methoxy-" "l681" );
standardThermochemistry
{
    dHf_298   -493090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351210.0
}
