/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxy-2-prop-2-enoxypropane  (C7H14O2, CAS 62322-46-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxy2Prop2Enoxypropane;
formula     C7H14O2;
CAS         62322-46-7;
InChIKey    VQDSIAMWMIZPGX-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          577.30;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.3805;      // -   [origin=predictive method=lee-kesler]
Tb          398.05;      // K   [origin=predictive method=joback]
HvapTb      34030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.061 0.64826 -0.0003297 5.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-2-prop-2-enoxy-propane" "2-methoxyisopropyl allyl ether" "3-(1-methoxy-1-methylethoxy)-1-propene" "1-propene, 3-(1-methoxy-1-methylethoxy)-" );
standardThermochemistry
{
    dHf_298   -335570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111260.0
}
