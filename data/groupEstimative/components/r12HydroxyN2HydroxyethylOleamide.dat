/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-12-hydroxy-n-(2-hydroxyethyl)oleamide  (C20H39NO3, CAS 106-16-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r12HydroxyN2HydroxyethylOleamide;
formula     C20H39NO3;
CAS         106-16-1;
InChIKey    JYDIHAYTECQGQK-UHFFFAOYSA-N;
MW          341.536;      // g/mol [origin=calculated method=formula-sum]
Tc          1169.87;      // K   [origin=predictive method=joback]
Pc          12.593;      // bar [origin=predictive method=joback]
omega       1.0967;      // -   [origin=predictive method=lee-kesler]
Tb          949.32;      // K   [origin=predictive method=joback]
HvapTb      106224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.425 2.04592 -0.0012419 2.9476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)-12-oxidanyl-octadec-9-enamide" "9-octadecenamide, 12-hydroxy-n-(2-hydroxyethyl)-, (9z,12r)-" "(z,12r)-12-hydroxy-n-(2-hydroxyethyl)octadec-9-enamide" );
standardThermochemistry
{
    dHf_298   -707760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1088.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117870.0
}
