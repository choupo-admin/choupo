/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzyl-4-hydroxypiperidine  (C12H17NO, CAS 51135-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Benzyl4Hydroxypiperidine;
formula     C12H17NO;
CAS         51135-96-7;
InChIKey    KJZBZOFESQSBCV-UHFFFAOYSA-N;
MW          191.274;      // g/mol [origin=calculated method=formula-sum]
Tc          893.64;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.9178;      // -   [origin=predictive method=lee-kesler]
Tb          661.36;      // K   [origin=predictive method=joback]
HvapTb      67297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.309 1.4995 -0.0012436 4.416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(phenylmethyl)piperidin-4-ol" "4-benzylpiperidin-4-ol" "4-piperidinol, 4-benzyl-" "4-benzyl-4-piperidinol" "4-piperidinol, 4-(phenylmethyl)-" );
standardThermochemistry
{
    dHf_298   -99340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132420.0
}
