/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl bromo(chloro)acetate  (C3H4BrClO2, CAS 20428-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylBromoChloroAcetate;
formula     C3H4BrClO2;
CAS         20428-74-4;
InChIKey    WIBYPHGWXYLWQX-UHFFFAOYSA-N;
MW          187.417;      // g/mol [origin=calculated method=formula-sum]
Tc          638.99;      // K   [origin=predictive method=joback]
Pc          46.849;      // bar [origin=predictive method=joback]
omega       0.4533;      // -   [origin=predictive method=lee-kesler]
Tb          429.61;      // K   [origin=predictive method=joback]
HvapTb      40111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.97 0.28492 -0.0001398 1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHCl; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group Cl; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-bromanyl-2-chloranyl-ethanoate" "methyl bromochloroacetate" "acetic acid, bromochloro-, methyl ester" "methyl 2-bromo-2-chloroacetate" );
standardThermochemistry
{
    dHf_298   -417220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-336040.0
}
