/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid;tert-butyl-dimethyl-oxidanyl-silane  (C13H22O3Si, CAS 75732-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H22O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzoicAcidTertButylDimethylOxidanylSilane;
formula     C13H22O3Si;
CAS         75732-41-1;
InChIKey    NTYGYRZLBJEAMT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          254.401;      // g/mol [origin=calculated method=formula-sum]
Tc          978.03;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       1.0611;      // -   [origin=predictive method=lee-kesler]
Tb          760.98;      // K   [origin=predictive method=joback]
HvapTb      79943.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.22 0.9582 -0.0001598 -1.557e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -809610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     855.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516420.0
    phase     gas;
}
