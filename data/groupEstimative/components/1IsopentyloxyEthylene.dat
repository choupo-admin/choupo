/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(isopentyloxy)ethylene  (C7H14O, CAS 39782-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1IsopentyloxyEthylene;
formula     C7H14O;
CAS         39782-38-2;
InChIKey    QIUCYKBVFAPWRR-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          550.15;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       0.3721;      // -   [origin=predictive method=lee-kesler]
Tb          378.42;      // K   [origin=predictive method=joback]
HvapTb      32528.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.352 0.59154 -0.0002721 3.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenoxy-3-methyl-butane" "butane, 1-(ethenyloxy)-3-methyl-" "vinylisopentyl ether" "1-ethenoxy-3-methylbutane" "1-(ethenyloxy)-3-methylbutane" "butane,1-(ethenyloxy)-3-methyl-" "ether,isopentyl vinyl (6ci,7ci); isoamyl vinyl ether; isopentyl vinyl ether" );
gibbsFormation
{
    dHf_298   -199880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11540.0
    phase     gas;
}
