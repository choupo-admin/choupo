/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-diethylaminocoumarin  (C13H15NO2, CAS 20571-42-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Diethylaminocoumarin;
formula     C13H15NO2;
CAS         20571-42-0;
InChIKey    QXAMGWKESXGGNV-UHFFFAOYSA-N;
MW          217.268;      // g/mol [origin=calculated method=formula-sum]
Tc          819.43;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.7782;      // -   [origin=predictive method=lee-kesler]
Tb          610.64;      // K   [origin=predictive method=joback]
HvapTb      57924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.798 1.24104 -0.0009078 2.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(diethylamino)chromen-2-one" "2h-1-benzopyran-2-one, 7-(diethylamino)-" "coumarine, 7-diethylamino-" "7-(diethylamino)coumarin" "7-diethylamino-chromen-2-one" "c 1h" "7-(diethylamino)-2-benzopyrone" "7-(diethylamino)-2h-chromen-2-one" "7-(diethylamino)-2h-1-benzopyran-2-one" );
standardThermochemistry
{
    dHf_298   -190730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62660.0
}
