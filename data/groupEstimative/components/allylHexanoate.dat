/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl hexanoate  (C9H16O2, CAS 123-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylHexanoate;
formula     C9H16O2;
CAS         123-68-2;
InChIKey    RCSBILYQLVXLJG-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          634.32;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.5739;      // -   [origin=predictive method=lee-kesler]
Tb          460.42;      // K   [origin=predictive method=joback]
HvapTb      42365.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.125 0.78402 -0.0003941 5.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl hexanoate" "allyl caproate" "hexanoic acid, 2-propenyl ester" "hexanoic acid, allyl ester" "2-propenyl n-hexanoate" "allyl n-caproate" "2-propenyl hexanoate" "allyl hexanoate (natural)" "hexanoic acid, 2-propen-1-yl ester" "allocopen" "hexanoic acid allyl ester" "allylester kyseliny kapronove" );
gibbsFormation
{
    dHf_298   -420940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197630.0
    phase     gas;
}
