/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanemethanol, 4-(methoxymethyl)-  (C9H18O2, CAS 98955-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanemethanol4Methoxymethyl;
formula     C9H18O2;
CAS         98955-27-2;
InChIKey    KSIFEWSPJQDERU-UHFFFAOYSA-N;
MW          158.241;      // g/mol [origin=calculated method=formula-sum]
Tc          721.98;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.8252;      // -   [origin=predictive method=lee-kesler]
Tb          535.00;      // K   [origin=predictive method=joback]
HvapTb      54837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.168 0.92522 -0.0004108 3.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(methoxymethyl)cyclohexyl]methanol" "agn-pc-02pt4g" );
gibbsFormation
{
    dHf_298   -479560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200180.0
    phase     gas;
}
