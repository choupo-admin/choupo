/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chlorophenylacetic acid  (C8H7ClO2, CAS 1878-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChlorophenylaceticAcid;
formula     C8H7ClO2;
CAS         1878-65-5;
InChIKey    WFPMUFXQDKMVCO-UHFFFAOYSA-N;
MW          170.592;      // g/mol [origin=calculated method=formula-sum]
Tc          830.55;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.7409;      // -   [origin=predictive method=lee-kesler]
Tb          597.24;      // K   [origin=predictive method=joback]
HvapTb      57889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.499 0.683 -0.00046856 1.216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-chlorophenyl)ethanoic acid" "m-chlorophenylacetic acid" "2-(3-chlorophenyl)acetic acid" "benzeneacetic acid, 3-chloro-" "3-chlorobenzeneacetic acid" "(m-chlorophenyl)acetic acid" "(3-chlorophenyl)acetic acid" "3-chlorophenylaceticacid" "benzeneaceticacid, 3-chloro-" "acetic acid, (m-chlorophenyl)-" "benzeneacetic acid, 3-chloro- (9ci)" "1878-65-5 3-chlorophenylacetic acid" );
standardThermochemistry
{
    dHf_298   -349400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-236580.0
}
