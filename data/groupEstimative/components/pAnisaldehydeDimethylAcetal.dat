/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-anisaldehyde dimethyl acetal  (C10H14O3, CAS 2186-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pAnisaldehydeDimethylAcetal;
formula     C10H14O3;
CAS         2186-92-7;
InChIKey    NNHYAHOTXLASEA-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          732.32;      // K   [origin=predictive method=joback]
Pc          27.556;      // bar [origin=predictive method=joback]
omega       0.5856;      // -   [origin=predictive method=lee-kesler]
Tb          526.88;      // K   [origin=predictive method=joback]
HvapTb      47634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.01 0.63176 -0.00015456 -5.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(dimethoxymethyl)-4-methoxy-benzene" "anisaldehyde dimethyl acetal" "1-(dimethoxymethyl)-4-methoxybenzene" "4-methoxybenzaldehyde dimethyl acetal" "p-(dimethoxymethyl)anisole" "benzene, 1-(dimethoxymethyl)-4-methoxy-" "alpha,alpha,4-trimethoxytoluene" "anisicaldehyde dimethylacetal" "a," "a,4-trimethoxytoluene" "4-methoxybenzaldehyddimethylacetal" "toluene, p,a,a-trimethoxy- (5ci);p-anisaldehyde, dimethyl acetal(7ci,8ci);(p-methoxyphenyl)dimethoxymethane;1-(dimethoxymethyl)-4-methoxybenzene;4-anisaldehyde dimethyl acetal;4-methoxybenzaldehyde dimethyl acetal;anisaldehyde dimethyl acetal;anisic aldehyde dimethyl acetal;dimethoxy(4-methoxyphenyl)methane;p-(dimethoxymethyl)anisole;p-methoxybenzaldehyde dimethyl acetal;" );
standardThermochemistry
{
    dHf_298   -426610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181340.0
}
