/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentane, 2,2,3,3,4,4-hexamethyl-  (C11H24, CAS 60302-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentane223344Hexamethyl;
formula     C11H24;
CAS         60302-27-4;
InChIKey    JKJQSSSRSKPVEM-UHFFFAOYSA-N;
MW          156.313;      // g/mol [origin=calculated method=formula-sum]
Tc          635.76;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       0.2688;      // -   [origin=predictive method=lee-kesler]
Tb          441.59;      // K   [origin=predictive method=joback]
HvapTb      36192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.53 1.42636 -0.00109 3.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group C; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,4,4-hexamethylpentane" "agn-pc-00kjiz" );
gibbsFormation
{
    dHf_298   -296620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50260.0
    phase     gas;
}
