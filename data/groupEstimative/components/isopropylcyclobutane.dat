/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropylcyclobutane  (C7H14, CAS 872-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylcyclobutane;
formula     C7H14;
CAS         872-56-0;
InChIKey    RFHQRRJFJJCQDJ-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          560.91;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.2575;      // -   [origin=predictive method=lee-kesler]
Tb          370.33;      // K   [origin=predictive method=joback]
HvapTb      30873.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.52 0.81604 -0.000534 1.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-ylcyclobutane" "cyclobutane, isopropyl-" );
gibbsFormation
{
    dHf_298   -126450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54270.0
    phase     gas;
}
