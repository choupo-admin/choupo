/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiiranepropanenitrile  (C5H7NS, CAS 54096-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiiranepropanenitrile;
formula     C5H7NS;
CAS         54096-45-6;
InChIKey    ZAGXORSINWAUSP-UHFFFAOYSA-N;
MW          113.178;      // g/mol [origin=calculated method=formula-sum]
Tc          692.98;      // K   [origin=predictive method=joback]
Pc          39.111;      // bar [origin=predictive method=joback]
omega       0.4319;      // -   [origin=predictive method=lee-kesler]
Tb          470.65;      // K   [origin=predictive method=joback]
HvapTb      42927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.078 0.57891 -0.0004561 1.501e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2CN; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group CN; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(thiiran-2-yl)propanenitrile" "4,5-epithiovaleronitrile" "1-cyano-3,4-epithiobutane" "valeronitrile, 4,5-epithio-" "2-thiiranepropanenitrile" "thiiranepropanenitrile, (+-)-" );
gibbsFormation
{
    dHf_298   136410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     316.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225010.0
    phase     gas;
}
