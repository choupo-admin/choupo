/*--------------------------------*- Choupo -*-----------------------*\
  Component: okadaic acid  (C44H68O13, CAS 78111-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        okadaicAcid;
formula     C44H68O13;
CAS         78111-17-8;
InChIKey    QNDVLZJODHBUFM-UHFFFAOYSA-N;
MW          805.015;      // g/mol [origin=calculated method=formula-sum]
Tc          3319.92;      // K   [origin=predictive method=joback]
Pc          7.340;      // bar [origin=predictive method=joback]
omega       -0.3957;      // -   [origin=predictive method=lee-kesler]
Tb          1996.04;      // K   [origin=predictive method=joback]
HvapTb      224263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-432.278 5.9092 -0.00467054 1.5581e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 14; } { group CH; count 7; } { group C; count 4; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group OH; count 4; } { group CH-O; count 6; } { group FCH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 13; } { group CH_ring; count 10; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 4; } { group O_ring; count 7; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-[4-methyl-2-[4-[2-[3-(3-methyl-1,7-dioxaspiro[5.5]undecan-2-yl)-1-oxidanyl-butyl]-3-methylidene-4-oxidanyl-spiro[4a,7,8,8a-tetrahydro-4h-pyrano[3,2-b]pyran-6,5'-oxolane]-2'-yl]but-3-en-2-yl]-11-oxidanyl-1,7-dioxaspiro[5.5]undec-4-en-8-yl]-2-oxidanyl-propanoic acid" "agn-pc-00io3q" "(2r)-3-[(2s,6r,8s,11r)-2-[(e,2r)-4-[(2s,2'r,4r,6r,8ar)-4-hydroxy-2-[(1s,3s)-1-hydroxy-3-[(3r,6s)-3-methyl-1,7-dioxaspiro[5.5]undecan-2-yl]butyl]-3-methylidenespiro[4a,7,8,8a-tetrahydro-4h-pyrano[3,2-b]pyran-6,5'-oxolane]-2'-yl]but-3-en-2-yl]-11-hydroxy-4-methyl-1,7-dioxaspiro[5.5]undec-4-en-8-yl]-2-hydroxy-2-methylpropanoic acid" "2-hydroxy-3-[7-hydroxy-4-[4-[4-hydroxy-2-[1-hydroxy-3-(9-methyl-5,11-dioxaspiro[5.5]undecan-10-yl)butyl]-3-methylidenespiro[4a,7,8,8a-tetrahydro-4h-pyrano[3,2-b]pyran-6,5'-oxolane]-2'-yl]but-3-en-2-yl]-2-methyl-5,11-dioxaspiro[5.5]undec-1-en-10-yl]-2-methylpropanoic acid" );
gibbsFormation
{
    dHf_298   -2270620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1245.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-844260.0
    phase     gas;
}
