/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5,6-pentabromoethylbenzene  (C8H5Br5, CAS 85-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23456Pentabromoethylbenzene;
formula     C8H5Br5;
CAS         85-22-3;
InChIKey    FIAXCDIQXHJNIX-UHFFFAOYSA-N;
MW          500.648;      // g/mol [origin=calculated method=formula-sum]
Tc          1050.16;      // K   [origin=predictive method=joback]
Pc          52.132;      // bar [origin=predictive method=joback]
omega       0.9911;      // -   [origin=predictive method=lee-kesler]
Tb          765.02;      // K   [origin=predictive method=joback]
HvapTb      71163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.161 0.57842 -0.0004644 1.555e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group AC; count 5; } { group ACCH2; count 1; } { group Br; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dC_ring; count 6; } { group Br; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(bromanyl)-6-ethyl-benzene" "pentabromoethylbenzene" "1,2,3,4,5-pentabromo-6-ethylbenzene" "benzene, pentabromoethyl-" "eb 80" "benzene, 1,2,3,4,5-pentabromo-6-ethyl-" "benzene,1,2,3,4,5-pentabromo-6-ethyl-" );
standardThermochemistry
{
    dHf_298   102380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152340.0
}
