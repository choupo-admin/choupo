/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3390551  (C20H16O2, CAS 16354-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3390551;
formula     C20H16O2;
CAS         16354-53-3;
InChIKey    PTYJZLYGAHHXDM-UHFFFAOYSA-N;
MW          288.346;      // g/mol [origin=calculated method=formula-sum]
Tc          1050.99;      // K   [origin=predictive method=joback]
Pc          21.315;      // bar [origin=predictive method=joback]
omega       0.9047;      // -   [origin=predictive method=lee-kesler]
Tb          805.58;      // K   [origin=predictive method=joback]
HvapTb      74778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.33 1.44944 -0.0010154 2.864e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 8; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,12-dimethoxybenzo[a]anthracene" "benz(a)anthracene, 7,12-dimethoxy-" "7,12-dimethoxytetraphene" );
gibbsFormation
{
    dHf_298   43290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=301360.0
    phase     gas;
}
