/*--------------------------------*- Choupo -*-----------------------*\
  Component: alphameprodine  (C17H25NO2, CAS 468-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphameprodine;
formula     C17H25NO2;
CAS         468-51-9;
InChIKey    ODEGQXRCQDVXSJ-WMLDXEAASA-N;
MW          275.392;      // g/mol [origin=calculated method=formula-sum]
Tc          915.27;      // K   [origin=predictive method=joback]
Pc          18.515;      // bar [origin=predictive method=joback]
omega       0.7573;      // -   [origin=predictive method=lee-kesler]
Tb          696.75;      // K   [origin=predictive method=joback]
HvapTb      63959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.288 2.00616 -0.0015548 5.062e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,4r)-3-ethyl-1-methyl-4-phenyl-piperidin-4-yl] propanoate" "alfameprodina" "alphameprodinum" "alphameprodinum [inn-latin]" "alphameprodine [inn:ban:dcf]" "cis-3-ethyl-1-methyl-4-phenyl-4-propionyloxypiperidine" "3alpha-ethyl-1-methyl-4-phenyl-4alpha-piperidyl propionat" "alpha-3-ethyl-1-methyl-4-phenyl-4-propionyloxypiperidine" "[(3s,4r)-3-ethyl-1-methyl-4-phenylpiperidin-4-yl] propanoate" );
gibbsFormation
{
    dHf_298   -352050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     755.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28430.0
    phase     gas;
}
