/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-diisopropylbenzylchloride  (C13H19Cl, CAS 58502-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Diisopropylbenzylchloride;
formula     C13H19Cl;
CAS         58502-84-4;
InChIKey    QWGSROBWVPQERA-UHFFFAOYSA-N;
MW          210.745;      // g/mol [origin=calculated method=formula-sum]
Tc          782.26;      // K   [origin=predictive method=joback]
Pc          20.927;      // bar [origin=predictive method=joback]
omega       0.5269;      // -   [origin=predictive method=lee-kesler]
Tb          570.23;      // K   [origin=predictive method=joback]
HvapTb      51741.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.709 1.05958 -0.00060732 1.272e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(chloromethyl)-1,4-di(propan-2-yl)benzene" "2,5-diisopropylbenzyl chloride" "benzene, 2-(chloromethyl)-1,4-bis(1-methylethyl)-" "3,6-diisopropylbenzyl chloride" );
standardThermochemistry
{
    dHf_298   -124360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134920.0
}
