/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentanone  (C5H8O, CAS 120-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanone;
formula     C5H8O;
CAS         120-92-3;
InChIKey    BGTOWKSIORTVQH-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          622.58;      // K   [origin=predictive method=joback]
Pc          47.562;      // bar [origin=predictive method=joback]
omega       0.2897;      // -   [origin=predictive method=lee-kesler]
Tb          401.77;      // K   [origin=predictive method=joback]
HvapTb      31537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.65 0.4687 -0.000187 3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "adipic ketone" "ketocyclopentane" "ketopentamethylene" "adipinketon" "dumasin" "cyclopentanon" "cyclopentyloxy" "cyclopentan-1-one" "oxocyclopentane" );
standardThermochemistry
{
    dHf_298   -203410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87110.0
}
