/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6,6-trimethyl-1-cyclohexene-1-acetaldehyde  (C11H18O, CAS 472-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        266Trimethyl1Cyclohexene1Acetaldehyde;
formula     C11H18O;
CAS         472-66-2;
InChIKey    VHTFHZGAMYUZEP-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          740.66;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.5218;      // -   [origin=predictive method=lee-kesler]
Tb          528.85;      // K   [origin=predictive method=joback]
HvapTb      47694.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.929 1.26236 -0.0010344 3.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CHO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,6,6-trimethylcyclohexen-1-yl)ethanal" "beta-homocyclocitral" "1-cyclohexene-1-acetaldehyde, 2,6,6-trimethyl-" "a-homocyclocitral" "cyclohomocitral, beta-" "homocyclocitral, beta-" "apo-8-carotenal, beta-" "ghl.pd_mitscher_leg0.59" "2,6,6-trimethyl-1-cyclohexen-1-acetaldehyde" "1-cyclohexene-1-acetaldehyde,2,6,6-trimethyl-" "2-(2,6,6-trimethylcyclohexen-1-yl)acetaldehyde" );
standardThermochemistry
{
    dHf_298   -251550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28120.0
}
