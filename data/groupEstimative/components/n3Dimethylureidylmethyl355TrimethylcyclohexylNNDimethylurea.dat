/*--------------------------------*- Choupo -*-----------------------*\
  Component: n'-(3-(dimethylureidylmethyl)-3,5,5-trimethylcyclohexyl)-n,n-dimethylurea  (C16H32N4O2, CAS 39992-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3Dimethylureidylmethyl355TrimethylcyclohexylNNDimethylurea;
formula     C16H32N4O2;
CAS         39992-90-0;
InChIKey    UZEZQRZYPITAFY-WBMJQRKESA-N;
MW          312.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.21;      // K   [origin=predictive method=joback]
Pc          17.699;      // bar [origin=predictive method=joback]
omega       1.1474;      // -   [origin=predictive method=lee-kesler]
Tb          809.33;      // K   [origin=predictive method=joback]
HvapTb      79169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-174.449 2.52104 -0.002167 8.0612e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 2; } { group CH2NH; count 1; } { group CHNH; count 1; } { group CON_CH3_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group CdO; count 2; } { group NH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(1r,3r)-3-[(dimethylcarbamoylamino)methyl]-3,5,5-trimethyl-cyclohexyl]-1,1-dimethyl-urea" "urea, n'-(3-((((dimethylamino)carbonyl)amino)methyl)-3,5,5-trimethylcyclohexyl)-n,n-dimethyl-" "3-[(1r,3r)-3-[(dimethylcarbamoylamino)methyl]-3,5,5-trimethylcyclohexyl]-1,1-dimethylurea" );
standardThermochemistry
{
    dHf_298   -312610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     969.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224390.0
}
