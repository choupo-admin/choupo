\*---------------------------------------------------------------------------*/

name        agG61522;
formula     C4H9NO3;
CAS         68258-70-8;
InChIKey    KGDLQPRAMMDEPD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          119.12;      // g/mol [origin=calculated method=formula-sum]
Tc          619.08;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.5245;      // -   [origin=predictive method=lee-kesler]
Tb          426.19;      // K   [origin=predictive method=joback]
HvapTb      41479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.93 0.46354 -0.0003246 8.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group HCOOH; count 1; } { group DMF-1; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylmethanamide;methanoic acid" "formic acid compd. with n,n-dimethylformamide (1:1)" "formic acid, compd. with n,n-dimethylformamide (1:1)" "formic acid, compound with n,n-dimethylformamide (1:1)" "n,n-dimethylformamide; formic acid" "formic acid, n,n-dimethylformamide salt" );
standardThermochemistry
{
    dHf_298   -387990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258750.0
}
