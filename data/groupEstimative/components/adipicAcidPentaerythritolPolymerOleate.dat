/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipic acid, pentaerythritol polymer, oleate  (C29H54O9, CAS 68130-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipicAcidPentaerythritolPolymerOleate;
formula     C29H54O9;
CAS         68130-33-6;
InChIKey    CXVILVNNGGLLPV-RRABGKBLSA-N;
MW          546.742;      // g/mol [origin=calculated method=formula-sum]
Tc          2294.43;      // K   [origin=predictive method=joback]
Pc          7.890;      // bar [origin=predictive method=joback]
omega       -0.2732;      // -   [origin=predictive method=lee-kesler]
Tb          1491.23;      // K   [origin=predictive method=joback]
HvapTb      170876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.172 2.84722 -0.0015364 2.643e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 3; } { group CH2COO; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 22; } { group C; count 1; } { group dCH; count 2; } { group OH; count 3; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-bis(hydroxymethyl)-3-oxidanyl-propyl] (e)-octadec-9-enoate;hexanedioic acid" "hexanedioic acid, polymer with 2,2-bis(hydroxymethyl)-1,3-propanediol, (9z)-9-octadecenoate" "hexanedioic acid; [3-hydroxy-2,2-bis(hydroxymethyl)propyl] (e)-octadec-9-enoate" );
gibbsFormation
{
    dHf_298   -2119550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1658.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1237050.0
    phase     gas;
}
