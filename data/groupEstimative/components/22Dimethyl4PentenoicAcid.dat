/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-4-pentenoic acid  (C7H12O2, CAS 16386-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl4PentenoicAcid;
formula     C7H12O2;
CAS         16386-93-9;
InChIKey    BGUAPYRHJPWVEM-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          701.51;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.6002;      // -   [origin=predictive method=lee-kesler]
Tb          498.72;      // K   [origin=predictive method=joback]
HvapTb      46374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.339 0.82544 -0.0006243 1.894e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpent-4-enoic acid" "2,2-dimethyl-pent-4-enoic acid" "4-pentenoic acid, 2,2-dimethyl-" "2,2-dimethylpent-4-enoicacid;2,2-dimethyl-pent-4-enoic acid;2,2-dimethylpent-4-enoic acid;4-pentenoic acid, 2,2-dimethyl-;2,2-dimethylpent-4-enoic acid;" );
standardThermochemistry
{
    dHf_298   -421400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245170.0
}
