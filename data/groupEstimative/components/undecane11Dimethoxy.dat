/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecane, 1,1-dimethoxy-  (C13H28O2, CAS 52517-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecane11Dimethoxy;
formula     C13H28O2;
CAS         52517-67-6;
InChIKey    FBJUQTUWWCVIDH-UHFFFAOYSA-N;
MW          216.365;      // g/mol [origin=calculated method=formula-sum]
Tc          704.67;      // K   [origin=predictive method=joback]
Pc          16.103;      // bar [origin=predictive method=joback]
omega       0.7427;      // -   [origin=predictive method=lee-kesler]
Tb          541.44;      // K   [origin=predictive method=joback]
HvapTb      48964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.389 1.11836 -0.0004646 3.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxyundecane" "undecanal dimethyl acetal" "undecanal-dimethyl acetal" "undecane,1,1-dimethoxy-" "undecanal,dimethyl acetal (7ci)" );
standardThermochemistry
{
    dHf_298   -581370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153860.0
}
