/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,5,8-tetrahydro-4a,8a-(methanothiomethano)naphthalene 10,10-dioxide  (C12H16O2S, CAS 17853-54-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H16O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1458Tetrahydro4a8aMethanothiomethanoNaphthalene1010Dioxide;
formula     C12H16O2S;
CAS         17853-54-2;
InChIKey    ONSLAKZHKJHODY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          224.318;      // g/mol [origin=calculated method=formula-sum]
Tc          707.18;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.5247;      // -   [origin=predictive method=lee-kesler]
Tb          489.66;      // K   [origin=predictive method=joback]
HvapTb      52970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-250.83 2.1052 -0.00222016 9.368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 2; } { group CH=CH; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 4; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4.alpha.,8.alpha.-(methanothiomethano)naphthalene,1,4,5,8-tetrahydro-10,10-dioxide" "4alpha,8alpha-(methanothiomethano)naphthalene, 1,4,5,8-tetrahydro-, 10,10-dioxide" );
standardThermochemistry
{
    dHf_298   -419930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     777.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248900.0
}
