/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl dibromofluoroacetate  (C4H5Br2FO2, CAS 565-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylDibromofluoroacetate;
formula     C4H5Br2FO2;
CAS         565-53-7;
InChIKey    COYRDMUQLSIAEX-UHFFFAOYSA-N;
MW          263.888;      // g/mol [origin=calculated method=formula-sum]
Tc          692.96;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.5649;      // -   [origin=predictive method=lee-kesler]
Tb          477.70;      // K   [origin=predictive method=joback]
HvapTb      42662.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.661 0.54302 -0.0004302 1.25e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group Br; count 2; } { group CF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group F; count 1; } { group Br; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2-bis(bromanyl)-2-fluoranyl-ethanoate" "ethyl 2,2-dibromo-2-fluoroacetate" "dibromofluoroacetic acid ethyl ester" "2,2-dibromo-1-ethoxy-2-fluoroethan-1-one" "aceticacid, dibromofluoro-, ethyl ester (6ci,7ci,8ci,9ci); ethyl dibromofluoroacetate" );
standardThermochemistry
{
    dHf_298   -595370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-490900.0
}
