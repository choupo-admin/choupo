/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-dimethyl-2-carbomethoxy-5-isopropenyl-5-norbornene  (C14H20O2, CAS 68698-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Dimethyl2Carbomethoxy5Isopropenyl5Norbornene;
formula     C14H20O2;
CAS         68698-57-7;
InChIKey    QGLOTHQLJUMRHT-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          807.35;      // K   [origin=predictive method=joback]
Pc          20.530;      // bar [origin=predictive method=joback]
omega       0.6085;      // -   [origin=predictive method=lee-kesler]
Tb          597.14;      // K   [origin=predictive method=joback]
HvapTb      53729.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.39 1.64158 -0.0013928 5.104e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,4-dimethyl-2-prop-1-en-2-yl-bicyclo[2.2.1]hept-2-ene-5-carboxylate" "methyl vetivate" "methyl 1,6-dimethyl-5-(1-methylvinyl)bicyclo(2.2.1)hept-5-ene-2-carboxylate" "methyl 1,6-dimethyl-5-(1-methylvinyl)bicyclo[2.2.1]hept-5-ene-2-carboxylate" "bicyclo(2.2.1)hept-5-ene-2-carboxylic acid, 1,6-dimethyl-5-(1-methylethenyl)-, methyl ester" "bicyclo[2.2.1]hept-5-ene-2-carboxylic acid, 1,6-dimethyl-5-(1-methylethenyl)-, methyl ester" "methyl 3,4-dimethyl-2-prop-1-en-2-ylbicyclo[2.2.1]hept-2-ene-5-carboxylate" );
standardThermochemistry
{
    dHf_298   -364750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57180.0
}
