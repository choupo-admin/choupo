/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloroundecane  (C11H23Cl, CAS 2473-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloroundecane;
formula     C11H23Cl;
CAS         2473-03-2;
InChIKey    ZHKKNUKCXPWZOP-UHFFFAOYSA-N;
MW          190.755;      // g/mol [origin=calculated method=formula-sum]
Tc          656.43;      // K   [origin=predictive method=joback]
Pc          18.724;      // bar [origin=predictive method=joback]
omega       0.6011;      // -   [origin=predictive method=lee-kesler]
Tb          488.71;      // K   [origin=predictive method=joback]
HvapTb      44465.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.78 1.05562 -0.000595 1.287e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylundecane" "n-undecyl chloride" "undecane, 1-chloro-" "1-chloro-undecane" );
standardThermochemistry
{
    dHf_298   -286110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29810.0
}
