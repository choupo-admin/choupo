/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylglycerol  (C9H12O3, CAS 16354-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylglycerol;
formula     C9H12O3;
CAS         16354-95-3;
InChIKey    CCFAGRVEHSCROQ-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          892.26;      // K   [origin=predictive method=joback]
Pc          46.977;      // bar [origin=predictive method=joback]
omega       1.8688;      // -   [origin=predictive method=lee-kesler]
Tb          707.86;      // K   [origin=predictive method=joback]
HvapTb      87165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.689 0.8937 -0.0005946 1.498e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylpropane-1,2,3-triol" "agn-pc-00l5m4" "(s(r*,r*))-1-phenylglycerol" "1,2,3-propanetriol, 1-phenyl-" );
gibbsFormation
{
    dHf_298   -459810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-278030.0
    phase     gas;
}
