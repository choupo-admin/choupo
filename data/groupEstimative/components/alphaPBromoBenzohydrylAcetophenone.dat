/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-p-bromo-benzohydryl-acetophenone  (C21H17BrO, CAS 5472-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaPBromoBenzohydrylAcetophenone;
formula     C21H17BrO;
CAS         5472-01-5;
InChIKey    WTKRBWMQAHGKHB-UHFFFAOYSA-N;
MW          365.27;      // g/mol [origin=calculated method=formula-sum]
Tc          1153.93;      // K   [origin=predictive method=joback]
Pc          22.334;      // bar [origin=predictive method=joback]
omega       0.9371;      // -   [origin=predictive method=lee-kesler]
Tb          884.69;      // K   [origin=predictive method=joback]
HvapTb      82623.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.749 1.7187 -0.00120106 3.1486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 3; } { group ACCH; count 1; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-bromophenyl)-1,3-diphenyl-propan-1-one" "1-propanone,3-(4-bromophenyl)-1,3-diphenyl-" );
gibbsFormation
{
    dHf_298   129820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=336500.0
    phase     gas;
}
