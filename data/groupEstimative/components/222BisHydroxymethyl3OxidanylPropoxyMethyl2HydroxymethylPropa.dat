/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[[2,2-bis(hydroxymethyl)-3-oxidanyl-propoxy]methyl]-2-(hydroxymethyl)propane-1,3-diol;oxepan-2-one  (C46H82O19, CAS 126850-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222BisHydroxymethyl3OxidanylPropoxyMethyl2HydroxymethylPropa;
formula     C46H82O19;
CAS         126850-29-1;
InChIKey    KBOYKJRAYYUXFE-UHFFFAOYSA-N;
MW          939.143;      // g/mol [origin=calculated method=formula-sum]
Tc          8184.64;      // K   [origin=predictive method=joback]
Pc          5.456;      // bar [origin=predictive method=joback]
omega       -0.5303;      // -   [origin=predictive method=lee-kesler]
Tb          2298.54;      // K   [origin=predictive method=joback]
HvapTb      267484.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.802 4.1494 -0.000934 -5.556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 31; } { group C; count 2; } { group OH; count 6; } { group CH2COO; count 6; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group C; count 2; } { group CH2_ring; count 30; } { group OH; count 6; } { group O; count 1; } { group COO; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxepanone, homopolymer, ester with 2,2'-(oxybis(methylene))bis(2-(hydroxymethyl)-1,3-propanediol) (6:1)" );
gibbsFormation
{
    dHf_298   -4144350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     3092.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2809020.0
    phase     gas;
}
