/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,16-dibromohexadecane  (C16H32Br2, CAS 45223-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        116Dibromohexadecane;
formula     C16H32Br2;
CAS         45223-18-5;
InChIKey    OTFBUFWEFKVFFR-UHFFFAOYSA-N;
MW          384.24;      // g/mol [origin=calculated method=formula-sum]
Tc          879.93;      // K   [origin=predictive method=joback]
Pc          14.613;      // bar [origin=predictive method=joback]
omega       0.9656;      // -   [origin=predictive method=lee-kesler]
Tb          698.00;      // K   [origin=predictive method=joback]
HvapTb      64080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.726 1.6002 -0.0009894 2.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 16; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,16-bis(bromanyl)hexadecane" "hexadecane, 1,16-dibromo-" "hexadecane,1,16-dibromo-" "1,16-dibromohexadecane;hexadecamethylene dibromide;" );
standardThermochemistry
{
    dHf_298   -320910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     881.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112480.0
}
