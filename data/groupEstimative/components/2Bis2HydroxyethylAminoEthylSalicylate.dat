/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(bis(2-hydroxyethyl)amino)ethyl salicylate  (C13H19NO5, CAS 10377-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis2HydroxyethylAminoEthylSalicylate;
formula     C13H19NO5;
CAS         10377-95-4;
InChIKey    NAFDCRMGWKHMJQ-UHFFFAOYSA-N;
MW          269.297;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.54;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       1.8903;      // -   [origin=predictive method=lee-kesler]
Tb          859.36;      // K   [origin=predictive method=joback]
HvapTb      102630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.454 1.4516 -0.00104976 3.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 2; } { group ACOH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethyl 2-oxidanylbenzoate" "benzoic acid, 2-hydroxy-, 2-(bis(2-hydroxyethyl)amino)ethyl ester" "benzoic acid, 2-hydroxy-, 2-[bis(2-hydroxyethyl)amino]ethyl ester" "2-[bis(2-hydroxyethyl)amino]ethyl 2-hydroxybenzoate" );
gibbsFormation
{
    dHf_298   -806640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     751.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-456860.0
    phase     gas;
}
