/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-biphenylmethanol  (C13H12O, CAS 3597-91-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Biphenylmethanol;
formula     C13H12O;
CAS         3597-91-9;
InChIKey    AXCHZLOJGKSWLV-UHFFFAOYSA-N;
MW          184.238;      // g/mol [origin=calculated method=formula-sum]
Tc          872.27;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.9070;      // -   [origin=predictive method=lee-kesler]
Tb          647.56;      // K   [origin=predictive method=joback]
HvapTb      66425.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.149 1.0555 -0.00070916 1.794e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-phenylphenyl)methanol" "biphenyl-4-ylmethanol" "4-phenylbenzyl alcohol" "4-hydroxymethylbiphenyl" "p-phenylbenzyl alcohol" "4-(hydroxymethyl)biphenyl" "biphenyl-4-methanol" "(1,1'-biphenyl)-4-methanol" "[1,1'-biphenyl]-4-methanol" "4-hydroxymethyl-biphenyl" "(4-phenylphenyl)methan-1-ol" "biphenyl-4-yl-methanol" );
gibbsFormation
{
    dHf_298   -2290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136950.0
    phase     gas;
}
