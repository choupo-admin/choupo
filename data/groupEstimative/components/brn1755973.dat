/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1755973  (C9H17NO2, CAS 10141-15-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1755973;
formula     C9H17NO2;
CAS         10141-15-8;
InChIKey    MYZYATBOEKPPPB-UHFFFAOYSA-N;
MW          171.24;      // g/mol [origin=calculated method=formula-sum]
Tc          804.91;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       1.0289;      // -   [origin=predictive method=lee-kesler]
Tb          618.53;      // K   [origin=predictive method=joback]
HvapTb      63511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.343 0.89616 -0.0005292 1.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-methyl-4-oxidanyl-pentan-2-yl)oxypropanenitrile" "2-pentanol, 4-cyanoethoxy-2-methyl-" "3-(4-hydroxy-4-methylpentan-2-yl)oxypropanenitrile" "3-[(4-hydroxy-4-methylpentan-2-yl)oxy]propanenitrile" );
gibbsFormation
{
    dHf_298   -362690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83340.0
    phase     gas;
}
