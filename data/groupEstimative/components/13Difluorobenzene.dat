/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-difluorobenzene  (C6H4F2, CAS 372-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Difluorobenzene;
formula     C6H4F2;
CAS         372-18-9;
InChIKey    UEMGWPRHOOEKTA-UHFFFAOYSA-N;
MW          114.094;      // g/mol [origin=calculated method=formula-sum]
Tc          558.14;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.3094;      // -   [origin=predictive method=lee-kesler]
Tb          367.08;      // K   [origin=predictive method=joback]
HvapTb      30254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.99 0.459 -0.00029956 7.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(fluoranyl)benzene" "m-difluorobenzene" "benzene, m-difluoro-" "1,3-difluoro benzene" "benzene, 1,3-difluoro-" "2,4-difluorobenzene" "meta-difluorobenzene" "1,3-difluorbenzol" "1 3-difluorobenzene" "benzene,3-difluoro-" "1,3 difluoro benzene" "benzene, 1,3-difluoro- (9ci)" );
gibbsFormation
{
    dHf_298   -334330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287200.0
    phase     gas;
}
