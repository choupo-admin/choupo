/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethyl-2,4-heptadiene  (C9H16, CAS 101935-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethyl24Heptadiene;
formula     C9H16;
CAS         101935-28-8;
InChIKey    UCZAREQHYMBQOS-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          600.60;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.3301;      // -   [origin=predictive method=lee-kesler]
Tb          413.60;      // K   [origin=predictive method=joback]
HvapTb      35704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.039 0.89868 -0.000638 1.943e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethylhepta-2,4-diene" );
gibbsFormation
{
    dHf_298   -14230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168240.0
    phase     gas;
}
