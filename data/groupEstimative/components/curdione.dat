/*--------------------------------*- Choupo -*-----------------------*\
  Component: curdione  (C15H24O2, CAS 13657-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        curdione;
formula     C15H24O2;
CAS         13657-68-6;
InChIKey    KDPFMRXIVDLQKX-NHFJXKHHSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          957.17;      // K   [origin=predictive method=joback]
Pc          19.119;      // bar [origin=predictive method=joback]
omega       0.6271;      // -   [origin=predictive method=lee-kesler]
Tb          714.10;      // K   [origin=predictive method=joback]
HvapTb      58852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.36 1.03988 -6.764e-05 -2.181e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } { group CH=C; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,6e,10s)-6,10-dimethyl-3-propan-2-yl-cyclodec-6-ene-1,4-dione" "germacr-1(10)-ene-5,8-dione" "cyclodecene-1,4-dione, 6,10-dimethyl-3-(1-methylethyl)-, (3s-(3r*,6e,10r*))-" "(3s,6e,10s)-6,10-dimethyl-3-propan-2-ylcyclodec-6-ene-1,4-dione" "6-cyclodecene-1,4-dione, 6,10-dimethyl-3-(1-methylethyl)-, (3s-(3r*,6e,10r*))-" "6-cyclodecene-1,4-dione, 6,10-dimethyl-3-(1-methylethyl)-, (3s-(3r*,6e,10r*))- (9ci)" );
gibbsFormation
{
    dHf_298   -577960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183530.0
    phase     gas;
}
