/*--------------------------------*- Choupo -*-----------------------*\
  Component: carvyl phenylacetate  (C18H22O2, CAS 72152-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carvylPhenylacetate;
formula     C18H22O2;
CAS         72152-81-9;
InChIKey    KDKVSYFQKDKENM-IAGOWNOFSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          938.97;      // K   [origin=predictive method=joback]
Pc          17.803;      // bar [origin=predictive method=joback]
omega       0.7017;      // -   [origin=predictive method=lee-kesler]
Tb          711.92;      // K   [origin=predictive method=joback]
HvapTb      65829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.239 1.54014 -0.00086304 1.513e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,5r)-2-methyl-5-prop-1-en-2-yl-cyclohex-2-en-1-yl] 2-phenylethanoate" "[(1r,5r)-2-methyl-5-prop-1-en-2-ylcyclohex-2-en-1-yl] 2-phenylacetate" );
gibbsFormation
{
    dHf_298   -299670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     676.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19080.0
    phase     gas;
}
