/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 1-(1-propenyl)-  (C13H12, CAS 22767-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene11Propenyl;
formula     C13H12;
CAS         22767-77-7;
InChIKey    ZZPDMMIMRUGHBQ-QHHAFSJGSA-N;
MW          168.239;      // g/mol [origin=calculated method=formula-sum]
Tc          788.75;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.4559;      // -   [origin=predictive method=lee-kesler]
Tb          551.84;      // K   [origin=predictive method=joback]
HvapTb      49068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.16 1.11672 -0.00086808 2.726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 7; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(e)-prop-1-enyl]naphthalene" "ghl.pd_mitscher_leg0.318" );
gibbsFormation
{
    dHf_298   221700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348230.0
    phase     gas;
}
