/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl 4-benzyloxybenzoate  (C21H18O3, CAS 56442-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzyl4Benzyloxybenzoate;
formula     C21H18O3;
CAS         56442-22-9;
InChIKey    BPLKDVGMXNZCQO-UHFFFAOYSA-N;
MW          318.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1093.22;      // K   [origin=predictive method=joback]
Pc          19.441;      // bar [origin=predictive method=joback]
omega       0.9276;      // -   [origin=predictive method=lee-kesler]
Tb          845.74;      // K   [origin=predictive method=joback]
HvapTb      79647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.708 1.5846 -0.00093956 1.784e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 4-phenylmethoxybenzoate" "benzyl p-(benzyloxy)benzoate" "benzyl 4-phenylmethoxybenzoate" "ambap56442-22-9" "benzoic acid,4-(phenylmethoxy)-, phenylmethyl ester" );
gibbsFormation
{
    dHf_298   -228150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38170.0
    phase     gas;
}
