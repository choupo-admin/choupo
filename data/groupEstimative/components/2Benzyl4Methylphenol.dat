/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzyl-4-methylphenol  (C14H14O, CAS 716-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Benzyl4Methylphenol;
formula     C14H14O;
CAS         716-96-1;
InChIKey    WGIJGSLQJSMKAH-UHFFFAOYSA-N;
MW          198.265;      // g/mol [origin=calculated method=formula-sum]
Tc          908.58;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.7109;      // -   [origin=predictive method=lee-kesler]
Tb          658.88;      // K   [origin=predictive method=joback]
HvapTb      64986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.269 1.27112 -0.00098952 3.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-(phenylmethyl)phenol" "2-benzyl-p-cresol" "benzyl-p-cresol" "4-methyl-2-benzylphenol" "phenol,4-methyl-2-(phenylmethyl)-" );
gibbsFormation
{
    dHf_298   -48010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127570.0
    phase     gas;
}
