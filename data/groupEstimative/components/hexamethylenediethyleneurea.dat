/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexamethylenediethyleneurea  (C12H22N4O2, CAS 2271-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexamethylenediethyleneurea;
formula     C12H22N4O2;
CAS         2271-93-4;
InChIKey    YVOQADGLLJCMOE-UHFFFAOYSA-N;
MW          254.334;      // g/mol [origin=calculated method=formula-sum]
Tc          911.88;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       1.3884;      // -   [origin=predictive method=lee-kesler]
Tb          721.40;      // K   [origin=predictive method=joback]
HvapTb      72856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.224 1.862 -0.001558 5.2412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH; count 2; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH2_ring; count 4; } { group CdO; count 2; } { group NH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[6-(aziridin-1-ylcarbonylamino)hexyl]aziridine-1-carboxamide" "hexamethylenebis(ethyleneurea)" "hbc (van)" "1,1'-(hexamethylenedicarbamoyl)diaziridine" "n,n'-hexamethylenebis(1-aziridinecarboxamide)" "n,n'-hexamethylene bis-1-aziridinyl carboxamide" "1,6-hexamethylenebis(ethyleneurea)" "1-aziridinecarboxamide, n,n'-1,6-hexanediylbis-" "n,n'-(hexane-1,6-diyl)bis(aziridine-1-carboxamide)" "1,6-bis(3,3-ethyleniminoureido)-n-hexane" "n,n'-hexamethylenebis-1-aziridinecarboxamide" "n,n'-1,6-hexanediylbis-1-aziridinecarboxamide" );
gibbsFormation
{
    dHf_298   -75570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=353780.0
    phase     gas;
}
