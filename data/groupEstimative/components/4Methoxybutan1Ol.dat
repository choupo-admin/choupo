/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxybutan-1-ol  (C5H12O2, CAS 111-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxybutan1Ol;
formula     C5H12O2;
CAS         111-32-0;
InChIKey    KOVAQMSVARJMPH-UHFFFAOYSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          590.63;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       0.8006;      // -   [origin=predictive method=lee-kesler]
Tb          428.60;      // K   [origin=predictive method=joback]
HvapTb      45813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.134 0.44962 -0.0001676 3.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-1-butanol" "1-butanol, 4-methoxy-" "dowanol bmat" "dowanol bm" "butylene glycol methyl ether" "dowanal bmat" "butylene glycol monomethyl ether" "4-methoxybutyl alcohol" "4-methoxybutanol-1" "tetramethylene glycol monomethyl ether" );
gibbsFormation
{
    dHf_298   -430980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250600.0
    phase     gas;
}
