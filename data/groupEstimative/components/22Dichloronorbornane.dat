/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichloronorbornane  (C7H10Cl2, CAS 19916-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dichloronorbornane;
formula     C7H10Cl2;
CAS         19916-65-5;
InChIKey    AVUURMDQMOTMIU-UHFFFAOYSA-N;
MW          165.057;      // g/mol [origin=calculated method=formula-sum]
Tc          676.20;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.2949;      // -   [origin=predictive method=lee-kesler]
Tb          447.94;      // K   [origin=predictive method=joback]
HvapTb      38484.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.35 1.24 -0.001269 5.286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)bicyclo[2.2.1]heptane" "2,2-dichlorobicyclo[2.2.1]heptane" "2,2-dichlorobicyclo(2.2.1)heptane" "bicyclo(2.2.1)heptane, 2,2-dichloro-" "bicyclo[2.2.1]heptane, 2,2-dichloro-" "norbornane,2-dichloro-" "norbornane, 2,2-dichloro-" "3,3-dichlorobicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane,2-dichloro-" );
standardThermochemistry
{
    dHf_298   -84950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80400.0
}
