/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylquinuclidine  (C13H17N, CAS 51069-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenylquinuclidine;
formula     C13H17N;
CAS         51069-11-5;
InChIKey    CSKNWIPXDBBWRW-UHFFFAOYSA-N;
MW          187.286;      // g/mol [origin=calculated method=formula-sum]
Tc          801.73;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.4742;      // -   [origin=predictive method=lee-kesler]
Tb          558.82;      // K   [origin=predictive method=joback]
HvapTb      48007.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-215.06 1.8944 -0.0018092 7.013e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-1-azabicyclo[2.2.2]octane" "1-azabicyclo[2.2.2]octane, 4-phenyl-" "1-azabicyclo(2.2.2)octane, 4-phenyl-" "1-azabicyclo[2.2.2]octane,4-phenyl-" "4-phenyl-1-aza-bicyclo[2.2.2]octane" "quinuclidine,4-phenyl- (6ci); 4-phenyl-1-azabicyclo[2.2.2]octane; 4-phenylquinuclidine" );
standardThermochemistry
{
    dHf_298   167430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=393390.0
}
