/*--------------------------------*- Choupo -*-----------------------*\
  Component: norbornane, 7,7-dimethyl-2-methylene-  (C10H16, CAS 471-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norbornane77Dimethyl2Methylene;
formula     C10H16;
CAS         471-84-1;
InChIKey    XCPQUQHBVVXMRQ-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          648.51;      // K   [origin=predictive method=joback]
Pc          28.843;      // bar [origin=predictive method=joback]
omega       0.3185;      // -   [origin=predictive method=lee-kesler]
Tb          440.88;      // K   [origin=predictive method=joback]
HvapTb      36551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.57 1.39394 -0.001299 5.172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,7-dimethyl-3-methylidene-bicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane, 7,7-dimethyl-2-methylene-" "bicyclo(2.2.1)heptane, 7,7-dimethyl-2-methylene-" "alpha-fenchene" "7,7-dimethyl-2-methylenebicyclo(2.2.1)heptane" "7,7-dimethyl-3-methylidenebicyclo[2.2.1]heptane" );
standardThermochemistry
{
    dHf_298   -31150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182600.0
}
