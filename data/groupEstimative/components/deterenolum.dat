/*--------------------------------*- Choupo -*-----------------------*\
  Component: deterenolum  (C11H17NO2, CAS 7376-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deterenolum;
formula     C11H17NO2;
CAS         7376-66-1;
InChIKey    MPCPSVWSWKWJLO-UHFFFAOYSA-N;
MW          195.262;      // g/mol [origin=calculated method=formula-sum]
Tc          907.76;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       1.3049;      // -   [origin=predictive method=lee-kesler]
Tb          700.05;      // K   [origin=predictive method=joback]
HvapTb      77709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.219 1.24654 -0.00094756 2.976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-oxidanyl-2-(propan-2-ylamino)ethyl]phenol" "deterenol" "4-[1-hydroxy-2-(propan-2-ylamino)ethyl]phenol" "4-hydroxy-alpha-isopropylaminomethylbenzyl alcohol" "( -)-1-(4-hydroxyphenyl)-2-(isopropylamino)ethanol" "benzyl alcohol, p-hydroxy-alpha-isopropylaminomethyl-" "4-hydroxy-alpha-(((1-methylethyl)amino)methyl)benzenemethanol" "deterenol [inn]" "4-(1-hydroxy-2-(isopropylamino)ethyl)phenol" "4-{1-hydroxy-2-[(propan-2-yl)amino]ethyl}phenol, 8" );
standardThermochemistry
{
    dHf_298   -320470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-52780.0
}
