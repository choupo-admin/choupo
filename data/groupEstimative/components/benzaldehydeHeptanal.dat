/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzaldehyde;heptanal  (C14H20O2, CAS 68608-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H20O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzaldehydeHeptanal;
formula     C14H20O2;
CAS         68608-75-3;
InChIKey    NPSTUPUZGGHOHT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          776.52;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       0.5971;      // -   [origin=predictive method=lee-kesler]
Tb          573.08;      // K   [origin=predictive method=joback]
HvapTb      53675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.025 1.03132 -0.0005002 5.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 5; } { group AC; count 1; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "alpha-amylcinnamaldehyde lights" "benzaldehyde; heptanal" "benzaldehyde - heptanal (1:1)" "benzaldehyde, reaction products with heptanal, distn. lights" );
gibbsFormation
{
    dHf_298   -216510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     802.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19090.0
    phase     gas;
}
