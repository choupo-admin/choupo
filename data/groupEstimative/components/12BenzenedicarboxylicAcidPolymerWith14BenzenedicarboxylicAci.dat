/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-benzenedicarboxylic acid, polymer with 1,4-benzenedicarboxylic acid and 1,4-butanediol  (C20H22O10, CAS 68966-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BenzenedicarboxylicAcidPolymerWith14BenzenedicarboxylicAci;
formula     C20H22O10;
CAS         68966-59-6;
InChIKey    GTPPRQOTLDUTCQ-UHFFFAOYSA-N;
MW          422.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1899.61;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       1.1441;      // -   [origin=predictive method=lee-kesler]
Tb          1489.72;      // K   [origin=predictive method=joback]
HvapTb      168592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.114 1.4858 -0.00051412 -7.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;phthalic acid;terephthalic acid" "phthalic acid, terephthalic acid, 1,4-butanediol polymer" );
standardThermochemistry
{
    dHf_298   -1934790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1239.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1535720.0
}
