/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl iodide  (C3H5I, CAS 556-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylIodide;
formula     C3H5I;
CAS         556-56-9;
InChIKey    HFEHLDPGIKPNKL-UHFFFAOYSA-N;
MW          167.973;      // g/mol [origin=calculated method=formula-sum]
Tc          568.65;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       0.1914;      // -   [origin=predictive method=lee-kesler]
Tb          358.06;      // K   [origin=predictive method=joback]
HvapTb      30975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.861 0.3078 -0.0002437 8.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanylprop-1-ene" "3-iodo-1-propene" "1-propene, 3-iodo-" "3-iodopropene" "propene, 3-iodo-" "3-iodopropylene" "3-iodoprop-1-ene" "3-iodo-prop-1-ene" );
standardThermochemistry
{
    dHf_298   97050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120340.0
}
