/*--------------------------------*- Choupo -*-----------------------*\
  Component: cedr-8(15)-en-9-ol  (C15H24O, CAS 28231-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cedr815En9Ol;
formula     C15H24O;
CAS         28231-03-0;
InChIKey    DJYWGTBEZVORGE-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          857.13;      // K   [origin=predictive method=joback]
Pc          22.334;      // bar [origin=predictive method=joback]
omega       0.8347;      // -   [origin=predictive method=lee-kesler]
Tb          649.37;      // K   [origin=predictive method=joback]
HvapTb      62676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-226.3 2.28316 -0.002197 8.975e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 4; } { group C; count 2; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cedrenol" "1h-3a,7-methanoazulen-5-ol, octahydro-3,8,8-trimethyl-6-methylene-" "1h-3a,7-methanoazulen-5-ol, octahydro-6-methylene-3,8,8-trimethyl-" "octahydro-3,8,8-trimethyl-6-methylene-1h-3a,7-methanoazulen-5-ol" "octahydro-6-methylene-3,8,8-trimethyl-1h-3a,7-methanoazulen-5-ol" "cedrenol (6ci)" "agn-pc-00ijty" ".beta.-cedren-9-.alpha.-ol" "cedr-8(15)-en-9-ol (8ci)" );
standardThermochemistry
{
    dHf_298   -245380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115620.0
}
