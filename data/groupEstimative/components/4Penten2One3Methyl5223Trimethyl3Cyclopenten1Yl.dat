/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-penten-2-one, 3-methyl-5-(2,2,3-trimethyl-3-cyclopenten-1-yl)-  (C14H22O, CAS 67801-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Penten2One3Methyl5223Trimethyl3Cyclopenten1Yl;
formula     C14H22O;
CAS         67801-15-4;
InChIKey    WPDAGRUACGXJJP-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          804.18;      // K   [origin=predictive method=joback]
Pc          20.181;      // bar [origin=predictive method=joback]
omega       0.5740;      // -   [origin=predictive method=lee-kesler]
Tb          592.50;      // K   [origin=predictive method=joback]
HvapTb      52825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.8 1.6134 -0.00133094 4.8186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-5-(2,2,3-trimethylcyclopent-3-en-1-yl)pent-4-en-2-one" "agn-pc-03vksw" "3-methyl-5-(2,2,3-trimethyl-3-cyclopenten-1-yl)pent-4-en-2-one" );
gibbsFormation
{
    dHf_298   -231240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59540.0
    phase     gas;
}
