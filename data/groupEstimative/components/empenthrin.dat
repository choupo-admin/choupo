/*--------------------------------*- Choupo -*-----------------------*\
  Component: empenthrin  (C18H26O2, CAS 54406-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        empenthrin;
formula     C18H26O2;
CAS         54406-48-3;
InChIKey    YUGWDVYLFSETPE-JLHYYAGUSA-N;
MW          274.404;      // g/mol [origin=calculated method=formula-sum]
Tc          871.66;      // K   [origin=predictive method=joback]
Pc          15.235;      // bar [origin=predictive method=joback]
omega       0.6520;      // -   [origin=predictive method=lee-kesler]
Tb          665.06;      // K   [origin=predictive method=joback]
HvapTb      60759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.069 2.00072 -0.00167413 6.0309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 2; } { group CH_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group tCH; count 1; } { group tC; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-4-methylhept-4-en-1-yn-3-yl] 2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "vaporthrin" "d-empenthrin" "bunganon va plate" "empenthrin [iso]" "s 2852 forte" "(rs)-(e)-1-ethynyl-2-methyl-2-pentenyl(1r)-cis,trans-chrysanthemate" "1-ethynyl-2-methylpent-2-enyl 2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropanecarboxylate" "cyclopropanecarboxylic acid, 2,2-dimethyl-3-(2-methyl-1-propenyl)-, 1-ethynyl-2-methyl-2-pentenyl ester" "1-ethinyl-2-methyl-2-penten-1-yl chrysanthemate" "1-ethynyl-2-methyl-2-pentenyl chrysanthemate" "o257" );
gibbsFormation
{
    dHf_298   -183290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=194120.0
    phase     gas;
}
