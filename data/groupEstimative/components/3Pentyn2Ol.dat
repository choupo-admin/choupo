/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pentyn-2-ol  (C5H8O, CAS 27301-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pentyn2Ol;
formula     C5H8O;
CAS         27301-54-8;
InChIKey    HJFRLXPEVRXBQZ-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          603.39;      // K   [origin=predictive method=joback]
Pc          48.360;      // bar [origin=predictive method=joback]
omega       0.5755;      // -   [origin=predictive method=lee-kesler]
Tb          414.74;      // K   [origin=predictive method=joback]
HvapTb      45167.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.51 0.36894 -0.00018966 3.658e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-3-yn-2-ol" "2-pentyn-4-ol" "(s)-pent-3-yne-2-ol" );
standardThermochemistry
{
    dHf_298   -31740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54760.0
}
