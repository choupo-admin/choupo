/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-difluorophenyl isocyanate  (C7H3F2NO, CAS 59025-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DifluorophenylIsocyanate;
formula     C7H3F2NO;
CAS         59025-55-7;
InChIKey    HNENEALJPWJWJY-UHFFFAOYSA-N;
MW          155.103;      // g/mol [origin=calculated method=formula-sum]
Tc          665.12;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.5365;      // -   [origin=predictive method=lee-kesler]
Tb          461.61;      // K   [origin=predictive method=joback]
HvapTb      42674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(fluoranyl)-1-isocyanato-benzene" "2,4-difluoro-1-isocyanatobenzene" "isocyanic acid 2,4-difluorophenyl ester" "2,4-difluoroisocyanatobenzene" "benzene, 2,4-difluoro-1-isocyanato-" "2,4-difluorobenzenisocyanate" "2,4-difluorophenylisocyanate" "2,4-difluoro-1-isocyanato-benzene;" "1,5-difluoro-2-isocyanatobenzene" "benzene, 2,4-difluoro-1-isocyanato- (9ci);isocyanic acid 2,4-difluorophenyl ester" );
