/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2,5-dibromohexanedioate  (C10H16Br2O4, CAS 869-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl25Dibromohexanedioate;
formula     C10H16Br2O4;
CAS         869-10-3;
InChIKey    UBCNJHBDCUBIPB-UHFFFAOYSA-N;
MW          360.042;      // g/mol [origin=calculated method=formula-sum]
Tc          881.68;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       1.0055;      // -   [origin=predictive method=lee-kesler]
Tb          676.28;      // K   [origin=predictive method=joback]
HvapTb      64762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.634 0.93244 -0.0004802 6.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group Br; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,5-bis(bromanyl)hexanedioate" "diethyl 2,5-dibromoadipate" "diethyl meso-2,5-dibromoadipate" "diethyl 2,5-dibromohexane-1,6-dioate" "1,6-diethyl 2,5-dibromohexanedioate" "2,5-dibromoadipic acid diethyl ester" "diethyl (2r,5s)-2,5-dibromohexanedioate;" "hexanedioic acid, 2,5-dibromo-, 1,6-diethyl ester" );
gibbsFormation
{
    dHf_298   -842190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     731.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-563660.0
    phase     gas;
}
