/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-((6-methyl-3-cyclohexen-1-yl)carbonyl)piperidine  (C13H21NO, CAS 72299-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Methyl3Cyclohexen1YlCarbonylPiperidine;
formula     C13H21NO;
CAS         72299-02-6;
InChIKey    HKEBZICUKLQKGY-UHFFFAOYSA-N;
MW          207.317;      // g/mol [origin=calculated method=formula-sum]
Tc          823.71;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.5938;      // -   [origin=predictive method=lee-kesler]
Tb          597.34;      // K   [origin=predictive method=joback]
HvapTb      54299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.57 1.53252 -0.00097298 2.2516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group CH=CH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6-methylcyclohex-3-en-1-yl)-piperidin-1-yl-methanone" "piperidine, 1-((6-methyl-3-cyclohexen-1-yl)carbonyl)-" "(6-methylcyclohex-3-en-1-yl)-piperidin-1-ylmethanone" "methanone,(6-methyl-3-cyclohexen-1-yl)-1-piperidinyl-" );
standardThermochemistry
{
    dHf_298   -184120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131400.0
}
