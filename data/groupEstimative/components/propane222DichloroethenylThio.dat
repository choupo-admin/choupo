/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 2-(2,2-dichloroethenyl)thio]-  (C5H8Cl2S, CAS 19284-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane222DichloroethenylThio;
formula     C5H8Cl2S;
CAS         19284-67-4;
InChIKey    QVTHANMSUIAFKP-UHFFFAOYSA-N;
MW          171.079;      // g/mol [origin=calculated method=formula-sum]
Tc          686.26;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.3437;      // -   [origin=predictive method=lee-kesler]
Tb          461.24;      // K   [origin=predictive method=joback]
HvapTb      41961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.17 0.51263 -0.0003381 8.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group Cl_C=C_; count 2; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,2-bis(chloranyl)ethenylsulfanyl]propane" "propane, 2-(2,2-dichloroethenyl)thio)-" "2-(2,2-dichloroethenylsulfanyl)propane" "2,2-dichloroethenyl propan-2-yl sulfide" );
standardThermochemistry
{
    dHf_298   -33990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69710.0
}
