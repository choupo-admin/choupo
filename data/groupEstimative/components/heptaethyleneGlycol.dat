/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptaethylene glycol  (C14H30O8, CAS 5617-32-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptaethyleneGlycol;
formula     C14H30O8;
CAS         5617-32-3;
InChIKey    XPJRQAIZZQMSCM-UHFFFAOYSA-N;
MW          326.386;      // g/mol [origin=calculated method=formula-sum]
Tc          1028.14;      // K   [origin=predictive method=joback]
Pc          16.259;      // bar [origin=predictive method=joback]
omega       1.3940;      // -   [origin=predictive method=lee-kesler]
Tb          838.80;      // K   [origin=predictive method=joback]
HvapTb      94576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (153.744 1.0226 -0.0001326 -1.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2O; count 4; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 14; } { group OH; count 2; } { group O; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-[2-(2-hydroxyethyloxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethanol" "3,6,9,12,15,18-hexaoxaicosane-1,20-diol" "3,6,9,12,15,18-hexaoxaeicosane-1,20-diol" "p33" "2-{2-[2-(2-{2-[2-(2-hydroxyethoxy)ethoxy]ethoxy}ethoxy)ethoxy]ethoxy}ethan-1-o l" "heptaethyleneglycol (6ci,7ci,8ci)" "2-[2-[2-[2-[2-[2-(2-hydroxyethoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethanol" );
standardThermochemistry
{
    dHf_298   -1430070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     870.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-836640.0
}
