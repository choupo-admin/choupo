/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylacrylic acid  (C9H8O2, CAS 492-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylacrylicAcid;
formula     C9H8O2;
CAS         492-38-6;
InChIKey    ONPJWQSDZCGSQM-UHFFFAOYSA-N;
MW          148.161;      // g/mol [origin=calculated method=formula-sum]
Tc          807.56;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.6708;      // -   [origin=predictive method=lee-kesler]
Tb          574.27;      // K   [origin=predictive method=joback]
HvapTb      54478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.28 0.8106 -0.0005948 1.686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylprop-2-enoic acid" "atropic acid" ".alpha.-phenyl acrylic acid" "benzeneacetic acid, .alpha.-methylene-" "acrylic acid, 2-phenyl-" "2-propenoic acid, 2-phenyl-" "2-phenylpropenoic acid" "alpha-phenylacrylic acid" "alpha-phenyl acrylic acid" "alpha-toluic acid, alpha-methylene-" "benzeneacetic acid, alpha-methylene-" ".alpha.-toluic acid, .alpha.-methylene-" );
gibbsFormation
{
    dHf_298   -227190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127310.0
    phase     gas;
}
