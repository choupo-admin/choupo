/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(1-ethoxyethoxy)hex-2-yn-1-ol  (C10H18O3, CAS 61565-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        61EthoxyethoxyHex2Yn1Ol;
formula     C10H18O3;
CAS         61565-20-6;
InChIKey    PNORXTMXJGBDBP-UHFFFAOYSA-N;
MW          186.251;      // g/mol [origin=calculated method=formula-sum]
Tc          752.15;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.9983;      // -   [origin=predictive method=lee-kesler]
Tb          573.98;      // K   [origin=predictive method=joback]
HvapTb      61117.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.965 0.71754 -0.00023966 -1.352e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group CH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group tC; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexyn-1-ol, 6-(1-ethoxyethoxy)-" "6-(1-ethoxyethoxy)-2-hexyn-1-ol" );
standardThermochemistry
{
    dHf_298   -399380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113140.0
}
