/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-3-heptanol  (C8H18O, CAS 5582-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl3Heptanol;
formula     C8H18O;
CAS         5582-82-1;
InChIKey    PQOSNJHBSNZITJ-UHFFFAOYSA-N;
MW          130.231;      // g/mol [origin=calculated method=formula-sum]
Tc          640.52;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.7540;      // -   [origin=predictive method=lee-kesler]
Tb          471.59;      // K   [origin=predictive method=joback]
HvapTb      48785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.566 0.92366 -0.0006136 1.657e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylheptan-3-ol" "butylethylmethylcarbinol" "3-heptanol, 3-methyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -369430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117500.0
}
