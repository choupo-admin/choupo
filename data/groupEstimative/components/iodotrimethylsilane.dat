/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodotrimethylsilane  (C3H9ISi, CAS 16029-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H9ISi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        iodotrimethylsilane;
formula     C3H9ISi;
CAS         16029-98-4;
InChIKey    CSRZQMIRAZTJOY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          200.09;      // g/mol [origin=calculated method=formula-sum]
Tc          576.78;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.1274;      // -   [origin=predictive method=lee-kesler]
Tb          362.78;      // K   [origin=predictive method=joback]
HvapTb      31939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.67 0.12166 0.000194 -1.528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group I; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanyl(trimethyl)silane" "trimethylsilyl iodide" "trimethyliodosilane" "iodo(trimethyl)silane" "silane, iodotrimethyl-" "trimethylsilyliodide" "tmis" "trimethyliodosilane;iodo-trimethyl-silane;silane, iodotrimethyl-;trimethyl iodo silane;(iodo)-trimethylsilane;trimethylsilyl iodide;trimethyliodosilane(tmis);trimethyliodo silane;" );
standardThermochemistry
{
    dHf_298   -140000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72260.0
}
