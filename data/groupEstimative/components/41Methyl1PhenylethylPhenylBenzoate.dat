/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(1-methyl-1-phenylethyl)phenyl benzoate  (C22H20O2, CAS 64641-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        41Methyl1PhenylethylPhenylBenzoate;
formula     C22H20O2;
CAS         64641-84-5;
InChIKey    IKYNDBQJTHKDIL-UHFFFAOYSA-N;
MW          316.4;      // g/mol [origin=calculated method=formula-sum]
Tc          1101.85;      // K   [origin=predictive method=joback]
Pc          18.452;      // bar [origin=predictive method=joback]
omega       0.7955;      // -   [origin=predictive method=lee-kesler]
Tb          842.97;      // K   [origin=predictive method=joback]
HvapTb      78167.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.59 1.86864 -0.00127676 3.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 14; } { group AC; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-phenylpropan-2-yl)phenyl] benzoate" "phenol, 4-(1-methyl-1-phenylethyl)-, benzoate" "phenol, 4-(1-methyl-1-phenylethyl)-, 1-benzoate" "p-cumylphenyl benzoate" );
gibbsFormation
{
    dHf_298   -125320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154430.0
    phase     gas;
}
