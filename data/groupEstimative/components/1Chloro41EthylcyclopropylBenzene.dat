/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-4-(1-ethylcyclopropyl)benzene  (C11H13Cl, CAS 63340-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro41EthylcyclopropylBenzene;
formula     C11H13Cl;
CAS         63340-06-7;
InChIKey    MQJNPOVDSYPPHV-UHFFFAOYSA-N;
MW          180.675;      // g/mol [origin=calculated method=formula-sum]
Tc          762.16;      // K   [origin=predictive method=joback]
Pc          30.190;      // bar [origin=predictive method=joback]
omega       0.4162;      // -   [origin=predictive method=lee-kesler]
Tb          527.35;      // K   [origin=predictive method=joback]
HvapTb      46165.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.059 1.36002 -0.00131196 5.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-(1-ethylcyclopropyl)benzene" "benzene,1-chloro-4-(1-ethylcyclopropyl)-" "benzene, 1-chloro-4-(1-ethylcyclopropyl)-" );
standardThermochemistry
{
    dHf_298   26990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187850.0
}
