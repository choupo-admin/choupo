/*--------------------------------*- Choupo -*-----------------------*\
  Component: ambenoxan  (C14H21NO4, CAS 1617-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ambenoxan;
formula     C14H21NO4;
CAS         1617-99-8;
InChIKey    IRDXKUVPWPVZMA-UHFFFAOYSA-N;
MW          267.325;      // g/mol [origin=calculated method=formula-sum]
Tc          919.60;      // K   [origin=predictive method=joback]
Pc          22.041;      // bar [origin=predictive method=joback]
omega       1.0137;      // -   [origin=predictive method=lee-kesler]
Tb          711.50;      // K   [origin=predictive method=joback]
HvapTb      70057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.375 1.28052 -0.00067456 1.089e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group O_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2,3-dihydro-1,4-benzodioxin-3-ylmethyl)-2-(2-methoxyethoxy)ethanamine" "ambenoxane" "ambenoxano" "ambenoxanum" "ambenoxane [inn-french]" "ambenoxanum [inn-latin]" "1617-99-8 (hydrochloride)" "2-(3',6'-dioxaheptyl)aminomethyl-1,4-benzodioxan" "2-(3',6'-dioxaheptyl)-aminomethyl-1:4-benzodioxane" "n-(2-(2-methoxyethoxy)ethyl)-1,4-benzodioxan-2-methylamine" "1,4-benzodioxin-2-methanamine, 2,3-dihydro-n-[2-(2-methoxyethoxy)ethyl]-" "n-(2,3-dihydro-1,4-benzodioxin-2-ylmethyl)-2-(2-methoxyethoxy)ethanamine" );
gibbsFormation
{
    dHf_298   -515560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74420.0
    phase     gas;
}
