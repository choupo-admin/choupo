/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(1-aziridinyl)butyronitrile  (C6H10N2, CAS 4078-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        31AziridinylButyronitrile;
formula     C6H10N2;
CAS         4078-19-7;
InChIKey    KMBJEVSXNIUPIH-UHFFFAOYSA-N;
MW          110.16;      // g/mol [origin=calculated method=formula-sum]
Tc          657.55;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.5206;      // -   [origin=predictive method=lee-kesler]
Tb          458.10;      // K   [origin=predictive method=joback]
HvapTb      41133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.999 0.82542 -0.0007094 2.482e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(aziridin-1-yl)butanenitrile" "1-aziridinepropanenitrile, .beta.-methyl-" "3-(n-aziridinyl)butyronitrile" "1-aziridinepropionitrile, beta-methyl-" "1-aziridinepropionitrile, .beta.-methyl-" "beta-methylaziridine-1-propiononitrile" "1-aziridinepropanenitrile, beta-methyl-" );
gibbsFormation
{
    dHf_298   159260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=321720.0
    phase     gas;
}
