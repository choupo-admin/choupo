/*--------------------------------*- Choupo -*-----------------------*\
  Component: ionox wsp  (C29H40O2, CAS 77-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ionoxWsp;
formula     C29H40O2;
CAS         77-62-3;
InChIKey    PHXLONCQBNATSL-UHFFFAOYSA-N;
MW          420.637;      // g/mol [origin=calculated method=formula-sum]
Tc          1410.81;      // K   [origin=predictive method=joback]
Pc          14.770;      // bar [origin=predictive method=joback]
omega       1.1532;      // -   [origin=predictive method=lee-kesler]
Tb          1137.22;      // K   [origin=predictive method=joback]
HvapTb      111932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-283.119 3.50028 -0.00308796 1.1667e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group C; count 2; } { group ACH; count 4; } { group AC; count 3; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 10; } { group C_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-(1-methylcyclohexyl)-6-[[5-methyl-3-(1-methylcyclohexyl)-2-oxidanyl-phenyl]methyl]phenol" "2,2'-methylenebis[6-(1-methylcyclohexyl)-p-cresol]" "bisalkofen mtsp" "nonox wsp" "2,2'-methylenebis[4-methyl-6-(1-methylcyclohexyl)phenol]" "2,2'-methylenebis(6-(1-methylcyclohexyl)-p-cresol)" "p-cresol, 2,2'-methylenebis(6-(1-methylcyclohexyl)-" "2,2'-methylenebis(4-methyl-6-(1-methylcyclohexyl)phenol)" "bis[2-hydroxy-5-methyl-3-(1-methylcyclohexyl)phenyl]methane" "phenol, 2,2'-methylenebis(4-methyl-6-(1-methylcyclohexyl)-" "phenol, 2,2'-methylenebis[4-methyl-6-(1-methylcyclohexyl)-" "2-[[2-hydroxy-5-methyl-3-(1-methylcyclohexyl)phenyl]methyl]-4-methyl-6-(1-methylcyclohexyl)phenol" );
standardThermochemistry
{
    dHf_298   -430210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1179.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108280.0
}
