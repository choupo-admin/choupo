/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(bis(2-hydroxyethyl)amino)ethyl laurate  (C18H37NO4, CAS 1793-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bis2HydroxyethylAminoEthylLaurate;
formula     C18H37NO4;
CAS         1793-68-6;
InChIKey    WGDZQINGRJYRHS-UHFFFAOYSA-N;
MW          331.497;      // g/mol [origin=calculated method=formula-sum]
Tc          1063.69;      // K   [origin=predictive method=joback]
Pc          13.137;      // bar [origin=predictive method=joback]
omega       1.1814;      // -   [origin=predictive method=lee-kesler]
Tb          866.46;      // K   [origin=predictive method=joback]
HvapTb      98470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.826 1.85092 -0.0010342 2.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group OH; count 2; } { group CH2COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group OH; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethyl dodecanoate" "dodecanoic acid, 2-(bis(2-hydroxyethyl)amino)ethyl ester" "dodecanoic acid, 2-[bis(2-hydroxyethyl)amino]ethyl ester" "dodecanoic acid,2-[bis(2-hydroxyethyl)amino]ethyl ester" "dodecanoic acid 2-[bis(2-hydroxyethyl)amino]ethyl ester" "lauricacid, 2-[bis(2-hydroxyethyl)amino]ethyl ester (6ci,7ci,8ci); ethanol,2,2',2''-nitrilotri-, monolaurate (ester) (8ci);2-[bis(2-hydroxyethyl)amino]ethyl dodecanoate; diethanolaminoethyl laurate;product no. 9; triethanolamine lauric monoester; triethanolamine monolaurate;[2-(lauroyloxy)ethyl]diethanolamine" );
standardThermochemistry
{
    dHf_298   -969060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1026.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-372550.0
}
