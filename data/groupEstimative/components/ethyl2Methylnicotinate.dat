/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-methylnicotinate  (C9H11NO2, CAS 1721-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Methylnicotinate;
formula     C9H11NO2;
CAS         1721-26-2;
InChIKey    TZORNSWZUZDUCU-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          772.52;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.5885;      // -   [origin=predictive method=lee-kesler]
Tb          549.10;      // K   [origin=predictive method=joback]
HvapTb      52183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.571 0.6994 -0.00034462 4.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C5H3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methylpyridine-3-carboxylate" "2-methylnicotinic acid ethyl ester" "2-methyl-nicotinic acid ethyl ester" "3-pyridinecarboxylic acid, 2-methyl-, ethyl ester" "ethyl 2-methyl nicotinate" "ethyl 2-methylnicotinate," "ethyl 2-methyl-3-pyridinecarboxylate" "2-methylpyridine-3-carboxylic acid ethyl ester" "2-methyl-3-pyridinecarboxylic acid ethyl ester;2-methylpyridine-3-carboxylic acid ethyl ester;2-methylnicotin ethyl ester" );
standardThermochemistry
{
    dHf_298   -288520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105640.0
}
