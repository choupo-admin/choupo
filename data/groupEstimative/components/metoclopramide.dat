/*--------------------------------*- Choupo -*-----------------------*\
  Component: metoclopramide  (C14H22ClN3O2, CAS 364-62-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        metoclopramide;
formula     C14H22ClN3O2;
CAS         364-62-5;
InChIKey    TTWJBBZEZQICBI-UHFFFAOYSA-N;
MW          299.799;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.22;      // K   [origin=predictive method=joback]
Pc          20.680;      // bar [origin=predictive method=joback]
omega       1.2268;      // -   [origin=predictive method=lee-kesler]
Tb          810.40;      // K   [origin=predictive method=joback]
HvapTb      83681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.494 1.25406 -0.00066318 1.1026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-5-chloranyl-n-[2-(diethylamino)ethyl]-2-methoxy-benzamide" "reglan" "primperan" "reliveran" "maxolon" "metaclopramide" "metochlopramide" "cerucal" "elieten" "methochlopramide" "metaclopromide" "metoclopramida" );
standardThermochemistry
{
    dHf_298   -235920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171290.0
}
