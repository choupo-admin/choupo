/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimercaptopropan-2-ol  (C3H8OS2, CAS 584-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimercaptopropan2Ol;
formula     C3H8OS2;
CAS         584-04-3;
InChIKey    WNPSAOYKQQUALV-UHFFFAOYSA-N;
MW          124.216;      // g/mol [origin=calculated method=formula-sum]
Tc          698.14;      // K   [origin=predictive method=joback]
Pc          61.226;      // bar [origin=predictive method=joback]
omega       0.7425;      // -   [origin=predictive method=lee-kesler]
Tb          485.70;      // K   [origin=predictive method=joback]
HvapTb      52037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.552 0.3833 -0.0002178 4.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(sulfanyl)propan-2-ol" "1,3-disulfanylpropan-2-ol" "1,3-dimercapto-2-propanol" "1,3-dithioglycerol" "2-propanol, 1,3-dimercapto-" "alpha,gamma-dithioglycerol" "2-propanol,1,3-dimercapto-" );
gibbsFormation
{
    dHf_298   -185800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106100.0
    phase     gas;
}
