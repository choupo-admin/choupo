/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4-triiodobenzene  (C6H3I3, CAS 615-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124Triiodobenzene;
formula     C6H3I3;
CAS         615-68-9;
InChIKey    KSXFNGRHPAHIQJ-UHFFFAOYSA-N;
MW          455.79;      // g/mol [origin=calculated method=formula-sum]
Tc          987.66;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.3338;      // -   [origin=predictive method=lee-kesler]
Tb          652.94;      // K   [origin=predictive method=joback]
HvapTb      60669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.2 0.4929 -0.00044392 1.556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group I; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tris(iodanyl)benzene" "benzene, 1,2,4-triiodo-" "1,2,4-triiodobenzene;" );
standardThermochemistry
{
    dHf_298   277030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267150.0
}
