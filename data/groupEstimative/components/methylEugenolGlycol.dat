/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl eugenol glycol  (C11H16O4, CAS 26509-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylEugenolGlycol;
formula     C11H16O4;
CAS         26509-45-5;
InChIKey    NZKYZDCTLPYISK-UHFFFAOYSA-N;
MW          212.245;      // g/mol [origin=calculated method=formula-sum]
Tc          902.55;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       1.5438;      // -   [origin=predictive method=lee-kesler]
Tb          716.68;      // K   [origin=predictive method=joback]
HvapTb      81470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.482 0.79844 -0.00031372 4.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,4-dimethoxyphenyl)propane-1,2-diol" "2,3-propanediol, 1-(3,4-dimethoxyphenyl)-" "3-(3,4-dimethoxyphenyl)-1,2-propanediol" );
gibbsFormation
{
    dHf_298   -630960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351190.0
    phase     gas;
}
