/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tridecyne  (C13H24, CAS 26186-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tridecyne;
formula     C13H24;
CAS         26186-02-7;
InChIKey    GZEDKDBFUBPZNG-UHFFFAOYSA-N;
MW          180.335;      // g/mol [origin=calculated method=formula-sum]
Tc          657.13;      // K   [origin=predictive method=joback]
Pc          18.611;      // bar [origin=predictive method=joback]
omega       0.5696;      // -   [origin=predictive method=lee-kesler]
Tb          487.16;      // K   [origin=predictive method=joback]
HvapTb      44390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.85 1.14492 -0.00067933 1.6189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridec-1-yne" "1-c13h24" "1-tridecylene" "agn-pc-00farb" );
standardThermochemistry
{
    dHf_298   -19750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=281650.0
}
