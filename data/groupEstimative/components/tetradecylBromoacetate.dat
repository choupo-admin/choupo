/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecyl bromoacetate  (C16H31BrO2, CAS 18992-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecylBromoacetate;
formula     C16H31BrO2;
CAS         18992-01-3;
InChIKey    JBGQZMPANSYTHT-UHFFFAOYSA-N;
MW          335.326;      // g/mol [origin=calculated method=formula-sum]
Tc          866.33;      // K   [origin=predictive method=joback]
Pc          13.923;      // bar [origin=predictive method=joback]
omega       0.9709;      // -   [origin=predictive method=lee-kesler]
Tb          690.06;      // K   [origin=predictive method=joback]
HvapTb      65052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.944 1.50722 -0.0008234 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl 2-bromanylethanoate" "bromoacetic acid, tetradecyl ester" "tetradecyl 2-bromoacetate" "acetic acid, bromo-, tetradecyl ester" );
gibbsFormation
{
    dHf_298   -664520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     881.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-212210.0
    phase     gas;
}
