/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-dimethylaminoethyl-methylamino)ethanol  (C7H18N2O, CAS 2212-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DimethylaminoethylMethylaminoEthanol;
formula     C7H18N2O;
CAS         2212-32-0;
InChIKey    LSYBWANTZYUTGJ-UHFFFAOYSA-N;
MW          146.234;      // g/mol [origin=calculated method=formula-sum]
Tc          634.99;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.9530;      // -   [origin=predictive method=lee-kesler]
Tb          476.82;      // K   [origin=predictive method=joback]
HvapTb      51941.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.566 0.95066 -0.0006126 1.567e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group OH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(dimethylamino)ethyl-methyl-amino]ethanol" "n-methyl-n-(n,n-dimethylaminoethyl)-aminoethanol" "2-((2-(dimethylamino)ethyl)(methyl)amino)ethanol" "2-((2-(dimethylamino)ethyl)methylamino)ethanol" "2-([2-(dimethylamino)ethyl]methylamino)ethanol" "2-[[2-(dimethylamino)ethyl]methylamino]ethanol" "2-{[2-(dimethylamino)ethyl]methylamino}ethanol" "2-{[2-(dimethylamino)ethyl](methyl)amino}ethanol" "ethanol, 2-((2-(dimethylamino)ethyl)methylamino)-" "ethanol, 2-[[2-(dimethylamino)ethyl]methylamino]-" "2-[2-dimethylaminoethyl(methyl)amino]ethanol" "2-((2-(dimethylamino)ethyl)methylamino)-ethanol" );
gibbsFormation
{
    dHf_298   -204980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92800.0
    phase     gas;
}
