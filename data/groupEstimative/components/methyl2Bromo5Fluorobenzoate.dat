/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-bromo-5-fluorobenzoate  (C8H6BrFO2, CAS 6942-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Bromo5Fluorobenzoate;
formula     C8H6BrFO2;
CAS         6942-39-8;
InChIKey    FCMQMRAFVRTHCR-UHFFFAOYSA-N;
MW          233.036;      // g/mol [origin=calculated method=formula-sum]
Tc          765.81;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.6292;      // -   [origin=predictive method=lee-kesler]
Tb          542.93;      // K   [origin=predictive method=joback]
HvapTb      50027.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.0 0.56112 -0.00030172 4.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group Br; count 1; } { group ACF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-bromanyl-5-fluoranyl-benzoate" "2-bromo-5-fluorobenzoic acid methyl ester" "1-bromo-4-fluoro-2-(methoxycarbonyl)benzene" "benzoic acid, 2-bromo-5-fluoro-, methyl ester" "methyl-2-bromo-5-fluorobenzoate" "2-bromo-5-fluorobenzoic acid, methyl ester" "2-bromo-5-fluoro-benzoic acid methyl ester" "methyl-2-brom-5-fluorbenzolcarboxylat;2-bromo-5-fluorobenzoic acid, methyl ester;" );
gibbsFormation
{
    dHf_298   -481920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-381230.0
    phase     gas;
}
