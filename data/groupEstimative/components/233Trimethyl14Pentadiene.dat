/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,3-trimethyl-1,4-pentadiene  (C8H14, CAS 756-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        233Trimethyl14Pentadiene;
formula     C8H14;
CAS         756-02-5;
InChIKey    OXYDHUPSYIQGAP-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          558.21;      // K   [origin=predictive method=joback]
Pc          28.354;      // bar [origin=predictive method=joback]
omega       0.2395;      // -   [origin=predictive method=lee-kesler]
Tb          372.65;      // K   [origin=predictive method=joback]
HvapTb      30846.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.53 0.84956 -0.0006313 1.925e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,3-trimethylpenta-1,4-diene" "1,4-pentadiene, 2,3,3-trimethyl-" "1, 2,3,3-trimethyl-" "2,3-trimethyl-1,4-pentadiene" "1,4-pentadiene,2,3,3-trimethyl-" );
standardThermochemistry
{
    dHf_298   23870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186450.0
}
