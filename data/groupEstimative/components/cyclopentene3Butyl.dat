/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene,3-butyl-  (C9H16, CAS 22531-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentene3Butyl;
formula     C9H16;
CAS         22531-00-6;
InChIKey    OCVYLEAVUIYGLL-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          613.11;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.3493;      // -   [origin=predictive method=lee-kesler]
Tb          419.96;      // K   [origin=predictive method=joback]
HvapTb      36177.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.997 0.93452 -0.00058048 1.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butylcyclopentene" "3-butyl-1-cyclopentene" "cyclopentene, 3-butyl-" );
gibbsFormation
{
    dHf_298   -110830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91410.0
    phase     gas;
}
