/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-1-iodopropyne  (C3H2ClI, CAS 109-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro1Iodopropyne;
formula     C3H2ClI;
CAS         109-71-7;
InChIKey    IRSNQGVPSQCWKJ-UHFFFAOYSA-N;
MW          200.399;      // g/mol [origin=calculated method=formula-sum]
Tc          656.51;      // K   [origin=predictive method=joback]
Pc          50.658;      // bar [origin=predictive method=joback]
omega       0.1819;      // -   [origin=predictive method=lee-kesler]
Tb          407.81;      // K   [origin=predictive method=joback]
HvapTb      38182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.301 0.1848 -0.00014906 5.238e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group I; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tC; count 2; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-1-iodanyl-prop-1-yne" "usaf do-18" "3-chloro-1-iodoprop-1-yne" "propyne, 3-chloro-1-iodo-" );
standardThermochemistry
{
    dHf_298   228180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223370.0
}
