/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5,5-trimethylheptanal  (C10H20O, CAS 72333-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        355Trimethylheptanal;
formula     C10H20O;
CAS         72333-11-0;
InChIKey    PCVQXUYBCYOTEJ-VIFPVBQESA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          655.94;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.5193;      // -   [origin=predictive method=lee-kesler]
Tb          473.39;      // K   [origin=predictive method=joback]
HvapTb      42890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.957 1.06008 -0.0006882 1.771e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r)-3,5,5-trimethylheptanal" );
gibbsFormation
{
    dHf_298   -349340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65800.0
    phase     gas;
}
