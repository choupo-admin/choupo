/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2-acetylglutarate  (C11H18O5, CAS 1501-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl2Acetylglutarate;
formula     C11H18O5;
CAS         1501-06-0;
InChIKey    NNOGMCQLKMLNPL-UHFFFAOYSA-N;
MW          230.26;      // g/mol [origin=calculated method=formula-sum]
Tc          805.63;      // K   [origin=predictive method=joback]
Pc          20.793;      // bar [origin=predictive method=joback]
omega       0.9415;      // -   [origin=predictive method=lee-kesler]
Tb          621.15;      // K   [origin=predictive method=joback]
HvapTb      61252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.384 0.91716 -0.0003699 -4.04e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-ethanoylpentanedioate" "2ovyv1&2vo2" "diethyl 2-acetylpentanedioate" "diethyl .alpha.-acetoglutarate" "1,5-diethyl 2-acetylpentanedioate" "diethyl alpha-acetylglutarate" "diethyl 2-acetylpentane-1,5-dioate" "pentanedioic acid, 2-acetyl-, diethyl ester" );
standardThermochemistry
{
    dHf_298   -1022790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-710360.0
}
