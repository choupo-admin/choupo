/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-octadien-1-ol, 3,6,7-trimethyl-  (C11H20O, CAS 42933-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Octadien1Ol367Trimethyl;
formula     C11H20O;
CAS         42933-32-4;
InChIKey    JEKZWFRYLQPVTR-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          729.73;      // K   [origin=predictive method=joback]
Pc          23.496;      // bar [origin=predictive method=joback]
omega       0.8443;      // -   [origin=predictive method=lee-kesler]
Tb          551.42;      // K   [origin=predictive method=joback]
HvapTb      56915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.257 1.12258 -0.0007795 2.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH=C; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH; count 1; } { group dC; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6,7-trimethylocta-2,6-dien-1-ol" );
standardThermochemistry
{
    dHf_298   -217530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39710.0
}
