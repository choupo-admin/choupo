/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexene-1,1-dimethanol, 6-methyl-  (C9H16O2, CAS 7328-07-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexene11Dimethanol6Methyl;
formula     C9H16O2;
CAS         7328-07-6;
InChIKey    OTRKULZGGPEGEA-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          790.69;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       1.2283;      // -   [origin=predictive method=lee-kesler]
Tb          604.16;      // K   [origin=predictive method=joback]
HvapTb      68247.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.588 1.25832 -0.00107208 3.991e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-(hydroxymethyl)-6-methyl-cyclohex-3-en-1-yl]methanol" "[1-(hydroxymethyl)-6-methylcyclohex-3-en-1-yl]methanol" "3-cyclohexene-1,1-dimethanol, 6-methyl-," );
standardThermochemistry
{
    dHf_298   -426550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207530.0
}
