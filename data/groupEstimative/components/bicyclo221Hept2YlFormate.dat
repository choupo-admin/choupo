/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hept-2-yl formate  (C8H12O2, CAS 41498-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H12O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept2YlFormate;
formula     C8H12O2;
CAS         41498-71-9;
InChIKey    SGXIEZNAOCVSKO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          570.72;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.2146;      // -   [origin=predictive method=lee-kesler]
Tb          372.14;      // K   [origin=predictive method=joback]
HvapTb      30718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.55 1.0376 -0.000903 3.212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bicyclo[2.2.1]heptanyl methanoate" "exo-2-norbornyl formate" "norbornan-2-yl formate" "2-norbornanol, formate" "agn-pc-00hn7v" "3-bicyclo[2.2.1]heptanyl formate" );
gibbsFormation
{
    dHf_298   -12900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162130.0
    phase     gas;
}
