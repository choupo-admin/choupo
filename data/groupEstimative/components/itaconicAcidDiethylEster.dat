/*--------------------------------*- Choupo -*-----------------------*\
  Component: itaconic acid diethyl ester  (C9H14O4, CAS 2409-52-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        itaconicAcidDiethylEster;
formula     C9H14O4;
CAS         2409-52-1;
InChIKey    ZEFVHSWKYCYFFL-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          701.37;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       0.6998;      // -   [origin=predictive method=lee-kesler]
Tb          518.52;      // K   [origin=predictive method=joback]
HvapTb      49852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.843 0.72914 -0.0003018 9e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-methylidenebutanedioate" "ethyl itaconate" "diethyl itaconate" "diethyl 2-methylenesuccinate" "butanedioic acid, methylene-, diethyl ester" "butanedioic acid, 2-methylene-, 1,4-diethyl ester" "agn-pc-0da248" "succinic acid, methylene-, diethyl ester" );
gibbsFormation
{
    dHf_298   -748010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516550.0
    phase     gas;
}
