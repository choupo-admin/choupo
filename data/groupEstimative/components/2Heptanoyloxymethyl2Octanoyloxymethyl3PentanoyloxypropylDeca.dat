/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2-(heptanoyloxymethyl)-2-(octanoyloxymethyl)-3-pentanoyloxypropyl] decanoate  (C35H64O8, CAS 71010-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Heptanoyloxymethyl2Octanoyloxymethyl3PentanoyloxypropylDeca;
formula     C35H64O8;
CAS         71010-74-7;
InChIKey    FXBBJRIECMQZCL-UHFFFAOYSA-N;
MW          612.889;      // g/mol [origin=calculated method=formula-sum]
Tc          1646.88;      // K   [origin=predictive method=joback]
Pc          4.854;      // bar [origin=predictive method=joback]
omega       -0.1509;      // -   [origin=predictive method=lee-kesler]
Tb          1230.05;      // K   [origin=predictive method=joback]
HvapTb      121836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.236 3.23548 -0.0016736 2.488e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 22; } { group C; count 1; } { group CH2COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 26; } { group C; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(heptanoyloxymethyl)-2-(octanoyloxymethyl)-3-pentanoyloxy-propyl] decanoate" "decanoic acid mixed esters with heptanoic acid isovaleric acid nonanoic acid octanoic acid pentaerythritol and valeric acid" "decanoic acid, mixed esters with heptanoic acid, isovaleric acid, nonanoic acid, octanoic acid, pentaerythritol and valeric acid" "pentaerythritol, ester with valeric acid, enanthylic acid, caprylic acid, pelargonic acid, capric acid, and isovaleric acid" );
standardThermochemistry
{
    dHf_298   -2043600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1685.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-994820.0
}
