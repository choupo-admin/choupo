/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(4-chlorobenzoyl)morpholine  (C11H12ClNO2, CAS 19202-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n4ChlorobenzoylMorpholine;
formula     C11H12ClNO2;
CAS         19202-04-1;
InChIKey    BGRFQNTYHMHVFJ-UHFFFAOYSA-N;
MW          225.672;      // g/mol [origin=calculated method=formula-sum]
Tc          876.04;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.7135;      // -   [origin=predictive method=lee-kesler]
Tb          633.58;      // K   [origin=predictive method=joback]
HvapTb      61268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.26 1.1683 -0.00082196 2.1666e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group FCH2O; count 1; } { group ACCl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-chlorophenyl)-morpholin-4-yl-methanone" "4-(4-chlorobenzoyl)morpholine" "4-chlorobenzoic acid, morpholide" "methanone,(4-chlorophenyl)-4-morpholinyl-" "(4-chlorophenyl)(morpholino)methanone" "4-chlorophenyl morpholin-4-yl ketone" "(4-chlorophenyl)-morpholin-4-ylmethanone" "(4-chlorophenyl)(morpholin-4-yl)methanone" );
gibbsFormation
{
    dHf_298   -157280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72590.0
    phase     gas;
}
