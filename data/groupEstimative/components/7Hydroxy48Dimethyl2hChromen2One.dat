/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-hydroxy-4,8-dimethyl-2h-chromen-2-one  (C11H10O3, CAS 4115-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Hydroxy48Dimethyl2hChromen2One;
formula     C11H10O3;
CAS         4115-76-8;
InChIKey    MVMMGVPSTRNMSV-UHFFFAOYSA-N;
MW          190.198;      // g/mol [origin=calculated method=formula-sum]
Tc          868.14;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.8711;      // -   [origin=predictive method=lee-kesler]
Tb          638.04;      // K   [origin=predictive method=joback]
HvapTb      65105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.91 1.02224 -0.00087572 3.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,8-dimethyl-7-oxidanyl-chromen-2-one" "7-hydroxy-4,8-dimethylchromen-2-one" "4, 8-dimethylumbelliferone" "2h-1-benzopyran-2-one,8-dimethyl-" "2h-1-benzopyran-2-one,7-hydroxy-4,8-dimethyl-" "7-hydroxy-4,8-dimethyl-2h-chromen-2-one; 2h-1-benzopyran-2-one, 7-hydroxy-4,8-dimethyl-; 4,8-dimethyl-7-hydroxycoumarin; 7-hydroxy-4,8-dimethylcoumarin; coumarin, 7-hydroxy-4,8-dimethyl-" );
standardThermochemistry
{
    dHf_298   -405760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229210.0
}
