/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl acetate, dibutyl maleate, monoethyl maleate terpolymer  (C22H34O10, CAS 68318-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylAcetateDibutylMaleateMonoethylMaleateTerpolymer;
formula     C22H34O10;
CAS         68318-23-0;
InChIKey    JUHZBXLZXGWXTO-GGSNWKIFSA-N;
MW          458.504;      // g/mol [origin=calculated method=formula-sum]
Tc          1338.11;      // K   [origin=predictive method=joback]
Pc          9.462;      // bar [origin=predictive method=joback]
omega       0.8789;      // -   [origin=predictive method=lee-kesler]
Tb          1089.15;      // K   [origin=predictive method=joback]
HvapTb      111192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (139.407 1.53308 -0.0002281 -2.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH2=CH; count 1; } { group CH=CH; count 2; } { group CH3COO; count 1; } { group COOH; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group dCH2; count 1; } { group dCH; count 5; } { group COOH; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutyl (z)-but-2-enedioate;ethenyl ethanoate;(z)-4-ethoxy-4-oxidanylidene-but-2-enoic acid" "2-butenedioic acid (2z)-, 1,4-dibutyl ester, polymer with ethenyl acetate and 1-ethyl hydrogen (2z)-2-butenedioate" "2-butenedioic acid (2z)-, dibutyl ester, polymer with ethenyl acetate and ethyl hydrogen (2z)-2-butenedioate" "dibutyl (z)-but-2-enedioate; ethenyl acetate; (z)-4-ethoxy-4-oxobut-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -1980170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1468.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1412270.0
}
