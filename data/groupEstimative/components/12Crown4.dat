/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-crown-4  (C8H16O4, CAS 294-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Crown4;
formula     C8H16O4;
CAS         294-93-9;
InChIKey    XQQZRZQVBFHBHL-UHFFFAOYSA-N;
MW          176.212;      // g/mol [origin=calculated method=formula-sum]
Tc          788.94;      // K   [origin=predictive method=joback]
Pc          37.454;      // bar [origin=predictive method=joback]
omega       0.4542;      // -   [origin=predictive method=lee-kesler]
Tb          540.28;      // K   [origin=predictive method=joback]
HvapTb      53212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.37 0.8428 -0.0002138 -9.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,10-tetraoxacyclododecane" "eoct" "ethylene oxide cyclic tetramer" "12-crown-4 ether" "12-crown 4-ether" "3,6,9,12-tetraoxacyclododecan" "xqqzrzqvbfhbhl-uhfffaoysa-" "wt604" "12-crown-4, lithium ionophore v" "294-93-9 12-crown-4" );
gibbsFormation
{
    dHf_298   -698750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-368440.0
    phase     gas;
}
