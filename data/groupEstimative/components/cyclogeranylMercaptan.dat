/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclogeranyl mercaptan  (C10H18S, CAS 71820-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclogeranylMercaptan;
formula     C10H18S;
CAS         71820-48-9;
InChIKey    AVZCLGHLTWUBHI-VIFPVBQESA-N;
MW          170.314;      // g/mol [origin=calculated method=formula-sum]
Tc          742.35;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.3630;      // -   [origin=predictive method=lee-kesler]
Tb          510.52;      // K   [origin=predictive method=joback]
HvapTb      44514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.889 1.25316 -0.00102104 3.721e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r)-2,6,6-trimethylcyclohex-2-en-1-yl]methanethiol" "2-cyclohexene-1-methanethiol, 2,6,6-trimethyl-" );
gibbsFormation
{
    dHf_298   -115720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94290.0
    phase     gas;
}
