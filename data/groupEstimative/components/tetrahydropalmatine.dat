/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydropalmatine  (C21H25NO4, CAS 10097-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydropalmatine;
formula     C21H25NO4;
CAS         10097-84-4;
InChIKey    AEQDJSLRWYMAQI-KRWDZBQOSA-N;
MW          355.434;      // g/mol [origin=calculated method=formula-sum]
Tc          1104.02;      // K   [origin=predictive method=joback]
Pc          16.471;      // bar [origin=predictive method=joback]
omega       1.1028;      // -   [origin=predictive method=lee-kesler]
Tb          879.32;      // K   [origin=predictive method=joback]
HvapTb      82510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.21 1.69308 -0.00098956 2.152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 4; } { group ACCH2; count 3; } { group ACCH; count 1; } { group CH3O; count 4; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group O; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(13as)-2,3,9,10-tetramethoxy-6,8,13,13a-tetrahydro-5h-isoquinolino[2,1-b]isoquinoline" "rotundine" "l-tetrahydropalmatine" "(-)-tetrahydropalmatine" "(s)-tetrahydropalmatine" "caseanine" "gindarine" "hyndarine" "(-)-corydalis" "corydalis b" "13a-alpha-berbine, 2,3,9,10-tetramethoxy-" "5,8,13,13a-tetrahydro-2,3,9,10-tetramethoxy-6h-dibenzo(a,g)quinolizine" );
standardThermochemistry
{
    dHf_298   -361780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125070.0
}
