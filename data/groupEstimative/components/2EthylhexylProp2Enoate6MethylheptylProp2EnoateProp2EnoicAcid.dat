/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl prop-2-enoate;6-methylheptyl prop-2-enoate;prop-2-enoic acid  (C25H44O6, CAS 68378-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylProp2Enoate6MethylheptylProp2EnoateProp2EnoicAcid;
formula     C25H44O6;
CAS         68378-18-7;
InChIKey    CRLBANSRFBZTRG-UHFFFAOYSA-N;
MW          440.621;      // g/mol [origin=calculated method=formula-sum]
Tc          1258.44;      // K   [origin=predictive method=joback]
Pc          7.922;      // bar [origin=predictive method=joback]
omega       0.7324;      // -   [origin=predictive method=lee-kesler]
Tb          1025.51;      // K   [origin=predictive method=joback]
HvapTb      101024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (104.88 1.85948 -0.0004651 -1.831e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group CH2=CH; count 3; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } { group dCH2; count 3; } { group dCH; count 3; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-ethylhexyl 2-propenoate, isooctyl 2-propenoate polymer" "2-ethylhexyl prop-2-enoate; 6-methylheptyl prop-2-enoate; prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1401670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1467.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-755910.0
    phase     gas;
}
