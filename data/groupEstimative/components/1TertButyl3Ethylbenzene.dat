/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-3-ethylbenzene  (C12H18, CAS 14411-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl3Ethylbenzene;
formula     C12H18;
CAS         14411-56-4;
InChIKey    MUJPTTGNHRHIPH-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          716.13;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.3897;      // -   [origin=predictive method=lee-kesler]
Tb          502.59;      // K   [origin=predictive method=joback]
HvapTb      43948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.099 1.13128 -0.00076496 2.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-3-ethyl-benzene" "1-t-butyl-3-ethylbenzene" "1-(tert-butyl)-3-ethylbenzene" "benzene, 1-(1,1-dimethylethyl)-3-ethyl-" "1-tert-butyl-3-ethyl benzene" "benzene,1-(1,1-dimethylethyl)-3-ethyl-" "benzene,1-tert-butyl-3-ethyl- (6ci);1-(1,1-dimethylethyl)-3-ethylbenzene;1-ethyl-3-(1,1-dimethylethyl)benzene;1-tert-butyl-3-ethylbenzene;m-tert-butylethylbenzene;" );
standardThermochemistry
{
    dHf_298   -74700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155780.0
}
