/*--------------------------------*- Choupo -*-----------------------*\
  Component: indisan  (C16H28O, CAS 80748-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        indisan;
formula     C16H28O;
CAS         80748-58-9;
InChIKey    JMLPIRYUSKIOGR-UHFFFAOYSA-N;
MW          236.399;      // g/mol [origin=calculated method=formula-sum]
Tc          909.62;      // K   [origin=predictive method=joback]
Pc          22.611;      // bar [origin=predictive method=joback]
omega       0.8116;      // -   [origin=predictive method=lee-kesler]
Tb          686.54;      // K   [origin=predictive method=joback]
HvapTb      64245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-315.67 2.79486 -0.002839 1.2049e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 2; } { group C; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group C_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,3,3-trimethyl-4-bicyclo[2.2.1]heptanyl)cyclohexan-1-ol" "isocamphyl cyclohexanol (mixed isomers)" "isocamphanyl cyclohexanol (mixed isomers)" "cyclohexanol, (2,2,3-trimethylnorbornanyl)- (mixed isomers)" "agn-pc-01m7ef" "cyclohexanol, (2,2,3-trimethylbicyclo[2.2.1]heptyl)-" );
standardThermochemistry
{
    dHf_298   -327000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     762.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48980.0
}
