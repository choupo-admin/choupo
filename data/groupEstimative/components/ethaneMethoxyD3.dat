/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, methoxy-d3  (C3H5D3O, CAS 16995-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H5D3O (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethaneMethoxyD3;
formula     C3H5D3O;
CAS         16995-14-5;
InChIKey    XOBKSJJDNFUZPF-BMSJAHLVSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          63.114;      // g/mol [origin=calculated method=formula-sum]
Tc          453.04;      // K   [origin=predictive method=joback]
Pc          43.112;      // bar [origin=predictive method=joback]
omega       0.2380;      // -   [origin=predictive method=lee-kesler]
Tb          290.66;      // K   [origin=predictive method=joback]
HvapTb      24682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.661 0.22564 -2.84e-05 -3.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trideuteriomethoxyethane" "[(2h3)methyloxy]ethane" );
standardThermochemistry
{
    dHf_298   -237470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     284.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130620.0
}
