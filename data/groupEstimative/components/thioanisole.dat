/*--------------------------------*- Choupo -*-----------------------*\
  Component: thioanisole  (C7H8S, CAS 100-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thioanisole;
formula     C7H8S;
CAS         100-68-5;
InChIKey    HNKJADCVZUBCPG-UHFFFAOYSA-N;
MW          124.201;      // g/mol [origin=calculated method=formula-sum]
Tc          694.10;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       0.3100;      // -   [origin=predictive method=lee-kesler]
Tb          455.22;      // K   [origin=predictive method=joback]
HvapTb      40269.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.78 0.58431 -0.000348 7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylsulfanylbenzene" "methyl phenyl sulfide" "benzene, (methylthio)-" "(methylthio)benzene" "thioanisol" "methylphenylsulfide" "phenyl methyl sulfide" "phenylthiomethane" "anisole, thio-" "(1-thiaethyl)benzene" "(methylsulfanyl)benzene" "sulfide, methyl phenyl" );
standardThermochemistry
{
    dHf_298   90590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153590.0
}
