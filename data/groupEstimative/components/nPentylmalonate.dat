/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-pentylmalonate  (C8H14O4, CAS 616-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPentylmalonate;
formula     C8H14O4;
CAS         616-88-6;
InChIKey    LAWHHRXCBUNWFI-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          875.23;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       1.1803;      // -   [origin=predictive method=lee-kesler]
Tb          673.22;      // K   [origin=predictive method=joback]
HvapTb      67342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.134 0.87132 -0.0005598 1.395e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentylpropanedioic acid" "malonic acid, pentyl-" "heptanoic acid, carboxy-" "2-pentylmalonate" "n-pentylmalonic acid" "2-pentylmalonic acid" "2-pentyl-propanedioic acid" "propanedioic acid, pentyl-" "1,1-hexanedicarboxylic acid" );
gibbsFormation
{
    dHf_298   -914270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-673780.0
    phase     gas;
}
