/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-2-propen-1-ol  (C3H5ClO, CAS 5976-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro2Propen1Ol;
formula     C3H5ClO;
CAS         5976-47-6;
InChIKey    OSCXYTRISGREIM-UHFFFAOYSA-N;
MW          92.522;      // g/mol [origin=calculated method=formula-sum]
Tc          571.55;      // K   [origin=predictive method=joback]
Pc          50.730;      // bar [origin=predictive method=joback]
omega       0.6165;      // -   [origin=predictive method=lee-kesler]
Tb          394.41;      // K   [origin=predictive method=joback]
HvapTb      42746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.661 0.3095 -0.0002154 6.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylprop-2-en-1-ol" "2-chloroallyl alcohol" "2-chloropropenol" "2-propen-1-ol, 2-chloro-" "2-chloro-2-propenol" ".beta.-chloroallyl alcohol" "beta-chloroallyl alcohol" "2-chloroprop-2-en-1-ol" "2-propen-1-ol,2-chloro- (6ci,7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   -157580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95080.0
    phase     gas;
}
