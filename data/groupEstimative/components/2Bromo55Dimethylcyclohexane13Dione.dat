/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-5,5-dimethylcyclohexane-1,3-dione  (C8H11BrO2, CAS 1195-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo55Dimethylcyclohexane13Dione;
formula     C8H11BrO2;
CAS         1195-91-1;
InChIKey    OCXANUSFMRALNG-UHFFFAOYSA-N;
MW          219.078;      // g/mol [origin=calculated method=formula-sum]
Tc          861.63;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.5374;      // -   [origin=predictive method=lee-kesler]
Tb          599.56;      // K   [origin=predictive method=joback]
HvapTb      47300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.99 0.85294 -0.000553 1.715e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group Br; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-5,5-dimethyl-cyclohexane-1,3-dione" "2-bromo-5,5-dimethyl-1,3-cyclohexanedione" "2-bromo-5,5-dimethyl-cyclohexane-1,3-dione" "1,3-cyclohexanedione, 2-bromo-5,5-dimethyl-" "bromodimethylcyclohexanedione" "1,3-cyclohexanedione,2-bromo-5,5-dimethyl-" "1-bromo-4,4-dimethyl-2,6-cyclohexanedione;2-bromo-5,5-dimethyl-1,3-cyclohexanedione;2-bromodimedone;bromodimedone;2-bromo-5,5-dimethyl-cyclohexane-1,3-quinone;2-bromo-5,5-dimethylcyclohexane-1,3-dione;" );
gibbsFormation
{
    dHf_298   -408300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-203130.0
    phase     gas;
}
