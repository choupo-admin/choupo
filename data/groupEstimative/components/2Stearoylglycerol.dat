/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-stearoylglycerol  (C21H42O4, CAS 621-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Stearoylglycerol;
formula     C21H42O4;
CAS         621-61-4;
InChIKey    YQEMORVAKMFKLG-UHFFFAOYSA-N;
MW          358.563;      // g/mol [origin=calculated method=formula-sum]
Tc          1139.01;      // K   [origin=predictive method=joback]
Pc          10.842;      // bar [origin=predictive method=joback]
omega       0.9406;      // -   [origin=predictive method=lee-kesler]
Tb          922.22;      // K   [origin=predictive method=joback]
HvapTb      102717.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.108 2.01792 -0.001088 2.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 1; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group CH; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(oxidanyl)propan-2-yl octadecanoate" "1,3-dihydroxypropan-2-yl octadecanoate" "stearin, 2-mono-" "octadecanoic acid, 2-hydroxy-1-(hydroxymethyl)ethyl ester" "2-monostearin" "2-stearoyl-glycerol" "2-monostearoylglycerol" "2-stearoyl-rac-glycerol" "glycerol " "a-monostearate" "a-glyceryl monostearate" "2-monooctadecanoylglycerol" "2-octadecanoyl-sn-glycerol" );
standardThermochemistry
{
    dHf_298   -1103790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1117.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-460510.0
}
