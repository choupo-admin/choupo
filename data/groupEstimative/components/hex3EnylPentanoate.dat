/*--------------------------------*- Choupo -*-----------------------*\
  Component: hex-3-enyl pentanoate  (C11H20O2, CAS 35852-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hex3EnylPentanoate;
formula     C11H20O2;
CAS         35852-46-1;
InChIKey    XPFTVTFOOTVHIA-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          689.00;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       0.6575;      // -   [origin=predictive method=lee-kesler]
Tb          513.66;      // K   [origin=predictive method=joback]
HvapTb      47445.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.116 1.01404 -0.0005638 1.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-3-hexen-1-yl valerate" "cis-3-hexenyl valerate" "(z)-3-hexenyl valerate" "(e)-hex-3-enyl valerate" "cis-3-hexenylvalerate" "pentanoic acid, (3z)-3-hexen-1-yl ester" "n-valeric acid cis-3-hexen-1-yl ester" "pentanoic acid,(3e)-3-hexen-1-yl ester" "pentanoic acid,(3z)-3-hexen-1-yl ester" "pentanoicacid, (3e)-3-hexenyl ester (9ci); pentanoic acid, 3-hexenyl ester, (e)-;trans-3-hexenyl pentanoate" "pentanoicacid, (3z)-3-hexenyl ester (9ci);z-3-hexenyl valerate;cis-3-hexenyl pentanoate;cis-hex-3-en-1-yl pentanoate;" );
gibbsFormation
{
    dHf_298   -470430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188410.0
    phase     gas;
}
