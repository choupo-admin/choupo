/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-norbornanone  (C7H10O, CAS 497-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Norbornanone;
formula     C7H10O;
CAS         497-38-1;
InChIKey    KPMKEVXVVHNIEY-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          669.73;      // K   [origin=predictive method=joback]
Pc          40.570;      // bar [origin=predictive method=joback]
omega       0.3525;      // -   [origin=predictive method=lee-kesler]
Tb          445.33;      // K   [origin=predictive method=joback]
HvapTb      35421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.65 0.7927 -0.000507 1.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]heptan-3-one" "bicyclo[2.2.1]heptan-2-one" "norcamphor" "norcampher" "2-oxonorbornane" "2,5-methanocyclohexanone" "8,9,10-trinorbornan-2-one" "bicyclo(2.2.1)heptan-2-one" "norbornan-2-one" "2-norcamphor" "bicyclo[2.2.1]heptanone" "agn-pc-00g6x7" );
standardThermochemistry
{
    dHf_298   -186070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     189.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5130.0
}
