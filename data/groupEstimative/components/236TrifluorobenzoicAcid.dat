/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,6-trifluorobenzoic acid  (C7H3F3O2, CAS 2358-29-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        236TrifluorobenzoicAcid;
formula     C7H3F3O2;
CAS         2358-29-4;
InChIKey    MGUPHQGQNHDGNK-UHFFFAOYSA-N;
MW          176.093;      // g/mol [origin=calculated method=formula-sum]
Tc          747.30;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.8157;      // -   [origin=predictive method=lee-kesler]
Tb          544.70;      // K   [origin=predictive method=joback]
HvapTb      50151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.39 0.4976 -0.00030888 6.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group COOH; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,6-tris(fluoranyl)benzoic acid" "2,5,6-trifluorobenzoic acid" "2,3,6-trifluorobenzoicacid" "2,3,6-trifluoro-benzoic acid" "wt501" "n566" "2358-29-4 2,3,6-trifluorobenzoic acid" "2,3,6-trifluorobenzoicacid;2,5,6-trifluorobenzoic acid;" );
standardThermochemistry
{
    dHf_298   -924290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-836760.0
}
