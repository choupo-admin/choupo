/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1,2-dimethylcyclopentane  (C7H14, CAS 1192-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis12Dimethylcyclopentane;
formula     C7H14;
CAS         1192-18-3;
InChIKey    RIRARCHMRDHZAR-KNVOCYPGSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          563.83;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.2326;      // -   [origin=predictive method=lee-kesler]
Tb          370.37;      // K   [origin=predictive method=joback]
HvapTb      31124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.02 0.77404 -0.000429 8.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-1,2-dimethylcyclopentane" "cyclopentane, 1,2-dimethyl-, cis-" "1,cis-2-dimethylcyclopentane" "cis-1,2-dimethyl cyclopentane" "cyclopentane,2-dimethyl-, cis-" "cyclopentane, 1,2-dimethyl-, (1r,2s)-" "cyclopentane,1,2-dimethyl-, (1r,2s)-rel-" "cyclopentane, 1,2-dimethyl-, cis- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -147670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36900.0
    phase     gas;
}
