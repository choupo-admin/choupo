/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-cyclopentanetetracarboxylic acid  (C9H10O8, CAS 3724-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234CyclopentanetetracarboxylicAcid;
formula     C9H10O8;
CAS         3724-52-5;
InChIKey    WOSVXXBNNCUXMT-UHFFFAOYSA-N;
MW          246.171;      // g/mol [origin=calculated method=formula-sum]
Tc          1227.91;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       1.9106;      // -   [origin=predictive method=lee-kesler]
Tb          988.83;      // K   [origin=predictive method=joback]
HvapTb      103614.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.56 1.1142 -0.0007174 1.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane-1,2,3,4-tetracarboxylic acid" "1,2,3,4-tetracarboxycyclopentane" "agn-pc-00hrd4" "1,2,3,4-tetracarboxycyclopentane;" "1,2,3,4-cyclopentanetetracarboxylicacid" "r-1,c-2,c-3,c-4-cyclopentanetetracarboxylic acid" "1,2,3,4-cyclopentanetetracarboxylic acid, (1alpha,2alpha,3alpha,4alpha)-" );
gibbsFormation
{
    dHf_298   -1630710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1337320.0
    phase     gas;
}
