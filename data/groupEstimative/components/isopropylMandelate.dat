/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl mandelate  (C11H14O3, CAS 4118-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylMandelate;
formula     C11H14O3;
CAS         4118-51-8;
InChIKey    SCJJMBMUZTUIJU-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          828.61;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       1.0085;      // -   [origin=predictive method=lee-kesler]
Tb          627.48;      // K   [origin=predictive method=joback]
HvapTb      65666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.68 0.96094 -0.000548 9.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 2-oxidanyl-2-phenyl-ethanoate" "mandelic acid, isopropyl ester" "propan-2-yl 2-hydroxy-2-phenylacetate" "propan-2-yl (2r)-2-hydroxy-2-phenylacetate" "benzeneacetic acid, alpha-hydroxy-, 1-methylethyl ester" "benzeneacetic acid, alpha-hydroxy-, 1-methylethyl ester (9ci)" );
gibbsFormation
{
    dHf_298   -513910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297920.0
    phase     gas;
}
