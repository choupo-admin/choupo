/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-undecyne, 11-bromo-  (C11H19Br, CAS 71317-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Undecyne11Bromo;
formula     C11H19Br;
CAS         71317-72-1;
InChIKey    DMAQFVRPONMOMR-UHFFFAOYSA-N;
MW          231.177;      // g/mol [origin=calculated method=formula-sum]
Tc          695.16;      // K   [origin=predictive method=joback]
Pc          23.634;      // bar [origin=predictive method=joback]
omega       0.5997;      // -   [origin=predictive method=lee-kesler]
Tb          507.56;      // K   [origin=predictive method=joback]
HvapTb      46373.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.859 0.9931 -0.00064193 1.7219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group Br; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group tCH; count 1; } { group tC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-bromanylundec-1-yne" "11-bromoundec-1-yne" );
gibbsFormation
{
    dHf_298   47860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=279130.0
    phase     gas;
}
