/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-ethylheptane  (C10H22, CAS 14676-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3Ethylheptane;
formula     C10H22;
CAS         14676-29-0;
InChIKey    NKMJCVVUYDKHAV-UHFFFAOYSA-N;
MW          142.286;      // g/mol [origin=calculated method=formula-sum]
Tc          597.20;      // K   [origin=predictive method=joback]
Pc          21.394;      // bar [origin=predictive method=joback]
omega       0.4354;      // -   [origin=predictive method=lee-kesler]
Tb          427.52;      // K   [origin=predictive method=joback]
HvapTb      37078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.566 0.96568 -0.0005266 1.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-2-methyl-heptane" "3-ethyl-2-methylheptane" "heptane, 3-ethyl-2-methyl-" "agn-pc-0cqcim" "2-methyl-3-ethyl-heptane" "3-ethyl-2-methyl heptane" "heptane,3-ethyl-2-methyl-" "2-methyl-3-ethylheptane;3-ethyl-2-methylheptane" );
gibbsFormation
{
    dHf_298   -260290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28440.0
    phase     gas;
}
