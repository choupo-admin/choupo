/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-phenyl-1-pentanol  (C12H18O, CAS 73177-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Phenyl1Pentanol;
formula     C12H18O;
CAS         73177-67-0;
InChIKey    AKMRXUUGAJOMFO-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          787.28;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       0.8852;      // -   [origin=predictive method=lee-kesler]
Tb          592.14;      // K   [origin=predictive method=joback]
HvapTb      60485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.998 1.11074 -0.000697 1.659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1-phenyl-pentan-1-ol" "2-methyl-1-phenylpentan-1-ol" "2-methyl-1-phenyl-1-pentanol, erythro + threo" "2-pentyl phenyl carbinol" "2-methyl-1-phenyl-1-pentanol;2-amyl phenyl carbinol;1-phenyl-2-methyl-1-pentanol;2-methyl-1-phenyl-1-pentanol, threo + erythro, 97%;2-pentyl phenyl carbinol;2-methyl-1-phenyl-1-pentanol, erythro + threo, 97%" );
standardThermochemistry
{
    dHf_298   -217270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20870.0
}
