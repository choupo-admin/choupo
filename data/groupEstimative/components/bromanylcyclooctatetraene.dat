/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromanylcyclooctatetraene  (C8H7Br, CAS 7567-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromanylcyclooctatetraene;
formula     C8H7Br;
CAS         7567-22-8;
InChIKey    NLLQBBNCJBPICS-UHFFFAOYSA-N;
MW          183.048;      // g/mol [origin=calculated method=formula-sum]
Tc          733.42;      // K   [origin=predictive method=joback]
Pc          44.444;      // bar [origin=predictive method=joback]
omega       0.3466;      // -   [origin=predictive method=lee-kesler]
Tb          483.18;      // K   [origin=predictive method=joback]
HvapTb      42749.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.56 0.6479 -0.00040848 8.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 3; } { group CH=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   99870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148970.0
}
