/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-ethyl-1-propenylsulfide  (C5H10S, CAS 61865-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eEthyl1Propenylsulfide;
formula     C5H10S;
CAS         61865-98-3;
InChIKey    GBUNXBFHVUCURS-HWKANZROSA-N;
MW          102.195;      // g/mol [origin=calculated method=formula-sum]
Tc          587.48;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.2888;      // -   [origin=predictive method=lee-kesler]
Tb          386.94;      // K   [origin=predictive method=joback]
HvapTb      33499.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.761 0.49323 -0.0002918 6.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-ethylsulfanylprop-1-ene" );
standardThermochemistry
{
    dHf_298   12560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104560.0
}
