/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-2-fluorophenol  (C6H4ClFO, CAS 348-62-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro2Fluorophenol;
formula     C6H4ClFO;
CAS         348-62-9;
InChIKey    ZKMUKBBWORLNLA-UHFFFAOYSA-N;
MW          146.545;      // g/mol [origin=calculated method=formula-sum]
Tc          714.13;      // K   [origin=predictive method=joback]
Pc          50.228;      // bar [origin=predictive method=joback]
omega       0.5372;      // -   [origin=predictive method=lee-kesler]
Tb          485.86;      // K   [origin=predictive method=joback]
HvapTb      48470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.11 0.6086 -0.00055992 2.085e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACOH; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2-fluoranyl-phenol" "2-fluoro-4-chlorophenol" "348-62-9 4-chloro-2-fluorophenol" "l680" "4-chloro-2-fluoro-phenol;2-fluoro-4-chlorophenol;" );
standardThermochemistry
{
    dHf_298   -331270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258940.0
}
