/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorododecane  (C12H25Cl, CAS 2350-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorododecane;
formula     C12H25Cl;
CAS         2350-11-0;
InChIKey    IRQJPTVOWBXCHM-UHFFFAOYSA-N;
MW          204.782;      // g/mol [origin=calculated method=formula-sum]
Tc          680.99;      // K   [origin=predictive method=joback]
Pc          17.376;      // bar [origin=predictive method=joback]
omega       0.6139;      // -   [origin=predictive method=lee-kesler]
Tb          511.15;      // K   [origin=predictive method=joback]
HvapTb      46303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.189 1.15654 -0.0006526 1.401e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyldodecane" "dodecane, 2-chloro-" "2-chlorododecane;" );
gibbsFormation
{
    dHf_298   -312030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35790.0
    phase     gas;
}
