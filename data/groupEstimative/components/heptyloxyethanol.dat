/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptyloxyethanol  (C9H20O2, CAS 7409-44-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptyloxyethanol;
formula     C9H20O2;
CAS         7409-44-1;
InChIKey    QJTOHHRPYAVWOO-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          679.37;      // K   [origin=predictive method=joback]
Pc          24.826;      // bar [origin=predictive method=joback]
omega       0.9926;      // -   [origin=predictive method=lee-kesler]
Tb          520.12;      // K   [origin=predictive method=joback]
HvapTb      54717.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.498 0.82962 -0.0003852 5.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-heptoxyethanol" "2-(heptyloxy)ethanol" "ethylene glycol monoheptyl ether" "2-heptyloxyethan-1-ol" "2-(heptyloxy)ethanol;ethylene glycol mono-n-heptyl ether; ethylene glycol monoheptyl ether; heptylcellosolve" );
standardThermochemistry
{
    dHf_298   -513540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216920.0
}
