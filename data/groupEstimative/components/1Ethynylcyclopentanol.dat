/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethynylcyclopentanol  (C7H10O, CAS 17356-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethynylcyclopentanol;
formula     C7H10O;
CAS         17356-19-3;
InChIKey    LQMDOONLLAJAPZ-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          665.51;      // K   [origin=predictive method=joback]
Pc          49.246;      // bar [origin=predictive method=joback]
omega       0.5845;      // -   [origin=predictive method=lee-kesler]
Tb          457.58;      // K   [origin=predictive method=joback]
HvapTb      46819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.88 1.0325 -0.00104333 4.3779e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethynylcyclopentan-1-ol" "cyclopentanol, 1-ethynyl-" "1-ethynyl-1-cyclopentanol" "1-ethynyl-cyclopentan-1-ol" "1-(1-ethynyl)-1-cyclopentanol" );
standardThermochemistry
{
    dHf_298   27580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125370.0
}
