/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylmalonic acid, diphenyl ester  (C17H16O4, CAS 26595-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylmalonicAcidDiphenylEster;
formula     C17H16O4;
CAS         26595-27-7;
InChIKey    HWZVGGMEXHEECA-UHFFFAOYSA-N;
MW          284.311;      // g/mol [origin=calculated method=formula-sum]
Tc          995.14;      // K   [origin=predictive method=joback]
Pc          21.453;      // bar [origin=predictive method=joback]
omega       0.8231;      // -   [origin=predictive method=lee-kesler]
Tb          755.13;      // K   [origin=predictive method=joback]
HvapTb      71506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.03 1.47724 -0.000946 1.998e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diphenyl 2,2-dimethylpropanedioate" );
standardThermochemistry
{
    dHf_298   -564460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300820.0
}
