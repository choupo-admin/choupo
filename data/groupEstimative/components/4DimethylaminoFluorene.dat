/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(dimethylamino)fluorene  (C15H15N, CAS 92013-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4DimethylaminoFluorene;
formula     C15H15N;
CAS         92013-89-3;
InChIKey    AUXNVAUAYSEDCH-UHFFFAOYSA-N;
MW          209.292;      // g/mol [origin=calculated method=formula-sum]
Tc          860.80;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       0.6439;      // -   [origin=predictive method=lee-kesler]
Tb          626.41;      // K   [origin=predictive method=joback]
HvapTb      57443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.29 1.41304 -0.00113448 3.683e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 4; } { group ACCH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-9h-fluoren-4-amine" );
gibbsFormation
{
    dHf_298   258710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=474790.0
    phase     gas;
}
