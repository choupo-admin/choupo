/*--------------------------------*- Choupo -*-----------------------*\
  Component: terpinyl iso-valerate  (C15H26O2, CAS 1142-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        terpinylIsoValerate;
formula     C15H26O2;
CAS         1142-85-4;
InChIKey    XRADSECIALQFFY-UHFFFAOYSA-N;
MW          238.371;      // g/mol [origin=calculated method=formula-sum]
Tc          827.33;      // K   [origin=predictive method=joback]
Pc          17.361;      // bar [origin=predictive method=joback]
omega       0.6139;      // -   [origin=predictive method=lee-kesler]
Tb          621.04;      // K   [origin=predictive method=joback]
HvapTb      56090.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.019 1.5124 -0.00087384 1.705e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylcyclohex-3-en-1-yl)propan-2-yl 3-methylbutanoate" "alpha-terpinyl isovalerate" "butanoic acid, 3-methyl-, 1-methyl-1-(4-methyl-3-cyclohexen-1-yl)ethyl ester" "terpinyl isovalerate" "terpinyl isopentanoate" "terpinyl isovalerianate" "p-menth-1-en-8-yl isovalerate" "p-menth-1-en-8-yl isopentanoate" "p-menth-1-en-8-yl 3-methylbutyrate" "p-menth-1-en-8-yl 3-methylbutanoate" "p-menth-1-en-8-yl beta-methylbutyrate" "isovaleric acid, p-menth-1-en-8-yl ester" );
standardThermochemistry
{
    dHf_298   -583610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189770.0
}
