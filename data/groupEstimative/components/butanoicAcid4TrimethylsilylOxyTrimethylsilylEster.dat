/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanoic acid, 4-[(trimethylsilyl)oxy]-, trimethylsilyl ester  (C10H24O3Si2, CAS 55133-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H24O3Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        butanoicAcid4TrimethylsilylOxyTrimethylsilylEster;
formula     C10H24O3Si2;
CAS         55133-95-4;
InChIKey    JQUWWJZPEOMMSB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.469;      // g/mol [origin=calculated method=formula-sum]
Tc          691.24;      // K   [origin=predictive method=joback]
Pc          16.935;      // bar [origin=predictive method=joback]
omega       0.5099;      // -   [origin=predictive method=lee-kesler]
Tb          511.84;      // K   [origin=predictive method=joback]
HvapTb      48259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.343 0.42352 0.000515 -4.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl 4-trimethylsilyloxybutanoate" "butyric acid, 4-(trimethylsiloxy)-, trimethylsilyl ester" "butanoic acid,4-trimethylsiloxy,trimethylsilyl ester" "trimethylsilyl 4-[(trimethylsilyl)oxy]butanoate" );
gibbsFormation
{
    dHf_298   -922470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     861.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-591570.0
    phase     gas;
}
