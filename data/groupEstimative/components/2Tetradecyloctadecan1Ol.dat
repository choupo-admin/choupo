/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tetradecyloctadecan-1-ol  (C32H66O, CAS 32582-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Tetradecyloctadecan1Ol;
formula     C32H66O;
CAS         32582-32-4;
InChIKey    RTXVDAJGIYOHFY-UHFFFAOYSA-N;
MW          466.879;      // g/mol [origin=calculated method=formula-sum]
Tc          1307.42;      // K   [origin=predictive method=joback]
Pc          5.696;      // bar [origin=predictive method=joback]
omega       0.1588;      // -   [origin=predictive method=lee-kesler]
Tb          1023.50;      // K   [origin=predictive method=joback]
HvapTb      103117.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.591 3.08374 -0.0017506 3.789e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 29; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 29; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-octadecanol, 2-tetradecyl-" );
gibbsFormation
{
    dHf_298   -861320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1443.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79300.0
    phase     gas;
}
