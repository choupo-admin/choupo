/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chlorooctadecane  (C18H37Cl, CAS 3386-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chlorooctadecane;
formula     C18H37Cl;
CAS         3386-33-2;
InChIKey    VUQPJRPDRDVQMN-UHFFFAOYSA-N;
MW          288.944;      // g/mol [origin=calculated method=formula-sum]
Tc          812.97;      // K   [origin=predictive method=joback]
Pc          11.238;      // bar [origin=predictive method=joback]
omega       0.8215;      // -   [origin=predictive method=lee-kesler]
Tb          648.87;      // K   [origin=predictive method=joback]
HvapTb      60047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.583 1.72062 -0.0009758 2.12e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyloctadecane" "octadecane, 1-chloro-" "octadecyl chloride" "n-octadecyl chloride" "1-chloroctadecane" "chlorooctadecane" );
standardThermochemistry
{
    dHf_298   -430590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     890.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88750.0
}
