    dHf_298   -542350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310940.0
    phase     gas;
}
