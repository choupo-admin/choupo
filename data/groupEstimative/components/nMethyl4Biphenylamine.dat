/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-4-biphenylamine  (C13H13N, CAS 3365-81-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyl4Biphenylamine;
formula     C13H13N;
CAS         3365-81-9;
InChIKey    UUYJYDILAMMXGM-UHFFFAOYSA-N;
MW          183.254;      // g/mol [origin=calculated method=formula-sum]
Tc          849.31;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.5827;      // -   [origin=predictive method=lee-kesler]
Tb          605.55;      // K   [origin=predictive method=joback]
HvapTb      56182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.65 1.09772 -0.00072736 1.801e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-4-phenyl-aniline" "n-methyl-4-phenylaniline" "4-(n-methylamino)biphenyl" "4-biphenylamine, n-methyl-" "n-methyl-[1,1'-biphenyl]-4-amine" "[1,1'-biphenyl]-4-amine,n-methyl-" "4-biphenylamine,n-methyl- (8ci); 4-biphenylamine, methyl- (7ci); n-methyl-4-aminobiphenyl;n-methyl-4-biphenylamine; p-phenyl-n-methylaniline" );
gibbsFormation
{
    dHf_298   203410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=363160.0
    phase     gas;
}
