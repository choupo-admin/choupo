/*--------------------------------*- Choupo -*-----------------------*\
  Component: hentriacontane  (C31H64, CAS 630-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hentriacontane;
formula     C31H64;
CAS         630-04-6;
InChIKey    IUJAMGNYPWYUPM-UHFFFAOYSA-N;
MW          436.853;      // g/mol [origin=calculated method=formula-sum]
Tc          1124.84;      // K   [origin=predictive method=joback]
Pc          5.685;      // bar [origin=predictive method=joback]
omega       0.3663;      // -   [origin=predictive method=lee-kesler]
Tb          908.88;      // K   [origin=predictive method=joback]
HvapTb      84600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.291 2.94884 -0.0016626 3.577e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 29; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 29; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "untriacontane" "n-hentriacontane" "hentriacontan" "n-hentriacontanone" "CH3-[CH2]29-ch3" "CH3-(CH2)29-CH3" "hentriacontane; untriacontane; n-hentriacontane" "CHEMBL257490" "hentriacontane, analytical standard" "HY-N9971" "N-c-31" "STL564734" );
gibbsFormation
{
    dHf_298   -683170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1363.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210140.0
    phase     gas;
}
