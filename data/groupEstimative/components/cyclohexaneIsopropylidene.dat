/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, isopropylidene-  (C9H16, CAS 5749-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexaneIsopropylidene;
formula     C9H16;
CAS         5749-72-4;
InChIKey    CUYJYVAWBJXBIC-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          647.56;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.3024;      // -   [origin=predictive method=lee-kesler]
Tb          436.26;      // K   [origin=predictive method=joback]
HvapTb      37233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.43 0.92984 -0.000573 1.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-ylidenecyclohexane" "cyclohexane, (1-methylethylidene)-" );
gibbsFormation
{
    dHf_298   -88190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93970.0
    phase     gas;
}
