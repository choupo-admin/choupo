/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodoprop-2-yn-1-ol  (C3H3IO, CAS 1725-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Iodoprop2Yn1Ol;
formula     C3H3IO;
CAS         1725-82-2;
InChIKey    JYQJMGROXSSXDR-UHFFFAOYSA-N;
MW          181.956;      // g/mol [origin=calculated method=formula-sum]
Tc          686.91;      // K   [origin=predictive method=joback]
Pc          61.418;      // bar [origin=predictive method=joback]
omega       0.5618;      // -   [origin=predictive method=lee-kesler]
Tb          462.56;      // K   [origin=predictive method=joback]
HvapTb      50476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.701 0.212 -0.00015906 5.318e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group I; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tC; count 2; } { group I; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanylprop-2-yn-1-ol" "2-propyn-1-ol, 3-iodo-" "3-iodo-2-propynol" "3-iodo-prop-2-yn-1-ol" "3-hydroxy-1-iodopropyne;3-iodo-2-propyn-1-ol; 3-iodo-2-propynol; 3-iodopropargyl alcohol; iodopropargylalcohol" );
standardThermochemistry
{
    dHf_298   91690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98480.0
}
