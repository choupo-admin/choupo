/*--------------------------------*- Choupo -*-----------------------*\
  Component: azuleno(2,1,8-ija)azulene, 10b,10c-dihydro-  (C16H12, CAS 38765-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azuleno218IjaAzulene10b10cDihydro;
formula     C16H12;
CAS         38765-94-5;
InChIKey    BOEDVIFOOMGTJW-UHFFFAOYSA-N;
MW          204.272;      // g/mol [origin=calculated method=formula-sum]
Tc          885.32;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.5642;      // -   [origin=predictive method=lee-kesler]
Tb          633.10;      // K   [origin=predictive method=joback]
HvapTb      56860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.33 1.512 -0.0012954 4.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "boedvifoomgtjw-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   292250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     296.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=465060.0
}
