/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethylsilane  (C4H12Si, CAS 75-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H12Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetramethylsilane;
formula     C4H12Si;
CAS         75-76-3;
InChIKey    CZDYPVPMEAXLPK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          88.225;      // g/mol [origin=calculated method=formula-sum]
Tc          460.48;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.1305;      // -   [origin=predictive method=lee-kesler]
Tb          292.52;      // K   [origin=predictive method=joback]
HvapTb      24792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.07 0.17768 0.000221 -1.808e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silane, tetramethyl-" "tetramethylsilicane" "silicon, tetramethyl-" "tetramethyl silane" "tetramethylsilane solution" "tetramethyl-silane" );
gibbsFormation
{
    dHf_298   -237510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121960.0
    phase     gas;
}
