/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trichloroisobutane  (C4H7Cl3, CAS 1871-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Trichloroisobutane;
formula     C4H7Cl3;
CAS         1871-58-5;
InChIKey    XMCSILBVFPYTLC-UHFFFAOYSA-N;
MW          161.45;      // g/mol [origin=calculated method=formula-sum]
Tc          603.75;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       0.2859;      // -   [origin=predictive method=lee-kesler]
Tb          400.18;      // K   [origin=predictive method=joback]
HvapTb      36357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.452 0.53002 -0.0004268 1.353e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(chloranyl)-2-methyl-propane" "1,2,3-trichloro-2-methylpropane" "propane, 1,2,3-trichloro-2-methyl-" "propane, 1,2,3-trichloro-2-methyl- (8ci)(9ci)" "1,3-trichloroisobutane" "1,3-trichloro-2-methylpropane" "propane,2,3-trichloro-2-methyl-" "1,2,3-trichloro-2-methyl-propane" );
standardThermochemistry
{
    dHf_298   -181860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50150.0
}
