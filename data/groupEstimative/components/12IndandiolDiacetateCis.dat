/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-indandiol, diacetate, cis-  (C13H14O4, CAS 19597-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12IndandiolDiacetateCis;
formula     C13H14O4;
CAS         19597-96-7;
InChIKey    ZSAGZMJOVRIXMF-UHFFFAOYSA-N;
MW          234.251;      // g/mol [origin=calculated method=formula-sum]
Tc          865.25;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.7755;      // -   [origin=predictive method=lee-kesler]
Tb          647.21;      // K   [origin=predictive method=joback]
HvapTb      61888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.02 1.11524 -0.00062316 1.01e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-acetyloxy-2,3-dihydro-1h-inden-2-yl) ethanoate" "agn-pc-00grov" "2,3-dihydro-1h-indene-1,2-diyl diacetate" "1h-indene-1, 2,3-dihydro-, diacetate, cis-" "(1-acetyloxy-2,3-dihydro-1h-inden-2-yl) acetate" "(1r,2r)-2,3-dihydro-1h-indene-1,2-diyl diacetate" "[(1s,2r)-1-acetyloxy-2,3-dihydro-1h-inden-2-yl] acetate" );
gibbsFormation
{
    dHf_298   -668690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-406340.0
    phase     gas;
}
