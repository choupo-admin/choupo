/*--------------------------------*- Choupo -*-----------------------*\
  Component: buta-1,3-diene;1-ethenyl-4-methyl-benzene;2-ethylhexyl 2-methylprop-2-enoate  (C25H38O2, CAS 104977-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buta13Diene1Ethenyl4MethylBenzene2Ethylhexyl2Methylprop2Enoa;
formula     C25H38O2;
CAS         104977-53-9;
InChIKey    XFRDXJWJXWYDFG-UHFFFAOYSA-N;
MW          370.577;      // g/mol [origin=calculated method=formula-sum]
Tc          1056.86;      // K   [origin=predictive method=joback]
Pc          9.227;      // bar [origin=predictive method=joback]
omega       0.7398;      // -   [origin=predictive method=lee-kesler]
Tb          850.44;      // K   [origin=predictive method=joback]
HvapTb      79189.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.265 1.69908 -0.00047326 -1.337e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 3; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 4; } { group dCH; count 3; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, 2-ethylhexyl ester, polymer with 1,3-butadiene and 1-ethenyl-4-methylbenzene" "benzene, 1-ethenyl-4-methyl-, polymer with 1,3-butadiene and 2-ethylhexyl methacrylate" );
gibbsFormation
{
    dHf_298   -388140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1251.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82880.0
    phase     gas;
}
