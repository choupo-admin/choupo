/*--------------------------------*- Choupo -*-----------------------*\
  Component: tripropyl citrate  (C15H26O7, CAS 1587-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tripropylCitrate;
formula     C15H26O7;
CAS         1587-21-9;
InChIKey    ODHUFJLMXDXVRC-UHFFFAOYSA-N;
MW          318.366;      // g/mol [origin=calculated method=formula-sum]
Tc          992.23;      // K   [origin=predictive method=joback]
Pc          15.598;      // bar [origin=predictive method=joback]
omega       1.3045;      // -   [origin=predictive method=lee-kesler]
Tb          806.41;      // K   [origin=predictive method=joback]
HvapTb      86588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.298 1.42426 -0.0007106 7.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } { group CH2COO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group C; count 1; } { group OH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tripropyl 2-oxidanylpropane-1,2,3-tricarboxylate" "1,2,3-propanetricarboxylic acid, 2-hydroxy-, tripropyl ester" "citric acid tripropyl ester" "tripropyl 2-hydroxypropane-1,2,3-tricarboxylate" "1,2,3-propanetricarboxylicacid, 2-hydroxy-, 1,2,3-tripropyl ester" "1,2,3-propanetricarboxylicacid, 2-hydroxy-, tripropyl ester (9ci); citric acid, tripropyl ester(7ci,8ci); propyl citrate; tripropyl citrate" );
standardThermochemistry
{
    dHf_298   -1465750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     906.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-989670.0
}
