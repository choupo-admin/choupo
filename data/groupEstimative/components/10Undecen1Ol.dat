/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-undecen-1-ol  (C11H22O, CAS 112-43-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10Undecen1Ol;
formula     C11H22O;
CAS         112-43-6;
InChIKey    GIEMHYCMBGELGY-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          700.60;      // K   [origin=predictive method=joback]
Pc          21.836;      // bar [origin=predictive method=joback]
omega       0.9736;      // -   [origin=predictive method=lee-kesler]
Tb          540.14;      // K   [origin=predictive method=joback]
HvapTb      56089.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.811 1.0628 -0.0006279 1.469e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undec-10-en-1-ol" "undecylenic alcohol" "10-undecenol" "undecylenyl alcohol" "10-undecylen-1-ol" "11-hydroxy-1-undecene" ".omega.-undecenyl alcohol" "undecen-1-ol" "omega-undecenyl alcohol" "c-11 alcohol" );
standardThermochemistry
{
    dHf_298   -297170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7240.0
}
