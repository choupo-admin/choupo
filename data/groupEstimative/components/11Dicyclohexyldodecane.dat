/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dicyclohexyldodecane  (C24H46, CAS 18254-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dicyclohexyldodecane;
formula     C24H46;
CAS         18254-57-4;
InChIKey    ZNUYDMONISMCKK-UHFFFAOYSA-N;
MW          334.632;      // g/mol [origin=calculated method=formula-sum]
Tc          987.19;      // K   [origin=predictive method=joback]
Pc          10.379;      // bar [origin=predictive method=joback]
omega       0.7515;      // -   [origin=predictive method=lee-kesler]
Tb          787.38;      // K   [origin=predictive method=joback]
HvapTb      69488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.82 2.53392 -0.001447 2.931e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyldodecylcyclohexane" );
gibbsFormation
{
    dHf_298   -435330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1020.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197660.0
    phase     gas;
}
