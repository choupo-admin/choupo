/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylnaphthalene-1,4-diamine  (C11H12N2, CAS 83-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylnaphthalene14Diamine;
formula     C11H12N2;
CAS         83-68-1;
InChIKey    BCKLPBBBFNWJHH-UHFFFAOYSA-N;
MW          172.231;      // g/mol [origin=calculated method=formula-sum]
Tc          909.42;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.7652;      // -   [origin=predictive method=lee-kesler]
Tb          656.94;      // K   [origin=predictive method=joback]
HvapTb      67264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.58 0.91152 -0.0006282 1.736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 2; } { group ACCH3; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diamino-2-methylnaphthalene;2-methyl-1,4-diaminonaphthalene; 2-methyl-1,4-naphthalenediamine; vitamin k6" );
gibbsFormation
{
    dHf_298   190400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=364810.0
    phase     gas;
}
