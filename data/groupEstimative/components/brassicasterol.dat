/*--------------------------------*- Choupo -*-----------------------*\
  Component: brassicasterol  (C28H46O, CAS 474-67-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brassicasterol;
formula     C28H46O;
CAS         474-67-9;
InChIKey    OILXMJHPFNGGTO-ZAUYPBDWSA-N;
MW          398.675;      // g/mol [origin=calculated method=formula-sum]
Tc          1201.37;      // K   [origin=predictive method=joback]
Pc          10.535;      // bar [origin=predictive method=joback]
omega       0.9323;      // -   [origin=predictive method=lee-kesler]
Tb          974.18;      // K   [origin=predictive method=joback]
HvapTb      91632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-323.16 3.68002 -0.00309124 1.1161e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 8; } { group CH; count 8; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group dCH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,8s,9s,10r,13r,14s,17r)-17-[(e,2r,5r)-5,6-dimethylhept-3-en-2-yl]-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-ol" "ergosta-5,22(e)-dien-3beta-ol" "ergosta-5,22e-dien-3beta-ol" "ergosta-5,22-dien-3-ol, (3beta,22e)-" );
standardThermochemistry
{
    dHf_298   -395930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     969.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=289680.0
}
