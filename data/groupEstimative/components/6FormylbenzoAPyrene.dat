/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-formylbenzo(a)pyrene  (C21H12O, CAS 13312-42-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C21H12O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        6FormylbenzoAPyrene;
formula     C21H12O;
CAS         13312-42-0;
InChIKey    JYHGZHPGIQQNJP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          280.326;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.11;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       0.7787;      // -   [origin=predictive method=lee-kesler]
Tb          771.32;      // K   [origin=predictive method=joback]
HvapTb      70815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.72 1.7504 -0.00168704 6.413e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 9; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo[b]pyrene-6-carbaldehyde" "3,4-benzpyrene-5-aldehyde" "benzo(a)pyrene-6-carboxaldehyde" "benzo[a]pyrene-6-carboxaldehyde" "benzo[pqr]tetraphene-6-carbaldehyde" "6-benzo[a]pyrenecarboxaldehyde;6-formylbenzo[a]pyrene; benzo[a]pyrene-6-carbaldehyde" );
standardThermochemistry
{
    dHf_298   509150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=664630.0
}
