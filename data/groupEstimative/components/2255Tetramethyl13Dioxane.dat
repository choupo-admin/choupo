/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,5,5-tetramethyl-1,3-dioxane  (C8H16O2, CAS 767-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2255Tetramethyl13Dioxane;
formula     C8H16O2;
CAS         767-55-5;
InChIKey    YIBHANDRZWPYTI-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          670.63;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.3320;      // -   [origin=predictive method=lee-kesler]
Tb          451.90;      // K   [origin=predictive method=joback]
HvapTb      40240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.39 1.43728 -0.0014744 6.44e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -407990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150000.0
    phase     gas;
}
