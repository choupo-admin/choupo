/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl (s)-2-isocyanato-3-phenylpropionate  (C11H11NO3, CAS 40203-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylS2Isocyanato3Phenylpropionate;
formula     C11H11NO3;
CAS         40203-94-9;
InChIKey    JOTMMIYKEOOTNZ-JTQLQIEISA-N;
MW          205.213;      // g/mol [origin=calculated method=formula-sum]
Tc          820.43;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.7455;      // -   [origin=predictive method=lee-kesler]
Tb          602.41;      // K   [origin=predictive method=joback]
HvapTb      58907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCd; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (2s)-2-isocyanato-3-phenyl-propanoate" "methyl (s)-(-)-2-isocyanato-3-phenylpropionate" "(s)-2-isocyanato-3-phenylpropionic acid methyl ester" "methyl (2s)-2-isocyanato-3-phenylpropanoate" "(s)-2-isocyanato-3-phenylpropanoic acid methyl ester" "benzenepropanoic acid, a-isocyanato-,methyl ester, (as)-" );
// formation datum unavailable (element entropy missing): dHf_298=-361810.0 dGf_298=None
