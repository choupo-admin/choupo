/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperalin  (C16H21Cl2NO2, CAS 3478-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperalin;
formula     C16H21Cl2NO2;
CAS         3478-94-2;
InChIKey    BZGLBXYQOMFXAU-UHFFFAOYSA-N;
MW          330.249;      // g/mol [origin=calculated method=formula-sum]
Tc          985.47;      // K   [origin=predictive method=joback]
Pc          18.201;      // bar [origin=predictive method=joback]
omega       0.8916;      // -   [origin=predictive method=lee-kesler]
Tb          763.12;      // K   [origin=predictive method=joback]
HvapTb      73287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.947 1.54032 -0.00092992 1.927e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2N; count 1; } { group ACCl; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylpiperidin-1-yl)propyl 3,4-bis(chloranyl)benzoate" "pipron" "benzoic acid, 3,4-dichloro-, 3-(2-methyl-1-piperidinyl)propyl ester" "3-(2-methylpiperidino)propyl 3,4-dichlorobenzoate" "gamma-(2-methylpiperidino)propyl 3,4-dichlorobenzoate" "3-(2-methylpiperidin-1-yl)propyl 3,4-dichlorobenzoate" "1-piperidinepropanol, 2-methyl-, 3,4-dichlorobenzoate (ester)" "benzoic acid, 3,4-dichloro-, 3-(2-methylpiperidino)propyl ester" "3,4-dichlorobenzoic acid, 3-(2-methylpiperidino)propyl ester" );
gibbsFormation
{
    dHf_298   -380730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     744.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9910.0
    phase     gas;
}
