/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxybenzyl alcohol  (C7H8O2, CAS 623-05-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxybenzylAlcohol;
formula     C7H8O2;
CAS         623-05-2;
InChIKey    BVJSUAQZOZWCKN-UHFFFAOYSA-N;
MW          124.139;      // g/mol [origin=calculated method=formula-sum]
Tc          772.08;      // K   [origin=predictive method=joback]
Pc          57.566;      // bar [origin=predictive method=joback]
omega       0.9959;      // -   [origin=predictive method=lee-kesler]
Tb          559.24;      // K   [origin=predictive method=joback]
HvapTb      63145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.009 0.7785 -0.00067496 2.405e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(hydroxymethyl)phenol" "p-hydroxybenzyl alcohol" "p-methylolphenol" "4-methylolphenol" "4-hydroxybenzenemethanol" "benzenemethanol, 4-hydroxy-" "p-(hydroxymethyl)phenol" "benzyl alcohol, p-hydroxy-" "alpha-hydroxy-p-cresol" "benzyl alcohol, p-hydroxy- (8ci)" "benzenemethanol, 4-hydroxy- (9ci)" "gastrodigenin" );
standardThermochemistry
{
    dHf_298   -280820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170970.0
}
