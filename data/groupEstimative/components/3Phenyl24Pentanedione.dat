/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-2,4-pentanedione  (C11H12O2, CAS 5910-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl24Pentanedione;
formula     C11H12O2;
CAS         5910-25-8;
InChIKey    YIWTXSVNRCWBAC-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          809.71;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       0.6653;      // -   [origin=predictive method=lee-kesler]
Tb          585.26;      // K   [origin=predictive method=joback]
HvapTb      55460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.98 0.91984 -0.0005716 1.2662e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpentane-2,4-dione" "3-phenylacetylacetone" "1-phenyl acetylacetone" "2,4-pentanedione, 3-phenyl-" );
gibbsFormation
{
    dHf_298   -264280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106130.0
    phase     gas;
}
