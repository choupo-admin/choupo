/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-pentanedione  (C5H8O2, CAS 600-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Pentanedione;
formula     C5H8O2;
CAS         600-14-6;
InChIKey    TZMFJUDUGYTVRY-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          613.32;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.5056;      // -   [origin=predictive method=lee-kesler]
Tb          421.74;      // K   [origin=predictive method=joback]
HvapTb      40216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.061 0.42284 -0.0002108 3.022e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane-2,3-dione" "acetylpropionyl" "acetyl propionyl" "2,3-pentadione" "acetylpropionyl (van)" "acetyl propionyl (natural)" "2,3-pentane-dione" "23-pentanedione" "benzil-related compound, 43" );
standardThermochemistry
{
    dHf_298   -371690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266620.0
}
