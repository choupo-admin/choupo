/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-[pentane-1,5-diylbis(oxy)]bis(3-chloropropan-2-ol)  (C11H22Cl2O4, CAS 24771-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Pentane15DiylbisOxyBis3Chloropropan2Ol;
formula     C11H22Cl2O4;
CAS         24771-52-6;
InChIKey    CSVIHZAMDIVWRG-UHFFFAOYSA-N;
MW          289.193;      // g/mol [origin=calculated method=formula-sum]
Tc          930.39;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       1.5346;      // -   [origin=predictive method=lee-kesler]
Tb          754.46;      // K   [origin=predictive method=joback]
HvapTb      86252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.889 1.0158 -0.0004606 4.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2Cl; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group CH; count 2; } { group Cl; count 2; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-[5-(3-chloranyl-2-oxidanyl-propoxy)pentoxy]propan-2-ol" "1,1'-(pentamethylenedioxy)bis(3-chloro-2-propanol)" "u-15,646" "2-propanol, 1,1'-(pentamethylenedioxy)bis(3-chloro-" "1,1'-(pentamethylenedioxy)bis(3-chloro-2-propanol) diacetate" "1,1'-(pentamethylenedioxy)bis(3-chloro-2-propanol)diacetate" "2-propanol,1,1'-(pentamethylenedioxy)bis[3-chloro- (8ci)" "1-chloro-3-[5-(3-chloro-2-hydroxypropoxy)pentoxy]propan-2-ol" "2-propanol,1,1'-[1,5-pentanediylbis(oxy)]bis[3-chloro- (9ci)" );
gibbsFormation
{
    dHf_298   -881310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-470640.0
    phase     gas;
}
