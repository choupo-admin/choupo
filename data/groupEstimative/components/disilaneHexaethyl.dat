/*--------------------------------*- Choupo -*-----------------------*\
  Component: disilane, hexaethyl-  (C12H30Si2, CAS 1633-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H30Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        disilaneHexaethyl;
formula     C12H30Si2;
CAS         1633-09-6;
InChIKey    XEJUFRSVJVTIFW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          230.542;      // g/mol [origin=calculated method=formula-sum]
Tc          648.16;      // K   [origin=predictive method=joback]
Pc          14.680;      // bar [origin=predictive method=joback]
omega       0.3955;      // -   [origin=predictive method=lee-kesler]
Tb          476.96;      // K   [origin=predictive method=joback]
HvapTb      42894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.616 0.73152 0.0002006 -3.028e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethyl(triethylsilyl)silane" "1,1,1,2,2,2-hexaethyldisilane" );
standardThermochemistry
{
    dHf_298   -514250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     876.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-159360.0
}
