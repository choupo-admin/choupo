/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromomethyl-6,7-dimethoxycoumarin  (C12H11BrO4, CAS 88404-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromomethyl67Dimethoxycoumarin;
formula     C12H11BrO4;
CAS         88404-25-5;
InChIKey    JGODLBJJCNQFII-UHFFFAOYSA-N;
MW          299.12;      // g/mol [origin=calculated method=formula-sum]
Tc          919.64;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.9706;      // -   [origin=predictive method=lee-kesler]
Tb          696.28;      // K   [origin=predictive method=joback]
HvapTb      66234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.591 0.81494 -0.00045612 8.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 2; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group Br; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(bromomethyl)-6,7-dimethoxy-chromen-2-one" "4-(bromomethyl)-6,7-dimethoxy-2h-chromen-2-one" "4-(bromomethyl)-6,7-dimethoxychromen-2-one" "4-(bromomethyl)-6,7-dimethoxycoumarin" "4-bdmc" "brdmc-4,6,7" "4-bromomethyl-6,7-dimethoxycoumarin;" "4-(bromomethyl)-6,7-dimethoxy-2-oxo-2h-benzopyran" "4-(bromomethyl)-6,7-dimethoxy-2-oxo-2h-chromene" "2h-1-benzopyran-2-one,4-(bromomethyl)-6,7-dimethoxy-" "2h-1-benzopyran-2-one, 4-(bromomethyl)-6,7-dimethoxy-" );
gibbsFormation
{
    dHf_298   -498670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271480.0
    phase     gas;
}
