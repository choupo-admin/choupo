/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2,4-bis(2-methylbutan-2-yl)phenoxy]ethanol  (C18H30O2, CAS 67906-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Bis2Methylbutan2YlPhenoxyEthanol;
formula     C18H30O2;
CAS         67906-07-4;
InChIKey    VSDBJXFBXDVKIS-UHFFFAOYSA-N;
MW          278.436;      // g/mol [origin=calculated method=formula-sum]
Tc          952.23;      // K   [origin=predictive method=joback]
Pc          15.598;      // bar [origin=predictive method=joback]
omega       1.0282;      // -   [origin=predictive method=lee-kesler]
Tb          756.22;      // K   [origin=predictive method=joback]
HvapTb      75759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.936 1.73842 -0.00111552 2.775e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "poly(oxy-1,2-ethanediyl), " "a-(2,4-bis(1,1-dimethylpropyl)phenyl)-" "o-hydroxy-" "ethoxylated-2,4-di-tert-amylphenol" "poly(oxy-1,2-ethanediyl), alpha-(2,4-bis(1,1-dimethylpropyl)phenyl)-omega-hydroxy-" );
standardThermochemistry
{
    dHf_298   -503210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42310.0
}
