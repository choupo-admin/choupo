/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1(3h)-isobenzofuranone,3-(2-methylpropylidene)-  (C12H12O2, CAS 88542-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13hIsobenzofuranone32Methylpropylidene;
formula     C12H12O2;
CAS         88542-70-5;
InChIKey    LYSNVWBBICAAMS-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          789.32;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.6459;      // -   [origin=predictive method=lee-kesler]
Tb          573.11;      // K   [origin=predictive method=joback]
HvapTb      52928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.74 1.07564 -0.00083866 2.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylpropylidene)-2-benzofuran-1-one" "1(3h)-isobenzofuranone, 3-(2-methylpropylidene)-, (3e)-" "1(3h)-isobenzofuranone, 3-(2-methylpropylidene)-, (3z)-" "phthalide,3-isobutylidene- (7ci)" );
standardThermochemistry
{
    dHf_298   -207020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21750.0
}
