/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dimethylamino)-1,2-propanediol  (C5H13NO2, CAS 623-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Dimethylamino12Propanediol;
formula     C5H13NO2;
CAS         623-57-4;
InChIKey    QCMHUGYTOGXZIW-UHFFFAOYSA-N;
MW          119.164;      // g/mol [origin=calculated method=formula-sum]
Tc          670.13;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       1.3039;      // -   [origin=predictive method=lee-kesler]
Tb          510.36;      // K   [origin=predictive method=joback]
HvapTb      61737.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.448 0.67664 -0.0004248 1.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dimethylamino)propane-1,2-diol" "3-dimethylamino-1,2-propanediol" "3-dimethylaminopropane-1,2-diol" "dimethylamino-2,3-propanediol" "1,2-propanediol, 3-(dimethylamino)-" "1, 3-(dimethylamino)-" "qcmhugytogxziw-uhfffaoysa-" "n,n-dimethyl-2,3-dihydroxypropylamine" "l372" "3-dimethylamino-1,2-propanedio(n,n-dimethyl-3-amino-1,2-propanediol)" );
gibbsFormation
{
    dHf_298   -388740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174080.0
    phase     gas;
}
