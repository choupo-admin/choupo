/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[5.2.1.03,6]deca-2,5,8-triene  (C10H10, CAS 6675-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo521036Deca258Triene;
formula     C10H10;
CAS         6675-71-4;
InChIKey    NZJIGYSMNUZUSW-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          688.99;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       0.3786;      // -   [origin=predictive method=lee-kesler]
Tb          465.00;      // K   [origin=predictive method=joback]
HvapTb      40274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.05 1.1364 -0.00101756 3.668e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(5.2.1.03,6)deca-2,5,8-triene" );
standardThermochemistry
{
    dHf_298   133250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     212.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=281800.0
}
