/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylaniline  (C10H15N, CAS 769-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylaniline;
formula     C10H15N;
CAS         769-92-6;
InChIKey    WRDWWAVNELMWAM-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          760.75;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.4599;      // -   [origin=predictive method=lee-kesler]
Tb          529.36;      // K   [origin=predictive method=joback]
HvapTb      50137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.79 1.00316 -0.00069956 1.913e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-tert-butylaniline" "4-(tert-butyl)aniline" "benzenamine, 4-(1,1-dimethylethyl)-" "4-(tert-butyl)phenylamine" "p-t-butylaniline" "p-tertbutyl aniline" "4-t-butylbenzeneamine" "4-tert-butyl aniline" "zr dx1&1&1" "1-amino-4-(tert-butyl)benzene" "wrdwwavnelmwam-uhfffaoysa-" "k338" );
gibbsFormation
{
    dHf_298   370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205390.0
    phase     gas;
}
