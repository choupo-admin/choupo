/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-undecadiyne  (C11H16, CAS 4117-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110Undecadiyne;
formula     C11H16;
CAS         4117-15-1;
InChIKey    PZWZXAPXSJTOOI-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          615.88;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.4065;      // -   [origin=predictive method=lee-kesler]
Tb          431.52;      // K   [origin=predictive method=joback]
HvapTb      39796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.447 0.861 -0.00056646 1.5648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undeca-1,10-diyne" );
standardThermochemistry
{
    dHf_298   313430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=487880.0
}
