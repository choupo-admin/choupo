/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-oxathiolane  (C3H6OS, CAS 2094-97-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Oxathiolane;
formula     C3H6OS;
CAS         2094-97-5;
InChIKey    WJJSZTJGFCFNKI-UHFFFAOYSA-N;
MW          90.14;      // g/mol [origin=calculated method=formula-sum]
Tc          583.08;      // K   [origin=predictive method=joback]
Pc          58.450;      // bar [origin=predictive method=joback]
omega       0.2288;      // -   [origin=predictive method=lee-kesler]
Tb          362.97;      // K   [origin=predictive method=joback]
HvapTb      33160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.12 0.45841 -0.000327 9.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group FCH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group O_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-oxathiole, dihydro-" "1,3-oxathiole,dihydro-; dihydro-1,3-oxathiole" );
standardThermochemistry
{
    dHf_298   -111170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27620.0
}
