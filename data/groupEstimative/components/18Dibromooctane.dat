/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-dibromooctane  (C8H16Br2, CAS 4549-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Dibromooctane;
formula     C8H16Br2;
CAS         4549-32-0;
InChIKey    DKEGCUDAFWNSSO-UHFFFAOYSA-N;
MW          272.024;      // g/mol [origin=calculated method=formula-sum]
Tc          711.31;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.6544;      // -   [origin=predictive method=lee-kesler]
Tb          514.96;      // K   [origin=predictive method=joback]
HvapTb      46272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.998 0.8402 -0.0005542 1.522e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-bis(bromanyl)octane" "octamethylene dibromide" "octane, 1,8-dibromo-" "octamethylene bromide" "octane,8-dibromo-" "1,8-dibromo-octane" "1,8-dibromo-octan;dibromo-1,8 octane" "k908" );
gibbsFormation
{
    dHf_298   -155790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45120.0
    phase     gas;
}
