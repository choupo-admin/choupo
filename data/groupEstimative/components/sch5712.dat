/*--------------------------------*- Choupo -*-----------------------*\
  Component: sch 5712  (C17H33NO4, CAS 13080-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sch5712;
formula     C17H33NO4;
CAS         13080-06-3;
InChIKey    CQXNKORKKPMCPE-UHFFFAOYSA-N;
MW          315.454;      // g/mol [origin=calculated method=formula-sum]
Tc          890.65;      // K   [origin=predictive method=joback]
Pc          12.548;      // bar [origin=predictive method=joback]
omega       0.9586;      // -   [origin=predictive method=lee-kesler]
Tb          714.21;      // K   [origin=predictive method=joback]
HvapTb      68997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.089 1.759 -0.0009962 1.862e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 8; } { group C; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 9; } { group C; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-[2-(diethylamino)ethyl] o3-ethyl 2-butyl-2-ethyl-propanedioate" "butylaethylmalonsaeure-aethyl-diaethylaminoaethyl-di-ester [german]" "malonic acid, butylethyl-, 2-(diethylamino)ethyl ethyl ester" "2-(diethylamino)ethyl ethyl butyl(ethyl)propanedioate" "butylaethylmalonsaeure-aethyl-diaethylaminoaethyl-di-ester" "1-o-(2-diethylaminoethyl) 3-o-ethyl 2-butyl-2-ethylpropanedioate" "propanedioic acid, butylethyl-, 2-(diethylamino)ethyl ethyl ester" "propanedioic acid, butylethyl-, 2-(diethylamino)ethyl ethyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -969990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     897.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-414860.0
}
