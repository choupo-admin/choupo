/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-3-(3-(trifluoromethyl)phenyl)acetone  (C16H13F3O, CAS 59756-57-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl33TrifluoromethylPhenylAcetone;
formula     C16H13F3O;
CAS         59756-57-9;
InChIKey    MHBVFQPMQKODRK-UHFFFAOYSA-N;
MW          278.273;      // g/mol [origin=calculated method=formula-sum]
Tc          891.51;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       0.7747;      // -   [origin=predictive method=lee-kesler]
Tb          672.47;      // K   [origin=predictive method=joback]
HvapTb      59423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.008 1.4397 -0.00104426 2.8496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-3-[3-(trifluoromethyl)phenyl]propan-2-one" "1-phenyl-3-[3-(trifluoromethyl)phenyl]acetone" "1-phenyl-3-(3-(trifluoromethyl)phenyl)propan-2-one" "2-propanone, 1-phenyl-3-(3-(trifluoromethyl)phenyl)-" "2-propanone, 1-phenyl-3-[3-(trifluoromethyl)phenyl]-" "2-propanone,1-phenyl-3-[3-(trifluoromethyl)phenyl]-" "1-phenyl-3-(3-trifluoromethylphenyl)-2-propanone" "1-phenyl-3-(alpha,alpha,alpha-trifluoro-m-tolyl)-2-propanone" );
standardThermochemistry
{
    dHf_298   -621640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411480.0
}
