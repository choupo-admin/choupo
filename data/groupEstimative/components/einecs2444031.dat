/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 244-403-1  (C11H22N2O2, CAS 21476-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2444031;
formula     C11H22N2O2;
CAS         21476-57-3;
InChIKey    AUBDFVCIDMEAKS-UHFFFAOYSA-N;
MW          214.309;      // g/mol [origin=calculated method=formula-sum]
Tc          704.66;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       0.7282;      // -   [origin=predictive method=lee-kesler]
Tb          530.50;      // K   [origin=predictive method=joback]
HvapTb      50595.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.448 1.2277 -0.0007336 1.561e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3N; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(dimethylamino)propan-2-yl 2-methylprop-2-enoate" "bis(dimethylamino)isopropylmethacrylate" "bis(dimethylaminomethyl)methyl methacrylate" "2-(dimethylamino)-1-((dimethylamino)methyl)ethyl methacrylate" "methacrylic acid, 2-(dimethylamino)-1-((dimethylamino)methyl)ethyl ester" "2-(dimethylamino)-1-[(dimethylamino)methyl]ethyl methacrylate" "bis-(dimethylaminomethyl)methylester kyseliny methakrylove" "2-propenoic acid, 2-methyl-, 2-(dimethylamino)-1-((dimethylamino)methyl)ethyl ester" "2-propenoic acid, 2-methyl-, 2-(dimethylamino)-1-((dimethylamino)methyl)ethyl ester (9ci)" "2-propenoic acid,2-methyl-, 2-(dimethylamino)-1-[(dimethylamino)methyl]ethyl ester" "methacrylicacid, 2-(dimethylamino)-1-[(dimethylamino)methyl]ethyl ester (8ci); 2-propanol,1,3-bis(dimethylamino)-, methacrylate (ester) (8ci);1,3-bis(dimethylamino)-2-propyl methacrylate; 1,3-bis(dimethylamino)isopropylmethacrylate; bis(dimethylamino)isopropyl methacrylate;bis(dimethylaminomethyl)methyl methacrylate" );
standardThermochemistry
{
    dHf_298   -342230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29780.0
}
