/*--------------------------------*- Choupo -*-----------------------*\
  Component: tri-t-butylmethane  (C13H28, CAS 35660-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triTButylmethane;
formula     C13H28;
CAS         35660-96-9;
InChIKey    LVLOQIPOJWLAEB-UHFFFAOYSA-N;
MW          184.367;      // g/mol [origin=calculated method=formula-sum]
Tc          681.01;      // K   [origin=predictive method=joback]
Pc          17.347;      // bar [origin=predictive method=joback]
omega       0.3295;      // -   [origin=predictive method=lee-kesler]
Tb          486.91;      // K   [origin=predictive method=joback]
HvapTb      40256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.03 1.62228 -0.001202 3.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group CH; count 1; } { group C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 9; } { group CH; count 1; } { group C; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tert-butyl-2,2,4,4-tetramethyl-pentane" "3-tert-butyl-2,2,4,4-tetramethylpentane" "pentane, 3-(1,1-dimethylethyl)-2,2,4,4-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -343180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64660.0
}
