/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutylisopropyldimethoxysilane  (C9H22O2Si, CAS 111439-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H22O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        isobutylisopropyldimethoxysilane;
formula     C9H22O2Si;
CAS         111439-76-0;
InChIKey    XFAOZKNGVLIXLC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          190.358;      // g/mol [origin=calculated method=formula-sum]
Tc          627.02;      // K   [origin=predictive method=joback]
Pc          20.291;      // bar [origin=predictive method=joback]
omega       0.4340;      // -   [origin=predictive method=lee-kesler]
Tb          450.88;      // K   [origin=predictive method=joback]
HvapTb      39966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (83.161 0.53812 0.0001646 -2.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH3O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethoxy-(2-methylpropyl)-propan-2-yl-silane" "dimethoxy-(2-methylpropyl)-propan-2-ylsilane" "silane,dimethoxy(1-methylethyl)(2-methylpropyl)-" "silane, dimethoxy(1-methylethyl)(2-methylpropyl)-" "dimethoxyisobutylisopropylsilane;isobutylisopropyldimethoxysilane;" );
gibbsFormation
{
    dHf_298   -615710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-294740.0
    phase     gas;
}
