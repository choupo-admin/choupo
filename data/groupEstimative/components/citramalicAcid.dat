/*--------------------------------*- Choupo -*-----------------------*\
  Component: citramalic acid  (C5H8O5, CAS 597-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citramalicAcid;
formula     C5H8O5;
CAS         597-44-4;
InChIKey    XFTRTWQBIOMVPK-UHFFFAOYSA-N;
MW          148.114;      // g/mol [origin=calculated method=formula-sum]
Tc          898.35;      // K   [origin=predictive method=joback]
Pc          50.371;      // bar [origin=predictive method=joback]
omega       1.5550;      // -   [origin=predictive method=lee-kesler]
Tb          693.97;      // K   [origin=predictive method=joback]
HvapTb      76435.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.639 0.74022 -0.0005956 1.86e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2-oxidanyl-butanedioic acid" "citramalate" "2-hydroxy-2-methylbutanedioic acid" "2-hydroxy-2-methylbutandis" "2-hydroxy-2-methylsuccinic acid" "2-hydroxy-2-methyl-butanedioic acid" "alpha-methylmalate" "malic acid, 2-methyl-" "(-)-citramalic acid" "dl-citramalate" "(b)-citramalate" "dl-citramalic acid" );
gibbsFormation
{
    dHf_298   -1008050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-830580.0
    phase     gas;
}
