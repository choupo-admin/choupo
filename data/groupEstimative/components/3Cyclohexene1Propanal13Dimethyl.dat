/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexene-1-propanal, 1,3-dimethyl-  (C11H18O, CAS 71735-72-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexene1Propanal13Dimethyl;
formula     C11H18O;
CAS         71735-72-3;
InChIKey    HAEFRQLHXUHJJP-LLVKDONJSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          734.55;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.5225;      // -   [origin=predictive method=lee-kesler]
Tb          523.87;      // K   [origin=predictive method=joback]
HvapTb      47032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.228 1.32184 -0.00110144 4.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(1r)-1,3-dimethylcyclohex-3-en-1-yl]propanal" "3-(1,3-dimethyl-3-cyclohexenyl)propanal" );
gibbsFormation
{
    dHf_298   -240080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18490.0
    phase     gas;
}
