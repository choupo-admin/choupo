/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]octa-2,5,7-triene  (C8H8, CAS 500-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Octa257Triene;
formula     C8H8;
CAS         500-24-3;
InChIKey    RHCCUQVVABYRDN-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          619.05;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.2631;      // -   [origin=predictive method=lee-kesler]
Tb          402.14;      // K   [origin=predictive method=joback]
HvapTb      34448.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.77 0.8784 -0.00072084 2.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(2.2.2)octa-2,5,7-triene" "barrelene" );
gibbsFormation
{
    dHf_298   98170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     214.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203660.0
    phase     gas;
}
