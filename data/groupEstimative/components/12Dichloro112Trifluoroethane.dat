/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-Dichloro-1,1,2-trifluoroethane  (C2HCl2F3, CAS 354-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dichloro112Trifluoroethane;
formula     C2HCl2F3;
CAS         354-23-4;
InChIKey    YMRMDGSNYHCUCL-UHFFFAOYSA-N;
MW          152.924;      // g/mol [origin=calculated method=formula-sum]
Tc          481.63;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.2704;      // -   [origin=predictive method=lee-kesler]
Tb          314.36;      // K   [origin=predictive method=joback]
HvapTb      24681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.97 0.3745 -0.00035 1.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group HCClF; count 1; } { group CClF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group F; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-trifluoro-1,2-dichloroethane" "1,2-dichloro-1,2,2-trifluoroethane" "1,2-dichlorotrifluoroethane" "CFC 123a" "ethane, 1,2-dichloro-1,1,2-trifluoro-" "f 123a" "HCFC 123a" "R 123a" "hcfc-123a" "CF2ClCHFCl" "BRN 1698496" "dichloro-1,1,2-trifluoroethane" );
gibbsFormation
{
    dHf_298   -718450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-641930.0
    phase     gas;
}
