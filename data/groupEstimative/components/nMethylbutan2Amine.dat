/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylbutan-2-amine  (C5H13N, CAS 7713-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylbutan2Amine;
formula     C5H13N;
CAS         7713-69-1;
InChIKey    PYFSCIWXNSXGNS-UHFFFAOYSA-N;
MW          87.166;      // g/mol [origin=calculated method=formula-sum]
Tc          538.16;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.3736;      // -   [origin=predictive method=lee-kesler]
Tb          363.73;      // K   [origin=predictive method=joback]
HvapTb      32772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.549 0.56096 -0.0003 5.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butanamine, n-methyl-" "sec-butylmethylamine" "n-methyl-sec-butylamine" "n-methyl-2-butylamine" "n,1-dimethylpropylamine" "agn-pc-01yns5" "propylamine,n,1-dimethyl- (7ci,8ci);2-(methylamino)butane;methyl-sec-butylamine;n,1-dimethylpropylamine;n-methyl-2-butanamine;n-methyl-2-butylamine;n-methyl-n-sec-butylamine;n-methyl-sec-butylamine;n-sec-butyl-n-methylamine;sec-butylmethylamine;" );
gibbsFormation
{
    dHf_298   -98340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78170.0
    phase     gas;
}
