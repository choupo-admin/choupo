/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylamine  (C4H11N, CAS 109-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylamine;
formula     C4H11N;
CAS         109-89-7;
InChIKey    HPNMFZURTQLUMO-UHFFFAOYSA-N;
MW          73.139;      // g/mol [origin=calculated method=formula-sum]
Tc          511.65;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.3570;      // -   [origin=predictive method=lee-kesler]
Tb          341.29;      // K   [origin=predictive method=joback]
HvapTb      30934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.958 0.46004 -0.0002424 4.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethylethanamine" "ethanamine, n-ethyl-" "n,n-diethylamine" "diethamine" "diethyl-amine" "n-ethyl-ethanamine" "2,2'-diethylamine" "diaethylamin [german]" "dwuetyloamina [polish]" "diethylamin" "diethyl amine" "diaethylamin" );
gibbsFormation
{
    dHf_298   -72420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72190.0
    phase     gas;
}
