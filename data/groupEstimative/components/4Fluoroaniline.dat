/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluoroaniline  (C6H6FN, CAS 371-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Fluoroaniline;
formula     C6H6FN;
CAS         371-40-4;
InChIKey    KRZCOLNOCZKSDF-UHFFFAOYSA-N;
MW          111.119;      // g/mol [origin=calculated method=formula-sum]
Tc          659.15;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.4218;      // -   [origin=predictive method=lee-kesler]
Tb          440.34;      // K   [origin=predictive method=joback]
HvapTb      41712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.59 0.5091 -0.00032656 7.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACNH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-fluoranylaniline" "p-fluoroaniline" "benzenamine, 4-fluoro-" "1-amino-4-fluorobenzene" "p-fluorophenylamine" "4-fluorobenzenamine" "4-fluoronaniline" "para-fluoro aniline" "aniline, p-fluoro-" "4-fluoro-benzenamine" "aniline, 4-fluoro-" "4-fluoranilin" );
gibbsFormation
{
    dHf_298   -104430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25940.0
    phase     gas;
}
