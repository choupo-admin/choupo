/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)dodecanamide  (C16H33NO3, CAS 120-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxyethylDodecanamide;
formula     C16H33NO3;
CAS         120-40-1;
InChIKey    AOMUHOFOVNGZAN-UHFFFAOYSA-N;
MW          287.444;      // g/mol [origin=calculated method=formula-sum]
Tc          999.44;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       1.3896;      // -   [origin=predictive method=lee-kesler]
Tb          816.35;      // K   [origin=predictive method=joback]
HvapTb      93357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.406 1.68772 -0.0010013 2.2716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "lauric diethanolamide" "standamidd ld" "lauryl diethanolamide" "rolamid cd" "dodecanamide, n,n-bis(2-hydroxyethyl)-" "condensate pl" "lankrostat jp" "comperlan ld" "incromide lr" "mackamide ll" "standamid ld" "alkamide le" );
standardThermochemistry
{
    dHf_298   -723080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     923.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207940.0
}
