/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-rhamnose  (C6H12O5, CAS 3615-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lRhamnose;
formula     C6H12O5;
CAS         3615-41-6;
InChIKey    PNNNRSAQSRJVSB-BXKVDMCESA-N;
MW          164.157;      // g/mol [origin=calculated method=formula-sum]
Tc          926.59;      // K   [origin=predictive method=joback]
Pc          57.392;      // bar [origin=predictive method=joback]
omega       2.4410;      // -   [origin=predictive method=lee-kesler]
Tb          752.50;      // K   [origin=predictive method=joback]
HvapTb      100834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.27 0.70792 -0.00043 9.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 4; } { group OH; count 4; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 4; } { group OH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r,4s,5s)-2,3,4,5-tetrakis(oxidanyl)hexanal" "6-deoxy-l-mannose" "l-rha" "locaose" "l-mannomethylose" "(2r,3r,4s,5s)-2,3,4,5-tetrahydroxyhexanal" "rhamnose, l-" "isodulcitol" "rns" "l-mannopyranose, 6-deoxy-" "alpha-l-rhamnoside" "rhamnose (van)" );
standardThermochemistry
{
    dHf_298   -882790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-656920.0
}
