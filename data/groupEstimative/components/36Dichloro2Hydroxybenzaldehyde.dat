/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dichloro-2-hydroxybenzaldehyde  (C7H4Cl2O2, CAS 27164-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H4Cl2O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        36Dichloro2Hydroxybenzaldehyde;
formula     C7H4Cl2O2;
CAS         27164-09-6;
InChIKey    JQZDVFAQNRLCDC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          191.007;      // g/mol [origin=calculated method=formula-sum]
Tc          771.94;      // K   [origin=predictive method=joback]
Pc          46.277;      // bar [origin=predictive method=joback]
omega       0.5352;      // -   [origin=predictive method=lee-kesler]
Tb          528.30;      // K   [origin=predictive method=joback]
HvapTb      54187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.42 0.6472 -0.00070428 2.956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group CHO; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-bis(chloranyl)-2-oxidanyl-benzaldehyde" "benzaldehyde, 3,6-dichloro-2-hydroxy-" "benzaldehyde,3,6-dichloro-2-hydroxy-" "salicylaldehyde,3,6-dichloro- (8ci); 3,6-dichloro-2-hydroxybenzaldehyde;3,6-dichlorosalicylaldehyde" );
gibbsFormation
{
    dHf_298   -106560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-33310.0
    phase     gas;
}
