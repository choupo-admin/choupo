/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiyne, 1-iodo-  (C4HI, CAS 6088-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiyne1Iodo;
formula     C4HI;
CAS         6088-91-1;
InChIKey    IUUUVWLBOCMKOY-UHFFFAOYSA-N;
MW          175.952;      // g/mol [origin=calculated method=formula-sum]
Tc          640.34;      // K   [origin=predictive method=joback]
Pc          57.742;      // bar [origin=predictive method=joback]
omega       0.1135;      // -   [origin=predictive method=lee-kesler]
Tb          383.38;      // K   [origin=predictive method=joback]
HvapTb      35881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.28 0.1791 -0.00017899 7.367e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 1; } { group CH_C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylbuta-1,3-diyne" "1-iodobuta-1,3-diyne" );
gibbsFormation
{
    dHf_298   515180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     308.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=466790.0
    phase     gas;
}
