/*--------------------------------*- Choupo -*-----------------------*\
  Component: traumatic acid  (C12H20O4, CAS 6402-36-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        traumaticAcid;
formula     C12H20O4;
CAS         6402-36-4;
InChIKey    MAZWDMBCPDUFDJ-VQHVLOKHSA-N;
MW          228.288;      // g/mol [origin=calculated method=formula-sum]
Tc          967.59;      // K   [origin=predictive method=joback]
Pc          21.836;      // bar [origin=predictive method=joback]
omega       1.3041;      // -   [origin=predictive method=lee-kesler]
Tb          769.34;      // K   [origin=predictive method=joback]
HvapTb      76592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.002 1.2654 -0.000858 2.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group dCH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-dodec-2-enedioic acid" "trans-2-dodecenedioic acid" "dodec-2-enedioic acid" "trans-traumatic acid" "2e-dodecenedioic acid" "dodecanedioic acid-2-ene" "2-dodecenedioic acid" "traumatate" "1-decene-1,10-dicarboxylic acid" "2-dodecendioate" "trans-traumatate" "2-dodecenedioate" );
standardThermochemistry
{
    dHf_298   -874330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-557440.0
}
