/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotridecanone  (C13H24O, CAS 832-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclotridecanone;
formula     C13H24O;
CAS         832-10-0;
InChIKey    VHUGWUBIUBBUAF-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          877.74;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       0.4209;      // -   [origin=predictive method=lee-kesler]
Tb          618.97;      // K   [origin=predictive method=joback]
HvapTb      50721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.89 1.1519 -0.000251 -1.41e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclotridecan-1-one" "cyclotridecanon" );
standardThermochemistry
{
    dHf_298   -417810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116550.0
}
