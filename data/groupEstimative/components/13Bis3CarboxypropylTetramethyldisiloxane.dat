/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(3-carboxypropyl)tetramethyldisiloxane  (C12H26O5Si2, CAS 3353-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H26O5Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13Bis3CarboxypropylTetramethyldisiloxane;
formula     C12H26O5Si2;
CAS         3353-68-2;
InChIKey    DNNFJTRYBMVMPE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          306.505;      // g/mol [origin=calculated method=formula-sum]
Tc          990.67;      // K   [origin=predictive method=joback]
Pc          16.673;      // bar [origin=predictive method=joback]
omega       1.1320;      // -   [origin=predictive method=lee-kesler]
Tb          790.40;      // K   [origin=predictive method=joback]
HvapTb      79632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (108.316 0.76988 0.0001664 -3.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group COOH; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[dimethyl-(4-oxidanyl-4-oxidanylidene-butyl)silyl]oxy-dimethyl-silyl]butanoic acid" "4,4'-(1,1,3,3-tetramethyldisiloxane-1,3-diyl)dibutanoic acid" "butanoic acid, 4,4'-(1,1,3,3-tetramethyl-1,3-disiloxanediyl)bis-" "bis(carboxypropyl)tetramethyldisiloxane" "1,3-bis-(3-carboxypropyl)tetramethyldisiloxane" "4-[[3-carboxypropyl(dimethyl)silyl]oxy-dimethylsilyl]butanoic acid" "butanoic acid,4,4'-(1,1,3,3-tetramethyl-1,3-disiloxanediyl)bis-" "4-[[(4-hydroxy-4-oxobutyl)-dimethylsilyl]oxy-dimethylsilyl]butanoic acid" );
standardThermochemistry
{
    dHf_298   -1347010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     993.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-952180.0
}
