/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylcycloheptanone  (C8H14O, CAS 932-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylcycloheptanone;
formula     C8H14O;
CAS         932-56-9;
InChIKey    FDMAFOTXGNYBFG-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          703.60;      // K   [origin=predictive method=joback]
Pc          33.763;      // bar [origin=predictive method=joback]
omega       0.3425;      // -   [origin=predictive method=lee-kesler]
Tb          474.28;      // K   [origin=predictive method=joback]
HvapTb      38250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.68 0.70802 -0.000202 -4.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylcycloheptan-1-one" "cycloheptanone, 2-methyl-" "2-methyl-cycloheptan-1-one" );
gibbsFormation
{
    dHf_298   -297990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93760.0
    phase     gas;
}
