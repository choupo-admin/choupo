/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,4-dimethyl-3-cyclohexen-1-yl)-1,3-dioxolane  (C11H18O2, CAS 67893-07-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Dimethyl3Cyclohexen1Yl13Dioxolane;
formula     C11H18O2;
CAS         67893-07-6;
InChIKey    GAARSHDEYZGKOY-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          766.11;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.4585;      // -   [origin=predictive method=lee-kesler]
Tb          539.48;      // K   [origin=predictive method=joback]
HvapTb      50431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.54 1.15464 -0.00062004 1.025e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 3; } { group CH=C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4-dimethylcyclohex-3-en-1-yl)-1,3-dioxolane" "1,3-dioxolane, 2-(2,4-dimethyl-3-cyclohexen-1-yl)-" "2-(2,4-dimethyl-3-cyclohexenyl)-1,3-dioxolane" );
standardThermochemistry
{
    dHf_298   -393600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56880.0
}
