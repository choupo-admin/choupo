/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentadiene  (C5H6, CAS 542-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentadiene;
formula     C5H6;
CAS         542-92-7;
InChIKey    ZSWFCLXCOIISFI-UHFFFAOYSA-N;
MW          66.103;      // g/mol [origin=calculated method=formula-sum]
Tc          532.94;      // K   [origin=predictive method=joback]
Pc          50.086;      // bar [origin=predictive method=joback]
omega       0.1899;      // -   [origin=predictive method=lee-kesler]
Tb          332.27;      // K   [origin=predictive method=joback]
HvapTb      27874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.52 0.525 -0.00040556 1.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenta-1,3-diene" "1,3-cyclopentadiene" "pyropentylene" "pentole" "r-pentine" "cyclopentadiene;pentole;pyropentylene;r-pentine;" );
standardThermochemistry
{
    dHf_298   49850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     267.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95400.0
}
