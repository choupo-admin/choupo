/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxytricyclo(3.3.1.13,7decane-1-carboxylic acid, methyl ester  (C13H20O3, CAS 103549-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxytricyclo331137decane1CarboxylicAcidMethylEster;
formula     C13H20O3;
CAS         103549-37-7;
InChIKey    CWOBWCDFHUNRGG-UHFFFAOYSA-N;
MW          224.3;      // g/mol [origin=calculated method=formula-sum]
Tc          820.46;      // K   [origin=predictive method=joback]
Pc          24.851;      // bar [origin=predictive method=joback]
omega       0.6143;      // -   [origin=predictive method=lee-kesler]
Tb          597.98;      // K   [origin=predictive method=joback]
HvapTb      51649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-207.91 2.12124 -0.0021018 8.674e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group C; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-methoxyadamantane-1-carboxylate" "3-methoxytricyclo[3.3.1.13,7decane-1-carboxylic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -538770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205330.0
}
