/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentenedioic acid, 4-(7-methoxy-3,7-dimethyloctylidene)-3-methyl-, (2z,4e)-  (C17H28O5, CAS 53023-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PentenedioicAcid47Methoxy37Dimethyloctylidene3Methyl2z4e;
formula     C17H28O5;
CAS         53023-60-2;
InChIKey    ZGOJGQUEKNNWOG-UHFFFAOYSA-N;
MW          312.406;      // g/mol [origin=calculated method=formula-sum]
Tc          1120.59;      // K   [origin=predictive method=joback]
Pc          15.403;      // bar [origin=predictive method=joback]
omega       1.2317;      // -   [origin=predictive method=lee-kesler]
Tb          906.41;      // K   [origin=predictive method=joback]
HvapTb      88566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.766 1.8288 -0.0012824 3.621e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 2; } { group CH3O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group dCH; count 2; } { group dC; count 2; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(7-methoxy-3,7-dimethyl-octylidene)-3-methyl-pent-2-enedioic acid" );
gibbsFormation
{
    dHf_298   -1026140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     865.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-556820.0
    phase     gas;
}
