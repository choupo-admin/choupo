/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)valeramide  (C9H19NO3, CAS 70942-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxyethylValeramide;
formula     C9H19NO3;
CAS         70942-03-9;
InChIKey    RBYBLKRMFXJVST-UHFFFAOYSA-N;
MW          189.255;      // g/mol [origin=calculated method=formula-sum]
Tc          821.14;      // K   [origin=predictive method=joback]
Pc          29.633;      // bar [origin=predictive method=joback]
omega       1.6124;      // -   [origin=predictive method=lee-kesler]
Tb          656.19;      // K   [origin=predictive method=joback]
HvapTb      77775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.957 1.02272 -0.0006205 1.4386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-hydroxyethyl)pentanamide" "pentanamide, n,n-bis(2-hydroxyethyl)-" );
gibbsFormation
{
    dHf_298   -578600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266880.0
    phase     gas;
}
