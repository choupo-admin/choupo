/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilylpiperidine  (C8H19NSi, CAS 3768-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H19NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylpiperidine;
formula     C8H19NSi;
CAS         3768-56-7;
InChIKey    WLADIVUISABQHN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          157.332;      // g/mol [origin=calculated method=formula-sum]
Tc          614.70;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       0.2904;      // -   [origin=predictive method=lee-kesler]
Tb          416.43;      // K   [origin=predictive method=joback]
HvapTb      36305.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.68 0.83976 -0.000292 -2.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(piperidin-1-yl)silane" "piperidine, 1-(trimethylsilyl)-" "1-(trimethylsilyl)piperidine" "piperidine,1-(trimethylsilyl)-" "1-(trimethylsilyl)piperidine;n-(trimethylsilyl)piperidine; piperidinotrimethylsilane;trimethylpiperidinosilane; trimethylsilylpiperidine" );
gibbsFormation
{
    dHf_298   -171720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     602.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66760.0
    phase     gas;
}
