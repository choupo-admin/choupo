/*--------------------------------*- Choupo -*-----------------------*\
  Component: diundecylamine  (C22H47N, CAS 16165-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diundecylamine;
formula     C22H47N;
CAS         16165-33-6;
InChIKey    NKGSHSILLGXYDW-UHFFFAOYSA-N;
MW          325.625;      // g/mol [origin=calculated method=formula-sum]
Tc          924.52;      // K   [origin=predictive method=joback]
Pc          9.089;      // bar [origin=predictive method=joback]
omega       0.8520;      // -   [origin=predictive method=lee-kesler]
Tb          753.13;      // K   [origin=predictive method=joback]
HvapTb      71002.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.32 2.17004 -0.0012216 2.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 20; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-undecylundecan-1-amine" "di-n-undecylamine" "n.-undecylamine, n-(n.-undecyl)-" );
standardThermochemistry
{
    dHf_298   -443940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1053.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223750.0
}
