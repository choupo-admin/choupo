/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 6-amino-3,4-dimethoxybenzoate  (C11H15NO4, CAS 20323-74-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl6Amino34Dimethoxybenzoate;
formula     C11H15NO4;
CAS         20323-74-4;
InChIKey    SMICMEHDDWELMR-UHFFFAOYSA-N;
MW          225.244;      // g/mol [origin=calculated method=formula-sum]
Tc          881.46;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.9374;      // -   [origin=predictive method=lee-kesler]
Tb          668.49;      // K   [origin=predictive method=joback]
HvapTb      67210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.781 0.67216 -0.00013148 -8.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 3; } { group CH3O; count 2; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-azanyl-4,5-dimethoxy-benzoate" "ethyl 2-amino-4,5-dimethoxybenzoate" "benzoic acid, 2-amino-4,5-dimethoxy-, ethyl ester" "ethyl 4,5-dimethoxyanthranilate" "ethyl 2-amino-4,5-dimethoxy-benzoate;ethyl 4,5-dimethoxyanthranilate;ethyl 6-amino-3,4-dimethoxybenzoate;2-amino-4,5-dimethoxybenzoic acid ethyl ester;ethyl 6-amino-3,4-dimethoxybenzoate;" );
standardThermochemistry
{
    dHf_298   -616180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-328660.0
}
