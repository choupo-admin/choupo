/*--------------------------------*- Choupo -*-----------------------*\
  Component: ambrate  (C14H22O2, CAS 37172-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ambrate;
formula     C14H22O2;
CAS         37172-05-7;
InChIKey    PKVIIPGIGKYQFI-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          799.24;      // K   [origin=predictive method=joback]
Pc          20.965;      // bar [origin=predictive method=joback]
omega       0.5313;      // -   [origin=predictive method=lee-kesler]
Tb          582.94;      // K   [origin=predictive method=joback]
HvapTb      52604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.989 1.57856 -0.00120053 3.9559e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH3COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-butan-2-yl-1-ethynyl-cyclohexyl) ethanoate" "1-ethynyl-2-(1-methylpropyl)cyclohexyl acetate" "cyclohexanol, 1-ethynyl-2-(1-methylpropyl)-, acetate" "2-sec-butyl-1-ethynylcyclohexyl acetate" "acetoxy-2-sec-butyl-1-ethynylcyclohexane" "1-acetoxy-1-ethynyl-2-sec-butylcyclohexanol" "1-ethynyl-2-(1-methylpropyl)cyclohexanol acetate" "cyclohexanol, 1-ethynyl-2-(1-methylpropyl)-, 1-acetate" "(2-butan-2-yl-1-ethynylcyclohexyl) acetate" "acetic acid (2-butan-2-yl-1-ethynylcyclohexyl) ester" "cyclohexanol,1-ethynyl-2-(1-methylpropyl)-, 1-acetate" "cyclohexanol,1-ethynyl-2-(1-methylpropyl)-, acetate (9ci);1-acetoxy-2-sec-butyl-1-ethynylcyclohexane" );
standardThermochemistry
{
    dHf_298   -313730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11490.0
}
