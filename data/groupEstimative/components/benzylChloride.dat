/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl chloride  (C7H7Cl, CAS 100-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylChloride;
formula     C7H7Cl;
CAS         100-44-7;
InChIKey    KCXMKQUNVWSEMD-UHFFFAOYSA-N;
MW          126.583;      // g/mol [origin=calculated method=formula-sum]
Tc          643.63;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.3024;      // -   [origin=predictive method=lee-kesler]
Tb          423.87;      // K   [origin=predictive method=joback]
HvapTb      37837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.489 0.5967 -0.0004086 1.066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethylbenzene" "(chloromethyl)benzene" "benzylchloride" "benzene, (chloromethyl)-" "alpha-chlorotoluene" "benzylchlorid" "tolyl chloride" "benzene, chloromethyl-" "chlorophenylmethane" "chlorotoluene" "toluene, ar-chloro-" "chlorure de benzyle" );
gibbsFormation
{
    dHf_298   32980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108540.0
    phase     gas;
}
