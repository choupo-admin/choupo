/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-acetoxy-2-naphthoic acid  (C13H10O4, CAS 17295-26-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Acetoxy2NaphthoicAcid;
formula     C13H10O4;
CAS         17295-26-0;
InChIKey    NFTLBCXRDNIJMI-UHFFFAOYSA-N;
MW          230.219;      // g/mol [origin=calculated method=formula-sum]
Tc          993.06;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       1.0648;      // -   [origin=predictive method=lee-kesler]
Tb          756.39;      // K   [origin=predictive method=joback]
HvapTb      74343.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.67 1.03322 -0.00069524 1.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CH3COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-acetyloxynaphthalene-2-carboxylic acid" "2-naphthalenecarboxylic acid, 6-(acetyloxy)-" "6-hydroxy-2-naphthoic acid acetate" "6-(acetyloxy)-2-naphthoic acid" "6-(acetyloxy)naphthalene-2-carboxylic acid" "2-naphthalenecarboxylicacid, 6-(acetyloxy)-" "2-naphthoicacid, 6-hydroxy-, acetate (8ci);2-acetoxy-6-naphthalenecarboxylic acid;2-acetoxy-6-naphthoic acid;6-acetoxy-2-naphthoic acid;6-acetoxy-b-naphthoic acid;6-acetoxynaphthalene-2-carboxylic acid;6-acetyloxy-2-naphthoic acid;" );
gibbsFormation
{
    dHf_298   -574540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-395900.0
    phase     gas;
}
