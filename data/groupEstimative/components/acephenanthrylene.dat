/*--------------------------------*- Choupo -*-----------------------*\
  Component: acephenanthrylene  (C16H10, CAS 201-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acephenanthrylene;
formula     C16H10;
CAS         201-06-9;
InChIKey    SQFPKRNUGBRTAR-UHFFFAOYSA-N;
MW          202.256;      // g/mol [origin=calculated method=formula-sum]
Tc          907.76;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.6239;      // -   [origin=predictive method=lee-kesler]
Tb          651.56;      // K   [origin=predictive method=joback]
HvapTb      59094.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.83 1.39 -0.0012594 4.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 10; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoacenaphthylene" "benz(e)acenaphthylene" "4,5-benzoacenaphthylene;benz[e]acenaphthylene;" );
gibbsFormation
{
    dHf_298   367770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=491180.0
    phase     gas;
}
