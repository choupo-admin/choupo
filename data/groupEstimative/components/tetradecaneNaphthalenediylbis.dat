/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecane, naphthalenediylbis-  (C38H64, CAS 224051-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecaneNaphthalenediylbis;
formula     C38H64;
CAS         224051-15-4;
InChIKey    HFCGSVULNJHSQK-UHFFFAOYSA-N;
MW          520.93;      // g/mol [origin=calculated method=formula-sum]
Tc          1412.51;      // K   [origin=predictive method=joback]
Pc          5.358;      // bar [origin=predictive method=joback]
omega       0.2147;      // -   [origin=predictive method=lee-kesler]
Tb          1124.66;      // K   [origin=predictive method=joback]
HvapTb      105422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.404 3.41224 -0.00207724 4.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 24; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-di(tetradecyl)naphthalene" );
gibbsFormation
{
    dHf_298   -422990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1408.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=468880.0
    phase     gas;
}
