/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-chloroacenaphthene  (C12H9Cl, CAS 5209-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Chloroacenaphthene;
formula     C12H9Cl;
CAS         5209-33-6;
InChIKey    XIDFXORSALFWOP-UHFFFAOYSA-N;
MW          188.654;      // g/mol [origin=calculated method=formula-sum]
Tc          825.79;      // K   [origin=predictive method=joback]
Pc          33.106;      // bar [origin=predictive method=joback]
omega       0.5261;      // -   [origin=predictive method=lee-kesler]
Tb          579.33;      // K   [origin=predictive method=joback]
HvapTb      52643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.64 1.0765 -0.0009382 3.299e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 2; } { group ACCH2; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranyl-1,2-dihydroacenaphthylene" "acenaphthene, 5-chloro-" "acenaphthene, 5-chloro- (8ci)" "5-chloro-1,2-dihydroacenaphthylene" "acenaphthylene, 5-chloro-1,2-dihydro- (9ci)" );
standardThermochemistry
{
    dHf_298   185740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308960.0
}
