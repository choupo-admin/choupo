/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methylbenz(a)anthracen-8-yl carbamide  (C20H15NO, CAS 64082-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7MethylbenzAAnthracen8YlCarbamide;
formula     C20H15NO;
CAS         64082-43-5;
InChIKey    PGUNKBHRWNPPPL-UHFFFAOYSA-N;
MW          285.346;      // g/mol [origin=calculated method=formula-sum]
Tc          1147.91;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       1.0797;      // -   [origin=predictive method=lee-kesler]
Tb          887.14;      // K   [origin=predictive method=joback]
HvapTb      87345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.48 1.60972 -0.0012621 3.9796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 7; } { group ACCH3; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methylbenzo[a]anthracene-8-carboxamide" "10-methyl-1,2-benzanthracene-5-carbonamide" "benz(a)anthracen-8-yl carbamide, 7-methyl-" "7-methyltetraphene-8-carboxamide" );
gibbsFormation
{
    dHf_298   228940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=448890.0
    phase     gas;
}
