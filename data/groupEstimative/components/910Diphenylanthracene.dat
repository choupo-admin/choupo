/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-diphenylanthracene  (C26H18, CAS 1499-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910Diphenylanthracene;
formula     C26H18;
CAS         1499-10-1;
InChIKey    FCNCGHJSNVOIKE-UHFFFAOYSA-N;
MW          330.43;      // g/mol [origin=calculated method=formula-sum]
Tc          1207.29;      // K   [origin=predictive method=joback]
Pc          19.304;      // bar [origin=predictive method=joback]
omega       0.8596;      // -   [origin=predictive method=lee-kesler]
Tb          927.42;      // K   [origin=predictive method=joback]
HvapTb      85564.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.45 2.0512 -0.00155652 4.622e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 18; } { group AC; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 18; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anthracene, 9,10-diphenyl-" "anthracene,10-diphenyl-" "9,10-diphenyl anthracene" "r496" );
gibbsFormation
{
    dHf_298   477350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=689680.0
    phase     gas;
}
