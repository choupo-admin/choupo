/*--------------------------------*- Choupo -*-----------------------*\
  Component: mdbcp  (C4H7Br2Cl, CAS 10474-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mdbcp;
formula     C4H7Br2Cl;
CAS         10474-14-3;
InChIKey    DPDUMUDRFCRZGY-UHFFFAOYSA-N;
MW          250.358;      // g/mol [origin=calculated method=formula-sum]
Tc          685.92;      // K   [origin=predictive method=joback]
Pc          45.531;      // bar [origin=predictive method=joback]
omega       0.4083;      // -   [origin=predictive method=lee-kesler]
Tb          457.64;      // K   [origin=predictive method=joback]
HvapTb      40457.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.052 0.59282 -0.0005288 1.855e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group CH2Cl; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-3-chloranyl-2-methyl-propane" "methyl-dbcp" "1,2-dibromo-3-chloro-2-methylpropane" "2-methyl-1,2-dibromo-3-chloropropane" "propane, 3-chloro-1,2-dibromo-2-methyl-" "propane,1,2-dibromo-3-chloro-2-methyl-" "1,2-dibromo-3-chloro-2-methylpropane;2-methyl-1,2-dibromo-3-chloropropane" );
gibbsFormation
{
    dHf_298   -97720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2350.0
    phase     gas;
}
