/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-propylanisole  (C10H14O, CAS 104-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Propylanisole;
formula     C10H14O;
CAS         104-45-0;
InChIKey    KBHWKXNXTURZCD-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          686.94;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       0.4637;      // -   [origin=predictive method=lee-kesler]
Tb          482.48;      // K   [origin=predictive method=joback]
HvapTb      43202.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.308 0.75224 -0.00037336 5.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-propyl-benzene" "dihydroanethole" "benzene, 1-methoxy-4-propyl-" "anisole, p-propyl-" "p-propylanisole" "4-n-propylanisole" "p-propyl anisole" "p-n-propylanisole" "1-methoxy-4-propylbenzene" "p-n-propyl anisole" "p-propylmethoxybenzene" "4-propylmethoxybenzene" );
gibbsFormation
{
    dHf_298   -156890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31100.0
    phase     gas;
}
