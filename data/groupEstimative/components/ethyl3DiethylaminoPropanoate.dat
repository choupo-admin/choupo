/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-(diethylamino)propanoate  (C9H19NO2, CAS 5515-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3DiethylaminoPropanoate;
formula     C9H19NO2;
CAS         5515-83-3;
InChIKey    QDISKADULUYVBM-UHFFFAOYSA-N;
MW          173.256;      // g/mol [origin=calculated method=formula-sum]
Tc          645.22;      // K   [origin=predictive method=joback]
Pc          23.136;      // bar [origin=predictive method=joback]
omega       0.6590;      // -   [origin=predictive method=lee-kesler]
Tb          476.18;      // K   [origin=predictive method=joback]
HvapTb      45078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.425 0.92796 -0.0004838 7.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl n,n-diethyl-" "a-alaninate" "ethyl 3-(diethylamino)propionate" "b-alanine, n,n-diethyl-, ethylester" "ethyl beta-diethylamino propionate" "beta-alanine, n,n-diethyl-, ethyl ester" "3-diethylaminopropionic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -478840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174690.0
    phase     gas;
}
