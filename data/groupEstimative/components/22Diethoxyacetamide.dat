/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-diethoxyacetamide  (C6H13NO3, CAS 61189-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Diethoxyacetamide;
formula     C6H13NO3;
CAS         61189-99-9;
InChIKey    DSKGWFQMJHBHRT-UHFFFAOYSA-N;
MW          147.174;      // g/mol [origin=calculated method=formula-sum]
Tc          700.96;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.7406;      // -   [origin=predictive method=lee-kesler]
Tb          507.68;      // K   [origin=predictive method=joback]
HvapTb      50769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.602 0.48724 -0.0001085 -4.794e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2O; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group O; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethoxyethanamide" "glyoxylic amide diethyl acetal" "2,2-diethoxy-acetamide" "acetamide,2,2-diethoxy-" );
standardThermochemistry
{
    dHf_298   -515680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275270.0
}
