/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propoxybutane  (C7H16O, CAS 61962-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propoxybutane;
formula     C7H16O;
CAS         61962-23-0;
InChIKey    NKCLBERXLKOMPK-UHFFFAOYSA-N;
MW          116.204;      // g/mol [origin=calculated method=formula-sum]
Tc          549.98;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.3958;      // -   [origin=predictive method=lee-kesler]
Tb          381.74;      // K   [origin=predictive method=joback]
HvapTb      33198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.343 0.61156 -0.0002492 1.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "sec-butyl propyl ether" "butane, 2-propoxy-" );
gibbsFormation
{
    dHf_298   -325310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99380.0
    phase     gas;
}
