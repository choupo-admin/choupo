/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-triazinane  (C3H9N3, CAS 110-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Triazinane;
formula     C3H9N3;
CAS         110-90-7;
InChIKey    LKLLNYWECKEQIB-UHFFFAOYSA-N;
MW          87.126;      // g/mol [origin=calculated method=formula-sum]
Tc          678.37;      // K   [origin=predictive method=joback]
Pc          70.262;      // bar [origin=predictive method=joback]
omega       0.4177;      // -   [origin=predictive method=lee-kesler]
Tb          438.11;      // K   [origin=predictive method=joback]
HvapTb      43284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.62 0.3972 -9.4e-05 -3.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group NH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-triazine, hexahydro-" "hexahydro-1,3,5-triazine" "agn-pc-0d7ac7" "cyclotrimethylene triamine, 50% in water" );
standardThermochemistry
{
    dHf_298   82840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     266.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=269670.0
}
