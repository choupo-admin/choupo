/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diethynylbenzene  (C10H6, CAS 1785-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diethynylbenzene;
formula     C10H6;
CAS         1785-61-1;
InChIKey    PNXLPYYXCOXPBM-UHFFFAOYSA-N;
MW          126.158;      // g/mol [origin=calculated method=formula-sum]
Tc          680.20;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.2513;      // -   [origin=predictive method=lee-kesler]
Tb          440.30;      // K   [origin=predictive method=joback]
HvapTb      40508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.75 0.6276 -0.00047622 1.4518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 2; } { group tC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-diethynylbenzene" "benzene, 1,3-diethynyl-" "1,3-diethynyl-benzene" "benzene,1,3-diethynyl-" "benzene,m-diethynyl- (6ci,7ci,8ci);m-diethynylbenzene;" );
standardThermochemistry
{
    dHf_298   559130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=582240.0
}
