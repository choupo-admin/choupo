/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxyzine pamoate (ester)  (C44H41ClN2O7, CAS 5978-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxyzinePamoateEster;
formula     C44H41ClN2O7;
CAS         5978-92-7;
InChIKey    YENRTVJWRCAGEM-UHFFFAOYSA-N;
MW          745.269;      // g/mol [origin=calculated method=formula-sum]
Tc          2434.67;      // K   [origin=predictive method=joback]
Pc          9.933;      // bar [origin=predictive method=joback]
omega       0.3268;      // -   [origin=predictive method=lee-kesler]
Tb          1840.84;      // K   [origin=predictive method=joback]
HvapTb      190718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-197.925 4.2336 -0.00329056 1.0153e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 19; } { group AC; count 8; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } { group CH2O; count 1; } { group CH2N; count 2; } { group COOH; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 19; } { group dC_ring; count 13; } { group Cl; count 1; } { group OH_phenol; count 2; } { group O; count 1; } { group COOH; count 1; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[3-[2-[2-[4-[(4-chlorophenyl)-phenyl-methyl]piperazin-1-yl]ethoxy]ethoxycarbonyl]-2-oxidanyl-naphthalen-1-yl]methyl]-3-oxidanyl-naphthalene-2-carboxylic acid" "2-naphthoic acid, 4,4'-methylenebis(3-hydroxy-, ester with 2-(2-(4-(p-chloro-alpha-phenylbenzyl)-1-piperazinyl)-ethoxy)ethanol" "4-[(3-{[2-(2-{4-[(4-chlorophenyl)(phenyl)methyl]piperazin-1-yl}ethoxy)ethoxy]carbonyl}-2-hydroxynaphthalen-1-yl)methyl]-3-hydroxynaphthalene-2-carboxylic acid" "4-[[3-[2-[2-[4-[(4-chlorophenyl)-phenylmethyl]piperazin-1-yl]ethoxy]ethoxycarbonyl]-2-hydroxynaphthalen-1-yl]methyl]-3-hydroxynaphthalene-2-carboxylic acid" );
gibbsFormation
{
    dHf_298   -633950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1392.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129420.0
    phase     gas;
}
