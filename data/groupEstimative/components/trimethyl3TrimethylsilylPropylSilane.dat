/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl[3-(trimethylsilyl)propyl]silane  (C9H24Si2, CAS 2295-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H24Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethyl3TrimethylsilylPropylSilane;
formula     C9H24Si2;
CAS         2295-05-8;
InChIKey    YMPSYNWHUIOPJH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          188.461;      // g/mol [origin=calculated method=formula-sum]
Tc          582.99;      // K   [origin=predictive method=joback]
Pc          18.547;      // bar [origin=predictive method=joback]
omega       0.2650;      // -   [origin=predictive method=lee-kesler]
Tb          408.32;      // K   [origin=predictive method=joback]
HvapTb      36216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.343 0.44652 0.0003638 -3.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(3-trimethylsilylpropyl)silane" "silane, 1,3-propanediylbis[trimethyl-" "silane, 1,3-propanediylbis(trimethyl-" "trimethyl-(3-trimethylsilylpropyl)silane" );
standardThermochemistry
{
    dHf_298   -452330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184620.0
}
