/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(ethylcyclohexyl)methane  (C17H32, CAS 98028-64-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisEthylcyclohexylMethane;
formula     C17H32;
CAS         98028-64-9;
InChIKey    DBGHVWCPQPPOOZ-UHFFFAOYSA-N;
MW          236.443;      // g/mol [origin=calculated method=formula-sum]
Tc          856.75;      // K   [origin=predictive method=joback]
Pc          18.108;      // bar [origin=predictive method=joback]
omega       0.4860;      // -   [origin=predictive method=lee-kesler]
Tb          628.14;      // K   [origin=predictive method=joback]
HvapTb      51992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-243.757 2.44684 -0.0021282 8.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 10; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-1-[(1-ethylcyclohexyl)methyl]cyclohexane" "1,1'-methanediylbis(1-ethylcyclohexane)" );
gibbsFormation
{
    dHf_298   -255090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     896.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130180.0
    phase     gas;
}
