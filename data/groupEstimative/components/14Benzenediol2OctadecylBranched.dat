/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenediol, 2-octadecyl-, branched  (C24H42O2, CAS 72207-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Benzenediol2OctadecylBranched;
formula     C24H42O2;
CAS         72207-59-1;
InChIKey    IPOXWYLONHBIFZ-UHFFFAOYSA-N;
MW          362.598;      // g/mol [origin=calculated method=formula-sum]
Tc          1148.30;      // K   [origin=predictive method=joback]
Pc          12.015;      // bar [origin=predictive method=joback]
omega       1.1122;      // -   [origin=predictive method=lee-kesler]
Tb          936.20;      // K   [origin=predictive method=joback]
HvapTb      96934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.355 2.52004 -0.00182892 5.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(16-methylheptadecyl)benzene-1,4-diol" );
gibbsFormation
{
    dHf_298   -662060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1027.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-48070.0
    phase     gas;
}
