/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonatetracontane  (C49H100, CAS 7098-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonatetracontane;
formula     C49H100;
CAS         7098-27-3;
InChIKey    QPGZDOBTQZCJFT-UHFFFAOYSA-N;
MW          689.339;      // g/mol [origin=calculated method=formula-sum]
Tc          2101.55;      // K   [origin=predictive method=joback]
Pc          2.851;      // bar [origin=predictive method=joback]
omega       -0.6218;      // -   [origin=predictive method=lee-kesler]
Tb          1320.72;      // K   [origin=predictive method=joback]
HvapTb      124668.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.653 4.65884 -0.0026418 5.719e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 47; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 47; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "Q11325709" "C49" "nc49" "n-c49" );
standardThermochemistry
{
    dHf_298   -1054690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2064.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=361700.0
}
