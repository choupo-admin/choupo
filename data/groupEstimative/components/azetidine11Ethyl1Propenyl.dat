/*--------------------------------*- Choupo -*-----------------------*\
  Component: azetidine, 1-(1-ethyl-1-propenyl)-  (C8H15N, CAS 81156-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azetidine11Ethyl1Propenyl;
formula     C8H15N;
CAS         81156-89-0;
InChIKey    RVYHBXNGTVVNGT-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          599.85;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.3885;      // -   [origin=predictive method=lee-kesler]
Tb          410.53;      // K   [origin=predictive method=joback]
HvapTb      35705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.129 1.08504 -0.0008857 2.981e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pent-2-en-3-ylazetidine" );
standardThermochemistry
{
    dHf_298   59650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267390.0
}
