/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptachlor  (C10H5Cl7, CAS 76-44-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptachlor;
formula     C10H5Cl7;
CAS         76-44-8;
InChIKey    FRCCEHPWNOQAEU-UHFFFAOYSA-N;
MW          373.3;      // g/mol [origin=calculated method=formula-sum]
Tc          989.11;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.5515;      // -   [origin=predictive method=lee-kesler]
Tb          709.89;      // K   [origin=predictive method=joback]
HvapTb      65988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-159.81 2.0097 -0.00254928 1.2068e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 1; } { group CHCl; count 1; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptachlorane" "heptamul" "3-chlorochlordene" "rhodiachlor" "aahepta" "agroceres" "heptagran" "drinox" "hepta" "velsicol heptachlor" "gpkh" "heptachloor" );
standardThermochemistry
{
    dHf_298   -70350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121020.0
}
