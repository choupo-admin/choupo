/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methoxyphenyl)-2-methylpiperazine  (C12H18N2O, CAS 35947-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Methoxyphenyl2Methylpiperazine;
formula     C12H18N2O;
CAS         35947-12-7;
InChIKey    LSIROHVGZARUJC-UHFFFAOYSA-N;
MW          206.289;      // g/mol [origin=calculated method=formula-sum]
Tc          834.51;      // K   [origin=predictive method=joback]
Pc          28.658;      // bar [origin=predictive method=joback]
omega       0.6474;      // -   [origin=predictive method=lee-kesler]
Tb          604.51;      // K   [origin=predictive method=joback]
HvapTb      56712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.38 1.18444 -0.00066156 1.214e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methoxyphenyl)-2-methyl-piperazine" "4-methoxy-1-(2-methylpiperazinyl)benzene" );
standardThermochemistry
{
    dHf_298   -32350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282980.0
}
