/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolethane trilaurate  (C41H78O6, CAS 67873-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolethaneTrilaurate;
formula     C41H78O6;
CAS         67873-95-4;
InChIKey    PBHKDCBZJONOSA-UHFFFAOYSA-N;
MW          667.069;      // g/mol [origin=calculated method=formula-sum]
Tc          1882.84;      // K   [origin=predictive method=joback]
Pc          3.815;      // bar [origin=predictive method=joback]
omega       -0.4346;      // -   [origin=predictive method=lee-kesler]
Tb          1309.11;      // K   [origin=predictive method=joback]
HvapTb      127785.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.373 3.86028 -0.0020946 3.773e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 30; } { group C; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 33; } { group C; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-dodecanoyloxy-2-(dodecanoyloxymethyl)-2-methyl-propyl] dodecanoate" "dodecanoic acid, 1,1'-(2-methyl-2-(((1-oxododecyl)oxy)methyl)-1,3-propanediyl) ester" "dodecanoic acid, 1,1'-[2-methyl-2-[[(1-oxododecyl)oxy]methyl]-1,3-propanediyl] ester" "[3-dodecanoyloxy-2-(dodecanoyloxymethyl)-2-methylpropyl] dodecanoate" "2-methyl-2-(((1-oxododecyl)oxy)methyl)propane-1,3-diyl dilaurate" "dodecanoic acid, 2-methyl-2-(((1-oxododecyl)oxy)methyl)-1,3-propanediyl ester" );
standardThermochemistry
{
    dHf_298   -1850160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1868.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-633930.0
}
