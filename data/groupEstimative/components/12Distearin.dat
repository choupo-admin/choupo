/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-distearin  (C39H76O5, CAS 1188-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Distearin;
formula     C39H76O5;
CAS         1188-58-5;
InChIKey    UHUSDOQQWJGJQS-UHFFFAOYSA-N;
MW          625.032;      // g/mol [origin=calculated method=formula-sum]
Tc          1922.71;      // K   [origin=predictive method=joback]
Pc          4.248;      // bar [origin=predictive method=joback]
omega       -0.4308;      // -   [origin=predictive method=lee-kesler]
Tb          1300.10;      // K   [origin=predictive method=joback]
HvapTb      133513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.864 3.63914 -0.0019422 3.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 32; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 34; } { group CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-octadecanoyloxy-3-oxidanyl-propyl) octadecanoate" "distearoylglycerol" "1,2-dioctadecanoyl-rac-glycerol" "dg(18:0/18:0/0:0)[rac]" "dl-1,2-distearin" "rac-1,2-distearoylglycerol" "rac-glycerol 1,2-distearate" "1,2-dioctadecanoylglycerol" "1,2-distearoyl-rac-glycerol" "1,2-distearoylglycerol" "(rs)-1,2-distearin" "glycerol 1,2-distearate" );
standardThermochemistry
{
    dHf_298   -1640360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1819.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-482500.0
}
