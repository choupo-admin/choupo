/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(dimethylamino)-3-(4-(dimethylamino)phenyl)phthalide  (C18H20N2O2, CAS 57515-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Dimethylamino34DimethylaminoPhenylPhthalide;
formula     C18H20N2O2;
CAS         57515-95-4;
InChIKey    TYIHCISAZQHKHT-UHFFFAOYSA-N;
MW          296.37;      // g/mol [origin=calculated method=formula-sum]
Tc          981.28;      // K   [origin=predictive method=joback]
Pc          19.788;      // bar [origin=predictive method=joback]
omega       0.9630;      // -   [origin=predictive method=lee-kesler]
Tb          761.04;      // K   [origin=predictive method=joback]
HvapTb      73262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.36 1.74068 -0.00126028 3.561e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 7; } { group AC; count 4; } { group ACCH; count 1; } { group CH3N; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(dimethylamino)-3-[4-(dimethylamino)phenyl]-3h-2-benzofuran-1-one" "1(3h)-isobenzofuranone, 6-(dimethylamino)-3-(4-(dimethylamino)phenyl)-" "1(3h)-isobenzofuranone, 6-(dimethylamino)-3-[4-(dimethylamino)phenyl]-" "6-(dimethylamino)-3-(4-dimethylaminophenyl)-3h-2-benzofuran-1-one" "6-(dimethylamino)-3-[4-(dimethylamino)phenyl]-2-benzofuran-1(3h)-one" );
gibbsFormation
{
    dHf_298   -73300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=292750.0
    phase     gas;
}
