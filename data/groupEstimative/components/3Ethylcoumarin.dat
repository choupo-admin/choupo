/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethylcoumarin  (C11H10O2, CAS 66898-39-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethylcoumarin;
formula     C11H10O2;
CAS         66898-39-3;
InChIKey    LKAXCASKXOSFIU-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          771.56;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.6142;      // -   [origin=predictive method=lee-kesler]
Tb          552.44;      // K   [origin=predictive method=joback]
HvapTb      51429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.289 0.92712 -0.0006864 1.999e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethylchromen-2-one" "coumarin, 3-ethyl-" "3-ethyl-2h-1-benzopyran-2-one" "2h-1-benzopyran-2-one, 3-ethyl-" );
standardThermochemistry
{
    dHf_298   -216980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64960.0
}
