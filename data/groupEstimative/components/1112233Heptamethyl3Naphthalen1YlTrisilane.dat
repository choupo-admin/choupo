name        1112233Heptamethyl3Naphthalen1YlTrisilane;
formula     C17H28Si3;
CAS         38446-42-3;
InChIKey    QMUHOVBKQKHWOD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          316.666;      // g/mol [origin=calculated method=formula-sum]
Tc          873.67;      // K   [origin=predictive method=joback]
Pc          14.251;      // bar [origin=predictive method=joback]
omega       0.3839;      // -   [origin=predictive method=lee-kesler]
Tb          643.40;      // K   [origin=predictive method=joback]
HvapTb      58896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.84 0.85824 0.00024252 -3.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group ACH; count 7; } { group AC; count 3; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[dimethyl(naphthalen-1-yl)silyl]-dimethyl-trimethylsilyl-silane" "trisilane,1,1,1,2,2,3,3-heptamethyl-3-(1-naphthalenyl)-" "[dimethyl(naphthalen-1-yl)silyl]-dimethyl-trimethylsilylsilane" "trisilane, 1,1,1,2,2,3,3-heptamethyl-3-(1-naphthalenyl)-" );
standardThermochemistry
{
    dHf_298   -312940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     976.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12590.0
}
