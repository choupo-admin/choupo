/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-chloro-3,20-dioxopregna-4,6-dien-17-yl acetate  (C23H29ClO4, CAS 302-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Chloro320Dioxopregna46Dien17YlAcetate;
formula     C23H29ClO4;
CAS         302-22-7;
InChIKey    QMBJSIBWORFWQT-UHFFFAOYSA-N;
MW          404.931;      // g/mol [origin=calculated method=formula-sum]
Tc          1246.37;      // K   [origin=predictive method=joback]
Pc          14.747;      // bar [origin=predictive method=joback]
omega       0.9989;      // -   [origin=predictive method=lee-kesler]
Tb          991.15;      // K   [origin=predictive method=joback]
HvapTb      87926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-256.44 3.09188 -0.00286678 1.13626e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group C; count 3; } { group CH=C; count 2; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6-chloranyl-17-ethanoyl-10,13-dimethyl-3-oxidanylidene-2,8,9,11,12,14,15,16-octahydro-1h-cyclopenta[a]phenanthren-17-yl) ethanoate" "verton" "c-quens" "pregna-4,6-diene-3,20-dione, 17-(acetyloxy)-6-chloro-" "-3,20-dione; 17.alpha.-acetoxy-6-chloro-6-dehydroproges" "(17xi)-6-chloro-3,20-dioxopregna-4,6-dien-17-yl acetate" "(17-acetyl-6-chloro-10,13-dimethyl-3-oxo-2,8,9,11,12,14,15,16-octahydro-1h-cyclopenta[a]phenanthren-17-yl) acetate" "[(10r,13r,17s)-17-acetyl-6-chloro-10,13-dimethyl-3-oxo-2,8,9,11,12,14,15,16-octahydro-1h-cyclopenta[a]phenanthren-17-yl] acetate" "6-chloro-3,20-dioxopregna-4,6-dien-17-yl acetate; .delta.(sup 6)-6-chloro-17.alpha.-acetoxyprogesterone; {6-chloro-.delta.6-[17.alpha.]acetoxyprogesterone}; 17.alpha.-acetoxy-6-chloro-4, 6-pregnadiene" );
gibbsFormation
{
    dHf_298   -743290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     859.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239760.0
    phase     gas;
}
