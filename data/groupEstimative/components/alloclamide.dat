/*--------------------------------*- Choupo -*-----------------------*\
  Component: alloclamide  (C16H23ClN2O2, CAS 5486-77-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alloclamide;
formula     C16H23ClN2O2;
CAS         5486-77-1;
InChIKey    UHWFVIPXDFZTFA-UHFFFAOYSA-N;
MW          310.822;      // g/mol [origin=calculated method=formula-sum]
Tc          978.53;      // K   [origin=predictive method=joback]
Pc          17.492;      // bar [origin=predictive method=joback]
omega       1.0920;      // -   [origin=predictive method=lee-kesler]
Tb          775.33;      // K   [origin=predictive method=joback]
HvapTb      76160.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.895 1.42164 -0.00081852 1.6536e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-n-[2-(diethylamino)ethyl]-2-prop-2-enoxy-benzamide" "alloclamida" "alloclamidum [inn-latin]" "alloclamide hcl" "2-(allyloxy)-4-chloro-n-(2-(diethylamino)ethyl)benzamide" "2-(allyloxy)-4-chloro-n-[2-(diethylamino)ethyl]benzamide" "benzamide, 2-(allyloxy)-4-chloro-n-(2-(diethylamino)ethyl)-" "4-chloro-n-(2-(diethylamino)ethyl)-2-(2-propenyloxy)benzamide" "alloclamidum" "aloclamida" "alloclamide [inn:dcf]" "5107-01-7 (hydrochloride)" );
standardThermochemistry
{
    dHf_298   -174090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219150.0
}
