/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzylbiphenyl  (C19H16, CAS 31307-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Benzylbiphenyl;
formula     C19H16;
CAS         31307-59-2;
InChIKey    ZOYJYNLKJSQUEM-UHFFFAOYSA-N;
MW          244.337;      // g/mol [origin=calculated method=formula-sum]
Tc          983.01;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.6105;      // -   [origin=predictive method=lee-kesler]
Tb          719.34;      // K   [origin=predictive method=joback]
HvapTb      65378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.799 1.5126 -0.00103636 2.665e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 3; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-2-(phenylmethyl)benzene" "(phenylmethyl)-1,1'-biphenyl" "1-benzyl-2-phenylbenzene" "1-benzyl-2-phenyl-benzene" "2-benzyl-1,1'-biphenyl" "1,1'-biphenyl,(phenylmethyl)-" "1,1'-biphenyl, 2-(phenylmethyl)-" "biphenyl,benzyl- (7ci); benzylbiphenyl; benzyldiphenyl" );
standardThermochemistry
{
    dHf_298   262630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=436700.0
}
