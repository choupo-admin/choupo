/*--------------------------------*- Choupo -*-----------------------*\
  Component: dsstox_cid_21491  (C9H10O, CAS 4510-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dsstoxCid21491;
formula     C9H10O;
CAS         4510-34-3;
InChIKey    OOCCDEMITAIZTP-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          732.36;      // K   [origin=predictive method=joback]
Pc          38.723;      // bar [origin=predictive method=joback]
omega       0.7721;      // -   [origin=predictive method=lee-kesler]
Tb          528.54;      // K   [origin=predictive method=joback]
HvapTb      54541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.089 0.8339 -0.0006112 1.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylprop-2-en-1-ol" "agn-pc-04y218" );
gibbsFormation
{
    dHf_298   -27570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80710.0
    phase     gas;
}
