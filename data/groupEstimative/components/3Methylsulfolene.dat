/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylsulfolene  (C5H8O2S, CAS 1193-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H8O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Methylsulfolene;
formula     C5H8O2S;
CAS         1193-10-8;
InChIKey    FAYFWMOSHFCQPG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          132.177;      // g/mol [origin=calculated method=formula-sum]
Tc          474.72;      // K   [origin=predictive method=joback]
Pc          52.282;      // bar [origin=predictive method=joback]
omega       0.4036;      // -   [origin=predictive method=lee-kesler]
Tb          312.82;      // K   [origin=predictive method=joback]
HvapTb      39890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.24 0.57032 -0.00037224 8.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2,5-dihydrothiophene 1,1-dioxide" "3-methyl-3-sulfolene" "thiophene, 2,5-dihydro-3-methyl-, 1,1-dioxide" "3-methyl-2,5-dihydrothiophene-1,1-dioxide" "3-methyl-2,5-dihydrothiophene dioxide" "2,5-dihydro-3-methyl-thiophene 1,1-dioxide" "3-methyl-2,1-dioxide" "1, 2-methyl-, sulfone" "isoprene cyclic sulfone" "1,3-butadiene, 2-methyl-, sulfone" "3-methyl-2,5-dihydrothiophene-1,1-dione" "3-methyl-2,5-dihydro-thiophene 1,1-dioxide" );
gibbsFormation
{
    dHf_298   -508460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-433750.0
    phase     gas;
}
