/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-2-pentanol  (C7H16O, CAS 19781-24-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl2Pentanol;
formula     C7H16O;
CAS         19781-24-9;
InChIKey    FCUOIGTWJDBTHR-UHFFFAOYSA-N;
MW          116.204;      // g/mol [origin=calculated method=formula-sum]
Tc          621.99;      // K   [origin=predictive method=joback]
Pc          31.883;      // bar [origin=predictive method=joback]
omega       0.6675;      // -   [origin=predictive method=lee-kesler]
Tb          448.27;      // K   [origin=predictive method=joback]
HvapTb      46171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.339 0.83458 -0.0005624 1.533e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylpentan-2-ol" "2-pentanol,3,3-dimethyl-" "fcuoigtwjdbthr-uhfffaoysa-" "3,3-dimethyl-2-pentanol;methyl-tert-pentylcarbinol" );
gibbsFormation
{
    dHf_298   -354070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-128360.0
    phase     gas;
}
