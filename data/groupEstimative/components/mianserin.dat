/*--------------------------------*- Choupo -*-----------------------*\
  Component: mianserin  (C18H20N2, CAS 24219-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mianserin;
formula     C18H20N2;
CAS         24219-97-4;
InChIKey    UEQUQVLFIPOEMF-UHFFFAOYSA-N;
MW          264.372;      // g/mol [origin=calculated method=formula-sum]
Tc          952.10;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.7860;      // -   [origin=predictive method=lee-kesler]
Tb          713.52;      // K   [origin=predictive method=joback]
HvapTb      65587.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-175.37 2.02272 -0.00165112 5.357e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "mianserine" "mianserina" "mianserinum" "tolvon" "mianseryna [polish]" "mianseryna" "norval" "mianserine [inn-french]" "mianserinum [inn-latin]" "mianserin [inn:ban]" "tolvan" "mianserin monohydrochloride" );
gibbsFormation
{
    dHf_298   342430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=669110.0
    phase     gas;
}
