/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptylcyclohexane  (C13H26, CAS 5617-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptylcyclohexane;
formula     C13H26;
CAS         5617-41-4;
InChIKey    MSTLSCNJAHAQNU-UHFFFAOYSA-N;
MW          182.351;      // g/mol [origin=calculated method=formula-sum]
Tc          706.62;      // K   [origin=predictive method=joback]
Pc          19.561;      // bar [origin=predictive method=joback]
omega       0.5094;      // -   [origin=predictive method=lee-kesler]
Tb          516.59;      // K   [origin=predictive method=joback]
HvapTb      44961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.534 1.36092 -0.0007644 1.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, heptyl-" "n-heptylcyclohexane" "n-heptyl cyclohexane" "heptane, 1-cyclohexyl-" "heptane, 1-cyclohexyl- (8ci)" );
gibbsFormation
{
    dHf_298   -257330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83030.0
    phase     gas;
}
