/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-(2-hydroxyethoxy)ethyl)octylamine  (C16H35NO4, CAS 68003-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis22HydroxyethoxyEthylOctylamine;
formula     C16H35NO4;
CAS         68003-29-2;
InChIKey    BBLLNWPZRQWZSP-UHFFFAOYSA-N;
MW          305.459;      // g/mol [origin=calculated method=formula-sum]
Tc          988.62;      // K   [origin=predictive method=joback]
Pc          14.725;      // bar [origin=predictive method=joback]
omega       1.3174;      // -   [origin=predictive method=lee-kesler]
Tb          807.32;      // K   [origin=predictive method=joback]
HvapTb      91431.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.235 1.58932 -0.000798 1.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2N; count 1; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group OH; count 2; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-(2-hydroxyethyloxy)ethyl-octyl-amino]ethoxy]ethanol" "ethanol, 2,2'-((octylimino)bis(2,1-ethanediyloxy))bis-" "ethanol, 2,2'-[(octylimino)bis(2,1-ethanediyloxy)]bis-" "2-(2-{[2-(2-hydroxyethoxy)ethyl]octylamino}ethoxy)ethan-1-ol" "2,2'-[(octylimino)bis(2,1-ethanediyloxy)]bisethanol" "2-[2-[2-(2-hydroxyethoxy)ethyl-octylamino]ethoxy]ethanol" );
standardThermochemistry
{
    dHf_298   -874940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     919.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-289020.0
}
