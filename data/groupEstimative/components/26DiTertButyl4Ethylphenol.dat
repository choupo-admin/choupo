/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-di-tert-butyl-4-ethylphenol  (C16H26O, CAS 4130-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiTertButyl4Ethylphenol;
formula     C16H26O;
CAS         4130-42-1;
InChIKey    BVUXDWXKPROUDO-UHFFFAOYSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          899.17;      // K   [origin=predictive method=joback]
Pc          19.475;      // bar [origin=predictive method=joback]
omega       0.6978;      // -   [origin=predictive method=lee-kesler]
Tb          676.48;      // K   [origin=predictive method=joback]
HvapTb      65232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.829 1.73224 -0.00134368 4.318e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butyl-4-ethyl-phenol" "ionol 2" "2,6-ditert-butyl-4-ethylphenol" "phenol, 2,6-bis(1,1-dimethylethyl)-4-ethyl-" "phenol, 2,6-di-tert-butyl-4-ethyl-" "4-ethyl-2,6-di-tert-butylphenol" "1-hydroxy-4-ethyl-2,6-di-tert-butylbenzene" "2,6-bis(1,1-dimethylethyl)-4-ethylphenol" "2,6-bis(tert-butyl)-4-ethylphenol" "bvuxdwxkproudo-uhfffaoysa-" "2,1-dimethylethyl)-4-ethylphenol" "phenol,6-di-tert-butyl-4-ethyl-" );
standardThermochemistry
{
    dHf_298   -354790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28050.0
}
