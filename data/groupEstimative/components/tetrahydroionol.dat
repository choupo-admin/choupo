/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydroionol  (C13H26O, CAS 4361-23-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydroionol;
formula     C13H26O;
CAS         4361-23-3;
InChIKey    UZWOWEPOVKVMEL-UHFFFAOYSA-N;
MW          198.35;      // g/mol [origin=calculated method=formula-sum]
Tc          788.89;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       0.8183;      // -   [origin=predictive method=lee-kesler]
Tb          599.23;      // K   [origin=predictive method=joback]
HvapTb      59483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.038 1.63978 -0.0012198 4.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,2,6-trimethylcyclohexyl)butan-2-ol" "cyclohexanepropanol, .alpha.,2,2,6-tetramethyl-" "cyclohexanepropanol, " "a,2,2,6-tetramethyl-" "tetrahydroional" "agn-pc-03vgkb" "alpha,2,2,6-tetramethylcyclohexanepropanol" "4-(2,2,6-trimethylcyclohexyl)-2-butanol" "cyclohexanepropanol, ?,2,2,6-tetramethyl-" "cyclohexanepropanol, alpha,2,2,6-tetramethyl-" "4-[(6r)-2,2,6-trimethylcyclohexyl]butan-2-ol" );
gibbsFormation
{
    dHf_298   -440280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77140.0
    phase     gas;
}
