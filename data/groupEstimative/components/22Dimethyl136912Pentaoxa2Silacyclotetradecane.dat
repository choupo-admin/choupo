/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-1,3,6,9,12-pentaoxa-2-silacyclotetradecane  (C10H22O5Si, CAS 70851-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H22O5Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        22Dimethyl136912Pentaoxa2Silacyclotetradecane;
formula     C10H22O5Si;
CAS         70851-49-9;
InChIKey    JIOBGPYSBDFDAB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          250.366;      // g/mol [origin=calculated method=formula-sum]
Tc          870.14;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       0.5048;      // -   [origin=predictive method=lee-kesler]
Tb          618.66;      // K   [origin=predictive method=joback]
HvapTb      62640.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.83 0.81404 0.0001525 -3.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2O; count 2; } { group FCH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group O_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-2-sila-14-crown-5" "1,3,6,9,12-pentaoxa-2-silacyclotetradecane, 2,2-dimethyl-" "1,1-dimethylsila-14-crown-5" "1,1-dimethyl-1-sila-2,5,8,11,14-oxacyclotetradecane" );
standardThermochemistry
{
    dHf_298   -989810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-554580.0
}
