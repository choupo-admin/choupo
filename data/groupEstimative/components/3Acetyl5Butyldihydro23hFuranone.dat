/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetyl-5-butyldihydro-2(3h)-furanone  (C10H16O3, CAS 40010-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetyl5Butyldihydro23hFuranone;
formula     C10H16O3;
CAS         40010-99-9;
InChIKey    NEBMUHXPHLFPGQ-UHFFFAOYSA-N;
MW          184.235;      // g/mol [origin=calculated method=formula-sum]
Tc          733.17;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       0.7132;      // -   [origin=predictive method=lee-kesler]
Tb          542.56;      // K   [origin=predictive method=joback]
HvapTb      51611.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.737 0.99544 -0.0005717 1.1276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-butyl-3-ethanoyl-oxolan-2-one" "2(3h)-furanone, 3-acetyl-5-butyldihydro-" );
gibbsFormation
{
    dHf_298   -627130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-352930.0
    phase     gas;
}
