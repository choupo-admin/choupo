/*--------------------------------*- Choupo -*-----------------------*\
  Component: crotonic acid  (C4H6O2, CAS 107-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        crotonicAcid;
formula     C4H6O2;
CAS         107-93-7;
InChIKey    LDHQCZJRKDOVOX-NSCUHMNNSA-N;
MW          86.09;      // g/mol [origin=calculated method=formula-sum]
Tc          643.80;      // K   [origin=predictive method=joback]
Pc          46.849;      // bar [origin=predictive method=joback]
omega       0.5423;      // -   [origin=predictive method=lee-kesler]
Tb          440.79;      // K   [origin=predictive method=joback]
HvapTb      41620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.33 0.45462 -0.0003502 1.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enoic acid" "trans-2-butenoic acid" "2-butenoic acid" "3-methylacrylic acid" "but-2-enoic acid" "trans-crotonic acid" "beta-methylacrylic acid" "(e)-2-butenoic acid" "crotonic acid, (e)-" "alpha-butenoic acid" "alpha-crotonic acid" "solid crotonic acid" );
standardThermochemistry
{
    dHf_298   -358940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-280890.0
}
