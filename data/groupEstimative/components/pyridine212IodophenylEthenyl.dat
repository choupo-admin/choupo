/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridine,2-(1-(2-iodophenyl))ethenyl-  (C13H10IN, CAS 74309-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridine212IodophenylEthenyl;
formula     C13H10IN;
CAS         74309-57-2;
InChIKey    MLPQTSJYPKZDLN-UHFFFAOYSA-N;
MW          307.13;      // g/mol [origin=calculated method=formula-sum]
Tc          992.43;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.5184;      // -   [origin=predictive method=lee-kesler]
Tb          698.78;      // K   [origin=predictive method=joback]
HvapTb      64739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.37 1.07416 -0.00079462 2.305e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group C5H4N; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group I; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(2-iodanylphenyl)ethenyl]pyridine" "2-[1-(2-iodophenyl)ethenyl]pyridine" "pyridine, 2-(1-(2-iodophenyl))ethenyl-" "(z)-pyridine, 2-(2-(2-iodophenyl)ethenyl-" );
standardThermochemistry
{
    dHf_298   375240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=488230.0
}
