/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 7138  (C18H14O2, CAS 5836-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris7138;
formula     C18H14O2;
CAS         5836-85-1;
InChIKey    NGXQHSGMHCOILD-UHFFFAOYSA-N;
MW          262.308;      // g/mol [origin=calculated method=formula-sum]
Tc          1054.48;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       0.8882;      // -   [origin=predictive method=lee-kesler]
Tb          797.65;      // K   [origin=predictive method=joback]
HvapTb      70745.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.32 1.33542 -0.00091248 2.508e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 6; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 7; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-methoxy-15,16-dihydrocyclopenta[a]phenanthren-17-one" "15,16-dihydro-11-methoxycyclopenta(a)phenanthren-17-one" "11-n-butoxy-15,16-dihydrocyclopenta(a)phenanthrene-17-one" "cyclopenta(a)phenanthren-17-one, 11-methoxy-15,16-dihydro-" "cyclopenta(a)phenanthren-17-one, 15,16-dihydro-11-methoxy-" "15,16-dihydro-11-methoxy-17h-cyclopenta(a)phenanthren-17-one" );
standardThermochemistry
{
    dHf_298   -18840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=228740.0
}
