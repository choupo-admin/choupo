/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene glycol succinate  (C6H12O6, CAS 25569-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneGlycolSuccinate;
formula     C6H12O6;
CAS         25569-53-3;
InChIKey    VJVOPINBJQWMNY-UHFFFAOYSA-N;
MW          180.156;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.62;      // K   [origin=predictive method=joback]
Pc          43.283;      // bar [origin=predictive method=joback]
omega       2.0733;      // -   [origin=predictive method=lee-kesler]
Tb          813.66;      // K   [origin=predictive method=joback]
HvapTb      96930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.034 0.5372 -9.38e-05 -8.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group COOH; count 2; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanedioic acid;ethane-1,2-diol" "succinic acid ethyleneglycol polymer" "butanedioic acid, polymer with 1,2-ethanediol" "poly(ethylene glycol succinate)" "poly(ethylene succinate)" "butanedioic acid; ethane-1,2-diol" "butanedioicacid,polymerwith1,2-ethanediol;ethylene glycol succinate polyester;poly(ethylene succinate);poly(ethylene glycol succinate);succinate ethylene glycol polyester;ethylene glycol succinate, for gc;poly(ethylene glycol succinate) [liquid phase for gc];ethylene succinate homopolymer" );
standardThermochemistry
{
    dHf_298   -1283790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     705.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1066580.0
}
