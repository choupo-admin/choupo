/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexaneacetic acid, 1-hydroxy-3,3,5-trimethyl-, tert-butyl ester  (C15H28O3, CAS 13278-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexaneaceticAcid1Hydroxy335TrimethylTertButylEster;
formula     C15H28O3;
CAS         13278-11-0;
InChIKey    WIVAYTMSEUPIAP-UHFFFAOYSA-N;
MW          256.386;      // g/mol [origin=calculated method=formula-sum]
Tc          901.74;      // K   [origin=predictive method=joback]
Pc          18.692;      // bar [origin=predictive method=joback]
omega       0.9414;      // -   [origin=predictive method=lee-kesler]
Tb          700.66;      // K   [origin=predictive method=joback]
HvapTb      69283.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.229 2.18682 -0.0019352 7.411e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 1; } { group C; count 3; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl 2-(3,3,5-trimethyl-1-oxidanyl-cyclohexyl)ethanoate" "tert-butyl 2-(1-hydroxy-3,3,5-trimethylcyclohexyl)acetate" "tert-butyl 2-(1-hydroxy-3,3,5-trimethyl-cyclohexyl)acetate" "cyclohexaneacetic acid,1-hydroxy-3,3,5-trimethyl-, 1,1-dimethylethyl ester" "cyclohexaneaceticacid, 1-hydroxy-3,3,5-trimethyl-, tert-butyl ester (7ci,8ci)" );
gibbsFormation
{
    dHf_298   -787070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     827.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-370880.0
    phase     gas;
}
