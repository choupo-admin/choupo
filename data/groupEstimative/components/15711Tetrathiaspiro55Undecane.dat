/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5,7,11-tetrathiaspiro[5.5]undecane  (C7H12S4, CAS 180-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15711Tetrathiaspiro55Undecane;
formula     C7H12S4;
CAS         180-97-2;
InChIKey    LZGXFMIPVMFXAQ-UHFFFAOYSA-N;
MW          224.413;      // g/mol [origin=calculated method=formula-sum]
Tc          911.57;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       0.3053;      // -   [origin=predictive method=lee-kesler]
Tb          590.82;      // K   [origin=predictive method=joback]
HvapTb      54268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.21 1.29864 -0.0012282 4.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group CH2S; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } { group S_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5,7,11-tetrathiaspiro(5.5)undecane" "1,5,7,11-tetrathiaspiro[5.5]undecan" );
standardThermochemistry
{
    dHf_298   143610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230720.0
}
