/*--------------------------------*- Choupo -*-----------------------*\
  Component: anthracene, 9,10-bis-methylene-  (C16H12, CAS 3302-51-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anthracene910BisMethylene;
formula     C16H12;
CAS         3302-51-0;
InChIKey    KKKIADYJUWHVJH-UHFFFAOYSA-N;
MW          204.272;      // g/mol [origin=calculated method=formula-sum]
Tc          879.20;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.5830;      // -   [origin=predictive method=lee-kesler]
Tb          634.46;      // K   [origin=predictive method=joback]
HvapTb      57454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.35 1.199 -0.00091212 2.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 2; } { group ACH; count 8; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-dimethylideneanthracene" "anthracene,9,10-dihydro-9,10-bis(methylene)-" );
standardThermochemistry
{
    dHf_298   344330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=476120.0
}
