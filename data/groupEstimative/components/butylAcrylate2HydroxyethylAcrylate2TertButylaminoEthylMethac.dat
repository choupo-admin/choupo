/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl acrylate, 2-hydroxyethyl acrylate, 2-(tert-butylamino)ethyl methacrylate, methyl methacrylate polymer  (C27H47NO9, CAS 57635-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylAcrylate2HydroxyethylAcrylate2TertButylaminoEthylMethac;
formula     C27H47NO9;
CAS         57635-61-7;
InChIKey    QDYQPSOFWHXFOR-UHFFFAOYSA-N;
MW          529.671;      // g/mol [origin=calculated method=formula-sum]
Tc          1483.19;      // K   [origin=predictive method=joback]
Pc          7.104;      // bar [origin=predictive method=joback]
omega       0.4310;      // -   [origin=predictive method=lee-kesler]
Tb          1180.04;      // K   [origin=predictive method=joback]
HvapTb      125505.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (170.697 1.88694 -0.0001692 -4.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 6; } { group C; count 1; } { group CH2=CH; count 2; } { group CH2=C; count 2; } { group OH; count 1; } { group CH2NH; count 1; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 7; } { group C; count 1; } { group dCH2; count 4; } { group dCH; count 2; } { group dC; count 2; } { group OH; count 1; } { group COO; count 4; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(tert-butylamino)ethyl 2-methylprop-2-enoate;butyl prop-2-enoate;2-hydroxyethyl prop-2-enoate;methyl 2-methylprop-2-enoate" "2-(tert-butylamino)ethyl 2-methylprop-2-enoate; butyl prop-2-enoate; 2-hydroxyethyl prop-2-enoate; methyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-((1,1-dimethylethyl)amino)ethyl ester, polymer with butyl 2-propenoate, 2-hydroxyethyl 2-propenoate and methyl 2-methyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -1829960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1761.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1089630.0
}
