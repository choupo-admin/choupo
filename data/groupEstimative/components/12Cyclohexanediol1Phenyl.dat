/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-cyclohexanediol, 1-phenyl-  (C12H16O2, CAS 27167-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Cyclohexanediol1Phenyl;
formula     C12H16O2;
CAS         27167-34-6;
InChIKey    QHNHEYDAIICUDL-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          912.76;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       1.2773;      // -   [origin=predictive method=lee-kesler]
Tb          700.32;      // K   [origin=predictive method=joback]
HvapTb      76909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.0 1.5204 -0.0012792 4.561e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylcyclohexane-1,2-diol" "1-phenyl-trans-1,2-cyclohexanediol" "1,2-cyclohexanediol, 1-phenyl-, trans-" "(1r,2s)-1-phenylcyclohexane-1,2-diol" "cis-1-phenyl-1,2-cyclohexanediol" "1-phenylcyclohexane-1,2-diol cis-" "1,2-cyclohexanediol, 1-phenyl-, cis-" );
gibbsFormation
{
    dHf_298   -309720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99820.0
    phase     gas;
}
