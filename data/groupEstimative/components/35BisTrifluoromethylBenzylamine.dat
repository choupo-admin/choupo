/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-bis(trifluoromethyl)benzylamine  (C9H7F6N, CAS 85068-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35BisTrifluoromethylBenzylamine;
formula     C9H7F6N;
CAS         85068-29-7;
InChIKey    DHVHORCFFOSRBP-UHFFFAOYSA-N;
MW          243.15;      // g/mol [origin=calculated method=formula-sum]
Tc          688.64;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       0.6657;      // -   [origin=predictive method=lee-kesler]
Tb          503.85;      // K   [origin=predictive method=joback]
HvapTb      42375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.509 1.0452 -0.00084832 2.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH2NH2; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,5-bis(trifluoromethyl)phenyl]methanamine" "3,5-di(trifluoromethyl)benzylamine" "(3,5-bis(trifluoromethyl)phenyl)methanamine" "mbt-bym" "3,5-ditrifluoromethylbenzylamine" "3, 5-bis(trifluoromethyl)benzylamine" "[3,5-bis(trifluoromethyl)phenyl]methylamine" "3,5-bis-trifluoromethyl-benzylamine" "3,5-bis(trifluoromethyl) benzylamine" "3,5-bis(trifluoromethyl)benzyl amine" "i674" "benzenemethanamine,3,5-bis(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -1175870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-978680.0
}
