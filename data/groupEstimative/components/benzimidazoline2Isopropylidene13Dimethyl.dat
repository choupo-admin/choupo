/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzimidazoline,2-isopropylidene-1,3-dimethyl-  (C12H16N2, CAS 143268-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzimidazoline2Isopropylidene13Dimethyl;
formula     C12H16N2;
CAS         143268-49-9;
InChIKey    QJFVNVGUTOOLOA-UHFFFAOYSA-N;
MW          188.274;      // g/mol [origin=calculated method=formula-sum]
Tc          746.14;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.6199;      // -   [origin=predictive method=lee-kesler]
Tb          540.09;      // K   [origin=predictive method=joback]
HvapTb      50075.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.54 1.37228 -0.00115756 3.97e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethyl-2-propan-2-ylidene-benzimidazole" "1,3-dimethyl-2-propan-2-ylidenebenzimidazole" );
gibbsFormation
{
    dHf_298   240810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=504070.0
    phase     gas;
}
