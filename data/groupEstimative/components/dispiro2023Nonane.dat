/*--------------------------------*- Choupo -*-----------------------*\
  Component: dispiro(2.0.2.3)nonane  (C9H14, CAS 24973-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dispiro2023Nonane;
formula     C9H14;
CAS         24973-90-8;
InChIKey    LEWHVRINFUSXMT-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          659.35;      // K   [origin=predictive method=joback]
Pc          40.621;      // bar [origin=predictive method=joback]
omega       0.2847;      // -   [origin=predictive method=lee-kesler]
Tb          430.89;      // K   [origin=predictive method=joback]
HvapTb      33374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-261.94 1.9218 -0.002247 1.018e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dispiro[2.0.2^{4}.3^{3}]nonane" "dispiro[2.0.2.3]nonane" "dispiro[2.0.2.3]nonane(8ci,9ci)" );
standardThermochemistry
{
    dHf_298   40130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203880.0
}
