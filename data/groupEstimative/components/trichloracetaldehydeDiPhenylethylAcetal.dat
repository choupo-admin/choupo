/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichloracetaldehyde di(phenylethyl)acetal  (C18H19Cl3O2, CAS 68171-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichloracetaldehydeDiPhenylethylAcetal;
formula     C18H19Cl3O2;
CAS         68171-30-2;
InChIKey    LMQHAMIDZPBQNY-UHFFFAOYSA-N;
MW          373.698;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.87;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       0.8483;      // -   [origin=predictive method=lee-kesler]
Tb          818.26;      // K   [origin=predictive method=joback]
HvapTb      76505.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.766 1.5817 -0.001032 2.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH2O; count 2; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Cl; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,2,2-tris(chloranyl)-1-(2-phenylethoxy)ethoxy]ethylbenzene" "1,1'-[(2,2,2-trichloroethylidene)bis(oxyethylene)]dibenzene" "1,1'-((2,2,2-trichloroethylidene)bis(oxyethylene))dibenzene" "benzene, 1,1'-((2,2,2-trichloroethylidene)bis(oxy-2,1-ethanediyl))bis-" "benzene, 1,1'-[(2,2,2-trichloroethylidene)bis(oxy-2,1-ethanediyl)]bis-" "2-(2,2,2-trichloro-1-phenethyloxyethoxy)ethylbenzene" );
gibbsFormation
{
    dHf_298   -267480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80110.0
    phase     gas;
}
