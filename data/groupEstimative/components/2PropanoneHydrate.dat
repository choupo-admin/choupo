/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanone, hydrate  (C3H8O2, CAS 18879-06-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H8O2 (delta H+2O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2PropanoneHydrate;
formula     C3H8O2;
CAS         18879-06-6;
InChIKey    OVARTBFNCCXQKS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          76.095;      // g/mol [origin=calculated method=formula-sum]
Tc          500.56;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.2417;      // -   [origin=predictive method=lee-kesler]
Tb          322.11;      // K   [origin=predictive method=joback]
HvapTb      29018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.52 0.26084 -0.0001207 1.546e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group H2O; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-one;hydrate" "2-propanone, monohydrate" "agn-pc-01v0xn" );
standardThermochemistry
{
    dHf_298   -217830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154540.0
}
