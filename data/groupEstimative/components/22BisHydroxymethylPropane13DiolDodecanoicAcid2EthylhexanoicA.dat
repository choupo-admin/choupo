/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)propane-1,3-diol; dodecanoic acid; 2-ethylhexanoic acid  (C25H52O8, CAS 70693-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylPropane13DiolDodecanoicAcid2EthylhexanoicA;
formula     C25H52O8;
CAS         70693-35-5;
InChIKey    CEQSIPAEUGWOTF-UHFFFAOYSA-N;
MW          480.683;      // g/mol [origin=calculated method=formula-sum]
Tc          2121.89;      // K   [origin=predictive method=joback]
Pc          9.639;      // bar [origin=predictive method=joback]
omega       -0.1274;      // -   [origin=predictive method=lee-kesler]
Tb          1430.47;      // K   [origin=predictive method=joback]
HvapTb      171192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.008 2.33576 -0.0009484 1.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } { group C; count 1; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol;dodecanoic acid;2-ethylhexanoic acid" "pentaerythritol 2-ethylhexanoate laurate" "pentaerythritol, esters with lauric acid and 2-ethylhexoic acid" "dodecanoic acid, mixed esters with 2-ethylhexanoic acid and pentaerythritol" );
gibbsFormation
{
    dHf_298   -2106060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1606.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1284600.0
    phase     gas;
}
