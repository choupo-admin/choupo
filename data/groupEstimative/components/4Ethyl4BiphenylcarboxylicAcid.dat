/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-ethyl-4-biphenylcarboxylic acid  (C15H14O2, CAS 5731-13-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethyl4BiphenylcarboxylicAcid;
formula     C15H14O2;
CAS         5731-13-5;
InChIKey    SCEBDBNGUCNRCE-UHFFFAOYSA-N;
MW          226.275;      // g/mol [origin=calculated method=formula-sum]
Tc          994.88;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.9189;      // -   [origin=predictive method=lee-kesler]
Tb          751.63;      // K   [origin=predictive method=joback]
HvapTb      72024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.359 1.20282 -0.00079312 1.965e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-ethylphenyl)benzoic acid" "4-ethylbiphenyl-4'-carboxylic acid" "4'-ethyl-[1,1'-biphenyl]-4-carboxylic acid" "4'-ethyl-biphenyl-4-carboxylic acid" "4'-ethyl 4-biphenyl carboxylic acid" "[1,1'-biphenyl]-4-carboxylicacid, 4'-ethyl-" "4 inverted exclamation marka-ethyl-4-biphenylcarboxylic acid" "4-biphenylcarboxylicacid, 4'-ethyl- (7ci,8ci);4-(4-ethylphenyl)benzoic acid;4-ethylbiphenyl-4'-carboxylic acid;4'-ethyl-1,1'-biphenyl-4-carboxylic acid;4'-ethyl-4-biphenylcarboxylic acid;" );
standardThermochemistry
{
    dHf_298   -253080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62930.0
}
