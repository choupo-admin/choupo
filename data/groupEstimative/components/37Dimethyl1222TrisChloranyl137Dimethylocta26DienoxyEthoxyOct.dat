/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyl-1-[2,2,2-tris(chloranyl)-1-(3,7-dimethylocta-2,6-dienoxy)ethoxy]octa-2,6-diene  (C22H35Cl3O2, CAS 68140-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyl1222TrisChloranyl137Dimethylocta26DienoxyEthoxyOct;
formula     C22H35Cl3O2;
CAS         68140-44-3;
InChIKey    GHZZIFJPGVHZTE-UHFFFAOYSA-N;
MW          437.87;      // g/mol [origin=calculated method=formula-sum]
Tc          1080.97;      // K   [origin=predictive method=joback]
Pc          9.645;      // bar [origin=predictive method=joback]
omega       0.8082;      // -   [origin=predictive method=lee-kesler]
Tb          872.58;      // K   [origin=predictive method=joback]
HvapTb      81009.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.084 2.19922 -0.0015316 4.362e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 4; } { group CH2O; count 2; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group dCH; count 4; } { group dC; count 4; } { group Cl; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -393380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1044.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175650.0
}
