/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-5-chloropentane  (C5H10BrCl, CAS 54512-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo5Chloropentane;
formula     C5H10BrCl;
CAS         54512-75-3;
InChIKey    PHHNNDKXQVKJEP-UHFFFAOYSA-N;
MW          185.489;      // g/mol [origin=calculated method=formula-sum]
Tc          610.36;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.4342;      // -   [origin=predictive method=lee-kesler]
Tb          417.59;      // K   [origin=predictive method=joback]
HvapTb      37544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.425 0.5238 -0.00034 9.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2Cl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-5-chloranyl-pentane" "pentane, 1-bromo-5-chloro-" "1-brom-5-chlorpentan" "5-chloropentyl bromide" "5-bromopentyl chloride" "pentane, 1-bromo-5-chloro-;1-bromo-5-chloro-pentan;(1-bromo-5-chloropentane);" );
standardThermochemistry
{
    dHf_298   -135940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6390.0
}
