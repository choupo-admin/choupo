/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-o-[(2r)-3-(1,1-dihydroxyethoxy)-2-hydroxypropyl] 1-o-octadecyl benzene-1,2-dicarboxylate  (C31H52O8, CAS 73049-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2O2r311Dihydroxyethoxy2Hydroxypropyl1OOctadecylBenzene12Dica;
formula     C31H52O8;
CAS         73049-89-5;
InChIKey    OBQZUEOMIZDDJR-SANMLTNESA-N;
MW          552.749;      // g/mol [origin=calculated method=formula-sum]
Tc          1900.75;      // K   [origin=predictive method=joback]
Pc          7.794;      // bar [origin=predictive method=joback]
omega       -0.0655;      // -   [origin=predictive method=lee-kesler]
Tb          1352.27;      // K   [origin=predictive method=joback]
HvapTb      153115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.139 2.87134 -0.00159276 2.901e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group COO; count 2; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 3; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-[(2r)-3-[1,1-bis(oxidanyl)ethoxy]-2-oxidanyl-propyl] o1-octadecyl benzene-1,2-dicarboxylate" );
gibbsFormation
{
    dHf_298   -1695610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1469.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-822880.0
    phase     gas;
}
