/*--------------------------------*- Choupo -*-----------------------*\
  Component: botryodiplodin  (C7H12O3, CAS 113531-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        botryodiplodin;
formula     C7H12O3;
CAS         113531-94-5;
InChIKey    CLYSZQBIUYRLNX-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          732.80;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.8924;      // -   [origin=predictive method=lee-kesler]
Tb          538.70;      // K   [origin=predictive method=joback]
HvapTb      58750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.11 0.75054 -0.0003714 4.726e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 3; } { group OH; count 1; } { group CH3CO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group OH; count 1; } { group O_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methyl-5-oxidanyl-oxolan-3-yl)ethanone" "cytostipin" "antibiotic psx 1" "ethanone, 1-(tetrahydro-5-hydroxy-4-methyl-3-furanyl)-" "2-hydroxy-3-methyl-4-acetyltetrahydrofuran" "2-hydroxy-3-methyl-4-acetyltetrahydrofurane" "methyltetrahydro-5-hydroxy-4-methyl-3-furyl-ketone" "1-(tetrahydro-5-hydroxy-4-methyl-3-furanyl)ethanone" "ketone, methyl tetrahydro-5-hydroxy-4-methyl-3-furyl" "botrydiplodin" "botryodipolodin" "botyrodiplodin" );
standardThermochemistry
{
    dHf_298   -564820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-322670.0
}
