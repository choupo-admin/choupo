/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylvinylbis(2-methoxyethoxy)silane  (C9H20O4Si, CAS 45117-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H20O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methylvinylbis2MethoxyethoxySilane;
formula     C9H20O4Si;
CAS         45117-69-9;
InChIKey    INWVHJGPNCHXOO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          220.34;      // g/mol [origin=calculated method=formula-sum]
Tc          664.65;      // K   [origin=predictive method=joback]
Pc          20.145;      // bar [origin=predictive method=joback]
omega       0.6210;      // -   [origin=predictive method=lee-kesler]
Tb          493.28;      // K   [origin=predictive method=joback]
HvapTb      44892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (134.534 0.37986 0.0003701 -3.231e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH3O; count 2; } { group CH2O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl-bis(2-methoxyethoxy)-methyl-silane" "6-methyl-6-vinyl-2,5,7,10-tetraoxa-6-silaundecane" "2,5,7,10-tetraoxa-6-silaundecane, 6-ethenyl-6-methyl-" "ethenyl-bis(2-methoxyethoxy)-methylsilane" );
standardThermochemistry
{
    dHf_298   -744160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-412020.0
}
