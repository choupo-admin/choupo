/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyloctacosane  (C29H60, CAS 1560-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyloctacosane;
formula     C29H60;
CAS         1560-98-1;
InChIKey    YGCGPCUUTAKOEU-UHFFFAOYSA-N;
MW          408.799;      // g/mol [origin=calculated method=formula-sum]
Tc          1059.24;      // K   [origin=predictive method=joback]
Pc          6.269;      // bar [origin=predictive method=joback]
omega       0.5172;      // -   [origin=predictive method=lee-kesler]
Tb          862.68;      // K   [origin=predictive method=joback]
HvapTb      79760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.155 2.76476 -0.001557 3.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 25; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 25; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octacosane, 2-methyl-" "isononacosane" );
gibbsFormation
{
    dHf_298   -647170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1276.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190860.0
    phase     gas;
}
