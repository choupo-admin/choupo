/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorobenzyl isocyanate  (C8H6FNO, CAS 132740-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4FluorobenzylIsocyanate;
formula     C8H6FNO;
CAS         132740-43-3;
InChIKey    HHSIWJYERNCLKQ-UHFFFAOYSA-N;
MW          151.14;      // g/mol [origin=calculated method=formula-sum]
Tc          690.78;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.5269;      // -   [origin=predictive method=lee-kesler]
Tb          480.24;      // K   [origin=predictive method=joback]
HvapTb      45055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH2; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-4-(isocyanatomethyl)benzene" "1-fluoro-4-(isocyanatomethyl)benzene" "(4-fluorophenyl)methanisocyanate" "benzene,1-fluoro-4-(isocyanatomethyl)-" "1-fluoro-4-isocyanatomethylbenzene;4-fluorobenzyl isocyanate;4-fluorophenylmethyl isocyanate;p-fluorobenzylisocyanate;" );
// formation datum unavailable (element entropy missing): dHf_298=-184910.0 dGf_298=None
