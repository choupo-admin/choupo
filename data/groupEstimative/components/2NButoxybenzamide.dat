/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-n-butoxybenzamide  (C11H15NO2, CAS 60444-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NButoxybenzamide;
formula     C11H15NO2;
CAS         60444-92-0;
InChIKey    VPTQXJGFCHOGAN-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          849.99;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.8364;      // -   [origin=predictive method=lee-kesler]
Tb          631.76;      // K   [origin=predictive method=joback]
HvapTb      62815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.633 0.88112 -0.00045246 6.746e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxybenzamide" "o-butoxybenzamide" "benzamide, o-butoxy-" );
standardThermochemistry
{
    dHf_298   -256320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22950.0
}
