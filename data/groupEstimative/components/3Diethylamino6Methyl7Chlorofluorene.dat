/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-diethylamino-6-methyl-7-chlorofluorene  (C18H20ClN, CAS 68528-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Diethylamino6Methyl7Chlorofluorene;
formula     C18H20ClN;
CAS         68528-00-7;
InChIKey    HJJJOCOYMMBYNN-UHFFFAOYSA-N;
MW          285.815;      // g/mol [origin=calculated method=formula-sum]
Tc          968.39;      // K   [origin=predictive method=joback]
Pc          19.153;      // bar [origin=predictive method=joback]
omega       0.8374;      // -   [origin=predictive method=lee-kesler]
Tb          742.44;      // K   [origin=predictive method=joback]
HvapTb      69830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.528 1.58586 -0.001184 3.632e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-chloranyl-n,n-diethyl-6-methyl-9h-fluoren-3-amine" "7-chloro-n,n-diethyl-6-methyl-9h-fluoren-3-amine" "9h-fluoren-3-amine, 7-chloro-n,n-diethyl-6-methyl-" );
standardThermochemistry
{
    dHf_298   158110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=468860.0
}
