/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-(2-ethoxyethoxy)benzene  (C10H13BrO2, CAS 39255-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo42EthoxyethoxyBenzene;
formula     C10H13BrO2;
CAS         39255-20-4;
InChIKey    QACZJJNHOATNHA-UHFFFAOYSA-N;
MW          245.116;      // g/mol [origin=calculated method=formula-sum]
Tc          787.94;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.6729;      // -   [origin=predictive method=lee-kesler]
Tb          571.06;      // K   [origin=predictive method=joback]
HvapTb      52047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.383 0.72722 -0.00033376 3.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-(2-ethoxyethoxy)benzene" "agn-pc-03iuow" "benzene,1-bromo-4-(2-ethoxyethoxy)-" "benzene, 1-bromo-4-(2-ethoxyethoxy)-" "1-bromo-4-(2-ethoxyethoxy)benzene;p-(2-ethoxyethoxy)bromobenzene" );
gibbsFormation
{
    dHf_298   -262780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59580.0
    phase     gas;
}
