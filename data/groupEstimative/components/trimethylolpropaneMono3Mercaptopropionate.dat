/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane mono(3-mercaptopropionate)  (C9H18O4S, CAS 67905-23-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneMono3Mercaptopropionate;
formula     C9H18O4S;
CAS         67905-23-1;
InChIKey    QBVJQXFEWRDCBR-UHFFFAOYSA-N;
MW          222.299;      // g/mol [origin=calculated method=formula-sum]
Tc          890.64;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       1.5578;      // -   [origin=predictive method=lee-kesler]
Tb          707.73;      // K   [origin=predictive method=joback]
HvapTb      81834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.116 1.02512 -0.0006262 1.359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group OH; count 2; } { group CH2COO; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group OH; count 2; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)butyl 3-sulfanylpropanoate" "2,2-bis(hydroxymethyl)butyl 3-mercaptopropionate" "propanoic acid, 3-mercapto-, 2,2-bis(hydroxymethyl)butyl ester" );
standardThermochemistry
{
    dHf_298   -821100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-526880.0
}
