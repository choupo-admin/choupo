/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopentyl-6-methylcyclohexanol  (C12H22O, CAS 72987-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopentyl6Methylcyclohexanol;
formula     C12H22O;
CAS         72987-61-2;
InChIKey    JMAQPZWRUIHRQH-UHFFFAOYSA-N;
MW          182.307;      // g/mol [origin=calculated method=formula-sum]
Tc          798.79;      // K   [origin=predictive method=joback]
Pc          26.057;      // bar [origin=predictive method=joback]
omega       0.7518;      // -   [origin=predictive method=lee-kesler]
Tb          591.83;      // K   [origin=predictive method=joback]
HvapTb      59053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.94 1.37862 -0.000757 1.341e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 4; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclopentyl-6-methyl-cyclohexan-1-ol" "cyclohexanol, 2-cyclopentyl-6-methyl-" "2-cyclopentyl-6-methylcyclohexan-1-ol" );
standardThermochemistry
{
    dHf_298   -369120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41080.0
}
