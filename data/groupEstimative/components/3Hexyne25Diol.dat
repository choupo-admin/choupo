/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexyne-2,5-diol  (C6H10O2, CAS 3031-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexyne25Diol;
formula     C6H10O2;
CAS         3031-66-1;
InChIKey    KDOWHHULNTXTNS-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          711.23;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       1.1375;      // -   [origin=predictive method=lee-kesler]
Tb          529.36;      // K   [origin=predictive method=joback]
HvapTb      63684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.21 0.50384 -0.00027766 5.778e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group OH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group tC; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-3-yne-2,5-diol" "hexyne-3-diol-2,5" "3-hexyne-3,5-diol" "3-hexyn-2,5-diol" "bis(1-hydroxyethyl)acetylene" );
gibbsFormation
{
    dHf_298   -209890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76080.0
    phase     gas;
}
