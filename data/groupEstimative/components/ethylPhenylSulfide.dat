/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl phenyl sulfide  (C8H10S, CAS 622-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylPhenylSulfide;
formula     C8H10S;
CAS         622-38-8;
InChIKey    AEHWKBXBXYNPCX-UHFFFAOYSA-N;
MW          138.228;      // g/mol [origin=calculated method=formula-sum]
Tc          712.89;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.3577;      // -   [origin=predictive method=lee-kesler]
Tb          478.10;      // K   [origin=predictive method=joback]
HvapTb      42495.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.689 0.67931 -0.0004024 8.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethylsulfanylbenzene" "(ethylthio)benzene" "benzene, (ethylthio)-" "ethylthiobenzene" "sulfide, ethyl phenyl" "thiophenetole" "phenylethyl sulfide" "(phenylthio)ethane" "phenyl ethyl sulfide" "(ethylsulfanyl)benzene" "(1-thiapropyl)benzene" "ethylphenylsulfide" );
gibbsFormation
{
    dHf_298   69950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162010.0
    phase     gas;
}
