/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-undecyloxybenzoic acid  (C18H28O3, CAS 15872-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4UndecyloxybenzoicAcid;
formula     C18H28O3;
CAS         15872-44-3;
InChIKey    NEJZHJHZOUISSH-UHFFFAOYSA-N;
MW          292.419;      // g/mol [origin=calculated method=formula-sum]
Tc          1011.39;      // K   [origin=predictive method=joback]
Pc          15.283;      // bar [origin=predictive method=joback]
omega       1.1201;      // -   [origin=predictive method=lee-kesler]
Tb          811.03;      // K   [origin=predictive method=joback]
HvapTb      78174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.98 1.56302 -0.00088116 1.768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-undecoxybenzoic acid" "4-(undecyloxy)benzoic acid" "p-undecyloxybenzoic acid" "4-n-undecyloxybenzoic acid" "benzoic acid,4-(undecyloxy)-" "4-(undecyloxy)benzoic acid;benzoicacid, p-(undecyloxy)- (8ci);" );
gibbsFormation
{
    dHf_298   -672280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     808.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245450.0
    phase     gas;
}
