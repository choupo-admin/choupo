/*--------------------------------*- Choupo -*-----------------------*\
  Component: monomethacryloxyisopropyl phthalate  (C15H16O6, CAS 65859-45-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monomethacryloxyisopropylPhthalate;
formula     C15H16O6;
CAS         65859-45-2;
InChIKey    HQYSAIKKBLWFBW-UHFFFAOYSA-N;
MW          292.287;      // g/mol [origin=calculated method=formula-sum]
Tc          1051.93;      // K   [origin=predictive method=joback]
Pc          20.888;      // bar [origin=predictive method=joback]
omega       1.2147;      // -   [origin=predictive method=lee-kesler]
Tb          832.53;      // K   [origin=predictive method=joback]
HvapTb      82922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.701 1.21744 -0.00066816 1.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(2-methylprop-2-enoyloxy)propan-2-yloxycarbonyl]benzoic acid" "1-methyl-2-((2-methyl-1-oxoallyl)oxy)ethyl hydrogen phthalate" "2-({[1-(methacryloyloxy)propan-2-yl]oxy}carbonyl)benzoic acid" "methacryloxyisopropyl acid phthalate" "1,2-benzenedicarboxylic acid, 1-(1-methyl-2-((2-methyl-1-oxo-2-propen-1-yl)oxy)ethyl) ester" "1,2-benzenedicarboxylic acid, 1-[1-methyl-2-[(2-methyl-1-oxo-2-propen-1-yl)oxy]ethyl] ester" "2-[({1-[(2-methylacryloyl)oxy]propan-2-yl}oxy)carbonyl]benzoic acid" "2-[1-(2-methyl-1-oxoprop-2-enoxy)propan-2-yloxy-oxomethyl]benzoic acid" "1,2-benzenedicarboxylic acid, mono(1-methyl-2-((2-methyl-1-oxo-2-propenyl)oxy)ethyl) ester" );
standardThermochemistry
{
    dHf_298   -1002340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     765.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-709600.0
}
