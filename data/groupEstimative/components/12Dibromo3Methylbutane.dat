/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromo-3-methylbutane  (C5H10Br2, CAS 10288-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromo3Methylbutane;
formula     C5H10Br2;
CAS         10288-13-8;
InChIKey    XCVOFNNXLRFMGX-UHFFFAOYSA-N;
MW          229.943;      // g/mol [origin=calculated method=formula-sum]
Tc          659.49;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.4331;      // -   [origin=predictive method=lee-kesler]
Tb          445.44;      // K   [origin=predictive method=joback]
HvapTb      38818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.361 0.56704 -0.0003974 1.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-3-methyl-butane" "butane, 1,2-dibromo-3-methyl-" );
gibbsFormation
{
    dHf_298   -104430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14980.0
    phase     gas;
}
