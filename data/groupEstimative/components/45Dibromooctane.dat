/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-dibromooctane  (C8H16Br2, CAS 61539-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45Dibromooctane;
formula     C8H16Br2;
CAS         61539-75-1;
InChIKey    UTHOIMRNKWYBCT-UHFFFAOYSA-N;
MW          272.024;      // g/mol [origin=calculated method=formula-sum]
Tc          719.14;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.5846;      // -   [origin=predictive method=lee-kesler]
Tb          514.08;      // K   [origin=predictive method=joback]
HvapTb      45496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.634 0.85204 -0.0005606 1.512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-bis(bromanyl)octane" "octane, 4,5-dibromo-" );
gibbsFormation
{
    dHf_298   -166350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40240.0
    phase     gas;
}
