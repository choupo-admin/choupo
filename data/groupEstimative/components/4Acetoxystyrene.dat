/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-acetoxystyrene  (C10H10O2, CAS 2628-16-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Acetoxystyrene;
formula     C10H10O2;
CAS         2628-16-2;
InChIKey    JAMNSIXSLVPNLC-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          730.67;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.5127;      // -   [origin=predictive method=lee-kesler]
Tb          514.96;      // K   [origin=predictive method=joback]
HvapTb      47529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.39 0.74062 -0.00041266 6.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-ethenylphenyl) ethanoate" "4-vinylphenyl acetate" "4-ethenylphenol acetate" "p-acetoxystyrene" "phenol, 4-ethenyl-, acetate" "p-vinylphenol acetate" "acetic acid 4-vinylphenyl ester" "phenol, 4-ethenyl-, 1-acetate" "phenol, p-vinyl-, acetate (6ci,7ci,8ci)" "4-ethenylphenyl acetate" "4-acetoxystyrene monomer" "(4-ethenylphenyl) acetate" );
gibbsFormation
{
    dHf_298   -216520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86430.0
    phase     gas;
}
