/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0763988  (C20H24N2O4, CAS 17766-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0763988;
formula     C20H24N2O4;
CAS         17766-63-1;
InChIKey    TYBAPDCCMCKUPD-UHFFFAOYSA-N;
MW          356.422;      // g/mol [origin=calculated method=formula-sum]
Tc          1116.56;      // K   [origin=predictive method=joback]
Pc          18.499;      // bar [origin=predictive method=joback]
omega       1.1668;      // -   [origin=predictive method=lee-kesler]
Tb          887.19;      // K   [origin=predictive method=joback]
HvapTb      85108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.03 1.76556 -0.00102818 2.0206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 7; } { group AC; count 5; } { group CH3O; count 3; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group O; count 3; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-phenylpiperazin-1-yl)-(3,4,5-trimethoxyphenyl)methanone" "4-phenylpiperazinyl 3,4,5-trimethoxyphenyl ketone" "piperazine, 1-phenyl-4-(3,4,5-trimethoxybenzoyl)-" "ketone, 4-phenylpiperazinyl 3,4,5-trimethoxyphenyl" "(4-phenylpiperazin-1-yl)(3,4,5-trimethoxyphenyl)methanone" "(4-phenyl-piperazin-1-yl)-(3,4,5-trimethoxy-phenyl)-methanone" );
standardThermochemistry
{
    dHf_298   -304680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     768.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147450.0
}
