/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2-tribromopropane  (C3H5Br3, CAS 14602-62-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Tribromopropane;
formula     C3H5Br3;
CAS         14602-62-1;
InChIKey    ZLOLQHBVMYXNHX-UHFFFAOYSA-N;
MW          280.785;      // g/mol [origin=calculated method=formula-sum]
Tc          705.57;      // K   [origin=predictive method=joback]
Pc          60.750;      // bar [origin=predictive method=joback]
omega       0.4639;      // -   [origin=predictive method=lee-kesler]
Tb          465.84;      // K   [origin=predictive method=joback]
HvapTb      40801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.37 0.41522 -0.00036 1.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 2; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2-tris(bromanyl)propane" "propane, 1,1,2-tribromo-" );
gibbsFormation
{
    dHf_298   -36820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12460.0
    phase     gas;
}
