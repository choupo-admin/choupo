/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(chloromethyl)-3-ethyloxetane  (C6H11ClO, CAS 2177-22-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloromethyl3Ethyloxetane;
formula     C6H11ClO;
CAS         2177-22-2;
InChIKey    UKLWXKWTXHHMFK-UHFFFAOYSA-N;
MW          134.603;      // g/mol [origin=calculated method=formula-sum]
Tc          617.78;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.3385;      // -   [origin=predictive method=lee-kesler]
Tb          412.51;      // K   [origin=predictive method=joback]
HvapTb      36779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.708 1.01082 -0.0010155 4.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group Cl; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(chloromethyl)-3-ethyl-oxetane" "oxetane, 3-(chloromethyl)-3-ethyl-" "3-ethyl-3-(chloromethyl)-oxetane" "oxetane,3-(chloromethyl)-3-ethyl-" "3-(chloromethyl)-3-ethyloxetane;3-ethyl-3-(chloromethyl)oxacyclobutane; 3-ethyl-3-(chloromethyl)oxetane" );
standardThermochemistry
{
    dHf_298   -233030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55250.0
}
