/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-6-methoxyphenol  (C7H7FO2, CAS 73943-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro6Methoxyphenol;
formula     C7H7FO2;
CAS         73943-41-6;
InChIKey    YZNHPLVFLRSVHY-UHFFFAOYSA-N;
MW          142.129;      // g/mol [origin=calculated method=formula-sum]
Tc          710.40;      // K   [origin=predictive method=joback]
Pc          45.225;      // bar [origin=predictive method=joback]
omega       0.6085;      // -   [origin=predictive method=lee-kesler]
Tb          493.73;      // K   [origin=predictive method=joback]
HvapTb      48721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.41 0.63362 -0.00048292 1.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-fluoranyl-6-methoxy-phenol" "2-hydroxy-3-fluoroanisole" "2-fluoro-6-methoxy-phenol" "2-fluoro-6-methoxyphenol," "phenol,2-fluoro-6-methoxy-" );
gibbsFormation
{
    dHf_298   -468390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343590.0
    phase     gas;
}
