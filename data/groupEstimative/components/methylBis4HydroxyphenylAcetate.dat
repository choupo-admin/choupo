/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl bis(4-hydroxyphenyl)acetate  (C15H14O4, CAS 5129-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylBis4HydroxyphenylAcetate;
formula     C15H14O4;
CAS         5129-00-0;
InChIKey    GKFFBAQBFJBIDR-UHFFFAOYSA-N;
MW          258.273;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.13;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       1.1762;      // -   [origin=predictive method=lee-kesler]
Tb          815.18;      // K   [origin=predictive method=joback]
HvapTb      86583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.67 1.53132 -0.00127592 4.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2-bis(4-hydroxyphenyl)ethanoate" "methyl 2,2-bis(4-hydroxyphenyl)acetate" "benzeneacetic acid,4-hydroxy-a-(4-hydroxyphenyl)-, methyl ester" "benzeneacetic acid, 4-hydroxy-.alpha.-(4-hydroxyphenyl)-, methyl ester" "benzeneacetic acid, 4-hydroxy-alpha-(4-hydroxyphenyl)-, methyl ester" "aceticacid, bis(p-hydroxyphenyl)-, methyl ester (6ci,7ci,8ci); methylbis(4-hydroxyphenyl)acetate; methyl bis(p-hydroxyphenyl)acetate" );
standardThermochemistry
{
    dHf_298   -557050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-321810.0
}
