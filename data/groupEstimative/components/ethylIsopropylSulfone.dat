/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl isopropyl sulfone  (C5H12O2S, CAS 4853-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H12O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethylIsopropylSulfone;
formula     C5H12O2S;
CAS         4853-75-2;
InChIKey    RDKKQZIFDSEMNU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          136.209;      // g/mol [origin=calculated method=formula-sum]
Tc          433.29;      // K   [origin=predictive method=joback]
Pc          39.856;      // bar [origin=predictive method=joback]
omega       0.4123;      // -   [origin=predictive method=lee-kesler]
Tb          292.56;      // K   [origin=predictive method=joback]
HvapTb      38154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.301 0.52396 -0.000226 1.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2SuCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylsulfonylpropane" "propane,2-(ethylsulfonyl)-" "agn-pc-03f1q0" "propane, 2-(ethylsulfonyl)-" "sulfone,ethyl isopropyl (7ci,8ci);ethyl isopropyl sulfone;" );
gibbsFormation
{
    dHf_298   -647030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-512880.0
    phase     gas;
}
