/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethoxy-2-iodoethane  (C6H13IO2, CAS 51806-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diethoxy2Iodoethane;
formula     C6H13IO2;
CAS         51806-20-3;
InChIKey    FWNJFIHTBFQKJD-UHFFFAOYSA-N;
MW          244.068;      // g/mol [origin=calculated method=formula-sum]
Tc          677.10;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.4686;      // -   [origin=predictive method=lee-kesler]
Tb          474.42;      // K   [origin=predictive method=joback]
HvapTb      42755.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.443 0.49234 -0.0001652 -1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group I; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxy-2-iodanyl-ethane" "ethane, 1,1-diethoxy-2-iodo-" );
standardThermochemistry
{
    dHf_298   -360020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154680.0
}
