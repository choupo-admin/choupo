/*--------------------------------*- Choupo -*-----------------------*\
  Component: aziridine, 1-[2-(trimethylsilyl)ethyl]-  (C7H17NSi, CAS 18387-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H17NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        aziridine12TrimethylsilylEthyl;
formula     C7H17NSi;
CAS         18387-12-7;
InChIKey    QJMJIBICTSDNAB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          143.305;      // g/mol [origin=calculated method=formula-sum]
Tc          557.28;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.3347;      // -   [origin=predictive method=lee-kesler]
Tb          380.74;      // K   [origin=predictive method=joback]
HvapTb      33563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.408 0.77356 -0.0003768 4.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(aziridin-1-yl)ethyl-trimethyl-silane" "agn-pc-03g22t" );
gibbsFormation
{
    dHf_298   -132600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94640.0
    phase     gas;
}
