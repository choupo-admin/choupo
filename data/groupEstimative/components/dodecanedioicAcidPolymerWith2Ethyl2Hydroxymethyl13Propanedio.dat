/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanedioic acid, polymer with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol and 1,6-hexanediol  (C24H50O9, CAS 145556-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanedioicAcidPolymerWith2Ethyl2Hydroxymethyl13Propanedio;
formula     C24H50O9;
CAS         145556-03-2;
InChIKey    DVCJXTYTFMJNOB-UHFFFAOYSA-N;
MW          482.655;      // g/mol [origin=calculated method=formula-sum]
Tc          2424.46;      // K   [origin=predictive method=joback]
Pc          10.814;      // bar [origin=predictive method=joback]
omega       -0.2575;      // -   [origin=predictive method=lee-kesler]
Tb          1500.21;      // K   [origin=predictive method=joback]
HvapTb      186033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.89 2.26882 -0.0009212 1.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group C; count 1; } { group OH; count 5; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group C; count 1; } { group OH; count 5; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanedioic acid;2-ethyl-2-(hydroxymethyl)propane-1,3-diol;hexane-1,6-diol" );
gibbsFormation
{
    dHf_298   -2232370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1628.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1427400.0
    phase     gas;
}
