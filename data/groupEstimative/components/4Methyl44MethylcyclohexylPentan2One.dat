/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-4-(4-methylcyclohexyl)pentan-2-one  (C13H24O, CAS 5505-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl44MethylcyclohexylPentan2One;
formula     C13H24O;
CAS         5505-84-0;
InChIKey    FIHXKZYLIWLRND-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          772.81;      // K   [origin=predictive method=joback]
Pc          20.438;      // bar [origin=predictive method=joback]
omega       0.5065;      // -   [origin=predictive method=lee-kesler]
Tb          562.56;      // K   [origin=predictive method=joback]
HvapTb      50102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.709 1.43228 -0.0008621 1.8776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentanone, 4-methyl-4-(4-methylcyclohexyl)-" "2-pentanone,4-methyl-4-(4-methylcyclohexyl)-" "4-methyl-4-(4-methylcyclohexyl)-2-pentanone" );
gibbsFormation
{
    dHf_298   -399000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50760.0
    phase     gas;
}
