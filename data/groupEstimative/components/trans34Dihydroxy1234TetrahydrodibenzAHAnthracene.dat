/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-3,4-dihydroxy-1,2,3,4-tetrahydrodibenz(a,h)anthracene  (C22H18O2, CAS 70443-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans34Dihydroxy1234TetrahydrodibenzAHAnthracene;
formula     C22H18O2;
CAS         70443-38-8;
InChIKey    MUKIATZFWSBOHR-VXKWHMMOSA-N;
MW          314.384;      // g/mol [origin=calculated method=formula-sum]
Tc          1234.06;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       1.6180;      // -   [origin=predictive method=lee-kesler]
Tb          997.20;      // K   [origin=predictive method=joback]
HvapTb      107544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.99 1.9486 -0.0015254 4.806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 6; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,4s)-1,2,3,4-tetrahydronaphtho[1,2-b]phenanthrene-3,4-diol" "trans-3,4-dihydroxy-1,2,3,4-tetrahydrodibenzo(a,h)anthracene" "dibenz(a,h)anthracene, 1,2,3,4-tetrahydro-3,4-dihydroxy-, (e)-" );
standardThermochemistry
{
    dHf_298   8290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=295500.0
}
