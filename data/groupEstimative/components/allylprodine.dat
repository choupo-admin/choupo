/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylprodine  (C18H25NO2, CAS 25384-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylprodine;
formula     C18H25NO2;
CAS         25384-17-2;
InChIKey    KGYFOSCXVAXULR-UHFFFAOYSA-N;
MW          287.403;      // g/mol [origin=calculated method=formula-sum]
Tc          935.24;      // K   [origin=predictive method=joback]
Pc          17.684;      // bar [origin=predictive method=joback]
omega       0.7775;      // -   [origin=predictive method=lee-kesler]
Tb          716.31;      // K   [origin=predictive method=joback]
HvapTb      65515.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.188 2.08114 -0.0016321 5.355e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methyl-4-phenyl-3-prop-2-enyl-piperidin-4-yl) propanoate" "4-piperidinol, 1-methyl-4-phenyl-3-(2-propenyl)-, propanoate (ester)" "aliprodina" "allilprodina" "allylprodinum" "alperidine" "allilprodina [dcit]" "allylprodinum [inn-latin]" "allylprodine [inn:ban:dcf]" "3-allyl-1-methyl-4-phenyl-4-propionyloxypiperidine" "alpha-3-allyl-1-methyl-4-phenyl-4-propionoxypiperidine" "(1-methyl-4-phenyl-3-prop-2-enylpiperidin-4-yl) propanoate" );
gibbsFormation
{
    dHf_298   -247260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     790.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124690.0
    phase     gas;
}
