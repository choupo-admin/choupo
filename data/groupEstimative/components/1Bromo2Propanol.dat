/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-propanol  (C3H7BrO, CAS 19686-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Propanol;
formula     C3H7BrO;
CAS         19686-73-8;
InChIKey    WEGOLYBUWCMMMY-UHFFFAOYSA-N;
MW          138.992;      // g/mol [origin=calculated method=formula-sum]
Tc          611.13;      // K   [origin=predictive method=joback]
Pc          55.942;      // bar [origin=predictive method=joback]
omega       0.7182;      // -   [origin=predictive method=lee-kesler]
Tb          426.14;      // K   [origin=predictive method=joback]
HvapTb      44998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.961 0.36692 -0.0002444 6.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylpropan-2-ol" "2-propanol, 1-bromo-" "1-bromopropan-2-ol" "2-hydroxypropyl bromide" "2-propanol, 1-bromo-, (r)-" "propylene bromohydrin" );
standardThermochemistry
{
    dHf_298   -236430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150560.0
}
