/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diphenyl-cyclopropabenzene  (C19H14, CAS 52750-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DiphenylCyclopropabenzene;
formula     C19H14;
CAS         52750-12-6;
InChIKey    GWDDTHGMCIPFBE-UHFFFAOYSA-N;
MW          242.321;      // g/mol [origin=calculated method=formula-sum]
Tc          997.93;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       0.6709;      // -   [origin=predictive method=lee-kesler]
Tb          732.17;      // K   [origin=predictive method=joback]
HvapTb      66580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.14 1.5902 -0.00127068 4.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-diphenylbicyclo[4.1.0]hepta-1,3,5-triene" "bicyclo[4.1.0]hepta-1,3,5-triene, 2,5-diphenyl-" "bicyclo(4.1.0)hepta-1,3,5-triene, 2,5-diphenyl-" );
standardThermochemistry
{
    dHf_298   345150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=510100.0
}
