/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-iodobenzoyl)estrone  (C25H25IO3, CAS 91999-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32IodobenzoylEstrone;
formula     C25H25IO3;
CAS         91999-14-3;
InChIKey    MGUISTZCIADYNH-KNPBPUNLSA-N;
MW          500.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1366.81;      // K   [origin=predictive method=joback]
Pc          15.610;      // bar [origin=predictive method=joback]
omega       1.0088;      // -   [origin=predictive method=lee-kesler]
Tb          1083.41;      // K   [origin=predictive method=joback]
HvapTb      97432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-176.24 2.55732 -0.00198528 6.403e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group ACH; count 7; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } { group I; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group I; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,13s,14s)-13-methyl-17-oxidanylidene-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthren-3-yl] 2-iodanylbenzoate" "estra-1,3,5(10)-triene-17-one, 3-((2-iodobenzoyl)oxy)-" "[(8r,9s,13s,14s)-13-methyl-17-oxo-7,8,9,11,12,14,15,16-octahydro-6h-cyclopenta[a]phenanthren-3-yl] 2-iodobenzoate" );
gibbsFormation
{
    dHf_298   -297810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125560.0
    phase     gas;
}
