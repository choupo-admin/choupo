/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-biphenyl, 2,2',3,3',4,4',6,6'-octachloro-  (C12H2Cl8, CAS 33091-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Biphenyl22334466Octachloro;
formula     C12H2Cl8;
CAS         33091-17-7;
InChIKey    YPDBBDKYNWRFMF-UHFFFAOYSA-N;
MW          429.748;      // g/mol [origin=calculated method=formula-sum]
Tc          1141.07;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.8522;      // -   [origin=predictive method=lee-kesler]
Tb          866.80;      // K   [origin=predictive method=joback]
HvapTb      87234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (141.69 0.5644 -0.00031828 5.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCl; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 10; } { group Cl; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,5-tetrakis(chloranyl)-4-[2,3,4,6-tetrakis(chloranyl)phenyl]benzene" "2,2',3,3',4,4',6,6'-octachlorobiphenyl" "biphenyl, 2,2',3,3',4,4',6,6'-octachloro-" "1,1'-biphenyl,2,2',3,3',4,4',6,6'-octachloro-" "1,2,3,5-tetrachloro-4-(2,3,4,6-tetrachlorophenyl)benzene" );
standardThermochemistry
{
    dHf_298   -35630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102500.0
}
