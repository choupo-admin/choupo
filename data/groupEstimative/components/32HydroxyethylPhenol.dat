/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-hydroxyethyl)phenol  (C8H10O2, CAS 13398-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32HydroxyethylPhenol;
formula     C8H10O2;
CAS         13398-94-2;
InChIKey    AMQIPHZFLIDOCB-UHFFFAOYSA-N;
MW          138.166;      // g/mol [origin=calculated method=formula-sum]
Tc          791.50;      // K   [origin=predictive method=joback]
Pc          50.015;      // bar [origin=predictive method=joback]
omega       1.0481;      // -   [origin=predictive method=lee-kesler]
Tb          582.12;      // K   [origin=predictive method=joback]
HvapTb      65371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.918 0.8735 -0.00072936 2.524e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-hydroxyphenyl)ethanol" "benzeneethanol, 3-hydroxy-" "3-hydroxyphenethyl alcohol" "phenethyl alcohol, m-hydroxy-" "m-phenethyl alcohol" "3-hydroxyphenethylalcohol" "m-hydroxyphenethyl alcohol" "benzeneethanol,3-hydroxy-" "3-(2-hydroxy-ethyl)-phenol" "3-hydroxyphenylmethyl carbinol" );
gibbsFormation
{
    dHf_298   -301460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162550.0
    phase     gas;
}
