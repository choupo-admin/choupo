/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6-dihydro-2h-pyran-2-one  (C5H6O2, CAS 3393-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56Dihydro2hPyran2One;
formula     C5H6O2;
CAS         3393-45-1;
InChIKey    QBDAFARLDLCWAT-UHFFFAOYSA-N;
MW          98.101;      // g/mol [origin=calculated method=formula-sum]
Tc          587.88;      // K   [origin=predictive method=joback]
Pc          46.340;      // bar [origin=predictive method=joback]
omega       0.3585;      // -   [origin=predictive method=lee-kesler]
Tb          387.06;      // K   [origin=predictive method=joback]
HvapTb      34817.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.77 0.5358 -0.00037008 9.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydropyran-6-one" "2h-pyran-2-one, 5,6-dihydro-" "5,6-dihydro-pyran-2-one" "2-pentenoicacid, 5-hydroxy-, d-lactone (6ci,7ci);5,6-dihydro-a-pyrone;d-2-pentenolide;" );
gibbsFormation
{
    dHf_298   -319050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     336.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232830.0
    phase     gas;
}
