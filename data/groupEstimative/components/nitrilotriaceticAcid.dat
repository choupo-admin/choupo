/*--------------------------------*- Choupo -*-----------------------*\
  Component: nitrilotriacetic acid  (C6H9NO6, CAS 139-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nitrilotriaceticAcid;
formula     C6H9NO6;
CAS         139-13-9;
InChIKey    MGFYIUFZLHCRTH-UHFFFAOYSA-N;
MW          191.139;      // g/mol [origin=calculated method=formula-sum]
Tc          998.08;      // K   [origin=predictive method=joback]
Pc          42.775;      // bar [origin=predictive method=joback]
omega       1.6882;      // -   [origin=predictive method=lee-kesler]
Tb          785.85;      // K   [origin=predictive method=joback]
HvapTb      82485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.543 0.8501 -0.000633 1.816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2N; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group COOH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxy-2-oxoethyl)amino]ethanoic acid" "triglycollamic acid" "aminotriacetic acid" "complexon i" "titriplex i" "trilon a" "versene nta acid" "hampshire nta acid" "2,2',2''-nitrilotriacetic acid" "nta" "nitrilotriacetate" "n,n-bis(carboxymethyl)glycine" );
standardThermochemistry
{
    dHf_298   -1150450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-921310.0
}
