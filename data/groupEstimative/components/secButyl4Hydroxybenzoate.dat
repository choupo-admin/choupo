/*--------------------------------*- Choupo -*-----------------------*\
  Component: sec-butyl 4-hydroxybenzoate  (C11H14O3, CAS 17696-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        secButyl4Hydroxybenzoate;
formula     C11H14O3;
CAS         17696-61-6;
InChIKey    ZUOTXZHOGPQFIU-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          838.25;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.7995;      // -   [origin=predictive method=lee-kesler]
Tb          616.36;      // K   [origin=predictive method=joback]
HvapTb      62389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.209 1.07564 -0.00077076 2.207e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-2-yl 4-oxidanylbenzoate" "sec-butylparaben" "4-hydroxybenzoic acid sec-butyl ester" "agn-pc-01yty0" "butan-2-yl 4-hydroxybenzoate" "benzoic acid,4-hydroxy-, 1-methylpropyl ester" "benzoic acid, 4-hydroxy-, 1-methylpropyl ester" "benzoicacid, p-hydroxy-, sec-butyl ester (6ci,7ci,8ci); 2-butyl p-hydroxybenzoate;p-hydroxybenzoic acid sec-butyl ester; sec-butyl 4-hydroxybenzoate; sec-butylp-hydroxybenzoate" );
gibbsFormation
{
    dHf_298   -533710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313280.0
    phase     gas;
}
