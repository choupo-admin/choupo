/*--------------------------------*- Choupo -*-----------------------*\
  Component: etretinate  (C23H30O3, CAS 54350-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etretinate;
formula     C23H30O3;
CAS         54350-48-0;
InChIKey    HQMNCQVAMBCHCO-DJRRULDNSA-N;
MW          354.49;      // g/mol [origin=calculated method=formula-sum]
Tc          1083.43;      // K   [origin=predictive method=joback]
Pc          11.499;      // bar [origin=predictive method=joback]
omega       0.8952;      // -   [origin=predictive method=lee-kesler]
Tb          869.48;      // K   [origin=predictive method=joback]
HvapTb      81525.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.071 1.83384 -0.00112464 2.697e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=CH; count 2; } { group CH=C; count 2; } { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 3; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group dCH; count 6; } { group dC; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (2e,4e,6e,8e)-9-(4-methoxy-2,3,6-trimethyl-phenyl)-3,7-dimethyl-nona-2,4,6,8-tetraenoate" "tegison" "ethyl etrinoate" "etretinato" "etretinatum" "retinoid" "etretinatum [inn-latin]" "tigason" "3,7-dimethyl-9-(4-methoxy-2,3,6-trimethylphenyl)-2,4,6,8-nonanetetraenoic acid ethyl ester" "ethyl all-trans-9-(4-methoxy-2,3,6-trimethylphenyl)-3,7-dimethyl-2,4,6,8-nonatetraenoate" "tigazon" "ethyl (all-e)-9-(4-methoxy-2,3,6-trimethylphenyl)-3,7-dimethyl-2,4,6,8-nonatetraenoate" );
gibbsFormation
{
    dHf_298   -327600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     948.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105080.0
    phase     gas;
}
