/*--------------------------------*- Choupo -*-----------------------*\
  Component: neodecanoic acid, ethenyl ester, polymer with ethenyl acetate and ethyl 2-propenoate  (C21H36O6, CAS 141667-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neodecanoicAcidEthenylEsterPolymerWithEthenylAcetateAndEthyl;
formula     C21H36O6;
CAS         141667-71-2;
InChIKey    FOYFDGRDNQTNAZ-UHFFFAOYSA-N;
MW          384.513;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.82;      // K   [origin=predictive method=joback]
Pc          9.514;      // bar [origin=predictive method=joback]
omega       0.8323;      // -   [origin=predictive method=lee-kesler]
Tb          843.91;      // K   [origin=predictive method=joback]
HvapTb      81455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (106.534 1.49382 -0.0002489 -2.434e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 3; } { group CH3COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl ethanoate;ethenyl 2-ethyl-2,5-dimethyl-hexanoate;ethyl prop-2-enoate" );
standardThermochemistry
{
    dHf_298   -1289590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1280.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-750770.0
}
