/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[4.4]nonene  (C9H14, CAS 873-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro44Nonene;
formula     C9H14;
CAS         873-12-1;
InChIKey    RWXPSIRAVCNFPR-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          665.18;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.2679;      // -   [origin=predictive method=lee-kesler]
Tb          435.88;      // K   [origin=predictive method=joback]
HvapTb      35420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-169.29 1.3942 -0.00134228 5.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[4.4]non-3-ene" "spiro[4.4]non-8-ene" "spiro[4.4]non-1-ene" "spiro(4.4)non-1-ene" );
standardThermochemistry
{
    dHf_298   -8610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142280.0
}
