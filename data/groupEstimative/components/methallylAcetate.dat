/*--------------------------------*- Choupo -*-----------------------*\
  Component: methallyl acetate  (C6H10O2, CAS 820-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methallylAcetate;
formula     C6H10O2;
CAS         820-71-3;
InChIKey    IVKYUXHYUAMPMT-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          572.53;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.3983;      // -   [origin=predictive method=lee-kesler]
Tb          391.66;      // K   [origin=predictive method=joback]
HvapTb      35767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.161 0.49894 -0.0002332 2.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylprop-2-enyl ethanoate" "2-methylallyl acetate" "2-methylprop-2-en-1-yl acetate" "2-propen-1-ol, 2-methyl-, acetate" "2-methyl-2-propenyl acetate" "beta-methallyl acetate" "2-methylprop-2-enyl acetate" "acetic acid 2-methylallyl ester" "2-propen-1-ol,2-methyl-, 1-acetate" "acetic acid 2-methyl-2-propenyl ester" "m643" "2-propen-1-ol,2-methyl-, acetate (6ci,7ci,8ci,9ci);1-acetoxy-2-methyl-2-propene;2-methyl-2-propen-1-ol acetate;2-methylallyl acetate;3-acetoxy-2-methylprop-1-ene;acetic acid 2-methyl-2-propenyl ester;methallylacetate;b-methallyl acetate;" );
standardThermochemistry
{
    dHf_298   -368810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231440.0
}
