/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-methylbenzoyl)propionic acid  (C11H12O3, CAS 4619-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34MethylbenzoylPropionicAcid;
formula     C11H12O3;
CAS         4619-20-9;
InChIKey    OEEUWZITKKSXAZ-UHFFFAOYSA-N;
MW          192.214;      // g/mol [origin=calculated method=formula-sum]
Tc          905.83;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.9773;      // -   [origin=predictive method=lee-kesler]
Tb          682.32;      // K   [origin=predictive method=joback]
HvapTb      66928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.758 0.93322 -0.00059266 1.3926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methylphenyl)-4-oxidanylidene-butanoic acid" "4-(4-methylphenyl)-4-oxobutanoic acid" "4-(4-methylphenyl)-4-oxobutyric acid" "4-oxo-4-(p-tolyl)butanoic acid" "4-oxo-4-p-tolyl-butyric acid" "4-(p-tolyl)-4-oxobutyric acid" "4-oxo-4-(para-tolyl)-butyric acid" );
gibbsFormation
{
    dHf_298   -508160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-328310.0
    phase     gas;
}
