/*--------------------------------*- Choupo -*-----------------------*\
  Component: 11-tricosene  (C23H46, CAS 52078-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Tricosene;
formula     C23H46;
CAS         52078-56-5;
InChIKey    RIERBYNHXFKVQP-UHFFFAOYSA-N;
MW          322.621;      // g/mol [origin=calculated method=formula-sum]
Tc          899.03;      // K   [origin=predictive method=joback]
Pc          8.784;      // bar [origin=predictive method=joback]
omega       0.7876;      // -   [origin=predictive method=lee-kesler]
Tb          730.00;      // K   [origin=predictive method=joback]
HvapTb      66750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.201 2.20884 -0.0013112 3.099e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricos-11-ene" );
standardThermochemistry
{
    dHf_298   -400830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1045.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223000.0
}
