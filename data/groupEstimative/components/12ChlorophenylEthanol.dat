/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-chlorophenyl)ethanol  (C8H9ClO, CAS 13524-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12ChlorophenylEthanol;
formula     C8H9ClO;
CAS         13524-04-4;
InChIKey    DDUBOVLGCYUYFX-UHFFFAOYSA-N;
MW          156.609;      // g/mol [origin=calculated method=formula-sum]
Tc          751.51;      // K   [origin=predictive method=joback]
Pc          38.723;      // bar [origin=predictive method=joback]
omega       0.7863;      // -   [origin=predictive method=lee-kesler]
Tb          543.47;      // K   [origin=predictive method=joback]
HvapTb      57016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.49 0.67212 -0.00042956 1.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chlorophenyl)ethan-1-ol" "2-chloro-alpha-methylbenzyl alcohol" "1-(2-chlorophenyl)-1-ethanol" "benzenemethanol, 2-chloro-.alpha.-methyl-" "benzyl alcohol, o-chloro-.alpha.-methyl-" "agn-pc-0daukb" "1-(2-chloro-phenyl)-ethanol" "ddubovlgcyuyfx-uhfffaoysa-" "1-(2-chlorophenyl)ethyl alcohol" "benzenemethanol,2-chloro-a-methyl-" "2-chlorophenyl methyl carbinol" "1-(2-chlorophenyl)-1-deuterioethanol" );
gibbsFormation
{
    dHf_298   -156640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31930.0
    phase     gas;
}
