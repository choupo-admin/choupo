/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanedioic acid, polymer with 1,4-cyclohexanedimethanol and 1,6-hexanediol  (C20H40O8, CAS 71113-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith14CyclohexanedimethanolAnd16Hexane;
formula     C20H40O8;
CAS         71113-96-7;
InChIKey    UMNUNJOBHARKGL-UHFFFAOYSA-N;
MW          408.532;      // g/mol [origin=calculated method=formula-sum]
Tc          1785.49;      // K   [origin=predictive method=joback]
Pc          14.839;      // bar [origin=predictive method=joback]
omega       0.4946;      // -   [origin=predictive method=lee-kesler]
Tb          1334.62;      // K   [origin=predictive method=joback]
HvapTb      161866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.042 1.8246 -0.000527 -1.31e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group CH; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid;hexane-1,6-diol;[4-(hydroxymethyl)cyclohexyl]methanol" "adipic acid, 1,6-hexanediol, 1,4-cyclohexanedimethanol" );
standardThermochemistry
{
    dHf_298   -1954850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1387.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1310360.0
}
