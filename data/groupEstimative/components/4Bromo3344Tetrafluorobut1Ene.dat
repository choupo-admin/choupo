/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-3,3,4,4-tetrafluorobut-1-ene  (C4H3BrF4, CAS 18599-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo3344Tetrafluorobut1Ene;
formula     C4H3BrF4;
CAS         18599-22-9;
InChIKey    GVCWGFZDSIWLMO-UHFFFAOYSA-N;
MW          206.964;      // g/mol [origin=calculated method=formula-sum]
Tc          516.70;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.3364;      // -   [origin=predictive method=lee-kesler]
Tb          344.58;      // K   [origin=predictive method=joback]
HvapTb      24403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.13 0.7008 -0.0006973 2.541e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group Br; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-3,3,4,4-tetrakis(fluoranyl)but-1-ene" "4-bromo-3,3,4,4-tetrafluoro-1-butene" "1-butene, 4-bromo-3,3,4,4-tetrafluoro-" "gvcwgfzdsiwlmo-uhfffaoysa-" "4-bromo-3,3,4,4-tetrafluorobutene" "4-bromo-3,3,4,4-tetrafluorobutene-1" "1-butene,4-bromo-3,3,4,4-tetrafluoro-" "4-bromo-3,3,4,4-tetrafluoro-1-butene;" );
standardThermochemistry
{
    dHf_298   -776070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-688600.0
}
