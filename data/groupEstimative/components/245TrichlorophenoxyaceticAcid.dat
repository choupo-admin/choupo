/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5-trichlorophenoxyacetic acid  (C8H5Cl3O3, CAS 93-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        245TrichlorophenoxyaceticAcid;
formula     C8H5Cl3O3;
CAS         93-76-5;
InChIKey    SMYMJHWAQXWPDB-UHFFFAOYSA-N;
MW          255.475;      // g/mol [origin=calculated method=formula-sum]
Tc          942.01;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.9597;      // -   [origin=predictive method=lee-kesler]
Tb          704.48;      // K   [origin=predictive method=joback]
HvapTb      70393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.381 0.5144 -0.00026428 3.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH2O; count 1; } { group COOH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4,5-tris(chloranyl)phenoxy]ethanoic acid" "fortex" "2,4,5-t" "(2,4,5-trichlorophenoxy)acetic acid" "trioxon" "fence rider" "bcf-bushkiller" "verton 2t" "trioxone" "tippontormona" "arbokan" "crossbow" );
standardThermochemistry
{
    dHf_298   -536040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-384700.0
}
