/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,4-dihydroxyphenyl)-2-(4-methoxyphenyl)ethanone  (C15H14O4, CAS 487-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124Dihydroxyphenyl24MethoxyphenylEthanone;
formula     C15H14O4;
CAS         487-49-0;
InChIKey    XHBZOAYMBBUURD-UHFFFAOYSA-N;
MW          258.273;      // g/mol [origin=calculated method=formula-sum]
Tc          1090.07;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       1.2839;      // -   [origin=predictive method=lee-kesler]
Tb          838.67;      // K   [origin=predictive method=joback]
HvapTb      89382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.239 1.42952 -0.00117058 3.9576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group ACOH; count 2; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH_phenol; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,4-bis(oxidanyl)phenyl]-2-(4-methoxyphenyl)ethanone" "acetophenone, 2',4'-dihydroxy-2-(p-methoxyphenyl)-" "1-(2,4-dihydroxyphenyl)-2-(4-methoxyphenyl)ethan-1-one" "sdccgmls-0066960.p001" "brd-k85385671-001-02-2" "ethanone,1-(2,4-dihydroxyphenyl)-2-(4-methoxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -490760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252550.0
}
