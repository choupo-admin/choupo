/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl citraconate  (C7H10O4, CAS 617-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylCitraconate;
formula     C7H10O4;
CAS         617-54-9;
InChIKey    WQEXBUQDXKPVHR-UHFFFAOYSA-N;
MW          158.153;      // g/mol [origin=calculated method=formula-sum]
Tc          671.86;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.5888;      // -   [origin=predictive method=lee-kesler]
Tb          480.24;      // K   [origin=predictive method=joback]
HvapTb      46028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.47 0.57916 -0.0002539 7.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-methylbut-2-enedioate" "2-butenedioic acid, 2-methyl-, 1,4-dimethyl ester, (2z)-" "2-butenedioic acid, 2-methyl-, dimethyl ester, (e)-" "2-butenedioic acid,2-methyl-, 1,4-dimethyl ester, (2z)-" "2-butenedioicacid, 2-methyl-, dimethyl ester, (2z)- (9ci); 2-butenedioic acid, 2-methyl-,dimethyl ester, (z)-; citraconic acid, dimethyl ester (6ci,7ci,8ci); dimethylcitraconate; dimethyl methylmaleate; methylmaleic acid, dimethyl ester" );
gibbsFormation
{
    dHf_298   -714940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-541010.0
    phase     gas;
}
