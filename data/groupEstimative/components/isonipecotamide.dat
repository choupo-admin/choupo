/*--------------------------------*- Choupo -*-----------------------*\
  Component: isonipecotamide  (C6H12N2O, CAS 39546-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isonipecotamide;
formula     C6H12N2O;
CAS         39546-32-2;
InChIKey    DPBWFNDFMCCGGJ-UHFFFAOYSA-N;
MW          128.175;      // g/mol [origin=calculated method=formula-sum]
Tc          769.24;      // K   [origin=predictive method=joback]
Pc          47.959;      // bar [origin=predictive method=joback]
omega       0.5991;      // -   [origin=predictive method=lee-kesler]
Tb          531.38;      // K   [origin=predictive method=joback]
HvapTb      53524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.4 0.7164 -0.0003477 3.886e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2NH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine-4-carboxamide" "4-piperidinecarboxamide" "hexahydroisonicotinamide" "piperidin-4-carboxamid" "piperidine-4-carboxylicacidamide" "piperidine-4-carboxylic acid amide" "iso nipecotamide" "isonipectoamide" "hexahydroisonicotinamide; isonipecotamide" "i360" );
standardThermochemistry
{
    dHf_298   -153830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49330.0
}
