/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dichlorobutanal  (C4H6Cl2O, CAS 55775-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dichlorobutanal;
formula     C4H6Cl2O;
CAS         55775-41-2;
InChIKey    KYBNZGCYBVOCEO-UHFFFAOYSA-N;
MW          140.991;      // g/mol [origin=calculated method=formula-sum]
Tc          613.07;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.4093;      // -   [origin=predictive method=lee-kesler]
Tb          413.76;      // K   [origin=predictive method=joback]
HvapTb      39212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.07 0.38372 -0.000234 5.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHO; count 1; } { group CHCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group Cl; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)butanal" "butanal, 2,3-dichloro-" );
gibbsFormation
{
    dHf_298   -253510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145460.0
    phase     gas;
}
