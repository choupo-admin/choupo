/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropenyl-1,2,4-trimethyl-1-cyclohexene  (C12H20, CAS 16195-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropenyl124Trimethyl1Cyclohexene;
formula     C12H20;
CAS         16195-58-7;
InChIKey    HNXIHAQWIOOZSF-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          712.74;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.3704;      // -   [origin=predictive method=lee-kesler]
Tb          499.63;      // K   [origin=predictive method=joback]
HvapTb      42610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.92 1.36278 -0.001121 4.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-trimethyl-4-prop-1-en-2-yl-cyclohexene" "cyclohexene, 1,2,4-trimethyl-4-(1-methylethenyl)-" "1,2,4-trimethyl-4-prop-1-en-2-ylcyclohexene" "cyclohexene,2,4-trimethyl-4-(1-methylethenyl)-" "cyclohexene,1,2,4-trimethyl-4-(1-methylethenyl)-" );
gibbsFormation
{
    dHf_298   -70970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159110.0
    phase     gas;
}
