/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethyl-1-octen-3-ol  (C10H20O, CAS 18479-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethyl1Octen3Ol;
formula     C10H20O;
CAS         18479-49-7;
InChIKey    IUDWWFNDSJRYRV-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          686.52;      // K   [origin=predictive method=joback]
Pc          24.580;      // bar [origin=predictive method=joback]
omega       0.7914;      // -   [origin=predictive method=lee-kesler]
Tb          513.59;      // K   [origin=predictive method=joback]
HvapTb      52179.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.057 1.09956 -0.0007485 2.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-1-en-3-ol" "1-octen-3-ol, 3,7-dimethyl-" "6,7-dihydrolinalool" "p778" );
gibbsFormation
{
    dHf_298   -290560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15260.0
    phase     gas;
}
