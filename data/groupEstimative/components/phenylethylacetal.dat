/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylethylacetal  (C18H22O2, CAS 122-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylethylacetal;
formula     C18H22O2;
CAS         122-71-4;
InChIKey    JBMMTNRBVCXMHJ-UHFFFAOYSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          929.62;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       0.7822;      // -   [origin=predictive method=lee-kesler]
Tb          709.20;      // K   [origin=predictive method=joback]
HvapTb      64646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.966 1.43552 -0.000799 1.439e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(2-phenylethoxy)ethoxy]ethylbenzene" "acetaldehyde diphenethyl acetal" "benzene, 1,1'-[ethylidenebis(oxy-2,1-ethanediyl)]bis-" "benzene, 1,1'-(ethylidenebis(oxy-2,1-ethanediyl))bis-" "1,1-bis(phenethyloxy)ethane" "2-(1-phenethyloxyethoxy)ethylbenzene" "1,1'-[ethane-1,1-diylbis(oxyethane-2,1-diyl)]dibenzene" );
standardThermochemistry
{
    dHf_298   -211510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113060.0
}
