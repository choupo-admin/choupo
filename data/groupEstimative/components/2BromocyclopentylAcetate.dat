/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromocyclopentyl acetate  (C7H11BrO2, CAS 53093-41-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromocyclopentylAcetate;
formula     C7H11BrO2;
CAS         53093-41-7;
InChIKey    RWFKZZAXUPSAQT-UHFFFAOYSA-N;
MW          207.067;      // g/mol [origin=calculated method=formula-sum]
Tc          714.46;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.4922;      // -   [origin=predictive method=lee-kesler]
Tb          494.75;      // K   [origin=predictive method=joback]
HvapTb      44966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.42 0.75742 -0.0004058 6.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH3COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-bromanylcyclopentyl) ethanoate" "cis-2-bromocyclopentanol acetate" "agn-pc-00njsc" "(2-bromocyclopentyl) acetate" "trans-2-bromocyclopentanol acetate" "cyclopentanol,2-bromo-,acetate,cis-" "cyclopentanol,2-bromo-,acetate,trans-" "[(1s,2s)-2-bromocyclopentyl] acetate" "cyclopentanol, 2-bromo-, acetate, cis-" "cyclopentanol, 2-bromo-, acetate, trans-" );
standardThermochemistry
{
    dHf_298   -438620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259150.0
}
