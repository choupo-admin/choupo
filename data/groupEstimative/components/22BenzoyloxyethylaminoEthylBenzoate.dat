/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-benzoyloxyethylamino)ethyl benzoate  (C18H19NO4, CAS 47309-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BenzoyloxyethylaminoEthylBenzoate;
formula     C18H19NO4;
CAS         47309-20-6;
InChIKey    SSKKNVDGEGQKNN-UHFFFAOYSA-N;
MW          313.353;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.49;      // K   [origin=predictive method=joback]
Pc          19.561;      // bar [origin=predictive method=joback]
omega       1.1124;      // -   [origin=predictive method=lee-kesler]
Tb          831.41;      // K   [origin=predictive method=joback]
HvapTb      81464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.676 1.5226 -0.0008772 1.503e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 10; } { group AC; count 2; } { group CH2NH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(phenylcarbonyloxy)ethylamino]ethyl benzoate" "ethanol, 2,2'-iminobis-, dibenzoate (ester)" "ethanol, 2,2'-iminobis-, 1,1'-dibenzoate" );
gibbsFormation
{
    dHf_298   -522880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     787.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205850.0
    phase     gas;
}
