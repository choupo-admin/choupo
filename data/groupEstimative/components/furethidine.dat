/*--------------------------------*- Choupo -*-----------------------*\
  Component: furethidine  (C21H31NO4, CAS 2385-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        furethidine;
formula     C21H31NO4;
CAS         2385-81-1;
InChIKey    NNCOZXNZFLUYGG-UHFFFAOYSA-N;
MW          361.482;      // g/mol [origin=calculated method=formula-sum]
Tc          1083.68;      // K   [origin=predictive method=joback]
Pc          15.735;      // bar [origin=predictive method=joback]
omega       0.9978;      // -   [origin=predictive method=lee-kesler]
Tb          857.59;      // K   [origin=predictive method=joback]
HvapTb      80349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.526 2.47812 -0.0018303 5.58e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-[2-(oxolan-2-ylmethoxy)ethyl]-4-phenyl-piperidine-4-carboxylate" "furethidinum" "furetidina [dcit]" "furethidinum [inn-latin]" "furethidine [inn:ban:dcf]" "ethyl 4-phenyl-1-(2-tetrahydrofurfuryloxyethyl)piperidine-4-carboxylate" "1-(2-tetrahydrofurfuryloxyethyl)-4-phenylpiperidine-4-carboxylic acid ethyl ester" "isonipecotic acid, 4-phenyl-1-(2-((tetrahydrofurfuryl)oxy)ethyl)-, ethyl ester" "4-piperidinecarboxylic acid, 4-phenyl-1-[2-[(tetrahydro-2-furanyl)methoxy]ethyl]-, ethyl ester" "furetidina" "1-(2'-tetrahydrofurfuryloxyethyl)norpethidine" "ethyl 1-[2-(oxolan-2-ylmethoxy)ethyl]-4-phenylpiperidine-4-carboxylate" );
standardThermochemistry
{
    dHf_298   -618010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84750.0
}
