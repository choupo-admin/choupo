/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethylphenylacetonitrile  (C10H11N, CAS 51632-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethylphenylacetonitrile;
formula     C10H11N;
CAS         51632-28-1;
InChIKey    NCPKDFDQDZMXCO-UHFFFAOYSA-N;
MW          145.205;      // g/mol [origin=calculated method=formula-sum]
Tc          786.58;      // K   [origin=predictive method=joback]
Pc          28.084;      // bar [origin=predictive method=joback]
omega       0.5551;      // -   [origin=predictive method=lee-kesler]
Tb          562.14;      // K   [origin=predictive method=joback]
HvapTb      51270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.808 0.75022 -0.00045336 1.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-ethylphenyl)ethanenitrile" "2-(4-ethylphenyl)acetonitrile" "acetonitrile,(p-ethylphenyl)- (6ci,7ci);(4-ethylphenyl)acetonitrile;4-ethylbenzeneacetonitrile;4-ethylbenzyl cyanide;" );
gibbsFormation
{
    dHf_298   140210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=269280.0
    phase     gas;
}
