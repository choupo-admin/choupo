/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-cyclohexadiene, 3-(4,4-dimethyl-2,5-cyclohexadien-1-ylidene)-6,6-dimethyl-  (C16H20, CAS 81478-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Cyclohexadiene344Dimethyl25Cyclohexadien1Ylidene66Dimethyl;
formula     C16H20;
CAS         81478-74-2;
InChIKey    PMVYCKVUMZGLBA-UHFFFAOYSA-N;
MW          212.336;      // g/mol [origin=calculated method=formula-sum]
Tc          857.99;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       0.4335;      // -   [origin=predictive method=lee-kesler]
Tb          611.02;      // K   [origin=predictive method=joback]
HvapTb      52550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-175.35 1.95288 -0.00187612 7.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group CH=CH; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(4,4-dimethylcyclohexa-2,5-dien-1-ylidene)-3,3-dimethyl-cyclohexa-1,4-diene" "6-(4,4-dimethyl-1-cyclohexa-2,5-dienylidene)-3,3-dimethyl-cyclohexa-1,4-diene" "6-(4,4-dimethylcyclohexa-2,5-dien-1-ylidene)-3,3-dimethylcyclohexa-1,4-diene" );
gibbsFormation
{
    dHf_298   31510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252300.0
    phase     gas;
}
