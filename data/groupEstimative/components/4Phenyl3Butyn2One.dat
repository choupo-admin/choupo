/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenyl-3-butyn-2-one  (C10H8O, CAS 1817-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenyl3Butyn2One;
formula     C10H8O;
CAS         1817-57-8;
InChIKey    UPEUQDJSUFHFQP-UHFFFAOYSA-N;
MW          144.173;      // g/mol [origin=calculated method=formula-sum]
Tc          762.71;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.4194;      // -   [origin=predictive method=lee-kesler]
Tb          517.95;      // K   [origin=predictive method=joback]
HvapTb      49028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.19 0.69712 -0.00044056 1.0324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH3CO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbut-3-yn-2-one" "1-phenyl-1-butyn-3-one" "3-butyn-2-one, 4-phenyl-" "4-phenyl-but-3-yn-2-one" "t340" );
gibbsFormation
{
    dHf_298   146520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219610.0
    phase     gas;
}
