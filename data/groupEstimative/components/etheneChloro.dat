/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethene, chloro-  (C2H3Cl, CAS 75-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etheneChloro;
formula     C2H3Cl;
CAS         75-01-4;
InChIKey    BZHJMEDXRYGGRV-UHFFFAOYSA-N;
MW          62.496;      // g/mol [origin=calculated method=formula-sum]
Tc          453.48;      // K   [origin=predictive method=joback]
Pc          50.658;      // bar [origin=predictive method=joback]
omega       0.1585;      // -   [origin=predictive method=lee-kesler]
Tb          279.47;      // K   [origin=predictive method=joback]
HvapTb      23761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.97 0.1806 -0.0001283 3.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylethene" "vinyl chloride" "chloroethylene" "chloroethene" "monochloroethene" "monochloroethylene" "ethylene, chloro-" "ethylene monochloride" "chlorethylene" "vinylchloride" "monovinyl chloride" "polyvinyl chloride" );
standardThermochemistry
{
    dHf_298   25080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     262.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41870.0
}
