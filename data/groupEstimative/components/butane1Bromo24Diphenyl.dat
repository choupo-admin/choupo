/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, 1-bromo-2,4-diphenyl-  (C16H17Br, CAS 27041-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane1Bromo24Diphenyl;
formula     C16H17Br;
CAS         27041-04-9;
InChIKey    SQSJCFQHNSGVBW-UHFFFAOYSA-N;
MW          289.216;      // g/mol [origin=calculated method=formula-sum]
Tc          931.27;      // K   [origin=predictive method=joback]
Pc          24.629;      // bar [origin=predictive method=joback]
omega       0.6676;      // -   [origin=predictive method=lee-kesler]
Tb          684.76;      // K   [origin=predictive method=joback]
HvapTb      61809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.957 1.4101 -0.0009836 2.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group ACCH2; count 1; } { group ACCH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-bromanyl-4-phenyl-butan-2-yl)benzene" "(1-bromo-4-phenyl-butan-2-yl)benzene" "butane, 1-bromo-2,4-diphenyl-," "(1-bromo-4-phenylbutan-2-yl)benzene" "butane,1-bromo-2,4-diphenyl- (8ci)" "(1-bromo-4-phenyl-butan-2-yl)benzene;1,1'-(4-bromobutane-1,3-diyl)dibenzene;" );
standardThermochemistry
{
    dHf_298   120540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=320540.0
}
