/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-(4-methoxyphenyl)ethyl]pyridine  (C14H17NO, CAS 118177-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124MethoxyphenylEthylPyridine;
formula     C14H17NO;
CAS         118177-96-1;
InChIKey    OBHGZJVYTSKPAH-UHFFFAOYSA-N;
MW          215.296;      // g/mol [origin=calculated method=formula-sum]
Tc          827.09;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.6482;      // -   [origin=predictive method=lee-kesler]
Tb          604.71;      // K   [origin=predictive method=joback]
HvapTb      55299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.498 1.30232 -0.00086092 2.147e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(4-methoxyphenyl)ethyl]-2h-pyridine" "pyridinium,1-[2-(4-methoxyphenyl)ethyl]-" );
standardThermochemistry
{
    dHf_298   24460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=279740.0
}
