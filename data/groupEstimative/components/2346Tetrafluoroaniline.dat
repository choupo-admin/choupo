/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,6-tetrafluoroaniline  (C6H3F4N, CAS 363-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2346Tetrafluoroaniline;
formula     C6H3F4N;
CAS         363-73-5;
InChIKey    SBYRHTZJKKWEMP-UHFFFAOYSA-N;
MW          165.089;      // g/mol [origin=calculated method=formula-sum]
Tc          642.51;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.6032;      // -   [origin=predictive method=lee-kesler]
Tb          453.09;      // K   [origin=predictive method=joback]
HvapTb      41247.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.58 0.366 -0.00017464 1.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACNH2; count 1; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,6-tetrakis(fluoranyl)aniline" "2,4,5,6-tetrafluoroaniline" "benzenamine, 2,3,4,6-tetrafluoro-" "2,3,4,6-tetrafluorophenylamine" "benzenamine,2,3,4,6-tetrafluoro-" "aniline,2,3,4,6-tetrafluoro- (8ci);2,3,4,6-tetrafluoroaniline;4-amino-1,2,3,5-tetrafluorobenzene;" );
standardThermochemistry
{
    dHf_298   -727170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-639260.0
}
