/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1(2h)-quinolineethanol, 3,4-dihydro-2,2,4-trimethyl-  (C14H21NO, CAS 53350-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12hQuinolineethanol34Dihydro224Trimethyl;
formula     C14H21NO;
CAS         53350-33-7;
InChIKey    UTQYEARNAQZWGU-UHFFFAOYSA-N;
MW          219.328;      // g/mol [origin=calculated method=formula-sum]
Tc          858.77;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       1.0028;      // -   [origin=predictive method=lee-kesler]
Tb          658.51;      // K   [origin=predictive method=joback]
HvapTb      66871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.138 1.76966 -0.00154236 5.723e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,2,4-trimethyl-3,4-dihydroquinolin-1-yl)ethanol" "3,4-dihydro-2,2,4-trimethyl-2h-quinoline-1-ethanol" );
standardThermochemistry
{
    dHf_298   -124230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191290.0
}
