/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-hydroxycarvotanacetone  (C10H16O2, CAS 60593-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Hydroxycarvotanacetone;
formula     C10H16O2;
CAS         60593-11-5;
InChIKey    DJOOMNLGIUGRKD-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          822.27;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.8371;      // -   [origin=predictive method=lee-kesler]
Tb          608.86;      // K   [origin=predictive method=joback]
HvapTb      58867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.48 0.95196 -0.00047964 6.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-(2-oxidanylpropan-2-yl)cyclohex-2-en-1-one" "s-(+)-5-(1-hydroxy-1-methylethyl)-2-methyl-2-cyclohexen-1-one" "5-(1-hydroxy-1-methylethyl)-2-methyl-2-cyclohexen-1-one" "5-(2-hydroxypropan-2-yl)-2-methylcyclohex-2-en-1-one" "(s)-(+)-5-(1-hydroxy-1-methylethyl)-2-methyl-2-cyclohexen-1-one" "5-(1-hydroxy-1-methylethel)-2-methyl-2-cyclohexen-1-one" "2-cyclohexen-1-one, 5-(1-hydroxy-1-methylethyl)-2-methyl-" "2-cyclohexen-1-one,5-(1-hydroxy-1-methylethyl)-2-methyl-, (s)-; (s)-(+)-5-(1-hydroxy-1-methylethyl)-2-methyl-2-cyclohexen-1-one;(s)-(+)-5-(1-hydroxy-1-methylethyl)-2-methyl-2-cyclohexene-1-one;(s)-8-hydroxy-p-menth-1-en-6-one; d-8-hydroxycarvotanacetone" );
standardThermochemistry
{
    dHf_298   -447780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-178470.0
}
