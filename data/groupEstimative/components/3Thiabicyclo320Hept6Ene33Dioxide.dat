/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-thiabicyclo(3.2.0)hept-6-ene 3,3-dioxide  (C6H8O2S, CAS 84451-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H8O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Thiabicyclo320Hept6Ene33Dioxide;
formula     C6H8O2S;
CAS         84451-42-3;
InChIKey    AOTYWRMIFZIYNX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          144.188;      // g/mol [origin=calculated method=formula-sum]
Tc          496.04;      // K   [origin=predictive method=joback]
Pc          51.609;      // bar [origin=predictive method=joback]
omega       0.4206;      // -   [origin=predictive method=lee-kesler]
Tb          328.52;      // K   [origin=predictive method=joback]
HvapTb      40886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.63 0.8588 -0.00070488 2.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH=CH; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3$l^{6}-thiabicyclo[3.2.0]hept-6-ene 3,3-dioxide" "3-thiabicyclo[3.2.0]hept-6-ene 3,3-dioxide" "3-thiabicyclo[3.2.0]hept-6-ene,3,3-dioxide" );
gibbsFormation
{
    dHf_298   -459010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-350560.0
    phase     gas;
}
