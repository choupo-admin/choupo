/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dimethylbenzene-1,3-dicarboxylic acid  (C10H10O4, CAS 2790-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dimethylbenzene13DicarboxylicAcid;
formula     C10H10O4;
CAS         2790-09-2;
InChIKey    HAYIPGIFANTODX-UHFFFAOYSA-N;
MW          194.186;      // g/mol [origin=calculated method=formula-sum]
Tc          991.84;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       1.2188;      // -   [origin=predictive method=lee-kesler]
Tb          761.04;      // K   [origin=predictive method=joback]
HvapTb      76444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.99 0.79804 -0.00049548 1.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -748150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-570980.0
    phase     gas;
}
