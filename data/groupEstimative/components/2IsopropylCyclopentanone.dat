/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropyl cyclopentanone  (C8H14O, CAS 14845-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IsopropylCyclopentanone;
formula     C8H14O;
CAS         14845-55-7;
InChIKey    RKZBBVUTJFJAJR-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          682.36;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.3742;      // -   [origin=predictive method=lee-kesler]
Tb          465.30;      // K   [origin=predictive method=joback]
HvapTb      37518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.12 0.73314 -0.000298 1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-ylcyclopentan-1-one" "agn-pc-0cxaq0" "2-(propan-2-yl)cyclopentan-1-one" "cyclopentanone, 2-(1-methylethyl)-" "s802" );
gibbsFormation
{
    dHf_298   -290950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72000.0
    phase     gas;
}
