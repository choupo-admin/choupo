/*--------------------------------*- Choupo -*-----------------------*\
  Component: n1,n1'-ethane-1,2-diylbis[n1-(3-aminopropyl)propane-1,3-diamine]  (C14H36N6, CAS 4879-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n1N1Ethane12DiylbisN13AminopropylPropane13Diamine;
formula     C14H36N6;
CAS         4879-98-5;
InChIKey    PJOLOHMGBICKJH-UHFFFAOYSA-N;
MW          288.484;      // g/mol [origin=calculated method=formula-sum]
Tc          1031.71;      // K   [origin=predictive method=joback]
Pc          18.294;      // bar [origin=predictive method=joback]
omega       1.3861;      // -   [origin=predictive method=lee-kesler]
Tb          834.92;      // K   [origin=predictive method=joback]
HvapTb      93408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.256 1.8292 -0.0011366 2.742e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2NH2; count 4; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 14; } { group NH2; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(3-azanylpropyl)-n'-[2-[bis(3-azanylpropyl)amino]ethyl]propane-1,3-diamine" "1,3-propanediamine, n,n''-1,2-ethanediylbis(n-(3-aminopropyl)-" "1,3-propanediamine, n,n''-1,2-ethanediylbis[n-(3-aminopropyl)-" "1,3-propanediamine, n1,n1'-1,2-ethanediylbis(n1-(3-aminopropyl)-" "1,3-propanediamine, n1,n1'-1,2-ethanediylbis[n1-(3-aminopropyl)-" "n'-(3-aminopropyl)-n'-[2-[bis(3-aminopropyl)amino]ethyl]propane-1,3-diamine" );
standardThermochemistry
{
    dHf_298   -62070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     939.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=554360.0
}
