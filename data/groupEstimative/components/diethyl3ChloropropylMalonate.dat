/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl (3-chloropropyl)malonate  (C10H17ClO4, CAS 18719-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl3ChloropropylMalonate;
formula     C10H17ClO4;
CAS         18719-43-2;
InChIKey    WUOPYKKJFZHTRA-UHFFFAOYSA-N;
MW          236.692;      // g/mol [origin=calculated method=formula-sum]
Tc          764.78;      // K   [origin=predictive method=joback]
Pc          20.718;      // bar [origin=predictive method=joback]
omega       0.8226;      // -   [origin=predictive method=lee-kesler]
Tb          581.83;      // K   [origin=predictive method=joback]
HvapTb      56665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.825 0.85694 -0.0003546 2.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2Cl; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group Cl; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-(3-chloranylpropyl)propanedioate" "malonic acid, 3-chloropropyl-, diethyl ester" "diethyl 2-(3-chloropropyl)propanedioate" "m275" "diethyl 2-(3-chloropropyl)propane-1,3-dioate" "2-(3-chloropropyl)propanedioic acid diethyl ester" "propanedioic acid, (3-chloropropyl)-, diethyl ester" "propanedioic acid,2-(3-chloropropyl)-, 1,3-diethyl ester" "malonicacid, (3-chloropropyl)-, diethyl ester (6ci,8ci);propanedioic acid,(3-chloropropyl)-, diethyl ester (9ci);chloropropylmalonic acid diethyl ester;diethyl (3-chloropropyl)malonate;diethyl (g-chloropropyl)malonate;" );
standardThermochemistry
{
    dHf_298   -905310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-601790.0
}
