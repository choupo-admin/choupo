/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethylcyclohexene  (C8H14, CAS 3742-42-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethylcyclohexene;
formula     C8H14;
CAS         3742-42-5;
InChIKey    CFOHRCNONSEVOJ-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          604.44;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.2718;      // -   [origin=predictive method=lee-kesler]
Tb          401.35;      // K   [origin=predictive method=joback]
HvapTb      34123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.209 0.82992 -0.00047968 9.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexene, 4-ethyl-" "4-ethyl-cyclohexene" );
standardThermochemistry
{
    dHf_298   -96350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=70890.0
}
