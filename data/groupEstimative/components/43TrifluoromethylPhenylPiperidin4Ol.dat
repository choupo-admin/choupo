/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[3-(trifluoromethyl)phenyl]piperidin-4-ol  (C12H14F3NO, CAS 2249-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        43TrifluoromethylPhenylPiperidin4Ol;
formula     C12H14F3NO;
CAS         2249-28-7;
InChIKey    ILKPZCKFWLTEBQ-UHFFFAOYSA-N;
MW          245.244;      // g/mol [origin=calculated method=formula-sum]
Tc          876.08;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.9927;      // -   [origin=predictive method=lee-kesler]
Tb          660.92;      // K   [origin=predictive method=joback]
HvapTb      64212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.21 1.6012 -0.00139756 5.054e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH2NH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group OH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[3-(trifluoromethyl)phenyl]-4-piperidinol" "4- pound 3-trifluoromethylphenyl)-4-piperidinol" "4-(3-trifuoromethyl)phenyl-4-piperidinol" "4-(3-trifluoromethylphenyl)-4-piperidinol" "4-piperidinol,4-[3-(trifluoromethyl)phenyl]-" "4-(3-trifluoromethylphenyl)-4-hydroxypiperidine" "4-hydroxy-4-[(3-trifluoromethyl)phenyl]piperidine" "4-(alpha,alpha,alpha-trifluoro-m-tolyl)piperidin-4-ol" "4-hydroxy-4-(3-trifluoromethylphenyl)piperidine;4-[m-(trifluoromethyl)phenyl]-4-piperidinol;4-(m-trifluoromethylphenyl)-4-hydroxypiperidine;4-(3-trifluoromethylphenyl)-4-hydroxypiperidine;4-piperidinol,4-(a,a,a-trifluoro-m-tolyl)- (7ci);" );
standardThermochemistry
{
    dHf_298   -707890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-458800.0
}
