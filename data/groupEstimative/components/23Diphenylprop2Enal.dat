/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-diphenylprop-2-enal  (C15H12O, CAS 1755-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Diphenylprop2Enal;
formula     C15H12O;
CAS         1755-47-1;
InChIKey    JYVONCAJVKBEGI-UHFFFAOYSA-N;
MW          208.26;      // g/mol [origin=calculated method=formula-sum]
Tc          899.85;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.6201;      // -   [origin=predictive method=lee-kesler]
Tb          648.86;      // K   [origin=predictive method=joback]
HvapTb      60294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.03 1.2654 -0.0009337 2.654e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-2,3-diphenylprop-2-enal" "3,3-diphenyl acrolein" "benzeneacetaldehyde, a-(phenylmethylene)-, (ae)-" "acrolein,2,3-diphenyl-, (e)- (8ci); benzeneacetaldehyde, a-(phenylmethylene)-, (e)-;(e)-2,3-diphenyl-2-propenal; (e)-2,3-diphenylacrolein;(e)-2,3-diphenylpropenal; (e)-a,b-diphenylacrolein; (e)-a-phenylcinnamaldehyde" );
gibbsFormation
{
    dHf_298   141980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272390.0
    phase     gas;
}
