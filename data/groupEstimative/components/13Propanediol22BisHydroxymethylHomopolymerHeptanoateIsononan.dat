/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-propanediol, 2,2-bis(hydroxymethyl)-, homopolymer, heptanoate isononanoate  (C21H40O6, CAS 70693-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Propanediol22BisHydroxymethylHomopolymerHeptanoateIsononan;
formula     C21H40O6;
CAS         70693-37-7;
InChIKey    NBGYYBBXBWGZDH-UHFFFAOYSA-N;
MW          388.545;      // g/mol [origin=calculated method=formula-sum]
Tc          1208.88;      // K   [origin=predictive method=joback]
Pc          11.015;      // bar [origin=predictive method=joback]
omega       0.9365;      // -   [origin=predictive method=lee-kesler]
Tb          977.21;      // K   [origin=predictive method=joback]
HvapTb      108828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.044 2.08896 -0.0011652 2.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(heptanoyloxymethyl)-2-(hydroxymethyl)-3-oxidanyl-propyl] 7-methyloctanoate" "polypentaerythritol, esters with enanthylic acid, isononanoic acid" );
standardThermochemistry
{
    dHf_298   -1429820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1129.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-768040.0
}
