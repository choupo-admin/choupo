/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodoheptane  (C7H15I, CAS 4282-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodoheptane;
formula     C7H15I;
CAS         4282-40-0;
InChIKey    LMHCYRULPLGEEZ-UHFFFAOYSA-N;
MW          226.097;      // g/mol [origin=calculated method=formula-sum]
Tc          651.13;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.4001;      // -   [origin=predictive method=lee-kesler]
Tb          452.90;      // K   [origin=predictive method=joback]
HvapTb      40549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.216 0.70782 -0.0004384 1.12e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylheptane" "n-heptyl iodide" "heptane, 1-iodo-" "heptane, iodo-" "1-iodo-heptane" "agn-pc-04y21o" "1-heptyliodide;1-iodo-n-heptane;" );
standardThermochemistry
{
    dHf_298   -110940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66180.0
}
