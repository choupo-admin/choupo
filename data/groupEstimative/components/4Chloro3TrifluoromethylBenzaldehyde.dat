/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-3-(trifluoromethyl)benzaldehyde  (C8H4ClF3O, CAS 34328-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H4ClF3O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Chloro3TrifluoromethylBenzaldehyde;
formula     C8H4ClF3O;
CAS         34328-46-6;
InChIKey    NIHMMULLFBKTOK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          208.563;      // g/mol [origin=calculated method=formula-sum]
Tc          625.36;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.3740;      // -   [origin=predictive method=lee-kesler]
Tb          427.71;      // K   [origin=predictive method=joback]
HvapTb      35267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.5 0.742 -0.00070292 2.541e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CHO; count 1; } { group ACCl; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-3-(trifluoromethyl)benzaldehyde" "2-chloro-5-formylbenzotrifluoride" "4-chloro-3-trifluoromethylbenzaldehyde" "4-chloro-3-trifluoromethyl-benzaldehyde" "4-chloro-3-trifluoromethylbenzaldehyde;" "34328-46-6 3-trifluoromethyl-4-chlorobenzaldehyde" );
standardThermochemistry
{
    dHf_298   -531230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-439930.0
}
