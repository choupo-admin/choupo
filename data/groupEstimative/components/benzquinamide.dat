/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzquinamide  (C22H32N2O5, CAS 63-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzquinamide;
formula     C22H32N2O5;
CAS         63-12-7;
InChIKey    JSZILQVIPPROJI-UHFFFAOYSA-N;
MW          404.507;      // g/mol [origin=calculated method=formula-sum]
Tc          1157.22;      // K   [origin=predictive method=joback]
Pc          13.108;      // bar [origin=predictive method=joback]
omega       1.1373;      // -   [origin=predictive method=lee-kesler]
Tb          939.47;      // K   [origin=predictive method=joback]
HvapTb      91576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.398 2.1408 -0.00123158 2.4096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3COO; count 1; } { group CH3O; count 2; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group CdO; count 1; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-(diethylcarbamoyl)-9,10-dimethoxy-2,3,4,6,7,11b-hexahydro-1h-benzo[a]quinolizin-2-yl] ethanoate" "quantril" "promecon" "emete-con" "benzchinamide" "benzochinamide" "emeticon" "quantryl" "benzchinamidum" "benzoquinamide" "benzquinamidum" "benzquinamida" );
standardThermochemistry
{
    dHf_298   -735430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108160.0
}
