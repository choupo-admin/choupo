/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4-trichlorobutane  (C4H7Cl3, CAS 1790-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124Trichlorobutane;
formula     C4H7Cl3;
CAS         1790-22-3;
InChIKey    PIQHRAXKAGNHCM-UHFFFAOYSA-N;
MW          161.45;      // g/mol [origin=calculated method=formula-sum]
Tc          597.88;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.3490;      // -   [origin=predictive method=lee-kesler]
Tb          402.97;      // K   [origin=predictive method=joback]
HvapTb      37265.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.243 0.4101 -0.0002582 6.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2Cl; count 2; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tris(chloranyl)butane" );
gibbsFormation
{
    dHf_298   -178390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55430.0
    phase     gas;
}
