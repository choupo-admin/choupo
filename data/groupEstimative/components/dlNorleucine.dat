/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-norleucine  (C6H13NO2, CAS 616-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlNorleucine;
formula     C6H13NO2;
CAS         616-06-8;
InChIKey    LRQKBLKVPFOOQJ-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          757.90;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.8493;      // -   [origin=predictive method=lee-kesler]
Tb          554.48;      // K   [origin=predictive method=joback]
HvapTb      56367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.843 0.69242 -0.0004218 9.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylhexanoic acid" "norleucine" "2-aminohexanoic acid" "norleucine, dl-" "norleucine, l-" "dl-2-aminohexanoic acid" "2-aminohexanoic acid, dl-" "hexanoic acid, (s)-" ".alpha.-aminocaproic acid" "(+/-)-2-aminocaproic acid" "d-(-)-norleucine" "2-amino-hexanoic acid" );
gibbsFormation
{
    dHf_298   -488930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-280260.0
    phase     gas;
}
