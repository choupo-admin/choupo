/*--------------------------------*- Choupo -*-----------------------*\
  Component: gamma-chlordan  (C10H6Cl8, CAS 5566-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gammaChlordan;
formula     C10H6Cl8;
CAS         5566-34-7;
InChIKey    JBZJEPYXXVKOKF-UHFFFAOYSA-N;
MW          409.758;      // g/mol [origin=calculated method=formula-sum]
Tc          1037.27;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       0.5689;      // -   [origin=predictive method=lee-kesler]
Tb          748.40;      // K   [origin=predictive method=joback]
HvapTb      68930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-204.69 2.3644 -0.003115 1.5096e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CCl2; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "gamma-chlordane" "2,2,4,5,6,7,8,8-octachloro-2,3,3a,4,7,7a-hexahydro-4,7-methano-1h-indene" "4,7-methano-1h-indene, 2,2,4,5,6,7,8,8-octachloro-2,3,3a,4,7,7a-hexahydro-" "2,2,4,5,6,7,8,8-octachloro-3a,4,7,7a-tetrahydro-4,7-methanoindan" "4,7-methanoindan, 2,2,4,5,6,7,8,8-octachloro-3a,4,7,7a-tetrahydro-, stereoisomer" "2,2,4,5,6,7,8,8-octachloro-2,3,3a,4,7,7a-hexahydro-1h-4,7-methanoindene" );
gibbsFormation
{
    dHf_298   -128630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     663.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73640.0
    phase     gas;
}
