/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,11-undecanediol  (C11H24O2, CAS 765-04-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Undecanediol;
formula     C11H24O2;
CAS         765-04-8;
InChIKey    XSMIOONHPKRREI-UHFFFAOYSA-N;
MW          188.311;      // g/mol [origin=calculated method=formula-sum]
Tc          793.73;      // K   [origin=predictive method=joback]
Pc          22.893;      // bar [origin=predictive method=joback]
omega       1.4332;      // -   [origin=predictive method=lee-kesler]
Tb          635.64;      // K   [origin=predictive method=joback]
HvapTb      73438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.471 1.1168 -0.0006354 1.393e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 11; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecane-1,11-diol" );
standardThermochemistry
{
    dHf_298   -574830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231900.0
}
