/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-di-tert-butyl chlorobenzene  (C14H21Cl, CAS 80438-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35DiTertButylChlorobenzene;
formula     C14H21Cl;
CAS         80438-67-1;
InChIKey    UMPNQCBQSXTKID-UHFFFAOYSA-N;
MW          224.772;      // g/mol [origin=calculated method=formula-sum]
Tc          812.78;      // K   [origin=predictive method=joback]
Pc          19.579;      // bar [origin=predictive method=joback]
omega       0.4450;      // -   [origin=predictive method=lee-kesler]
Tb          587.53;      // K   [origin=predictive method=joback]
HvapTb      52151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.2 1.39442 -0.00099892 2.839e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-ditert-butyl-5-chloranyl-benzene" "1,3-ditert-butyl-5-chlorobenzene" "benzene, 1-chloro-3,5-bis(1,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   -151940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153900.0
    phase     gas;
}
