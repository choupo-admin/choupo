/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecanedioic acid  (C16H30O4, CAS 505-54-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecanedioicAcid;
formula     C16H30O4;
CAS         505-54-4;
InChIKey    QQHJDPROMQRDLA-UHFFFAOYSA-N;
MW          286.412;      // g/mol [origin=calculated method=formula-sum]
Tc          1053.44;      // K   [origin=predictive method=joback]
Pc          15.070;      // bar [origin=predictive method=joback]
omega       1.2824;      // -   [origin=predictive method=lee-kesler]
Tb          856.70;      // K   [origin=predictive method=joback]
HvapTb      85538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.456 1.6254 -0.0009918 2.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 14; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thapsic acid" "1,14-tetradecanedicarboxylic acid" "1,16-hexadecanedioic acid" "hexadecane-1,16-dioic acid" "n-tetradecane-.omega.,.omega.'-dicarboxylic acid" "1,16-hexadecanedioate" "thapsate" "hexadecanedioic" "a,w-tetradecanedicarboxylate" "1,14-tetradecanedicarboxylate" "a,w-tetradecanedicarboxylic acid" "n-tetradecane-w,w'-dicarboxylate" );
gibbsFormation
{
    dHf_298   -1074110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     885.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-603980.0
    phase     gas;
}
