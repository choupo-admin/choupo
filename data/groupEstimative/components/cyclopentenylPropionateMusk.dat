/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentenyl propionate musk  (C17H28O2, CAS 84012-64-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentenylPropionateMusk;
formula     C17H28O2;
CAS         84012-64-6;
InChIKey    RWSDULKUTPNPMB-UHFFFAOYSA-N;
MW          264.409;      // g/mol [origin=calculated method=formula-sum]
Tc          863.17;      // K   [origin=predictive method=joback]
Pc          14.873;      // bar [origin=predictive method=joback]
omega       0.7059;      // -   [origin=predictive method=lee-kesler]
Tb          664.51;      // K   [origin=predictive method=joback]
HvapTb      60830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.417 1.6265 -0.000984 2.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group CH2COO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-dimethyl-3-(2-methyl-5-prop-1-en-2-yl-cyclopenten-1-yl)propyl] propanoate" "2-(2,2-dimethyl-3-propionyl)-1-methyl-3-(methylethenyl)cyclopentene" "5-isopropenyl-beta,beta,2-trimethylcyclopent-1-ene-1-propyl propionate" "1-cyclopentene-1-propanol, 5-(1-methylethenyl)-beta,beta,2-trimethyl-, propanoate" "1-cyclopentene-1-propanol, beta,beta,2-trimethyl-5-(1-methylethenyl)-, propanoate" "5-(1-methylethenyl)-beta,beta,2-trimethyl-1-cyclopentene-1-propanol propanoate" "[2,2-dimethyl-3-(2-methyl-5-prop-1-en-2-ylcyclopenten-1-yl)propyl] propanoate" "1-cyclopentene-1-propanol, .beta.,.beta.,2-trimethyl-5-(1-methylethenyl)-, 1-propanoate" "1-cyclopentene-1-propanol, .beta.,.beta.,2-trimethyl-5-(1-methylethenyl)-, propanoate" "1-cyclopentene-1-propanol, beta,beta,2-trimethyl-5-(1-methylethenyl)-, 1-propanoate" );
standardThermochemistry
{
    dHf_298   -509280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88730.0
}
