/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)cyclohexanecarboxylic acid  (C13H15ClO2, CAS 58880-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ChlorophenylCyclohexanecarboxylicAcid;
formula     C13H15ClO2;
CAS         58880-37-8;
InChIKey    UPNXUJXIIZGXLQ-UHFFFAOYSA-N;
MW          238.711;      // g/mol [origin=calculated method=formula-sum]
Tc          988.54;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.8061;      // -   [origin=predictive method=lee-kesler]
Tb          731.43;      // K   [origin=predictive method=joback]
HvapTb      68297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.64 1.572 -0.00135416 4.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)cyclohexane-1-carboxylic acid" "1-(4-chlorophenyl)-1-cyclohexanecarboxylic acid" "cyclohexanecarboxylicacid, 1-(4-chlorophenyl)-" "1-(4-chlorophenyl)-1-cyclohexane-carboxylic acid" "1-(4-chlorophenyl)cyclohexanecarboxylicacid;tai 746;" "1-(4-chlorophenyl)-1-cyclohexanecarboxylic acid, 95%" );
gibbsFormation
{
    dHf_298   -383040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-175520.0
    phase     gas;
}
