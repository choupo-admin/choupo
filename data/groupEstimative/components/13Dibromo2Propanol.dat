/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibromo-2-propanol  (C3H6Br2O, CAS 96-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibromo2Propanol;
formula     C3H6Br2O;
CAS         96-21-9;
InChIKey    KIHQZLPHVZKELA-UHFFFAOYSA-N;
MW          217.888;      // g/mol [origin=calculated method=formula-sum]
Tc          693.88;      // K   [origin=predictive method=joback]
Pc          62.196;      // bar [origin=predictive method=joback]
omega       0.8786;      // -   [origin=predictive method=lee-kesler]
Tb          492.30;      // K   [origin=predictive method=joback]
HvapTb      51433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.152 0.4051 -0.0003158 1.02e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group Br; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)propan-2-ol" "1,3-dibromopropan-2-ol" "2-propanol, 1,3-dibromo-" "1,3-dibromohydrin" ".alpha.-dibromohydrin" "glycerol 1,3-dibromohydrin" "alpha-dibromohydrin" "2-hydroxy-1,3-dibromopropane" "1,3-dibromo-2-hydroxypropane" "glycerol alpha,gamma-dibromohydrin" "glycerol alpha,gamma-dibromohydrine" "glycerol-alpha,gamma-dibromohydrine" );
gibbsFormation
{
    dHf_298   -210100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136240.0
    phase     gas;
}
