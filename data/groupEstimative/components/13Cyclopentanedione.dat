/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-cyclopentanedione  (C5H6O2, CAS 3859-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Cyclopentanedione;
formula     C5H6O2;
CAS         3859-41-4;
InChIKey    LOGSONSNCYTHPS-UHFFFAOYSA-N;
MW          98.101;      // g/mol [origin=calculated method=formula-sum]
Tc          711.25;      // K   [origin=predictive method=joback]
Pc          49.944;      // bar [origin=predictive method=joback]
omega       0.3959;      // -   [origin=predictive method=lee-kesler]
Tb          469.59;      // K   [origin=predictive method=joback]
HvapTb      35784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.78 0.3004 5.7e-05 -1.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane-1,3-dione" "1,3-cyclopentadione" "cyclopentan-1,3-dion" "1,3-dioxocyclopentane" "cyclopentane-1,3-quinone" "agn-pc-0czn9j" "1.3-cyclopentanedione" "maleimide-related compound 12" "logsonsncythps-uhfffaoysa-" "q573" );
standardThermochemistry
{
    dHf_298   -341110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     185.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209700.0
}
