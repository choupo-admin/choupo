/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,8-trimethyl-4,9-decadienal  (C13H22O, CAS 72928-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        248Trimethyl49Decadienal;
formula     C13H22O;
CAS         72928-00-8;
InChIKey    ZFSXPBRJVFBKHU-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          730.20;      // K   [origin=predictive method=joback]
Pc          19.287;      // bar [origin=predictive method=joback]
omega       0.6420;      // -   [origin=predictive method=lee-kesler]
Tb          545.54;      // K   [origin=predictive method=joback]
HvapTb      49844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.757 1.22506 -0.0007918 2.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,8-trimethyldeca-4,9-dienal" "4,9-decadienal, 2,4,8-trimethyl-" "4,9-decadienal,2,4,8-trimethyl-" );
gibbsFormation
{
    dHf_298   -174930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113690.0
    phase     gas;
}
