/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydrocinnamic acid  (C9H10O2, CAS 501-52-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydrocinnamicAcid;
formula     C9H10O2;
CAS         501-52-0;
InChIKey    XMIIGOLPHOKFCH-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          801.80;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.7280;      // -   [origin=predictive method=lee-kesler]
Tb          577.71;      // K   [origin=predictive method=joback]
HvapTb      55068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.598 0.8307 -0.0005696 1.494e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropanoic acid" "3-phenylpropionic acid" "benzylacetic acid" "benzenepropanoic acid" "dihydrocinnamic acid" "benzenepropionic acid" "beta-phenylpropionic acid" "phenylpropanoate" "3-phenyl-propionic acid" "phenylpropanoic acid" "phenyl propionic acid" "benzylacetate" );
standardThermochemistry
{
    dHf_298   -342830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206600.0
}
