/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-citronellyl bromide  (C10H19Br, CAS 143615-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sCitronellylBromide;
formula     C10H19Br;
CAS         143615-81-0;
InChIKey    QPKCDMXLSDFCQD-JTQLQIEISA-N;
MW          219.166;      // g/mol [origin=calculated method=formula-sum]
Tc          691.39;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.5256;      // -   [origin=predictive method=lee-kesler]
Tb          498.16;      // K   [origin=predictive method=joback]
HvapTb      43939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.566 1.01786 -0.0006809 1.906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6s)-8-bromanyl-2,6-dimethyl-oct-2-ene" "(s)-()-citronellyl bromide" "2-octene,8-bromo-2,6-dimethyl-, (6s)-" "2-octene,8-bromo-2,6-dimethyl-, (s)-; (s)-(+)-citronellyl bromide;(s)-8-bromo-2,6-dimethyl-2-octene; (s)-citronellyl bromide" );
standardThermochemistry
{
    dHf_298   -121250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116870.0
}
