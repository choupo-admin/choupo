/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-butanol  (C5H12O, CAS 137-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Butanol;
formula     C5H12O;
CAS         137-32-6;
InChIKey    QPRQEDXDYOZYLA-UHFFFAOYSA-N;
MW          88.15;      // g/mol [origin=calculated method=formula-sum]
Tc          571.04;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.6755;      // -   [origin=predictive method=lee-kesler]
Tb          405.74;      // K   [origin=predictive method=joback]
HvapTb      43015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.952 0.51874 -0.0002818 5.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbutan-1-ol" "sec-butylcarbinol" "active amyl alcohol" "1-butanol, 2-methyl-" "2-methylbutanol" "2-methyl-n-butanol" "2-methylbutyl alcohol" "primary active amyl alcohol" "2-methyl butanol-1" "active primary amyl alcohol" "dl-2-methyl-1-butanol" "(+/-)-2-methyl-1-butanol" );
standardThermochemistry
{
    dHf_298   -304040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148040.0
}
