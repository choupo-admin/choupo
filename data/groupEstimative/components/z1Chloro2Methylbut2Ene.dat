/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-1-chloro-2-methylbut-2-ene  (C5H9Cl, CAS 23009-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z1Chloro2Methylbut2Ene;
formula     C5H9Cl;
CAS         23009-74-7;
InChIKey    ZAJKEDQTROWDDD-HYXAFXHYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          541.41;      // K   [origin=predictive method=joback]
Pc          35.515;      // bar [origin=predictive method=joback]
omega       0.2567;      // -   [origin=predictive method=lee-kesler]
Tb          355.47;      // K   [origin=predictive method=joback]
HvapTb      31147.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.639 0.50554 -0.0003547 1.065e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-1-chloranyl-2-methyl-but-2-ene" "cis-1-chloro-2-methyl-2-butene" );
standardThermochemistry
{
    dHf_298   -54840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50960.0
}
