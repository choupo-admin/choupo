/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-1-methylcyclohexane  (C7H13Cl, CAS 931-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro1Methylcyclohexane;
formula     C7H13Cl;
CAS         931-78-2;
InChIKey    OGYBTPYJHQSBBR-UHFFFAOYSA-N;
MW          132.631;      // g/mol [origin=calculated method=formula-sum]
Tc          637.75;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.2419;      // -   [origin=predictive method=lee-kesler]
Tb          416.98;      // K   [origin=predictive method=joback]
HvapTb      34839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.18 1.08962 -0.000991 3.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-1-methyl-cyclohexane" "1-chloro-1-methyl-cyclohexane" );
gibbsFormation
{
    dHf_298   -133990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15090.0
    phase     gas;
}
