/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylethane-1,2-diyl maleate  (C7H8O4, CAS 71550-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylethane12DiylMaleate;
formula     C7H8O4;
CAS         71550-61-3;
InChIKey    ZLUFYQVHJAVDHU-IHWYPQMZSA-N;
MW          156.137;      // g/mol [origin=calculated method=formula-sum]
Tc          689.38;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.5829;      // -   [origin=predictive method=lee-kesler]
Tb          486.37;      // K   [origin=predictive method=joback]
HvapTb      46367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.24 0.64452 -0.00032888 3.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6z)-2-methyl-2,3-dihydro-1,4-dioxocine-5,8-dione" );
standardThermochemistry
{
    dHf_298   -697950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-534070.0
}
