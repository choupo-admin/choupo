/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2'-chlorobiphenyl-2,5-diol  (C12H9ClO2, CAS 117-71-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorobiphenyl25Diol;
formula     C12H9ClO2;
CAS         117-71-5;
InChIKey    XRKJFSFMYUQOSD-UHFFFAOYSA-N;
MW          220.652;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.98;      // K   [origin=predictive method=joback]
Pc          46.785;      // bar [origin=predictive method=joback]
omega       0.9490;      // -   [origin=predictive method=lee-kesler]
Tb          731.17;      // K   [origin=predictive method=joback]
HvapTb      77933.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.48 1.2425 -0.00115748 4.329e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 2; } { group ACOH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 1; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chlorophenyl)benzene-1,4-diol" "(1,1'-biphenyl)-2,5-diol, 2'-chloro-" "2'-chloro(1,1'-biphenyl)-2,5-diol" "2-(2-chlorophenyl)-hydroquinone" "[1,1'-biphenyl]-2,5-diol, 2'-chloro-" "2'-chloro[1,1'-biphenyl]-2,5-diol" "[1,1'-biphenyl]-2,5-diol,2'-chloro-" "hydroquinone,(o-chlorophenyl)- (8ci); (o-chlorophenyl)hydroquinone;2-(2-chlorophenyl)hydroquinone" );
standardThermochemistry
{
    dHf_298   -199780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55820.0
}
