/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenoxypropyl methacrylate  (C13H16O3, CAS 67923-42-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenoxypropylMethacrylate;
formula     C13H16O3;
CAS         67923-42-6;
InChIKey    JNRPOURQJNXRPA-UHFFFAOYSA-N;
MW          220.268;      // g/mol [origin=calculated method=formula-sum]
Tc          806.91;      // K   [origin=predictive method=joback]
Pc          22.676;      // bar [origin=predictive method=joback]
omega       0.7113;      // -   [origin=predictive method=lee-kesler]
Tb          600.92;      // K   [origin=predictive method=joback]
HvapTb      56035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.393 1.02182 -0.0005342 7.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenoxypropyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 3-phenoxypropyl ester" "methacrylic acid, 3-phenoxypropyl ester" );
standardThermochemistry
{
    dHf_298   -408980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-165090.0
}
