/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(dimethylamino)-3-biphenylol  (C14H15NO, CAS 63019-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Dimethylamino3Biphenylol;
formula     C14H15NO;
CAS         63019-93-2;
InChIKey    ORIAIGHQLDPLDL-UHFFFAOYSA-N;
MW          213.28;      // g/mol [origin=calculated method=formula-sum]
Tc          916.66;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.7782;      // -   [origin=predictive method=lee-kesler]
Tb          671.32;      // K   [origin=predictive method=joback]
HvapTb      67029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.96 1.39504 -0.00110212 3.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)-5-phenyl-phenol" "4-dimethylamino-3-hydroxydiphenyl" "3-biphenylol, 4-(dimethylamino)-" "2-(dimethylamino)-5-phenylphenol" );
standardThermochemistry
{
    dHf_298   19520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238350.0
}
