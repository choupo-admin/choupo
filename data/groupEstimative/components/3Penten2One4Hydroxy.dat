/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-penten-2-one, 4-hydroxy-  (C5H8O2, CAS 1522-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Penten2One4Hydroxy;
formula     C5H8O2;
CAS         1522-20-9;
InChIKey    POILWHVDKZOXJZ-ARJAWSKDSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          648.23;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       0.7930;      // -   [origin=predictive method=lee-kesler]
Tb          464.09;      // K   [origin=predictive method=joback]
HvapTb      50187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.88 0.50474 -0.000346 9.826e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-4-oxidanylpent-3-en-2-one" "3-penten-2-one, 4-hydroxy-, (3z)-" "z-2-pentene-4-one-2-ol" "(z)-4-hydroxypent-3-en-2-one" "(3z)-4-hydroxypent-3-en-2-one" );
gibbsFormation
{
    dHf_298   -303910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202850.0
    phase     gas;
}
