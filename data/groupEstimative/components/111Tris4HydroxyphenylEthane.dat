/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-tris(4-hydroxyphenyl)ethane  (C20H18O3, CAS 27955-94-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Tris4HydroxyphenylEthane;
formula     C20H18O3;
CAS         27955-94-8;
InChIKey    BRPSWMCDEYMRPE-UHFFFAOYSA-N;
MW          306.361;      // g/mol [origin=calculated method=formula-sum]
Tc          1259.88;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       1.3493;      // -   [origin=predictive method=lee-kesler]
Tb          975.87;      // K   [origin=predictive method=joback]
HvapTb      104688.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-168.24 2.25672 -0.00209868 7.745e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 12; } { group AC; count 3; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1,1-bis(4-hydroxyphenyl)ethyl]phenol" "phenol, 4,4',4''-ethylidynetris-" "4,4',4''-ethylidynetrisphenol" "tris(4-hydroxyphenyl)ethane" "4,4',4''-(ethane-1,1,1-triyl)triphenol" "agn-pc-0cr297" "triphenylmethane derivative, 7" "phenol, 4,4',4''-ethylidynetri-" ""4,4,4""-ethane-1,1,1-triyltriphenol"" ""4,4',4""-ethane-1,1,1-triyltriphenol"" "o215" "phenol, 4,4',4''-ethylidynetri- (8ci)" );
standardThermochemistry
{
    dHf_298   -287220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6270.0
}
