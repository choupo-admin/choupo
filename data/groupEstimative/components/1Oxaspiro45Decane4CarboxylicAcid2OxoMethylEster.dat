/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-oxaspiro(4.5)decane-4-carboxylic acid, 2-oxo-, methyl ester  (C11H16O4, CAS 2819-57-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Oxaspiro45Decane4CarboxylicAcid2OxoMethylEster;
formula     C11H16O4;
CAS         2819-57-0;
InChIKey    CWZOQLTZSMTILL-UHFFFAOYSA-N;
MW          212.245;      // g/mol [origin=calculated method=formula-sum]
Tc          808.96;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.6695;      // -   [origin=predictive method=lee-kesler]
Tb          589.98;      // K   [origin=predictive method=joback]
HvapTb      53913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.01 1.51372 -0.0012656 4.423e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-oxidanylidene-1-oxaspiro[4.5]decane-4-carboxylate" "1-oxaspiro[4.5]decane-4-carboxylic acid, 2-oxo-, methyl ester" "methyl 3-oxo-4-oxaspiro[4.5]decane-1-carboxylate" );
gibbsFormation
{
    dHf_298   -756410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-487190.0
    phase     gas;
}
