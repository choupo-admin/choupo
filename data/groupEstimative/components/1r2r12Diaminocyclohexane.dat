/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-(-)-1,2-diaminocyclohexane  (C6H14N2, CAS 20439-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2r12Diaminocyclohexane;
formula     C6H14N2;
CAS         20439-47-8;
InChIKey    SSJXIUAHEKJCMH-PHDIDXHHSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          730.32;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       0.4850;      // -   [origin=predictive method=lee-kesler]
Tb          496.82;      // K   [origin=predictive method=joback]
HvapTb      50352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.25 0.7932 -0.000415 6.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CHNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2r)-cyclohexane-1,2-diamine" "trans-1,2-diaminocyclohexane" "r-dach" "(1r,2r)-1,2-diaminocyclohexane" "(1r)-trans-1,2-cyclohexanediamine" "(1r,2r)-diaminocyclohexane" "rr-diaminocyclohexane" "trans-cyclohexane-1,2-diamine" "(1r,2r)-(-)-1,2-cyclohexanediamine" "trans-1,2-cyclohexanediamine" "(1r)-(-)-trans-1,2-diaminocyclohexane" "1r,2r-diaminocyclohexane" );
standardThermochemistry
{
    dHf_298   -65610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149280.0
}
