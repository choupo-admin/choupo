/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hepten-2-one  (C7H12O, CAS 24332-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hepten2One;
formula     C7H12O;
CAS         24332-22-7;
InChIKey    VQKIKHHXFHNXJT-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          603.39;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       0.4405;      // -   [origin=predictive method=lee-kesler]
Tb          417.79;      // K   [origin=predictive method=joback]
HvapTb      37880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.298 0.66084 -0.0004221 1.1046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hept-4-en-2-one" "4-hepten-2-one, (4z)-" );
gibbsFormation
{
    dHf_298   -183170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40640.0
    phase     gas;
}
