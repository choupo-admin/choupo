/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,6-difluorophenyl)butan-1-one  (C10H10F2O, CAS 95727-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        126DifluorophenylButan1One;
formula     C10H10F2O;
CAS         95727-77-8;
InChIKey    MNDPYRXCTIANDJ-UHFFFAOYSA-N;
MW          184.185;      // g/mol [origin=calculated method=formula-sum]
Tc          713.67;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.6342;      // -   [origin=predictive method=lee-kesler]
Tb          517.45;      // K   [origin=predictive method=joback]
HvapTb      46566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.032 0.75152 -0.00043142 8.566e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2CO; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,6-bis(fluoranyl)phenyl]butan-1-one" "2,6-difluorobutyrophenone" "1-(2,6-difluorophenyl)-1-butanone" );
standardThermochemistry
{
    dHf_298   -540940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-392070.0
}
