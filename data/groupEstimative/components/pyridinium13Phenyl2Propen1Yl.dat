/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyridinium,1-(3-phenyl-2-propen-1-yl)-  (C14H15N, CAS 125713-88-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyridinium13Phenyl2Propen1Yl;
formula     C14H15N;
CAS         125713-88-4;
InChIKey    GTNKQCHKXUPRRF-UHFFFAOYSA-N;
MW          197.281;      // g/mol [origin=calculated method=formula-sum]
Tc          815.98;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.5341;      // -   [origin=predictive method=lee-kesler]
Tb          581.47;      // K   [origin=predictive method=joback]
HvapTb      52185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.479 1.445 -0.00112276 3.418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-phenylprop-2-enyl)-2h-pyridine" "pyridinium,1-(3-phenyl-2-propenyl)- (9ci)" );
gibbsFormation
{
    dHf_298   285370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=474590.0
    phase     gas;
}
