/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-hydroxyethyl)cyclohexanol  (C8H16O2, CAS 24337-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21HydroxyethylCyclohexanol;
formula     C8H16O2;
CAS         24337-52-8;
InChIKey    MVYIQVQYQBTWRR-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          765.56;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       1.1848;      // -   [origin=predictive method=lee-kesler]
Tb          581.44;      // K   [origin=predictive method=joback]
HvapTb      66492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.15 0.93332 -0.000501 8.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 3; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-hydroxyethyl)cyclohexan-1-ol" "agn-pc-00mx21" "2-(alpha-hydroxyethyl)cyclohexanol" "cyclohexanemethanol, 2-hydroxy-alpha-methyl-" "cyclohexanemethanol, 2-hydroxy-.alpha.-methyl-," );
standardThermochemistry
{
    dHf_298   -484210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242860.0
}
