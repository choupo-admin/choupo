/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo(5.4.2)trideca-7,9,11,12-tetraene  (C13H16, CAS 33800-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo542Trideca791112Tetraene;
formula     C13H16;
CAS         33800-90-7;
InChIKey    XRXWAKCPFJMTBC-IRMDFWPKSA-N;
MW          172.271;      // g/mol [origin=calculated method=formula-sum]
Tc          805.14;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       0.3959;      // -   [origin=predictive method=lee-kesler]
Tb          556.35;      // K   [origin=predictive method=joback]
HvapTb      48672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.42 1.1834 -0.00072484 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH=CH; count 2; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1z,7z,9z,12z)-bicyclo[5.4.2]trideca-1(11),7,9,12-tetraene" );
gibbsFormation
{
    dHf_298   39690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=211380.0
    phase     gas;
}
