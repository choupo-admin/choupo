/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,8-dimethyl-3,4-dihydro-1(2h)-naphthalenone  (C12H14O, CAS 5037-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        58Dimethyl34Dihydro12hNaphthalenone;
formula     C12H14O;
CAS         5037-63-8;
InChIKey    ZSMGKPHICFZGQU-UHFFFAOYSA-N;
MW          174.243;      // g/mol [origin=calculated method=formula-sum]
Tc          840.59;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.5541;      // -   [origin=predictive method=lee-kesler]
Tb          599.28;      // K   [origin=predictive method=joback]
HvapTb      51209.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.9 0.88594 -0.00044428 6.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,8-dimethyl-3,4-dihydro-2h-naphthalen-1-one" "1(2h)-naphthalenone, 3,4-dihydro-5,8-dimethyl-" "5,8-dimethyl-1-tetralone" "t330" "1(2h)-naphthalenone,4-dihydro-5,8-dimethyl-" "5,8-dimethyl-3,4-dihydronaphthalen-1(2h)-one" "1(2h)-naphthalenone,3,4-dihydro-5,8-dimethyl-" );
standardThermochemistry
{
    dHf_298   -139610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67450.0
}
