/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2094671  (C14H23N, CAS 33132-61-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2094671;
formula     C14H23N;
CAS         33132-61-5;
InChIKey    FJOZZUIUWQVWPT-UHFFFAOYSA-N;
MW          205.345;      // g/mol [origin=calculated method=formula-sum]
Tc          757.81;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       0.5764;      // -   [origin=predictive method=lee-kesler]
Tb          558.16;      // K   [origin=predictive method=joback]
HvapTb      50301.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.798 1.39068 -0.000888 2.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,3-trimethyl-2-phenyl-pentan-1-amine" "beta-sec-butyl-n,n-dimethylphenethylamine" "phenethylamine, beta-(sec-butyl)-n,n-dimethyl-" );
standardThermochemistry
{
    dHf_298   -38790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285310.0
}
