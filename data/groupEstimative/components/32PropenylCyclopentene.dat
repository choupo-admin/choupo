/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-propenyl)cyclopentene  (C8H12, CAS 14564-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32PropenylCyclopentene;
formula     C8H12;
CAS         14564-97-7;
InChIKey    VWGHETFSGHHDRB-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          592.94;      // K   [origin=predictive method=joback]
Pc          33.490;      // bar [origin=predictive method=joback]
omega       0.2792;      // -   [origin=predictive method=lee-kesler]
Tb          393.76;      // K   [origin=predictive method=joback]
HvapTb      33281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.079 0.8195 -0.00054898 1.451e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-enylcyclopentene" "cyclopentene,3-(2-propenyl)-" );
standardThermochemistry
{
    dHf_298   35240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170830.0
}
