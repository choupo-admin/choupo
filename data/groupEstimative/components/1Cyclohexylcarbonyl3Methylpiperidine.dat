/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(cyclohexylcarbonyl)-3-methylpiperidine  (C13H23NO, CAS 63441-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexylcarbonyl3Methylpiperidine;
formula     C13H23NO;
CAS         63441-20-3;
InChIKey    NPXDSRAYXKEXAV-UHFFFAOYSA-N;
MW          209.333;      // g/mol [origin=calculated method=formula-sum]
Tc          822.42;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.5942;      // -   [origin=predictive method=lee-kesler]
Tb          598.18;      // K   [origin=predictive method=joback]
HvapTb      54007.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.35 1.58852 -0.0009857 2.2096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexyl-(3-methylpiperidin-1-yl)methanone" "piperidine, 1-(cyclohexylcarbonyl)-3-methyl-" "cyclohexyl 3-methylpiperidyl ketone" );
standardThermochemistry
{
    dHf_298   -241900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101440.0
}
