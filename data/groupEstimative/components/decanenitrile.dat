/*--------------------------------*- Choupo -*-----------------------*\
  Component: decanenitrile  (C10H19N, CAS 1975-78-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decanenitrile;
formula     C10H19N;
CAS         1975-78-6;
InChIKey    HBZDPWBWBJMYRY-UHFFFAOYSA-N;
MW          153.269;      // g/mol [origin=calculated method=formula-sum]
Tc          711.87;      // K   [origin=predictive method=joback]
Pc          20.605;      // bar [origin=predictive method=joback]
omega       0.6617;      // -   [origin=predictive method=lee-kesler]
Tb          530.48;      // K   [origin=predictive method=joback]
HvapTb      48332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.798 0.88862 -0.0004892 1.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "caprinitrile" "decanonitrile" "1-cyanononane" "n-decanenitrile" "nonyl cyanide" "decanoic acid nitrile" );
standardThermochemistry
{
    dHf_298   -84850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166500.0
}
