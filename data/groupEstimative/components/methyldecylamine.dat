/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyldecylamine  (C11H25N, CAS 7516-82-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyldecylamine;
formula     C11H25N;
CAS         7516-82-7;
InChIKey    IKVDMBQGHZVMRN-UHFFFAOYSA-N;
MW          171.328;      // g/mol [origin=calculated method=formula-sum]
Tc          666.88;      // K   [origin=predictive method=joback]
Pc          19.561;      // bar [origin=predictive method=joback]
omega       0.6964;      // -   [origin=predictive method=lee-kesler]
Tb          501.45;      // K   [origin=predictive method=joback]
HvapTb      46516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.321 1.12504 -0.0006232 1.302e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyldecan-1-amine" "decylmethylamine" "decyl-methyl-amine" );
gibbsFormation
{
    dHf_298   -216900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131130.0
    phase     gas;
}
