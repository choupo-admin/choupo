/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl 1-cyclohexene-1-acetate  (C11H18O2, CAS 93952-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropyl1Cyclohexene1Acetate;
formula     C11H18O2;
CAS         93952-58-0;
InChIKey    LXDRIYLDFQGETL-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          744.66;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.5556;      // -   [origin=predictive method=lee-kesler]
Tb          537.42;      // K   [origin=predictive method=joback]
HvapTb      48791.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.849 1.03304 -0.00053984 7.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 2-(cyclohexen-1-yl)ethanoate" "propan-2-yl 2-(cyclohexen-1-yl)acetate" "1-cyclohexene-1-acetic acid 1-methylethyl ester" );
gibbsFormation
{
    dHf_298   -471960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-218580.0
    phase     gas;
}
