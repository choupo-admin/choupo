/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanoic acid, 1,4-dioxaspiro[4.5]dec-2-ylmethyl ester  (C27H50O4, CAS 223736-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanoicAcid14Dioxaspiro45Dec2YlmethylEster;
formula     C27H50O4;
CAS         223736-95-6;
InChIKey    BQYWSIXWGYRUSU-UHFFFAOYSA-N;
MW          438.693;      // g/mol [origin=calculated method=formula-sum]
Tc          1175.67;      // K   [origin=predictive method=joback]
Pc          8.560;      // bar [origin=predictive method=joback]
omega       0.8267;      // -   [origin=predictive method=lee-kesler]
Tb          960.28;      // K   [origin=predictive method=joback]
HvapTb      91486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.563 3.06332 -0.00211 6.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group C; count 1; } { group CH2COO; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dioxaspiro[4.5]decan-3-ylmethyl octadecanoate" "1,4-dioxaspiro[4.5]decane-2-methanol,stearate (5ci)" );
standardThermochemistry
{
    dHf_298   -1045690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1125.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238540.0
}
