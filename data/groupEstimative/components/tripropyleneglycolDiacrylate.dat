/*--------------------------------*- Choupo -*-----------------------*\
  Component: tripropyleneglycol diacrylate  (C15H24O6, CAS 89190-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tripropyleneglycolDiacrylate;
formula     C15H24O6;
CAS         89190-98-7;
InChIKey    ZDQNWDNMNKSMHI-UHFFFAOYSA-N;
MW          300.351;      // g/mol [origin=calculated method=formula-sum]
Tc          878.45;      // K   [origin=predictive method=joback]
Pc          15.093;      // bar [origin=predictive method=joback]
omega       0.9800;      // -   [origin=predictive method=lee-kesler]
Tb          696.12;      // K   [origin=predictive method=joback]
HvapTb      66114.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (80.043 1.17056 -0.0004364 -2.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 3; } { group CH2=CH; count 2; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(2-prop-2-enoyloxypropoxy)propoxy]propan-2-yl prop-2-enoate" "acrylic acid, propylenebis(oxypropylene) ester" "propane-1,3-diylbis(oxypropane-1,3-diyl) diacrylate" "2-propenoic acid, 1,3-propanediylbis(oxy-3,1-propanediyl) ester" "(1-methyl-1,2-ethanediyl)bis(oxy(methyl-2,1-ethanediyl)) diacrylate" "2-(2-[2-(acryloyloxy)propoxy]-1-methylethoxy)-1-methylethylacrylate" "2-propenoic acid, (1-methyl-1,2-ethanediyl)bis(oxy(methyl-2,1-ethanediyl)) ester" "2-propenoic acid, (1-methyl-1,2-ethanediyl)bis(oxy(1-methyl-2,1-ethanediyl)) ester" "2-propenoic acid, (1-methyl-1,2-ethanediyl)bis[oxy(1-methyl-2,1-ethanediyl)] ester" "2-propenoic acid, (1-methyl-1,2-ethanediyl)bis[oxy(methyl-2,1-ethanediyl)] ester" "2-propenoic acid, 1,1'-((1-methyl-1,2-ethanediyl)bis(oxy(1-methyl-2,1-ethanediyl))) ester" "2-propenoic acid, 1,1'-[(1-methyl-1,2-ethanediyl)bis[oxy(1-methyl-2,1-ethanediyl)]] ester" );
gibbsFormation
{
    dHf_298   -1016910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     827.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-586960.0
    phase     gas;
}
