/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(dodecyloxy)-3-((2-hydroxyethyl)amino)propan-2-ol  (C17H37NO3, CAS 18448-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dodecyloxy32HydroxyethylAminoPropan2Ol;
formula     C17H37NO3;
CAS         18448-68-5;
InChIKey    FUVVCZPEOKAHJS-UHFFFAOYSA-N;
MW          303.487;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.46;      // K   [origin=predictive method=joback]
Pc          14.112;      // bar [origin=predictive method=joback]
omega       1.2708;      // -   [origin=predictive method=lee-kesler]
Tb          845.07;      // K   [origin=predictive method=joback]
HvapTb      95252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.625 1.70572 -0.0009026 1.659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group OH; count 1; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 2; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-dodecoxy-3-(2-hydroxyethylamino)propan-2-ol" "2-propanol, 1-(dodecyloxy)-3-((2-hydroxyethyl)amino)-" "2-propanol, 1-(dodecyloxy)-3-[(2-hydroxyethyl)amino]-" "1-(dodecyloxy)-3-[(2-hydroxyethyl)amino]propan-2-ol" );
standardThermochemistry
{
    dHf_298   -782700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     962.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199430.0
}
