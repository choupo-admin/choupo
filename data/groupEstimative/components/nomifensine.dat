/*--------------------------------*- Choupo -*-----------------------*\
  Component: nomifensine  (C16H18N2, CAS 24526-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nomifensine;
formula     C16H18N2;
CAS         24526-64-5;
InChIKey    XXPANQJNYNUNES-UHFFFAOYSA-N;
MW          238.334;      // g/mol [origin=calculated method=formula-sum]
Tc          970.37;      // K   [origin=predictive method=joback]
Pc          26.653;      // bar [origin=predictive method=joback]
omega       0.7824;      // -   [origin=predictive method=lee-kesler]
Tb          720.71;      // K   [origin=predictive method=joback]
HvapTb      69683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.31 1.58372 -0.00115112 3.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-phenyl-3,4-dihydro-1h-isoquinolin-8-amine" "nomifensin" "linamiphen" "(+-)-nomifensin" "(+-)-nomifensine" "nomifensinum" "nomifensina" "2-methyl-4-phenyl-1,2,3,4-tetrahydroisoquinolin-8-amine" "(+)-nomifensine" "(+)-nomiphensine" "nomifenison" "nomifensinum [inn-latin]" );
gibbsFormation
{
    dHf_298   250670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=527380.0
    phase     gas;
}
