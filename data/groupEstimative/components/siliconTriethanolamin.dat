/*--------------------------------*- Choupo -*-----------------------*\
  Component: silicon triethanolamin  (C8H19NO3Si, CAS 42959-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H19NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        siliconTriethanolamin;
formula     C8H19NO3Si;
CAS         42959-18-2;
InChIKey    NSYDOBYFTHLPFM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          205.329;      // g/mol [origin=calculated method=formula-sum]
Tc          759.65;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.9033;      // -   [origin=predictive method=lee-kesler]
Tb          566.78;      // K   [origin=predictive method=joback]
HvapTb      62176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.868 0.85814 -0.0002482 -6.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group OH; count 1; } { group CH2O; count 2; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group OH; count 1; } { group O_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,2-dimethyl-1,3,6,2-dioxazasilocan-6-yl)ethanol" "silicon triethanolamine" "triethanolamine siliciee [french]" "2,2-dimethyl-1,3-dioxa-6-aza-2-silacyclooctane-6-ethanol" "1,3-dioxa-6-aza-2-silacyclooctane-6-ethanol, 2,2-dimethyl-" "dimethyl-1,1-dioxa-2,8-hydroxyethyl-5 sila-1 aza-5 cyclooctane [french]" "triethanolamine siliciee" "t.e.a.s" "t.e.a.s." "dimethyl-1,1-dioxa-2,8-hydroxyethyl-5 sila-1 aza-5 cyclooctane" );
gibbsFormation
{
    dHf_298   -594110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-254400.0
    phase     gas;
}
