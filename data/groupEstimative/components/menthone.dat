/*--------------------------------*- Choupo -*-----------------------*\
  Component: menthone  (C10H18O, CAS 10458-14-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        menthone;
formula     C10H18O;
CAS         10458-14-7;
InChIKey    NFLGAXVYCFJBMK-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          728.97;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.4122;      // -   [origin=predictive method=lee-kesler]
Tb          510.66;      // K   [origin=predictive method=joback]
HvapTb      41833.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.12 0.88706 -0.000305 -2.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-2-propan-2-yl-cyclohexan-1-one" "isomenthone" "2-isopropyl-5-methylcyclohexanone" "p-menthan-3-one" "cyclohexanone, 5-methyl-2-(1-methylethyl)-" "p-menthan-3-one, trans-" ".alpha.-isomenthone" "cyclohexanone, 5-methyl-2-(1-methylethyl)-, cis-" "5-methyl-2-(isopropylcyclo)hexanone" "cyclohexanone, 5-methyl-2-(1-methylethyl)-, trans-" "p-menthan-3-one, (1r,4r)-(+)-" "p-menthan-3-one, (1s,4s)-(-)-" );
gibbsFormation
{
    dHf_298   -358730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74970.0
    phase     gas;
}
