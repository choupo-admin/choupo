/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl ethylbromomalonate  (C9H15BrO4, CAS 29237-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylEthylbromomalonate;
formula     C9H15BrO4;
CAS         29237-78-3;
InChIKey    CNDSZGJUDZRYST-UHFFFAOYSA-N;
MW          267.119;      // g/mol [origin=calculated method=formula-sum]
Tc          784.71;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.7821;      // -   [origin=predictive method=lee-kesler]
Tb          584.89;      // K   [origin=predictive method=joback]
HvapTb      55581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.243 0.91326 -0.0005198 8.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group Br; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group Br; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-bromanyl-2-ethyl-propanedioate" "malonic acid, bromoethyl-, diethyl ester" "diethyl 2-bromo-2-ethylpropanedioate" "malonic acid, (bromo)(ethyl)-, diethyl ester" "propanedioic acid,2-bromo-2-ethyl-, 1,3-diethyl ester" "malonicacid, bromoethyl-, diethyl ester (6ci,8ci);propanedioic acid, bromoethyl-,diethyl ester (9ci);diethyl 2-bromo-2-ethylmalonate;diethylbromoethylmalonate;" );
standardThermochemistry
{
    dHf_298   -846070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-578680.0
}
