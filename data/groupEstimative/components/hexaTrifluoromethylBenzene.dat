/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexa[trifluoromethyl]benzene  (C12F18, CAS 2340-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexaTrifluoromethylBenzene;
formula     C12F18;
CAS         2340-93-4;
InChIKey    XJGMLRCIWIZTKI-UHFFFAOYSA-N;
MW          486.096;      // g/mol [origin=calculated method=formula-sum]
Tc          622.55;      // K   [origin=predictive method=joback]
Pc          12.664;      // bar [origin=predictive method=joback]
omega       0.8431;      // -   [origin=predictive method=lee-kesler]
Tb          493.22;      // K   [origin=predictive method=joback]
HvapTb      25410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.63 1.7346 -0.001651 5.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 6; } { group CF3; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 6; } { group dC_ring; count 6; } { group F; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6-hexakis(trifluoromethyl)benzene" "benzene, hexakis(trifluoromethyl)-" "benzene,1,2,3,4,5,6-hexakis(trifluoromethyl)-" );
standardThermochemistry
{
    dHf_298   -3694310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     823.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3375120.0
}
