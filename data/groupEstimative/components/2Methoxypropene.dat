/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxypropene  (C4H8O, CAS 116-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxypropene;
formula     C4H8O;
CAS         116-11-0;
InChIKey    YOWQWFMSQCOSBA-UHFFFAOYSA-N;
MW          72.107;      // g/mol [origin=calculated method=formula-sum]
Tc          480.78;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.2363;      // -   [origin=predictive method=lee-kesler]
Tb          310.10;      // K   [origin=predictive method=joback]
HvapTb      26318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.07 0.30054 -0.000108 8e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyprop-1-ene" "1-propene, 2-methoxy-" "isopropenyl methyl ether" "2-methoxy-1-propene" "methyl isopropenyl ether" "ether, isopropenyl methyl" "propene, 2-methoxy-" "2-methyoxypropene" "2-methoxy propene" "2-methoxypropene st. 0.5% potassium carbonate" "isopropenyl methyl ether;methyl 1-methylvinyl ether;methyl isopropenyl ether;ether,isopropenyl methyl (6ci,7ci,8ci);2-methoxyprop-1-ene;" );
gibbsFormation
{
    dHf_298   -142470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42910.0
    phase     gas;
}
