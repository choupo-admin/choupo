/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanoic acid, (1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl) ester  (C47H76O8, CAS 106894-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanoicAcid1MethylethylideneBis41Phenyleneoxy21Ethanediyl;
formula     C47H76O8;
CAS         106894-52-4;
InChIKey    RBVFLLRHOSVNTL-UHFFFAOYSA-N;
MW          769.117;      // g/mol [origin=calculated method=formula-sum]
Tc          2335.14;      // K   [origin=predictive method=joback]
Pc          3.789;      // bar [origin=predictive method=joback]
omega       -0.5000;      // -   [origin=predictive method=lee-kesler]
Tb          1541.17;      // K   [origin=predictive method=joback]
HvapTb      149250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.298 3.95548 -0.00199992 2.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 22; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 28; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[4-[2-[4-[2-(2-dodecanoyloxyethoxy)ethoxy]phenyl]propan-2-yl]phenoxy]ethoxy]ethyl dodecanoate" "dodecanoic acid, 1,1'-[(1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyl)] ester" );
gibbsFormation
{
    dHf_298   -1735480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1870.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-487480.0
    phase     gas;
}
