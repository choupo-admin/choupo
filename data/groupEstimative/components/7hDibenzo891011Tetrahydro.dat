/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7h-dibenzo-8,9,10,11-tetrahydro-  (C21H18, CAS 78631-72-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7hDibenzo891011Tetrahydro;
formula     C21H18;
CAS         78631-72-8;
InChIKey    ZXDRPLPGXKZLMT-UHFFFAOYSA-N;
MW          270.375;      // g/mol [origin=calculated method=formula-sum]
Tc          1076.56;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       0.5567;      // -   [origin=predictive method=lee-kesler]
Tb          781.35;      // K   [origin=predictive method=joback]
HvapTb      73086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.72 1.5806 -0.00104544 2.6556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 8; } { group AC; count 4; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group CH2_ring; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10,16,17-tetradehydro-12,13,14,15-tetrahydro-11h-dibenzo[a,c][13]annulene" );
standardThermochemistry
{
    dHf_298   598770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=781360.0
}
