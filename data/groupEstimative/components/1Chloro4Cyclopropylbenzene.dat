/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-4-cyclopropylbenzene  (C9H9Cl, CAS 1798-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro4Cyclopropylbenzene;
formula     C9H9Cl;
CAS         1798-84-1;
InChIKey    HXBOFIGSLNDZRW-UHFFFAOYSA-N;
MW          152.621;      // g/mol [origin=calculated method=formula-sum]
Tc          714.57;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.3608;      // -   [origin=predictive method=lee-kesler]
Tb          481.35;      // K   [origin=predictive method=joback]
HvapTb      42864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.25 0.8781 -0.00067056 2.048e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group ACCH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-cyclopropyl-benzene" "1-chloro-4-cyclopropyl-benzene" "benzene,1-chloro-4-cyclopropyl-" );
standardThermochemistry
{
    dHf_298   53030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     337.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176500.0
}
