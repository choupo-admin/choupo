/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexene, 1-bromo-, (3z)-  (C6H11Br, CAS 5009-31-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexene1Bromo3z;
formula     C6H11Br;
CAS         5009-31-4;
InChIKey    HSNATJOWAYTBGM-UHFFFAOYSA-N;
MW          163.058;      // g/mol [origin=calculated method=formula-sum]
Tc          600.61;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.3891;      // -   [origin=predictive method=lee-kesler]
Tb          407.20;      // K   [origin=predictive method=joback]
HvapTb      35343.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.557 0.63202 -0.0004578 1.417e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylhex-3-ene" "3-hexene, 1-bromo-, (e)-" );
gibbsFormation
{
    dHf_298   -23620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94180.0
    phase     gas;
}
