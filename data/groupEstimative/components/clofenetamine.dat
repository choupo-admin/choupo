/*--------------------------------*- Choupo -*-----------------------*\
  Component: clofenetamine  (C20H26ClNO, CAS 511-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clofenetamine;
formula     C20H26ClNO;
CAS         511-46-6;
InChIKey    IKFQEQVEOQNTRJ-UHFFFAOYSA-N;
MW          331.884;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.49;      // K   [origin=predictive method=joback]
Pc          15.648;      // bar [origin=predictive method=joback]
omega       0.8295;      // -   [origin=predictive method=lee-kesler]
Tb          784.60;      // K   [origin=predictive method=joback]
HvapTb      72870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.576 1.87986 -0.00125336 3.164e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 9; } { group AC; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(4-chlorophenyl)-1-phenyl-ethoxy]-n,n-diethyl-ethanamine" "keithon" "clofenetaminum [inn-latin]" "kt 5" "2-(1-(4-chlorophenyl)-1-phenylethoxy)-n,n-diethylethanamine" "triethylamine, 2-(alpha-(p-chlorophenyl)-alpha-methylbenzyloxy)-" "2-(alpha-(p-chlorophenyl)-alpha-methylbenzyloxy)-n,n-diethylethylamine" "ethylamine, 2-(alpha-(p-chlorophenyl)-alpha-methylbenzyloxy)-n,n-diethyl-" "clofenetamina" "clofenetaminum" "kaithon" "2-[1-(4-chlorophenyl)-1-phenylethoxy]-n,n-diethylethanamine" );
gibbsFormation
{
    dHf_298   -83720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     737.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=329400.0
    phase     gas;
}
