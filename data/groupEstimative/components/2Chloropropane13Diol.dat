/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloropropane-1,3-diol  (C3H7ClO2, CAS 497-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloropropane13Diol;
formula     C3H7ClO2;
CAS         497-04-1;
InChIKey    DYPJJAAKPQKWTM-UHFFFAOYSA-N;
MW          110.537;      // g/mol [origin=calculated method=formula-sum]
Tc          657.94;      // K   [origin=predictive method=joback]
Pc          54.788;      // bar [origin=predictive method=joback]
omega       1.2028;      // -   [origin=predictive method=lee-kesler]
Tb          489.59;      // K   [origin=predictive method=joback]
HvapTb      59627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.952 0.3695 -0.0002238 5.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 2; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylpropane-1,3-diol" "2-chloro-1,3-propanediol" "1,3-propanediol, 2-chloro-" "glycerol beta-chlorohydrin" "2-chloro-1,3-propandiol" "2-chloro-1,3-dihydroxypropane" "glycerol " "a-chlorohydrin" "2-mcpd" "1,3-propanediol,2-chloro-" "2-chloro-1,3-dihydroxypropane;2-chloro-1,3-propanediol; glycerol b-chlorohydrin" );
gibbsFormation
{
    dHf_298   -430730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313630.0
    phase     gas;
}
