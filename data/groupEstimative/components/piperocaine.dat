/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperocaine  (C16H23NO2, CAS 136-82-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperocaine;
formula     C16H23NO2;
CAS         136-82-3;
InChIKey    YQKAVWCGQQXBGW-UHFFFAOYSA-N;
MW          261.365;      // g/mol [origin=calculated method=formula-sum]
Tc          892.98;      // K   [origin=predictive method=joback]
Pc          19.930;      // bar [origin=predictive method=joback]
omega       0.7857;      // -   [origin=predictive method=lee-kesler]
Tb          678.30;      // K   [origin=predictive method=joback]
HvapTb      63193.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.327 1.64572 -0.0010232 2.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylpiperidin-1-yl)propyl benzoate" "metycaine" "neothesin" "isocaine (iso-sol. co.) base" "(2-methylpiperidino)propyl benzoate" "2-methyl-1-piperidinopropanol, benzoate" "gamma-(2-methylpiperidyl)propyl benzoate" "3-benzoxy-1-(2-methylpiperidino)propane" "benzoyl-gamma-(2-methylpiperidino)propanol" "1-piperidinepropanol, 2-methyl-, benzoate(ester)" "1-piperidinepropanol, 2-methyl-, benzoate (ester), (.+/-.)-" "piperocaina" );
gibbsFormation
{
    dHf_298   -326310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33210.0
    phase     gas;
}
