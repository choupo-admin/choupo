/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-arterenol  (C8H11NO3, CAS 138-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlArterenol;
formula     C8H11NO3;
CAS         138-65-8;
InChIKey    SFLSHLFXELFNJZ-UHFFFAOYSA-N;
MW          169.18;      // g/mol [origin=calculated method=formula-sum]
Tc          963.87;      // K   [origin=predictive method=joback]
Pc          69.444;      // bar [origin=predictive method=joback]
omega       1.6034;      // -   [origin=predictive method=lee-kesler]
Tb          734.83;      // K   [origin=predictive method=joback]
HvapTb      88638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.029 1.0959 -0.00103232 3.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-azanyl-1-oxidanyl-ethyl)benzene-1,2-diol" "dl-noradrenaline" "dl-norepinephrine" "d-arterenol" "d-norepinephrine" "noradrenalin, dl-" "4-(2-amino-1-hydroxyethyl)benzene-1,2-diol" "(+-)-noradrenaline" "2-amino-1-(3,4-dihydroxyphenyl)ethanol" "(1)-4-(2-amino-1-hydroxyethyl)pyrocatechol" "(s)-4-(2-amino-1-hydroxyethyl)pyrocatechol" "1,2-benzenediol, 4-(2-amino-1-hydroxyethyl)-" );
standardThermochemistry
{
    dHf_298   -450260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253160.0
}
