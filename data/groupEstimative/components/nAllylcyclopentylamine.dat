/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-allylcyclopentylamine  (C8H15N, CAS 55611-39-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nAllylcyclopentylamine;
formula     C8H15N;
CAS         55611-39-7;
InChIKey    CTSIKBGUCQWRIM-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          645.66;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.4267;      // -   [origin=predictive method=lee-kesler]
Tb          444.77;      // K   [origin=predictive method=joback]
HvapTb      39425.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.069 0.9517 -0.0006103 1.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-prop-2-enylcyclopentanamine" "n-allyl-n-cyclopentylamine" "n-(prop-2-en-1-yl)cyclopentanamine" );
gibbsFormation
{
    dHf_298   30930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230260.0
    phase     gas;
}
