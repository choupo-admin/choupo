/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloropentane  (C5H11Cl, CAS 543-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloropentane;
formula     C5H11Cl;
CAS         543-59-9;
InChIKey    SQCZQTSHSZLZIQ-UHFFFAOYSA-N;
MW          106.593;      // g/mol [origin=calculated method=formula-sum]
Tc          524.01;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       0.3153;      // -   [origin=predictive method=lee-kesler]
Tb          351.43;      // K   [origin=predictive method=joback]
HvapTb      31109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.234 0.48562 -0.0002686 5.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylpentane" "pentane, 1-chloro-" "n-amyl chloride" "amyl chloride" "pentyl chloride" "n-pentyl chloride" "chloropentane" "pentane, chloro-" "1-chloro-pentane" "n-butylcarbonyl chloride" "7cl" );
gibbsFormation
{
    dHf_298   -162270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20710.0
    phase     gas;
}
