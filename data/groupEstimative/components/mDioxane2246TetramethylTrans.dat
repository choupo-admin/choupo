/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-dioxane, 2,2,4,6-tetramethyl-, trans-  (C8H16O2, CAS 17227-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mDioxane2246TetramethylTrans;
formula     C8H16O2;
CAS         17227-17-7;
InChIKey    GPKRWHGIASNHBE-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          655.93;      // K   [origin=predictive method=joback]
Pc          30.190;      // bar [origin=predictive method=joback]
omega       0.3465;      // -   [origin=predictive method=lee-kesler]
Tb          446.99;      // K   [origin=predictive method=joback]
HvapTb      41082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.46 1.11888 -0.0008864 3.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,6-tetramethyl-1,3-dioxane" "1,3-dioxane, 2,2,4,6-tetramethyl-, trans-" "cis-2,2,4,6-tetramethyl-1,3-dioxane" "1,3-dioxane,2,2,4,6-tetramethyl-,cis-" "(4r,6r)-2,2,4,6-tetramethyl-1,3-dioxane" "1,3-dioxane,2,2,4,6-tetramethyl-, (4r,6s)-rel-" "1,3-dioxane,2,2,4,6-tetramethyl-, cis-; m-dioxane, 2,2,4,6-tetramethyl-, cis- (8ci);cis-2,2,4,6-tetramethyl-1,3-dioxane" );
standardThermochemistry
{
    dHf_298   -443570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-152220.0
}
