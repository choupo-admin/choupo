/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-1,2,3,4-tetrahydronaphthalene  (C14H20, CAS 42044-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl1234Tetrahydronaphthalene;
formula     C14H20;
CAS         42044-22-4;
InChIKey    FCXYHCYNCWKCOS-UHFFFAOYSA-N;
MW          188.314;      // g/mol [origin=calculated method=formula-sum]
Tc          790.09;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.4171;      // -   [origin=predictive method=lee-kesler]
Tb          559.36;      // K   [origin=predictive method=joback]
HvapTb      48485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.28 1.46256 -0.00104756 2.973e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 2-(1,1-dimethylethyl)-1,2,3,4-tetrahydro-" "2-tert-butyl[1,2,3,4-tetrahydronaphthalene]" );
gibbsFormation
{
    dHf_298   -49340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221270.0
    phase     gas;
}
