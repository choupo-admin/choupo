/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiepin, 2,3,6,7-tetrahydro-3,3,6,6-tetramethyl-1,1-dioxide  (C10H18O2S, CAS 86596-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H18O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        thiepin2367Tetrahydro3366Tetramethyl11Dioxide;
formula     C10H18O2S;
CAS         86596-79-4;
InChIKey    IECOJFJQIZQAFO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          202.312;      // g/mol [origin=calculated method=formula-sum]
Tc          609.35;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.4409;      // -   [origin=predictive method=lee-kesler]
Tb          421.92;      // K   [origin=predictive method=joback]
HvapTb      47782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.43 1.61648 -0.00157288 6.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group CH=CH; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,6,6-tetramethyl-2,7-dihydrothiepine 1,1-dioxide" "2,3,6,7-tetrahydro-3,3,6,6-tetramethylthiepin-1,1-dioxide" );
standardThermochemistry
{
    dHf_298   -622710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     833.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-432620.0
}
