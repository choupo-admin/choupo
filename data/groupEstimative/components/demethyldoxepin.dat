/*--------------------------------*- Choupo -*-----------------------*\
  Component: demethyldoxepin  (C18H19NO, CAS 1225-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        demethyldoxepin;
formula     C18H19NO;
CAS         1225-56-5;
InChIKey    HVKCEFHNSNZIHO-MHWRWJLKSA-N;
MW          265.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.68;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.8969;      // -   [origin=predictive method=lee-kesler]
Tb          769.93;      // K   [origin=predictive method=joback]
HvapTb      73493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.658 1.61012 -0.00116252 3.344e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group FCH2O; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 5; } { group O_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e)-3-(6h-benzo[c][1]benzoxepin-11-ylidene)-n-methyl-propan-1-amine" "desmethyl doxepin" "n-desmethyldoxepin" "monodesmethyldoxepin" "nordoxepin" "3-dibenz(b,e)oxepin-11(6h)-ylidene-n-methyl-1-propanamine" "dibenz(b,e)oxepin-delta11(6h),gamma-propylamine, n-methyl-" "1-propanamine, 3-dibenz(b,e)oxepin-11(6h)-ylidene-n-methyl-" "doxepin impurity c" "(e)-desmethyldoxepin" "trans-desmethyldoxepin" "desmethyldoxepin, (e)-" );
standardThermochemistry
{
    dHf_298   125910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=423430.0
}
