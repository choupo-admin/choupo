/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-nonadecanone  (C19H38O, CAS 629-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Nonadecanone;
formula     C19H38O;
CAS         629-66-3;
InChIKey    IEDKVDCIEARIIU-UHFFFAOYSA-N;
MW          282.512;      // g/mol [origin=calculated method=formula-sum]
Tc          856.14;      // K   [origin=predictive method=joback]
Pc          11.268;      // bar [origin=predictive method=joback]
omega       0.8955;      // -   [origin=predictive method=lee-kesler]
Tb          688.19;      // K   [origin=predictive method=joback]
HvapTb      64634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.024 1.78084 -0.0009911 2.0586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonadecan-2-one" "methyl heptadecyl ketone" "heptadecyl methyl ketone" "nonadeca-2-one" );
standardThermochemistry
{
    dHf_298   -548070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     922.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19820.0
}
