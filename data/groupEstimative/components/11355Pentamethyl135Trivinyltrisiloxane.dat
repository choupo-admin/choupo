  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H24O2Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11355Pentamethyl135Trivinyltrisiloxane;
formula     C11H24O2Si3;
CAS         1529-65-3;
InChIKey    OFVIRRZRPPRVFE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          272.566;      // g/mol [origin=calculated method=formula-sum]
Tc          677.96;      // K   [origin=predictive method=joback]
Pc          15.476;      // bar [origin=predictive method=joback]
omega       0.3313;      // -   [origin=predictive method=lee-kesler]
Tb          490.36;      // K   [origin=predictive method=joback]
HvapTb      43772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (157.37 0.2439 0.0008231 -5.893e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2=CH; count 3; } { group Si; count 1; } { group SiO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH2; count 3; } { group dCH; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl-bis[[ethenyl(dimethyl)silyl]oxy]-methyl-silane" "trisiloxane, 1,3,5-triethenyl-1,1,3,5,5-pentamethyl-" "1,3,5-trivinyl-1,1,3,5,5-pentamethyl-trisiloxane" "ethenyl-bis[[ethenyl(dimethyl)silyl]oxy]-methylsilane" "trisiloxane,1,3,5-triethenyl-1,1,3,5,5-pentamethyl-" "1,3,5-trivinyl-1,1,3,5,5-pentamethyltrisiloxane" "1,1,3,5,5-pentamethyl-1,3,5-trivinyltrisiloxane;trisiloxane,1,1,3,5,5-pentamethyl-1,3,5-trivinyl- (7ci,8ci);" );
standardThermochemistry
{
    dHf_298   -493380.0;      // J/mol ideal-gas [origin=predictive method=joback]
