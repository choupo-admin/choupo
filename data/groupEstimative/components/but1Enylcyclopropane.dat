/*--------------------------------*- Choupo -*-----------------------*\
  Component: but-1-enylcyclopropane  (C7H12, CAS 7736-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        but1Enylcyclopropane;
formula     C7H12;
CAS         7736-35-8;
InChIKey    BNFXSCXEKBQBRB-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          558.61;      // K   [origin=predictive method=joback]
Pc          34.279;      // bar [origin=predictive method=joback]
omega       0.2842;      // -   [origin=predictive method=lee-kesler]
Tb          370.66;      // K   [origin=predictive method=joback]
HvapTb      31047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.899 0.83972 -0.000661 2.188e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   2210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149030.0
    phase     gas;
}
