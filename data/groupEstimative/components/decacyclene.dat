/*--------------------------------*- Choupo -*-----------------------*\
  Component: decacyclene  (C36H18, CAS 191-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decacyclene;
formula     C36H18;
CAS         191-48-0;
InChIKey    CUIWZLHUNCCYBL-UHFFFAOYSA-N;
MW          450.54;      // g/mol [origin=calculated method=formula-sum]
Tc          1526.30;      // K   [origin=predictive method=joback]
Pc          15.797;      // bar [origin=predictive method=joback]
omega       1.2843;      // -   [origin=predictive method=lee-kesler]
Tb          1237.52;      // K   [origin=predictive method=joback]
HvapTb      116154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-224.95 3.0612 -0.00297652 1.1402e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 18; } { group AC; count 18; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 18; } { group dC_ring; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diacenaphtho[1,2-j:1',2'-l]fluoranthene" "diacenaphtho(1,2-j:1',2'-l)fluoranthene" ""benzo(a,a',a"")triacenaphthylene"" "diacenaphtho[1,2'-l]fluoranthene" "diacenaphtheno[1,2'-l]fluoranthen" "diacenaphtheno(1,2-j:1',2'-l)fluoranthen" "decacyclo[24.7.1.1^{4,8}.1^{15,19}.0^{2,25}.0^{3,13}.0^{14,24}.0^{30,34}.0^{12,36}.0^{23,35}]hexatriaconta-1(34),2,4,6,8,10,12(36),13,15,17,19,21,23(35),24,26,28,30,32-octadecaene" );
gibbsFormation
{
    dHf_298   941650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1230180.0
    phase     gas;
}
