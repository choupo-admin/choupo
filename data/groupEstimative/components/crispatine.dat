/*--------------------------------*- Choupo -*-----------------------*\
  Component: crispatine  (C16H23NO5, CAS 6029-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        crispatine;
formula     C16H23NO5;
CAS         6029-87-4;
InChIKey    PSUFRPOAICRSTC-RYQNPAGMSA-N;
MW          309.362;      // g/mol [origin=calculated method=formula-sum]
Tc          1015.84;      // K   [origin=predictive method=joback]
Pc          20.401;      // bar [origin=predictive method=joback]
omega       1.2935;      // -   [origin=predictive method=lee-kesler]
Tb          810.54;      // K   [origin=predictive method=joback]
HvapTb      84014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.24 2.12906 -0.00171024 5.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13-epicrispatine" "fulvine" "(3s,4s,5s,13ar,13br)-4-hydroxy-3,4,5-trimethyl-4,5,8,10,12,13,13a,13b-octahydro-2h-[1,6]dioxacycloundecino[2,3,4-gh]pyrrolizine-2,6(3h)-dione" "20-norcrotalanan-11,15-dione, 14,19-dihydro-13-hydroxy-, (12-xi,13-xi)-" "fulvine (8ci)" "2h-[1,6]dioxacycloundecino[2,3,4-gh]pyrrolizine-2,6(3h)-dione,4,5,8,10,12,13,13a,13b-octahydro-4-hydroxy-3,4,5-trimethyl-,(3r,4s,5s,13ar,13br)- (9ci)" );
standardThermochemistry
{
    dHf_298   -865880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-405470.0
}
