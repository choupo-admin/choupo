/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dihydropentalene  (C8H8, CAS 33284-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dihydropentalene;
formula     C8H8;
CAS         33284-11-6;
InChIKey    GESVYKMBMUVRNT-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          642.51;      // K   [origin=predictive method=joback]
Pc          42.607;      // bar [origin=predictive method=joback]
omega       0.3149;      // -   [origin=predictive method=lee-kesler]
Tb          421.44;      // K   [origin=predictive method=joback]
HvapTb      36390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.05 0.8124 -0.00069756 2.42e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dihydropentalene" "1,5-dihydro-pentalene" "pentalene, 1,5-dihydro-" "gesvykmbmuvrnt-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   115910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     287.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199820.0
}
