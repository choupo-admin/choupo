/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-bis(p-hydroxyphenyl)-2-hexanone  (C18H20O3, CAS 101564-54-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34BisPHydroxyphenyl2Hexanone;
formula     C18H20O3;
CAS         101564-54-9;
InChIKey    HNQLJUUKIAVRLQ-UHFFFAOYSA-N;
MW          284.355;      // g/mol [origin=calculated method=formula-sum]
Tc          1128.05;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       1.2405;      // -   [origin=predictive method=lee-kesler]
Tb          879.03;      // K   [origin=predictive method=joback]
HvapTb      92212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.129 1.84904 -0.00151822 5.1016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 8; } { group ACCH; count 2; } { group ACOH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(4-hydroxyphenyl)hexan-2-one" "2-hexanone, 3,4-bis(p-hydroxyphenyl)-" "agn-pc-00ka1m" "(3r,4s)-3,4-bis(4-hydroxyphenyl)hexan-2-one" );
gibbsFormation
{
    dHf_298   -419550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-117540.0
    phase     gas;
}
