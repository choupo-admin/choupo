/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetyl-2,6-heptanedione  (C9H14O3, CAS 29214-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetyl26Heptanedione;
formula     C9H14O3;
CAS         29214-57-1;
InChIKey    RQZJIXZNJBCGQC-UHFFFAOYSA-N;
MW          170.208;      // g/mol [origin=calculated method=formula-sum]
Tc          762.89;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.8139;      // -   [origin=predictive method=lee-kesler]
Tb          566.69;      // K   [origin=predictive method=joback]
HvapTb      55478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.102 0.78076 -0.0004129 6.828e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3CO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CdO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethanoylheptane-2,6-dione" "3-acetylheptane-2,6-dione" "2,6-heptanedione, 3-acetyl-" "3-acetyl-heptane-2,6-dione" "2,6-heptanedione,3-acetyl-" );
standardThermochemistry
{
    dHf_298   -572110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-364300.0
}
