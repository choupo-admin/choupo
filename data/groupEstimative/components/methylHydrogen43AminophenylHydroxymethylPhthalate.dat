/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl hydrogen 4-((3-aminophenyl)hydroxymethyl)phthalate  (C16H15NO5, CAS 23843-86-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylHydrogen43AminophenylHydroxymethylPhthalate;
formula     C16H15NO5;
CAS         23843-86-9;
InChIKey    SZMFFXCNDCWPND-UHFFFAOYSA-N;
MW          301.298;      // g/mol [origin=calculated method=formula-sum]
Tc          1241.15;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       1.7191;      // -   [origin=predictive method=lee-kesler]
Tb          1001.98;      // K   [origin=predictive method=joback]
HvapTb      109251.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.54 1.28532 -0.00076288 1.467e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[(3-aminophenyl)-oxidanyl-methyl]-2-methoxycarbonyl-benzoic acid" "phthalic acid, 4-(m-amino-" "a-hydroxybenzyl)-, monomethyl ester" "1,2-benzenedicarboxylic acid, 4-((3-aminophenyl)hydroxymethyl)-, 1-methyl ester" "1,2-benzenedicarboxylic acid, 4-[(3-aminophenyl)hydroxymethyl]-, 1-methyl ester" "5-[(3-aminophenyl)(hydroxy)methyl]-2-(methoxycarbonyl)benzoic acid" "5-[(3-aminophenyl)-hydroxymethyl]-2-methoxycarbonylbenzoic acid" "1,2-benzenedicarboxylic acid, 4-((3-aminophenyl)hydroxymethyl)-, 1-methyl ester, homopolymer" );
standardThermochemistry
{
    dHf_298   -726190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     745.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-447320.0
}
