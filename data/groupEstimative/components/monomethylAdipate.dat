/*--------------------------------*- Choupo -*-----------------------*\
  Component: monomethyl adipate  (C7H12O4, CAS 627-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monomethylAdipate;
formula     C7H12O4;
CAS         627-91-8;
InChIKey    UOBSVARXACCLLH-UHFFFAOYSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          755.08;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.9051;      // -   [origin=predictive method=lee-kesler]
Tb          563.49;      // K   [origin=predictive method=joback]
HvapTb      55747.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.534 0.66482 -0.000335 4.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methoxy-6-oxidanylidene-hexanoic acid" "adipic acid monomethyl ester" "methyl hydrogen adipate" "hexanedioic acid, monomethyl ester" "methyl hemiadipate" "adipic acid, monomethyl ester" "6-methoxy-6-oxohexanoic acid" "mono-methyl adipate" "monomethyl 1,6-hexanedioate" "hexanedioic acid, 1-methyl ester" "methyl hexanedioate" "monomethyl hexanedioate" );
standardThermochemistry
{
    dHf_298   -855360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-646220.0
}
