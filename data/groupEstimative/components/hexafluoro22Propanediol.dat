/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexafluoro-2,2-propanediol  (C3H2F6O2, CAS 677-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexafluoro22Propanediol;
formula     C3H2F6O2;
CAS         677-71-4;
InChIKey    AKVXSYUWYXOLMY-UHFFFAOYSA-N;
MW          184.035;      // g/mol [origin=calculated method=formula-sum]
Tc          580.45;      // K   [origin=predictive method=joback]
Pc          42.441;      // bar [origin=predictive method=joback]
omega       1.2001;      // -   [origin=predictive method=lee-kesler]
Tb          438.53;      // K   [origin=predictive method=joback]
HvapTb      46840.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.13 0.805 -0.000814 2.934e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group OH; count 2; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 6; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)propane-2,2-diol" "1,1,1,3,3,3-hexafluoropropane-2,2-diol" "2,2-propanediol, 1,1,1,3,3,3-hexafluoro-" "1,1,1,3,3,3-hexafluoropropanediol" "fac" "2,2-propanediol, hexafluoro- (7ci)" "2,2-propanediol,1,1,1,3,3,3-hexafluoro-" "2,2-propanediol, 1,1,1,3,3,3-hexafluoro- (6ci,8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -1612620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1459600.0
}
