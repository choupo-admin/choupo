/*--------------------------------*- Choupo -*-----------------------*\
  Component: gestrinone  (C21H24O2, CAS 16320-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gestrinone;
formula     C21H24O2;
CAS         16320-04-0;
InChIKey    BJJXHLWLUDYTGC-ANULTFPQSA-N;
MW          308.421;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.46;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       1.1238;      // -   [origin=predictive method=lee-kesler]
Tb          891.41;      // K   [origin=predictive method=joback]
HvapTb      84196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-221.019 2.56352 -0.00237565 9.3549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CH_C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,13s,14s,17r)-13-ethyl-17-ethynyl-17-oxidanyl-1,2,6,7,8,14,15,16-octahydrocyclopenta[a]phenanthren-3-one" "dimetriose" "nemestran" "dimetrose" "tridomose" "gestrigone" "ethylnorgestrienone" "gestrinona" "gestrinonum [inn-latin]" "13-ethyl-17-alpha-ethinyl-17-hydroxygon-4,9,11-trien-3-one" "13-beta-ethyl-17-alpha-ethinyl-17-hydroxy-gona-4,9,11-triene-3-one" "13-ethyl-17-hydroxy-18,19-dinor-17alpha-pregna-4,9,11-trien-20-yn-3-one" );
gibbsFormation
{
    dHf_298   -44990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=322110.0
    phase     gas;
}
