/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 1082  (C20H16O, CAS 568-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris1082;
formula     C20H16O;
CAS         568-75-2;
InChIKey    JCBBZYDVQJQMMB-UHFFFAOYSA-N;
MW          272.347;      // g/mol [origin=calculated method=formula-sum]
Tc          1086.85;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       1.2227;      // -   [origin=predictive method=lee-kesler]
Tb          852.92;      // K   [origin=predictive method=joback]
HvapTb      86637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.039 1.60982 -0.0012678 4.058e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 6; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(12-methylbenzo[a]anthracen-7-yl)methanol" "7-(hydroxymethyl)-12-methylbenz[a]anthracene" "12-methylbenz(a)anthracene-7-methanol" "7-hydroxymethyl-12-methylbenz(a)anthracene" "7-(hydroxymethyl)-12-methylbenz(a)anthracene" "benz(a)anthracene-7-methanol, 12-methyl-" "12-methylbenz[a]anthracene-7-methanol" "7-hydroxymethyl-12-methylbenz[a]anthracene" "(12-methyltetraphen-7-yl)methanol" "benz[a]anthracene-7-methanol,12-methyl-" );
standardThermochemistry
{
    dHf_298   155500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=374540.0
}
