/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-hydroxyethyl)dimethylammonium lactate  (C7H17NO4, CAS 56669-87-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylDimethylammoniumLactate;
formula     C7H17NO4;
CAS         56669-87-5;
InChIKey    QFQMQSNDWYRIAG-UHFFFAOYSA-N;
MW          179.216;      // g/mol [origin=calculated method=formula-sum]
Tc          882.43;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       1.6935;      // -   [origin=predictive method=lee-kesler]
Tb          703.03;      // K   [origin=predictive method=joback]
HvapTb      83647.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.152 0.71126 -0.0001914 -6.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethanol;2-oxidanylpropanoic acid" "propanoic acid, 2-hydroxy-, compd. with 2-(dimethylamino)ethanol (1:1)" "n,n-dimethylaminoethanol lactate" "2-(dimethylamino)ethanol; 2-hydroxypropanoic acid" );
gibbsFormation
{
    dHf_298   -891910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-605910.0
    phase     gas;
}
