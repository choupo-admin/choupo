/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,11-diaminoundecane  (C11H26N2, CAS 822-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Diaminoundecane;
formula     C11H26N2;
CAS         822-08-2;
InChIKey    KLNPWTHGTVSSEU-UHFFFAOYSA-N;
MW          186.343;      // g/mol [origin=calculated method=formula-sum]
Tc          778.79;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       0.8995;      // -   [origin=predictive method=lee-kesler]
Tb          596.34;      // K   [origin=predictive method=joback]
HvapTb      61362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.871 1.1726 -0.0006614 1.417e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 11; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecane-1,11-diamine" "1,11-undecanediamine" "undecamethylenediamine" );
standardThermochemistry
{
    dHf_298   -202790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174640.0
}
