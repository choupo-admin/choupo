/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-octen-3-yne  (C9H14, CAS 17603-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Octen3Yne;
formula     C9H14;
CAS         17603-76-8;
InChIKey    FPKTZBDAOSTAHN-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          605.01;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.3108;      // -   [origin=predictive method=lee-kesler]
Tb          411.08;      // K   [origin=predictive method=joback]
HvapTb      37190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.583 0.68894 -0.00039886 9.408e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2=C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyloct-1-en-3-yne" "2-methyl-1-octene-3-yne" "2-methyl-1-octen-3-yne;2-methyl-1-octene-3-yne;1-octen-3-yne, 2-methyl-;2-methyl-oct-1-en-3-yne" );
standardThermochemistry
{
    dHf_298   158850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=306990.0
}
