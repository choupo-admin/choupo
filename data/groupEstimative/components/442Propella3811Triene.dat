/*--------------------------------*- Choupo -*-----------------------*\
  Component: [4.4.2]propella-3,8,11-triene  (C12H14, CAS 20295-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        442Propella3811Triene;
formula     C12H14;
CAS         20295-17-4;
InChIKey    VGWHURSVJWSFCK-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          762.45;      // K   [origin=predictive method=joback]
Pc          35.685;      // bar [origin=predictive method=joback]
omega       0.3293;      // -   [origin=predictive method=lee-kesler]
Tb          509.82;      // K   [origin=predictive method=joback]
HvapTb      41444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-256.69 2.01 -0.00223284 9.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 2; } { group CH=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4a,8a-ethenonaphthalene, 1,4,5,8-tetrahydro-" "(4.4.2)-propella-3,8,11-triene" );
standardThermochemistry
{
    dHf_298   133070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282720.0
}
