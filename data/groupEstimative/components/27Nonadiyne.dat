/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-nonadiyne  (C9H12, CAS 31699-35-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Nonadiyne;
formula     C9H12;
CAS         31699-35-1;
InChIKey    LTKSZLAHHLPXQC-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          636.85;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.2707;      // -   [origin=predictive method=lee-kesler]
Tb          423.52;      // K   [origin=predictive method=joback]
HvapTb      39932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.823 0.55924 -0.00028152 5.386e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group tC; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nona-2,7-diyne" );
standardThermochemistry
{
    dHf_298   315510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=430500.0
}
