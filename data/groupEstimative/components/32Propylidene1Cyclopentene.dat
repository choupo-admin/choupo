/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-propylidene)-1-cyclopentene  (C8H12, CAS 10514-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32Propylidene1Cyclopentene;
formula     C8H12;
CAS         10514-79-1;
InChIKey    BOJHICPAMVJRDP-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          615.59;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.2845;      // -   [origin=predictive method=lee-kesler]
Tb          408.27;      // K   [origin=predictive method=joback]
HvapTb      35127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.62 0.78844 -0.00055228 1.586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propan-2-ylidenecyclopentene" );
gibbsFormation
{
    dHf_298   -3610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127610.0
    phase     gas;
}
