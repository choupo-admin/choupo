\*---------------------------------------------------------------------------*/

name        caprolactoneHydroquinoneBis2HydroxyethylEtherMethylenebisPhe;
formula     C31H38N2O8;
CAS         152187-62-7;
InChIKey    LGRSGWBMPDYYSP-UHFFFAOYSA-N;
MW          566.651;      // g/mol [origin=calculated method=formula-sum]
Tc          1776.77;      // K   [origin=predictive method=joback]
Pc          11.940;      // bar [origin=predictive method=joback]
omega       0.8851;      // -   [origin=predictive method=lee-kesler]
Tb          1420.27;      // K   [origin=predictive method=joback]
HvapTb      153065.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 2; } { group CH=CH; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2COO; count 1; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 5; } { group dCd; count 2; } { group CH2_ring; count 7; } { group C_ring; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-hydroxyethyloxy)phenoxy]ethanol;5-isocyanato-5-[(1-isocyanatocyclohexa-2,4-dien-1-yl)methyl]cyclohexa-1,3-diene;oxepan-2-one" "2-oxepanone, polymer with 1,1'-methylenebis(isocyanatobenzene) and 2,2'-(1,4-phenylenebis(oxy))bis(ethanol)" );
