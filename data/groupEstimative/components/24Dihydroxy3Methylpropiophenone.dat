/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',4'-dihydroxy-3'-methylpropiophenone  (C10H12O3, CAS 63876-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dihydroxy3Methylpropiophenone;
formula     C10H12O3;
CAS         63876-46-0;
InChIKey    VSJSCDVYCXQGAX-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          911.48;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       1.0442;      // -   [origin=predictive method=lee-kesler]
Tb          675.17;      // K   [origin=predictive method=joback]
HvapTb      73566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.289 1.09664 -0.00097838 3.6556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-methyl-2,4-bis(oxidanyl)phenyl]propan-1-one" "1-(2,4-dihydroxy-3-methylphenyl)propan-1-one" "1-(2,4-dihydroxy-3-methylphenyl)-1-propanone" "2,6-dihydroxy-3-(ethylcarbonyl)toluene" "4-(ethylcarbonyl)-2-methylbenzene-1,3-diol" "1-propanone,1-(2,4-dihydroxy-3-methylphenyl)-" "propiophenone,2,4-dihydroxy-3-methyl- (4ci);1-(2,4-dihydroxy-3-methylphenyl)propan-1-one;" );
gibbsFormation
{
    dHf_298   -491870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-302060.0
    phase     gas;
}
