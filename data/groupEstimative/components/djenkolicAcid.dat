/*--------------------------------*- Choupo -*-----------------------*\
  Component: djenkolic acid  (C7H14N2O4S2, CAS 498-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        djenkolicAcid;
formula     C7H14N2O4S2;
CAS         498-59-9;
InChIKey    JMQMNWIBUCGUDO-WHFBIAKZSA-N;
MW          254.319;      // g/mol [origin=calculated method=formula-sum]
Tc          1179.76;      // K   [origin=predictive method=joback]
Pc          41.731;      // bar [origin=predictive method=joback]
omega       1.7243;      // -   [origin=predictive method=lee-kesler]
Tb          932.52;      // K   [origin=predictive method=joback]
HvapTb      99644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.543 0.89478 -0.000515 9.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHNH2; count 2; } { group COOH; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 2; } { group COOH; count 2; } { group NH2; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanyl-3-[[(2r)-2-azanyl-3-oxidanyl-3-oxidanylidene-propyl]sulfanylmethylsulfanyl]propanoic acid" "djenkolate" "l-djenkolic acid" "l-djenkolate" "3,3'-(methylenedithio)dialanine" "beta,beta'-methylenedithiodialanine" "l-cysteine thioacetal of formaldehyde" "alanine, 3,3'-(methylenedithio)di-" "3,3'-methylenedithiobis(2-aminopropanoic acid)" "jengkolic acid" "s,s'-methylenebiscysteine" "s,s'-methylenebis-l-cysteine" );
standardThermochemistry
{
    dHf_298   -747590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-485500.0
}
