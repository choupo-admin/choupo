/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyric acid, 4-(2,4,5-trichlorophenoxy)-, methyl ester  (C11H11Cl3O3, CAS 25333-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyricAcid4245TrichlorophenoxyMethylEster;
formula     C11H11Cl3O3;
CAS         25333-21-5;
InChIKey    OTBMAATXBNOQHO-UHFFFAOYSA-N;
MW          297.556;      // g/mol [origin=calculated method=formula-sum]
Tc          904.33;      // K   [origin=predictive method=joback]
Pc          22.440;      // bar [origin=predictive method=joback]
omega       0.8461;      // -   [origin=predictive method=lee-kesler]
Tb          685.83;      // K   [origin=predictive method=joback]
HvapTb      67314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (91.463 0.69382 -0.00026028 -1.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-[2,4,5-tris(chloranyl)phenoxy]butanoate" "butanoic acid, 4-(2,4,5-trichlorophenoxy)-, methyl ester" "methyl 4-(2,4,5-trichlorophenoxy)butanoate" "4-(2,4,5-trichlorophenoxy)butanoic acid methyl ester" );
gibbsFormation
{
    dHf_298   -564970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-325900.0
    phase     gas;
}
