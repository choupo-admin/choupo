/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-3,5-diiodobenzoic acid  (C7H4I2O3, CAS 618-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy35DiiodobenzoicAcid;
formula     C7H4I2O3;
CAS         618-76-8;
InChIKey    XREKTVACBXQCSB-UHFFFAOYSA-N;
MW          389.906;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.80;      // K   [origin=predictive method=joback]
Pc          51.387;      // bar [origin=predictive method=joback]
omega       1.0164;      // -   [origin=predictive method=lee-kesler]
Tb          808.81;      // K   [origin=predictive method=joback]
HvapTb      83700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.28 0.7543 -0.00074588 2.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group COOH; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group I; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-bis(iodanyl)-4-oxidanyl-benzoic acid" "ioxynil acid" "3,5-diiodo-4-hydroxybenzoic acid" "benzoic acid, 4-hydroxy-3,5-diiodo-" "benzoic acid, 3,5-diiodo-4-hydroxy-" "3,5-diiodo-4-hydroxy-benzoic acid" "benzoic acid,4-hydroxy-3,5-diiodo-" );
standardThermochemistry
{
    dHf_298   -348060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281080.0
}
