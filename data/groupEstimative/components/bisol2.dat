/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisol 2  (C7H16N2O4, CAS 132050-00-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisol2;
formula     C7H16N2O4;
CAS         132050-00-1;
InChIKey    FIBXFCHTGYEBED-UHFFFAOYSA-N;
MW          192.215;      // g/mol [origin=calculated method=formula-sum]
Tc          878.73;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       1.1949;      // -   [origin=predictive method=lee-kesler]
Tb          677.06;      // K   [origin=predictive method=joback]
HvapTb      69884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.161 0.81208 -0.0003126 -1.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH3N; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group COOH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanedioic acid;n,n,n',n'-tetramethylmethanediamine" "n,n,n',n'-tetramethylmethanediamine ethanedioate" "methanediamine, n,n,n',n'-tetramethyl-, ethanedioate" "oxalic acid; n,n,n',n'-tetramethylmethanediamine" );
gibbsFormation
{
    dHf_298   -864910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-562960.0
    phase     gas;
}
