/*--------------------------------*- Choupo -*-----------------------*\
  Component: (heptafluoropropyl)trimethylsilane  (C6H9F7Si, CAS 3834-42-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H9F7Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        heptafluoropropylTrimethylsilane;
formula     C6H9F7Si;
CAS         3834-42-2;
InChIKey    PKLASFRWKXWKII-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          242.209;      // g/mol [origin=calculated method=formula-sum]
Tc          462.40;      // K   [origin=predictive method=joback]
Pc          21.197;      // bar [origin=predictive method=joback]
omega       0.3178;      // -   [origin=predictive method=lee-kesler]
Tb          323.48;      // K   [origin=predictive method=joback]
HvapTb      19637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.47 0.82766 -0.000518 9.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CF3; count 1; } { group CF2; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 3; } { group F; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,3,3-heptakis(fluoranyl)propyl-trimethyl-silane" "1-(trimethylsilyl)heptafluoropropane" "1,1,2,2,3,3,3-heptafluoropropyl(trimethyl)silane" "silane,(1,1,2,2,3,3,3-heptafluoropropyl)trimethyl-" );
standardThermochemistry
{
    dHf_298   -1677810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1460270.0
}
