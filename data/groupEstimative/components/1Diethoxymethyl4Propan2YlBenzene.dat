/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(diethoxymethyl)-4-(propan-2-yl)benzene  (C14H22O2, CAS 35364-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Diethoxymethyl4Propan2YlBenzene;
formula     C14H22O2;
CAS         35364-90-0;
InChIKey    GGYICDQKJLQSFI-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          795.17;      // K   [origin=predictive method=joback]
Pc          19.510;      // bar [origin=predictive method=joback]
omega       0.6659;      // -   [origin=predictive method=lee-kesler]
Tb          595.54;      // K   [origin=predictive method=joback]
HvapTb      53740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.192 1.08088 -0.00048636 4.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group ACCH; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(diethoxymethyl)-4-propan-2-yl-benzene" "1-(diethoxymethyl)-4-propan-2-ylbenzene" "benzene,1-(diethoxymethyl)-4-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -382230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45100.0
    phase     gas;
}
