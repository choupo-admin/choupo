/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodo-l-tyrosine  (C9H10INO3, CAS 70-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3IodoLTyrosine;
formula     C9H10INO3;
CAS         70-78-0;
InChIKey    UQTZMGFTRHFAAM-ZETCQYMHSA-N;
MW          307.083;      // g/mol [origin=calculated method=formula-sum]
Tc          1095.18;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       1.2540;      // -   [origin=predictive method=lee-kesler]
Tb          828.54;      // K   [origin=predictive method=joback]
HvapTb      88370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.719 1.0326 -0.00088692 3.08e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 1; } { group OH_phenol; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-(3-iodanyl-4-oxidanyl-phenyl)propanoic acid" "3-iodo-tyrosine" "3-monoiodo-l-tyrosine" "iodotyrosine" "tyrosine, 3-iodo-" "(2s)-2-amino-3-(4-hydroxy-3-iodophenyl)propanoic acid" "(s)-2-amino-3-(4-hydroxy-3-iodophenyl)propanoic acid" "iyr" "l-tyrosine-3-iodo" "iotyrosine" "4-hydroxy-3-iodophenylalanine" "s(-)-3-iodo-4-hydroxy-phenylamine" );
gibbsFormation
{
    dHf_298   -426230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248720.0
    phase     gas;
}
