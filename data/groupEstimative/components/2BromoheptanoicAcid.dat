/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoheptanoic acid  (C7H13BrO2, CAS 2624-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromoheptanoicAcid;
formula     C7H13BrO2;
CAS         2624-01-3;
InChIKey    NQRFAUVGDLHPGH-UHFFFAOYSA-N;
MW          209.083;      // g/mol [origin=calculated method=formula-sum]
Tc          775.64;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.8430;      // -   [origin=predictive method=lee-kesler]
Tb          570.99;      // K   [origin=predictive method=joback]
HvapTb      54387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.634 0.76372 -0.0005042 1.337e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylheptanoic acid" "agn-pc-0cp3je" "nqrfauvgdlhpgh-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -517030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-323970.0
    phase     gas;
}
