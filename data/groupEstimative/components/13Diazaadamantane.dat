/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diazaadamantane  (C8H14N2, CAS 281-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diazaadamantane;
formula     C8H14N2;
CAS         281-29-8;
InChIKey    QQQIDWOQAXJWFO-UHFFFAOYSA-N;
MW          138.214;      // g/mol [origin=calculated method=formula-sum]
Tc          625.85;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.4697;      // -   [origin=predictive method=lee-kesler]
Tb          428.14;      // K   [origin=predictive method=joback]
HvapTb      37364.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-177.31 1.5004 -0.001399 5.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diazatricyclo[3.3.1.13,7]decane" "1,3-diazatricyclo(3.3.1.13,7)decane" );
gibbsFormation
{
    dHf_298   171510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     251.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=440100.0
    phase     gas;
}
