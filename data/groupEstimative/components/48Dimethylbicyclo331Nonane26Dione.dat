/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,8-dimethylbicyclo[3.3.1]nonane-2,6-dione  (C11H16O2, CAS 139914-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        48Dimethylbicyclo331Nonane26Dione;
formula     C11H16O2;
CAS         139914-54-8;
InChIKey    OTBXXMWIANCGFF-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          844.29;      // K   [origin=predictive method=joback]
Pc          26.708;      // bar [origin=predictive method=joback]
omega       0.5359;      // -   [origin=predictive method=lee-kesler]
Tb          603.87;      // K   [origin=predictive method=joback]
HvapTb      48298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.22 0.93224 -0.000277 -5.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 4; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,8-dimethylbicyclo(3.3.1)nona-2,6-dione" "bicyclo[3.3.1]nonane-2,6-dione,4,8-dimethyl-, (exo,exo)- (9ci)" "4,8-dimethylbicyclo[3.3.1]nona-2,6-dione" "agn-pc-03f3g4" "(1r,4s,5r,8r)-4,8-dimethylbicyclo[3.3.1]nonane-2,6-dione" );
standardThermochemistry
{
    dHf_298   -459330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     221.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133660.0
}
