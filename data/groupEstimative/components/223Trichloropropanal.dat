/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3-trichloropropanal  (C3H3Cl3O, CAS 7789-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223Trichloropropanal;
formula     C3H3Cl3O;
CAS         7789-90-4;
InChIKey    VMVQOWJGWBIGEU-UHFFFAOYSA-N;
MW          161.406;      // g/mol [origin=calculated method=formula-sum]
Tc          638.96;      // K   [origin=predictive method=joback]
Pc          43.056;      // bar [origin=predictive method=joback]
omega       0.3846;      // -   [origin=predictive method=lee-kesler]
Tb          425.96;      // K   [origin=predictive method=joback]
HvapTb      40851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.761 0.4095 -0.0003654 1.213e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group CH2Cl; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group Cl; count 3; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3-tris(chloranyl)propanal" "propionaldehyde, 2,2,3-trichloro-" "2,2,3-trichloropropionaldehyde" "propanal, 2,2,3-trichloro-" );
standardThermochemistry
{
    dHf_298   -246800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158090.0
}
