/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-furanone, dihydro-5-(2-methylpropyl)-  (C8H14O2, CAS 18432-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hFuranoneDihydro52Methylpropyl;
formula     C8H14O2;
CAS         18432-37-6;
InChIKey    CFNNUWKVCNMSFJ-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          636.90;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.4787;      // -   [origin=predictive method=lee-kesler]
Tb          447.16;      // K   [origin=predictive method=joback]
HvapTb      40334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.899 0.86584 -0.0005402 1.257e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(2-methylpropyl)oxolan-2-one" "5-isobutyldihydrofuran-2(3h)-one" "agn-pc-0cu1db" "5-isobutyltetrahydrofuran-2-one" );
standardThermochemistry
{
    dHf_298   -458210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235580.0
}
