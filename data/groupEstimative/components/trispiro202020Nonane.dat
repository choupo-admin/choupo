/*--------------------------------*- Choupo -*-----------------------*\
  Component: trispiro(2.0.2.0.2.0)nonane  (C9H12, CAS 31561-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trispiro202020Nonane;
formula     C9H12;
CAS         31561-59-8;
InChIKey    HAIZYAZVYQEJME-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          655.16;      // K   [origin=predictive method=joback]
Pc          46.340;      // bar [origin=predictive method=joback]
omega       0.3011;      // -   [origin=predictive method=lee-kesler]
Tb          425.06;      // K   [origin=predictive method=joback]
HvapTb      31620.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-346.81 2.3934 -0.003139 1.505e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trispiro[2.0.2^{4}.0.2^{7}.0^{3}]nonane" "trispiro[2.0.2.0.2.0]nonane" );
standardThermochemistry
{
    dHf_298   146650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     336.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=295440.0
}
