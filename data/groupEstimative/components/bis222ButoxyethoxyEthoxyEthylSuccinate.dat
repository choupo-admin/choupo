/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-(2-(2-butoxyethoxy)ethoxy)ethyl) succinate  (C24H46O10, CAS 65520-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis222ButoxyethoxyEthoxyEthylSuccinate;
formula     C24H46O10;
CAS         65520-45-8;
InChIKey    POSOSGFICGBKPO-UHFFFAOYSA-N;
MW          494.622;      // g/mol [origin=calculated method=formula-sum]
Tc          1246.11;      // K   [origin=predictive method=joback]
Pc          7.656;      // bar [origin=predictive method=joback]
omega       0.5576;      // -   [origin=predictive method=lee-kesler]
Tb          999.68;      // K   [origin=predictive method=joback]
HvapTb      98292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (184.89 1.79504 -0.0004266 -1.686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH2COO; count 2; } { group CH2O; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 20; } { group O; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-[2-(2-butoxyethoxy)ethoxy]ethyl] butanedioate" "butanedioic acid, bis(2-(2-(2-butoxyethoxy)ethoxy)ethyl) ester" "dibutylcarbityl succinate" "bis[2-[2-(2-butoxyethoxy)ethoxy]ethyl] succinate" "butanedioic acid, bis[2-[2-(2-butoxyethoxy)ethoxy]ethyl] ester" "butanedioic acid, 1,4-bis(2-(2-(2-butoxyethoxy)ethoxy)ethyl) ester" "butanedioic acid, 1,4-bis[2-[2-(2-butoxyethoxy)ethoxy]ethyl] ester" );
standardThermochemistry
{
    dHf_298   -1966570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1261.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1099540.0
}
