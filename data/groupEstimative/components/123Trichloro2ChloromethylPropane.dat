/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-trichloro-2-(chloromethyl)propane  (C4H6Cl4, CAS 18963-00-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Trichloro2ChloromethylPropane;
formula     C4H6Cl4;
CAS         18963-00-3;
InChIKey    CFLWPMRPCYBIIS-UHFFFAOYSA-N;
MW          195.892;      // g/mol [origin=calculated method=formula-sum]
Tc          648.69;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.3415;      // -   [origin=predictive method=lee-kesler]
Tb          437.61;      // K   [origin=predictive method=joback]
HvapTb      40742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.343 0.5368 -0.0004472 1.443e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH2; count 3; } { group C; count 1; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(chloranyl)-2-(chloromethyl)propane" "propane, 1,2,3-trichloro-2-(chloromethyl)-" "propane,1,2,3-trichloro-2-(chloromethyl)-" );
standardThermochemistry
{
    dHf_298   -197600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62080.0
}
