{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-522.27 5.88352 -0.00536739 2.09205e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 6; } { group C; count 5; } { group CH=C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 13; } { group CH_ring; count 7; } { group C_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
