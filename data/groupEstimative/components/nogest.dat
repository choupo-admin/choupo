name        nogest;
formula     C44H58O6;
CAS         8003-08-5;
InChIKey    YSZHJUWOONGQGP-YOIZPZDGSA-N;
MW          682.942;      // g/mol [origin=calculated method=formula-sum]
Tc          2063.07;      // K   [origin=predictive method=joback]
Pc          7.908;      // bar [origin=predictive method=joback]
omega       0.5146;      // -   [origin=predictive method=lee-kesler]
Tb          1641.27;      // K   [origin=predictive method=joback]
HvapTb      158970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
