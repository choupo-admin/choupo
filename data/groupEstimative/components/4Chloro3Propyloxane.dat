/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-3-propyloxane  (C8H15ClO, CAS 31563-52-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro3Propyloxane;
formula     C8H15ClO;
CAS         31563-52-7;
InChIKey    WZCICSOYQNNEDU-UHFFFAOYSA-N;
MW          162.657;      // g/mol [origin=calculated method=formula-sum]
Tc          669.28;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.3861;      // -   [origin=predictive method=lee-kesler]
Tb          461.90;      // K   [origin=predictive method=joback]
HvapTb      42417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.838 0.86322 -0.0004435 6.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group FCH2O; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group Cl; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-3-propyl-oxane" "pyran, 4-chloro-3-propyltetrahydro-" "4-chloro-3-propyltetrahydro-2h-pyran" "pyran, 4-chloro-3-propyltetrahydro-," "2h-pyran, 4-chlorotetrahydro-3-propyl-" );
standardThermochemistry
{
    dHf_298   -322210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64830.0
}
