/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetyl-2-heptanone  (C9H16O2, CAS 1540-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetyl2Heptanone;
formula     C9H16O2;
CAS         1540-36-9;
InChIKey    MBXOOYPCIDHXGH-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          700.51;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.6737;      // -   [origin=predictive method=lee-kesler]
Tb          512.82;      // K   [origin=predictive method=joback]
HvapTb      48732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.743 0.80876 -0.0004316 7.732e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butylpentane-2,4-dione" "3-butyl-2,4-pentanedione" "2,4-pentanedione, 3-butyl-" "3-n-butyl-2,4-pentanedione" "3-butylacetylacetone" "2, 3-butyl-" "2,4-pentanedione,3-butyl-" );
gibbsFormation
{
    dHf_298   -459530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235380.0
    phase     gas;
}
