/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-2,2,5,5-tetramethylhex-3-ene  (C10H20, CAS 692-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e2255Tetramethylhex3Ene;
formula     C10H20;
CAS         692-48-8;
InChIKey    UYWLQEPMPVDASH-BQYQJAHWSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          619.20;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.2789;      // -   [origin=predictive method=lee-kesler]
Tb          426.10;      // K   [origin=predictive method=joback]
HvapTb      35220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.33 1.22552 -0.0009476 2.99e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexene, 2,2,5,5-tetramethyl-, (e)-" "trans-1,2-di-tert-butylethylene" "(e)-2,2,5,5-tetramethyl-hex-3-ene" );
standardThermochemistry
{
    dHf_298   -150010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119220.0
}
