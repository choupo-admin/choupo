/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4r)-4-methyl-1-propan-2-yl-cyclohexene  (C10H18, CAS 619-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4r4Methyl1Propan2YlCyclohexene;
formula     C10H18;
CAS         619-52-3;
InChIKey    YYCPSEFQLGXPCO-VIFPVBQESA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          656.61;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.3350;      // -   [origin=predictive method=lee-kesler]
Tb          451.65;      // K   [origin=predictive method=joback]
HvapTb      38849.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.41 0.96636 -0.00052464 9.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -154380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75660.0
    phase     gas;
}
