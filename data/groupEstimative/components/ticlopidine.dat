/*--------------------------------*- Choupo -*-----------------------*\
  Component: ticlopidine  (C14H14ClNS, CAS 55142-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ticlopidine;
formula     C14H14ClNS;
CAS         55142-85-3;
InChIKey    PHWBOXQYWZNQIN-UHFFFAOYSA-N;
MW          263.783;      // g/mol [origin=calculated method=formula-sum]
Tc          946.24;      // K   [origin=predictive method=joback]
Pc          28.505;      // bar [origin=predictive method=joback]
omega       0.6777;      // -   [origin=predictive method=lee-kesler]
Tb          688.92;      // K   [origin=predictive method=joback]
HvapTb      64632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.869 1.44511 -0.00115254 3.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group Cl; count 1; } { group N; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[(2-chlorophenyl)methyl]-6,7-dihydro-4h-thieno[3,2-c]pyridine" "ticlid" "ticlopidina" "ticlopidinum" "ticlopidine [inn:ban]" "ticlopidinum [inn-latin]" "ticlopidine (inn)" "5-(2-chlorobenzyl)-4,5,6,7-tetrahydrothieno[3,2-c]pyridine" "ticlopidin-puren (tn)" "thieno(3,2-c)pyridine, 4,5,6,7-tetrahydro-5-((2-chlorophenyl)methyl)-" "5-((2-chlorophenyl)methyl)-4,5,6,7-tetrahydrothieno(3,2-c)pyridine" "thieno(3,2-c)pyridine, 5-((2-chlorophenyl)methyl)-4,5,6,7-tetrahydro-" );
standardThermochemistry
{
    dHf_298   256400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=461870.0
}
