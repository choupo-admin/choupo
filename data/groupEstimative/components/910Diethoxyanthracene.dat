/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-diethoxyanthracene  (C18H18O2, CAS 68818-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910Diethoxyanthracene;
formula     C18H18O2;
CAS         68818-86-0;
InChIKey    GJNKQJAJXSUJBO-UHFFFAOYSA-N;
MW          266.34;      // g/mol [origin=calculated method=formula-sum]
Tc          964.16;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       0.8453;      // -   [origin=predictive method=lee-kesler]
Tb          735.86;      // K   [origin=predictive method=joback]
HvapTb      68024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.368 1.32264 -0.00083692 2.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 6; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anthracene, 9,10-diethoxy-" );
gibbsFormation
{
    dHf_298   -95030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187500.0
    phase     gas;
}
