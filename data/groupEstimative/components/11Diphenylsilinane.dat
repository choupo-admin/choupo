/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diphenylsilinane  (C17H20Si, CAS 18002-79-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C17H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11Diphenylsilinane;
formula     C17H20Si;
CAS         18002-79-4;
InChIKey    BXGZDRHWAIMTPD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          252.432;      // g/mol [origin=calculated method=formula-sum]
Tc          930.01;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       0.4451;      // -   [origin=predictive method=lee-kesler]
Tb          663.27;      // K   [origin=predictive method=joback]
HvapTb      58848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.98 1.413 -0.0007314 9.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 10; } { group AC; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diphenylsilacyclohexane" "silacyclohexane, 1,1-diphenyl-" "cyclopentamethylenediphenylsilane" );
standardThermochemistry
{
    dHf_298   48050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=256580.0
}
