/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrethrin i  (C21H28O3, CAS 121-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrethrinI;
formula     C21H28O3;
CAS         121-21-1;
InChIKey    ROVGZAWFACYCSP-UHFFFAOYSA-N;
MW          328.452;      // g/mol [origin=calculated method=formula-sum]
Tc          1053.99;      // K   [origin=predictive method=joback]
Pc          13.242;      // bar [origin=predictive method=joback]
omega       0.8542;      // -   [origin=predictive method=lee-kesler]
Tb          833.04;      // K   [origin=predictive method=joback]
HvapTb      73337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.869 2.1422 -0.0015954 5.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 4; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-4-oxidanylidene-3-penta-2,4-dienyl-cyclopent-2-en-1-yl) 2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "cyclopropanecarboxylic acid, 2,2-dimethyl-3-(2-methyl-1-propenyl)-, (1s)-2-methyl-4-oxo-3-(2z)-2,4-pentadienyl-2-cyclopenten-1-yl ester, (1r,3r)-" "(1s)-2-methyl-4-oxo-3-(penta-2,4-dien-1-yl)cyclopent-2-en-1-yl (1r,3r)-2,2-dimethyl-3-(2-methylprop-1-en-1-yl)cyclopropanecarboxylate" "(2-methyl-4-oxo-3-penta-2,4-dienylcyclopent-2-en-1-yl) 2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "2-methyl-4-oxo-3-(penta-2,4-dien-1-yl)cyclopent-2-en-1-yl 2,2-dimethyl-3-(2-methylprop-1-en-1-yl)cyclopropanecarboxylate" );
standardThermochemistry
{
    dHf_298   -438990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19800.0
}
