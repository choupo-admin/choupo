/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-bis(2-hydroxybenzyl)ethylenediamine  (C16H20N2O2, CAS 18653-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxybenzylEthylenediamine;
formula     C16H20N2O2;
CAS         18653-98-0;
InChIKey    MLFXJCXPSODAIS-UHFFFAOYSA-N;
MW          272.348;      // g/mol [origin=calculated method=formula-sum]
Tc          1121.18;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       1.4421;      // -   [origin=predictive method=lee-kesler]
Tb          880.62;      // K   [origin=predictive method=joback]
HvapTb      94662.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.726 1.8276 -0.00151892 5.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group ACCH2; count 2; } { group ACOH; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2-[(2-hydroxyphenyl)methylamino]ethylamino]methyl]phenol" "h4 salen" "2-[((2-[(2-hydroxybenzyl)amino]ethyl)amino)methyl]phenol" "n n'-bis(2-hydroxybenzyl)ethylenediamine h4 salen" "alpha, alpha'-(ethylenediimino)di-o-cresol" "n,n&#39-bis(2-hydroxybenzyl)ethylenediamine" "n,n'-bis(2-hydroxybenzyl)ethylenediamine h4 salen" "2,2'-((ethane-1,2-diylbis(azanediyl))bis(methylene))diphenol" "phenol,2,2'-[1,2-ethanediylbis(iminomethylene)]bis- (9ci)" );
standardThermochemistry
{
    dHf_298   -148190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178200.0
}
