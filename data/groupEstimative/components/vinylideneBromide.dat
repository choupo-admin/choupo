/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinylidene bromide  (C2H2Br2, CAS 593-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylideneBromide;
formula     C2H2Br2;
CAS         593-92-0;
InChIKey    IWHJPYXAFGKABF-UHFFFAOYSA-N;
MW          185.846;      // g/mol [origin=calculated method=formula-sum]
Tc          594.59;      // K   [origin=predictive method=joback]
Pc          66.639;      // bar [origin=predictive method=joback]
omega       0.3035;      // -   [origin=predictive method=lee-kesler]
Tb          374.24;      // K   [origin=predictive method=joback]
HvapTb      32326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.77 0.2501 -0.000253 1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(bromanyl)ethene" "ethene, 1,1-dibromo-" "1,1-dibromoethene" "gem-dibromoethylene" "1,1-dibromoethylene" "2,2-dibromoethyl" "ethylene, 1,1-dibromo- (6ci,7ci,8ci)" "ethylene, 1,1-dibromo-" );
gibbsFormation
{
    dHf_298   83690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73890.0
    phase     gas;
}
