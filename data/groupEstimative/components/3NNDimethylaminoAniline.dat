/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(n,n-dimethylamino)aniline  (C8H12N2, CAS 2836-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3NNDimethylaminoAniline;
formula     C8H12N2;
CAS         2836-04-6;
InChIKey    HHSBHVJQXZLIRW-UHFFFAOYSA-N;
MW          136.198;      // g/mol [origin=calculated method=formula-sum]
Tc          720.33;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.5244;      // -   [origin=predictive method=lee-kesler]
Tb          499.27;      // K   [origin=predictive method=joback]
HvapTb      49024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.19 0.81124 -0.00053156 1.33e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n3,n3-dimethylbenzene-1,3-diamine" "n,n-dimethyl-m-phenylenediamine" "1,3-benzenediamine, n,n-dimethyl-" "n1,n1-dimethylbenzene-1,3-diamine" "1,3-benzenediamine, n1,n1-dimethyl-" "n,n-dimethyl-m-phenylenediaminedihydrochloride" "n,n-dimethyl-3-phenylenediamine" "n,n-dimethyl-1,3-benzenediamine" "n,n-dimethylbenzene-1,3-diamine" "3575-32-4 (di-hydrochloride)" "n,n-dimethyl-1,3-phenylenediamine" "1,3-benzenediamine,n1,n1-dimethyl-" );
gibbsFormation
{
    dHf_298   117930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=296490.0
    phase     gas;
}
