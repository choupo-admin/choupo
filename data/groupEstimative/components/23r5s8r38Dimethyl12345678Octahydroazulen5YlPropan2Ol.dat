/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[(3r,5s,8r)-3,8-dimethyl-1,2,3,4,5,6,7,8-octahydroazulen-5-yl]propan-2-ol  (C15H26O, CAS 489-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23r5s8r38Dimethyl12345678Octahydroazulen5YlPropan2Ol;
formula     C15H26O;
CAS         489-86-1;
InChIKey    TWVJWDMOZJXUID-UTUOFQBUSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          872.88;      // K   [origin=predictive method=joback]
Pc          20.401;      // bar [origin=predictive method=joback]
omega       0.8467;      // -   [origin=predictive method=lee-kesler]
Tb          666.76;      // K   [origin=predictive method=joback]
HvapTb      66188.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.58 1.65058 -0.001047 2.542e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-azulenemethanol, 1,2,3,4,5,6,7,8-octahydro-.alpha.,.alpha.,3,8-tetramethyl-, [3s-(3.alpha.,5.alpha.,8.alpha.)]-" );
gibbsFormation
{
    dHf_298   -378450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17530.0
    phase     gas;
}
