/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentene, 3-methyl-  (C6H12, CAS 922-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentene3Methyl;
formula     C6H12;
CAS         922-61-2;
InChIKey    BEQGRRJLJLVQAQ-UHFFFAOYSA-N;
MW          84.162;      // g/mol [origin=calculated method=formula-sum]
Tc          516.99;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.2490;      // -   [origin=predictive method=lee-kesler]
Tb          340.92;      // K   [origin=predictive method=joback]
HvapTb      28988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.439 0.59376 -0.0003887 1.094e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpent-2-ene" "trans-3-methyl-2-pentene" "cis-3-methyl-2-pentene" "3-methyl-2-pentene" "3-methyl-2-pentene, mixture of cis and trans" );
standardThermochemistry
{
    dHf_298   -59740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71310.0
}
