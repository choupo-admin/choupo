/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-2-propan-2-ylhex-2-enal  (C10H18O, CAS 35158-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl2Propan2Ylhex2Enal;
formula     C10H18O;
CAS         35158-25-9;
InChIKey    IOLQAHFPDADCHJ-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          667.41;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       0.5238;      // -   [origin=predictive method=lee-kesler]
Tb          480.22;      // K   [origin=predictive method=joback]
HvapTb      43836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.039 0.96008 -0.0006057 1.539e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-2-propan-2-yl-hex-2-enal" );
standardThermochemistry
{
    dHf_298   -238440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=590.0
}
