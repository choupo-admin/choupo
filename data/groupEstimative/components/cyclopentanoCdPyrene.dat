/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentano(cd)pyrene  (C18H12, CAS 25732-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentanoCdPyrene;
formula     C18H12;
CAS         25732-74-5;
InChIKey    LEYRJZXFRUAKLV-UHFFFAOYSA-N;
MW          228.294;      // g/mol [origin=calculated method=formula-sum]
Tc          969.36;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.7537;      // -   [origin=predictive method=lee-kesler]
Tb          714.42;      // K   [origin=predictive method=joback]
HvapTb      64920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.11 1.648 -0.00155612 5.852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 6; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenta(cd)pyrene, 3,4-dihydro-" "3,4-dihydrocyclopenta[cd]pyrene" );
gibbsFormation
{
    dHf_298   402850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     329.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=569320.0
    phase     gas;
}
