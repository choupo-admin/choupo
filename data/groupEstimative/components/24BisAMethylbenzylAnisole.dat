/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-bis(|a-methylbenzyl)anisole  (C23H24O, CAS 2456-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24BisAMethylbenzylAnisole;
formula     C23H24O;
CAS         2456-45-3;
InChIKey    LSILZVKNUDAPDE-UHFFFAOYSA-N;
MW          316.444;      // g/mol [origin=calculated method=formula-sum]
Tc          1085.18;      // K   [origin=predictive method=joback]
Pc          16.471;      // bar [origin=predictive method=joback]
omega       0.7932;      // -   [origin=predictive method=lee-kesler]
Tb          837.38;      // K   [origin=predictive method=joback]
HvapTb      76578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.0 1.78176 -0.00108232 2.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 13; } { group AC; count 3; } { group ACCH; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2,4-bis(1-phenylethyl)benzene" "2,4-bis(.alpha.-methylbenzyl)anisole" "benzene, 1-methoxy-2,4-bis(1-phenylethyl)-" "2,4-bis(alpha-methylbenzyl)anisole" "anisole,4-bis(.alpha.-methylbenzyl)-" "2,4-bis(1-phenylethyl)anisole" "anisole, 2,4-bis(alpha-methylbenzyl)- (8ci)" );
gibbsFormation
{
    dHf_298   25820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     712.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=350870.0
    phase     gas;
}
