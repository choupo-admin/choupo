/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(dipropylamino)butan-1-ol  (C10H23NO, CAS 70289-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4DipropylaminoButan1Ol;
formula     C10H23NO;
CAS         70289-17-7;
InChIKey    KYNWWRBJIBSVBX-UHFFFAOYSA-N;
MW          173.3;      // g/mol [origin=calculated method=formula-sum]
Tc          690.60;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       1.0170;      // -   [origin=predictive method=lee-kesler]
Tb          533.02;      // K   [origin=predictive method=joback]
HvapTb      56576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.602 1.11174 -0.0006632 1.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butanol, 4-dipropylamino-" "1-butanol, 4-dipropylamino-," "4-di-n-propylamino-1-butanol" );
gibbsFormation
{
    dHf_298   -334430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7280.0
    phase     gas;
}
