/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxythioanisole  (C8H10OS, CAS 2388-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxythioanisole;
formula     C8H10OS;
CAS         2388-73-0;
InChIKey    YCUXDIFPTHNTSR-UHFFFAOYSA-N;
MW          154.227;      // g/mol [origin=calculated method=formula-sum]
Tc          738.86;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.4323;      // -   [origin=predictive method=lee-kesler]
Tb          505.50;      // K   [origin=predictive method=joback]
HvapTb      45567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.11 0.55663 -0.00022436 2.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-methylsulfanyl-benzene" "2-methoxy thioanisole" "1-methoxy-2-(methylthio)benzene" "2-(methylthio)anisole" "benzene, 1-methoxy-2-(methylthio)-" "anisole, o-(methylthio)-" "1-methoxy-2-methylthiobenzene" "2-methoxy-1-methylthiobenzene" "2-methoxyphenyl methyl sulfide" "1-methoxy-2-methylsulfanylbenzene" "1-methoxy-2-(methylsulfanyl)benzene" "l298" );
standardThermochemistry
{
    dHf_298   -73740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47380.0
}
