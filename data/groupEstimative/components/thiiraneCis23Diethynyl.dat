/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiirane, cis-2,3-diethynyl-  (C6H4S, CAS 50555-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiiraneCis23Diethynyl;
formula     C6H4S;
CAS         50555-55-0;
InChIKey    ZEODDVBXGCQFTC-UHFFFAOYSA-N;
MW          108.158;      // g/mol [origin=calculated method=formula-sum]
Tc          594.68;      // K   [origin=predictive method=joback]
Pc          50.514;      // bar [origin=predictive method=joback]
omega       0.1619;      // -   [origin=predictive method=lee-kesler]
Tb          367.02;      // K   [origin=predictive method=joback]
HvapTb      34082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.51 0.52481 -0.00047796 1.7688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH_C; count 2; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 2; } { group tC; count 2; } { group CH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-diethynylthiirane" "thiirane,cis-2,3-diethynyl-" "thiirane,trans-2,3-diethynyl-" "thiirane, trans-2,3-diethynyl-" );
gibbsFormation
{
    dHf_298   514350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     246.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=538680.0
    phase     gas;
}
