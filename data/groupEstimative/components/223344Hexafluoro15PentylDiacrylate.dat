/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3,3,4,4-hexafluoro-1,5-pentyl diacrylate  (C11H10F6O4, CAS 678-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        223344Hexafluoro15PentylDiacrylate;
formula     C11H10F6O4;
CAS         678-95-5;
InChIKey    DOZNAYNLYNBXKE-UHFFFAOYSA-N;
MW          320.185;      // g/mol [origin=calculated method=formula-sum]
Tc          709.24;      // K   [origin=predictive method=joback]
Pc          17.463;      // bar [origin=predictive method=joback]
omega       0.8280;      // -   [origin=predictive method=lee-kesler]
Tb          547.01;      // K   [origin=predictive method=joback]
HvapTb      44764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.852 1.3474 -0.001045 2.896e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group CF2; count 3; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 3; } { group dCH2; count 2; } { group dCH; count 2; } { group F; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2,3,3,4,4-hexakis(fluoranyl)-5-prop-2-enoyloxy-pentyl] prop-2-enoate" "2-propenoic acid, 2,2,3,3,4,4-hexafluoro-1,5-pentanediyl ester" "2-propenoic acid, 1,1'-(2,2,3,3,4,4-hexafluoro-1,5-pentanediyl) ester" "1h,1h,5h,5h-perfluoropentane-1,5-diyl diacrylate" "2,2,3,3,4,4-hexafluoropentane-1,5-diyl bis(prop-2-enoate)" "(2,2,3,3,4,4-hexafluoro-5-prop-2-enoyloxypentyl) prop-2-enoate" "2,2,3,3,4,4-hexafluoro-5-(prop-2-enoyloxy)pentyl prop-2-enoate" "2-propenoic acid [2,2,3,3,4,4-hexafluoro-5-(1-oxoprop-2-enoxy)pentyl] ester" "2-propenoicacid, 2,2,3,3,4,4-hexafluoro-1,5-pentanediyl ester (9ci); acrylic acid, 2,2,3,3,4,4-hexafluoropentamethyleneester (7ci,8ci); 2,2,3,3,4,4-hexafluoropentamethylene diacrylate" );
standardThermochemistry
{
    dHf_298   -1856980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     751.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1563660.0
}
