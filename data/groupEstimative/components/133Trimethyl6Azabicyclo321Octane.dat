/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-trimethyl-6-azabicyclo[3.2.1]octane  (C10H19N, CAS 53460-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Trimethyl6Azabicyclo321Octane;
formula     C10H19N;
CAS         53460-46-1;
InChIKey    FRAKHUZTNLUGPB-UHFFFAOYSA-N;
MW          153.269;      // g/mol [origin=calculated method=formula-sum]
Tc          725.05;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.3674;      // -   [origin=predictive method=lee-kesler]
Tb          494.78;      // K   [origin=predictive method=joback]
HvapTb      42171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.05 1.78036 -0.001817 7.815e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,5-trimethyl-7-azabicyclo[3.2.1]octane" "1,3,3-trimethyl-6-azabicyclo(3.2.1)octane" "1,3,3-trimethyl-6-aza-bicyclo[3.2.1]octane" "6-azabicyclo(3.2.1)octane, 1,3,3-trimethyl-" "6-azabicyclo[3.2.1]octane, 1,3,3-trimethyl-" "6-azabicyclo[3.2.1]octane,1,3,3-trimethyl-" );
gibbsFormation
{
    dHf_298   -68500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=199640.0
    phase     gas;
}
