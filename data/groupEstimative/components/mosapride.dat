/*--------------------------------*- Choupo -*-----------------------*\
  Component: mosapride  (C21H25ClFN3O3, CAS 112885-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mosapride;
formula     C21H25ClFN3O3;
CAS         112885-41-3;
InChIKey    YPELFRMCRYSPKZ-UHFFFAOYSA-N;
MW          421.897;      // g/mol [origin=calculated method=formula-sum]
Tc          1287.30;      // K   [origin=predictive method=joback]
Pc          16.949;      // bar [origin=predictive method=joback]
omega       1.3454;      // -   [origin=predictive method=lee-kesler]
Tb          1043.72;      // K   [origin=predictive method=joback]
HvapTb      106151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.547 1.92112 -0.00113804 2.3056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group ACF; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group F; count 1; } { group Cl; count 1; } { group O; count 1; } { group O_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-5-chloranyl-2-ethoxy-n-[[4-[(4-fluorophenyl)methyl]morpholin-2-yl]methyl]benzamide" "4-amino-5-chloro-2-ethoxy-n-((4-(4-fluorobenzyl)-2-morpholinyl)methyl)benzamide" "mosapride [inn]" "mosapride (inn)" "4-amino-5-chloro-2-ethoxy-n-[[4-[(4-fluorophenyl)methyl]morpholin-2-yl]methyl]benzamide" "4-amino-5-chloro-2-ethoxy-n-[[4-[(4-fluorophenyl)methyl]-2-morpholinyl]methyl]benzamide" "4-amino-5-chloro-2-ethoxy-n-{[4-(4-fluorobenzyl)morpholin-2-yl]methyl}benzamide" "mosart (tn)" "agn-pc-00f93s" "m687" "(+-)-4-amino-5-chloro-2-ethoxy-n-((4-(p-fluorobenzyl)-2-morpholinyl)methyl)benzamide" "(- )-4-amino-5-chloro-2-ethoxy-n-((4-(p-fluorobenzyl)-2-morpholinyl)methyl)-benzamide" );
gibbsFormation
{
    dHf_298   -422970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     846.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88630.0
    phase     gas;
}
