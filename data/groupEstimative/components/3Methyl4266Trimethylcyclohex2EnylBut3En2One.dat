/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-4-(2,6,6-trimethylcyclohex-2-enyl)but-3-en-2-one  (C14H22O, CAS 127-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl4266Trimethylcyclohex2EnylBut3En2One;
formula     C14H22O;
CAS         127-51-5;
InChIKey    JRJBVWJSTHECJK-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          815.23;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       0.5473;      // -   [origin=predictive method=lee-kesler]
Tb          597.09;      // K   [origin=predictive method=joback]
HvapTb      53465.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.93 1.5978 -0.00128364 4.5426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-(2,6,6-trimethylcyclohex-2-en-1-yl)but-3-en-2-one" "isonaline 70" "3-buten-2-one, 3-methyl-4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-" "3-buten-2-one, 3-methyl-4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-, (e)-" );
standardThermochemistry
{
    dHf_298   -241910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41330.0
}
