/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexachloropropene  (C3Cl6, CAS 1888-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexachloropropene;
formula     C3Cl6;
CAS         1888-71-7;
InChIKey    VFDYKPARTDCDCU-UHFFFAOYSA-N;
MW          248.733;      // g/mol [origin=calculated method=formula-sum]
Tc          741.93;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.3198;      // -   [origin=predictive method=lee-kesler]
Tb          493.51;      // K   [origin=predictive method=joback]
HvapTb      47404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.47 0.4752 -0.000522 2.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl3; count 1; } { group Cl_C=C_; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dC; count 2; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,3,3,3-hexakis(chloranyl)prop-1-ene" "propene, hexachloro-" "perchloropropylene" "hexachloropropylene" "perchloropropene" "1-propene, 1,1,2,3,3,3-hexachloro-" "1,1,2,3,3,3-hexachloroprop-1-ene" "1-propene,1,2,3,3,3-hexachloro-" );
standardThermochemistry
{
    dHf_298   -110800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31240.0
}
