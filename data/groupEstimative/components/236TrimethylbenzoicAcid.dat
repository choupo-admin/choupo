/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,6-trimethylbenzoic acid  (C10H12O2, CAS 2529-36-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        236TrimethylbenzoicAcid;
formula     C10H12O2;
CAS         2529-36-4;
InChIKey    JRUKSSBDIZXQDX-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          838.43;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.7751;      // -   [origin=predictive method=lee-kesler]
Tb          615.53;      // K   [origin=predictive method=joback]
HvapTb      59280.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.39 0.74726 -0.00042288 8.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 2,3,6-trimethyl-" );
standardThermochemistry
{
    dHf_298   -397880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227070.0
}
