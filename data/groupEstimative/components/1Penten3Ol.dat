/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-penten-3-ol  (C5H10O, CAS 616-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Penten3Ol;
formula     C5H10O;
CAS         616-25-1;
InChIKey    VHVMXWZXFBOANQ-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          571.04;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       0.6496;      // -   [origin=predictive method=lee-kesler]
Tb          402.42;      // K   [origin=predictive method=joback]
HvapTb      42345.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.039 0.49872 -0.0003047 7.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-en-3-ol" "ethyl vinyl carbinol" "1-penten-3-ol (e)" "1-penten-3-ol, (r)-" "vinyl ethyl carbinol" "1-pentene-3-ol" "1-ethylallyl alcohol" "1-propanol, ethenyl-" "alpha-ethylallyl alcohol" "vhvmxwzxfboanq-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -178610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60200.0
    phase     gas;
}
