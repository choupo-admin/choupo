/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-Amino-1-methoxypropane  (C4H11NO, CAS 37143-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino1Methoxypropane;
formula     C4H11NO;
CAS         37143-54-7;
InChIKey    NXMXETCTWNXSFG-UHFFFAOYSA-N;
MW          89.138;      // g/mol [origin=calculated method=formula-sum]
Tc          572.15;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.4186;      // -   [origin=predictive method=lee-kesler]
Tb          385.63;      // K   [origin=predictive method=joback]
HvapTb      37161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.561 0.38844 -0.0001294 -7.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3O; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxypropan-2-amine" "(1-Methoxypropan-2-yl)amine" "(±)-1-methoxy-2-propanamine" "(±)-1-methoxy-2-propylamine" "1-methoxy-2-aminopropane" "1-methoxy-2-propanamine" "1-methoxy-2-propylamine" "1-methoxyisopropylamine" "1-methyl-2-methoxyethylamine" "2-methoxy-1-methylethylamine" "2-propanamine, 1-methoxy-" "dl-alaninol methyl ether" );
standardThermochemistry
{
    dHf_298   -229600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58190.0
}
