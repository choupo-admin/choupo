/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipamide  (C6H12N2O2, CAS 628-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipamide;
formula     C6H12N2O2;
CAS         628-94-4;
InChIKey    GVNWZKBFMFUVNX-UHFFFAOYSA-N;
MW          144.174;      // g/mol [origin=calculated method=formula-sum]
Tc          799.99;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.9651;      // -   [origin=predictive method=lee-kesler]
Tb          589.68;      // K   [origin=predictive method=joback]
HvapTb      63724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.134 0.6416 -0.000352 6.412e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanediamide" "adipic diamide" "adipic acid amide" "adipic acid diamide" "1,4-butanedicarboxamide" "butane-1,4-dicarboxamide" "hexanedioic diamide" "hexanedoic acid, diamide" "gvnwzkbfmfuvnx-uhfffaoysa-" "d4733c63-3c78-4f1e-b531-6c2c98ec3f28" );
gibbsFormation
{
    dHf_298   -324750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125300.0
    phase     gas;
}
