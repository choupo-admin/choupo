/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclopentylethanol  (C7H14O, CAS 52829-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopentylethanol;
formula     C7H14O;
CAS         52829-98-8;
InChIKey    WPCMSUSLCWXTKB-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          656.77;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.6703;      // -   [origin=predictive method=lee-kesler]
Tb          466.78;      // K   [origin=predictive method=joback]
HvapTb      47724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.35 0.84042 -0.000518 1.209e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentanemethanol, .alpha.-methyl-" "alpha-methylcyclopentanemethanol" "1-cyclopentylethan-1-ol" "a-methylcyclopentanemethanol" "cyclopentanemethanol, alpha-methyl-" );
standardThermochemistry
{
    dHf_298   -284840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94650.0
}
