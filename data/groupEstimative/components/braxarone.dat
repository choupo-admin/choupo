/*--------------------------------*- Choupo -*-----------------------*\
  Component: braxarone  (C21H27BrO3, CAS 2527-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        braxarone;
formula     C21H27BrO3;
CAS         2527-11-9;
InChIKey    NWFOHSCPTMLQIH-WHJJYKQUSA-N;
MW          407.348;      // g/mol [origin=calculated method=formula-sum]
Tc          1254.98;      // K   [origin=predictive method=joback]
Pc          18.953;      // bar [origin=predictive method=joback]
omega       0.9952;      // -   [origin=predictive method=lee-kesler]
Tb          979.58;      // K   [origin=predictive method=joback]
HvapTb      81410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-270.38 2.93526 -0.00273934 1.10236e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group C; count 3; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH2CO; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Br; count 1; } { group CdO; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,10s,13s,14s,17s)-9-bromanyl-17-ethanoyl-10,13-dimethyl-1,2,6,7,8,12,14,15,16,17-decahydrocyclopenta[a]phenanthrene-3,11-dione" "braxorone" "broxoron" "broxorone" "brolon" "9alpha-bop" "braxoron" "9alpha-bromo-11-oxoprogesterone" "9alpha-bromo-11-ketoprogesterone" "9-alpha-bromo-11-ketoprogesterone" "9-bromopregn-4-ene-3,11,20-trione" "pregn-4-ene-3,11,20-trione, 9-bromo-" );
gibbsFormation
{
    dHf_298   -526670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62900.0
    phase     gas;
}
