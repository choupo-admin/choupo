/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzyl terephthalate  (C22H18O4, CAS 19851-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzylTerephthalate;
formula     C22H18O4;
CAS         19851-61-7;
InChIKey    IWGFEQWCMAADJZ-UHFFFAOYSA-N;
MW          346.382;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.17;      // K   [origin=predictive method=joback]
Pc          18.232;      // bar [origin=predictive method=joback]
omega       1.0329;      // -   [origin=predictive method=lee-kesler]
Tb          904.42;      // K   [origin=predictive method=joback]
HvapTb      86870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.708 1.688 -0.00101036 1.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 2; } { group ACCH2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(phenylmethyl) benzene-1,4-dicarboxylate" "terephthalic acid, dibenzyl ester" "dibenzyl benzene-1,4-dicarboxylate" "phenylmethyl 4-[benzyloxycarbonyl]benzoate" "1,4-benzendicarboxylicacidbis(phenylmethyl)ester;" );
standardThermochemistry
{
    dHf_298   -433850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     790.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158780.0
}
