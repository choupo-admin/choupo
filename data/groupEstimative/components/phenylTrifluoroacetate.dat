/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl trifluoroacetate  (C8H5F3O2, CAS 500-73-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylTrifluoroacetate;
formula     C8H5F3O2;
CAS         500-73-2;
InChIKey    DVCMYAIUSOSIQP-UHFFFAOYSA-N;
MW          190.12;      // g/mol [origin=calculated method=formula-sum]
Tc          658.46;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.5141;      // -   [origin=predictive method=lee-kesler]
Tb          462.12;      // K   [origin=predictive method=joback]
HvapTb      39338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.08 0.7913 -0.000569 1.411e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl 2,2,2-tris(fluoranyl)ethanoate" "phenyl 2,2,2-trifluoroacetate" "acetic acid, trifluoro-, phenyl ester" "acetic acid, 2,2,2-trifluoro-, phenyl ester" "dvcmyaiusosiqp-uhfffaoysa-" "trifluoroacetic acid phenyl ester" );
gibbsFormation
{
    dHf_298   -886280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-763070.0
    phase     gas;
}
