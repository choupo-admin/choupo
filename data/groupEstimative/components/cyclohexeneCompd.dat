/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene compd.  (C27H51NO7, CAS 68227-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexeneCompd;
formula     C27H51NO7;
CAS         68227-48-5;
InChIKey    IITZECLZJWPUHA-UHFFFAOYSA-N;
MW          501.705;      // g/mol [origin=calculated method=formula-sum]
Tc          1993.25;      // K   [origin=predictive method=joback]
Pc          9.346;      // bar [origin=predictive method=joback]
omega       -0.0054;      // -   [origin=predictive method=lee-kesler]
Tb          1408.13;      // K   [origin=predictive method=joback]
HvapTb      162501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.402 2.70322 -0.00133668 1.731e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH; count 3; } { group CH=CH; count 1; } { group OH; count 3; } { group CH2N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group OH; count 3; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethanol;2-hexyl-5-(8-oxidanyl-8-oxidanylidene-octyl)cyclohex-3-ene-1-carboxylic acid" "5-(7-carboxyheptyl)-2-hexylcyclohex-3-ene-1-carboxylic acid- 2,2',2''-nitrilotriethanol(1:1)" "2-[bis(2-hydroxyethyl)amino]ethanol; 2-hexyl-5-(8-hydroxy-8-oxooctyl)cyclohex-3-ene-1-carboxylic acid" "5(or 6)-carboxy-4-hexylcyclohex-2-ene-1-octanoic acid, compound with 2,2',2''-nitrilotriethanol" "5-carboxy-4-hexylcyclohex-2-ene-1-octanoic acid, compound with 2,2',2''-nitrilotriethanol" "2-cyclohexene-1-octanoic acid, 5(or 6)-carboxy-4-hexyl-, compd. with 2,2',2''-nitrilotris(ethanol)" "2-cyclohexene-1-octanoic acid, 5(or 6)-carboxy-4-hexyl-, compd. with 2,2',2''-nitrilotris(ethanol) (1:?)" );
standardThermochemistry
{
    dHf_298   -1730510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1437.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-876810.0
}
