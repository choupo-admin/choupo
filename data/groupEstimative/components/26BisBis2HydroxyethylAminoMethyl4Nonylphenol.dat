/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-bis((bis(2-hydroxyethyl)amino)methyl)-4-nonylphenol  (C25H46N2O5, CAS 20073-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26BisBis2HydroxyethylAminoMethyl4Nonylphenol;
formula     C25H46N2O5;
CAS         20073-51-2;
InChIKey    HUFXECXTFFUYQG-UHFFFAOYSA-N;
MW          454.652;      // g/mol [origin=calculated method=formula-sum]
Tc          1763.93;      // K   [origin=predictive method=joback]
Pc          12.719;      // bar [origin=predictive method=joback]
omega       0.2581;      // -   [origin=predictive method=lee-kesler]
Tb          1282.46;      // K   [origin=predictive method=joback]
HvapTb      158660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.282 2.71932 -0.00183648 5.091e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group ACH; count 2; } { group ACCH2; count 3; } { group OH; count 4; } { group ACOH; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 4; } { group OH_phenol; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis[[bis(2-hydroxyethyl)amino]methyl]-4-nonyl-phenol" "2,6-bis[[bis(2-hydroxyethyl)amino]methyl]-4-nonylphenol" "phenol, 2,6-bis((bis(2-hydroxyethyl)amino)methyl)-4-nonyl-" "phenol, 2,6-bis[[bis(2-hydroxyethyl)amino]methyl]-4-nonyl-" );
standardThermochemistry
{
    dHf_298   -996910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1273.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227570.0
}
