/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3'-bromo-trans-anethole  (C10H11BrO, CAS 16034-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BromoTransAnethole;
formula     C10H11BrO;
CAS         16034-99-4;
InChIKey    XXILDBMRKXAIDA-NSCUHMNNSA-N;
MW          227.101;      // g/mol [origin=calculated method=formula-sum]
Tc          782.50;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.5544;      // -   [origin=predictive method=lee-kesler]
Tb          552.80;      // K   [origin=predictive method=joback]
HvapTb      49595.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.299 0.81042 -0.00052856 1.351e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(e)-3-bromanylprop-1-enyl]-4-methoxy-benzene" "anisole, p-(3-bromopropenyl)-, (e)-" "(e)-p-(3-bromopropenyl)anisole" "benzene, 1-(3-bromo-1-propenyl)-4-methoxy-, (e)-" "1-[(e)-3-bromoprop-1-enyl]-4-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -13340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125640.0
}
