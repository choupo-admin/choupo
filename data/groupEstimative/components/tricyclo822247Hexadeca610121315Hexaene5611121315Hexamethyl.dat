/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[8.2.2.24,7]hexadeca-6,10,12,13,15-hexaene, 5,6,11,12,13,15-hexamethyl-  (C22H28, CAS 77897-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo822247Hexadeca610121315Hexaene5611121315Hexamethyl;
formula     C22H28;
CAS         77897-17-7;
InChIKey    COWSCXIHIVAWAL-UHFFFAOYSA-N;
MW          292.466;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.30;      // K   [origin=predictive method=joback]
Pc          14.793;      // bar [origin=predictive method=joback]
omega       0.7837;      // -   [origin=predictive method=lee-kesler]
Tb          811.84;      // K   [origin=predictive method=joback]
HvapTb      74808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.83 1.62792 -0.00092828 2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 6; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(8.2.2.24,7)hexadeca-6,10,12,13,15-hexaene, 5,6,11,12,13,15-hexamethyl-" "2,3,5,2',5',6'-hexamethyl-[2.2]paracyclophane" );
standardThermochemistry
{
    dHf_298   -29130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=338500.0
}
