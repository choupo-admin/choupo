/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pentadecylphenol  (C21H36O, CAS 501-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pentadecylphenol;
formula     C21H36O;
CAS         501-24-6;
InChIKey    PTFIPECGHSYQNR-UHFFFAOYSA-N;
MW          304.518;      // g/mol [origin=calculated method=formula-sum]
Tc          980.81;      // K   [origin=predictive method=joback]
Pc          13.185;      // bar [origin=predictive method=joback]
omega       1.0114;      // -   [origin=predictive method=lee-kesler]
Tb          787.38;      // K   [origin=predictive method=joback]
HvapTb      77630.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.026 2.07452 -0.00140616 3.973e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 3-pentadecyl-" "hydroginkgol" "3-n-pentadecylphenol" "phenol, m-pentadecyl-" "hydrocardanol" "cyclogallipharaol" "m-pentadecylphenol" "tetrahydroanacardol" "anacardol, tetrahydro-" "5-pentadecylphenol" "3-pentadecyl-phenol" "3-pentadecyl phenol" );
gibbsFormation
{
    dHf_298   -417550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     894.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83730.0
    phase     gas;
}
