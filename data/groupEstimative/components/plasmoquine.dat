/*--------------------------------*- Choupo -*-----------------------*\
  Component: plasmoquine  (C19H29N3O, CAS 491-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        plasmoquine;
formula     C19H29N3O;
CAS         491-92-9;
InChIKey    QTQWMSOQOSJFBV-UHFFFAOYSA-N;
MW          315.461;      // g/mol [origin=calculated method=formula-sum]
Tc          1040.89;      // K   [origin=predictive method=joback]
Pc          16.090;      // bar [origin=predictive method=joback]
omega       1.0735;      // -   [origin=predictive method=lee-kesler]
Tb          828.23;      // K   [origin=predictive method=joback]
HvapTb      79839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.155 1.78384 -0.0011063 2.661e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 1; } { group CHNH; count 1; } { group CH2N; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 4; } { group O; count 1; } { group NH; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1-diethyl-n4-(6-methoxyquinolin-8-yl)pentane-1,4-diamine" "pamaquin" "pamaquine" "plasmochin" "plasmocide" "praequine" "prequine" "rhodoquine" "beprochine" "aminoquin" "gamefar" "quipenyl" );
standardThermochemistry
{
    dHf_298   -14540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     739.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=478680.0
}
