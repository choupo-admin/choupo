/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[2-(dimethylamino)ethyl]benzene-1,2-diamine  (C10H17N3, CAS 78156-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2DimethylaminoEthylBenzene12Diamine;
formula     C10H17N3;
CAS         78156-03-3;
InChIKey    YMYPZBOBAISUFL-UHFFFAOYSA-N;
MW          179.267;      // g/mol [origin=calculated method=formula-sum]
Tc          808.78;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.7980;      // -   [origin=predictive method=lee-kesler]
Tb          595.20;      // K   [origin=predictive method=joback]
HvapTb      59912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.218 1.07744 -0.00068896 1.673e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2NH; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n2-[2-(dimethylamino)ethyl]benzene-1,2-diamine" "n-(beta-dimethylaminoethyl)-o-phenylenediamine" "2-n-(2-dimethylaminoethyl)benzene-1,2-diamine" "1,2-benzenediamine,n1-[2-(dimethylamino)ethyl]-" "1,2-benzenediamine,n-[2-(dimethylamino)ethyl]- (9ci)" );
gibbsFormation
{
    dHf_298   130120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=402720.0
    phase     gas;
}
