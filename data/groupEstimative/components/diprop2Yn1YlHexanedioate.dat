/*--------------------------------*- Choupo -*-----------------------*\
  Component: diprop-2-yn-1-yl hexanedioate  (C12H14O4, CAS 6900-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diprop2Yn1YlHexanedioate;
formula     C12H14O4;
CAS         6900-06-7;
InChIKey    UUKXRCZQOHIIPD-UHFFFAOYSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          763.79;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.7574;      // -   [origin=predictive method=lee-kesler]
Tb          570.84;      // K   [origin=predictive method=joback]
HvapTb      56836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.356 0.8464 -0.00043166 5.418e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2COO; count 2; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group tCH; count 2; } { group tC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(prop-2-ynyl) hexanedioate" "di-2-propynyl adipate" "adipic acid, di-2-propynyl ester" "hexanedioic acid, di-2-propynyl ester" "hexanedioic acid, di-2-propynyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -341770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     664.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124440.0
}
