/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyanoethyl-m-toluidine  (C10H12N2, CAS 27618-25-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyanoethylMToluidine;
formula     C10H12N2;
CAS         27618-25-3;
InChIKey    VUUHXRVVDUAGOL-UHFFFAOYSA-N;
MW          160.22;      // g/mol [origin=calculated method=formula-sum]
Tc          835.75;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.7198;      // -   [origin=predictive method=lee-kesler]
Tb          612.31;      // K   [origin=predictive method=joback]
HvapTb      57706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.018 0.82642 -0.00050196 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(3-methylphenyl)amino]propanenitrile" "propanenitrile, 3-((3-methylphenyl)amino)-" "propanenitrile, 3-[(3-methylphenyl)amino]-" "3-m-toluidinopropiononitrile" "3-(m-tolylamino)propanenitrile" "3-(3-methylanilino)propanenitrile" "i644" "propanenitrile,3-[(3-methylphenyl)amino]-" "propionitrile,3-m-toluidino- (8ci);n-(2-cyanoethyl)-3-methylaniline;n-(b-cyanoethyl)-m-toluidine;" );
standardThermochemistry
{
    dHf_298   193680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=358670.0
}
