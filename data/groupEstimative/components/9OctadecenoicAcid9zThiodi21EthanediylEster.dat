/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenoic acid (9z)-, thiodi-2,1-ethanediyl ester  (C40H74O4S, CAS 65808-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenoicAcid9zThiodi21EthanediylEster;
formula     C40H74O4S;
CAS         65808-58-4;
InChIKey    ZULIEXNFTXZXEI-UHFFFAOYSA-N;
MW          651.088;      // g/mol [origin=calculated method=formula-sum]
Tc          1815.67;      // K   [origin=predictive method=joback]
Pc          4.119;      // bar [origin=predictive method=joback]
omega       -0.3352;      // -   [origin=predictive method=lee-kesler]
Tb          1308.34;      // K   [origin=predictive method=joback]
HvapTb      126181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.582 3.72863 -0.0020904 4.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 29; } { group CH=CH; count 2; } { group CH2COO; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 32; } { group dCH; count 4; } { group COO; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-octadec-9-enoyloxyethylsulfanyl)ethyl octadec-9-enoate" "9-octadecenoic acid (9z)-, 1,1'-(thiodi-2,1-ethanediyl) ester" "2-[2-[(e)-octadec-9-enoyl]oxyethylsulfanyl]ethyl (e)-octadec-9-enoate" "2-[2-[(z)-octadec-9-enoyl]oxyethylsulfanyl]ethyl (z)-octadec-9-enoate" );
standardThermochemistry
{
    dHf_298   -1227180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1864.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141260.0
}
