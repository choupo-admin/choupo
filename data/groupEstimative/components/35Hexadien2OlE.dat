/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-hexadien-2-ol, (e)-  (C6H10O, CAS 94736-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Hexadien2OlE;
formula     C6H10O;
CAS         94736-77-3;
InChIKey    VAOJQRMYAXTUQI-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          605.48;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       0.6636;      // -   [origin=predictive method=lee-kesler]
Tb          429.46;      // K   [origin=predictive method=joback]
HvapTb      44529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.13 0.61372 -0.0004429 1.343e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-3,5-dien-2-ol" "3,5-hexadien-2-ol" );
gibbsFormation
{
    dHf_298   -82030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28440.0
    phase     gas;
}
