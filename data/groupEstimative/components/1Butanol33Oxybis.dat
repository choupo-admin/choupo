/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butanol, 3,3'-oxybis-  (C8H18O3, CAS 54289-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butanol33Oxybis;
formula     C8H18O3;
CAS         54289-82-6;
InChIKey    ZIYSJVFROIOYRQ-UHFFFAOYSA-N;
MW          162.229;      // g/mol [origin=calculated method=formula-sum]
Tc          750.61;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       1.3922;      // -   [origin=predictive method=lee-kesler]
Tb          588.54;      // K   [origin=predictive method=joback]
HvapTb      68394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.334 0.78044 -0.0003676 4.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 2; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-oxidanylbutan-2-yloxy)butan-1-ol" "3,3'-oxybisbutan-1-ol" "3,3'-oxydibutan-1-ol" "3-(4-hydroxybutan-2-yloxy)butan-1-ol" );
gibbsFormation
{
    dHf_298   -655690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367040.0
    phase     gas;
}
