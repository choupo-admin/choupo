/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromononanoic acid  (C9H17BrO2, CAS 2623-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromononanoicAcid;
formula     C9H17BrO2;
CAS         2623-83-8;
InChIKey    MELJYLJLJXTLGX-UHFFFAOYSA-N;
MW          237.137;      // g/mol [origin=calculated method=formula-sum]
Tc          815.60;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.9400;      // -   [origin=predictive method=lee-kesler]
Tb          616.75;      // K   [origin=predictive method=joback]
HvapTb      58839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.816 0.95372 -0.000613 1.575e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylnonanoic acid" "nonanoic acid, 2-bromo-" "2-bromo-nonanoic acid" "alpha-bromopelargonic acid" "2-bromononan-1-oic acid" "2-bromonanoic acid" "2-bromononanoicacid;a-bromopelargonic acid;" );
gibbsFormation
{
    dHf_298   -558310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307130.0
    phase     gas;
}
