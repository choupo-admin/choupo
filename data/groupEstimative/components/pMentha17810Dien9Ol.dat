/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-mentha-1(7),8(10)-dien-9-ol  (C10H16O, CAS 29548-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMentha17810Dien9Ol;
formula     C10H16O;
CAS         29548-13-8;
InChIKey    SDDQNZKSVASSFO-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          730.58;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.7613;      // -   [origin=predictive method=lee-kesler]
Tb          535.85;      // K   [origin=predictive method=joback]
HvapTb      54531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.909 0.9723 -0.0005644 1.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 2; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylidenecyclohexyl)prop-2-en-1-ol" "2-(4-methylenecyclohexyl)-2-propen-1-ol" "cyclohexaneethanol, b,4-bis(methylene)-" "beta,4-bis(methylene)cyclohexaneethanol" "p-mentha-1(7),8(10)-dien-9-ol(7ci,8ci)" );
standardThermochemistry
{
    dHf_298   -147760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53320.0
}
