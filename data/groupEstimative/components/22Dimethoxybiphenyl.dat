/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-dimethoxybiphenyl  (C14H14O2, CAS 4877-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethoxybiphenyl;
formula     C14H14O2;
CAS         4877-93-4;
InChIKey    VGMKUVCDINAAFC-UHFFFAOYSA-N;
MW          214.264;      // g/mol [origin=calculated method=formula-sum]
Tc          862.67;      // K   [origin=predictive method=joback]
Pc          25.925;      // bar [origin=predictive method=joback]
omega       0.6292;      // -   [origin=predictive method=lee-kesler]
Tb          628.08;      // K   [origin=predictive method=joback]
HvapTb      57454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.95 0.93064 -0.00044412 4.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-(2-methoxyphenyl)benzene" "2,2'-dimethoxy-1,1'-biphenyl" "1,1'-biphenyl, 2,2'-dimethoxy-" "2,2'-dimethoxy-biphenyl" "agn-pc-03ec4c" "biphenyl, 2,2'-dimethoxy-" "1,1'-biphenyl,2,2'-dimethoxy-" "2,2 inverted exclamation marka-dimethoxybiphenyl" );
gibbsFormation
{
    dHf_298   -146610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62560.0
    phase     gas;
}
