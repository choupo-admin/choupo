/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dichlorobenzyl iodide  (C7H5Cl2I, CAS 116529-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DichlorobenzylIodide;
formula     C7H5Cl2I;
CAS         116529-35-2;
InChIKey    JASQNLDZUCSGKV-UHFFFAOYSA-N;
MW          286.917;      // g/mol [origin=calculated method=formula-sum]
Tc          828.58;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.4048;      // -   [origin=predictive method=lee-kesler]
Tb          564.40;      // K   [origin=predictive method=joback]
HvapTb      52919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.691 0.5235 -0.00037632 1.057e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group ACCl; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)-1-(iodanylmethyl)benzene" "1,3-dichloro-4-(iodomethyl)benzene" "benzene,2,4-dichloro-1-(iodomethyl)-" "2,4-dichloro-alpha-iodo toluene" "2,4-dichlorophenylmethyl iodide" "2,4-dichloro-1-(iodomethyl)benzene" "2,4-dichlorobenzyliodide;2,4-dichlorophenylmethyl iodide;" );
gibbsFormation
{
    dHf_298   71170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135470.0
    phase     gas;
}
