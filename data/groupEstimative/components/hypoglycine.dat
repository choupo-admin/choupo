/*--------------------------------*- Choupo -*-----------------------*\
  Component: hypoglycine  (C7H11NO2, CAS 156-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hypoglycine;
formula     C7H11NO2;
CAS         156-56-9;
InChIKey    OOJZCXFXPZGUBJ-UHFFFAOYSA-N;
MW          141.17;      // g/mol [origin=calculated method=formula-sum]
Tc          799.87;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.8587;      // -   [origin=predictive method=lee-kesler]
Tb          583.26;      // K   [origin=predictive method=joback]
HvapTb      58665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.019 0.8208 -0.000604 1.808e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-(2-methylidenecyclopropyl)propanoic acid" "hypoglycine a" "hypoglycin a" "cyclopropanealanine, 2-methylene-" "hypoglycin" "a-amino-b-(2-methylenecyclopropyl)propionic acid" ".alpha.-amino-2-methylenecyclopropanepropionic acid" "2-methylenecyclopropanylalanine" ".alpha.-amino-.beta.-(2-methylenecyclopropyl)propionic acid" "2-methylenecyclopropanealanine" "beta-(methylenecyclopropyl)alanine" "(s)-2-amino-3-(2-methylenecyclopropyl)propanoic acid" );
gibbsFormation
{
    dHf_298   -352530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158010.0
    phase     gas;
}
