/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octadecanol  (C18H38O, CAS 112-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octadecanol;
formula     C18H38O;
CAS         112-92-5;
InChIKey    GLDOVTGHNKAZLK-UHFFFAOYSA-N;
MW          270.501;      // g/mol [origin=calculated method=formula-sum]
Tc          867.09;      // K   [origin=predictive method=joback]
Pc          12.277;      // bar [origin=predictive method=joback]
omega       1.0744;      // -   [origin=predictive method=lee-kesler]
Tb          703.62;      // K   [origin=predictive method=joback]
HvapTb      72341.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.183 1.74782 -0.0009858 2.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecan-1-ol" "stearyl alcohol" "octadecanol" "n-octadecanol" "octadecyl alcohol" "1-hydroxyoctadecane" "n-1-octadecanol" "stearol" "n-octadecyl alcohol" "stearic alcohol" "1-0ctadecanol" "atalco s" );
gibbsFormation
{
    dHf_298   -567080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     908.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-36140.0
    phase     gas;
}
