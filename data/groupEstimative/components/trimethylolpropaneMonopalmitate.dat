/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane monopalmitate  (C22H44O4, CAS 64131-22-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneMonopalmitate;
formula     C22H44O4;
CAS         64131-22-2;
InChIKey    ROXXKZWLQOWAJU-UHFFFAOYSA-N;
MW          372.59;      // g/mol [origin=calculated method=formula-sum]
Tc          1164.92;      // K   [origin=predictive method=joback]
Pc          10.260;      // bar [origin=predictive method=joback]
omega       0.8827;      // -   [origin=predictive method=lee-kesler]
Tb          942.31;      // K   [origin=predictive method=joback]
HvapTb      104035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.592 2.23284 -0.001311 2.85e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group C; count 1; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group C; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)butyl hexadecanoate" "2,2-bis(hydroxymethyl)butyl palmitate" "hexadecanoic acid, 2,2-bis(hydroxymethyl)butyl ester" "hexadecanoic acid,2,2-bis(hydroxymethyl)butyl ester" );
standardThermochemistry
{
    dHf_298   -1127900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1127.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-446810.0
}
