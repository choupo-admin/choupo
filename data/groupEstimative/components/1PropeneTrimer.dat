/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propene, trimer  (C27H60, CAS 13987-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PropeneTrimer;
formula     C27H60;
CAS         13987-01-4;
InChIKey    PCINYZCOJRSWJK-UHFFFAOYSA-N;
MW          384.777;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.67;      // K   [origin=predictive method=joback]
Pc          6.475;      // bar [origin=predictive method=joback]
omega       0.5423;      // -   [origin=predictive method=lee-kesler]
Tb          817.08;      // K   [origin=predictive method=joback]
HvapTb      73568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.207 2.19796 -0.0006378 -1.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 13; } { group CH2; count 7; } { group CH; count 7; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 13; } { group CH2; count 7; } { group CH; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylheptane;2,4-dimethylheptane;2,3,5-trimethylhexane" "2,3-dimethylheptane; 2,4-dimethylheptane; 2,3,5-trimethylhexane" );
standardThermochemistry
{
    dHf_298   -860810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1356.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50140.0
}
