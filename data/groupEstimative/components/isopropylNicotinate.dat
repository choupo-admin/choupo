/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl nicotinate  (C9H11NO2, CAS 553-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylNicotinate;
formula     C9H11NO2;
CAS         553-60-6;
InChIKey    VSRSQDMWBSKNSF-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          771.05;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.5546;      // -   [origin=predictive method=lee-kesler]
Tb          543.68;      // K   [origin=predictive method=joback]
HvapTb      51133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.41 0.7648 -0.00041486 6.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl pyridine-3-carboxylate" "nipyl" "3-pyridinecarboxylic acid, 1-methylethyl ester" "nicotinic acid, isopropyl ester" "iso-propyl nicotinate" "nicotinic acidisopropyl ester" "nicotinic acid, isopropyl ester (8ci)" "u511" "3-pyridinecarboxylicacid, 1-methylethyl ester" );
gibbsFormation
{
    dHf_298   -282330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98450.0
    phase     gas;
}
