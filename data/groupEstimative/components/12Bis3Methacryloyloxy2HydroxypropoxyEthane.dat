/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(3-methacryloyloxy-2-hydroxypropoxy)ethane  (C16H26O8, CAS 68856-43-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis3Methacryloyloxy2HydroxypropoxyEthane;
formula     C16H26O8;
CAS         68856-43-9;
InChIKey    YPBNDGVRPOECEP-UHFFFAOYSA-N;
MW          346.376;      // g/mol [origin=calculated method=formula-sum]
Tc          1106.55;      // K   [origin=predictive method=joback]
Pc          16.207;      // bar [origin=predictive method=joback]
omega       1.4035;      // -   [origin=predictive method=lee-kesler]
Tb          903.56;      // K   [origin=predictive method=joback]
HvapTb      102246.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.016 1.32744 -0.000553 1.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2=C; count 2; } { group COO; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group OH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-[2-[3-(2-methylprop-2-enoyloxy)-2-oxidanyl-propoxy]ethoxy]-2-oxidanyl-propyl] 2-methylprop-2-enoate" "1,2-ethanediylbis(oxy(2-hydroxy-3,1-propanediyl)) methacrylate" "1,2-ethanediylbis[oxy(2-hydroxy-3,1-propanediyl)] methacrylate" "2-propenoic acid, 2-methyl-, 1,1'-(1,2-ethanediylbis(oxy(2-hydroxy-3,1-propanediyl))) ester" "2-propenoic acid, 2-methyl-, 1,1'-[1,2-ethanediylbis[oxy(2-hydroxy-3,1-propanediyl)]] ester" "ethylenebis(oxy(2-hydroxypropane-1,3-diyl)) dimethacrylate" "1,2-ethanediol, bis(2-hydroxy-3-((2-methyl-2-propenoyl)oxy)propyl) ether" "2-propenoic acid, 2-methyl-, 1,2-ethanediylbis(oxy(2-hydroxy-3,1-propanediyl)) ester" "[2-hydroxy-3-[2-[2-hydroxy-3-(2-methylprop-2-enoyloxy)propoxy]ethoxy]propyl] 2-methylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -1356310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     969.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-866840.0
    phase     gas;
}
