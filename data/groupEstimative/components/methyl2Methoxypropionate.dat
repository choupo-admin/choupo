/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-methoxypropionate  (C5H10O3, CAS 17639-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Methoxypropionate;
formula     C5H10O3;
CAS         17639-76-8;
InChIKey    VABBJJOSOCPYIT-UHFFFAOYSA-N;
MW          118.132;      // g/mol [origin=calculated method=formula-sum]
Tc          572.97;      // K   [origin=predictive method=joback]
Pc          34.521;      // bar [origin=predictive method=joback]
omega       0.4438;      // -   [origin=predictive method=lee-kesler]
Tb          394.20;      // K   [origin=predictive method=joback]
HvapTb      36153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.57 0.36676 -4.58e-05 -6.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methoxypropanoate" "methyl methoxypropionate" "propanoic acid, 2-methoxy-, methyl ester" "2-methoxy-propionic acid methyl ester" "propionicacid, 2-methoxy-, methyl ester (6ci,8ci);methyl 2-methoxypropanoate;methyl2-methoxypropionate;methyl a-methoxypropionate;" );
standardThermochemistry
{
    dHf_298   -601310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-426590.0
}
