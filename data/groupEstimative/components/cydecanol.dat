/*--------------------------------*- Choupo -*-----------------------*\
  Component: cydecanol  (C10H14O, CAS 133-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cydecanol;
formula     C10H14O;
CAS         133-21-1;
InChIKey    LDUKQFUHJZHLRC-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          736.55;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.7584;      // -   [origin=predictive method=lee-kesler]
Tb          534.89;      // K   [origin=predictive method=joback]
HvapTb      54118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.1 1.3219 -0.00104128 3.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 5; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 5; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclopentadiene alcohol" "tricyclo[5.2.1.02,6]dec-4-en-8-ol" "3a,4,5,6,7,7a-hexahydro-4,7-methano-1h-inden-5-ol" "4,7-methano-1h-inden-5-ol, 3a,4,5,6,7,7a-hexahydro-" "3a,4,5,6,7,7a-hexahydro-4,7-methano-1h-indenol" "4,7-methano-1h-indenol, 3a,4,5,6,7,7a-hexahydro-" "hydroxy dicyclopentadiene" "dicyclopentenyl alcohol" "agn-pc-03dhwt" "agn-pc-03oowf" "4, 3a,4,5,6,7,7a-hexahydro-, exo-" "4,7-methanoinden-5-ol, 3a,4,5,6,7,7a-hexahydro-" );
standardThermochemistry
{
    dHf_298   -172620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     223.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81190.0
}
