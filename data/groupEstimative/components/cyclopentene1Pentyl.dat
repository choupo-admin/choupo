/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene, 1-pentyl-  (C10H18, CAS 4291-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentene1Pentyl;
formula     C10H18;
CAS         4291-98-9;
InChIKey    QCNVZKGTZWZQPR-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          645.49;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.4240;      // -   [origin=predictive method=lee-kesler]
Tb          452.49;      // K   [origin=predictive method=joback]
HvapTb      39374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.546 0.99652 -0.00062324 1.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pentylcyclopentene" "1-amyl-1-cyclopentene" "1-amyl-1-cyclopentene;1-pentyl-1-cyclopentene; 1-pentylcyclopentene" );
gibbsFormation
{
    dHf_298   -122600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97910.0
    phase     gas;
}
