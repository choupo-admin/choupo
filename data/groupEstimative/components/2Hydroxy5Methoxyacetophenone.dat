/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2'-hydroxy-5'-methoxyacetophenone  (C9H10O3, CAS 705-15-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy5Methoxyacetophenone;
formula     C9H10O3;
CAS         705-15-7;
InChIKey    MLIBGOFSXXWRIY-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          822.91;      // K   [origin=predictive method=joback]
Pc          40.518;      // bar [origin=predictive method=joback]
omega       0.7968;      // -   [origin=predictive method=lee-kesler]
Tb          594.09;      // K   [origin=predictive method=joback]
HvapTb      60736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.96 0.78384 -0.00055662 1.6576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5-methoxy-2-oxidanyl-phenyl)ethanone" "1-(2-hydroxy-5-methoxyphenyl)ethanone" "ethanone, 1-(2-hydroxy-5-methoxyphenyl)-" "5-methoxy-2-hydroxyacetophenone" "acetophenone, 2'-hydroxy-5'-methoxy-" "2'-hydroxy-5'-methoxyacetylphenone" "1-(2-hydroxy-5-methoxyphenyl)ethan-1-one" "1-acetyl-2-hydroxy-5-methoxybenzene" "2-hydroxy-5-methoxyacetophenone" "1-(2-hydroxy-5-methoxy-phenyl)-ethanone" );
gibbsFormation
{
    dHf_298   -426140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260860.0
    phase     gas;
}
