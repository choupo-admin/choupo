/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4,4'-(1,1,3,3-tetramethyl-1,3-disiloxanediyl)bis-  (C18H22O5Si2, CAS 18054-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C18H22O5Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        benzoicAcid441133Tetramethyl13DisiloxanediylBis;
formula     C18H22O5Si2;
CAS         18054-10-9;
InChIKey    JVVGCMZNVXAOOZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          374.539;      // g/mol [origin=calculated method=formula-sum]
Tc          1238.22;      // K   [origin=predictive method=joback]
Pc          17.463;      // bar [origin=predictive method=joback]
omega       1.2058;      // -   [origin=predictive method=lee-kesler]
Tb          991.00;      // K   [origin=predictive method=joback]
HvapTb      98864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.65 1.06308 -8.832e-05 -2.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 8; } { group AC; count 4; } { group COOH; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[(4-carboxyphenyl)-dimethyl-silyl]oxy-dimethyl-silyl]benzoic acid" );
standardThermochemistry
{
    dHf_298   -1020730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1002.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-696100.0
}
