/*--------------------------------*- Choupo -*-----------------------*\
  Component: tribenzylamine  (C21H21N, CAS 620-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tribenzylamine;
formula     C21H21N;
CAS         620-40-6;
InChIKey    MXHTZQSKTCCMFG-UHFFFAOYSA-N;
MW          287.406;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.53;      // K   [origin=predictive method=joback]
Pc          19.877;      // bar [origin=predictive method=joback]
omega       0.7648;      // -   [origin=predictive method=lee-kesler]
Tb          772.56;      // K   [origin=predictive method=joback]
HvapTb      71211.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.607 1.886 -0.0013248 3.526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-n,n-bis(phenylmethyl)methanamine" "benzenemethanamine, n,n-bis(phenylmethyl)-" "trisbenzylamine" "n,n-dibenzyl(phenyl)methanamine" "n,n-dibenzyl-1-phenylmethanamine" );
standardThermochemistry
{
    dHf_298   300350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=573950.0
}
