/*--------------------------------*- Choupo -*-----------------------*\
  Component: durohydroquinone  (C10H14O2, CAS 527-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        durohydroquinone;
formula     C10H14O2;
CAS         527-18-4;
InChIKey    SUNVJLYYDZCIIK-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          863.12;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.8766;      // -   [origin=predictive method=lee-kesler]
Tb          631.26;      // K   [origin=predictive method=joback]
HvapTb      68144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.05 1.00568 -0.000863 3.248e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH3; count 4; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5,6-tetramethylbenzene-1,4-diol" "dihydroxydurene" "duro-p-hydroquinone" "hydroquinone, tetramethyl-" "2,5,6-tetramethylhydroquinone" "2,3,5,6-tetramethyl-1,4-benzenediol" "1,4-benzenediol,2,3,5,6-tetramethyl-" "1,4-dihydroxy-2,3,5,6-tetramethylbenzene" );
standardThermochemistry
{
    dHf_298   -402230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192400.0
}
