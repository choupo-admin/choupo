/*--------------------------------*- Choupo -*-----------------------*\
  Component: biphenylene, 1,8-diethenyl-  (C16H12, CAS 36230-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        biphenylene18Diethenyl;
formula     C16H12;
CAS         36230-21-4;
InChIKey    MIWBJWDOTMGNHX-UHFFFAOYSA-N;
MW          204.272;      // g/mol [origin=calculated method=formula-sum]
Tc          867.43;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.6146;      // -   [origin=predictive method=lee-kesler]
Tb          630.92;      // K   [origin=predictive method=joback]
HvapTb      56776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.07 1.2942 -0.00110144 3.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group CH=CH; count 2; } { group CH=C; count 2; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-bis(ethenyl)biphenylene" "1,8-diethenylbiphenylene" );
standardThermochemistry
{
    dHf_298   416090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=550580.0
}
