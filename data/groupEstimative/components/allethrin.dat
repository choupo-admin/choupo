/*--------------------------------*- Choupo -*-----------------------*\
  Component: allethrin  (C19H26O3, CAS 584-79-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allethrin;
formula     C19H26O3;
CAS         584-79-2;
InChIKey    ZCVAOQKBXKSDMS-UHFFFAOYSA-N;
MW          302.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.31;      // K   [origin=predictive method=joback]
Pc          14.702;      // bar [origin=predictive method=joback]
omega       0.8238;      // -   [origin=predictive method=lee-kesler]
Tb          783.12;      // K   [origin=predictive method=joback]
HvapTb      68927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.869 1.9322 -0.0014028 4.462e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-4-oxidanylidene-3-prop-2-enyl-cyclopent-2-en-1-yl) 2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "bioallethrin" "esbiothrin" "pyrethrin" "pynamin" "pallethrine" "allethrine" "pyresin" "pyresyn" "trans-allethrin" "d-allethrin" "allyl cinerin i" );
standardThermochemistry
{
    dHf_298   -514930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77260.0
}
