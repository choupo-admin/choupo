/*--------------------------------*- Choupo -*-----------------------*\
  Component: annatto  (C24H28O4, CAS 1393-63-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        annatto;
formula     C24H28O4;
CAS         1393-63-1;
InChIKey    ZVKOASAVGLETCT-LRRSNBNMSA-N;
MW          380.484;      // g/mol [origin=calculated method=formula-sum]
Tc          1320.84;      // K   [origin=predictive method=joback]
Pc          12.260;      // bar [origin=predictive method=joback]
omega       1.1285;      // -   [origin=predictive method=lee-kesler]
Tb          1076.70;      // K   [origin=predictive method=joback]
HvapTb      103288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.13 2.56508 -0.0021904 7.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH=CH; count 5; } { group CH=C; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 14; } { group dC; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e,6e,8e,10e,12e,14e,16z,18e)-4,8,13,17-tetramethylicosa-2,4,6,8,10,12,14,16,18-nonaenedioic acid" "annatto extract acid proof" "annatto extract" "annatto pigment" "annotta extract" "annatto (color)" "natural orange 4" "annatto coloring dye" "bixa orellana extract" "annatto seed (bixa orellana l.)" "annatto extract (bixa orellana l.)" "annatto, extract (bixa orellana l.)" );
standardThermochemistry
{
    dHf_298   -223410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1121.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151160.0
}
