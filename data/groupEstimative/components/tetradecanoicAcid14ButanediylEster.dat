/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecanoic acid, 1,4-butanediyl ester  (C32H62O4, CAS 26719-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecanoicAcid14ButanediylEster;
formula     C32H62O4;
CAS         26719-58-4;
InChIKey    HAVZZMORNRVMDE-UHFFFAOYSA-N;
MW          510.844;      // g/mol [origin=calculated method=formula-sum]
Tc          1331.00;      // K   [origin=predictive method=joback]
Pc          5.459;      // bar [origin=predictive method=joback]
omega       0.1621;      // -   [origin=predictive method=lee-kesler]
Tb          1048.20;      // K   [origin=predictive method=joback]
HvapTb      101640.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.618 2.93424 -0.0015278 2.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 26; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 28; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tetradecanoyloxybutyl tetradecanoate" "tetradecanoic acid, 1,1'-(1,4-butanediyl) ester" );
standardThermochemistry
{
    dHf_298   -1338370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1505.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-402180.0
}
