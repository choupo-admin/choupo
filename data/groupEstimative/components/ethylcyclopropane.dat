/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylcyclopropane  (C5H10, CAS 1191-96-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylcyclopropane;
formula     C5H10;
CAS         1191-96-4;
InChIKey    FOTXAJDDGPYIFU-UHFFFAOYSA-N;
MW          70.135;      // g/mol [origin=calculated method=formula-sum]
Tc          499.08;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.2255;      // -   [origin=predictive method=lee-kesler]
Tb          320.74;      // K   [origin=predictive method=joback]
HvapTb      26637.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.899 0.62972 -0.0004684 1.476e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropane, ethyl-" "ethyl cyclopropane" );
standardThermochemistry
{
    dHf_298   -73730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     260.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51970.0
}
