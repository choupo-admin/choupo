/*--------------------------------*- Choupo -*-----------------------*\
  Component: decyl octanoate  (C18H36O2, CAS 2306-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decylOctanoate;
formula     C18H36O2;
CAS         2306-89-0;
InChIKey    WVWRBUIUZMBLNI-UHFFFAOYSA-N;
MW          284.484;      // g/mol [origin=calculated method=formula-sum]
Tc          835.25;      // K   [origin=predictive method=joback]
Pc          11.561;      // bar [origin=predictive method=joback]
omega       0.8897;      // -   [origin=predictive method=lee-kesler]
Tb          669.66;      // K   [origin=predictive method=joback]
HvapTb      63069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.935 1.65904 -0.0008608 1.459e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanoic acid, decyl ester" "octanoic acid, decylester" "decylcaprylate; decyl octanoate" "octanoic acid decyl ester" "we(10:0/8:0)" );
gibbsFormation
{
    dHf_298   -732130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     908.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209690.0
    phase     gas;
}
