/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-aminohexanoic acid  (C6H13NO2, CAS 60-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6AminohexanoicAcid;
formula     C6H13NO2;
CAS         60-32-2;
InChIKey    SLXKOJJOQWFEFD-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          754.16;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.8879;      // -   [origin=predictive method=lee-kesler]
Tb          554.92;      // K   [origin=predictive method=joback]
HvapTb      56755.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.525 0.6865 -0.0004186 9.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-azanylhexanoic acid" "aminocaproic acid" "6-aminocaproic acid" "amicar" "acepramin" "caprolisin" "epsikapron" "hemocaprol" "capramol" "caprocid" "epsamon" "ipsilon" );
standardThermochemistry
{
    dHf_298   -483650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277820.0
}
