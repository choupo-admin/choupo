/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropylamine  (C3H9N, CAS 75-31-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylamine;
formula     C3H9N;
CAS         75-31-0;
InChIKey    JJWLVOIRVHMVIS-UHFFFAOYSA-N;
MW          59.112;      // g/mol [origin=calculated method=formula-sum]
Tc          527.04;      // K   [origin=predictive method=joback]
Pc          48.158;      // bar [origin=predictive method=joback]
omega       0.2961;      // -   [origin=predictive method=lee-kesler]
Tb          340.33;      // K   [origin=predictive method=joback]
HvapTb      32525.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.97 0.35664 -0.000186 3.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-amine" "1-methylethylamine" "2-aminopropane" "2-isopropylamine" "2-propanamine" "2-propylamine" "monoisopropylamine" "propan-2-ylamine" "sec-propylamine" "isopropyl amine" "propane, 2-amino-" "isopropilamina" );
standardThermochemistry
{
    dHf_298   -76740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     314.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38390.0
}
