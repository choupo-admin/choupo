/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3,5,5-pentamethyl-1,3,5-azadisilinane  (C8H21NSi2, CAS 69320-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H21NSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13355Pentamethyl135Azadisilinane;
formula     C8H21NSi2;
CAS         69320-68-9;
InChIKey    FTWWWHUTSLAILC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          187.433;      // g/mol [origin=calculated method=formula-sum]
Tc          598.81;      // K   [origin=predictive method=joback]
Pc          23.451;      // bar [origin=predictive method=joback]
omega       0.2598;      // -   [origin=predictive method=lee-kesler]
Tb          409.29;      // K   [origin=predictive method=joback]
HvapTb      36255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.38 0.6528 3e-05 -1.855e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH3N; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-aza-3,5-disilacyclohexane,1,3,3,5,5-pentamethyl-" "1-aza-3,5-disilacyclohexane, 1,3,3,5,5-pentamethyl-" );
gibbsFormation
{
    dHf_298   -271020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-13800.0
    phase     gas;
}
