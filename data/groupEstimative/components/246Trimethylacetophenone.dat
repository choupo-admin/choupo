/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',4',6'-trimethylacetophenone  (C11H14O, CAS 1667-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethylacetophenone;
formula     C11H14O;
CAS         1667-01-2;
InChIKey    XWCIICLTKWRWCI-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          761.63;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.5625;      // -   [origin=predictive method=lee-kesler]
Tb          546.77;      // K   [origin=predictive method=joback]
HvapTb      51088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.24 0.76348 -0.00038598 6.146e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,4,6-trimethylphenyl)ethanone" "acetylmesitylene" "2-acetylmesitylene" "mesityl methyl ketone" "acetomesitylene" "1-mesitylethanone" "ethanone, 1-(2,4,6-trimethylphenyl)-" "acetophenone, 2',4',6'-trimethyl-" "1-acetyl-2,4,6-trimethylbenzene" "2',6'-trimethylacetophenone" "1,5-trimethyl-2-acetylbenzene" "acetophenone,4',6'-trimethyl-" );
standardThermochemistry
{
    dHf_298   -180830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3660.0
}
