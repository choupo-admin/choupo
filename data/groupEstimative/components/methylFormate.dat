/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl formate  (C2H4O2, CAS 107-31-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2H4O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methylFormate;
formula     C2H4O2;
CAS         107-31-3;
InChIKey    TZIHFWKZFHZASV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          60.052;      // g/mol [origin=calculated method=formula-sum]
Tc          371.24;      // K   [origin=predictive method=joback]
Pc          51.166;      // bar [origin=predictive method=joback]
omega       0.0780;      // -   [origin=predictive method=lee-kesler]
Tb          221.78;      // K   [origin=predictive method=joback]
HvapTb      17673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.43 0.20192 -0.000238 1.093e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl methanoate" "formic acid, methyl ester" "formic acid methyl ester" "methylformiaat [dutch]" "methylformiat [german]" "formiate de methyle [french]" "methyle (formiate de) [french]" "methylformiaat" "methylformiat" "formiate de methyle" "mravencan methylnaty" "metil (formiato di)" );
standardThermochemistry
{
    dHf_298   -8160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9920.0
}
