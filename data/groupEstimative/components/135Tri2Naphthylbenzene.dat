/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tri-2-naphthylbenzene  (C36H24, CAS 7059-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Tri2Naphthylbenzene;
formula     C36H24;
CAS         7059-70-3;
InChIKey    AWIOMAWDKDFGDP-UHFFFAOYSA-N;
MW          456.588;      // g/mol [origin=calculated method=formula-sum]
Tc          1507.66;      // K   [origin=predictive method=joback]
Pc          13.820;      // bar [origin=predictive method=joback]
omega       1.0643;      // -   [origin=predictive method=lee-kesler]
Tb          1211.84;      // K   [origin=predictive method=joback]
HvapTb      113064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-188.29 2.7996 -0.00213436 6.38e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 24; } { group AC; count 12; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 24; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3,5-dinaphthalen-2-ylphenyl)naphthalene" );
standardThermochemistry
{
    dHf_298   675610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=973680.0
}
