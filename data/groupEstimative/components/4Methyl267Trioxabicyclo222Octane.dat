/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2,6,7-trioxabicyclo[2.2.2]octane  (C6H10O3, CAS 766-32-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl267Trioxabicyclo222Octane;
formula     C6H10O3;
CAS         766-32-5;
InChIKey    IVYGPMQYLKQFNP-UHFFFAOYSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          663.96;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.3868;      // -   [origin=predictive method=lee-kesler]
Tb          439.99;      // K   [origin=predictive method=joback]
HvapTb      41499.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.32 1.13932 -0.0011411 4.709e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group FCH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2,6,7-trioxabicyclo(2.2.2)octane" "2,6,7-trioxabicyclo(2.2.2)octane, 4-methyl-" );
standardThermochemistry
{
    dHf_298   -414650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     164.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166910.0
}
