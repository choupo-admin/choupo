  Component: 2-oxepanone, polymer with 1,6-hexanediol and 1,1'-methylenebis(4-isocyanatocyclohexane)  (C27H46N2O6, CAS 68958-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxepanonePolymerWith16HexanediolAnd11Methylenebis4Isocyanat;
formula     C27H46N2O6;
CAS         68958-08-7;
InChIKey    CKRJKJFDDOEABG-UHFFFAOYSA-N;
MW          494.673;      // g/mol [origin=calculated method=formula-sum]
Tc          1548.00;      // K   [origin=predictive method=joback]
Pc          10.460;      // bar [origin=predictive method=joback]
omega       0.8456;      // -   [origin=predictive method=lee-kesler]
Tb          1245.79;      // K   [origin=predictive method=joback]
HvapTb      136919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 19; } { group CH; count 4; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 7; } { group dCd; count 2; } { group CH2_ring; count 13; } { group CH_ring; count 4; } { group OH; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane-1,6-diol;1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane;oxepan-2-one" );
