/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[3-(dimethylamino)propyl]octanamide  (C13H28N2O, CAS 22890-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3DimethylaminoPropylOctanamide;
formula     C13H28N2O;
CAS         22890-10-4;
InChIKey    RZJGTTOKUNMVCJ-UHFFFAOYSA-N;
MW          228.38;      // g/mol [origin=calculated method=formula-sum]
Tc          784.23;      // K   [origin=predictive method=joback]
Pc          17.477;      // bar [origin=predictive method=joback]
omega       0.9596;      // -   [origin=predictive method=lee-kesler]
Tb          613.52;      // K   [origin=predictive method=joback]
HvapTb      59757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.471 1.41096 -0.0008259 1.8236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH3N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(3-(dimethylamino)propyl)octanamide" "octanamide, n-(3-(dimethylamino)propyl)-" "octanamide, n-[3-(dimethylamino)propyl]-" );
standardThermochemistry
{
    dHf_298   -303230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     745.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129830.0
}
