/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxy-4-methylpent-1-ene  (C8H16O, CAS 16969-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxy4Methylpent1Ene;
formula     C8H16O;
CAS         16969-29-2;
InChIKey    PEGWCMWUBAGRKQ-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          584.91;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.4095;      // -   [origin=predictive method=lee-kesler]
Tb          408.78;      // K   [origin=predictive method=joback]
HvapTb      35382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.252 0.72656 -0.0003874 7.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-4-methyl-pent-1-ene" "1-pentene,1-ethoxy-4-methyl-, (z)- (9ci)" "ether,ethyl 4-methyl-1-pentenyl, (z)- (8ci)" );
gibbsFormation
{
    dHf_298   -228730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10740.0
    phase     gas;
}
