/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidine, 1-(1-butenyl)-  (C9H17N, CAS 7182-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidine11Butenyl;
formula     C9H17N;
CAS         7182-10-7;
InChIKey    YBTBLUIZFVXVOK-XVNBXDOJSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          641.15;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       0.4001;      // -   [origin=predictive method=lee-kesler]
Tb          442.07;      // K   [origin=predictive method=joback]
HvapTb      38195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.589 1.16092 -0.000845 2.484e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(e)-but-1-enyl]piperidine" "1-(1-butenyl)piperidine" );
standardThermochemistry
{
    dHf_298   36480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=260160.0
}
