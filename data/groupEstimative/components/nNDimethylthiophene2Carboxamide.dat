/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylthiophene-2-carboxamide  (C7H9NOS, CAS 30717-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylthiophene2Carboxamide;
formula     C7H9NOS;
CAS         30717-57-8;
InChIKey    CDXVCHCOBYAVHR-UHFFFAOYSA-N;
MW          155.215;      // g/mol [origin=calculated method=formula-sum]
Tc          722.38;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.5135;      // -   [origin=predictive method=lee-kesler]
Tb          497.15;      // K   [origin=predictive method=joback]
HvapTb      47589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.55 0.76585 -0.00055992 1.6046e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CON_CH3_2; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group CdO; count 1; } { group N; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-thiophenecarboxamide,n,n-dimethyl-" "n,n-dimethyl-2-thienylcarboxamide" "n,n-dimethyl-thiophene-2-carboxamide" "2-thiophenecarboxamide, n,n-dimethyl-" );
standardThermochemistry
{
    dHf_298   -2690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124330.0
}
