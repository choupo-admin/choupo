/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisphenol a  (C15H16O2, CAS 80-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisphenolA;
formula     C15H16O2;
CAS         80-05-7;
InChIKey    IISBACLAFKSPIT-UHFFFAOYSA-N;
MW          228.291;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.89;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.9144;      // -   [origin=predictive method=lee-kesler]
Tb          754.17;      // K   [origin=predictive method=joback]
HvapTb      78268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.87 1.70604 -0.00153912 5.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-hydroxyphenyl)propan-2-yl]phenol" "2,2-bis(4-hydroxyphenyl)propane" "4,4'-isopropylidenediphenol" "diano" "diphenylolpropane" "4,4'-bisphenol a" "phenol, 4,4'-(1-methylethylidene)bis-" "bisphenol" "dian" "p,p'-isopropylidenebisphenol" "2,2-di(4-phenylol)propane" "biphenol a" );
standardThermochemistry
{
    dHf_298   -243240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6160.0
}
