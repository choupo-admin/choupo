/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(benzylamino)propionitrile  (C10H12N2, CAS 706-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BenzylaminoPropionitrile;
formula     C10H12N2;
CAS         706-03-6;
InChIKey    MWTGBAURSCEGSL-UHFFFAOYSA-N;
MW          160.22;      // g/mol [origin=calculated method=formula-sum]
Tc          829.81;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.7211;      // -   [origin=predictive method=lee-kesler]
Tb          607.33;      // K   [origin=predictive method=joback]
HvapTb      57044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.317 0.8859 -0.000569 1.375e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(phenylmethyl)amino]propanenitrile" "3-(benzylamino)propanenitrile" "(" "a-cyanoethyl)benzylamine" "3-[benzylamino]propanenitrile" "propanenitrile, 3-((phenylmethyl)amino)-" "propanenitrile, 3-[(phenylmethyl)amino]-" "mwtgbaurscegsl-uhfffaoysa-" ".beta.-(benzylamino)propionitrile" "3-(phenylmethylamino)propanenitrile" "propanenitrile,3-[(phenylmethyl)amino]-" "propionitrile,3-(benzylamino)- (6ci,7ci,8ci);(2-cyanoethyl)(phenylmethyl)amine;3-(benzylamino)propanenitrile;3-(benzylamino)propionitrile;3-[(phenylmethyl)amino]propanenitrile;benzyl(2-cyanoethyl)amine;n-(2-cyanoethyl)benzylamine;n-(2-nitrilethyl)benzylamine;n-benzyl-2-cyanoethylamine;b-(benzylamino)propionitrile;" );
gibbsFormation
{
    dHf_298   205150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368300.0
    phase     gas;
}
