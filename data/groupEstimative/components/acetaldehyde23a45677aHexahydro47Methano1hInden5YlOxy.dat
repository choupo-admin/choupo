/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetaldehyde, 2-((3a,4,5,6,7,7a-hexahydro-4,7-methano-1h-inden-5-yl)oxy)-  (C13H20O2, CAS 72928-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetaldehyde23a45677aHexahydro47Methano1hInden5YlOxy;
formula     C13H20O2;
CAS         72928-15-5;
InChIKey    CSURFFDFRLCSED-AMGFRPDHSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          776.35;      // K   [origin=predictive method=joback]
Pc          20.869;      // bar [origin=predictive method=joback]
omega       0.5338;      // -   [origin=predictive method=lee-kesler]
Tb          566.70;      // K   [origin=predictive method=joback]
HvapTb      51646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.77 1.32156 -0.00071108 1.149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 5; } { group CH=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 5; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3as,4r,5s,7s,7ar)-4,7-dimethyl-3a,4,5,6,7,7a-hexahydro-1h-inden-5-yl] ethanoate" "[(3as,4r,5s,7s,7ar)-4,7-dimethyl-3a,4,5,6,7,7a-hexahydro-1h-inden-5-yl] acetate" );
gibbsFormation
{
    dHf_298   -505050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-159760.0
    phase     gas;
}
