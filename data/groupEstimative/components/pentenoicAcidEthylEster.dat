/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentenoic acid, ethyl ester  (C7H12O2, CAS 24410-84-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentenoicAcidEthylEster;
formula     C7H12O2;
CAS         24410-84-2;
InChIKey    AGMKVZDPATUSMS-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          603.55;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.4638;      // -   [origin=predictive method=lee-kesler]
Tb          422.14;      // K   [origin=predictive method=joback]
HvapTb      38541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.752 0.63404 -0.0003462 6.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl pent-2-enoate" "ethyl 2-pentenoate" "ethyl trans-pent-2-enoate" "ethyl pent-2-en-1-oate" "ethyl trans-pent-2-enoate 99%" "2-pentenoic acid, ethylester, (2e)-" "2-pentenoicacid, ethyl ester, (e)- (8ci); ethyl (e)-2-pentenoate; ethyltrans-2-pentenoate; trans-2-pentenoic acid ethyl ester" );
standardThermochemistry
{
    dHf_298   -387870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222090.0
}
