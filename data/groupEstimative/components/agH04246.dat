/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-h-04246  (C29H34O2, CAS 69777-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agH04246;
formula     C29H34O2;
CAS         69777-74-8;
InChIKey    RHUXKIANICSJAI-UHFFFAOYSA-N;
MW          414.589;      // g/mol [origin=calculated method=formula-sum]
Tc          1254.38;      // K   [origin=predictive method=joback]
Pc          10.871;      // bar [origin=predictive method=joback]
omega       0.9408;      // -   [origin=predictive method=lee-kesler]
Tb          1015.44;      // K   [origin=predictive method=joback]
HvapTb      95593.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.246 2.30068 -0.00135808 2.776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group ACH; count 12; } { group AC; count 4; } { group ACCH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-methylbutyl)phenyl] 4-[4-(2-methylbutyl)phenyl]benzoate" "4-(2-methylbutyl)phenyl 4'-(2-methylbutyl)(1,1'-biphenyl)-4-carboxylate" "(s-(r*,r*))-4-(2-methylbutyl)phenyl 4-(2-methylbutyl)(1,1'-biphenyl)-4-carboxylate" "[s-(r*,r*)]-4-(2-methylbutyl)phenyl 4-(2-methylbutyl)[1,1'-biphenyl]-4-carboxylate" "4-(2-methylbutyl)phenyl 4'-(2-methylbutyl)[1,1'-biphenyl]-4-carboxylate" "(1,1'-biphenyl)-4-carboxylic acid, 4'-((2s)-2-methylbutyl)-, 4-((2s)-2-methylbutyl)phenyl ester" "[1,1'-biphenyl]-4-carboxylic acid, 4'-[(2s)-2-methylbutyl]-, 4-[(2s)-2-methylbutyl]phenyl ester" "[4-[(2s)-2-methylbutyl]phenyl] 4-[4-[(2s)-2-methylbutyl]phenyl]benzoate" "[1,1'-biphenyl]-4-carboxylic acid, 4'-(2-methylbutyl)-, 4-(2-methylbutyl)phenyl ester" "[1,1'-biphenyl]-4-carboxylicacid, 4'-(2-methylbutyl)-, 4-(2-methylbutyl)phenyl ester" "4-(2-methylbutyl)phenyl4'-(2-methylbutyl)-4-biphenylcarboxylate; ce 2; ce 2 (liquid crystal)" );
standardThermochemistry
{
    dHf_298   -294550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     980.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186390.0
}
