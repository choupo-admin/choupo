/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl isocyanate  (C7H11NO, CAS 3173-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylIsocyanate;
formula     C7H11NO;
CAS         3173-53-3;
InChIKey    KQWGXHWJMSMDJJ-UHFFFAOYSA-N;
MW          125.171;      // g/mol [origin=calculated method=formula-sum]
Tc          661.69;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.3915;      // -   [origin=predictive method=lee-kesler]
Tb          445.98;      // K   [origin=predictive method=joback]
HvapTb      41137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "isocyanatocyclohexane" "cyclohexane, isocyanato-" "cyclohexylisocyanate" "isocyanato-cyclohexane" "isocyanic acid, cyclohexyl ester" "isocyanic acid cyclohexyl ester" "cyclohexanisocyanate" "chi" );
// formation datum unavailable (element entropy missing): dHf_298=-138900.0 dGf_298=None
