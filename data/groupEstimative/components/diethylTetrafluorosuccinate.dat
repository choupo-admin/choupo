/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl tetrafluorosuccinate  (C8H10F4O4, CAS 377-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylTetrafluorosuccinate;
formula     C8H10F4O4;
CAS         377-71-9;
InChIKey    BLZSSBPZHBFNBN-UHFFFAOYSA-N;
MW          246.156;      // g/mol [origin=calculated method=formula-sum]
Tc          654.77;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.7329;      // -   [origin=predictive method=lee-kesler]
Tb          489.70;      // K   [origin=predictive method=joback]
HvapTb      42356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.852 0.95304 -0.0006314 1.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CF2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 2; } { group F; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,2,3,3-tetrakis(fluoranyl)butanedioate" "diethyl perfluorosuccinate" "butanedioic acid, tetrafluoro-, diethyl ester" "butanedioic acid, 2,2,3,3-tetrafluoro-, 1,4-diethyl ester" "diethyl 2,2,3,3-tetrafluorobutane-1,4-dioate" "succinic acid, tetrafluoro-, diethyl ester" "diethyl tetrafluorosuccinate 97%" "diethyl 2,2,3,3-tetrafluorobutanedioate" "1,4-diethyl 2,2,3,3-tetrafluorobutanedioate" "butanedioicacid, tetrafluoro-, diethyl ester (9ci); succinic acid, tetrafluoro-, diethylester (6ci,7ci,8ci); diethyl tetrafluorosuccinate" );
standardThermochemistry
{
    dHf_298   -1644950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1377820.0
}
