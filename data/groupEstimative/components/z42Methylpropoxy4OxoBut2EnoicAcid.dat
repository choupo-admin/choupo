/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-4-(2-methylpropoxy)-4-oxo-but-2-enoic acid  (C8H12O4, CAS 67906-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z42Methylpropoxy4OxoBut2EnoicAcid;
formula     C8H12O4;
CAS         67906-92-7;
InChIKey    UKXDHEBARGMWMO-UHFFFAOYSA-N;
MW          172.18;      // g/mol [origin=calculated method=formula-sum]
Tc          790.95;      // K   [origin=predictive method=joback]
Pc          29.795;      // bar [origin=predictive method=joback]
omega       0.8801;      // -   [origin=predictive method=lee-kesler]
Tb          590.09;      // K   [origin=predictive method=joback]
HvapTb      57543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.761 0.78574 -0.0004764 1.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-methylpropoxy)-4-oxidanylidene-but-2-enoic acid" "2-butenedioic acid (2z)-, 1-(2-methylpropyl) ester" "2-butenedioic acid (2z)-, mono(2-methylpropyl) ester" );
gibbsFormation
{
    dHf_298   -764060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-560020.0
    phase     gas;
}
