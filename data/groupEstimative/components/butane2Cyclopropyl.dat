/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, 2-cyclopropyl-  (C7H14, CAS 5750-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane2Cyclopropyl;
formula     C7H14;
CAS         5750-02-7;
InChIKey    INSSHDIMRIMVLZ-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          548.66;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.2875;      // -   [origin=predictive method=lee-kesler]
Tb          366.06;      // K   [origin=predictive method=joback]
HvapTb      30701.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.399 0.82564 -0.0005804 1.709e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butan-2-ylcyclopropane" "cyclopropane, sec-butyl-" "sec-butylcyclopropane" "agn-pc-0d749d" "cyclopropane,(1-methylpropyl)-" "cyclopropane, (1-methylpropyl)-" );
standardThermochemistry
{
    dHf_298   -120290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66370.0
}
