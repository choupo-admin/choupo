/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6,9,12-tetraoxatetradecan-1-ol  (C10H22O5, CAS 5650-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36912Tetraoxatetradecan1Ol;
formula     C10H22O5;
CAS         5650-20-4;
InChIKey    GTAKOUPXIUWZIA-UHFFFAOYSA-N;
MW          222.281;      // g/mol [origin=calculated method=formula-sum]
Tc          770.38;      // K   [origin=predictive method=joback]
Pc          21.553;      // bar [origin=predictive method=joback]
omega       1.2494;      // -   [origin=predictive method=lee-kesler]
Tb          610.26;      // K   [origin=predictive method=joback]
HvapTb      64173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (101.089 0.73502 -0.0001066 -1.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2O; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group OH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-(2-ethoxyethoxy)ethoxy]ethoxy]ethanol" "tetraethylene glycol monoethyl ether" "tetraethylene glycol, monoethyl ether" "ethanol,2-[[2-(2-ethoxyethoxy)ethoxy]ethoxy]- (6ci); ethyltetraglycol; tetraethyleneglycol ethyl ether; tetraethylene glycol monoethyl ether; tetraethylene glycolmonoethyl ether, monoethyl ether" );
gibbsFormation
{
    dHf_298   -930840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-523500.0
    phase     gas;
}
