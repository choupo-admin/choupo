/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16-azatricyclo[9.2.2.14,8]hexadeca-4,6,8(16),11,13,14-hexaene,12,13,14,15-tetramethyl-  (C19H23N, CAS 70389-15-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Azatricyclo922148Hexadeca46816111314Hexaene12131415Tetrame;
formula     C19H23N;
CAS         70389-15-0;
InChIKey    PGGRIMDRJDUNJZ-UHFFFAOYSA-N;
MW          265.4;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.62;      // K   [origin=predictive method=joback]
Pc          19.220;      // bar [origin=predictive method=joback]
omega       0.7662;      // -   [origin=predictive method=lee-kesler]
Tb          786.94;      // K   [origin=predictive method=joback]
HvapTb      73016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.64 1.49564 -0.00090842 2.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACCH3; count 4; } { group ACCH2; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 8; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12,13,14,15-tetramethyl-16-azatricyclo[9.2.2.14,8]hexadeca-1(13),4(16),5,7,11,14-hexaene" "16-azatricyclo(9.2.2.14,8)hexadeca-4,6,8(16),11,13,14-hexaene, 12,13,14,15-tetramethyl-" );
gibbsFormation
{
    dHf_298   88520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=409550.0
    phase     gas;
}
