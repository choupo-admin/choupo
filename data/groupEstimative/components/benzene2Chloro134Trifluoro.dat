/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene,2-chloro-1,3,4-trifluoro-  (C6H2ClF3, CAS 39153-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene2Chloro134Trifluoro;
formula     C6H2ClF3;
CAS         39153-73-6;
InChIKey    LAHJDOYPEPWPFT-UHFFFAOYSA-N;
MW          166.526;      // g/mol [origin=calculated method=formula-sum]
Tc          605.32;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.4230;      // -   [origin=predictive method=lee-kesler]
Tb          413.74;      // K   [origin=predictive method=joback]
HvapTb      35146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.59 0.3586 -0.00020228 3.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCl; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,3,4-tris(fluoranyl)benzene" "2-chloro-1,3,4-trifluorobenzene" "benzene, 2-chloro-1,3,4-trifluoro-" );
standardThermochemistry
{
    dHf_298   -569120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-513200.0
}
