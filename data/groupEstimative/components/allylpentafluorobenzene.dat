/*--------------------------------*- Choupo -*-----------------------*\
  Component: allylpentafluorobenzene  (C9H5F5, CAS 1736-60-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylpentafluorobenzene;
formula     C9H5F5;
CAS         1736-60-3;
InChIKey    YBDBTBVNQQBHGJ-UHFFFAOYSA-N;
MW          208.129;      // g/mol [origin=calculated method=formula-sum]
Tc          618.36;      // K   [origin=predictive method=joback]
Pc          24.777;      // bar [origin=predictive method=joback]
omega       0.6050;      // -   [origin=predictive method=lee-kesler]
Tb          450.13;      // K   [origin=predictive method=joback]
HvapTb      36459.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.761 0.5214 -0.0002667 4.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACCH2; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dC_ring; count 6; } { group F; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(fluoranyl)-6-prop-2-enyl-benzene" "benzene, allylpentafluoro-" "2,3,4,5,6-pentafluoro(allylbenzene)" "benzene, pentafluoro-2-propenyl-" "allyl pentafluorobenzene" "3-(pentafluorophenyl)-1-propene" "3-(pentafluorophenyl)prop-1-ene" "1,2,3,4,5-pentafluoro-6-prop-2-enylbenzene" "1,2,3,5,6-pentafluoro-4-prop-2-enylbenzene" "1,2,3,4,5-pentafluoro-6-(prop-2-en-1-yl)benzene" );
gibbsFormation
{
    dHf_298   -905030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-797050.0
    phase     gas;
}
