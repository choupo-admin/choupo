/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5,6,7,8-octahydronaphthalene  (C10H16, CAS 493-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12345678Octahydronaphthalene;
formula     C10H16;
CAS         493-03-8;
InChIKey    ZKZCHOVDCNLSKG-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          705.19;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.3501;      // -   [origin=predictive method=lee-kesler]
Tb          477.42;      // K   [origin=predictive method=joback]
HvapTb      40602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.67 1.0952 -0.000739 1.976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-octalin" "1,2,3,4,5,6,7,8-octahydro-naphthalene" "naphthalene,1,2,3,4,5,6,7,8-octahydro-" "naphthalene, 1,2,3,4,5,6,7,8-octahydro-" "1,2,3,5,6,8-hexahydro-naphthalene;9,10-dehydrodecalin; 9,10-octalin; 9-octalin; d9,10-octalin; d9-octalin" );
gibbsFormation
{
    dHf_298   -53250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132540.0
    phase     gas;
}
