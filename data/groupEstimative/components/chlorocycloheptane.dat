/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorocycloheptane  (C7H13Cl, CAS 2453-46-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorocycloheptane;
formula     C7H13Cl;
CAS         2453-46-5;
InChIKey    KMJSGLZXFNSANB-UHFFFAOYSA-N;
MW          132.631;      // g/mol [origin=calculated method=formula-sum]
Tc          640.84;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.2513;      // -   [origin=predictive method=lee-kesler]
Tb          421.01;      // K   [origin=predictive method=joback]
HvapTb      36162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.31 0.7881 -0.000412 6.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloranylcycloheptane" "cycloheptyl chloride" "cycloheptane, chloro-" "chloro-cycloheptane" );
standardThermochemistry
{
    dHf_298   -155390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8480.0
}
