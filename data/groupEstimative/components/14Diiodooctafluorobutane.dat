/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diiodooctafluorobutane  (C4F8I2, CAS 375-50-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diiodooctafluorobutane;
formula     C4F8I2;
CAS         375-50-8;
InChIKey    JILAKKYYZPDQBE-UHFFFAOYSA-N;
MW          453.828;      // g/mol [origin=calculated method=formula-sum]
Tc          662.79;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       0.3680;      // -   [origin=predictive method=lee-kesler]
Tb          458.64;      // K   [origin=predictive method=joback]
HvapTb      31524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.53 1.0594 -0.001175 4.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 2; } { group CF2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 4; } { group F; count 8; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,3,4,4-octakis(fluoranyl)-1,4-bis(iodanyl)butane" "octafluoro-1,4-diiodobutane" "1,1,2,2,3,3,4,4-octafluoro-1,4-diiodobutane" "perfluoro-1,4-diiodobutane" "butane, 1,1,2,2,3,3,4,4-octafluoro-1,4-diiodo-" "1,4-diiodoperfluorobutane" "1,4-diiodo octafluorobutane" "butane,1,1,2,2,3,3,4,4-octafluoro-1,4-diiodo-" "butane,octafluoro-1,4-diiodo- (7ci,8ci); 1,1,2,2,3,3,4,4-octafluoro-1,4-diiodobutane;1,4-diiodo-1,1,2,2,3,3,4,4-octafluorobutane; 1,4-diiodooctafluorobutane;1,4-diiodoperfluorobutane; octafluoro-1,4-diiodobutane; a,w-diiodoperfluorobutane" );
standardThermochemistry
{
    dHf_298   -1576030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1448080.0
}
