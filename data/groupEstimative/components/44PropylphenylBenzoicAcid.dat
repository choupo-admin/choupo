/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-propylphenyl)benzoic acid  (C16H16O2, CAS 88038-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44PropylphenylBenzoicAcid;
formula     C16H16O2;
CAS         88038-94-2;
InChIKey    HCPBURTZSXRGBN-UHFFFAOYSA-N;
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.09;      // K   [origin=predictive method=joback]
Pc          24.195;      // bar [origin=predictive method=joback]
omega       0.9630;      // -   [origin=predictive method=lee-kesler]
Tb          774.51;      // K   [origin=predictive method=joback]
HvapTb      74250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.268 1.29782 -0.00084752 2.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propylbiphenyl-4'-carboxylic acid" "4-(4-n-propylphenyl)benzoic acid" "4-propyl-4'-biphenylcarboxylic acid" "4-n-propylbiphenyl-4'-carboxylic acid" "4'-propylbiphenyl-4-carboxylic acid" "4'-propyl-[1,1'-biphenyl]-4-carboxylic acid" "4-(4-propylphenyl)benzoicacid; 4'-propylbiphenyl-4-carboxylic acid" );
gibbsFormation
{
    dHf_298   -273720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54510.0
    phase     gas;
}
