/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethoxyhex-2-ene  (C10H20O2, CAS 67746-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diethoxyhex2Ene;
formula     C10H20O2;
CAS         67746-30-9;
InChIKey    WMQKYHTZGYIHHD-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          650.34;      // K   [origin=predictive method=joback]
Pc          21.593;      // bar [origin=predictive method=joback]
omega       0.5808;      // -   [origin=predictive method=lee-kesler]
Tb          476.96;      // K   [origin=predictive method=joback]
HvapTb      42244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.934 0.85336 -0.0003852 4.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-2-hexen-1-al diethyl acetal" "2-hexene, 1,1-diethoxy-" "2-hexenaldiethylacetal" "agn-pc-00l3o4" );
standardThermochemistry
{
    dHf_298   -402230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98900.0
}
