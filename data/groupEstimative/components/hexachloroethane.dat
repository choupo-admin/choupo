/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexachloroethane  (C2Cl6, CAS 67-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexachloroethane;
formula     C2Cl6;
CAS         67-72-1;
InChIKey    VHHHONWQHHHLTI-UHFFFAOYSA-N;
MW          236.722;      // g/mol [origin=calculated method=formula-sum]
Tc          710.98;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.2650;      // -   [origin=predictive method=lee-kesler]
Tb          463.48;      // K   [origin=predictive method=joback]
HvapTb      43764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.47 0.4862 -0.000551 2.104e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2,2-hexakis(chloranyl)ethane" "perchloroethane" "avlothane" "ethane, hexachloro-" "carbon hexachloride" "ethylene hexachloride" "distokal" "distopan" "distopin" "falkitol" "mottenhexe" "phenohep" );
gibbsFormation
{
    dHf_298   -196550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99940.0
    phase     gas;
}
