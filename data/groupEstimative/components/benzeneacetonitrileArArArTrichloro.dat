/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneacetonitrile, ar,ar,ar-trichloro-  (C8H4Cl3N, CAS 70833-63-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneacetonitrileArArArTrichloro;
formula     C8H4Cl3N;
CAS         70833-63-5;
InChIKey    KQWHNBIYSHFRLC-UHFFFAOYSA-N;
MW          220.477;      // g/mol [origin=calculated method=formula-sum]
Tc          885.28;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.6382;      // -   [origin=predictive method=lee-kesler]
Tb          638.63;      // K   [origin=predictive method=joback]
HvapTb      61297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.281 0.4616 -0.00027168 5.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH2CN; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4,6-tris(chloranyl)phenyl]ethanenitrile" "trichlorophenylacetonitrile" "(2,4,6-trichlorophenyl)acetonitrile" "2-(2,4,6-trichlorophenyl)acetonitrile" );
standardThermochemistry
{
    dHf_298   111330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197390.0
}
