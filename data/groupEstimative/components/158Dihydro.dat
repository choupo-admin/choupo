/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1, 5,8-dihydro-  (C10H10O2, CAS 3090-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        158Dihydro;
formula     C10H10O2;
CAS         3090-45-7;
InChIKey    LZODMDMDIZUSHT-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          894.08;      // K   [origin=predictive method=joback]
Pc          55.692;      // bar [origin=predictive method=joback]
omega       0.8475;      // -   [origin=predictive method=lee-kesler]
Tb          636.14;      // K   [origin=predictive method=joback]
HvapTb      67506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.17 1.2364 -0.00121356 4.764e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,8-dihydronaphthalene-1,4-diol" "5,8-dihydro-1,4-naphthalenediol" "1,4-naphthalenediol, 5,8-dihydro-" "5,4-naphthalenediol" "5,8-dihydro-naphthalene-1,4-diol" "1,4-naphthalenediol,5,8-dihydro-" );
gibbsFormation
{
    dHf_298   -234530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86820.0
    phase     gas;
}
