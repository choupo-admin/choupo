/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-bis(bromomethyl)oxetane  (C5H8Br2O, CAS 2402-83-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33BisBromomethylOxetane;
formula     C5H8Br2O;
CAS         2402-83-7;
InChIKey    QOPMHMFIIMJWET-UHFFFAOYSA-N;
MW          243.926;      // g/mol [origin=calculated method=formula-sum]
Tc          723.95;      // K   [origin=predictive method=joback]
Pc          53.357;      // bar [origin=predictive method=joback]
omega       0.4800;      // -   [origin=predictive method=lee-kesler]
Tb          484.52;      // K   [origin=predictive method=joback]
HvapTb      43038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.308 0.9854 -0.0010835 4.752e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group FCH2O; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group Br; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-di(bromomethyl) oxetane" "oxetane, 3,3-bis(bromomethyl)-" "oxetane,3-bis(bromomethyl)-" "oxetane,3,3-bis(bromomethyl)-" "ht158" "2402-83-7 3,3-bis(bromomethyl)oxetane" );
standardThermochemistry
{
    dHf_298   -143990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23100.0
}
