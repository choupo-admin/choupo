/*--------------------------------*- Choupo -*-----------------------*\
  Component: gem-dimethylcyclopentane  (C7H14, CAS 1638-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gemDimethylcyclopentane;
formula     C7H14;
CAS         1638-26-2;
InChIKey    QWHNJUXXYKPLQM-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          578.58;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.2186;      // -   [origin=predictive method=lee-kesler]
Tb          375.28;      // K   [origin=predictive method=joback]
HvapTb      30282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.95 1.09244 -0.001017 4.096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethylcyclopentane" "cyclopentane, 1,1-dimethyl-" "cyclopentane,1-dimethyl-" "1,1-dimethyl-cyclopentane" "ghl.pd_mitscher_leg0.791" "cyclopentane, 1,1-dimethyl- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -112090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39120.0
    phase     gas;
}
