/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-dodecylaniline  (C18H31N, CAS 104-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Dodecylaniline;
formula     C18H31N;
CAS         104-42-7;
InChIKey    KLPPPIIIEMUEGP-UHFFFAOYSA-N;
MW          261.453;      // g/mol [origin=calculated method=formula-sum]
Tc          910.18;      // K   [origin=predictive method=joback]
Pc          15.105;      // bar [origin=predictive method=joback]
omega       0.9022;      // -   [origin=predictive method=lee-kesler]
Tb          715.63;      // K   [origin=predictive method=joback]
HvapTb      69241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.589 1.63732 -0.00096296 2.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-dodecylaniline" "benzenamine, 4-dodecyl-" "p-dodecyl aniline" "4-dodecylphenylamine" "p-dodecylaniline, tech" "q234" "aniline,p-dodecyl- (6ci,7ci,8ci);(p-aminododecyl)benzene;1-(p-aminophenyl)dodecane;4-dodecylbenzenamine;4-dodecylphenylamine;4-n-dodecylaniline;p-dodecylaniline;" );
gibbsFormation
{
    dHf_298   -156000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     796.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=269910.0
    phase     gas;
}
