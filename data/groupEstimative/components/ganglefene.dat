/*--------------------------------*- Choupo -*-----------------------*\
  Component: ganglefene  (C20H33NO3, CAS 299-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ganglefene;
formula     C20H33NO3;
CAS         299-61-6;
InChIKey    GRALFSQRIBJAHX-UHFFFAOYSA-N;
MW          335.488;      // g/mol [origin=calculated method=formula-sum]
Tc          975.86;      // K   [origin=predictive method=joback]
Pc          12.646;      // bar [origin=predictive method=joback]
omega       0.9389;      // -   [origin=predictive method=lee-kesler]
Tb          780.62;      // K   [origin=predictive method=joback]
HvapTb      73748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.274 1.78912 -0.00094496 1.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group CH; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(diethylamino)-3-methyl-butan-2-yl] 4-(2-methylpropoxy)benzoate" "ganglerone" "gangleron" "ganglefenum [inn-latin]" "1,2-dimethyl-3-diethylaminopropyl p-isobutoxybenzoate" "p-isobutoxybenzoic acid 3-(diethylamino)-1,2-dimethylpropyl ester" "4-(2-methylpropoxy)benzoic acid 3-(diethylamino)-1,2-dimethylpropyl ester" "benzoic acid, p-isobutoxy-, 3-(diethylamino)-1,2-dimethylpropyl ester" "p-isobutoxybenzoic acid, alpha,beta-dimethyl-gamma-diethylaminopropyl ester" "benzoic acid, 4-(2-methylpropoxy)-, 3-(diethylamino)-1,2-dimethylpropyl ester" "ganglefen" "ganglefeno" );
gibbsFormation
{
    dHf_298   -628880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91610.0
    phase     gas;
}
