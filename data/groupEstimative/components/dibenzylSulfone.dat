/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzyl sulfone  (C14H14O2S, CAS 620-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H14O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dibenzylSulfone;
formula     C14H14O2S;
CAS         620-32-6;
InChIKey    AWHNUHMUCGRKRA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          246.324;      // g/mol [origin=calculated method=formula-sum]
Tc          763.37;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.6796;      // -   [origin=predictive method=lee-kesler]
Tb          552.28;      // K   [origin=predictive method=joback]
HvapTb      63128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.008 1.2152 -0.0007748 1.708e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl)sulfonylmethylbenzene" "benzyl sulfone" "(sulfonylbis(methylene))dibenzene" "phenyl[benzylsulfonyl]methane" "benzene,1'-[sulfonylbis(methylene)]bis-" "dibenzyl sulphone" "dibenzyl-sulfone" "benzylsulfonylmethylbenzene" "benzil-related compound, 59" "[(benzylsulfonyl)methyl]benzene" "benzene,1,1'-[sulfonylbis(methylene)]bis-" "benzene, 1,1'-(sulfonylbis(methylene))bis-" );
standardThermochemistry
{
    dHf_298   -354450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209840.0
}
