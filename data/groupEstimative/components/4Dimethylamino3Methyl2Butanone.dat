/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-dimethylamino-3-methyl-2-butanone  (C7H15NO, CAS 22104-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Dimethylamino3Methyl2Butanone;
formula     C7H15NO;
CAS         22104-62-7;
InChIKey    SDABKFFSTRDBBD-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          604.61;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.5036;      // -   [origin=predictive method=lee-kesler]
Tb          425.63;      // K   [origin=predictive method=joback]
HvapTb      39577.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.489 0.77068 -0.0004541 9.996e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dimethylamino)-3-methyl-butan-2-one" "4-(dimethylamino)-3-methylbutan-2-one" "2-butanone, 4-(dimethylamino)-3-methyl-" "1-dimethylamino-2-methyl butane-3-one" "t167" "1-dimethylamino-2-methylbutane-3-one" );
gibbsFormation
{
    dHf_298   -238140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12520.0
    phase     gas;
}
