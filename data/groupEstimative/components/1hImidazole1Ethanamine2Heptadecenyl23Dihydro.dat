/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-imidazole-1-ethanamine, 2-(heptadecenyl)-2,3-dihydro-  (C22H43N3, CAS 27476-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hImidazole1Ethanamine2Heptadecenyl23Dihydro;
formula     C22H43N3;
CAS         27476-93-3;
InChIKey    HZWMDAFUECSDJU-UHFFFAOYSA-N;
MW          349.607;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.85;      // K   [origin=predictive method=joback]
Pc          11.059;      // bar [origin=predictive method=joback]
omega       1.0118;      // -   [origin=predictive method=lee-kesler]
Tb          850.81;      // K   [origin=predictive method=joback]
HvapTb      84343.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.154 2.37152 -0.00151328 3.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH=CH; count 2; } { group CH2NH2; count 1; } { group CHNH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group dCH; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group NH2; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-heptadec-5-enyl-1,2-dihydroimidazol-3-yl)ethanamine" "1h-imidazole-1-ethanamine, 2-(heptadecen-1-yl)-2,3-dihydro-" );
gibbsFormation
{
    dHf_298   -116640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     960.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=558130.0
    phase     gas;
}
