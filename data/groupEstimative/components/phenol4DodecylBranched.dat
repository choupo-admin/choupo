/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 4-dodecyl-, branched  (C18H30O, CAS 210555-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol4DodecylBranched;
formula     C18H30O;
CAS         210555-94-5;
InChIKey    ZLIZUPQZVMVLPA-UHFFFAOYSA-N;
MW          262.437;      // g/mol [origin=calculated method=formula-sum]
Tc          922.14;      // K   [origin=predictive method=joback]
Pc          16.769;      // bar [origin=predictive method=joback]
omega       0.8778;      // -   [origin=predictive method=lee-kesler]
Tb          717.42;      // K   [origin=predictive method=joback]
HvapTb      69788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.345 1.80728 -0.00125256 3.601e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 3; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3,5,7-trimethylnonyl)phenol" "agn-pc-03vch9" );
standardThermochemistry
{
    dHf_298   -371470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51150.0
}
