/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-cyanoethyl) ether  (C6H8N2O, CAS 1656-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2CyanoethylEther;
formula     C6H8N2O;
CAS         1656-48-0;
InChIKey    BCGCCTGNWPKXJL-UHFFFAOYSA-N;
MW          124.143;      // g/mol [origin=calculated method=formula-sum]
Tc          769.56;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.7227;      // -   [origin=predictive method=lee-kesler]
Tb          563.46;      // K   [origin=predictive method=joback]
HvapTb      52316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.934 0.3802 -0.0001296 -7.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2O; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group O; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-cyanoethoxy)propanenitrile" "2,2′-dicyanodiethyl ether" "2-cyanoethyl ether" "3,3′-oxybis[propanenitrile]" "3,3′-oxybispropionitrile" "3,3′-oxydipropionitrile" "bis(propionitrile) ether" "Bis(β-cyanoethyl) ether" "propanenitrile, 3,3′-oxybis-" "propionitrile, 3,3′-oxydi-" "β,β′-Bis(cyanoethyl) ether" "β,β′-dicyanodiethyl ether" );
standardThermochemistry
{
    dHf_298   30370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161000.0
}
