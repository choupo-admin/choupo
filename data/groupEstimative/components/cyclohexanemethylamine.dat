/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanemethylamine  (C7H15N, CAS 3218-02-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanemethylamine;
formula     C7H15N;
CAS         3218-02-8;
InChIKey    AVKNGPAMCBSNSO-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          669.79;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.3876;      // -   [origin=predictive method=lee-kesler]
Tb          451.84;      // K   [origin=predictive method=joback]
HvapTb      42246.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.589 0.8528 -0.0004814 9.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexylmethanamine" "(aminomethyl)cyclohexane" "hexahydrobenzylamine" "aminomethylcyclohexane" "cyclohexanemethanamine" "1-cyclohexylmethanamine" "4-aminomethylcyclohexane" "cyclohexyl-methanamine" "cyclohexyl-methyl-amine" "decarboxylated derivative" "phenylmethanamine;1-phenylmethanamine;monobenzylamine;.omega.-aminotoluene;benzylazanium;(phenylmethyl)amine;benzenemethanamine;.alpha.-aminotoluene;benzylamine(ba);benzyl amine;n-benzylamine;benzylamine 99%;" );
standardThermochemistry
{
    dHf_298   -99700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98960.0
}
