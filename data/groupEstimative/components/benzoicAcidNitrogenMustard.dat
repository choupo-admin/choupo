/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid nitrogen mustard  (C11H13Cl2NO2, CAS 1141-37-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcidNitrogenMustard;
formula     C11H13Cl2NO2;
CAS         1141-37-3;
InChIKey    PCLQMXVMRDPVKX-UHFFFAOYSA-N;
MW          262.13;      // g/mol [origin=calculated method=formula-sum]
Tc          936.12;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       1.0207;      // -   [origin=predictive method=lee-kesler]
Tb          715.75;      // K   [origin=predictive method=joback]
HvapTb      70995.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.026 1.0987 -0.00076476 2.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2N; count 1; } { group COOH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[bis(2-chloroethyl)amino]benzoic acid" "4-n-bis(2-chloroethyl)aminobenzoic acid" "4-(bis(2-chloroethyl)amino)benzoic acid" "p-n,n-bis(2-chloroethyl)aminobenzoic acid" "benzoic acid, 4-(bis(2-chloroethyl)amino)-" "benzoic acid, p-(bis(2-chloroethyl)amino)-" "benzoic acid, 4-[bis(2-chloroethyl)amino]-" "benzoic acid, p-[bis(2-chloroethyl)amino]-" "benzoic acid, 4-(bis(2-chloroethyl)amino)- (9ci)" );
gibbsFormation
{
    dHf_298   -359530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112470.0
    phase     gas;
}
