/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl diallylmalonate  (C13H20O4, CAS 3195-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylDiallylmalonate;
formula     C13H20O4;
CAS         3195-24-2;
InChIKey    LYUUVYQGUMRKOV-UHFFFAOYSA-N;
MW          240.299;      // g/mol [origin=calculated method=formula-sum]
Tc          788.93;      // K   [origin=predictive method=joback]
Pc          18.062;      // bar [origin=predictive method=joback]
omega       0.7823;      // -   [origin=predictive method=lee-kesler]
Tb          603.61;      // K   [origin=predictive method=joback]
HvapTb      56710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.434 1.21504 -0.0007118 1.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,2-bis(prop-2-enyl)propanedioate" "diallylmalonic acid diethyl ester" "diethyl 2,2-diallylmalonate" "diethyl 2,2-diprop-2-enylpropane-1,3-dioate" "lyuuvyqgumrkov-uhfffaoysa-" "diethyl 2,2-diprop-2-enylpropanedioate" "propanedioic acid, di-2-propenyl-, diethyl ester" "1,3-diethyl 2,2-bis(prop-2-en-1-yl)propanedioate" );
standardThermochemistry
{
    dHf_298   -704100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383640.0
}
