/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-glucopyranoside, hexyl  (C12H24O6, CAS 54549-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dGlucopyranosideHexyl;
formula     C12H24O6;
CAS         54549-24-5;
InChIKey    JVAZJLFFSJARQM-OZRWLHRGSA-N;
MW          264.318;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.56;      // K   [origin=predictive method=joback]
Pc          26.164;      // bar [origin=predictive method=joback]
omega       1.8266;      // -   [origin=predictive method=lee-kesler]
Tb          893.12;      // K   [origin=predictive method=joback]
HvapTb      115135.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.116 1.22972 -0.0004851 4.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 4; } { group OH; count 4; } { group CH2O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH_ring; count 5; } { group OH; count 4; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,4s,5s,6r)-2-hexoxy-6-(hydroxymethyl)oxane-3,4,5-triol" "hexyl d-glucoside" "jzr" );
standardThermochemistry
{
    dHf_298   -1191190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-694630.0
}
