/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetoxy-1-phenylpropane  (C11H14O2, CAS 2114-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetoxy1Phenylpropane;
formula     C11H14O2;
CAS         2114-33-2;
InChIKey    LOHDWLZDQXQLJA-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          746.99;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       0.5543;      // -   [origin=predictive method=lee-kesler]
Tb          535.74;      // K   [origin=predictive method=joback]
HvapTb      49375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.289 0.92104 -0.0005144 8.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylpropan-2-yl ethanoate" "1-methyl-2-phenylethyl acetate" "methylbenzylcarbinyl acetate" "1-phenyl-2-propanol acetate" "benzylmethylcarbinyl acetate" "alpha-methylphenethyl acetate" "1-phenylpropan-2-yl acetate" "alpha-methyl-beta-phenylethyl acetate" "benzeneethanol, alpha-methyl-, acetate" "phenethyl alcohol, alpha-methyl-, acetate" "benzeneethanol, ?-methyl-, acetate" "benzeneethanol, a-methyl-, 1-acetate" );
gibbsFormation
{
    dHf_298   -356400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158660.0
    phase     gas;
}
