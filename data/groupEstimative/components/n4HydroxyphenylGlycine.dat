/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(4-hydroxyphenyl)glycine  (C8H9NO3, CAS 122-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n4HydroxyphenylGlycine;
formula     C8H9NO3;
CAS         122-87-2;
InChIKey    WRUZLCLJULHLEY-UHFFFAOYSA-N;
MW          167.164;      // g/mol [origin=calculated method=formula-sum]
Tc          921.38;      // K   [origin=predictive method=joback]
Pc          50.730;      // bar [origin=predictive method=joback]
omega       1.1594;      // -   [origin=predictive method=lee-kesler]
Tb          685.62;      // K   [origin=predictive method=joback]
HvapTb      72292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.819 0.9665 -0.00082016 2.811e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4-hydroxyphenyl)amino]ethanoic acid" "photoglycine" "hydroxyphenyl glycine" "p-hydroxyanilinoacetic acid" "iconyl" "p-hydroxyphenylglycine" "4-(carboxymethylamino)phenol" "p-hydroxyphenyl glycine" "p-hydroxyphenylaminoacetic acid" "glitsin" "monazol" "glycine, n-(4-hydroxyphenyl)-" );
gibbsFormation
{
    dHf_298   -446030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-280250.0
    phase     gas;
}
