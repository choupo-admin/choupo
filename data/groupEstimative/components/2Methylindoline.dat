/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylindoline  (C9H11N, CAS 6872-06-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylindoline;
formula     C9H11N;
CAS         6872-06-6;
InChIKey    QRWRJDVVXAXGBT-UHFFFAOYSA-N;
MW          133.194;      // g/mol [origin=calculated method=formula-sum]
Tc          725.75;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.4221;      // -   [origin=predictive method=lee-kesler]
Tb          492.47;      // K   [origin=predictive method=joback]
HvapTb      45237.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.22 0.85792 -0.00058956 1.629e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2,3-dihydro-1h-indole" "indoline, 2-methyl-" "1h-indole, 2,3-dihydro-2-methyl-" "dihydroindole, 2-methyl-" "2,3-dihydro-2-methylindole" "2-methyl-2,3-dihydroindole" "alpha-methyldihydroindole" "pe-11" "2,3-dihydro-2-methyl-1h-indole" ".alpha.-methyldihydroindole" "1h-indole,3-dihydro-2-methyl-" );
gibbsFormation
{
    dHf_298   106580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     297.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=276140.0
    phase     gas;
}
