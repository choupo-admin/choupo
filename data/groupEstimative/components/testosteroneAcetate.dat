/*--------------------------------*- Choupo -*-----------------------*\
  Component: testosterone acetate  (C21H30O3, CAS 1045-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        testosteroneAcetate;
formula     C21H30O3;
CAS         1045-69-8;
InChIKey    DJPZSBANTAQNFN-PXQJOHHUSA-N;
MW          330.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1096.13;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       0.8108;      // -   [origin=predictive method=lee-kesler]
Tb          849.71;      // K   [origin=predictive method=joback]
HvapTb      72540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-246.96 2.74666 -0.00230344 8.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17s)-10,13-dimethyl-3-oxidanylidene-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl] ethanoate" "deposteron" "farmatest" "testosterone 17-acetate" "perandrone a" "androtest a" "17beta-acetoxy-4-androsten-3-one" "3-oxoandrost-4-en-17beta-yl acetate" "amolisin" "17beta-hydroxyandrost-4-en-3-one acetate" "aceto-sterandryl" "aceto-testoviron" );
standardThermochemistry
{
    dHf_298   -635240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130590.0
}
