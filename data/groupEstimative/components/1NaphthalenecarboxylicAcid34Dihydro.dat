/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthalenecarboxylic acid, 3,4-dihydro-  (C11H10O2, CAS 3333-23-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1NaphthalenecarboxylicAcid34Dihydro;
formula     C11H10O2;
CAS         3333-23-1;
InChIKey    JNPFDSPGHQBUPF-UHFFFAOYSA-N;
MW          174.199;      // g/mol [origin=calculated method=formula-sum]
Tc          891.58;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.7919;      // -   [origin=predictive method=lee-kesler]
Tb          648.27;      // K   [origin=predictive method=joback]
HvapTb      61530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.34 1.0135 -0.0007608 2.252e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dihydronaphthalene-1-carboxylic acid" "3,4-dihydro-.alpha.-naphthoic acid" "3,4-dihydro-1-naphthoicacid" );
standardThermochemistry
{
    dHf_298   -262290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122700.0
}
