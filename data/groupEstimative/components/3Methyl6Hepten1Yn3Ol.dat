/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-6-hepten-1-yn-3-ol  (C8H12O, CAS 51193-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl6Hepten1Yn3Ol;
formula     C8H12O;
CAS         51193-99-8;
InChIKey    PVJVUJJZSINIGV-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          642.16;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.6549;      // -   [origin=predictive method=lee-kesler]
Tb          458.39;      // K   [origin=predictive method=joback]
HvapTb      47973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.778 0.80972 -0.00063243 2.0149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylhept-6-en-1-yn-3-ol" "6-hepten-1-yn-3-ol,3-methyl-" );
standardThermochemistry
{
    dHf_298   47900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193410.0
}
