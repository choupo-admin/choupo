/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromocyclohexanone  (C6H9BrO, CAS 822-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromocyclohexanone;
formula     C6H9BrO;
CAS         822-85-5;
InChIKey    KDXYEWRAWRZXFT-UHFFFAOYSA-N;
MW          177.041;      // g/mol [origin=calculated method=formula-sum]
Tc          736.58;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.3977;      // -   [origin=predictive method=lee-kesler]
Tb          490.41;      // K   [origin=predictive method=joback]
HvapTb      40061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.55 0.5658 -0.000211 -9.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Br; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylcyclohexan-1-one" "2-bromo-cyclohexanone" "cyclohexanone, 2-bromo-" "2-bromo-1-cyclohexanone" "2-bromo-cyclohexan-1-one" "agn-pc-00g7cp" "cyclohexanone,2-bromo-, (?a'a a'a currency)-;(?a'a a'a currency)-2-bromo-1-cyclohexanone;2-bromo-1-cyclohexanone;2-bromocyclohexanone;a-bromocyclohexanone;a-monobromocyclohexanone;" );
gibbsFormation
{
    dHf_298   -224220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84180.0
    phase     gas;
}
