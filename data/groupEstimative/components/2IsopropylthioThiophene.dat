/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(isopropylthio)thiophene  (C7H10S2, CAS 50878-65-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IsopropylthioThiophene;
formula     C7H10S2;
CAS         50878-65-4;
InChIKey    INLCSHFGQRKEKW-UHFFFAOYSA-N;
MW          158.277;      // g/mol [origin=calculated method=formula-sum]
Tc          746.80;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.3603;      // -   [origin=predictive method=lee-kesler]
Tb          499.18;      // K   [origin=predictive method=joback]
HvapTb      45229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.3 0.67024 -0.00042902 1.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CHS; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-ylsulfanylthiophene" "thiophene, 2-[(1-methylethyl)thio]-" );
gibbsFormation
{
    dHf_298   78950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173150.0
    phase     gas;
}
