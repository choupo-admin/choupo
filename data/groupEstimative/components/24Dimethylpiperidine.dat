/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethylpiperidine  (C7H15N, CAS 6287-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethylpiperidine;
formula     C7H15N;
CAS         6287-19-0;
InChIKey    QOZOFODNIBQPGN-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          634.36;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.3118;      // -   [origin=predictive method=lee-kesler]
Tb          423.19;      // K   [origin=predictive method=joback]
HvapTb      38054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.22 0.75104 -0.000322 2.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethylpiperidin" "cis-2,4-dimethylpiperidine" "2,4-dimethyl-piperidine" "2,4-dimethyl piperidine" "piperidine, 2,4-dimethyl-" );
standardThermochemistry
{
    dHf_298   -116020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112510.0
}
