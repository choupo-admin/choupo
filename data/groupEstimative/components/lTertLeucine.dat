/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-tert-leucine  (C6H13NO2, CAS 20859-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lTertLeucine;
formula     C6H13NO2;
CAS         20859-02-3;
InChIKey    NPDBDJFLKKQMCM-SCSAIBSYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          767.33;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.7327;      // -   [origin=predictive method=lee-kesler]
Tb          551.25;      // K   [origin=predictive method=joback]
HvapTb      55071.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.63 0.81826 -0.0005936 1.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3,3-dimethyl-butanoic acid" "l-valine,3-methyl" "(2s)-2-amino-3,3-dimethylbutanoic acid" "3-methyl-l-valin" "(s)-2-amino-3,3-dimethylbutyric acid" "l-alpha-tert-butylglycine" "(s)-2-amino-3,3-dimethylbutanoic acid" "l-2-amino-3,3-dimethylbutanoic acid" "3-methyl-l-valine" "l-tert leucine" "t-leucine" "t-butyl glycine" );
standardThermochemistry
{
    dHf_298   -497680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277420.0
}
