/*--------------------------------*- Choupo -*-----------------------*\
  Component: normorphine  (C16H17NO3, CAS 466-97-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        normorphine;
formula     C16H17NO3;
CAS         466-97-7;
InChIKey    ONBWJWYUHXVEJS-UHFFFAOYSA-N;
MW          271.316;      // g/mol [origin=calculated method=formula-sum]
Tc          1116.58;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       1.4944;      // -   [origin=predictive method=lee-kesler]
Tb          872.31;      // K   [origin=predictive method=joback]
HvapTb      94255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-223.59 2.3111 -0.00230126 9.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH-O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,4a,7,7a,13-octahydro-4,12-methanobenzofuro[3,2-e]isoquinoline-7,9-diol" "demethylmorphine" "n-normorphine" "desmethylmorphine" "(-)-normorphine" "morphinan-3,6-diol, 7,8-didehydro-4,5-epoxy-, (5.alpha.,6.alpha.)-" "base normorphine" "4,6-dihydroxymorphin-7-ene" "morphinan-3, 7,8-didehydro-4,5.alpha.-epoxy-" "morphinan-3, 7,8-didehydro-4,5-epoxy-, (5.alpha.,6.alpha.)-" );
standardThermochemistry
{
    dHf_298   -239830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146900.0
}
