/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-chloroacetoacetate  (C5H7ClO3, CAS 4755-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Chloroacetoacetate;
formula     C5H7ClO3;
CAS         4755-81-1;
InChIKey    GYQRIAVRKLRQKP-UHFFFAOYSA-N;
MW          150.558;      // g/mol [origin=calculated method=formula-sum]
Tc          661.24;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.5571;      // -   [origin=predictive method=lee-kesler]
Tb          463.08;      // K   [origin=predictive method=joback]
HvapTb      44874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.32 0.40874 -0.0001585 -9.34e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3CO; count 1; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-chloranyl-3-oxidanylidene-butanoate" "methyl 2-chloro-3-oxobutanoate" "butanoic acid, 2-chloro-3-oxo-, methyl ester" "gyqriavrklrqkp-uhfffaoysa-" "2-chloroacetoacetic acid methyl ester" "2-chloro-3-oxo-butyric acid methyl ester" "butanoic acid,2-chloro-3-oxo-, methyl ester" );
gibbsFormation
{
    dHf_298   -597410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-462440.0
    phase     gas;
}
