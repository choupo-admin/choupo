/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl alpha,4-dihydroxyphenylacetate  (C9H10O4, CAS 68758-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylAlpha4Dihydroxyphenylacetate;
formula     C9H10O4;
CAS         68758-69-0;
InChIKey    DHPYYPJMQRYNLX-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          875.45;      // K   [origin=predictive method=joback]
Pc          44.623;      // bar [origin=predictive method=joback]
omega       1.2514;      // -   [origin=predictive method=lee-kesler]
Tb          662.78;      // K   [origin=predictive method=joback]
HvapTb      74616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.1 0.91962 -0.00069236 2.067e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(4-hydroxyphenyl)-2-oxidanyl-ethanoate" "methyl " "a,4-dihydroxyphenylacetate" "benzeneacetic acid, .alpha.,4-dihydroxy-, methyl ester" "methyl hydroxy(4-hydroxyphenyl)acetate" "methyl 2-hydroxy-2-(4-hydroxyphenyl)acetate" "benzeneacetic acid, alpha,4-dihydroxy-, methyl ester" );
gibbsFormation
{
    dHf_298   -644660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-466940.0
    phase     gas;
}
