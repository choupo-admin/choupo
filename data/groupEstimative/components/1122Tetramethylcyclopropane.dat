/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetramethylcyclopropane  (C7H14, CAS 4127-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122Tetramethylcyclopropane;
formula     C7H14;
CAS         4127-47-3;
InChIKey    JCHUCGKEGUAHEH-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          556.90;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.2142;      // -   [origin=predictive method=lee-kesler]
Tb          362.31;      // K   [origin=predictive method=joback]
HvapTb      28478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-147.76 1.37708 -0.001587 7.392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 1; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropane, 1,1,2,2-tetramethyl-" "jchucgkeguaheh-uhfffaoysa-" "1,1,2,2-tetramethyl cyclopropane" );
standardThermochemistry
{
    dHf_298   -104870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50120.0
}
