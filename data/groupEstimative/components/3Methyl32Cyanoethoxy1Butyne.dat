/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-3-(2-cyanoethoxy)-1-butyne  (C8H11NO, CAS 15496-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl32Cyanoethoxy1Butyne;
formula     C8H11NO;
CAS         15496-08-9;
InChIKey    BRMRUCOZUIVFCW-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          703.66;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.4702;      // -   [origin=predictive method=lee-kesler]
Tb          494.03;      // K   [origin=predictive method=joback]
HvapTb      44852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.422 0.66734 -0.00043713 1.1319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylbut-3-yn-2-yloxy)propanenitrile" "propanenitrile, 3-((1,1-dimethyl-2-propynyl)oxy)-" "propanenitrile, 3-[(1,1-dimethyl-2-propynyl)oxy]-" "propanenitrile, 3-((1,1-dimethyl-2-propyn-1-yl)oxy)-" "propanenitrile, 3-[(1,1-dimethyl-2-propyn-1-yl)oxy]-" "3-[(2-methylbut-3-yn-2-yl)oxy]propanenitrile" );
gibbsFormation
{
    dHf_298   107360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270570.0
    phase     gas;
}
