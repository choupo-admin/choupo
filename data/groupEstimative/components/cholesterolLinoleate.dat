/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesterol linoleate  (C45H76O2, CAS 604-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterolLinoleate;
formula     C45H76O2;
CAS         604-33-1;
InChIKey    NAACPBBQTFFYQB-XNTGVSEISA-N;
MW          649.101;      // g/mol [origin=calculated method=formula-sum]
Tc          1708.43;      // K   [origin=predictive method=joback]
Pc          4.421;      // bar [origin=predictive method=joback]
omega       -0.0364;      // -   [origin=predictive method=lee-kesler]
Tb          1333.78;      // K   [origin=predictive method=joback]
HvapTb      120548.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-330.995 5.22032 -0.00397164 1.2994e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 22; } { group CH; count 7; } { group C; count 2; } { group CH=CH; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 15; } { group CH; count 2; } { group dCH; count 4; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] octadeca-9,12-dienoate" );
gibbsFormation
{
    dHf_298   -789360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1634.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=341930.0
    phase     gas;
}
