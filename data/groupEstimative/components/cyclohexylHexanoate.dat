/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl hexanoate  (C12H22O2, CAS 6243-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylHexanoate;
formula     C12H22O2;
CAS         6243-10-3;
InChIKey    DTNOERNOMHQUCN-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          748.89;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       0.6084;      // -   [origin=predictive method=lee-kesler]
Tb          551.93;      // K   [origin=predictive method=joback]
HvapTb      50142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.216 1.21112 -0.0006154 8.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanoic acid, cyclohexyl ester" "cyclohexyl caproate" );
standardThermochemistry
{
    dHf_298   -553970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235760.0
}
