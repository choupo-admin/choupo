/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diacetyldiphenylmethane  (C17H16O2, CAS 790-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diacetyldiphenylmethane;
formula     C17H16O2;
CAS         790-82-9;
InChIKey    UTELZOWACOGDKG-UHFFFAOYSA-N;
MW          252.313;      // g/mol [origin=calculated method=formula-sum]
Tc          998.41;      // K   [origin=predictive method=joback]
Pc          22.849;      // bar [origin=predictive method=joback]
omega       0.8843;      // -   [origin=predictive method=lee-kesler]
Tb          759.62;      // K   [origin=predictive method=joback]
HvapTb      72804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.059 1.28604 -0.00079192 1.7422e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-[(4-ethanoylphenyl)methyl]phenyl]ethanone" "1-[4-(4-acetylbenzyl)phenyl]ethanone" "1-{4-[(4-acetylphenyl)methyl]phenyl}ethan-1-one" "1-[4-[(4-acetylphenyl)methyl]phenyl]ethanone" "1-{4-[(4-acetylphenyl)methyl]phenyl}ethanone" "bis(4-acetylphenyl)methane" "1-acetyl-4-[(4-acetylphenyl)methyl]benzene" );
gibbsFormation
{
    dHf_298   -169250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39980.0
    phase     gas;
}
