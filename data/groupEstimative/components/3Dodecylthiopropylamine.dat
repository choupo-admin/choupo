/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-dodecylthiopropylamine  (C15H33NS, CAS 29873-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Dodecylthiopropylamine;
formula     C15H33NS;
CAS         29873-33-4;
InChIKey    AJJBNKUPXKYSKX-UHFFFAOYSA-N;
MW          259.496;      // g/mol [origin=calculated method=formula-sum]
Tc          867.37;      // K   [origin=predictive method=joback]
Pc          14.977;      // bar [origin=predictive method=joback]
omega       0.9265;      // -   [origin=predictive method=lee-kesler]
Tb          684.11;      // K   [origin=predictive method=joback]
HvapTb      66442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.344 1.48511 -0.0007954 1.507e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2NH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-dodecylsulfanylpropan-1-amine" "1-propanamine, 3-(dodecylthio)-" "propylamine, 3-(dodecylthio)-" "3-(dodecylthio)propylamine" "1-propanamine,3-(dodecylthio)-" "3-(dodecylsulfanyl)propan-1-amine" );
standardThermochemistry
{
    dHf_298   -277270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     853.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174990.0
}
