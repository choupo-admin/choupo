/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2-tetrachloro-1,2-diethoxyethane  (C6H10Cl4O2, CAS 65087-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122Tetrachloro12Diethoxyethane;
formula     C6H10Cl4O2;
CAS         65087-21-0;
InChIKey    YANHWQPKPABZFO-UHFFFAOYSA-N;
MW          255.944;      // g/mol [origin=calculated method=formula-sum]
Tc          739.88;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.4899;      // -   [origin=predictive method=lee-kesler]
Tb          524.98;      // K   [origin=predictive method=joback]
HvapTb      48718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.052 0.72624 -0.0005058 1.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2O; count 2; } { group CCl2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 2; } { group Cl; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetrakis(chloranyl)-1,2-diethoxy-ethane" "1,2-diethoxy-1,1,2,2-tetrachloroethane" "ethane, 1,2-diethoxy-1,1,2,2-tetrachloro-" "1,2-diaethoxy-1,1,2,2-tetrachloraethan [german]" "1,2-diaethoxy-1,1,2,2-tetrachloraethan" );
standardThermochemistry
{
    dHf_298   -512070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252400.0
}
