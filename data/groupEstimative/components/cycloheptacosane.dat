/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptacosane  (C27H54, CAS 297-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptacosane;
formula     C27H54;
CAS         297-23-4;
InChIKey    WFTFLGIWIKFFDZ-UHFFFAOYSA-N;
MW          378.729;      // g/mol [origin=calculated method=formula-sum]
Tc          1206.83;      // K   [origin=predictive method=joback]
Pc          10.771;      // bar [origin=predictive method=joback]
omega       0.5088;      // -   [origin=predictive method=lee-kesler]
Tb          931.25;      // K   [origin=predictive method=joback]
HvapTb      80046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-200.74 2.5158 -0.000607 -2.8e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 27; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 27; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -655310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1637.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45480.0
    phase     gas;
}
