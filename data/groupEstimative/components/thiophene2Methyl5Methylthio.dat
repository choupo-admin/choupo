/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiophene,2-methyl-5-(methylthio)-  (C6H8S2, CAS 40990-29-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiophene2Methyl5Methylthio;
formula     C6H8S2;
CAS         40990-29-2;
InChIKey    VSUGUKXAAPOFPQ-UHFFFAOYSA-N;
MW          144.25;      // g/mol [origin=calculated method=formula-sum]
Tc          729.45;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.3435;      // -   [origin=predictive method=lee-kesler]
Tb          481.72;      // K   [origin=predictive method=joback]
HvapTb      44053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.59 0.50984 -0.00030438 6.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3S; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group S; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-methylsulfanyl-thiophene" "2-methyl-5-(methylsulfanyl)thiophene" "2-methyl-5-methylsulfanylthiophene" "thiophene, 2-methyl-5-(methylthiol)-" );
gibbsFormation
{
    dHf_298   93400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157540.0
    phase     gas;
}
