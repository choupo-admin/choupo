/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethyl-2-pentene  (C7H14, CAS 10574-37-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethyl2Pentene;
formula     C7H14;
CAS         10574-37-5;
InChIKey    WFHALSLYRWWUGH-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          543.21;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.2702;      // -   [origin=predictive method=lee-kesler]
Tb          363.68;      // K   [origin=predictive method=joback]
HvapTb      31294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.039 0.68868 -0.0004454 1.231e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylpent-2-ene" "ethyltrimethylethylene" "2-pentene, 2,3-dimethyl-" );
gibbsFormation
{
    dHf_298   -90170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71180.0
    phase     gas;
}
