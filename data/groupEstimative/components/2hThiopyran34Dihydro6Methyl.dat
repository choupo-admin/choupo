/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-thiopyran,3,4-dihydro-6-methyl-  (C6H10S, CAS 13042-79-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hThiopyran34Dihydro6Methyl;
formula     C6H10S;
CAS         13042-79-0;
InChIKey    KKEOQCCWQMQGHQ-UHFFFAOYSA-N;
MW          114.206;      // g/mol [origin=calculated method=formula-sum]
Tc          640.01;      // K   [origin=predictive method=joback]
Pc          42.111;      // bar [origin=predictive method=joback]
omega       0.2512;      // -   [origin=predictive method=lee-kesler]
Tb          413.07;      // K   [origin=predictive method=joback]
HvapTb      36454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.21 0.62133 -0.00037794 8.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-3,4-dihydro-2h-thiopyran" );
gibbsFormation
{
    dHf_298   -940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91990.0
    phase     gas;
}
