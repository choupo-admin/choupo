/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(dimethylamino)-2-methylpropane  (C8H20N2, CAS 68367-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BisDimethylamino2Methylpropane;
formula     C8H20N2;
CAS         68367-53-3;
InChIKey    IHOVNUMTDBCBAJ-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          575.73;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.4206;      // -   [origin=predictive method=lee-kesler]
Tb          404.29;      // K   [origin=predictive method=joback]
HvapTb      36192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.239 1.13752 -0.0008084 2.307e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n2,n2,2-pentamethylpropane-1,2-diamine" "n,n,n',n',2-pentamethyl-1,2-propanediamine" "1,2-propanediamine, n,n,n',n',2-pentamethyl-" "1,2-propanediamine, n1,n1,n2,n2,2-pentamethyl-" "n,n,n',n',2-pentamethylpropane-1,2-diamine" "[2-(dimethylamino)-2-methylpropyl]dimethylamine" "1,2-propanediamine,n1,n1,n2,n2,2-pentamethyl-" "1-n,1-n,2-n,2-n,2-pentamethylpropane-1,2-diamine" "1,2-propanediamine,n,n,n',n',2-pentamethyl- (9ci);" );
gibbsFormation
{
    dHf_298   -82140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=240880.0
    phase     gas;
}
