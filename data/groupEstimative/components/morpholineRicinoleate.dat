/*--------------------------------*- Choupo -*-----------------------*\
  Component: morpholine ricinoleate  (C22H43NO4, CAS 68134-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        morpholineRicinoleate;
formula     C22H43NO4;
CAS         68134-02-1;
InChIKey    GLMCOBSUGSPCHB-DPMBMXLASA-N;
MW          385.589;      // g/mol [origin=calculated method=formula-sum]
Tc          1281.95;      // K   [origin=predictive method=joback]
Pc          11.704;      // bar [origin=predictive method=joback]
omega       1.0925;      // -   [origin=predictive method=lee-kesler]
Tb          1045.49;      // K   [origin=predictive method=joback]
HvapTb      110279.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.567 2.13052 -0.0010101 1.143e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group Morpholine; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 4; } { group OH; count 1; } { group O_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholine;(z,12r)-12-oxidanyloctadec-9-enoic acid" "9-octadecenoic acid, 12-hydroxy-, (9z,12r)-, compd. with morpholine (1:1)" "(z,12r)-12-hydroxyoctadec-9-enoic acid; morpholine" "(r)-12-hydroxyoleic acid, compound with morpholine (1:1)" );
standardThermochemistry
{
    dHf_298   -1019120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1162.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-339600.0
}
