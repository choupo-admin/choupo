/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl lauryl ether  (C14H28O, CAS 765-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylLaurylEther;
formula     C14H28O;
CAS         765-14-0;
InChIKey    LAYAKLSFVAPMEL-UHFFFAOYSA-N;
MW          212.377;      // g/mol [origin=calculated method=formula-sum]
Tc          701.28;      // K   [origin=predictive method=joback]
Pc          15.537;      // bar [origin=predictive method=joback]
omega       0.7220;      // -   [origin=predictive method=lee-kesler]
Tb          539.02;      // K   [origin=predictive method=joback]
HvapTb      48498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.671 1.25062 -0.0006497 1.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenoxydodecane" "dodecyl vinyl ether" "lauryl vinyl ether" "dodecane, 1-(ethenyloxy)-" "1-(vinyloxy)dodecane" "1-(ethenyloxy)dodecane" "dodecane,1-(ethenyloxy)-" "r835" "ether,dodecyl vinyl (6ci,7ci,8ci); dodecyl vinyl ether; lauryl vinyl ether; rapi-cureddve" );
standardThermochemistry
{
    dHf_298   -339080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49840.0
}
