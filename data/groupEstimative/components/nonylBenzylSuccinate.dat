/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonyl benzyl succinate  (C20H30O4, CAS 119450-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonylBenzylSuccinate;
formula     C20H30O4;
CAS         119450-17-8;
InChIKey    LZXXTGLTBYLDBX-UHFFFAOYSA-N;
MW          334.456;      // g/mol [origin=calculated method=formula-sum]
Tc          994.28;      // K   [origin=predictive method=joback]
Pc          12.782;      // bar [origin=predictive method=joback]
omega       1.0153;      // -   [origin=predictive method=lee-kesler]
Tb          800.32;      // K   [origin=predictive method=joback]
HvapTb      77204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.621 1.71532 -0.0009062 1.381e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-nonyl o4-(phenylmethyl) butanedioate" "1-benzyl 4-nonyl succinate" "butanedioic acid, nonyl phenylmethyl ester" "4-o-benzyl 1-o-nonyl butanedioate" );
standardThermochemistry
{
    dHf_298   -854160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     931.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-390810.0
}
