/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-diaminobenzidine  (C12H14N4, CAS 91-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Diaminobenzidine;
formula     C12H14N4;
CAS         91-95-2;
InChIKey    HSTOKWSFWGCZMH-UHFFFAOYSA-N;
MW          214.272;      // g/mol [origin=calculated method=formula-sum]
Tc          1110.59;      // K   [origin=predictive method=joback]
Pc          42.166;      // bar [origin=predictive method=joback]
omega       1.1788;      // -   [origin=predictive method=lee-kesler]
Tb          837.56;      // K   [origin=predictive method=joback]
HvapTb      92070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.33 0.9956 -0.00059684 1.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACNH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 6; } { group NH2; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[3,4-bis(azanyl)phenyl]benzene-1,2-diamine" "3,3',4,4'-tetraaminobiphenyl" "3,3',4,4'-tetraaminodiphenyl" "3,3'-diaminobenzidene" "[1,1'-biphenyl]-3,3',4,4'-tetramine" "4-(3,4-diaminophenyl)benzene-1,2-diamine" "3,3',4,4'-diphenyltetramine" "3,3',4,4'-tetraminobiphenyl" "3,3'4,4'-biphenyltetramine" "biphenyl-3,3',4,4'-tetrayltetraamine" "(1,1'-biphenyl)-3,3',4,4'-tetramine" "3,3',4,4'-biphenyltetramine" );
gibbsFormation
{
    dHf_298   271330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=502260.0
    phase     gas;
}
