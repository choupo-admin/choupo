/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylnonane  (C11H24, CAS 17302-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylnonane;
formula     C11H24;
CAS         17302-14-6;
InChIKey    WDSBVMLUILIJOW-UHFFFAOYSA-N;
MW          156.313;      // g/mol [origin=calculated method=formula-sum]
Tc          619.56;      // K   [origin=predictive method=joback]
Pc          19.666;      // bar [origin=predictive method=joback]
omega       0.4495;      // -   [origin=predictive method=lee-kesler]
Tb          448.05;      // K   [origin=predictive method=joback]
HvapTb      38784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.584 1.17468 -0.0007464 1.916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane, trimethyl-" "2,2-dimethyl-nonane" "3-hydroxy-1-phenoxy-6,7-dihydro-5h-cyclopenta[c]pyridine-4-carbonitrile" );
standardThermochemistry
{
    dHf_298   -279120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=44580.0
}
