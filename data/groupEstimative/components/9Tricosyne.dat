/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-tricosyne  (C23H44, CAS 39487-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Tricosyne;
formula     C23H44;
CAS         39487-08-6;
InChIKey    LFCOTQSSVSUPCL-UHFFFAOYSA-N;
MW          320.605;      // g/mol [origin=calculated method=formula-sum]
Tc          908.91;      // K   [origin=predictive method=joback]
Pc          9.375;      // bar [origin=predictive method=joback]
omega       0.7999;      // -   [origin=predictive method=lee-kesler]
Tb          734.84;      // K   [origin=predictive method=joback]
HvapTb      68944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.461 2.03904 -0.00113526 2.4148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricos-9-yne" );
gibbsFormation
{
    dHf_298   -245750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1023.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=345580.0
    phase     gas;
}
