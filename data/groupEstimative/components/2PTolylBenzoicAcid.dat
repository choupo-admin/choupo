/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(p-tolyl)benzoic acid  (C14H12O2, CAS 7148-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PTolylBenzoicAcid;
formula     C14H12O2;
CAS         7148-03-0;
InChIKey    ZSTUEICKYWFYIC-UHFFFAOYSA-N;
MW          212.248;      // g/mol [origin=calculated method=formula-sum]
Tc          977.16;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.8716;      // -   [origin=predictive method=lee-kesler]
Tb          728.75;      // K   [origin=predictive method=joback]
HvapTb      69798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.45 1.10782 -0.00073872 1.846e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH3; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylphenyl)benzoic acid" "4'-methylbiphenyl-2-carboxylic acid" "4'-methyl-2-biphenylcarboxylic acid" "4'-methyl-[1,1'-biphenyl]-2-carboxylic acid" "[1,1'-biphenyl]-2-carboxylic acid, 4'-methyl-" "benzoic acid, 2-(4-methylphenyl)-" "2-biphenyl-4'-methyl-carboxylic acid" "4'-methyl-biphenyl-2-carboxylic acid" "biphenyl-2-carboxylic acid, 4'-methyl-" "4'-methyl(1,1'-biphenyl)-2-carboxylic acid" "4'-methyl[1,1'-biphenyl]-2-carboxylic acid" "4'-methyl-2-bipenylcarboxylic acid" );
gibbsFormation
{
    dHf_298   -232440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71350.0
    phase     gas;
}
