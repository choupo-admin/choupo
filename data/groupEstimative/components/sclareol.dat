/*--------------------------------*- Choupo -*-----------------------*\
  Component: sclareol  (C20H36O2, CAS 515-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sclareol;
formula     C20H36O2;
CAS         515-03-7;
InChIKey    XVULBTBTFGYVRC-FFADBYAMSA-N;
MW          308.506;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.57;      // K   [origin=predictive method=joback]
Pc          16.038;      // bar [origin=predictive method=joback]
omega       1.2080;      // -   [origin=predictive method=lee-kesler]
Tb          852.28;      // K   [origin=predictive method=joback]
HvapTb      87640.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-285.298 3.1373 -0.0030061 1.2241e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 2; } { group C; count 4; } { group CH2=CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 3; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2r,8as)-2,5,5,8a-tetramethyl-1-[(3r)-3-methyl-3-oxidanyl-pent-4-enyl]-3,4,4a,6,7,8-hexahydro-1h-naphthalen-2-ol" "sclareol (natural)" "(1r,2r,8as)-1-[(3r)-3-hydroxy-3-methylpent-4-en-1-yl]-2,5,5,8a-tetramethyldecahydronaphthalen-2-ol" "(13r)-labd-14-ene-8,13-diol" "(1r-(1alpha(r*),2beta,4abeta,8aalpha))-2-hydroxy-alpha,2,5,5,8a-pentamethyl-alpha-vinyldecahydronaphthalene-1-propan-1-ol" "1-naphthalenepropanol, alpha-ethenyldecahydro-2-hydroxy-alpha,2,5,5,8a-pentamethyl-, (1theta-(1alpha(theta),2beta,4abeta,8aalpha))-" "1-naphthalenepropanol, alpha-ethenyldecahydro-2-hydroxy-alpha,2,5,5,8a-pentamethyl-, (alphar,1r,2r,4as,8as)-" "1-naphthalenepropanol, decahydro-alpha-ethenyl-2-hydroxy-alpha,2,5,5,8a-pentamethyl-, (1r-(1-alpha(r*),2-beta,4a-beta,8a-alpha))-" "labd-14-ene-8,13-diol, (13r)-" "sclareol (6ci)" "labd-14-ene-8,13-diol, (13r)- (8ci)" "(1r,2r,8as)-1-[(3r)-3-hydroxy-3-methylpent-4-enyl]-2,5,5,8a-tetramethyl-3,4,4a,6,7,8-hexahydro-1h-naphthalen-2-ol" );
gibbsFormation
{
    dHf_298   -538250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     974.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31940.0
    phase     gas;
}
