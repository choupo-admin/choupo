/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dimethylamino-2,2'-bipyridine  (C14H18N4, CAS 85698-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethylamino22Bipyridine;
formula     C14H18N4;
CAS         85698-56-2;
InChIKey    IHULFFMBCBEJPL-UHFFFAOYSA-N;
MW          242.326;      // g/mol [origin=calculated method=formula-sum]
Tc          961.08;      // K   [origin=predictive method=joback]
Pc          26.791;      // bar [origin=predictive method=joback]
omega       0.8034;      // -   [origin=predictive method=lee-kesler]
Tb          715.52;      // K   [origin=predictive method=joback]
HvapTb      69140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.31 1.3724 -0.00090984 2.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH3N; count 2; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group N; count 2; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(dimethylamino)pyridin-2-yl]-n,n-dimethyl-pyridin-4-amine" "n,n,n',n'-tetramethyl-2,2'-bipyridine-4,4'-diamine" "2-[4-(dimethylamino)pyridin-2-yl]-n,n-dimethylpyridin-4-amine" );
gibbsFormation
{
    dHf_298   318470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=648220.0
    phase     gas;
}
