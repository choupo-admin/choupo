/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-2-naphthylamine  (C11H11NO, CAS 3178-03-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy2Naphthylamine;
formula     C11H11NO;
CAS         3178-03-8;
InChIKey    DZCCNHQOMASNEB-UHFFFAOYSA-N;
MW          173.215;      // g/mol [origin=calculated method=formula-sum]
Tc          843.13;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.6532;      // -   [origin=predictive method=lee-kesler]
Tb          601.85;      // K   [origin=predictive method=joback]
HvapTb      58371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.87 0.84592 -0.00054084 1.327e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group CH3O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxynaphthalen-2-amine" "2-amino-1-methoxynaphthalene" "2-naphthylamine, 1-methoxy-" );
standardThermochemistry
{
    dHf_298   35860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202990.0
}
