/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin 153  (C16H14F3NO2, CAS 53518-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin153;
formula     C16H14F3NO2;
CAS         53518-18-6;
InChIKey    VSSSHNJONFTXHS-UHFFFAOYSA-N;
MW          309.287;      // g/mol [origin=calculated method=formula-sum]
Tc          923.64;      // K   [origin=predictive method=joback]
Pc          22.440;      // bar [origin=predictive method=joback]
omega       0.9855;      // -   [origin=predictive method=lee-kesler]
Tb          711.62;      // K   [origin=predictive method=joback]
HvapTb      63285.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.19 1.8635 -0.00164208 5.658e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group ACH; count 1; } { group AC; count 3; } { group ACCH2; count 2; } { group CH2N; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 6; } { group F; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "coumarin 540a" "c 6f" "1h,5h,11h-[1]benzopyrano[6,7,8-ij]quinolizin-11-one, 2,3,6,7-tetrahydro-9-(trifluoromethyl)-" "9-(trifluoromethyl)-2,3,6,7-tetrahydro-1h,5h,11h-pyrano[2,3-f]pyrido[3,2,1-ij]quinolin-11-one" "2,3,6,7-tetrahydro-9-trifluoromethyl-1h,5h-quinolizino(9,1-gh)coumarin" "2,3,6,7-tetrahydro-9-(trifluoromethyl)-1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizin-11-one" "2,3,6,7-tetrahydro-9-(trifluoromethyl)-1h,5h,11h-[1]benzopyrano(6,7,8-ij)quinolizin-11-one" "8-trifluoromethyl-2,3,5,6-4h-1,h-11-oxa-3a-aza-benzo(de)anthracen-10-one" "8-trifluoromethyl-2,3,5,6-4h-1,h-11-oxa-3a-aza-benzo[de]anthracen-10-one" "1h,5h,11h-(1)benzopyrano(6,7,8-ij)quinolizin-11-one, 2,3,6,7-tetrahydro-9-(trifluoromethyl)-" "8-trifluoromethyl-2,3,5,6-tetrahydro-1h,4h-11-oxa-3a-aza-benzo[de]anthracen-10-one" "1h,11h-[1]benzopyrano[6,7,8-ij]quinolizin-11-one, 2,3,6,7-tetrahydro-9-(trifluoromethyl)-" );
gibbsFormation
{
    dHf_298   -697860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-385640.0
    phase     gas;
}
