/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3-tetraphenyl-1,3-disiloxanediol  (C24H22O3Si2, CAS 1104-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H22O3Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1133Tetraphenyl13Disiloxanediol;
formula     C24H22O3Si2;
CAS         1104-93-4;
InChIKey    MYZTUAOLAYIKSJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          414.607;      // g/mol [origin=calculated method=formula-sum]
Tc          1318.86;      // K   [origin=predictive method=joback]
Pc          19.389;      // bar [origin=predictive method=joback]
omega       1.4070;      // -   [origin=predictive method=lee-kesler]
Tb          1065.02;      // K   [origin=predictive method=joback]
HvapTb      114478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.83 1.5606 -0.0005268 -9.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 20; } { group AC; count 4; } { group OH; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 20; } { group dC_ring; count 4; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxidanyl-[oxidanyl(diphenyl)silyl]oxy-diphenyl-silane" "1,1,3,3-tetraphenyldisiloxane-1,3-diol" "1,3-dihydroxy-1,1,3,3-tetraphenyldisiloxane" "hydroxy-[hydroxy(diphenyl)silyl]oxy-diphenylsilane" );
gibbsFormation
{
    dHf_298   -252490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1031.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12680.0
    phase     gas;
}
