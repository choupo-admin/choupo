/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7-dioxaspiro[5.5]undecane  (C9H16O2, CAS 180-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Dioxaspiro55Undecane;
formula     C9H16O2;
CAS         180-84-7;
InChIKey    GBBVHDGKDQAEOT-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          741.26;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       0.3756;      // -   [origin=predictive method=lee-kesler]
Tb          499.16;      // K   [origin=predictive method=joback]
HvapTb      44492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.67 1.425 -0.0012344 4.538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "olive-fly ketal" "1,7-dioxaspiro(5.5)undecane" "olean" "eco-trap" "1,7-dioxaspiro[5.5]undecan" "5,11-dioxaspiro[5.5]undecane" "(r)-1,7-dioxaspiro[5.5]undecane" "(s)-1,7-dioxaspiro[5.5]undecane" );
standardThermochemistry
{
    dHf_298   -342710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84120.0
}
