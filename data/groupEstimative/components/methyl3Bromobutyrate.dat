/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-bromobutyrate  (C5H9BrO2, CAS 21249-59-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Bromobutyrate;
formula     C5H9BrO2;
CAS         21249-59-2;
InChIKey    WJYBMWHJTZBYSO-UHFFFAOYSA-N;
MW          181.029;      // g/mol [origin=calculated method=formula-sum]
Tc          635.68;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.4927;      // -   [origin=predictive method=lee-kesler]
Tb          437.94;      // K   [origin=predictive method=joback]
HvapTb      40178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.261 0.46814 -0.0002282 2.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-bromanylbutanoate" "methyl 3-bromobutanoate" "3-bromobutyric acid methyl ester" "butanoic acid, 3-bromo-, methyl ester" "butanoic acid,3-bromo-, methyl ester" "butyric acid, 3-bromo-, methyl ester" "butyricacid, 3-bromo-, methyl ester (8ci);methyl 3-bromobutanoate;methyl3-bromobutyrate;" );
standardThermochemistry
{
    dHf_298   -442760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307270.0
}
