/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-3,5-dichlorobenzamide  (C7H6Cl2N2O, CAS 36765-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino35Dichlorobenzamide;
formula     C7H6Cl2N2O;
CAS         36765-01-2;
InChIKey    PRKRQUUATBDWTL-UHFFFAOYSA-N;
MW          205.038;      // g/mol [origin=calculated method=formula-sum]
Tc          929.95;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       0.8831;      // -   [origin=predictive method=lee-kesler]
Tb          675.17;      // K   [origin=predictive method=joback]
HvapTb      72236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.64 0.5208 -0.00029598 5.386e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3,5-bis(chloranyl)benzamide" "benzamide,2-amino-5-chloro-" "benzamide, 2-amino-3,5-dichloro-" );
standardThermochemistry
{
    dHf_298   -62170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71700.0
}
