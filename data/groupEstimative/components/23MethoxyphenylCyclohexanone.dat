/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3-methoxyphenyl)cyclohexanone  (C13H16O2, CAS 15547-89-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23MethoxyphenylCyclohexanone;
formula     C13H16O2;
CAS         15547-89-4;
InChIKey    KACQSVYTBQDRGP-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          885.62;      // K   [origin=predictive method=joback]
Pc          26.930;      // bar [origin=predictive method=joback]
omega       0.5869;      // -   [origin=predictive method=lee-kesler]
Tb          638.49;      // K   [origin=predictive method=joback]
HvapTb      54556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.21 0.99102 -0.00037356 -1.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methoxyphenyl)cyclohexan-1-one" "cyclohexanone, 2-(3-methoxyphenyl)-" "cyclohexanone,2-(3-methoxyphenyl)-" "2-(3-methoxyphenyl)-cyclohexan-1-one" );
gibbsFormation
{
    dHf_298   -302190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41780.0
    phase     gas;
}
