/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3h-1,4,6-ethanylylidene-2h-1,2a-diazacyclopenta(cd)pentalene, hexahydro-  (C10H14N2, CAS 103021-44-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3h146Ethanylylidene2h12aDiazacyclopentaCdPentaleneHexahydro;
formula     C10H14N2;
CAS         103021-44-9;
InChIKey    HJLXOOJJCPEXAL-UHFFFAOYSA-N;
MW          162.236;      // g/mol [origin=calculated method=formula-sum]
Tc          654.54;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.5721;      // -   [origin=predictive method=lee-kesler]
Tb          460.96;      // K   [origin=predictive method=joback]
HvapTb      40336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-247.25 1.9776 -0.002023 8.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 6; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 6; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3h-1,4,6-ethanylylidene-2h-1,2a-diazacyclopenta[cd]pentalene, hexahydro-" );
gibbsFormation
{
    dHf_298   259790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -15.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=611420.0
    phase     gas;
}
