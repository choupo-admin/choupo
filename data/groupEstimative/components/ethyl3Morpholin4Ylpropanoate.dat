/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-morpholin-4-ylpropanoate  (C9H17NO3, CAS 20120-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Morpholin4Ylpropanoate;
formula     C9H17NO3;
CAS         20120-24-5;
InChIKey    WRBIQTVRBWJCQT-UHFFFAOYSA-N;
MW          187.239;      // g/mol [origin=calculated method=formula-sum]
Tc          717.87;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.6821;      // -   [origin=predictive method=lee-kesler]
Tb          523.08;      // K   [origin=predictive method=joback]
HvapTb      50154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.677 1.08312 -0.0006527 1.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2COO; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-morpholinepropionate" "ethyl 3-(morpholino)propionate" "ethyl 3-(4-morpholino)propionate" "4-[2-(ethoxycarbonyl)ethyl]morpholine" "3-(morpholino)propionic acid ethyl ester" "3-morpholin-4-yl-propanoic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -530020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216550.0
    phase     gas;
}
