/*--------------------------------*- Choupo -*-----------------------*\
  Component: neophyl chloride  (C10H13Cl, CAS 515-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neophylChloride;
formula     C10H13Cl;
CAS         515-40-2;
InChIKey    DNXXUUPUQXSUFH-UHFFFAOYSA-N;
MW          168.664;      // g/mol [origin=calculated method=formula-sum]
Tc          714.16;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.3507;      // -   [origin=predictive method=lee-kesler]
Tb          489.28;      // K   [origin=predictive method=joback]
HvapTb      43219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.689 1.00754 -0.0007436 2.142e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-chloranyl-2-methyl-propan-2-yl)benzene" "1-chloro-2-methyl-2-phenylpropane" "(1-chloro-2-methylpropan-2-yl)benzene" "2-methyl-2-phenylpropyl chloride" "(2-chloro-1,1-dimethylethyl)benzene" "beta-chloro-tert-butylbenzene" "benzene, (2-chloro-1,1-dimethylethyl)-" "2-chloromethyl-2-phenylpropane" ".beta.-chloro-tert-butylbenzene" "(.beta.-chloro-tert-butyl)benzene" ".beta.,.beta.-dimethylphenethyl chloride" "(.beta.-chloro-.alpha.,.alpha.-dimethyl)ethylbenzene" );
standardThermochemistry
{
    dHf_298   -37690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136640.0
}
