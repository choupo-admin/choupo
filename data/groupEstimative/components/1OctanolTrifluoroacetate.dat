/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octanol, trifluoroacetate  (C10H17F3O2, CAS 2561-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1OctanolTrifluoroacetate;
formula     C10H17F3O2;
CAS         2561-21-9;
InChIKey    MGRWEFWRZHQSRH-UHFFFAOYSA-N;
MW          226.238;      // g/mol [origin=calculated method=formula-sum]
Tc          637.10;      // K   [origin=predictive method=joback]
Pc          19.086;      // bar [origin=predictive method=joback]
omega       0.7151;      // -   [origin=predictive method=lee-kesler]
Tb          481.20;      // K   [origin=predictive method=joback]
HvapTb      41514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.007 1.06022 -0.0006466 1.394e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group C; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl 2,2,2-tris(fluoranyl)ethanoate" "acetic acid, trifluoro-, octyl ester" "octyl 2,2,2-trifluoroacetate" );
standardThermochemistry
{
    dHf_298   -1164090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-858640.0
}
