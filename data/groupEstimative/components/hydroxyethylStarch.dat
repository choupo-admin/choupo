/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxyethyl starch  (C22H44O17, CAS 9005-27-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxyethylStarch;
formula     C22H44O17;
CAS         9005-27-0;
InChIKey    DNZMDASEFMLYBU-RNBXVSKKSA-N;
MW          580.577;      // g/mol [origin=calculated method=formula-sum]
Tc          5760.25;      // K   [origin=predictive method=joback]
Pc          16.592;      // bar [origin=predictive method=joback]
omega       -0.4818;      // -   [origin=predictive method=lee-kesler]
Tb          1793.90;      // K   [origin=predictive method=joback]
HvapTb      251106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (155.062 1.9378 -0.0001982 -3.664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 8; } { group OH; count 5; } { group CH-O; count 2; } { group C2H5O2; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group CH_ring; count 10; } { group OH; count 10; } { group O; count 5; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3r,4s,5s,6r)-6-(hydroxymethyl)oxane-2,3,4,5-tetrol;2-[[(2r,3r,4s,5r,6s)-3,4,5,6-tetrakis(2-hydroxyethyloxy)oxan-2-yl]methoxy]ethanol" "2-hydroxyethyl starch" "hydroxyethylated amylopectin" "hydroxyethyl starch 200/0.5" "hydroxyethyl starch 130/0.4" "h695" );
standardThermochemistry
{
    dHf_298   -3110510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1183.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2048620.0
}
