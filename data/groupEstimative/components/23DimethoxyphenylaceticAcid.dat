/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethoxyphenylacetic acid  (C10H12O4, CAS 90-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DimethoxyphenylaceticAcid;
formula     C10H12O4;
CAS         90-53-9;
InChIKey    UZULEJNWMHZSGY-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          871.90;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.9488;      // -   [origin=predictive method=lee-kesler]
Tb          655.39;      // K   [origin=predictive method=joback]
HvapTb      63438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.091 0.68034 -0.00026792 1.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,3-dimethoxyphenyl)ethanoic acid" "o-homoveratric acid" "(2,3-dimethoxyphenyl)acetic acid" "2,3-dimethoxy phenyl acetic acid" "2-(2,3-dimethoxyphenyl)acetic acid" "acetic acid, (2,3-dimethoxyphenyl)-" "benzeneacetic acid,3-dimethoxy-" "acetic acid,3-dimethoxyphenyl)-" );
standardThermochemistry
{
    dHf_298   -650850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-427440.0
}
