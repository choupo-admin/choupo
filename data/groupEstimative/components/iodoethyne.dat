/*--------------------------------*- Choupo -*-----------------------*\
  Component: iodoethyne  (C2HI, CAS 14545-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iodoethyne;
formula     C2HI;
CAS         14545-08-5;
InChIKey    JCIVIRQSXLTMEF-UHFFFAOYSA-N;
MW          151.93;      // g/mol [origin=calculated method=formula-sum]
Tc          552.33;      // K   [origin=predictive method=joback]
Pc          60.655;      // bar [origin=predictive method=joback]
omega       0.1095;      // -   [origin=predictive method=lee-kesler]
Tb          328.62;      // K   [origin=predictive method=joback]
HvapTb      29277.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.54 0.1389 -0.00016233 7.089e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanylethyne" "ethyne, iodo-" "iodoacetylene" "ethyne, iodo- (9ci)" "jcivirqsxltmef-uhfffaoysa-" "acetylene,iodo- (6ci,7ci,8ci); ethynyl iodide; iodoacetylene; iodoethyne;monoiodoacetylene" );
standardThermochemistry
{
    dHf_298   284160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     259.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247150.0
}
