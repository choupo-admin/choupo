/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-(2,2-dimethyl-1-methylenepropyl)-3-(trifluoromethyl)-  (C13H15F3, CAS 146558-45-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene122Dimethyl1Methylenepropyl3Trifluoromethyl;
formula     C13H15F3;
CAS         146558-45-4;
InChIKey    HSVJYQINDWDIPW-UHFFFAOYSA-N;
MW          228.257;      // g/mol [origin=calculated method=formula-sum]
Tc          716.26;      // K   [origin=predictive method=joback]
Pc          20.661;      // bar [origin=predictive method=joback]
omega       0.4593;      // -   [origin=predictive method=lee-kesler]
Tb          516.61;      // K   [origin=predictive method=joback]
HvapTb      41837.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.89 1.36736 -0.00106556 3.239e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,3-dimethylbut-1-en-2-yl)-3-(trifluoromethyl)benzene" "benzene,1-(2,2-dimethyl-1-methylenepropyl)-3-(trifluoromethyl)-" );
gibbsFormation
{
    dHf_298   -576780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-338100.0
    phase     gas;
}
