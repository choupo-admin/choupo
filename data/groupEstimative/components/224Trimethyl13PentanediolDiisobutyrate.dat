/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-1,3-pentanediol diisobutyrate  (C16H30O4, CAS 6846-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl13PentanediolDiisobutyrate;
formula     C16H30O4;
CAS         6846-50-0;
InChIKey    OMVSWZDEEGIJJI-UHFFFAOYSA-N;
MW          286.412;      // g/mol [origin=calculated method=formula-sum]
Tc          864.16;      // K   [origin=predictive method=joback]
Pc          13.789;      // bar [origin=predictive method=joback]
omega       0.8038;      // -   [origin=predictive method=lee-kesler]
Tb          677.13;      // K   [origin=predictive method=joback]
HvapTb      63176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.961 1.56376 -0.000842 1.349e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 1; } { group CH; count 4; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 1; } { group CH; count 4; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2,4-trimethyl-3-(2-methylpropanoyloxy)pentyl] 2-methylpropanoate" "kodaflex txib" "txib" "propanoic acid, 2-methyl-, 2,2-dimethyl-1-(1-methylethyl)-1,3-propanediyl ester" "2,2,4-trimethylpentane-1,3-diyl bis(2-methylpropanoate)" "2,2,4-trimethyl-1,3-pentanediol ester" "2,2,4-trimethylpentanediol-1,3-diisobutyrate" "1-isopropyl-2,2-dimethyltrimethylene diisobutyrate" "1,3-pentanediol, 2,2,4-trimethyl-, diisobutyrate (ester)" "isobutyric acid, 1-isopropyl-2,2-dimethyltrimethylene ester" "propanoic acid, 2-methyl-, 1,1'-(2,2-dimethyl-1-(1-methylethyl)-1,3-propanediyl) ester" "propanoic acid, 2-methyl-, 1,1'-[2,2-dimethyl-1-(1-methylethyl)-1,3-propanediyl] ester" );
gibbsFormation
{
    dHf_298   -1038000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     804.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-543820.0
    phase     gas;
}
