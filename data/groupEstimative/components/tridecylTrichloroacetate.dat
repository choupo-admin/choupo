/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecyl trichloroacetate  (C15H27Cl3O2, CAS 74339-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecylTrichloroacetate;
formula     C15H27Cl3O2;
CAS         74339-51-8;
InChIKey    IVESCNMAOKRZNG-UHFFFAOYSA-N;
MW          345.729;      // g/mol [origin=calculated method=formula-sum]
Tc          895.79;      // K   [origin=predictive method=joback]
Pc          13.271;      // bar [origin=predictive method=joback]
omega       0.8844;      // -   [origin=predictive method=lee-kesler]
Tb          710.08;      // K   [origin=predictive method=joback]
HvapTb      68250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.862 1.52022 -0.0009306 2.091e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group C; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tridecyl 2,2,2-tris(chloranyl)ethanoate" "trichloroacetic acid, tridecyl ester" "tridecyl 2,2,2-trichloroacetate" );
standardThermochemistry
{
    dHf_298   -726180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     852.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267900.0
}
