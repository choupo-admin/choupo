/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbitol phthalate  (C20H30O8, CAS 117-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbitolPhthalate;
formula     C20H30O8;
CAS         117-85-1;
InChIKey    BWTZODIETZQWSD-UHFFFAOYSA-N;
MW          398.452;      // g/mol [origin=calculated method=formula-sum]
Tc          1097.91;      // K   [origin=predictive method=joback]
Pc          12.056;      // bar [origin=predictive method=joback]
omega       1.1134;      // -   [origin=predictive method=lee-kesler]
Tb          894.98;      // K   [origin=predictive method=joback]
HvapTb      87506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (117.92 1.40304 -0.00039516 -1.06e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2-(2-ethoxyethoxy)ethyl] benzene-1,2-dicarboxylate" "bis[2-(2-ethoxyethoxy)ethyl] phthalate" "bis(2-(2-ethoxyethoxy)ethyl) phthalate" "1,2-benzenedicarboxylic acid, bis(ethoxyethoxyethyl) ester" "bis[2-(ethoxyethoxy)ethyl] phthalate" "di(ethyleneglycol) ethyl ether phthalate" "1, bis[2-(2-ethoxyethoxy)ethyl] ester" "bis(diethyleneglycol) monoethyl ether phthalate" "phthalic acid, bis[2-(2-ethoxyethoxy)ethyl] ester" "1,2-benzenedicarboxylic acid, bis(2-(2-ethoxyethoxy)ethyl) ester" "1,2-benzenedicarboxylicacid, 1,2-bis[2-(2-ethoxyethoxy)ethyl] ester" );
standardThermochemistry
{
    dHf_298   -1394510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     970.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-820440.0
}
