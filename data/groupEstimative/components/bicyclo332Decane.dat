/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[3.3.2]decane  (C10H18, CAS 283-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo332Decane;
formula     C10H18;
CAS         283-50-1;
InChIKey    WMRPOCDOMSNXCQ-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          681.10;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.3000;      // -   [origin=predictive method=lee-kesler]
Tb          458.96;      // K   [origin=predictive method=joback]
HvapTb      38368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.17 1.2172 -0.000775 1.868e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-00krj0" );
standardThermochemistry
{
    dHf_298   -128770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=106420.0
}
