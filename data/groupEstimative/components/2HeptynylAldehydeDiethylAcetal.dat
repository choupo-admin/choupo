/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-heptynyl aldehyde diethyl acetal  (C11H20O2, CAS 18232-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HeptynylAldehydeDiethylAcetal;
formula     C11H20O2;
CAS         18232-30-9;
InChIKey    NKXTVBJJMIROGV-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          689.72;      // K   [origin=predictive method=joback]
Pc          21.836;      // bar [origin=predictive method=joback]
omega       0.5722;      // -   [origin=predictive method=lee-kesler]
Tb          504.68;      // K   [origin=predictive method=joback]
HvapTb      46664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.765 0.77856 -0.00026366 -1.142e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH2O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group tC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxyhept-2-yne" "2-heptyn-1-al diethyl acetal" "2-heptyn-1-al-diethyl acetal" );
gibbsFormation
{
    dHf_298   -267790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32100.0
    phase     gas;
}
