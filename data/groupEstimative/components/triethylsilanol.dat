/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethylsilanol  (C6H16OSi, CAS 597-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triethylsilanol;
formula     C6H16OSi;
CAS         597-52-4;
InChIKey    WVMSIBFANXCZKT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          132.278;      // g/mol [origin=calculated method=formula-sum]
Tc          596.97;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.6430;      // -   [origin=predictive method=lee-kesler]
Tb          430.46;      // K   [origin=predictive method=joback]
HvapTb      45923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.543 0.40166 8.18e-05 -1.472e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group OH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethyl(oxidanyl)silane" "silanol, triethyl-" "hydroxytriethylsilane" "triethyl(hydroxy)silane" "silanol, 1,1,1-triethyl-" "agn-pc-0cvd9g" "silanol,triethyl- (6ci,7ci,8ci,9ci);hydroxytriethylsilane;triethylhydroxysilane;triethylsilanol;triethylsilyl hydroxide;" );
gibbsFormation
{
    dHf_298   -431020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-241940.0
    phase     gas;
}
