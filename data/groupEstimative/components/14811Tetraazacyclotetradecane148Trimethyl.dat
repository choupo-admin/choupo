/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,8,11-tetraazacyclotetradecane, 1,4,8-trimethyl-  (C13H30N4, CAS 67707-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14811Tetraazacyclotetradecane148Trimethyl;
formula     C13H30N4;
CAS         67707-85-1;
InChIKey    NWTDWQBLYRISDC-UHFFFAOYSA-N;
MW          242.411;      // g/mol [origin=calculated method=formula-sum]
Tc          848.89;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       0.6782;      // -   [origin=predictive method=lee-kesler]
Tb          628.48;      // K   [origin=predictive method=joback]
HvapTb      59017.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.23 1.69776 -0.000865 1.111e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2NH; count 1; } { group CH3N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 10; } { group NH_ring; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,8-trimethyl-1,4,8,11-tetrazacyclotetradecane" "trimethylcyclam" );
gibbsFormation
{
    dHf_298   -27390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     815.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=450290.0
    phase     gas;
}
