/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethyl-2-vinylpyridine  (C9H11N, CAS 5408-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Ethyl2Vinylpyridine;
formula     C9H11N;
CAS         5408-74-2;
InChIKey    YQUDMNIUBTXLSX-UHFFFAOYSA-N;
MW          133.194;      // g/mol [origin=calculated method=formula-sum]
Tc          712.18;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.4104;      // -   [origin=predictive method=lee-kesler]
Tb          487.56;      // K   [origin=predictive method=joback]
HvapTb      44106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.829 0.73418 -0.00046212 1.157e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenyl-5-ethyl-pyridine" "2-vinyl-5-ethylpyridine" "pyridine, 5-ethyl-2-vinyl-" "pyridine, 2-ethenyl-5-ethyl-" "3-ethyl-6-vinylpyridine" "2-ethenyl-5-ethylpyridine" "pyridine, 2-vinyl-5-ethyl-" "5-ethyl-2-vinyl pyridine" "5-ethyl-2-vinyl-pyridine" "pyridine,2-ethenyl-5-ethyl-" "pyridine, 2-ethenyl-5-ethyl- (9ci)" );
gibbsFormation
{
    dHf_298   154190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=292570.0
    phase     gas;
}
