/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 2,2,5-trimethyl-  (C9H18O, CAS 73210-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol225Trimethyl;
formula     C9H18O;
CAS         73210-25-0;
InChIKey    WWIBETAPAOBCKI-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          703.57;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.6620;      // -   [origin=predictive method=lee-kesler]
Tb          508.15;      // K   [origin=predictive method=joback]
HvapTb      50967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.72 1.25386 -0.000999 3.569e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,5-trimethylcyclohexan-1-ol" "agn-pc-03cz3d" );
gibbsFormation
{
    dHf_298   -352440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108380.0
    phase     gas;
}
