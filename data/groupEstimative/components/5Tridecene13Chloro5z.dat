/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-tridecene, 13-chloro-, (5z)-  (C13H25Cl, CAS 71487-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Tridecene13Chloro5z;
formula     C13H25Cl;
CAS         71487-17-7;
InChIKey    IKVOAYSYYWFSDI-UHFFFAOYSA-N;
MW          216.793;      // g/mol [origin=calculated method=formula-sum]
Tc          710.87;      // K   [origin=predictive method=joback]
Pc          16.646;      // bar [origin=predictive method=joback]
omega       0.6556;      // -   [origin=predictive method=lee-kesler]
Tb          538.63;      // K   [origin=predictive method=joback]
HvapTb      48875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.22 1.26562 -0.0007876 1.999e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13-chloranyltridec-5-ene" "(z)-13-chlorotridec-5-ene" );
gibbsFormation
{
    dHf_298   -210170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126870.0
    phase     gas;
}
