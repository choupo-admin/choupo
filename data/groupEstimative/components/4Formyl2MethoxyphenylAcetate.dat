/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-formyl-2-methoxyphenyl acetate  (C10H10O4, CAS 881-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H10O4 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Formyl2MethoxyphenylAcetate;
formula     C10H10O4;
CAS         881-68-5;
InChIKey    PZSJOBKRSVRODF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          194.186;      // g/mol [origin=calculated method=formula-sum]
Tc          732.07;      // K   [origin=predictive method=joback]
Pc          29.377;      // bar [origin=predictive method=joback]
omega       0.5643;      // -   [origin=predictive method=lee-kesler]
Tb          522.10;      // K   [origin=predictive method=joback]
HvapTb      48898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.9 0.64604 -0.00036472 6.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } { group CH3COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methanoyl-2-methoxy-phenyl) ethanoate" "vanillin, acetate" "4-acetoxy-3-methoxybenzaldehyde" "benzaldehyde, 4-(acetyloxy)-3-methoxy-" "acetovanillin" "acetylvanillin" "o-acetylvanillin" "4-o-acetylvanillin" "4-formyl-2-methoxyphenol acetate" "acetyl vanillin" "4-acetoxy-m-anisaldehyde" "vanillin, acetate (8ci)" );
standardThermochemistry
{
    dHf_298   -409190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244940.0
}
