/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3,5,5-trimethyl-1,2,3,4,4a,5,6,8a-octahydronaphthalen-2-yl)propan-1-one  (C16H26O, CAS 68311-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1355Trimethyl12344a568aOctahydronaphthalen2YlPropan1One;
formula     C16H26O;
CAS         68311-16-0;
InChIKey    CJZNQYNYXSLJAM-UHFFFAOYSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          854.15;      // K   [origin=predictive method=joback]
Pc          18.123;      // bar [origin=predictive method=joback]
omega       0.5783;      // -   [origin=predictive method=lee-kesler]
Tb          635.50;      // K   [origin=predictive method=joback]
HvapTb      56684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.659 1.91568 -0.00143638 4.6676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3,5,5-trimethyl-2,3,4,4a,6,8a-hexahydro-1h-naphthalen-2-yl)propan-1-one" "1-propanone, 1-(octahydro-3,5,5-trimethyl-2-naphthalenyl)-" "1-(octahydro-3,5,5-trimethyl-2-naphthyl)propan-1-one" );
standardThermochemistry
{
    dHf_298   -353190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29360.0
}
