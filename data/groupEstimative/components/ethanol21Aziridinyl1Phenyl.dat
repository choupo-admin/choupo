/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-(1-aziridinyl)-1-phenyl-  (C10H13NO, CAS 17918-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol21Aziridinyl1Phenyl;
formula     C10H13NO;
CAS         17918-11-5;
InChIKey    LYWIFGDFJLWXHK-UHFFFAOYSA-N;
MW          163.22;      // g/mol [origin=calculated method=formula-sum]
Tc          767.58;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.9348;      // -   [origin=predictive method=lee-kesler]
Tb          566.40;      // K   [origin=predictive method=joback]
HvapTb      58514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.249 1.2257 -0.0010196 3.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(aziridin-1-yl)-1-phenyl-ethanol" "alpha-phenyl-1-aziridineethanol" "alpha-phenylaziridine-1-ethanol" "1-aziridineethanol, .alpha.-phenyl-" "1-aziridineethanol, alpha-phenyl-" "alpha-(1-aziridinylmethyl)benzyl alcohol" "benzenemethanol, alpha-(1-aziridinylmethyl)-" "benzyl alcohol, alpha-(1-aziridinylmethyl)-" ".alpha.-(1-aziridinylmethyl)benzyl alcohol" "1-aziridineethanol, a-phenyl-" ".alpha.-phenyl-1-aziridineethanol" "2-(aziridin-1-yl)-1-phenylethanol" );
gibbsFormation
{
    dHf_298   -3880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197810.0
    phase     gas;
}
