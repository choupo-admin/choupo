/*--------------------------------*- Choupo -*-----------------------*\
  Component: dilinoleic acid  (C36H64O4, CAS 67922-65-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dilinoleicAcid;
formula     C36H64O4;
CAS         67922-65-0;
InChIKey    VJZWIFWPGRIJSN-XRHABHTOSA-N;
MW          560.904;      // g/mol [origin=calculated method=formula-sum]
Tc          1779.20;      // K   [origin=predictive method=joback]
Pc          5.222;      // bar [origin=predictive method=joback]
omega       -0.0996;      // -   [origin=predictive method=lee-kesler]
Tb          1332.34;      // K   [origin=predictive method=joback]
HvapTb      130184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.546 3.39924 -0.0020002 4.456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 24; } { group CH=CH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 24; } { group dCH; count 8; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(9z,12z)-octadeca-9,12-dienoic acid" "9,12-octadecadienoic acid (z,z)-, dimer" "9,12-octadecadienoic acid (9z,12z)-, dimer" "9,12-octadecadienoic acid, dimer" "9,12-octadecadienoic acid (9z,12z)-, dimer, homopolymer" );
gibbsFormation
{
    dHf_298   -1129650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1745.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-219460.0
    phase     gas;
}
