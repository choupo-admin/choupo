/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromohydroxyphenylpropanone  (C9H9BrO2, CAS 17764-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromohydroxyphenylpropanone;
formula     C9H9BrO2;
CAS         17764-92-0;
InChIKey    CPZPNEVIZAJTDT-UHFFFAOYSA-N;
MW          229.073;      // g/mol [origin=calculated method=formula-sum]
Tc          882.51;      // K   [origin=predictive method=joback]
Pc          45.347;      // bar [origin=predictive method=joback]
omega       0.8604;      // -   [origin=predictive method=lee-kesler]
Tb          637.83;      // K   [origin=predictive method=joback]
HvapTb      64761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.269 0.88522 -0.00073902 2.5466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-bromanyl-2-oxidanyl-phenyl)propan-1-one" "1-(4-bromo-2-hydroxyphenyl)propan-1-one" "1-(4-bromo-2-hydroxyphenyl)-1-propanone" "propiophenone, 4-bromo-2-hydroxy-" "propiophenone, 4-bromo-2-hydroxy-," "propiophenone, 4'-bromo-2'-hydroxy-" "1-propanone,1-(4-bromo-2-hydroxyphenyl)-" "propiophenone,4'-bromo-2'-hydroxy- (8ci)" );
standardThermochemistry
{
    dHf_298   -267590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141540.0
}
