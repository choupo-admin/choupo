/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tetracosanol  (C24H50O, CAS 506-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tetracosanol;
formula     C24H50O;
CAS         506-51-4;
InChIKey    TYWMIZZBOVGFOV-UHFFFAOYSA-N;
MW          354.663;      // g/mol [origin=calculated method=formula-sum]
Tc          1031.56;      // K   [origin=predictive method=joback]
Pc          8.500;      // bar [origin=predictive method=joback]
omega       0.7991;      // -   [origin=predictive method=lee-kesler]
Tb          840.90;      // K   [origin=predictive method=joback]
HvapTb      85697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.637 2.31782 -0.0013122 2.842e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 23; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 23; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetracosan-1-ol" "lignoceryl alcohol" "n-tetracosanol" "lignocerol" "tetracosanol" "tetracosyl alcohol" "lignoceric alcohol" "lignoceryl alkohol" "1- paragraph signthorne(r)ea (1/4)" );
standardThermochemistry
{
    dHf_298   -690920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1141.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14380.0
}
