/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyloctanedioic acid  (C10H18O4, CAS 3971-33-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthyloctanedioicAcid;
formula     C10H18O4;
CAS         3971-33-3;
InChIKey    WUDDSDIHJHPJRP-UHFFFAOYSA-N;
MW          202.25;      // g/mol [origin=calculated method=formula-sum]
Tc          916.76;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       1.2501;      // -   [origin=predictive method=lee-kesler]
Tb          718.98;      // K   [origin=predictive method=joback]
HvapTb      71794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.316 1.06132 -0.0006686 1.633e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylsuberic acid" "octanedioic acid, 2-ethyl-" "2-ethylsubericacid" "octanedioic acid,2-ethyl-" );
gibbsFormation
{
    dHf_298   -955550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     642.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-656940.0
    phase     gas;
}
