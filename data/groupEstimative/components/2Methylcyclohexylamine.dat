/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylcyclohexylamine  (C7H15N, CAS 7003-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylcyclohexylamine;
formula     C7H15N;
CAS         7003-32-9;
InChIKey    FEUISMYEFPANSS-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          664.80;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.3599;      // -   [origin=predictive method=lee-kesler]
Tb          447.17;      // K   [origin=predictive method=joback]
HvapTb      41937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.65 0.82632 -0.000426 6.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylcyclohexan-1-amine" "cyclohexanamine, 2-methyl-" "o-methylcyclohexylamine" "cyclohexylamine, 2-methyl-" "2-methylcyclohexylamine,c&t" "1-amino-2-methylcyclohexane" "2-methylcyclohexanamine" "agn-pc-03cz3k" "cis-2-methyl-cyclohexylamine" "trans-2-methyl-cyclohexylamine" "2-methylcyclohexylamine, mixture of cis and trans" );
gibbsFormation
{
    dHf_298   -120040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91250.0
    phase     gas;
}
