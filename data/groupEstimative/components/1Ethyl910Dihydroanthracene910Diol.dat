/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-9,10-dihydroanthracene-9,10-diol  (C16H16O2, CAS 67923-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl910Dihydroanthracene910Diol;
formula     C16H16O2;
CAS         67923-88-0;
InChIKey    ZPAFNFCCRHYXIS-UHFFFAOYSA-N;
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          1026.72;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       1.5023;      // -   [origin=predictive method=lee-kesler]
Tb          816.14;      // K   [origin=predictive method=joback]
HvapTb      90538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.169 1.38952 -0.00097988 2.761e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl-9,10-dihydroanthracene-9,10-diol" "9,10-anthracenediol, ethyl-9,10-dihydro-" );
standardThermochemistry
{
    dHf_298   -180760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71270.0
}
