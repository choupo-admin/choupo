/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylphenyl 2-chlorobenzoate  (C14H11ClO2, CAS 6280-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylphenyl2Chlorobenzoate;
formula     C14H11ClO2;
CAS         6280-48-4;
InChIKey    XLJNELFCIDKGTK-UHFFFAOYSA-N;
MW          246.69;      // g/mol [origin=calculated method=formula-sum]
Tc          924.37;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.6881;      // -   [origin=predictive method=lee-kesler]
Tb          678.89;      // K   [origin=predictive method=joback]
HvapTb      64426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.75 1.00902 -0.00059192 1.085e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methylphenyl) 2-chloranylbenzoate" "(4-methylphenyl) 2-chlorobenzoate" "(4-methylphenyl)2-chlorobenzoate" "2-chlorobenzoic acid, 4-tolyl ester" "benzoic acid,2-chloro-, 4-methylphenyl ester" );
standardThermochemistry
{
    dHf_298   -215190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49740.0
}
