/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethoxyresorcinol  (C8H10O3, CAS 28334-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Ethoxyresorcinol;
formula     C8H10O3;
CAS         28334-98-7;
InChIKey    NCKTXJDJNMSYDR-UHFFFAOYSA-N;
MW          154.165;      // g/mol [origin=calculated method=formula-sum]
Tc          827.96;      // K   [origin=predictive method=joback]
Pc          52.970;      // bar [origin=predictive method=joback]
omega       0.8702;      // -   [origin=predictive method=lee-kesler]
Tb          592.98;      // K   [origin=predictive method=joback]
HvapTb      64116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.629 0.93092 -0.00084432 3.209e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethoxybenzene-1,3-diol" "1,3-benzenediol, 5-ethoxy-" "1,3-benzenediol,5-ethoxy-" "resorcinol,5-ethoxy- (8ci); 1-ethoxy-3,5-dihydroxybenzene" );
gibbsFormation
{
    dHf_298   -458760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-285350.0
    phase     gas;
}
