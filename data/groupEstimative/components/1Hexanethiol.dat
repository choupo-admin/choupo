/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexanethiol  (C6H14S, CAS 111-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexanethiol;
formula     C6H14S;
CAS         111-31-9;
InChIKey    PMBXCGGQNSVESQ-UHFFFAOYSA-N;
MW          118.238;      // g/mol [origin=calculated method=formula-sum]
Tc          588.45;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.3721;      // -   [origin=predictive method=lee-kesler]
Tb          399.74;      // K   [origin=predictive method=joback]
HvapTb      35687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.325 0.60112 -0.000325 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexane-1-thiol" "hexyl mercaptan" "n-hexyl mercaptan" "1-mercaptohexane" "hexanethiol" "hexylthiol" "n-hexylmercaptan" "1-hexylthiol" "mercaptan c6" "n-hexanethiol" );
gibbsFormation
{
    dHf_298   -128690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29030.0
    phase     gas;
}
