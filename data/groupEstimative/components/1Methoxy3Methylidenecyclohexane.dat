/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-3-methylidenecyclohexane  (C8H14O, CAS 97551-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy3Methylidenecyclohexane;
formula     C8H14O;
CAS         97551-98-9;
InChIKey    GNHABTVGRZMHNF-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          625.88;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.3363;      // -   [origin=predictive method=lee-kesler]
Tb          423.77;      // K   [origin=predictive method=joback]
HvapTb      36400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.2 0.70522 -0.000289 9.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-3-methylidene-cyclohexane" "cyclohexanol, 1-methoxy-3-methylene-, (+-)-" );
gibbsFormation
{
    dHf_298   -202110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10990.0
    phase     gas;
}
