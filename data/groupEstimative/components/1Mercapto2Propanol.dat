/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-mercapto-2-propanol  (C3H8OS, CAS 1068-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Mercapto2Propanol;
formula     C3H8OS;
CAS         1068-47-9;
InChIKey    FETFXNFGOYOOSP-UHFFFAOYSA-N;
MW          92.156;      // g/mol [origin=calculated method=formula-sum]
Tc          612.69;      // K   [origin=predictive method=joback]
Pc          55.526;      // bar [origin=predictive method=joback]
omega       0.6542;      // -   [origin=predictive method=lee-kesler]
Tb          422.84;      // K   [origin=predictive method=joback]
HvapTb      45300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.661 0.35602 -0.0001954 3.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-sulfanylpropan-2-ol" "mercapto-2-propanol" "1-mercaptopropan-2-ol" "2-propanol, 1-mercapto-(7ci,8ci,9ci)" "(?a'a a'a currency)-1-mercapto-2-propanol;1-mercapto-2-propanol; 1-methyl-2-mercaptoethanol; 2-hydroxy-1-propanethiol;2-hydroxy-3-propanethiol; 3-mercapto-2-propanol; b-hydroxypropylmercaptan" );
standardThermochemistry
{
    dHf_298   -224280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135490.0
}
