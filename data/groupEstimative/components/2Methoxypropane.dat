/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxypropane  (C4H10O, CAS 598-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxypropane;
formula     C4H10O;
CAS         598-53-8;
InChIKey    RMGHERXMTMUMMV-UHFFFAOYSA-N;
MW          74.123;      // g/mol [origin=calculated method=formula-sum]
Tc          480.84;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.2539;      // -   [origin=predictive method=lee-kesler]
Tb          313.10;      // K   [origin=predictive method=joback]
HvapTb      26520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.07 0.32656 -8.6e-05 -1.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propane, 2-methoxy-" "methyl isopropyl ether" "ether, isopropyl methyl" "isopropyl methyl ether" "isopryl" "agn-pc-00ldty" "i-c3h7och3" "propane, 2-methoxy- (9ci)" );
gibbsFormation
{
    dHf_298   -263390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     313.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124640.0
    phase     gas;
}
