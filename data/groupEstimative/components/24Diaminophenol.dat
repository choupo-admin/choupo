/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-diaminophenol  (C6H8N2O, CAS 95-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Diaminophenol;
formula     C6H8N2O;
CAS         95-86-3;
InChIKey    XIWMTQIUUWJNRP-UHFFFAOYSA-N;
MW          124.143;      // g/mol [origin=calculated method=formula-sum]
Tc          849.41;      // K   [origin=predictive method=joback]
Pc          67.740;      // bar [origin=predictive method=joback]
omega       0.8211;      // -   [origin=predictive method=lee-kesler]
Tb          594.22;      // K   [origin=predictive method=joback]
HvapTb      66184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.11 0.7138 -0.00060992 2.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACOH; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(azanyl)phenol" "diaminopropane" "phenol, 2,4-diamino-" "amidol" "xiwmtqiuuwjnrp-uhfffaoysa-" "137-09-7 (di-hydrochloride)" );
standardThermochemistry
{
    dHf_298   -51840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80700.0
}
