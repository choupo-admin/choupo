/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-(1,2-ethanediyl)bis(octanamide)  (C18H36N2O2, CAS 17832-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nN12EthanediylBisOctanamide;
formula     C18H36N2O2;
CAS         17832-30-3;
InChIKey    BOAOBQLVSVMFBZ-UHFFFAOYSA-N;
MW          312.498;      // g/mol [origin=calculated method=formula-sum]
Tc          1063.39;      // K   [origin=predictive method=joback]
Pc          13.820;      // bar [origin=predictive method=joback]
omega       1.1845;      // -   [origin=predictive method=lee-kesler]
Tb          863.36;      // K   [origin=predictive method=joback]
HvapTb      89660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.862 1.79344 -0.0010112 2.0592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 2; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 2; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dihexylhexanediamide" );
standardThermochemistry
{
    dHf_298   -582990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     994.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29140.0
}
