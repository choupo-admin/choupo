/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-prop-2-enoyloxyethoxy)ethyl 3-(diethylamino)propanoate  (C14H25NO5, CAS 73287-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Prop2EnoyloxyethoxyEthyl3DiethylaminoPropanoate;
formula     C14H25NO5;
CAS         73287-52-2;
InChIKey    CNHYJXIHRPPVEW-UHFFFAOYSA-N;
MW          287.356;      // g/mol [origin=calculated method=formula-sum]
Tc          840.54;      // K   [origin=predictive method=joback]
Pc          15.635;      // bar [origin=predictive method=joback]
omega       1.0362;      // -   [origin=predictive method=lee-kesler]
Tb          667.90;      // K   [origin=predictive method=joback]
HvapTb      65355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.798 1.26494 -0.0005731 4.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2=CH; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-((1-oxoallyl)oxy)ethoxy)ethyl n,n-diethyl-beta-alaninate" "2-(2-((3-(diethylamino)propionyl)oxy)ethoxy)ethyl 2-propenoate" ".beta.-alanine, n,n-diethyl-, 2-[2-[(1-oxo-2-propen-1-yl)oxy]ethoxy]ethyl ester" ".beta.-alanine, n,n-diethyl-, 2-[2-[(1-oxo-2-propenyl)oxy]ethoxy]ethyl ester" "beta-alanine, n,n-diethyl-, 2-(2-((1-oxo-2-propen-1-yl)oxy)ethoxy)ethyl ester" "beta-alanine, n,n-diethyl-, 2-(2-((1-oxo-2-propenyl)oxy)ethoxy)ethyl ester" );
gibbsFormation
{
    dHf_298   -906110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     826.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-460120.0
    phase     gas;
}
