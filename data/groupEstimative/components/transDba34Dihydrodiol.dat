/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-dba-3,4-dihydrodiol  (C22H16O2, CAS 66267-19-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transDba34Dihydrodiol;
formula     C22H16O2;
CAS         66267-19-4;
InChIKey    DKAAILWGWGVYES-FGZHOGPDSA-N;
MW          312.368;      // g/mol [origin=calculated method=formula-sum]
Tc          1234.07;      // K   [origin=predictive method=joback]
Pc          25.456;      // bar [origin=predictive method=joback]
omega       1.6361;      // -   [origin=predictive method=lee-kesler]
Tb          996.36;      // K   [origin=predictive method=joback]
HvapTb      107836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.21 1.8926 -0.00151268 4.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 7; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,4r)-3,4-dihydronaphtho[1,2-b]phenanthrene-3,4-diol" "trans-dibenz(a,h)anthracene-3,4-dihydrodiol" "trans-3,4-dihydro-3,4-dihydroxydibenz(a,h)anthracene" "trans-3,4-dihydroxy-3,4-dihydrodibenz(a,h)anthracene" "dibenz(a,h)anthracene-3,4-diol, 3,4-dihydro-, trans-" "dibenz(a,h)anthracene, 3,4-dihydro-3,4-dihydroxy-, (e)-" );
standardThermochemistry
{
    dHf_298   66070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=325460.0
}
