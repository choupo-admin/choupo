/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,5-dibromo-2,4-dimethoxy-6-methylbenzoate  (C11H12Br2O4, CAS 150965-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl35Dibromo24Dimethoxy6Methylbenzoate;
formula     C11H12Br2O4;
CAS         150965-73-4;
InChIKey    HCKWDQNSOKQKEN-UHFFFAOYSA-N;
MW          368.021;      // g/mol [origin=calculated method=formula-sum]
Tc          967.57;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       1.0248;      // -   [origin=predictive method=lee-kesler]
Tb          738.24;      // K   [origin=predictive method=joback]
HvapTb      70763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (123.27 0.56768 -9.68e-05 -7.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group AC; count 5; } { group ACCH3; count 1; } { group CH3O; count 2; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC_ring; count 6; } { group Br; count 2; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,5-bis(bromanyl)-2,4-dimethoxy-6-methyl-benzoate" "methyl 3,5-dibromo-4,6-dimethoxy-2-methylbenzoate" "benzoic acid,3,5-dibromo-2,4-dimethoxy-6-methyl-, methyl ester" "methyl 3,5-dibromo-2,4-dimethoxy-6-methylbenzoate;3,5-dibromo-2,4-dimethoxy-6-methylbenzoic acid methyl ester;methyl 3,5-dibromo-2,4-dimethoxy-6-methylbenzoate, 98+%" );
gibbsFormation
{
    dHf_298   -620250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-385730.0
    phase     gas;
}
