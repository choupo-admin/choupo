/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxypropane  (C4H10O, CAS 557-17-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxypropane;
formula     C4H10O;
CAS         557-17-5;
InChIKey    VNKYTQGIUYNRMY-UHFFFAOYSA-N;
MW          74.123;      // g/mol [origin=calculated method=formula-sum]
Tc          477.20;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.2838;      // -   [origin=predictive method=lee-kesler]
Tb          313.54;      // K   [origin=predictive method=joback]
HvapTb      26908.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.752 0.32064 -8.28e-05 -1.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propane, 1-methoxy-" "methyl propyl ether" "metopryl" "neothyl" "methyl n-propyl ether" "alpha-methoxy propane" "ether, methyl propyl" "methoxypropane" "neo-thyl" "propane, 1-methoxy" "propane, 1-methoxy- (9ci)" "ether,methyl propyl (6ci,7ci,8ci); 1-methoxypropane; methyl n-propyl ether; methylpropyl ether; metopryl; neothyl; propyl methyl ether; a-methoxypropane" );
gibbsFormation
{
    dHf_298   -258110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122200.0
    phase     gas;
}
