/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxyethyl methacrylate, ethoxyethyl methacrylate polymer  (C14H24O6, CAS 29403-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyethylMethacrylateEthoxyethylMethacrylatePolymer;
formula     C14H24O6;
CAS         29403-23-4;
InChIKey    TWIPIEXYBMUFMA-UHFFFAOYSA-N;
MW          288.34;      // g/mol [origin=calculated method=formula-sum]
Tc          927.07;      // K   [origin=predictive method=joback]
Pc          16.378;      // bar [origin=predictive method=joback]
omega       1.2104;      // -   [origin=predictive method=lee-kesler]
Tb          745.48;      // K   [origin=predictive method=joback]
HvapTb      79775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (107.225 0.94866 -0.0001036 -1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH2=C; count 2; } { group OH; count 1; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCH2; count 2; } { group dC; count 2; } { group OH; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxyethyl 2-methylprop-2-enoate;2-hydroxyethyl 2-methylprop-2-enoate" "phemfilcon a" "2-ethoxyethyl 2-methylprop-2-enoate- 2-hydroxyethyl 2-methylprop-2-enoate(1:1)" "fresh look" "2-propenoic acid, 2-methyl-, 2-ethoxyethyl ester, polymer with 2-hydroxyethyl 2-methyl-2-propenoate" "2-ethoxyethyl 2-methylprop-2-enoate; 2-hydroxyethyl 2-methylprop-2-enoate" "2-ethoxyethyl 2-methylprop-2-enoate - 2-hydroxyethyl 2-methylprop-2-enoate (1:1)" );
gibbsFormation
{
    dHf_298   -1131640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     956.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-741740.0
    phase     gas;
}
