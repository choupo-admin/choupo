/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopentyl oleate  (C23H44O2, CAS 627-89-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopentylOleate;
formula     C23H44O2;
CAS         627-89-4;
InChIKey    PHUSOTFVZQDLMC-UHFFFAOYSA-N;
MW          352.603;      // g/mol [origin=calculated method=formula-sum]
Tc          967.14;      // K   [origin=predictive method=joback]
Pc          8.852;      // bar [origin=predictive method=joback]
omega       0.8275;      // -   [origin=predictive method=lee-kesler]
Tb          787.78;      // K   [origin=predictive method=joback]
HvapTb      73769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.474 2.15996 -0.0012198 2.523e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl octadec-9-enoate" "agn-pc-00flkt" "3-methylbutyl (z)-octadec-9-enoate" "9-octadecenoic acid(9z)-, 3-methylbutyl ester" "9-octadecenoicacid (z)-, 3-methylbutyl ester; oleic acid, isopentyl ester (7ci);3-methylbutyl oleate; isoamyl oleate; isopentyl oleate; iso-amyl oleate" );
gibbsFormation
{
    dHf_298   -723390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1087.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89810.0
    phase     gas;
}
