/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-di(2-propynyl)-amine  (C7H9N, CAS 2568-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylDi2PropynylAmine;
formula     C7H9N;
CAS         2568-61-8;
InChIKey    SQRXWXCCRCQPKC-UHFFFAOYSA-N;
MW          107.156;      // g/mol [origin=calculated method=formula-sum]
Tc          539.44;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.2724;      // -   [origin=predictive method=lee-kesler]
Tb          352.44;      // K   [origin=predictive method=joback]
HvapTb      32935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.392 0.60492 -0.00046146 1.4628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3N; count 1; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group tCH; count 2; } { group tC; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-n-prop-2-ynyl-prop-2-yn-1-amine" "n,n-di(2-propynyl)-n-methylamine" "n-methyl-n-prop-2-ynylprop-2-yn-1-amine" "2-propyn-1-amine,n-methyl-n-2-propyn-1-yl-" "2-propyn-1-amine,n-methyl-n-2-propynyl- (9ci); di-2-propynylamine, n-methyl- (6ci,7ci,8ci);methyldi-2-propynylamine; n-methyldipropargylamine" );
gibbsFormation
{
    dHf_298   463520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=564980.0
    phase     gas;
}
