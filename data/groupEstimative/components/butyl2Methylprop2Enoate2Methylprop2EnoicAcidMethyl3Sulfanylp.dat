/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-methylprop-2-enoate;2-methylprop-2-enoic acid;methyl 3-sulfanylpropanoate  (C16H28O6S, CAS 158706-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2Methylprop2Enoate2Methylprop2EnoicAcidMethyl3Sulfanylp;
formula     C16H28O6S;
CAS         158706-64-0;
InChIKey    BBWHBDNZYLHMKK-UHFFFAOYSA-N;
MW          348.454;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.70;      // K   [origin=predictive method=joback]
Pc          13.996;      // bar [origin=predictive method=joback]
omega       1.0967;      // -   [origin=predictive method=lee-kesler]
Tb          886.41;      // K   [origin=predictive method=joback]
HvapTb      89333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (134.925 1.03978 2.68e-05 -2.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH2=C; count 2; } { group CH2COO; count 1; } { group COOH; count 1; } { group CH2SH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group dCH2; count 2; } { group dC; count 2; } { group COOH; count 1; } { group COO; count 2; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, telomer with butyl 2-methyl-2-propenoate and methyl 3-mercaptopropanoate" );
gibbsFormation
{
    dHf_298   -1311880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1195.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-902360.0
    phase     gas;
}
