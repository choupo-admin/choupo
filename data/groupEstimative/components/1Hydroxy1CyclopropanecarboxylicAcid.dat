/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hydroxy-1-cyclopropanecarboxylic acid  (C4H6O3, CAS 17994-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hydroxy1CyclopropanecarboxylicAcid;
formula     C4H6O3;
CAS         17994-25-1;
InChIKey    GQXURJDNDYACGE-UHFFFAOYSA-N;
MW          102.089;      // g/mol [origin=calculated method=formula-sum]
Tc          740.33;      // K   [origin=predictive method=joback]
Pc          64.412;      // bar [origin=predictive method=joback]
omega       1.0453;      // -   [origin=predictive method=lee-kesler]
Tb          535.79;      // K   [origin=predictive method=joback]
HvapTb      57103.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.09 0.9114 -0.0010496 4.715e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-oxidanylcyclopropane-1-carboxylic acid" "1-hydroxycyclopropanecarboxylic acid" "1-hydroxy-cyclopropanecarboxylic acid" "1-hydroxycyclopropane-1-carboxylic acid" "1-hydroxy-1-cyclopropanecarboxylicacid" "1-carboxy-1-hydroxycyclopropane" "bh780" "cyclopropanecarboxylicacid, 1-hydroxy-" "1-hydroxy-cyclopropane-1-carboxylic acid" "1-hydroxy-1-cyclopropanecarboxylicacid;1-hydroxycyclopropanecarboxylic acid;1-hydroxy-1-cyclopropanecarboxylic acid;" );
gibbsFormation
{
    dHf_298   -540350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-442670.0
    phase     gas;
}
