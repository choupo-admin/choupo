/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dimethyl-5-octylnaphthalene  (C20H28, CAS 55000-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dimethyl5Octylnaphthalene;
formula     C20H28;
CAS         55000-53-8;
InChIKey    BSKSLVGHMZRDLE-UHFFFAOYSA-N;
MW          268.444;      // g/mol [origin=calculated method=formula-sum]
Tc          921.88;      // K   [origin=predictive method=joback]
Pc          14.714;      // bar [origin=predictive method=joback]
omega       0.7937;      // -   [origin=predictive method=lee-kesler]
Tb          717.80;      // K   [origin=predictive method=joback]
HvapTb      66016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.743 1.64276 -0.001031 2.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 5; } { group AC; count 2; } { group ACCH3; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethyl-5-octyl-naphthalene" "naphthalene, 1,4-dimethyl-5-octyl-" );
standardThermochemistry
{
    dHf_298   -62940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=307690.0
}
