/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3,3-dimethylcyclopent-1-enylmethyl)trimethylsilane  (C11H22Si, CAS 177087-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H22Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        33Dimethylcyclopent1EnylmethylTrimethylsilane;
formula     C11H22Si;
CAS         177087-93-3;
InChIKey    LDZGPJIBWOQWAO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.382;      // g/mol [origin=calculated method=formula-sum]
Tc          677.86;      // K   [origin=predictive method=joback]
Pc          21.674;      // bar [origin=predictive method=joback]
omega       0.3096;      // -   [origin=predictive method=lee-kesler]
Tb          472.34;      // K   [origin=predictive method=joback]
HvapTb      40434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.689 1.1508 -0.00074004 2.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,3-dimethylcyclopenten-1-yl)methyl-trimethyl-silane" "(3,3-dimethylcyclopenten-1-yl)methyl-trimethylsilane" );
standardThermochemistry
{
    dHf_298   -259960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11630.0
}
