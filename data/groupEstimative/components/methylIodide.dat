/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl iodide  (CH3I, CAS 74-88-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylIodide;
formula     CH3I;
CAS         74-88-4;
InChIKey    INQOMBQAUSQDDS-UHFFFAOYSA-N;
MW          141.935;      // g/mol [origin=calculated method=formula-sum]
Tc          522.78;      // K   [origin=predictive method=joback]
Pc          56.026;      // bar [origin=predictive method=joback]
omega       0.1278;      // -   [origin=predictive method=lee-kesler]
Tb          315.62;      // K   [origin=predictive method=joback]
HvapTb      27193.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.67 0.13782 -0.000112 4.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanylmethane" "iodomethane" "methane, iodo-" "monoiodomethane" "methyliodide" "methyljodid" "jod-methan" "iodometano" "joodmethaan" "methyljodide" "metylu jodek" "iodure de methyle" );
gibbsFormation
{
    dHf_298   12900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     250.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15660.0
    phase     gas;
}
