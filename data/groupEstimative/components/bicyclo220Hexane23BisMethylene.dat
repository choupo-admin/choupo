/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.0]hexane, 2,3-bis(methylene)-  (C8H10, CAS 40117-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo220Hexane23BisMethylene;
formula     C8H10;
CAS         40117-13-3;
InChIKey    BWABVUBNQYHTFR-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          591.26;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.3139;      // -   [origin=predictive method=lee-kesler]
Tb          394.44;      // K   [origin=predictive method=joback]
HvapTb      33546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.29 0.8306 -0.000667 2.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylidenebicyclo[2.2.0]hexane" "bicyclo(2.2.0)hexane, 2,3-bis(methylene)-" );
standardThermochemistry
{
    dHf_298   105630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     234.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244140.0
}
