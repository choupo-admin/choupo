/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(trimethylsilyl)acetylene  (C8H18Si2, CAS 14630-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H18Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisTrimethylsilylAcetylene;
formula     C8H18Si2;
CAS         14630-40-1;
InChIKey    ZDWYFWIBTZJGOR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          170.402;      // g/mol [origin=calculated method=formula-sum]
Tc          596.15;      // K   [origin=predictive method=joback]
Pc          23.428;      // bar [origin=predictive method=joback]
omega       0.1401;      // -   [origin=predictive method=lee-kesler]
Tb          394.44;      // K   [origin=predictive method=joback]
HvapTb      36142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (94.81 0.20172 0.00051034 -3.7142e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C_C; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(2-trimethylsilylethynyl)silane" "silane, 1,2-ethynediylbis[trimethyl-" "btmsa" "ethyne-1,2-diylbis(trimethylsilane)" "1,2-bis-trimethylsilanyl-ethyne" "2,5-disilahex-3-yne, 2,2,5,5-tetramethyl-" "silane, 1,2-ethynediylbis(trimethyl-" "silane, 1,1'-(1,2-ethynediyl)bis(1,1,1-trimethyl-" "silane, 1,1'-(1,2-ethynediyl)bis[1,1,1-trimethyl-" "bis-(trimethylsilyl)acetylene" "bis-(trimethylsilyl)-acetylene" "1,2-ethynediylbis[trimethyl-silane]" );
standardThermochemistry
{
    dHf_298   -159390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     692.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9760.0
}
