/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-tamoxifen  (C26H29NO, CAS 13002-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisTamoxifen;
formula     C26H29NO;
CAS         13002-65-8;
InChIKey    NKANXQFJJICGDU-OCEACIFDSA-N;
MW          371.524;      // g/mol [origin=calculated method=formula-sum]
Tc          1158.03;      // K   [origin=predictive method=joback]
Pc          13.789;      // bar [origin=predictive method=joback]
omega       0.9173;      // -   [origin=predictive method=lee-kesler]
Tb          918.28;      // K   [origin=predictive method=joback]
HvapTb      85531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.917 2.25816 -0.00150716 3.834e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 14; } { group AC; count 4; } { group CH2O; count 1; } { group CH3N; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dC; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[(e)-1,2-diphenylbut-1-enyl]phenoxy]-n,n-dimethyl-ethanamine" "tamoxifen (e)" "(e)-tamoxifen" "ethanamine, 2-(4-(1,2-diphenyl-1-butenyl)phenoxy)-n,n-dimethyl-, (e)-" "ethylamine, n,n-dimethyl-2-(p-(1,2-diphenyl-1-butenyl)phenoxy)-, (e)-" "upcmld-dp027:001" "brd-k43744935-048-01-6" "{2-[4-(1,2-diphenylbut-1-en-1-yl)phenoxy]ethyl}dimethylamine" "2-[4-[(e)-1,2-diphenylbut-1-enyl]phenoxy]-n,n-dimethylethanamine" );
standardThermochemistry
{
    dHf_298   151100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     855.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=564540.0
}
