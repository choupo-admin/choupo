/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropenylphenol  (C9H10O, CAS 4286-23-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropenylphenol;
formula     C9H10O;
CAS         4286-23-1;
InChIKey    JAGRUUPXPPLSRX-UHFFFAOYSA-N;
MW          134.178;      // g/mol [origin=calculated method=formula-sum]
Tc          741.23;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.5112;      // -   [origin=predictive method=lee-kesler]
Tb          509.38;      // K   [origin=predictive method=joback]
HvapTb      50328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.8 0.91442 -0.00077856 2.737e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-prop-1-en-2-ylphenol" "p-isopropenylphenol" "4-(prop-1-en-2-yl)phenol" "4-(1-methylethenyl)-phenol" "phenol, 4-(1-methylethenyl)-, dimer" "4-iso-propenylphenol" "4-isopropenyl-phenol" "p-isopropenylphenol dimer" "4-(1-methylethenyl)phenol" "4-(1-methylethenyl)phenol dimer" "phenol,4-(1-methylethenyl)-, dimer" "4-isopropenylphenoldimer; p-isopropenylphenol dimer" );
gibbsFormation
{
    dHf_298   -54230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61980.0
    phase     gas;
}
