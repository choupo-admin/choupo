/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-hydroxypropyl) azelaate  (C15H28O6, CAS 51851-36-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2HydroxypropylAzelaate;
formula     C15H28O6;
CAS         51851-36-6;
InChIKey    HILXNQDVXRHFJW-UHFFFAOYSA-N;
MW          304.383;      // g/mol [origin=calculated method=formula-sum]
Tc          1031.79;      // K   [origin=predictive method=joback]
Pc          16.687;      // bar [origin=predictive method=joback]
omega       1.4336;      // -   [origin=predictive method=lee-kesler]
Tb          842.72;      // K   [origin=predictive method=joback]
HvapTb      96380.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.289 1.39904 -0.0006702 7.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 2; } { group OH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 2; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-oxidanylpropyl) nonanedioate" "nonanedioic acid, bis(2-hydroxypropyl) ester" "nonanedioic acid, 1,9-bis(2-hydroxypropyl) ester" "bis(2-hydroxypropyl) azelate" "bis(2-hydroxypropyl) nonanedioate" "nonanedioic acid,1,9-bis(2-hydroxypropyl) ester" "nonanedioicacid, bis(2-hydroxypropyl) ester (9ci); bis(2-hydroxypropyl)azelate" );
gibbsFormation
{
    dHf_298   -1302510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     925.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-823840.0
    phase     gas;
}
