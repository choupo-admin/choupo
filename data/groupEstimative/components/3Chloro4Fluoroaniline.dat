/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-fluoroaniline  (C6H5ClFN, CAS 367-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4Fluoroaniline;
formula     C6H5ClFN;
CAS         367-21-5;
InChIKey    YSEMCVGMNUUNRK-UHFFFAOYSA-N;
MW          145.561;      // g/mol [origin=calculated method=formula-sum]
Tc          709.33;      // K   [origin=predictive method=joback]
Pc          43.397;      // bar [origin=predictive method=joback]
omega       0.4820;      // -   [origin=predictive method=lee-kesler]
Tb          482.75;      // K   [origin=predictive method=joback]
HvapTb      46759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.6 0.4564 -0.00027992 6.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACNH2; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-4-fluoranyl-aniline" "benzenamine, 3-chloro-4-fluoro-" "3-chloro-4-fluorobenzenamine" "3-chloro-4-fluorophenylamine" "3-chloro-4-fluoro-phenylamine" "aniline, 3-chloro-4-fluoro-" "3-chlor-4-fluoranilin" "chlorofluoroaniline" "3-chloro-4-fluoro aniline" "agn-pc-00b8mp" "4-fluoro-3-chloroaniline" "wt174" );
standardThermochemistry
{
    dHf_298   -131640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-47500.0
}
