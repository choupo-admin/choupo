/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dibromocyclohexane  (C6H10Br2, CAS 10489-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dibromocyclohexane;
formula     C6H10Br2;
CAS         10489-97-1;
InChIKey    BWNYAKOZXVLZQO-UHFFFAOYSA-N;
MW          241.954;      // g/mol [origin=calculated method=formula-sum]
Tc          746.04;      // K   [origin=predictive method=joback]
Pc          50.586;      // bar [origin=predictive method=joback]
omega       0.3701;      // -   [origin=predictive method=lee-kesler]
Tb          488.99;      // K   [origin=predictive method=joback]
HvapTb      41098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.78 1.0642 -0.001059 4.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(bromanyl)cyclohexane" "cyclohexane, 1,1-dibromo-" );
standardThermochemistry
{
    dHf_298   -44950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47240.0
}
