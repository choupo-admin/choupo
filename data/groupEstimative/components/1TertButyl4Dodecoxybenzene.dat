/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-4-dodecoxybenzene  (C22H38O, CAS 6940-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl4Dodecoxybenzene;
formula     C22H38O;
CAS         6940-96-1;
InChIKey    AUYPJCDTURCDRS-UHFFFAOYSA-N;
MW          318.545;      // g/mol [origin=calculated method=formula-sum]
Tc          943.40;      // K   [origin=predictive method=joback]
Pc          11.023;      // bar [origin=predictive method=joback]
omega       0.8169;      // -   [origin=predictive method=lee-kesler]
Tb          753.81;      // K   [origin=predictive method=joback]
HvapTb      68618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.689 2.01808 -0.00119796 2.683e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 11; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-dodecoxy-benzene" "benzene, 1-tert-butyl-4-dodecyl-oxy-" "4-tert-butylphenyl dodecyl ether" "benzene, 1-tert-butyl-4-dodecyl-oxy-," );
gibbsFormation
{
    dHf_298   -413320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134980.0
    phase     gas;
}
