/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-(2-chloroethene-1,1-diyl)bis(4-methoxybenzene)  (C16H15ClO2, CAS 2132-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Chloroethene11DiylBis4Methoxybenzene;
formula     C16H15ClO2;
CAS         2132-66-3;
InChIKey    BAHSALYPNGPXKT-UHFFFAOYSA-N;
MW          274.744;      // g/mol [origin=calculated method=formula-sum]
Tc          956.63;      // K   [origin=predictive method=joback]
Pc          21.918;      // bar [origin=predictive method=joback]
omega       0.7216;      // -   [origin=predictive method=lee-kesler]
Tb          715.31;      // K   [origin=predictive method=joback]
HvapTb      66329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.85 1.14734 -0.00065942 1.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 2; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-chloranyl-1-(4-methoxyphenyl)ethenyl]-4-methoxy-benzene" "bim-0044215.p001" "1-[2-chloro-1-(4-methoxyphenyl)ethenyl]-4-methoxy-benzene" "1-[2-chloro-1-(4-methoxyphenyl)ethenyl]-4-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -96200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139140.0
}
