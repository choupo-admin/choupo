/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-bromo-4-chlorobutyrophenone  (C10H10BrClO, CAS 4559-96-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo4Chlorobutyrophenone;
formula     C10H10BrClO;
CAS         4559-96-0;
InChIKey    WJKPUMBLABGUCQ-UHFFFAOYSA-N;
MW          261.543;      // g/mol [origin=calculated method=formula-sum]
Tc          851.47;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.7109;      // -   [origin=predictive method=lee-kesler]
Tb          617.52;      // K   [origin=predictive method=joback]
HvapTb      58358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.633 0.8324 -0.00055746 1.4246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group CH2Cl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-bromophenyl)-4-chloranyl-butan-1-one" "1-(4-bromophenyl)-4-chlorobutan-1-one" "1-butanone, 1-(4-bromophenyl)-4-chloro-" "butyrophenone,4'-bromo-4-chloro- (6ci,7ci,8ci); 1-(4-bromophenyl)-4-chloro-1-butanone;3-chloropropyl 4-bromophenyl ketone; 4-bromophenyl 3-chloropropyl ketone;4-chloro-p-bromobutyrophenone; 4'-bromo-4-chlorobutyrophenone" );
standardThermochemistry
{
    dHf_298   -126660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9570.0
}
