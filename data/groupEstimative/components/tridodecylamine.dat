/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridodecylamine  (C36H75N, CAS 102-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridodecylamine;
formula     C36H75N;
CAS         102-87-4;
InChIKey    SWZDQOUHBYYPJD-UHFFFAOYSA-N;
MW          522.003;      // g/mol [origin=calculated method=formula-sum]
Tc          1333.58;      // K   [origin=predictive method=joback]
Pc          4.574;      // bar [origin=predictive method=joback]
omega       -0.0364;      // -   [origin=predictive method=lee-kesler]
Tb          1035.72;      // K   [origin=predictive method=joback]
HvapTb      97773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.527 3.54776 -0.0020472 4.546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 32; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 33; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-didodecyldodecan-1-amine" "trilaurylamine" "tri-n-dodecylamine" "tridodecyl amine" "1-dodecanamine, n,n-didodecyl-" "n,n-didodceyl-1-dodecanamine" "n,n-didodecyl-1-dodecanamine" "hydrogen ionophore i" "tri-dodecyl amine" "proton ionophore i" "tridodecylamine, tech" "1-dodecanamine,n-didodecyl-" );
gibbsFormation
{
    dHf_298   -718840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1574.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=363020.0
    phase     gas;
}
