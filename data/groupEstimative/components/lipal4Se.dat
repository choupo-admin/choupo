/*--------------------------------*- Choupo -*-----------------------*\
  Component: lipal 4 se  (C36H72O11, CAS 5349-52-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lipal4Se;
formula     C36H72O11;
CAS         5349-52-0;
InChIKey    XPHIURAKMYNURA-UHFFFAOYSA-N;
MW          680.961;      // g/mol [origin=calculated method=formula-sum]
Tc          2143.54;      // K   [origin=predictive method=joback]
Pc          4.502;      // bar [origin=predictive method=joback]
omega       -0.4848;      // -   [origin=predictive method=lee-kesler]
Tb          1353.04;      // K   [origin=predictive method=joback]
HvapTb      139096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (204.864 2.89742 -0.0009824 -6.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 24; } { group CH2COO; count 1; } { group CH2O; count 7; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 34; } { group OH; count 1; } { group O; count 8; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-[2-[2-[2-(2-hydroxyethyloxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethyl octadecanoate" "nonaethylene glycol monostearate" "26-hydroxy-3,6,9,12,15,18,21,24-octaoxahexacos-1-yl stearate" "stearic acid, monoester with nonaethylene glycol" "stearic acid, monoester with nonaethylene glycol (8ci)" "octadecanoic acid,6,9,12,15,18,21,24-octaoxahexacos-1-yl ester" "octadecanoic acid 26-hydroxy-3,6,9,12,15,18,21,24-octaoxahexacos-1-yl ester" "octadecanoic acid,26-hydroxy-3,6,9,12,15,18,21,24-octaoxahexacos-1-yl ester" "2-[2-[2-[2-[2-[2-[2-[2-(2-hydroxyethoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethyl octadecanoate" );
standardThermochemistry
{
    dHf_298   -2313640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1750.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1034950.0
}
