/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,2-tetrabromoethane  (C2H2Br4, CAS 630-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1112Tetrabromoethane;
formula     C2H2Br4;
CAS         630-16-0;
InChIKey    RVHSTXJKKZWWDQ-UHFFFAOYSA-N;
MW          345.654;      // g/mol [origin=calculated method=formula-sum]
Tc          775.08;      // K   [origin=predictive method=joback]
Pc          80.436;      // bar [origin=predictive method=joback]
omega       0.5156;      // -   [origin=predictive method=lee-kesler]
Tb          506.77;      // K   [origin=predictive method=joback]
HvapTb      44490.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.361 0.4724 -0.0005424 2.209e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C; count 1; } { group Br; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group Br; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2-tetrakis(bromanyl)ethane" "tetrabromoethane" "ethane, 1,1,1,2-tetrabromo-" "halogenated ethanes cs (1,1, 1,2-tetrabromoethane)" "1,1,1,2-tetrabromoethane (seealso halogenated ethanes cs (1,1,1,2-tetrabromoethane))" );
standardThermochemistry
{
    dHf_298   11960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26080.0
}
