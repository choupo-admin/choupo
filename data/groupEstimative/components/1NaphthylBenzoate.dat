/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthyl benzoate  (C17H12O2, CAS 607-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1NaphthylBenzoate;
formula     C17H12O2;
CAS         607-55-6;
InChIKey    KZWCTFLBFSWYHS-UHFFFAOYSA-N;
MW          248.281;      // g/mol [origin=calculated method=formula-sum]
Tc          979.74;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.7372;      // -   [origin=predictive method=lee-kesler]
Tb          724.10;      // K   [origin=predictive method=joback]
HvapTb      67697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.11 1.343 -0.00093848 2.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 12; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-1-yl benzoate" "1-naphthalenol, benzoate" "1-naphthol, benzoate" "1-naphthalenol,1-benzoate" "brd-k26027170-001-01-0" );
standardThermochemistry
{
    dHf_298   -58830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103730.0
}
