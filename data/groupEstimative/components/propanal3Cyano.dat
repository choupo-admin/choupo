/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanal, 3-cyano-  (C4H5NO, CAS 3515-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanal3Cyano;
formula     C4H5NO;
CAS         3515-93-3;
InChIKey    CGFGIKNLZTZJDE-UHFFFAOYSA-N;
MW          83.09;      // g/mol [origin=calculated method=formula-sum]
Tc          641.11;      // K   [origin=predictive method=joback]
Pc          41.463;      // bar [origin=predictive method=joback]
omega       0.5272;      // -   [origin=predictive method=lee-kesler]
Tb          441.86;      // K   [origin=predictive method=joback]
HvapTb      41696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.652 0.2931 -0.0001558 2.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group OdCH_al; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidenebutanenitrile" "butanenitrile, 4-oxo-" "3-formylpropiononitrile" "4-oxobutanenitrile" "3-cyanopropanal" "b-cyanopropionaldehyde;3-cyanopropanal;4-oxobutanenitrile" "propionaldehyde,3-cyano- (6ci,7ci); succinaldehydonitrile (8ci); 3-cyanopropanal;3-cyanopropionaldehyde; 3-formylpropionitrile; 4-oxobutanenitrile;4-oxobutyronitrile; b-cyanopropionaldehyde; b-cyanopropionic aldehyde" );
standardThermochemistry
{
    dHf_298   -46590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     336.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16460.0
}
