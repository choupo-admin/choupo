/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-undecene  (C12H24, CAS 18516-37-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Undecene;
formula     C12H24;
CAS         18516-37-5;
InChIKey    SJVKHZYVCVKEGM-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          637.53;      // K   [origin=predictive method=joback]
Pc          18.531;      // bar [origin=predictive method=joback]
omega       0.5414;      // -   [origin=predictive method=lee-kesler]
Tb          470.72;      // K   [origin=predictive method=joback]
HvapTb      41716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.702 1.12374 -0.0006542 1.508e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylundec-1-ene" "1-undecene, 2-methyl-" "2-methyl-undec-1-ene" );
gibbsFormation
{
    dHf_298   -175370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129450.0
    phase     gas;
}
