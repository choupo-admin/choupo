/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclandelate  (C17H24O3, CAS 456-59-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclandelate;
formula     C17H24O3;
CAS         456-59-7;
InChIKey    WZHCOOQXZCIUNC-UHFFFAOYSA-N;
MW          276.376;      // g/mol [origin=calculated method=formula-sum]
Tc          992.42;      // K   [origin=predictive method=joback]
Pc          20.109;      // bar [origin=predictive method=joback]
omega       1.0505;      // -   [origin=predictive method=lee-kesler]
Tb          775.65;      // K   [origin=predictive method=joback]
HvapTb      78070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.17 1.88606 -0.001374 4.2e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3,3,5-trimethylcyclohexyl) 2-oxidanyl-2-phenyl-ethanoate" "cyclospasmol" "capilan" "ciclandelato" "ciclospasmol" "cyclandelatum" "cyclomandol" "spasmocyclon" "spasmocyclone" "clandilon" "cyclolyt" "dilatan" );
gibbsFormation
{
    dHf_298   -603590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-241420.0
    phase     gas;
}
