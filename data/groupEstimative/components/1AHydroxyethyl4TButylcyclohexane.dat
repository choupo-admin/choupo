/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(|a-hydroxyethyl)-4-t-butylcyclohexane  (C12H24O, CAS 63767-87-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1AHydroxyethyl4TButylcyclohexane;
formula     C12H24O;
CAS         63767-87-3;
InChIKey    FNBYRKVLUFZUKN-UHFFFAOYSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          773.32;      // K   [origin=predictive method=joback]
Pc          23.136;      // bar [origin=predictive method=joback]
omega       0.7438;      // -   [origin=predictive method=lee-kesler]
Tb          577.55;      // K   [origin=predictive method=joback]
HvapTb      57421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.55 1.40518 -0.00086 1.942e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-tert-butylcyclohexyl)ethanol" "1-(alpha-hydroxyethyl)-4-t-butylcyclohexane" "4-(1,1-dimethylethyl)-alpha-methylcyclohexylmethanol" "cis-4-(1,1-dimethylethyl)-alpha-methylcyclohexylmethanol" "cyclohexanemethanol, 4-(1,1-dimethylethyl)-.alpha.-methyl-" "cyclohexanemethanol, 4-(1,1-dimethylethyl)-alpha-methyl-" );
standardThermochemistry
{
    dHf_298   -423290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69520.0
}
