/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-hexadecylcyclopentane  (C21H42, CAS 6812-39-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nHexadecylcyclopentane;
formula     C21H42;
CAS         6812-39-1;
InChIKey    YUMSFAHUVUYTKV-UHFFFAOYSA-N;
MW          294.567;      // g/mol [origin=calculated method=formula-sum]
Tc          870.07;      // K   [origin=predictive method=joback]
Pc          10.722;      // bar [origin=predictive method=joback]
omega       0.7966;      // -   [origin=predictive method=lee-kesler]
Tb          695.36;      // K   [origin=predictive method=joback]
HvapTb      62597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.685 2.13052 -0.001246 2.782e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecylcyclopentane" "cyclopentane, hexadecyl-" );
gibbsFormation
{
    dHf_298   -416290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     923.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=162490.0
    phase     gas;
}
