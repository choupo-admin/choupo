/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethylcyclopropene  (C5H8, CAS 3907-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethylcyclopropene;
formula     C5H8;
CAS         3907-06-0;
InChIKey    ZHYHTHWCDOOOJU-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          509.20;      // K   [origin=predictive method=joback]
Pc          45.225;      // bar [origin=predictive method=joback]
omega       0.1863;      // -   [origin=predictive method=lee-kesler]
Tb          320.14;      // K   [origin=predictive method=joback]
HvapTb      25778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.11 0.86564 -0.00098828 4.498e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropene, 3,3-dimethyl-" );
gibbsFormation
{
    dHf_298   -710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     292.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76440.0
    phase     gas;
}
