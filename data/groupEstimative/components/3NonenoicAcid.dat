/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-nonenoic acid  (C9H16O2, CAS 4124-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3NonenoicAcid;
formula     C9H16O2;
CAS         4124-88-3;
InChIKey    ZBPYTVBKHKUNHG-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          745.78;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.7976;      // -   [origin=predictive method=lee-kesler]
Tb          555.19;      // K   [origin=predictive method=joback]
HvapTb      52750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.875 0.92962 -0.0006222 1.713e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-3-enoic acid" "3-nonenic acid" );
standardThermochemistry
{
    dHf_298   -462140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238790.0
}
