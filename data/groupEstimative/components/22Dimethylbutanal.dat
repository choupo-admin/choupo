/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylbutanal  (C6H12O, CAS 2094-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylbutanal;
formula     C6H12O;
CAS         2094-75-9;
InChIKey    QYPLKDUOPJZROX-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          566.47;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.3565;      // -   [origin=predictive method=lee-kesler]
Tb          382.31;      // K   [origin=predictive method=joback]
HvapTb      34374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.639 0.67416 -0.0004674 1.3e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanal, 2,2-dimethyl-" "2,2-dimethyl-butyraldehyde" "butyraldehyde,2,2-dimethyl- (7ci,8ci); 2,2-dimethylbutanal; 2,2-dimethylbutyraldehyde" );
standardThermochemistry
{
    dHf_298   -261500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97040.0
}
