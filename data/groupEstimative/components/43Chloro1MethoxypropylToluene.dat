/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(3-chloro-1-methoxypropyl)toluene  (C11H15ClO, CAS 6968-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        43Chloro1MethoxypropylToluene;
formula     C11H15ClO;
CAS         6968-70-3;
InChIKey    BRGBFUVDFKKJQK-UHFFFAOYSA-N;
MW          198.69;      // g/mol [origin=calculated method=formula-sum]
Tc          753.44;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       0.5394;      // -   [origin=predictive method=lee-kesler]
Tb          542.35;      // K   [origin=predictive method=joback]
HvapTb      49425.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.992 0.85994 -0.00045136 7.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-chloranyl-1-methoxy-propyl)-4-methyl-benzene" "1-(3-chloro-1-methoxypropyl)-4-methylbenzene" "3-methoxy-3-(4-tolyl)-propyl chloride" "benzene, 1-(3-chloro-1-methoxypropyl)-4-methyl-" "benzene,1-(3-chloro-1-methoxypropyl)-4-methyl-" );
gibbsFormation
{
    dHf_298   -198550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25150.0
    phase     gas;
}
