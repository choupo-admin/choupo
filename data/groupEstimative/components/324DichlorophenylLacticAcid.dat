/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2,4-dichlorophenyl)lactic acid  (C9H8Cl2O3, CAS 68921-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        324DichlorophenylLacticAcid;
formula     C9H8Cl2O3;
CAS         68921-92-6;
InChIKey    NBORNXKEEFIAMC-UHFFFAOYSA-N;
MW          235.06;      // g/mol [origin=calculated method=formula-sum]
Tc          973.78;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       1.3599;      // -   [origin=predictive method=lee-kesler]
Tb          754.27;      // K   [origin=predictive method=joback]
HvapTb      81453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.391 0.7652 -0.00050992 1.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group OH; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2,4-dichlorophenyl)-2-oxidanyl-propanoic acid" "3-(2,4-dichlorophenyl)-2-hydroxypropanoic acid" "benzenepropanoic acid,2,4-dichloro-a-hydroxy-" "benzenepropanoic acid, 2,4-dichloro-alpha-hydroxy-" "benzenepropanoic acid, 2,4-dichloro-.alpha.-hydroxy-" );
standardThermochemistry
{
    dHf_298   -554760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-388980.0
}
