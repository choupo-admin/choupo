/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethyltetradecane  (C16H34, CAS 18435-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethyltetradecane;
formula     C16H34;
CAS         18435-23-9;
InChIKey    ZQRVEWIJXCRTFW-UHFFFAOYSA-N;
MW          226.448;      // g/mol [origin=calculated method=formula-sum]
Tc          728.71;      // K   [origin=predictive method=joback]
Pc          13.339;      // bar [origin=predictive method=joback]
omega       0.6871;      // -   [origin=predictive method=lee-kesler]
Tb          564.80;      // K   [origin=predictive method=joback]
HvapTb      50434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.02 1.53568 -0.000853 1.782e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -384130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     760.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78960.0
    phase     gas;
}
