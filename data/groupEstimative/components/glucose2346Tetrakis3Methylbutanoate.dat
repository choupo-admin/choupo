/*--------------------------------*- Choupo -*-----------------------*\
  Component: glucose, 2,3,4,6-tetrakis(3-methylbutanoate)  (C26H44O10, CAS 63512-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glucose2346Tetrakis3Methylbutanoate;
formula     C26H44O10;
CAS         63512-39-0;
InChIKey    WBUNPXFRBBHRLC-UHFFFAOYSA-N;
MW          516.628;      // g/mol [origin=calculated method=formula-sum]
Tc          1472.27;      // K   [origin=predictive method=joback]
Pc          8.334;      // bar [origin=predictive method=joback]
omega       0.5106;      // -   [origin=predictive method=lee-kesler]
Tb          1164.68;      // K   [origin=predictive method=joback]
HvapTb      123393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (84.125 2.31046 -0.0010612 7.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 1; } { group CH; count 8; } { group OH; count 1; } { group CHO; count 1; } { group CH2COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 5; } { group CH; count 8; } { group OH; count 1; } { group OdCH_al; count 1; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,4,5-tris(3-methylbutanoyloxy)-2-oxidanyl-6-oxidanylidene-hexyl] 3-methylbutanoate" "2,3,4,6-tetrakis-o-(3-methylbutanoyl)hexose" "[2-hydroxy-3,4,5-tris(3-methylbutanoyloxy)-6-oxohexyl] 3-methylbutanoate" "[(2r,3r,4s,5r)-2-hydroxy-3,4,5-tris(3-methylbutanoyloxy)-6-oxohexyl] 3-methylbutanoate" );
gibbsFormation
{
    dHf_298   -2129140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1367.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1329300.0
    phase     gas;
}
