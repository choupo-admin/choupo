/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl bicyclo(2.2.1)heptane-1-carboxylate  (C9H14O2, CAS 2287-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylBicyclo221Heptane1Carboxylate;
formula     C9H14O2;
CAS         2287-57-2;
InChIKey    ICBCULSDMSBNNZ-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          696.58;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.4476;      // -   [origin=predictive method=lee-kesler]
Tb          481.73;      // K   [origin=predictive method=joback]
HvapTb      41882.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.48 1.38812 -0.0012978 5.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl bicyclo[2.2.1]heptane-4-carboxylate" "bicyclo[2.2.1]heptan-1-carboxylic acid, methyl ester" "bicyclo[2.2.1]heptane-1-carboxylicacid, methyl ester" "1-norbornanecarboxylicacid, methyl ester (6ci,7ci,8ci)" );
gibbsFormation
{
    dHf_298   -391690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181560.0
    phase     gas;
}
