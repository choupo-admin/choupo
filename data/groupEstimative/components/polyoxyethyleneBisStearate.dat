/*--------------------------------*- Choupo -*-----------------------*\
  Component: polyoxyethylene bis(stearate)  (C19H40O4, CAS 9005-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polyoxyethyleneBisStearate;
formula     C19H40O4;
CAS         9005-08-7;
InChIKey    QYJQHDWGURXGNL-UHFFFAOYSA-N;
MW          332.525;      // g/mol [origin=calculated method=formula-sum]
Tc          1191.54;      // K   [origin=predictive method=joback]
Pc          12.251;      // bar [origin=predictive method=joback]
omega       1.0565;      // -   [origin=predictive method=lee-kesler]
Tb          965.59;      // K   [origin=predictive method=joback]
HvapTb      108704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.617 1.72142 -0.0007284 4.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group COOH; count 1; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;heptadecanoic acid" "poly(ethylene glycol) distearate" "ethylene glycol; heptadecanoic acid" "poly(oxy-1,2-ethanediyl), ?-(1-oxooctadecyl)- ?-[(1-oxooctadecyl)oxy]-" );
standardThermochemistry
{
    dHf_298   -1201840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1158.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-613210.0
}
