/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl valerate  (C8H16O2, CAS 18362-97-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylValerate;
formula     C8H16O2;
CAS         18362-97-5;
InChIKey    OCAIYHCKLADPEG-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          615.93;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       0.5159;      // -   [origin=predictive method=lee-kesler]
Tb          440.42;      // K   [origin=predictive method=joback]
HvapTb      40421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.343 0.71496 -0.00032 2.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl pentanoate" "valeric acid, isopropyl ester" "pentanoic acid, 1-methylethyl ester" "pentanoic acid,1-methylethyl ester" "valericacid, isopropyl ester (8ci);isopropyl pentanoate;isopropyl valerate;" );
standardThermochemistry
{
    dHf_298   -531010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296330.0
}
