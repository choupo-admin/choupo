/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetylsalicylsalicylic acid  (C16H12O6, CAS 530-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetylsalicylsalicylicAcid;
formula     C16H12O6;
CAS         530-75-6;
InChIKey    DDSFKIFGAPZBSR-UHFFFAOYSA-N;
MW          300.266;      // g/mol [origin=calculated method=formula-sum]
Tc          1130.93;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       1.2794;      // -   [origin=predictive method=lee-kesler]
Tb          890.95;      // K   [origin=predictive method=joback]
HvapTb      89064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.55 1.18822 -0.00065832 9.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH3COO; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-acetyloxyphenyl)carbonyloxybenzoic acid" "salicylacetylsalicylic acid" "2-((2-acetoxybenzoyl)oxy)benzoic acid" "2-carboxyphenyl o-acetylsalicylate" "benzoic acid, 2-(acetyloxy)-, 2-carboxyphenyl ester" "2-carboxyphenyl 2-(acetyloxy)benzoate" "prestwick_544" "diplosalacetat" "acesalum" "diplosal acetate" "aspirin impurity d" "2-(2-acetyloxybenzoyl)oxybenzoic acid" );
standardThermochemistry
{
    dHf_298   -908280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     709.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-675250.0
}
