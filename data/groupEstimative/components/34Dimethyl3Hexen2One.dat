/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethyl-3-hexen-2-one  (C8H14O, CAS 1635-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethyl3Hexen2One;
formula     C8H14O;
CAS         1635-02-5;
InChIKey    WRHRFVOAEDXVPC-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          631.69;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.4348;      // -   [origin=predictive method=lee-kesler]
Tb          440.43;      // K   [origin=predictive method=joback]
HvapTb      40266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.589 0.75568 -0.0004811 1.2596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethylhex-3-en-2-one" "3-hexen-2-one,3,4-dimethyl-" );
standardThermochemistry
{
    dHf_298   -223390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49320.0
}
