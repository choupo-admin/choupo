/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isocyanatoethylbenzene  (C9H9NO, CAS 33375-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isocyanatoethylbenzene;
formula     C9H9NO;
CAS         33375-06-3;
InChIKey    JJSCUXAFAJEQGB-UHFFFAOYSA-N;
MW          147.177;      // g/mol [origin=calculated method=formula-sum]
Tc          721.03;      // K   [origin=predictive method=joback]
Pc          35.899;      // bar [origin=predictive method=joback]
omega       0.4834;      // -   [origin=predictive method=lee-kesler]
Tb          498.43;      // K   [origin=predictive method=joback]
HvapTb      47048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCd; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "alpha-methylbenzyl isocyanate" "1-phenylethanisocyanate" "(1-isocyanatoethyl)benzene" "(1-isocyanato-ethyl)-benzene" "benzene,(1-isocyanatoethyl)-" "benzene, (1-isocyanatoethyl)-" "jjscuxafajeqgb-uhfffaoysa-" "r-(+)-?methylbenzyl isocyanate" "s-(-)-?methylbenzyl isocyanate" "(+)-.alpha.-phenethyl isocyanate" "r-(+)-alpha-methylbenzyl isocyanate" "s-(-)-alpha-methylbenzyl isocyanate" );
