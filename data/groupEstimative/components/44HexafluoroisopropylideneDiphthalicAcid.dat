/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-(hexafluoroisopropylidene)diphthalic acid  (C19H10F6O8, CAS 3016-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44HexafluoroisopropylideneDiphthalicAcid;
formula     C19H10F6O8;
CAS         3016-76-0;
InChIKey    APXJLYIVOFARRM-UHFFFAOYSA-N;
MW          480.269;      // g/mol [origin=calculated method=formula-sum]
Tc          1567.59;      // K   [origin=predictive method=joback]
Pc          18.953;      // bar [origin=predictive method=joback]
omega       1.4943;      // -   [origin=predictive method=lee-kesler]
Tb          1275.57;      // K   [origin=predictive method=joback]
HvapTb      124954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.47 2.0644 -0.00170824 5.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 6; } { group AC; count 6; } { group COOH; count 4; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group F; count 6; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(3,4-dicarboxyphenyl)-1,1,1,3,3,3-hexakis(fluoranyl)propan-2-yl]phthalic acid" "4,4'-(perfluoropropane-2,2-diyl)diphthalic acid" "4,4'-(1,1,1,3,3,3-hexafluoro-2,2-propanediyl)diphthalic acid" "4-[2-(3,4-dicarboxyphenyl)-1,1,1,3,3,3-hexafluoropropan-2-yl]phthalic acid" "1,2-benzenedicarboxylic acid, 4,4'-(2,2,2-trifluoro-1-(trifluoromethyl)ethylidene)bis-" "1,2-benzenedicarboxylic acid, 4,4'-[2,2,2-trifluoro-1-(trifluoromethyl)ethylidene]bis-" "4,4'-(2,2,2-trifluoro-1-(trifluoromethyl)ethylidene)bisphthalic acid" "4,4'-(hexafluoroisopropylidene)bisphthalic acid" "1,2-benzenedicarboxylicacid, 4,4'-[2,2,2-trifluoro-1-(trifluoromethyl)ethylidene]bis-" "phthalicacid, 4,4'-[2,2,2-trifluoro-1-(trifluoromethyl)ethylidene]di- (7ci);phthalicacid, 4,4'-[trifluoro-1-(trifluoromethyl)ethylidene]di- (8ci);2,2-bis(3,4-dicarboxyphenyl)hexafluoropropane;2,2-bis(3,4-dicarboxyphenyl)perfluoropropane;4,4'-hexafluoroisopropylidenebis(phthalic acid);" );
gibbsFormation
{
    dHf_298   -2612300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     944.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2240580.0
    phase     gas;
}
