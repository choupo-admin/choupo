/*--------------------------------*- Choupo -*-----------------------*\
  Component: 17-methyltritriacontane  (C34H70, CAS 58349-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Methyltritriacontane;
formula     C34H70;
CAS         58349-88-5;
InChIKey    MKCKYDLYUUOTRB-UHFFFAOYSA-N;
MW          478.934;      // g/mol [origin=calculated method=formula-sum]
Tc          1227.02;      // K   [origin=predictive method=joback]
Pc          4.996;      // bar [origin=predictive method=joback]
omega       0.1602;      // -   [origin=predictive method=lee-kesler]
Tb          977.08;      // K   [origin=predictive method=joback]
HvapTb      90890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.7 3.23976 -0.001829 3.929e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 30; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 30; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(s)17-methyl-tritriacontane" "tritriacontane, 17-methyl-" );
gibbsFormation
{
    dHf_298   -750370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1470.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232960.0
    phase     gas;
}
