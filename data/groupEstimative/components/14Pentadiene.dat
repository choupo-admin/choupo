/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-pentadiene  (C5H8, CAS 591-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Pentadiene;
formula     C5H8;
CAS         591-93-5;
InChIKey    QYZLKGVUSQXAMU-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          476.96;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.2164;      // -   [origin=predictive method=lee-kesler]
Tb          307.36;      // K   [origin=predictive method=joback]
HvapTb      25384.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.639 0.4388 -0.000294 8.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "penta-1,4-diene" );
standardThermochemistry
{
    dHf_298   104330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166900.0
}
