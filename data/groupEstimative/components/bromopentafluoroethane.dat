/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromopentafluoroethane  (C2BrF5, CAS 354-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromopentafluoroethane;
formula     C2BrF5;
CAS         354-55-2;
InChIKey    USYVEDJTMCGMKN-UHFFFAOYSA-N;
MW          198.916;      // g/mol [origin=calculated method=formula-sum]
Tc          459.07;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.3204;      // -   [origin=predictive method=lee-kesler]
Tb          301.41;      // K   [origin=predictive method=joback]
HvapTb      19804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.23 0.5426 -0.000582 2.185e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group F; count 5; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-1,1,2,2,2-pentakis(fluoranyl)ethane" "ethane, bromopentafluoro-" "1-bromo-1,1,2,2,2-pentafluoroethane" "2-bromo-1,1,1,2,2-pentafluoroethane" "ethane,1-bromo-1,1,2,2,2-pentafluoro-" "ethane,bromopentafluoro- (6ci,7ci,8ci,9ci);bromopentafluoroethane;pentafluoroethylbromide;perfluoroethyl bromide;" );
standardThermochemistry
{
    dHf_298   -1056330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-988090.0
}
