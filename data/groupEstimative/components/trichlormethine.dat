/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichlormethine  (C6H12Cl3N, CAS 555-77-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichlormethine;
formula     C6H12Cl3N;
CAS         555-77-1;
InChIKey    FDAYLTPAFBGXAB-UHFFFAOYSA-N;
MW          204.519;      // g/mol [origin=calculated method=formula-sum]
Tc          646.55;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.5394;      // -   [origin=predictive method=lee-kesler]
Tb          461.61;      // K   [origin=predictive method=joback]
HvapTb      44148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.416 0.7181 -0.0004764 1.246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2N; count 1; } { group CH2Cl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Cl; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n,n-bis(2-chloroethyl)ethanamine" "sinalost base" "trimitan base" "tris(2-chloroethyl)amine" "trimustine" "2-chloro-n,n-bis(2-chloroethyl)ethanamine" "agent hn3" "ethanamine, 2-chloro-n,n-bis(2-chloroethyl)-" "tri-(2-chloroethyl)amine" "nitrogen mustard (hn-3)" "tris(beta-chloroethyl)amine" "trichlomethine" );
gibbsFormation
{
    dHf_298   -146860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74630.0
    phase     gas;
}
