/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4,5-tetrachloro-3-iodobenzene  (C6HCl4I, CAS 32770-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1245Tetrachloro3Iodobenzene;
formula     C6HCl4I;
CAS         32770-82-4;
InChIKey    OUOGYOBZKZJEQN-UHFFFAOYSA-N;
MW          341.774;      // g/mol [origin=calculated method=formula-sum]
Tc          905.78;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.4731;      // -   [origin=predictive method=lee-kesler]
Tb          626.34;      // K   [origin=predictive method=joback]
HvapTb      60787.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (83.98 0.3231 -0.00022864 6.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group ACCl; count 4; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 4; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetrakis(chloranyl)-3-iodanyl-benzene" "2,3,5,6-tetrachloroiodobenzene" "benzene, 1,2,4,5-tetrachloro-3-iodo-" );
standardThermochemistry
{
    dHf_298   37390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83930.0
}
