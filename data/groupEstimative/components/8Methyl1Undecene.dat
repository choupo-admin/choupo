/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methyl-1-undecene  (C12H24, CAS 74630-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methyl1Undecene;
formula     C12H24;
CAS         74630-40-3;
InChIKey    KUIGECHVOHJTNQ-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          637.73;      // K   [origin=predictive method=joback]
Pc          18.579;      // bar [origin=predictive method=joback]
omega       0.5366;      // -   [origin=predictive method=lee-kesler]
Tb          470.40;      // K   [origin=predictive method=joback]
HvapTb      41248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.693 1.12974 -0.0006551 1.485e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methylundec-1-ene" "1-undecene, 8-methyl-" );
gibbsFormation
{
    dHf_298   -170860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135560.0
    phase     gas;
}
