/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetaldehyde, diethyl mercaptal  (C6H14S2, CAS 14252-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetaldehydeDiethylMercaptal;
formula     C6H14S2;
CAS         14252-42-7;
InChIKey    CIYDRAJJTMIKGP-UHFFFAOYSA-N;
MW          150.298;      // g/mol [origin=calculated method=formula-sum]
Tc          691.35;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       0.4040;      // -   [origin=predictive method=lee-kesler]
Tb          474.00;      // K   [origin=predictive method=joback]
HvapTb      42196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.952 0.56854 -0.0002254 4.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(ethylsulfanyl)ethane" "ethane, 1,1-bis(ethylthio)-" "acetaldehyde diethyl mercaptal" "ethane,1-bis(ethylthio)-" "formaldehyde diethylthioacetal" "4-methyl-3,5-dithiaheptane" "ethane,1,1-bis(ethylthio)-" );
standardThermochemistry
{
    dHf_298   -88710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63440.0
}
