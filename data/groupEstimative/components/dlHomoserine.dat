/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-homoserine  (C4H9NO3, CAS 1927-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlHomoserine;
formula     C4H9NO3;
CAS         1927-25-9;
InChIKey    UKAUYVFTDYCKQA-UHFFFAOYSA-N;
MW          119.12;      // g/mol [origin=calculated method=formula-sum]
Tc          797.05;      // K   [origin=predictive method=joback]
Pc          54.385;      // bar [origin=predictive method=joback]
omega       1.3279;      // -   [origin=predictive method=lee-kesler]
Tb          600.90;      // K   [origin=predictive method=joback]
HvapTb      68594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.952 0.5364 -0.0003434 8.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-oxidanyl-butanoic acid" "homoserine" "dl-2-amino-4-hydroxybutyric acid" "2-amino-4-hydroxybutanoic acid" "butyric acid, 2-amino-4-hydroxy-, dl-" "h-dl-hoser-oh" "dl -2-amino-4-hydroxybutyric acid" "u723" "a6f72b1b-294b-4295-bf49-79f879f4ff2b" );
gibbsFormation
{
    dHf_298   -599880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-433920.0
    phase     gas;
}
