/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydro-3-ethyl-6-methyl-1h-cyclopenta(a)anthracene  (C20H20, CAS 5096-24-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dihydro3Ethyl6Methyl1hCyclopentaAAnthracene;
formula     C20H20;
CAS         5096-24-2;
InChIKey    LCRYYWPJVUWCSS-UHFFFAOYSA-N;
MW          260.38;      // g/mol [origin=calculated method=formula-sum]
Tc          989.51;      // K   [origin=predictive method=joback]
Pc          19.806;      // bar [origin=predictive method=joback]
omega       0.7490;      // -   [origin=predictive method=lee-kesler]
Tb          748.50;      // K   [origin=predictive method=joback]
HvapTb      68231.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.129 1.73044 -0.00132088 4.142e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 7; } { group AC; count 4; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-6-methyl-2,3-dihydro-1h-cyclopenta[a]anthracene" "1h-cyclopent(a)anthracene, 3-ethyl-2,3-dihydro-6-methyl-" "1h-cyclopent[a]anthracene,3-ethyl-2,3-dihydro-6-methyl-" "2,3-dihydro-3-ethyl-6-methyl-cyclopenta[a]-anthracene" );
standardThermochemistry
{
    dHf_298   189460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=465460.0
}
