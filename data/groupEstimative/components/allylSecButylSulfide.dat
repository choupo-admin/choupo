/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl sec-butyl sulfide  (C7H14S, CAS 70289-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylSecButylSulfide;
formula     C7H14S;
CAS         70289-07-5;
InChIKey    QLCUOCVKHIAUIL-UHFFFAOYSA-N;
MW          130.249;      // g/mol [origin=calculated method=formula-sum]
Tc          620.74;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.3636;      // -   [origin=predictive method=lee-kesler]
Tb          424.78;      // K   [origin=predictive method=joback]
HvapTb      36935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.452 0.64913 -0.0003429 6.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enylsulfanylbutane" "sulfide, allyl sec-butyl," "5-methyl-4-thia-1-heptene" "allyl-sec-butyl sulfide" "2-(prop-2-en-1-ylsulfanyl)butane" );
standardThermochemistry
{
    dHf_298   -25790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126580.0
}
