/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propanone, 1,3,3-triphenyl-  (C21H18O, CAS 606-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propanone133Triphenyl;
formula     C21H18O;
CAS         606-86-0;
InChIKey    WYRBITQXPQGTBL-UHFFFAOYSA-N;
MW          286.374;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.84;      // K   [origin=predictive method=joback]
Pc          21.236;      // bar [origin=predictive method=joback]
omega       0.8039;      // -   [origin=predictive method=lee-kesler]
Tb          813.55;      // K   [origin=predictive method=joback]
HvapTb      75526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.239 1.74 -0.0011967 3.0566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 2; } { group ACCH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,3-triphenylpropan-1-one" "propiophenone, 3,3-diphenyl-" "3,3-diphenylpropiophenone" "1,3,3-triphenyl-1-propanone" "propiophenone,3-diphenyl-" "1-propanone,3,3-triphenyl-" "1,3,3-triphenyl-propan-1-one" "1-propanone,1,3,3-triphenyl-" );
standardThermochemistry
{
    dHf_298   114960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=331810.0
}
