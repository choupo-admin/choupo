/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-cumylphenyl acetate  (C17H18O2, CAS 24133-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pCumylphenylAcetate;
formula     C17H18O2;
CAS         24133-73-1;
InChIKey    AWLNMOJGJLOVGR-UHFFFAOYSA-N;
MW          254.329;      // g/mol [origin=calculated method=formula-sum]
Tc          942.63;      // K   [origin=predictive method=joback]
Pc          21.061;      // bar [origin=predictive method=joback]
omega       0.6685;      // -   [origin=predictive method=lee-kesler]
Tb          701.89;      // K   [origin=predictive method=joback]
HvapTb      64761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.14 1.47256 -0.00097356 2.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-phenylpropan-2-yl)phenyl] ethanoate" "4-(1-methyl-1-phenylethyl)phenyl acetate" "phenol, 4-(1-methyl-1-phenylethyl)-, acetate" "phenol, 4-(1-methyl-1-phenylethyl)-, 1-acetate" "phenol,.alpha.-dimethylbenzyl)-, acetate" "[4-(2-phenylpropan-2-yl)phenyl] acetate" "phenol, p-(alpha,alpha-dimethylbenzyl)-, acetate" );
gibbsFormation
{
    dHf_298   -258650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80.0
    phase     gas;
}
