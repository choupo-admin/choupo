/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxopentanoic acid  (C5H8O3, CAS 1821-02-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxopentanoicAcid;
formula     C5H8O3;
CAS         1821-02-9;
InChIKey    KDVFRMMRZOCFLS-UHFFFAOYSA-N;
MW          116.116;      // g/mol [origin=calculated method=formula-sum]
Tc          714.49;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.7797;      // -   [origin=predictive method=lee-kesler]
Tb          513.38;      // K   [origin=predictive method=joback]
HvapTb      50634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.302 0.50162 -0.0003021 6.726e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylidenepentanoic acid" "2-oxovaleric acid" "2-ketopentanoic acid" "2-oxopentanoate" "alpha-ketovaleric acid" "2-oxo-n-valeric acid" "2-ketovaleric acid" "2-keto valeric acid" "2-oxo-pentanoic acid" "2-oxovalerate" ".alpha.-keto-n-valeric acid" "2-ketopentanoate" );
standardThermochemistry
{
    dHf_298   -609380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-481610.0
}
