/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylene glycol monobenzoate  (C11H14O4, CAS 20587-61-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyleneGlycolMonobenzoate;
formula     C11H14O4;
CAS         20587-61-5;
InChIKey    DNUPYEDSAQDUSO-UHFFFAOYSA-N;
MW          210.229;      // g/mol [origin=calculated method=formula-sum]
Tc          843.41;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       1.1670;      // -   [origin=predictive method=lee-kesler]
Tb          650.78;      // K   [origin=predictive method=joback]
HvapTb      68852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.184 0.8859 -0.0004306 4.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethyloxy)ethyl benzoate" "diethylene glycol benzoate" "2-(2-hydroxyethoxy)ethyl benzoate" "diethylene glycol, monobenzoate" "ethanol, 2-[2-(benzoyloxy)ethoxy]-" "ethanol, 2-(2-(benzoyloxy)ethoxy)-" "ethanol, 2,2'-oxybis-, monobenzoate" "ethanol,2'-oxybis-, monobenzoate" "ethanol,2-[2-(benzoyloxy)ethoxy]-" "diethylene glycol monobenzoate; 2,2-(benzoyloxy)ethoxy-ethanol" );
standardThermochemistry
{
    dHf_298   -635570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-398040.0
}
