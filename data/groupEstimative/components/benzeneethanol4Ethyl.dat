/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneethanol,4-ethyl-  (C10H14O, CAS 22545-13-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneethanol4Ethyl;
formula     C10H14O;
CAS         22545-13-7;
InChIKey    RNUYBEOUXPOHNW-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          745.75;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.8598;      // -   [origin=predictive method=lee-kesler]
Tb          552.24;      // K   [origin=predictive method=joback]
HvapTb      57471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.517 0.84942 -0.00051476 1.182e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-ethylphenyl)ethanol" "4-ethylphenethyl alcohol" "2-(4-ethylphenyl)ethan-1-ol" "phenethylalcohol, p-ethyl- (6ci,8ci); 2-(4-ethylphenyl)ethanol; 4-ethylphenethylalcohol; p-ethylphenethyl alcohol" );
standardThermochemistry
{
    dHf_298   -176900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-720.0
}
