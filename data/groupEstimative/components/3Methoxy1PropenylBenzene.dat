/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-methoxy-1-propenyl)benzene  (C10H12O, CAS 16277-67-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy1PropenylBenzene;
formula     C10H12O;
CAS         16277-67-1;
InChIKey    XOURNDFHPYLQDJ-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          694.85;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.4287;      // -   [origin=predictive method=lee-kesler]
Tb          481.66;      // K   [origin=predictive method=joback]
HvapTb      42498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.789 0.83172 -0.0005242 1.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxyprop-1-enylbenzene" "benzene,(3-methoxy-1-propen-1-yl)-" "benzene,(3-methoxy-1-propenyl)- (9ci); ether, cinnamyl methyl (7ci,8ci);(3-methoxy-1-propenyl)benzene; 1-methoxy-3-phenyl-2-propene;1-phenyl-3-methoxy-1-propene; 3-methoxy-1-phenyl-1-propene;3-methoxy-1-phenylpropene; cinnamyl methyl ether" );
standardThermochemistry
{
    dHf_298   -28200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120950.0
}
