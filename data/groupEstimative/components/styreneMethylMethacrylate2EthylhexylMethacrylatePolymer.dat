/*--------------------------------*- Choupo -*-----------------------*\
  Component: styrene, methyl methacrylate, 2-ethylhexyl methacrylate polymer  (C25H38O4, CAS 60163-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        styreneMethylMethacrylate2EthylhexylMethacrylatePolymer;
formula     C25H38O4;
CAS         60163-90-8;
InChIKey    VSALQZDLJCHXDS-UHFFFAOYSA-N;
MW          402.575;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.91;      // K   [origin=predictive method=joback]
Pc          9.133;      // bar [origin=predictive method=joback]
omega       0.8028;      // -   [origin=predictive method=lee-kesler]
Tb          906.88;      // K   [origin=predictive method=joback]
HvapTb      86684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.675 1.7237 -0.0004251 -1.815e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;2-ethylhexyl 2-methylprop-2-enoate;methyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-ethylhexyl ester, polymer with ethenylbenzene and methyl 2-methyl-2-propenoate" "2-ethylhexyl 2-methylprop-2-enoate; methyl 2-methylprop-2-enoate; styrene" );
gibbsFormation
{
    dHf_298   -829170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1309.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-314250.0
    phase     gas;
}
