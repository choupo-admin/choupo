/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dithiocan-3-ol  (C6H12OS2, CAS 86944-00-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dithiocan3Ol;
formula     C6H12OS2;
CAS         86944-00-5;
InChIKey    WUMSAPPXLGVSSD-UHFFFAOYSA-N;
MW          164.281;      // g/mol [origin=calculated method=formula-sum]
Tc          790.22;      // K   [origin=predictive method=joback]
Pc          46.977;      // bar [origin=predictive method=joback]
omega       0.6625;      // -   [origin=predictive method=lee-kesler]
Tb          552.81;      // K   [origin=predictive method=joback]
HvapTb      58026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.48 0.73952 -0.0003586 3.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-dithiacyclooctan-3-ol" );
standardThermochemistry
{
    dHf_298   -186880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57210.0
}
