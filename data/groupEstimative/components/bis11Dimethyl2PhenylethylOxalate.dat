/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(1,1-dimethyl-2-phenylethyl) oxalate  (C22H26O4, CAS 70714-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis11Dimethyl2PhenylethylOxalate;
formula     C22H26O4;
CAS         70714-74-8;
InChIKey    JNQGUZHCDNTTRD-UHFFFAOYSA-N;
MW          354.446;      // g/mol [origin=calculated method=formula-sum]
Tc          1098.60;      // K   [origin=predictive method=joback]
Pc          14.568;      // bar [origin=predictive method=joback]
omega       0.9037;      // -   [origin=predictive method=lee-kesler]
Tb          866.30;      // K   [origin=predictive method=joback]
HvapTb      81340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.048 2.07808 -0.0013898 3.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group ACH; count 10; } { group ACCH2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-methyl-1-phenyl-propan-2-yl) ethanedioate" "bis(2-methyl-1-phenylpropan-2-yl) oxalate" "ethanedioic acid, bis(1,1-dimethyl-2-phenylethyl) ester" "ethanedioic acid, 1,2-bis(1,1-dimethyl-2-phenylethyl) ester" "bis(1,1-dimethyl-2-phenylethyl) ethanedioate" "ethanedioic acid,1,2-bis(1,1-dimethyl-2-phenylethyl) ester" "ethanedioicacid, bis(1,1-dimethyl-2-phenylethyl) ester (9ci)" );
gibbsFormation
{
    dHf_298   -676410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     824.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255880.0
    phase     gas;
}
