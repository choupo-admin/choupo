/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholest-5-en-3-ol (3.beta.)-, 11-bromoundecanoate  (C38H65BrO2, CAS 82962-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholest5En3Ol3Beta11Bromoundecanoate;
formula     C38H65BrO2;
CAS         82962-34-3;
InChIKey    DIPGSHTZYTZXEJ-UHFFFAOYSA-N;
MW          633.84;      // g/mol [origin=calculated method=formula-sum]
Tc          1526.26;      // K   [origin=predictive method=joback]
Pc          5.894;      // bar [origin=predictive method=joback]
omega       0.3860;      // -   [origin=predictive method=lee-kesler]
Tb          1231.46;      // K   [origin=predictive method=joback]
HvapTb      111485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-288.077 4.5535 -0.00349464 1.1554e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 20; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 13; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[10,13-dimethyl-17-(6-methylheptan-2-yl)-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] 11-bromanylundecanoate" "cholest-5-en-3-ol (3.beta.)-, 3-(11-bromoundecanoate)" );
gibbsFormation
{
    dHf_298   -852990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1426.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136870.0
    phase     gas;
}
