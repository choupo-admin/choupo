/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene, 2,3-dichloro-  (C4H4Cl2, CAS 1653-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiene23Dichloro;
formula     C4H4Cl2;
CAS         1653-19-6;
InChIKey    LIFLRQVHKGGNSG-UHFFFAOYSA-N;
MW          122.976;      // g/mol [origin=calculated method=formula-sum]
Tc          557.47;      // K   [origin=predictive method=joback]
Pc          39.956;      // bar [origin=predictive method=joback]
omega       0.2278;      // -   [origin=predictive method=lee-kesler]
Tb          359.10;      // K   [origin=predictive method=joback]
HvapTb      32088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.67 0.3572 -0.000285 9.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 2; } { group Cl_C=C_; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dC; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)buta-1,3-diene" "2,3-dichlorobuta-1,3-diene" "2,3-dichloro-1,3-butadiene" "2,3-dichlorobutadiene" "2,3-dichlorobutadiene-1,3" "2,3-dichlor-1,3-butadien" "1,3-butadiene, 2,3-dichloro-, homopolymer, brominated" "1,3-butadiene,2,3-dichloro-" "brominated poly(2,3-dichloro-1,3-butadiene)" "2,3-dichloro-1,3-butadiene;2,3-dichlorobuta-1,3-diyne; 2,3-dichlorobutadiene; 2,3-dichlorobutadiene-1,3;dichlorobutadiene" );
gibbsFormation
{
    dHf_298   73910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117520.0
    phase     gas;
}
