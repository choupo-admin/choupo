/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethylidene-2-norbornene  (C9H12, CAS 16219-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Ethylidene2Norbornene;
formula     C9H12;
CAS         16219-75-3;
InChIKey    OJOWICOBYCXEKR-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          638.40;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.3255;      // -   [origin=predictive method=lee-kesler]
Tb          429.07;      // K   [origin=predictive method=joback]
HvapTb      36705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.02 1.01752 -0.00081558 2.697e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethylidenebicyclo[2.2.1]hept-2-ene" "ethylidene-norbornene" "bicyclo[2.2.1]hept-2-ene,5-ethylidene-" "2-norbornene,5-ethylidene- (7ci,8ci); 5-ethylidene-2-norbornene;5-ethylidenebicyclo[2.2.1]hept-2-ene; ethylidenenorbornene" );
gibbsFormation
{
    dHf_298   44160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     280.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209720.0
    phase     gas;
}
