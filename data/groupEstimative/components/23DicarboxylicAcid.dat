/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dicarboxylic acid  (C9H8O4, CAS 15872-28-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DicarboxylicAcid;
formula     C9H8O4;
CAS         15872-28-3;
InChIKey    NRIMHVFWRMABGJ-UHFFFAOYSA-N;
MW          180.159;      // g/mol [origin=calculated method=formula-sum]
Tc          954.73;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       1.1847;      // -   [origin=predictive method=lee-kesler]
Tb          722.57;      // K   [origin=predictive method=joback]
HvapTb      71862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.54 1.0216 -0.00084548 2.792e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group COOH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]hepta-2,5-diene-2,3-dicarboxylic acid" "2,5-norbornadiene-2,3-dicarboxylic acid" "bicyclo(2.2.1)hepta-2,5-diene-2,3-dicarboxylic acid" "bicyclo[2.2.1]-2,5-heptadiene-2,3-dicarboxylic acid" "bicyclo(2.2.1)-2,5-heptadiene-2,3-dicarboxylic acid" "bicyclo[2.2.1]hepta-2,3-dicarboxylic acid" "bicyclo[2.2.1]hepta-2,5-diene-2,3-dicarboxylicacid" );
gibbsFormation
{
    dHf_298   -697570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-512860.0
    phase     gas;
}
