/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-dimethoxyethyl)dimethylamine  (C6H15NO2, CAS 38711-20-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DimethoxyethylDimethylamine;
formula     C6H15NO2;
CAS         38711-20-5;
InChIKey    HUYAEQCJNXODLQ-UHFFFAOYSA-N;
MW          133.191;      // g/mol [origin=calculated method=formula-sum]
Tc          561.65;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.4806;      // -   [origin=predictive method=lee-kesler]
Tb          393.72;      // K   [origin=predictive method=joback]
HvapTb      35425.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.061 0.57728 -0.0001964 -1.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethoxy-n,n-dimethyl-ethanamine" "ethanamine, 2,2-dimethoxy-n,n-dimethyl-" "dimethylaminoacetaldehyde dimethylacetal" "dimethylaminoacetaldehyde dimethyl acetal" "(dimethylamino)acetaldehyde dimethyl acetal" "2,2-dimethoxy-n,n-dimethylethanamin" "2,2-dimethoxy-n,n-dimethylethanamine" "2-(dimethylamino)acetaldehyde dimethylacetal" "2,2-dimethoxyethyl(dimethyl)amine" "n-(2,2-dimethoxyethyl)dimethylamine" "ethanamine,2,2-dimethoxy-n,n-dimethyl-" "acetaldehyde,(dimethylamino)-, dimethyl acetal (6ci,7ci);(dimethylamino)acetaldehydedimethyl acetal;1,1-dimethoxy-2-(dimethylamino)ethane;2,2-dimethoxy-n,n-dimethylethylamine;2-(dimethylamino)acetaldehyde dimethylacetal;" );
standardThermochemistry
{
    dHf_298   -369360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102020.0
}
