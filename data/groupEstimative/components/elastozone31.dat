/*--------------------------------*- Choupo -*-----------------------*\
  Component: elastozone 31  (C22H40N2, CAS 139-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        elastozone31;
formula     C22H40N2;
CAS         139-60-6;
InChIKey    JUHXTONDLXIGGK-UHFFFAOYSA-N;
MW          332.576;      // g/mol [origin=calculated method=formula-sum]
Tc          1032.33;      // K   [origin=predictive method=joback]
Pc          11.444;      // bar [origin=predictive method=joback]
omega       0.9520;      // -   [origin=predictive method=lee-kesler]
Tb          833.20;      // K   [origin=predictive method=joback]
HvapTb      78824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.864 2.13152 -0.00124716 2.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CHNH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n4-bis(5-methylheptan-3-yl)benzene-1,4-diamine" "eastozone 31" "santoflex 17" "tenamene 31" "uop 88" "1,4-benzenediamine, n,n'-bis(1-ethyl-3-methylpentyl)-" "n,n'-bis(5-methyl-3-heptyl)-p-phenylenediamine" "n,n'-bis(5-methylheptan-3-yl)benzene-1,4-diamine" "n,n'-di(1-ethyl-3-methylpentyl)-p-phenylenediamine" "n,n'-bis(1-ethyl-3-methylpentyl)-p-phenylenediamine" "p-phenylenediamine, n,n'-bis(1-ethyl-3-methylpentyl)-" "1,4-benzenediamine, n1,n4-bis(1-ethyl-3-methylpentyl)-" );
standardThermochemistry
{
    dHf_298   -186530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     943.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=406160.0
}
