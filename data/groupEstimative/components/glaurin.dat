/*--------------------------------*- Choupo -*-----------------------*\
  Component: glaurin  (C16H32O4, CAS 141-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glaurin;
formula     C16H32O4;
CAS         141-20-8;
InChIKey    WGIMXKDCVCTHGW-UHFFFAOYSA-N;
MW          288.428;      // g/mol [origin=calculated method=formula-sum]
Tc          908.80;      // K   [origin=predictive method=joback]
Pc          13.985;      // bar [origin=predictive method=joback]
omega       1.2062;      // -   [origin=predictive method=lee-kesler]
Tb          738.50;      // K   [origin=predictive method=joback]
HvapTb      77706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.544 1.43982 -0.0006714 7.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2COO; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethyloxy)ethyl dodecanoate" "diethylene glycol laurate" "diglycol laurate" "dodecanoic acid, 2-(2-hydroxyethoxy)ethyl ester" "lauro-sebum" "diethylene glycol monolaurate" "pegosperse 100l" "diglycol monolaurate" "peg-2 laurate" "emcol rdc-d" "diethylene glycol mono laurate" "diethylene glycol sesquilaurate" );
standardThermochemistry
{
    dHf_298   -975300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     892.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-468350.0
}
