/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2,2-diethoxyethyl)methylamine  (C13H29NO4, CAS 6948-86-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis22DiethoxyethylMethylamine;
formula     C13H29NO4;
CAS         6948-86-3;
InChIKey    DPLOXPRJCFWURN-UHFFFAOYSA-N;
MW          263.378;      // g/mol [origin=calculated method=formula-sum]
Tc          763.32;      // K   [origin=predictive method=joback]
Pc          15.747;      // bar [origin=predictive method=joback]
omega       0.9026;      // -   [origin=predictive method=lee-kesler]
Tb          598.28;      // K   [origin=predictive method=joback]
HvapTb      55439.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.016 1.1218 -0.0003584 -3.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group CH2O; count 4; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 2; } { group O; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2,2-diethoxyethyl)-2,2-diethoxy-n-methyl-ethanamine" "n-(2,2-diethoxyethyl)-2,2-diethoxy-n-methylethanamine" "n-[2,2-bis(ethyloxy)ethyl]-2,2-bis(ethyloxy)-n-methylethanamine" "dploxprjcfwurn-uhfffaoysa-" "ethanamine, n-(2,2-diethoxyethyl)-2,2-diethoxy-n-methyl-" "2,2 inverted exclamation marka-methyliminobis(acetaldehyde diethyl acetal)" );
gibbsFormation
{
    dHf_298   -783560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255520.0
    phase     gas;
}
