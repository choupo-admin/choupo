/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 2-bromobutanedioate  (C6H9BrO4, CAS 760-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl2Bromobutanedioate;
formula     C6H9BrO4;
CAS         760-90-7;
InChIKey    RGYMYJITHXYRMA-UHFFFAOYSA-N;
MW          225.038;      // g/mol [origin=calculated method=formula-sum]
Tc          719.87;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.7064;      // -   [origin=predictive method=lee-kesler]
Tb          519.04;      // K   [origin=predictive method=joback]
HvapTb      49811.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.761 0.50834 -0.000188 -2.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2COO; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-bromanylbutanedioate" "butanedioic acid, bromo-, dimethyl ester" "succinic acid, bromo-, dimethyl ester" "agn-pc-00kv54" );
gibbsFormation
{
    dHf_298   -780680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-609220.0
    phase     gas;
}
