/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1-indanone  (C10H10O, CAS 6072-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl1Indanone;
formula     C10H10O;
CAS         6072-57-7;
InChIKey    XVTQSYKCADSUHN-UHFFFAOYSA-N;
MW          146.189;      // g/mol [origin=calculated method=formula-sum]
Tc          775.05;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.4589;      // -   [origin=predictive method=lee-kesler]
Tb          534.62;      // K   [origin=predictive method=joback]
HvapTb      44952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.62 0.79802 -0.00046056 9.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2,3-dihydroinden-1-one" "3-methylindan-1-one" "3-methylindanone" "3-methyl-indan-1-one" "1h-inden-1-one, 2,3-dihydro-3-methyl-" "1-indanone, 3-methyl-" "3-methyl-2,3-dihydro-1h-inden-1-one" "3-methyl-2,3-dihydro-inden-1-one" "1h-inden-1-one,3-dihydro-3-methyl-" "2,3-dihydro-3-methyl-1h-inden-1-one" "2,3-dihydro-3-methyl-1-oxo-1h-indene" );
standardThermochemistry
{
    dHf_298   -89570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74260.0
}
