/*--------------------------------*- Choupo -*-----------------------*\
  Component: promethestrol  (C20H26O2, CAS 130-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        promethestrol;
formula     C20H26O2;
CAS         130-73-4;
InChIKey    PYWBJEDBESDHNP-UHFFFAOYSA-N;
MW          298.426;      // g/mol [origin=calculated method=formula-sum]
Tc          1119.22;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       1.1494;      // -   [origin=predictive method=lee-kesler]
Tb          880.88;      // K   [origin=predictive method=joback]
HvapTb      91242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.708 1.94808 -0.00151164 4.932e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 6; } { group ACCH3; count 2; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-[4-(3-methyl-4-oxidanyl-phenyl)hexan-3-yl]phenol" "methestrol" "promethoestrol" "methoestrolum" "methestrolum" "metestrol" "dimethylhexestrol" "methestrolum [inn-latin]" "4,4'-hexane-3,4-diylbis(2-methylphenol)" "4,4'-(hexane-3,4-diyl)bis(2-methylphenol)" "(e)-alpha,beta-diethyl-3,3'-dimethyl-4,4'-stilbendiol" "4-[4-(4-hydroxy-3-methylphenyl)hexan-3-yl]-2-methylphenol" );
gibbsFormation
{
    dHf_298   -371190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=8960.0
    phase     gas;
}
