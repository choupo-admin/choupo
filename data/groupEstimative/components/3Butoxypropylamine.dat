/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butoxypropylamine  (C7H17NO, CAS 16499-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butoxypropylamine;
formula     C7H17NO;
CAS         16499-88-0;
InChIKey    LPUBRQWGZPPVBS-UHFFFAOYSA-N;
MW          131.219;      // g/mol [origin=calculated method=formula-sum]
Tc          633.06;      // K   [origin=predictive method=joback]
Pc          29.218;      // bar [origin=predictive method=joback]
omega       0.6040;      // -   [origin=predictive method=lee-kesler]
Tb          454.71;      // K   [origin=predictive method=joback]
HvapTb      44227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.516 0.66752 -0.0002894 2.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-butoxypropan-1-amine" "3-butoxypropanamine" "3-n-butoxypropylamine" "3-butoxy-1-propylamine" "3-n-butoxy-1-propylamine" "1-propanamine, 3-butoxy-" "3-butoxy propylamine" "3-aminopropyl butyl ether" "lpubrqwgzppvbs-uhfffaoysa-" "p793" "propylamine,3-butoxy- (6ci,7ci,8ci);3-(butyloxy)propylamine;3-(n-butoxy)propylamine;3-aminopropyl butyl ether;3-butoxy-1-propanamine;" );
standardThermochemistry
{
    dHf_298   -286240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30490.0
}
