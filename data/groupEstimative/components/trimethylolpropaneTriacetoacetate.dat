/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane triacetoacetate  (C18H26O9, CAS 22208-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneTriacetoacetate;
formula     C18H26O9;
CAS         22208-25-9;
InChIKey    VRWWRSQIOZLGAM-UHFFFAOYSA-N;
MW          386.397;      // g/mol [origin=calculated method=formula-sum]
Tc          1157.48;      // K   [origin=predictive method=joback]
Pc          13.487;      // bar [origin=predictive method=joback]
omega       1.2273;      // -   [origin=predictive method=lee-kesler]
Tb          944.48;      // K   [origin=predictive method=joback]
HvapTb      96825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (60.357 1.59128 -0.0007873 7.648e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group CH3CO; count 3; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group C; count 1; } { group CdO; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(3-oxidanylidenebutanoyloxymethyl)butyl 3-oxidanylidenebutanoate" "2,2-bis{[(3-oxobutanoyl)oxy]methyl}butyl 3-oxobutanoate" "2-ethyl-2-(hydroxymethyl)-1,3-propanediol triacetoacetate" "acetoacetic acid, 1,1,1-trihydroxy-methylpropane triester" "1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-, triacetoacetate" "butanoic acid, 3-oxo-, 2-((1,3-dioxobutoxy)methyl)-2-ethyl-1,3-propanediyl ester" "butanoic acid, 3-oxo-, 1,1'-(2-((1,3-dioxobutoxy)methyl)-2-ethyl-1,3-propanediyl) ester" "butanoic acid, 3-oxo-, 1,1'-[2-[(1,3-dioxobutoxy)methyl]-2-ethyl-1,3-propanediyl] ester" "butanoic acid, 3-oxo-, 2-[(1,3-dioxobutoxy)methyl]-2-ethyl-1,3-propanediyl ester" "2,2-bis(3-oxobutanoyloxymethyl)butyl 3-oxobutanoate" "acetoacetic acid, triester with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol" "acetoacetic acid, triester with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol (8ci)" );
gibbsFormation
{
    dHf_298   -1713180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1052.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1214350.0
    phase     gas;
}
