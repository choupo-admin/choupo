/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, trimethyl((4-(methylthio)phenyl)methyl)-  (C11H18SSi, CAS 59163-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H18SSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTrimethyl4MethylthioPhenylMethyl;
formula     C11H18SSi;
CAS         59163-55-2;
InChIKey    ZPWTXDMOXFLTBC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          210.41;      // g/mol [origin=calculated method=formula-sum]
Tc          784.21;      // K   [origin=predictive method=joback]
Pc          23.542;      // bar [origin=predictive method=joback]
omega       0.4030;      // -   [origin=predictive method=lee-kesler]
Tb          553.12;      // K   [origin=predictive method=joback]
HvapTb      50129.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.701 0.69867 -8.376e-05 -1.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group Si; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[(4-methylsulfanylphenyl)methyl]silane" );
gibbsFormation
{
    dHf_298   -115060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72880.0
    phase     gas;
}
