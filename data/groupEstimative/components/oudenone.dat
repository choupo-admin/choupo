/*--------------------------------*- Choupo -*-----------------------*\
  Component: oudenone  (C12H16O3, CAS 31323-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oudenone;
formula     C12H16O3;
CAS         31323-50-9;
InChIKey    AFHDYMGMZUYZQT-QMMMGPOBSA-N;
MW          208.257;      // g/mol [origin=calculated method=formula-sum]
Tc          924.65;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.7374;      // -   [origin=predictive method=lee-kesler]
Tb          681.10;      // K   [origin=predictive method=joback]
HvapTb      57749.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.368 0.91912 -0.0002905 -4.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2CO; count 2; } { group CH-O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group O_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(5s)-5-propyloxolan-2-ylidene]cyclopentane-1,3-dione" "1,3-cyclopentanedione, 2-(dihydro-5-propyl-2(3h)-furylidene)-, (s)-" );
standardThermochemistry
{
    dHf_298   -522270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189630.0
}
