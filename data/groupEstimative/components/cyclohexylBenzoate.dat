/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl benzoate  (C13H16O2, CAS 2412-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylBenzoate;
formula     C13H16O2;
CAS         2412-73-9;
InChIKey    DQZKGSRJOUYVPL-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          839.62;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.5501;      // -   [origin=predictive method=lee-kesler]
Tb          601.49;      // K   [origin=predictive method=joback]
HvapTb      54644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.03 1.2272 -0.000701 1.215e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, cyclohexyl ester" "benzoic acid cyclohexyl ester" "1-cyclohexylhydroxyphenylketone" );
gibbsFormation
{
    dHf_298   -338080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114930.0
    phase     gas;
}
