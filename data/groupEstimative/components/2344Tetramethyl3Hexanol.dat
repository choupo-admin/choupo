/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,4-tetramethyl-3-hexanol  (C10H22O, CAS 66256-67-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2344Tetramethyl3Hexanol;
formula     C10H22O;
CAS         66256-67-5;
InChIKey    ZQFIWHOYWCJIHU-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          693.11;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       0.7091;      // -   [origin=predictive method=lee-kesler]
Tb          513.68;      // K   [origin=predictive method=joback]
HvapTb      51553.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.539 1.24542 -0.0008974 2.609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,4-tetramethylhexan-3-ol" );
standardThermochemistry
{
    dHf_298   -424740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100260.0
}
