/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-4-piperidone  (C7H13NO, CAS 3612-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl4Piperidone;
formula     C7H13NO;
CAS         3612-18-8;
InChIKey    BDVKAMAALQXGLM-UHFFFAOYSA-N;
MW          127.187;      // g/mol [origin=calculated method=formula-sum]
Tc          672.31;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.4447;      // -   [origin=predictive method=lee-kesler]
Tb          459.97;      // K   [origin=predictive method=joback]
HvapTb      38032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.159 0.78262 -0.0004084 6.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylpiperidin-4-one" "4-piperidinone, 1-ethyl-" "n-ethyl-4-piperidone" "1-ethyl-piperidin-4-one" "s973" "4-piperidone,1-ethyl- (6ci,7ci,8ci);1-ethyl-4-oxopiperidine;1-ethyl-4-piperidinone;" );
gibbsFormation
{
    dHf_298   -177160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40510.0
    phase     gas;
}
