/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-benzyl-l-tyrosine  (C16H17NO3, CAS 16652-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oBenzylLTyrosine;
formula     C16H17NO3;
CAS         16652-64-5;
InChIKey    KAFHLONDOVSENM-HNNXBMFYSA-N;
MW          271.316;      // g/mol [origin=calculated method=formula-sum]
Tc          1107.50;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       1.2077;      // -   [origin=predictive method=lee-kesler]
Tb          864.04;      // K   [origin=predictive method=joback]
HvapTb      86251.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.258 1.3619 -0.00085016 1.89e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2O; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-(4-phenylmethoxyphenyl)propanoic acid" "h-tyr(bzl)-oh" "h-tyr(bn)-oh" "l-tyrosine benzyl ether" "h-tyr (bzl)-oh" "(s)-2-amino-3-(4-(benzyloxy)phenyl)propanoic acid" "(2s)-2-amino-3-[4-(phenylmethoxy)phenyl]propanoic acid" "(s)-b-(p-benzyloxyphenyl)alanine" "t953" "(2s)-2-amino-3-(4-phenylmethoxyphenyl)propanoic acid" "(2s)-2-amino-3-[4-(benzyloxy)phenyl]propanoic acid" );
standardThermochemistry
{
    dHf_298   -365960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85870.0
}
