/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlordane  (C10H6Cl8, CAS 12789-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlordane;
formula     C10H6Cl8;
CAS         12789-03-6;
InChIKey    BIWJNBZANLAXMG-UHFFFAOYSA-N;
MW          409.758;      // g/mol [origin=calculated method=formula-sum]
Tc          1021.69;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.5823;      // -   [origin=predictive method=lee-kesler]
Tb          743.49;      // K   [origin=predictive method=joback]
HvapTb      69772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.76 2.046 -0.002527 1.1834e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CHCl; count 2; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chlorindan" "chlordan" "cis-chlordane" "trans-chlordane" "dowchlor" "oktaterr" "synklor" "topiclor" "cortilan-neu" "dichlorochlordene" "octa-klor" "tat chlor 4" );
gibbsFormation
{
    dHf_298   -164210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71420.0
    phase     gas;
}
