/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexanamine, 5-methyl-  (C7H17N, CAS 28292-43-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexanamine5Methyl;
formula     C7H17N;
CAS         28292-43-5;
InChIKey    IZCBXLKODYZSDJ-UHFFFAOYSA-N;
MW          115.22;      // g/mol [origin=calculated method=formula-sum]
Tc          618.44;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       0.4578;      // -   [origin=predictive method=lee-kesler]
Tb          431.41;      // K   [origin=predictive method=joback]
HvapTb      41041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.348 0.74256 -0.0004068 8.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhexan-2-amine" "1,4-dimethylpentylamine" "2-amino-5-methylhexane" "5-methyl-2-hexylamine" "pentylamine, 1,4-dimethyl-" "5-methylhex-2-ylamine" "pentylamine,4-dimethyl-" "2-amino-5-methyl hexane" );
standardThermochemistry
{
    dHf_298   -164580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69630.0
}
