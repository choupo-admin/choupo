/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclopentenecarboxylic acid  (C6H8O2, CAS 1560-11-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1CyclopentenecarboxylicAcid;
formula     C6H8O2;
CAS         1560-11-8;
InChIKey    PYRZPBDTPRQYKG-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          730.14;      // K   [origin=predictive method=joback]
Pc          46.214;      // bar [origin=predictive method=joback]
omega       0.6069;      // -   [origin=predictive method=lee-kesler]
Tb          506.48;      // K   [origin=predictive method=joback]
HvapTb      47634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.31 0.6673 -0.00047824 1.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentene-1-carboxylic acid" "1-cyclopentene-1-carboxylic acid" "isoaleprolic acid" "1-cyclopentenylcarboxylic acid" "cyclopent-1-ene-1-carboxylic acid" "ghl.pd_mitscher_leg0.28" "ambap1560-11-8" "cyclopent-1-enecarboxylic acid" );
gibbsFormation
{
    dHf_298   -390310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279680.0
    phase     gas;
}
