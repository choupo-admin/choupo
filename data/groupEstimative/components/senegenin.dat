/*--------------------------------*- Choupo -*-----------------------*\
  Component: senegenin  (C30H45ClO6, CAS 2469-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        senegenin;
formula     C30H45ClO6;
CAS         2469-34-3;
InChIKey    CWHJIJJSDGEHNS-UHFFFAOYSA-N;
MW          537.134;      // g/mol [origin=calculated method=formula-sum]
Tc          1810.07;      // K   [origin=predictive method=joback]
Pc          11.769;      // bar [origin=predictive method=joback]
omega       0.8583;      // -   [origin=predictive method=lee-kesler]
Tb          1444.70;      // K   [origin=predictive method=joback]
HvapTb      149221.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-456.709 4.8431 -0.0047946 1.9928e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 9; } { group CH; count 6; } { group C; count 5; } { group OH; count 2; } { group COOH; count 2; } { group CH2Cl; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 6; } { group C_ring; count 5; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "13-(chloromethyl)-4,6a,11,11,14b-pentamethyl-2,3-bis(oxidanyl)-2,3,4a,5,6,7,8,9,10,12,12a,13,14,14a-tetradecahydro-1h-picene-4,8a-dicarboxylic acid" "senegin" "27-noro-13-ene-23,28-dioic acid, 12-(chloromethyl)-2-beta,3-beta-dihydroxy-" "13-(chloromethyl)-2,3-dihydroxy-4,6a,11,11,14b-pentamethyl-2,3,4a,5,6,7,8,9,10,12,12a,13,14,14a-tetradecahydro-1h-picene-4,8a-dicarboxylic acid" );
standardThermochemistry
{
    dHf_298   -1373390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1297.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-615630.0
}
