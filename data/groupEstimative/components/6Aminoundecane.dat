/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-aminoundecane  (C11H25N, CAS 33788-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Aminoundecane;
formula     C11H25N;
CAS         33788-00-0;
InChIKey    GFBRYGJZWXLRFR-UHFFFAOYSA-N;
MW          171.328;      // g/mol [origin=calculated method=formula-sum]
Tc          699.74;      // K   [origin=predictive method=joback]
Pc          20.493;      // bar [origin=predictive method=joback]
omega       0.6848;      // -   [origin=predictive method=lee-kesler]
Tb          523.37;      // K   [origin=predictive method=joback]
HvapTb      50333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.302 1.11664 -0.0006212 1.302e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecan-6-amine" "6-undecylamine" "6-undecanamine" "hexylamine,1-pentyl- (8ci); 6-aminoundecane; 6-undecylamine" );
gibbsFormation
{
    dHf_298   -241860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105750.0
    phase     gas;
}
