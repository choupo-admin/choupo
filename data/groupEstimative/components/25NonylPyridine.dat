/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(5-nonyl)pyridine  (C14H23N, CAS 2961-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25NonylPyridine;
formula     C14H23N;
CAS         2961-49-1;
InChIKey    YGCMUHWPXXEZCR-UHFFFAOYSA-N;
MW          205.345;      // g/mol [origin=calculated method=formula-sum]
Tc          805.72;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.6454;      // -   [origin=predictive method=lee-kesler]
Tb          599.86;      // K   [origin=predictive method=joback]
HvapTb      54856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.364 1.2946 -0.00078146 1.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-nonan-5-ylpyridine" "pyridine, 2-(1-butylpentyl)-" "2-(nonan-5-yl)pyridine" "2-(1-n-butylpentyl)pyridine" "2-(1-butylpentyl)-pyridine" );
standardThermochemistry
{
    dHf_298   -68250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254020.0
}
