/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-3-methyl-2-butene  (C5H9Cl, CAS 17773-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro3Methyl2Butene;
formula     C5H9Cl;
CAS         17773-65-8;
InChIKey    WIIKEBDPJPYJHF-UHFFFAOYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          545.24;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.2320;      // -   [origin=predictive method=lee-kesler]
Tb          355.35;      // K   [origin=predictive method=joback]
HvapTb      31227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.33 0.50546 -0.000357 1.083e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group Cl_C=C_; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-3-methyl-but-2-ene" "2-butene, 2-chloro-3-methyl-" "2-chloro-3-methylbut-2-ene" "2-chloro-3-methyl-but-2-ene" );
standardThermochemistry
{
    dHf_298   -64630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42410.0
}
