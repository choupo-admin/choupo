/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-ethynylbenzene  (C8H5Br, CAS 766-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Ethynylbenzene;
formula     C8H5Br;
CAS         766-96-1;
InChIKey    LTLVZQZDXQWLHU-UHFFFAOYSA-N;
MW          181.032;      // g/mol [origin=calculated method=formula-sum]
Tc          719.19;      // K   [origin=predictive method=joback]
Pc          47.366;      // bar [origin=predictive method=joback]
omega       0.3410;      // -   [origin=predictive method=lee-kesler]
Tb          470.58;      // K   [origin=predictive method=joback]
HvapTb      42633.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.02 0.5697 -0.00044289 1.3709e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-ethynyl-benzene" "4-bromophenylacetylene" "1-bromo-4-ethynyl-benzene" "benzene, 1-bromo-4-ethynyl-" "(4-bromophenyl)acetylene" "4'-bromophenylacetylene" "4'-bromophenyl acetylene" "(4-bromphenyl)acetylene" "4-bromo-1-ethynylbenzene" "b180" "(4-bromophenyl)ethyne;(p-bromophenyl)acetylene;(p-bromophenyl)ethyne;1-(4-bromophenyl)acetylene;1-bromo-4-ethynylbenzene;4-bromo(ethynyl)benzene;4-bromo-1-ethynylbenzene;p-ethynylbromobenzene;" );
gibbsFormation
{
    dHf_298   334840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356650.0
    phase     gas;
}
