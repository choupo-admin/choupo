/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2809178  (C15H24ClNO, CAS 27778-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2809178;
formula     C15H24ClNO;
CAS         27778-78-5;
InChIKey    FLPXRJWWTNHJSL-UHFFFAOYSA-N;
MW          269.813;      // g/mol [origin=calculated method=formula-sum]
Tc          851.85;      // K   [origin=predictive method=joback]
Pc          17.405;      // bar [origin=predictive method=joback]
omega       0.7475;      // -   [origin=predictive method=lee-kesler]
Tb          650.85;      // K   [origin=predictive method=joback]
HvapTb      60646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.282 1.3103 -0.00071772 1.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } { group CH3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-chloranyl-4-methoxy-phenyl)-n,n,3-trimethyl-pentan-1-amine" "beta-sec-butyl-3-chloro-n,n-dimethyl-4-methoxyphenethylamine" "phenethylamine, beta-(sec-butyl)-3-chloro-n,n-dimethyl-4-methoxy-" );
gibbsFormation
{
    dHf_298   -230330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     663.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157540.0
    phase     gas;
}
