/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene, 2-methoxy-3-methyl-  (C6H12O, CAS 26578-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene2Methoxy3Methyl;
formula     C6H12O;
CAS         26578-81-4;
InChIKey    QFVDGBFHOZBSII-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          543.83;      // K   [origin=predictive method=joback]
Pc          32.690;      // bar [origin=predictive method=joback]
omega       0.2928;      // -   [origin=predictive method=lee-kesler]
Tb          363.22;      // K   [origin=predictive method=joback]
HvapTb      31478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.37 0.53048 -0.00028 5.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH3O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-3-methyl-but-2-ene" "2-methoxy-3-methylbut-2-ene" );
gibbsFormation
{
    dHf_298   -201750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42240.0
    phase     gas;
}
