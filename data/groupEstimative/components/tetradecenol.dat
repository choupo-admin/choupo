/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecenol  (C14H28O, CAS 28982-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecenol;
formula     C14H28O;
CAS         28982-37-8;
InChIKey    GXBLITCOLKGJDG-UHFFFAOYSA-N;
MW          212.377;      // g/mol [origin=calculated method=formula-sum]
Tc          768.63;      // K   [origin=predictive method=joback]
Pc          16.963;      // bar [origin=predictive method=joback]
omega       1.0641;      // -   [origin=predictive method=lee-kesler]
Tb          608.78;      // K   [origin=predictive method=joback]
HvapTb      62767.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.538 1.3478 -0.0007911 1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradec-13-en-1-ol" "13-tetradecenol" "13-tetradecen-1-ol" "tetradecen-1-ol" );
standardThermochemistry
{
    dHf_298   -359090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18020.0
}
