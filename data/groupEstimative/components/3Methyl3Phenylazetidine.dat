/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-3-phenylazetidine  (C10H13N, CAS 5961-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl3Phenylazetidine;
formula     C10H13N;
CAS         5961-33-1;
InChIKey    YOLLUMURPUEOJW-UHFFFAOYSA-N;
MW          147.221;      // g/mol [origin=calculated method=formula-sum]
Tc          762.21;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.3963;      // -   [origin=predictive method=lee-kesler]
Tb          514.88;      // K   [origin=predictive method=joback]
HvapTb      45822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.54 1.29472 -0.0011972 4.678e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-3-phenyl-azetidine" "azetidine, 3-methyl-3-phenyl-" "azetidine,3-methyl-3-phenyl-" );
standardThermochemistry
{
    dHf_298   106490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=276600.0
}
