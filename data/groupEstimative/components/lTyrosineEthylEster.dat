/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-tyrosine ethyl ester  (C11H15NO3, CAS 34081-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lTyrosineEthylEster;
formula     C11H15NO3;
CAS         34081-17-9;
InChIKey    SBBWEQLNKVHYCX-UHFFFAOYSA-N;
MW          209.245;      // g/mol [origin=calculated method=formula-sum]
Tc          917.22;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       1.0068;      // -   [origin=predictive method=lee-kesler]
Tb          688.89;      // K   [origin=predictive method=joback]
HvapTb      73030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.718 1.13752 -0.00081416 2.317e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-azanyl-3-(4-hydroxyphenyl)propanoate" "ethyl 2-amino-3-(4-hydroxyphenyl)propanoate" "tyrosine ethyl ester" "tyrosine, ethyl ester" "dl-tyrosine ethyl ester" "2-amino-3-(4-hydroxy-phenyl)-propionic acid ethyl ester" "2-[4-(2,6-dichloro-4-nitro-phenyl)azo-n-(2-methoxycarbonyloxyethyl)-3-methyl-anilino]ethyl methyl carbonate" );
gibbsFormation
{
    dHf_298   -499920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246830.0
    phase     gas;
}
