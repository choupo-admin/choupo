/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dihydro-1,2-acenaphthylenediol  (C12H10O2, CAS 17976-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dihydro12Acenaphthylenediol;
formula     C12H10O2;
CAS         17976-92-0;
InChIKey    ARGFAPRYULRPAN-UHFFFAOYSA-N;
MW          186.21;      // g/mol [origin=calculated method=formula-sum]
Tc          918.17;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       1.4552;      // -   [origin=predictive method=lee-kesler]
Tb          711.94;      // K   [origin=predictive method=joback]
HvapTb      80336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.37 1.1442 -0.00093484 3.09e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACCH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dihydroacenaphthylene-1,2-diol" "cis-1,2-acenaphthenediol" "cis-1,2-acenaphthylene glycol" "(1,2)-acenaphthenediol" "1, 1,2-dihydro-, cis-" "1,2-acenaphthenediol, cis- (8ci)" "1,2-acenaphthylenediol, 1,2-dihydro-" "1,2-acenaphthylenediol, 1,2-dihydro-, cis- (9ci)" );
gibbsFormation
{
    dHf_298   -132190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41460.0
    phase     gas;
}
