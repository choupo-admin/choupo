/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethyl-4-stilbenamine  (C18H21N, CAS 40193-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethyl4Stilbenamine;
formula     C18H21N;
CAS         40193-47-3;
InChIKey    FBZZYZMCLSMELP-UHFFFAOYSA-N;
MW          251.373;      // g/mol [origin=calculated method=formula-sum]
Tc          914.31;      // K   [origin=predictive method=joback]
Pc          19.771;      // bar [origin=predictive method=joback]
omega       0.6906;      // -   [origin=predictive method=lee-kesler]
Tb          686.38;      // K   [origin=predictive method=joback]
HvapTb      62877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-91.858 1.64044 -0.00114716 3.139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-4-(2-phenylethenyl)aniline" );
standardThermochemistry
{
    dHf_298   231490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=506870.0
}
