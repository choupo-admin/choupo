/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-diisopropylcatechol  (C12H18O2, CAS 2138-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Diisopropylcatechol;
formula     C12H18O2;
CAS         2138-49-0;
InChIKey    VMYLKGAEBQHVPE-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          896.63;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.9052;      // -   [origin=predictive method=lee-kesler]
Tb          666.18;      // K   [origin=predictive method=joback]
HvapTb      70496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.83 1.32648 -0.00111228 3.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 2; } { group ACCH; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-di(propan-2-yl)benzene-1,2-diol" "3,5-diisopropylpyrocatechol" "3,5-diisopropylbenzene-1,2-diol" "1,2-benzenediol,3,5-bis(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -431130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161180.0
    phase     gas;
}
