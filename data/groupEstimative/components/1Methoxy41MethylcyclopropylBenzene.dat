/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-4-(1-methylcyclopropyl)benzene  (C11H14O, CAS 63340-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy41MethylcyclopropylBenzene;
formula     C11H14O;
CAS         63340-01-2;
InChIKey    YDPONOLPXBJBIJ-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          739.34;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.4328;      // -   [origin=predictive method=lee-kesler]
Tb          512.34;      // K   [origin=predictive method=joback]
HvapTb      44190.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.45 1.29004 -0.00118056 4.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene,1-methoxy-4-(1-methylcyclopropyl)-" "benzene, 1-methoxy-4-(1-methylcyclopropyl)-" );
standardThermochemistry
{
    dHf_298   -89490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94780.0
}
