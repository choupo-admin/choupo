/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-phenyllactate  (C9H10O3, CAS 7326-19-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rPhenyllactate;
formula     C9H10O3;
CAS         7326-19-4;
InChIKey    VOXXWSYKYCBWHO-MRVPVSSYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          881.05;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       1.2360;      // -   [origin=predictive method=lee-kesler]
Tb          669.45;      // K   [origin=predictive method=joback]
HvapTb      71359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.989 0.8706 -0.0006032 1.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-oxidanyl-3-phenyl-propanoic acid" "d-(+)-phenyllactic acid" "(r)-2-hydroxy-3-phenylpropionic acid" "(r)-(+)-3-phenyllactic acid" "(r)-2-hydroxy-3-phenylpropanoic acid" "(2r)-2-hydroxy-3-phenylpropanoic acid" "d-(+)-3-phenyllactic acid" "(r)-3-phenyllactic acid" "l-2-hydroxy-3-phenyl-propionic acid" "benzenepropanoic acid, alpha-hydroxy-" "(2s)-2-hydroxy-3-phenylpropanoic acid" "l-3-phenyllactate" );
gibbsFormation
{
    dHf_298   -500340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-345860.0
    phase     gas;
}
