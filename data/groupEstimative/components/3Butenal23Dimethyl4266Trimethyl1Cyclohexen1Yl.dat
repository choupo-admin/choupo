/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butenal, 2,3-dimethyl-4-(2,6,6-trimethyl-1-cyclohexen-1-yl)-  (C15H24O, CAS 68140-49-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butenal23Dimethyl4266Trimethyl1Cyclohexen1Yl;
formula     C15H24O;
CAS         68140-49-8;
InChIKey    GYKAQARGVABFQW-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          828.35;      // K   [origin=predictive method=joback]
Pc          19.220;      // bar [origin=predictive method=joback]
omega       0.5899;      // -   [origin=predictive method=lee-kesler]
Tb          614.32;      // K   [origin=predictive method=joback]
HvapTb      55277.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.48 1.7012 -0.00135294 4.726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethyl-4-(2,6,6-trimethylcyclohex-2-en-1-yl)but-3-enal" "3-butenal, 2,3-dimethyl-4-(2,6,6-trimethyl-2-cyclohexen-1-yl)-" );
gibbsFormation
{
    dHf_298   -240830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76710.0
    phase     gas;
}
