/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroanisole  (C7H7ClO, CAS 766-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloroanisole;
formula     C7H7ClO;
CAS         766-51-8;
InChIKey    QGRPVMLBTFGQDQ-UHFFFAOYSA-N;
MW          142.582;      // g/mol [origin=calculated method=formula-sum]
Tc          670.90;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.3748;      // -   [origin=predictive method=lee-kesler]
Tb          451.27;      // K   [origin=predictive method=joback]
HvapTb      40909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.31 0.47402 -0.00023056 2.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH3O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-methoxy-benzene" "1-chloro-2-methoxybenzene" "o-chloroanisole" "benzene, 1-chloro-2-methoxy-" "anisole, o-chloro-" "o-chlorophenyl methyl ether" "2-chlorophenol methyl ether" "2-chloro-1-methoxybenzene" "1-chloro-2-methoxy-benzene" "anisole, o-chloro- (8ci)" "l244" );
gibbsFormation
{
    dHf_298   -110710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6090.0
    phase     gas;
}
