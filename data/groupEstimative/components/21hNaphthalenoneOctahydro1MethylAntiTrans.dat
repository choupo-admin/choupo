/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(1h)-naphthalenone, octahydro-1-methyl-, anti-trans-  (C11H18O, CAS 21102-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21hNaphthalenoneOctahydro1MethylAntiTrans;
formula     C11H18O;
CAS         21102-88-5;
InChIKey    OATKSURGQMWHRL-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          779.80;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.4234;      // -   [origin=predictive method=lee-kesler]
Tb          544.99;      // K   [origin=predictive method=joback]
HvapTb      44532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.71 1.11742 -0.00053 5.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3,4,4a,5,6,7,8,8a-octahydro-1h-naphthalen-2-one" "2(1h)-naphthalenone, octahydro-1-methyl-, (1.alpha.,4a.beta.,8a.alpha.)-" "1-methyl-2-decalone" "2(1h)-naphthalenone, octahydro-1-methyl-" "2(1h)-naphthalenone, octahydro-1-methyl-, (1alpha,4abeta,8aalpha)-" );
gibbsFormation
{
    dHf_298   -307450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15460.0
    phase     gas;
}
