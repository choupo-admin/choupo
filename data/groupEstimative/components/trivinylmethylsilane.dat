/*--------------------------------*- Choupo -*-----------------------*\
  Component: trivinylmethylsilane  (C7H12Si, CAS 18244-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H12Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trivinylmethylsilane;
formula     C7H12Si;
CAS         18244-95-6;
InChIKey    PKRKCDBTXBGLKV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          124.258;      // g/mol [origin=calculated method=formula-sum]
Tc          532.00;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.1966;      // -   [origin=predictive method=lee-kesler]
Tb          351.20;      // K   [origin=predictive method=joback]
HvapTb      29460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.37 0.40262 -1.09e-05 -9.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 3; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(ethenyl)-methyl-silane" "methyltrivinylsilane" "silane, triethenylmethyl-" "tris(ethenyl)-methylsilane" );
gibbsFormation
{
    dHf_298   76860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166820.0
    phase     gas;
}
