/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexafluoro-2-phenyl-2-propanol  (C9H6F6O, CAS 718-64-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexafluoro2Phenyl2Propanol;
formula     C9H6F6O;
CAS         718-64-9;
InChIKey    IZPIZCAYJQCTNG-UHFFFAOYSA-N;
MW          244.134;      // g/mol [origin=calculated method=formula-sum]
Tc          684.21;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.8532;      // -   [origin=predictive method=lee-kesler]
Tb          510.31;      // K   [origin=predictive method=joback]
HvapTb      45793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.78 1.2621 -0.0011412 3.805e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 6; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)-2-phenyl-propan-2-ol" "1,1,1,3,3,3-hexafluoro-2-phenylpropan-2-ol" "1,1,1,3,3,3-hexafluoro-2-phenyl-2-propanol" "bis(trifluoromethyl)phenylcarbinol" "alpha,alpha-bis(trifluoromethyl)benzyl alcohol" "2,2,2,2',2',2'-hexafluorocumyl alcohol" "hexafluoro-2-phenyl isopropanol" "(hexafluoro-2-hydroxyisopropyl)benzene" "benzenemethanol, alpha,alpha-bis(trifluoromethyl)-" "izpizcayjqctng-uhfffaoysa-" "2-hydroxy-2-phenylhexafluoropropane" "2,2,2,2,2,2,-hexafluorocumyl alcohol" );
gibbsFormation
{
    dHf_298   -1347700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1159850.0
    phase     gas;
}
