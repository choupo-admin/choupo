/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropoxyphenol  (C9H12O2, CAS 7495-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropoxyphenol;
formula     C9H12O2;
CAS         7495-77-4;
InChIKey    QEYQMWSESURNPP-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          759.54;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.6136;      // -   [origin=predictive method=lee-kesler]
Tb          534.80;      // K   [origin=predictive method=joback]
HvapTb      52940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.3 0.87724 -0.00064556 1.992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-propan-2-yloxyphenol" "phenol, 4-(1-methylethoxy)-" "phenol, p-isopropoxy-" "4-(propan-2-yloxy)phenol" "isopropyl p-hydroxyphenyl ether" "p-isopropoxyphenol" "4-isopropoxy-phenol" "4-(1-methylethoxy)-phenol" );
gibbsFormation
{
    dHf_298   -307370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124750.0
    phase     gas;
}
