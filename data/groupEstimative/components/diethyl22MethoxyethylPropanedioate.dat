/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2-(2-methoxyethyl)propanedioate  (C10H18O5, CAS 6335-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl22MethoxyethylPropanedioate;
formula     C10H18O5;
CAS         6335-02-0;
InChIKey    NBUBXXFBXDUOHG-UHFFFAOYSA-N;
MW          218.249;      // g/mol [origin=calculated method=formula-sum]
Tc          744.36;      // K   [origin=predictive method=joback]
Pc          21.100;      // bar [origin=predictive method=joback]
omega       0.8418;      // -   [origin=predictive method=lee-kesler]
Tb          566.82;      // K   [origin=predictive method=joback]
HvapTb      54690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.434 0.78696 -0.0002232 -6.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH3O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "malonic acid, 2-methoxyethyl-, diethyl ester" "1,3-diethyl 2-(2-methoxyethyl)propanedioate" );
standardThermochemistry
{
    dHf_298   -1021790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-694860.0
}
