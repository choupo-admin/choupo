/*--------------------------------*- Choupo -*-----------------------*\
  Component: clomid  (C32H36ClNO8, CAS 50-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clomid;
formula     C32H36ClNO8;
CAS         50-41-9;
InChIKey    PYTMYKVIJXPNBD-UHFFFAOYSA-N;
MW          598.089;      // g/mol [origin=calculated method=formula-sum]
Tc          2104.26;      // K   [origin=predictive method=joback]
Pc          10.994;      // bar [origin=predictive method=joback]
omega       0.5055;      // -   [origin=predictive method=lee-kesler]
Tb          1619.87;      // K   [origin=predictive method=joback]
HvapTb      170441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.044 2.94094 -0.00185916 4.123e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 14; } { group AC; count 4; } { group OH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group COOH; count 3; } { group Cl_C=C_; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group dC; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } { group COOH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-chloranyl-1,2-diphenyl-ethenyl)phenoxy]-n,n-diethyl-ethanamine;2-oxidanylpropane-1,2,3-tricarboxylic acid" "clomiphene citrate" "clomifene citrate" "chloramiphene" "chloramiphene citrate" "2-[4-(2-chloro-1,2-diphenylethenyl)phenoxy]-n,n-diethylethanamine; 2-hydroxypropane-1,2,3-tricarboxylic acid" "2-chloro-1-(p-(beta-diethylaminoethoxy)phenyl)-1,2-diphenylethylene" "2-(p-(2-chloro-1,2-diphenyl vinyl)phenoxy)triethylamine citrate (1:1)" "2-[4-(2-chloranyl-1,2-diphenyl-ethenyl)phenoxy]-n,n-diethyl-ethanamine; 2-oxidanylpropane-1,2,3-tricarboxylic acid" );
gibbsFormation
{
    dHf_298   -1311890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1401.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-667340.0
    phase     gas;
}
