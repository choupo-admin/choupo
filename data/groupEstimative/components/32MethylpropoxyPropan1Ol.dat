/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-methylpropoxy)propan-1-ol  (C7H16O2, CAS 34150-35-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32MethylpropoxyPropan1Ol;
formula     C7H16O2;
CAS         34150-35-1;
InChIKey    BUIXEGYUDCDLCD-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          637.72;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.8646;      // -   [origin=predictive method=lee-kesler]
Tb          473.92;      // K   [origin=predictive method=joback]
HvapTb      49877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.634 0.64554 -0.0002796 2.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "isobutoxypropanol, mixed isomers" "propanol, isobutoxy-, (mixed isomers)" );
gibbsFormation
{
    dHf_298   -477540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-236200.0
    phase     gas;
}
