/*--------------------------------*- Choupo -*-----------------------*\
  Component: brompheniramine  (C16H19BrN2, CAS 86-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brompheniramine;
formula     C16H19BrN2;
CAS         86-22-6;
InChIKey    ZDIGNSYAACHWNL-UHFFFAOYSA-N;
MW          319.246;      // g/mol [origin=calculated method=formula-sum]
Tc          1004.03;      // K   [origin=predictive method=joback]
Pc          24.243;      // bar [origin=predictive method=joback]
omega       0.8330;      // -   [origin=predictive method=lee-kesler]
Tb          755.88;      // K   [origin=predictive method=joback]
HvapTb      70724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.288 1.5083 -0.00103842 2.781e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Br; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-bromophenyl)-n,n-dimethyl-3-pyridin-2-yl-propan-1-amine" "dimetane" "bromfeniramina" "brompheniraminum" "bromfenex" "bromfed" "parabromdylamine" "p-bromdylamine" "para-bromdylamine" "ilvin" "lodrane" "brompheniramine [inn:ban]" );
gibbsFormation
{
    dHf_298   209390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=498740.0
    phase     gas;
}
