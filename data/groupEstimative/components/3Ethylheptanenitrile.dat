/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethylheptanenitrile  (C9H17N, CAS 2571-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethylheptanenitrile;
formula     C9H17N;
CAS         2571-05-3;
InChIKey    SNZMXYKDANOXRV-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          694.28;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       0.5818;      // -   [origin=predictive method=lee-kesler]
Tb          507.16;      // K   [origin=predictive method=joback]
HvapTb      45718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.025 0.79954 -0.000438 8.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptanenitrile, 3-ethyl-" "heptanenitrile, 3-ethyl-," );
gibbsFormation
{
    dHf_298   -69490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155640.0
    phase     gas;
}
