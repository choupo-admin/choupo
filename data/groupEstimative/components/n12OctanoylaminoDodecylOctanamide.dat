/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[12-(octanoylamino)dodecyl]octanamide  (C28H56N2O2, CAS 62103-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n12OctanoylaminoDodecylOctanamide;
formula     C28H56N2O2;
CAS         62103-65-5;
InChIKey    PFNKAJSRMNFZHQ-UHFFFAOYSA-N;
MW          452.768;      // g/mol [origin=calculated method=formula-sum]
Tc          1312.42;      // K   [origin=predictive method=joback]
Pc          7.096;      // bar [origin=predictive method=joback]
omega       0.4606;      // -   [origin=predictive method=lee-kesler]
Tb          1048.32;      // K   [origin=predictive method=joback]
HvapTb      104286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.266 2.76024 -0.0015592 3.2492e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 22; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 24; } { group CdO; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -739470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1381.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105820.0
}
