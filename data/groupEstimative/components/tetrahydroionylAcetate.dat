/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydroionyl acetate  (C15H28O2, CAS 68555-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydroionylAcetate;
formula     C15H28O2;
CAS         68555-59-9;
InChIKey    OAKWLQFVIYUNRW-UHFFFAOYSA-N;
MW          240.387;      // g/mol [origin=calculated method=formula-sum]
Tc          810.65;      // K   [origin=predictive method=joback]
Pc          16.511;      // bar [origin=predictive method=joback]
omega       0.6130;      // -   [origin=predictive method=lee-kesler]
Tb          611.03;      // K   [origin=predictive method=joback]
HvapTb      54663.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.738 1.741 -0.0012036 3.609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,2,6-trimethylcyclohexyl)butan-2-yl ethanoate" "cyclohexanepropanol, .alpha.,2,2,6-tetramethyl-, acetate" "alpha,2,2,6-tetramethylcyclohexylpropyl acetate" "4-(2,2,6-trimethylcyclohexyl)butan-2-yl acetate" "cyclohexanepropanol, alpha,2,2,6-tetramethyl-, acetate" "cyclohexanepropanol, alpha,2,2,6-tetramethyl-, 1-acetate" "cyclohexanepropanol, .alpha.,2,2,6-tetramethyl-, 1-acetate" );
standardThermochemistry
{
    dHf_298   -646610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     736.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-233850.0
}
