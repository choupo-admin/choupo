/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalen-1,4-imine, 1,2,3,4-tetrahydro-9-methyl-  (C11H13N, CAS 55257-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalen14Imine1234Tetrahydro9Methyl;
formula     C11H13N;
CAS         55257-99-3;
InChIKey    UWNOWNVIUHVGID-UHFFFAOYSA-N;
MW          159.232;      // g/mol [origin=calculated method=formula-sum]
Tc          717.51;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.4879;      // -   [origin=predictive method=lee-kesler]
Tb          500.32;      // K   [origin=predictive method=joback]
HvapTb      44543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.65 1.35532 -0.00118456 4.161e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group ACCH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-11-aza-tricyclo(6.2.1.0(2,7))undec-2,4,6,-triene" "agn-pc-04y284" );
gibbsFormation
{
    dHf_298   180140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     267.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=401000.0
    phase     gas;
}
