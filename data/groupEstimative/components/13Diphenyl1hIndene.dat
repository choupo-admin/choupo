/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-diphenyl-1h-indene  (C21H16, CAS 4467-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Diphenyl1hIndene;
formula     C21H16;
CAS         4467-88-3;
InChIKey    PTZVKDFWFSDSMK-UHFFFAOYSA-N;
MW          268.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1047.57;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.6708;      // -   [origin=predictive method=lee-kesler]
Tb          775.98;      // K   [origin=predictive method=joback]
HvapTb      70697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.78 1.738 -0.0012856 3.689e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 14; } { group AC; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-indene, 1,3-diphenyl-" "1,3-diphenylindene" "1,3-diphenyl-1h-inden" );
standardThermochemistry
{
    dHf_298   340460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=534620.0
}
