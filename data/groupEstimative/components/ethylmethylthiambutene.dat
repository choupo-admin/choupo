/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylmethylthiambutene  (C15H19NS2, CAS 441-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylmethylthiambutene;
formula     C15H19NS2;
CAS         441-61-2;
InChIKey    MORSAEFGQPDBKM-UHFFFAOYSA-N;
MW          277.444;      // g/mol [origin=calculated method=formula-sum]
Tc          950.64;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.6596;      // -   [origin=predictive method=lee-kesler]
Tb          701.00;      // K   [origin=predictive method=joback]
HvapTb      65925.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.479 1.58078 -0.00121214 3.734e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=C; count 1; } { group CH3N; count 1; } { group C4H3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group N; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n-methyl-4,4-dithiophen-2-yl-but-3-en-2-amine" "3-buten-2-amine, n-ethyl-n-methyl-4,4-di-2-thienyl-" "emethibutin" "etilmetiltiambutene" "etilmetiltiambuteno" "ethylmethylthiambutenum" "aethylmethylthiambutenum" "etilmetiltiambutene [dcit]" "ethylmethylthiambutenum [inn-latin]" "n-ethyl-n,1-dimethyl-3,3-di-2-thienylallylamine" "allylamine, n-ethyl-n,1-dimethyl-3,3-di-2-thienyl-" "n-ethyl-n-methyl-4,4-dithiophen-2-ylbut-3-en-2-amine" );
standardThermochemistry
{
    dHf_298   277090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=524250.0
}
