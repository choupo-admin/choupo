/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pyrenecarboxylic acid  (C17H10O2, CAS 19694-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PyrenecarboxylicAcid;
formula     C17H10O2;
CAS         19694-02-1;
InChIKey    HYISVWRHTUCNCS-UHFFFAOYSA-N;
MW          246.265;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.56;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       1.0957;      // -   [origin=predictive method=lee-kesler]
Tb          824.93;      // K   [origin=predictive method=joback]
HvapTb      79146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.84 1.4763 -0.00131936 4.688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 7; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 7; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrene-1-carboxylic acid" "pyrenecarboxylic acid" "1-pyrenecarboxylicacid" "3-pyrenecarboxylicacid;" "lowicryl k4m reagent kit" "lowicryl(r) k4m reagent kit" );
gibbsFormation
{
    dHf_298   -14610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146060.0
    phase     gas;
}
