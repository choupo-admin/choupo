/*--------------------------------*- Choupo -*-----------------------*\
  Component: ditolylethane  (C16H18, CAS 4613-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ditolylethane;
formula     C16H18;
CAS         4613-11-0;
InChIKey    NGCFVIRRWORSML-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          858.38;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.5074;      // -   [origin=predictive method=lee-kesler]
Tb          618.16;      // K   [origin=predictive method=joback]
HvapTb      54986.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.83 1.37784 -0.0009154 2.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 10; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylbutan-2-ylbenzene" "ethane, ditolyl-" "meso-2,3-diphenylbutane" "benzene, 1,1'-(1,2-dimethyl-1,2-ethanediyl)bis-" "bibenzyl, .alpha.,.alpha.'-dimethyl-" "bibenzyl, .alpha.,.alpha.'-dimethyl-, dl-" "bibenzyl, .alpha.,.alpha.'-dimethyl-, erythro-" "benzene, 1,1'-(1,2-dimethyl-1,2-ethanediyl)bis-, (r*,s*)-" "benzene, 1,1'-(1,2-dimethyl-1,2-ethanediyl)bis-, (r*,r*)-(.+/-.)-" "dl-2,3-diphenylbutane" "erythro-2,3-diphenylbutane" "agn-pc-03e9zl" );
gibbsFormation
{
    dHf_298   88930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=303780.0
    phase     gas;
}
