/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-methylenebis(2,6-di-t-butylphenol)  (C29H44O2, CAS 118-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Methylenebis26DiTButylphenol;
formula     C29H44O2;
CAS         118-82-1;
InChIKey    MDWVSAYEQPLWMX-UHFFFAOYSA-N;
MW          424.669;      // g/mol [origin=calculated method=formula-sum]
Tc          1336.58;      // K   [origin=predictive method=joback]
Pc          10.921;      // bar [origin=predictive method=joback]
omega       0.9731;      // -   [origin=predictive method=lee-kesler]
Tb          1084.72;      // K   [origin=predictive method=joback]
HvapTb      108192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.819 3.17564 -0.00254796 8.391e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 4; } { group ACH; count 4; } { group AC; count 5; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 1; } { group C; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butyl-4-[(3,5-ditert-butyl-4-oxidanyl-phenyl)methyl]phenol" "4,4'-methylenebis(2,6-di-tert-butylphenol)" "bimox m" "binox m" "mb 1 (antioxidant)" "ionox 220 antioxidant" "lz-mb 1" "l 3mb1" "mb 1 (antioxidant) (van)" "phenol, 4,4'-methylenebis[2,6-bis(1,1-dimethylethyl)-" "di(4-hydroxy-3,5-di-tert-butylphenyl)methane" "2,6-ditert-butyl-4-[(3,5-ditert-butyl-4-hydroxyphenyl)methyl]phenol" );
gibbsFormation
{
    dHf_298   -604330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     945.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81720.0
    phase     gas;
}
