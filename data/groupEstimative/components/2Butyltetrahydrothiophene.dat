/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyltetrahydrothiophene  (C8H16S, CAS 1613-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyltetrahydrothiophene;
formula     C8H16S;
CAS         1613-49-6;
InChIKey    NBPQJOLVXAKDFK-UHFFFAOYSA-N;
MW          144.276;      // g/mol [origin=calculated method=formula-sum]
Tc          653.90;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.3513;      // -   [origin=predictive method=lee-kesler]
Tb          445.75;      // K   [origin=predictive method=joback]
HvapTb      39471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.047 0.90993 -0.0005575 1.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butylthiolane" "thiophene, 2-butyltetrahydro-" );
standardThermochemistry
{
    dHf_298   -102710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92890.0
}
