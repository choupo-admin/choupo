/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-6-iodobenzoic acid  (C7H4FIO2, CAS 111771-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro6IodobenzoicAcid;
formula     C7H4FIO2;
CAS         111771-08-5;
InChIKey    CYCXAPWOBWWNRK-UHFFFAOYSA-N;
MW          266.005;      // g/mol [origin=calculated method=formula-sum]
Tc          886.32;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.7401;      // -   [origin=predictive method=lee-kesler]
Tb          634.32;      // K   [origin=predictive method=joback]
HvapTb      60496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.6 0.5725 -0.00042452 1.213e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group COOH; count 1; } { group I; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group I; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-fluoranyl-6-iodanyl-benzoic acid" "6-fluoro-2-iodobenzoic acid" "2-fluoro-6-iodobenzoicacid" );
gibbsFormation
{
    dHf_298   -443730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-379390.0
    phase     gas;
}
