/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-6-phenylhexane  (C12H17Cl, CAS 56644-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro6Phenylhexane;
formula     C12H17Cl;
CAS         56644-06-5;
InChIKey    RCVNHNOEUMFFDY-UHFFFAOYSA-N;
MW          196.718;      // g/mol [origin=calculated method=formula-sum]
Tc          742.63;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.5452;      // -   [origin=predictive method=lee-kesler]
Tb          538.27;      // K   [origin=predictive method=joback]
HvapTb      48967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.034 1.0717 -0.0006806 1.661e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-chloranylhexylbenzene" "(6-chlorohexyl)benzene" "6-phenylhexylchloride" "6-chlorohexylbenzene" "6-phenyl-n-hexylchloride;6-phenylhexylchloride;(6-chlorohexyl)benzene;1-chloro-6-phenylhexane" );
gibbsFormation
{
    dHf_298   -70220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150640.0
    phase     gas;
}
