/*--------------------------------*- Choupo -*-----------------------*\
  Component: sulfide, ethyl hexyl  (C8H18S, CAS 7309-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sulfideEthylHexyl;
formula     C8H18S;
CAS         7309-44-6;
InChIKey    MGVUJBCOCITTRS-UHFFFAOYSA-N;
MW          146.292;      // g/mol [origin=calculated method=formula-sum]
Tc          637.09;      // K   [origin=predictive method=joback]
Pc          25.793;      // bar [origin=predictive method=joback]
omega       0.4679;      // -   [origin=predictive method=lee-kesler]
Tb          451.42;      // K   [origin=predictive method=joback]
HvapTb      40219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.216 0.75823 -0.0003712 5.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylsulfanylhexane" "hexane, 1-(ethylthio)-" "ethylthiohexane" "ethyl n-hexyl sulfide" );
standardThermochemistry
{
    dHf_298   -166580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49600.0
}
