/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptene  (C7H12, CAS 628-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptene;
formula     C7H12;
CAS         628-92-2;
InChIKey    ZXIJMRYMVAMXQP-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          601.88;      // K   [origin=predictive method=joback]
Pc          39.506;      // bar [origin=predictive method=joback]
omega       0.2215;      // -   [origin=predictive method=lee-kesler]
Tb          387.41;      // K   [origin=predictive method=joback]
HvapTb      32378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.36 0.7518 -0.00043428 8.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-cycloheptene" "cyclohept-1-ene" );
gibbsFormation
{
    dHf_298   -61530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=58080.0
    phase     gas;
}
