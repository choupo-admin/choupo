/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbetidine  (C18H27NO4, CAS 469-82-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbetidine;
formula     C18H27NO4;
CAS         469-82-9;
InChIKey    KJTKYGFGPQSRRA-UHFFFAOYSA-N;
MW          321.417;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.01;      // K   [origin=predictive method=joback]
Pc          18.708;      // bar [origin=predictive method=joback]
omega       1.2993;      // -   [origin=predictive method=lee-kesler]
Tb          838.90;      // K   [origin=predictive method=joback]
HvapTb      85583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.345 2.09842 -0.001584 5.013e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group COO; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-[2-(2-hydroxyethyloxy)ethyl]-4-phenyl-piperidine-4-carboxylate" "etoxeridine" "atenos" "etosseridina" "etoxeridina" "etoxeridinum" "etosseridina [dcit]" "etoxeridine [inn:ban]" "etoxeridinum [inn-latin]" "ethyl 1-[2-(2-hydroxyethoxy)ethyl]-4-phenylpiperidine-4-carboxylate" "isonipecotic acid, 1-(2-(2-hydroxyethoxy)ethyl)-4-phenyl-, ethyl ester" "1-(2-(2-hydroxyethoxy)ethyl)-4-phenylpiperidine-4-carboxylic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -636800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     899.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197260.0
    phase     gas;
}
