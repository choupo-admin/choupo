/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-acetyl-7-(diethylamino)-2h-chromen-2-one  (C15H17NO3, CAS 74696-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Acetyl7Diethylamino2hChromen2One;
formula     C15H17NO3;
CAS         74696-96-1;
InChIKey    JQYDECSZBZCKFQ-UHFFFAOYSA-N;
MW          259.305;      // g/mol [origin=calculated method=formula-sum]
Tc          925.34;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       1.0031;      // -   [origin=predictive method=lee-kesler]
Tb          715.25;      // K   [origin=predictive method=joback]
HvapTb      69784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.958 1.34356 -0.00093086 2.5096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3CO; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group CdO; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(diethylamino)-3-ethanoyl-chromen-2-one" "3-acetyl-7-diethylamino-chromen-2-one" "3-acetyl-7-(diethylamino)chromen-2-one" "2h-1-benzopyran-2-one, 3-acetyl-7-(diethylamino)-" "3-acetyl-7-(diethylamino)coumarin" "3-acetyl-7-(diethylamino)-2-oxochromene" "3-acetyl-7-(diethylamino)-2-oxo-2h-chromene" "2h-1-benzopyran-2-one,3-acetyl-7-(diethylamino)-" "3-acetyl-7-(diethylamino)coumarin;7-diethylamino-3-acetylchromen-2-one;7-n,n-diethylamino-3-acetylcoumarin;3-acetyl-7-(diethylamino)-2h-chromen-2-one;2h-1-benzopyran-2-one, 3-acetyl-7-(diethylamino)-;3-acetyl-7-(diethylamino)-2h-chromen-2-one;3-acetyl-7-diethylamino-chromen-2-one;" );
gibbsFormation
{
    dHf_298   -356060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59050.0
    phase     gas;
}
