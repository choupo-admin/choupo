/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-octyn-2-one  (C8H12O, CAS 1119-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Octyn2One;
formula     C8H12O;
CAS         1119-58-0;
InChIKey    VJKHTMGYHCBXHV-UHFFFAOYSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          645.33;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.4316;      // -   [origin=predictive method=lee-kesler]
Tb          445.51;      // K   [origin=predictive method=joback]
HvapTb      42300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.533 0.58604 -0.00030056 5.394e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH3CO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group tC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-3-yn-2-one" "butyl(acetyl)acetylene" "3-octyne-2-one" );
standardThermochemistry
{
    dHf_298   -48730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90360.0
}
