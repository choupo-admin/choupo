/*--------------------------------*- Choupo -*-----------------------*\
  Component: octoxynol-9 carboxylic acid  (C32H56O11, CAS 25338-58-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octoxynol9CarboxylicAcid;
formula     C32H56O11;
CAS         25338-58-3;
InChIKey    LQGIRXNHIMWFSU-UHFFFAOYSA-N;
MW          616.789;      // g/mol [origin=calculated method=formula-sum]
Tc          1770.91;      // K   [origin=predictive method=joback]
Pc          6.133;      // bar [origin=predictive method=joback]
omega       -0.0516;      // -   [origin=predictive method=lee-kesler]
Tb          1310.71;      // K   [origin=predictive method=joback]
HvapTb      128618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (188.294 2.38742 -0.00075476 -9.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 9; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 24; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 9; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-[2-[2-[2-[2-(2-octylphenoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethanoic acid" "26-(2-octylphenoxy)-3,6,9,12,15,18,21,24-octaoxahexacosan-1-oic acid" "peg-9 octyl phenyl ether carboxylic acid" "3,6,9,12,15,18,21,24-octaoxahexacosanoic acid, 26-(octylphenoxy)-" "polyoxyethylene (9) octyl phenyl ether carboxylic acid" "polyethylene glycol 450 octyl phenyl ether carboxylic acid" "26-(octylphenoxy)-3,6,9,12,15,18,21,24-octaoxahexacosanoic acid" "3,6,9,12,15,18,21,24-octaoxahexacosanoicacid, 26-(octylphenoxy)-" "2-[2-[2-[2-[2-[2-[2-[2-[2-(2-octylphenoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]acetic acid" "aceticacid, [2-[2-[2-[2-[2-[2-[2-[2-(octylphenoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]-(8ci); octylphenoxyoctakis(ethyleneoxy)acetic acid" );
standardThermochemistry
{
    dHf_298   -2019000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1444.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-967570.0
}
