/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorobenzyl alcohol  (C7H7FO, CAS 459-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4FluorobenzylAlcohol;
formula     C7H7FO;
CAS         459-56-3;
InChIKey    GEZMEIHVFSWOCA-UHFFFAOYSA-N;
MW          126.13;      // g/mol [origin=calculated method=formula-sum]
Tc          674.10;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.7707;      // -   [origin=predictive method=lee-kesler]
Tb          482.87;      // K   [origin=predictive method=joback]
HvapTb      49976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.699 0.5762 -0.00036796 8.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-fluorophenyl)methanol" "p-fluorobenzyl alcohol" "benzenemethanol, 4-fluoro-" "4-fluorobenzylalcohol" "4-fluorobenzylic alcohol" "4-fluorobenzoic alcohol" "(4-fluorophenyl)methan-1-ol" "q1r df[wln]" "4-fluoro benzyl alcohol" "gezmeihvfswoca-uhfffaoysa-" "4- fluoro benzyl alcohol" "benzenemethanol, 4-fluoro- (9ci)" );
gibbsFormation
{
    dHf_298   -311090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-220790.0
    phase     gas;
}
