/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-hydroxystearamide  (C18H37NO2, CAS 7059-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Hydroxystearamide;
formula     C18H37NO2;
CAS         7059-49-6;
InChIKey    ALDZNWBBPCZXGH-UHFFFAOYSA-N;
MW          299.499;      // g/mol [origin=calculated method=formula-sum]
Tc          1016.92;      // K   [origin=predictive method=joback]
Pc          13.457;      // bar [origin=predictive method=joback]
omega       1.2220;      // -   [origin=predictive method=lee-kesler]
Tb          829.58;      // K   [origin=predictive method=joback]
HvapTb      89340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.985 1.78762 -0.0010137 2.1426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12-oxidanyloctadecanamide" "octadecanamide, 12-hydroxy-" "12-hydroxystearamine" "12-hydroxyoctadecanamide" "agn-pc-04t8sa" "12-hydroxyoctadecan-1-amide" "12-hydroxystearamide, tech" );
gibbsFormation
{
    dHf_298   -651150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     976.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101050.0
    phase     gas;
}
