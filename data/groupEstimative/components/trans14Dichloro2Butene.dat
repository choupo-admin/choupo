/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1,4-dichloro-2-butene  (C4H6Cl2, CAS 110-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans14Dichloro2Butene;
formula     C4H6Cl2;
CAS         110-57-6;
InChIKey    FQDIANVAWVHZIR-OWOJBTEDSA-N;
MW          124.992;      // g/mol [origin=calculated method=formula-sum]
Tc          562.11;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.2900;      // -   [origin=predictive method=lee-kesler]
Tb          370.14;      // K   [origin=predictive method=joback]
HvapTb      33226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.852 0.4174 -0.0003184 1.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1,4-bis(chloranyl)but-2-ene" "1,4-dichlorobut-2-ene" "(2e)-1,4-dichlorobut-2-ene" "2-butene, 1,4-dichloro-" "2-butylene dichloride" "trans-1,4-dichlorobutene" "2-butene, 1,4-dichloro-, (e)-" "1,4-dichloro-2-butene" "2-butene, 1,4-dichloro-, (2e)-" "1,4-dichlorobutene-2" "1,4-dichloro-2-butylene" "trans-1,4-dichlorobutene-2" );
standardThermochemistry
{
    dHf_298   -40150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39160.0
}
