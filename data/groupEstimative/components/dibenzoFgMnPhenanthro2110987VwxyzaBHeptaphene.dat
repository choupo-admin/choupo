/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzo[fg,mn]phenanthro[2,1,10,9,8,7-vwxyza,b]heptaphene  (C42H20, CAS 34814-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzoFgMnPhenanthro2110987VwxyzaBHeptaphene;
formula     C42H20;
CAS         34814-80-7;
InChIKey    KSYHAESVGPXYEH-UHFFFAOYSA-N;
MW          524.622;      // g/mol [origin=calculated method=formula-sum]
Tc          1732.41;      // K   [origin=predictive method=joback]
Pc          13.536;      // bar [origin=predictive method=joback]
omega       1.2437;      // -   [origin=predictive method=lee-kesler]
Tb          1415.02;      // K   [origin=predictive method=joback]
HvapTb      133478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-262.23 3.58 -0.0035478 1.3796e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 20; } { group AC; count 22; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 20; } { group dC_ring; count 22; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo(fg,mn)phenanthro(2,1,10,9,8,7-vwxyza,b)heptaphene" );
standardThermochemistry
{
    dHf_298   1131550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1468980.0
}
