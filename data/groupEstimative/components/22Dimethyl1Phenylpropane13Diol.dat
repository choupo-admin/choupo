/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-1-phenylpropane-1,3-diol  (C11H16O2, CAS 33950-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl1Phenylpropane13Diol;
formula     C11H16O2;
CAS         33950-46-8;
InChIKey    UTWCLCFHXYGTTF-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          851.84;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       1.2872;      // -   [origin=predictive method=lee-kesler]
Tb          658.65;      // K   [origin=predictive method=joback]
HvapTb      74030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.589 1.16964 -0.0008416 2.362e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-1-phenyl-propane-1,3-diol" "2,2-dimethyl-1-phenyl-1,3-propanediol" "1,3-propanediol,2,2-dimethyl-1-phenyl-" "1,3-propanediol, 2,2-dimethyl-1-phenyl-" );
standardThermochemistry
{
    dHf_298   -352330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119090.0
}
