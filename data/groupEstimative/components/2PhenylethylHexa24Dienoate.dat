/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylethyl hexa-2,4-dienoate  (C14H16O2, CAS 35416-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylethylHexa24Dienoate;
formula     C14H16O2;
CAS         35416-42-3;
InChIKey    PPZYQYDDSJRELL-UHFFFAOYSA-N;
MW          216.28;      // g/mol [origin=calculated method=formula-sum]
Tc          827.62;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       0.6629;      // -   [origin=predictive method=lee-kesler]
Tb          613.14;      // K   [origin=predictive method=joback]
HvapTb      56357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.698 1.24012 -0.000842 2.186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-hexadienoic acid, 2-phenylethyl ester" "2,4-hexadienoicacid, phenethyl ester" "2,4-hexadienoic acid,2-phenylethyl ester" "2,4-hexadienoic acid 2-phenylethyl ester" );
gibbsFormation
{
    dHf_298   -178600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29480.0
    phase     gas;
}
