/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl metacrylate, butyl acrylate, tetraethylene glycol dimethacrylate polymer  (C26H42O10, CAS 56938-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylMetacrylateButylAcrylateTetraethyleneGlycolDimethacryl;
formula     C26H42O10;
CAS         56938-23-9;
InChIKey    BHYKTJVJXZAAFT-UHFFFAOYSA-N;
MW          514.612;      // g/mol [origin=calculated method=formula-sum]
Tc          1308.98;      // K   [origin=predictive method=joback]
Pc          7.222;      // bar [origin=predictive method=joback]
omega       0.6023;      // -   [origin=predictive method=lee-kesler]
Tb          1061.36;      // K   [origin=predictive method=joback]
HvapTb      106066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (202.489 1.6356 -5.91e-05 -3.992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 7; } { group CH2=CH; count 1; } { group CH2=C; count 3; } { group CH2O; count 2; } { group COO; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 9; } { group dCH2; count 4; } { group dCH; count 1; } { group dC; count 3; } { group O; count 2; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;methyl 2-methylprop-2-enoate;2-[2-[2-(2-methylprop-2-enoyloxy)ethoxy]ethoxy]ethyl 2-methylprop-2-enoate" "butyl prop-2-enoate; methyl 2-methylprop-2-enoate; 2-[2-[2-(2-methylprop-2-enoyloxy)ethoxy]ethoxy]ethyl 2-methylprop-2-enoate" "methyl methacrylate, polymer with butyl acrylate and tetraethylene glycol dimethacrylate" "2-propenoic acid, 2-methyl-, 1,2-ethanediylbis(oxy-2,1-ethanediyl) ester, polymer with butyl 2-propenoate and methyl 2-methyl-2-propenoate" "2-propenoic acid, 2-methyl-, 1,1'-(1,2-ethanediylbis(oxy-2,1-ethanediyl)) ester, polymer with butyl 2-propenoate and methyl 2-methyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -1864420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1580.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1167250.0
}
