/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(benzyloxy)ethoxy]ethanol  (C11H16O3, CAS 2050-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BenzyloxyEthoxyEthanol;
formula     C11H16O3;
CAS         2050-25-1;
InChIKey    LJVNVNLFZQFJHU-UHFFFAOYSA-N;
MW          196.246;      // g/mol [origin=calculated method=formula-sum]
Tc          802.66;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       1.0808;      // -   [origin=predictive method=lee-kesler]
Tb          614.98;      // K   [origin=predictive method=joback]
HvapTb      63855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.275 0.8775 -0.0004142 4.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-phenylmethoxyethoxy)ethanol" "diethylene glycol monobenzyl ether" "di(ethylene glycol) benzyl ether" "ethanol, 2-[2-(benzyloxy)ethoxy]-" "ethanol, 2-[2-(phenylmethoxy)ethoxy]-" "2-(2-(benzyloxy)ethoxy)ethanol" "ethanol,2-[2-(phenylmethoxy)ethoxy]-" );
standardThermochemistry
{
    dHf_298   -450510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-192670.0
}
