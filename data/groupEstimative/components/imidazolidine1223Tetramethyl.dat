/*--------------------------------*- Choupo -*-----------------------*\
  Component: imidazolidine, 1,2,2,3-tetramethyl-  (C7H16N2, CAS 33709-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        imidazolidine1223Tetramethyl;
formula     C7H16N2;
CAS         33709-65-8;
InChIKey    NAADVJQGVMQUNR-UHFFFAOYSA-N;
MW          128.219;      // g/mol [origin=calculated method=formula-sum]
Tc          574.81;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.3901;      // -   [origin=predictive method=lee-kesler]
Tb          391.62;      // K   [origin=predictive method=joback]
HvapTb      34024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.09 1.35948 -0.001335 5.442e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2,3-tetramethylimidazolidine" );
standardThermochemistry
{
    dHf_298   35290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=284880.0
}
