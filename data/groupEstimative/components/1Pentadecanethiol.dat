/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentadecanethiol  (C15H32S, CAS 25276-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentadecanethiol;
formula     C15H32S;
CAS         25276-70-4;
InChIKey    IGMQODZGDORXEN-UHFFFAOYSA-N;
MW          244.481;      // g/mol [origin=calculated method=formula-sum]
Tc          779.96;      // K   [origin=predictive method=joback]
Pc          14.861;      // bar [origin=predictive method=joback]
omega       0.7771;      // -   [origin=predictive method=lee-kesler]
Tb          605.66;      // K   [origin=predictive method=joback]
HvapTb      55721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.144 1.45612 -0.0008146 1.729e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecane-1-thiol" "pentadecyl mercaptan" "pentadecanethiol;pentadecane-1-thiol;n-pentadecyl mercaptan;" );
standardThermochemistry
{
    dHf_298   -314450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     802.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104810.0
}
