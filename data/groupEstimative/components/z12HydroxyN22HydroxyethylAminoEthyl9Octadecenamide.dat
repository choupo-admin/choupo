/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-12-hydroxy-n-[2-[(2-hydroxyethyl)amino]ethyl]-9-octadecenamide  (C22H44N2O3, CAS 94425-50-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z12HydroxyN22HydroxyethylAminoEthyl9Octadecenamide;
formula     C22H44N2O3;
CAS         94425-50-0;
InChIKey    MXWVBGZSOBZROQ-UHFFFAOYSA-N;
MW          384.605;      // g/mol [origin=calculated method=formula-sum]
Tc          1311.28;      // K   [origin=predictive method=joback]
Pc          11.133;      // bar [origin=predictive method=joback]
omega       0.8016;      // -   [origin=predictive method=lee-kesler]
Tb          1045.25;      // K   [origin=predictive method=joback]
HvapTb      117112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.453 2.31212 -0.0013993 3.2906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 2; } { group CH2NH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 2; } { group CdO; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(2-hydroxyethylamino)ethyl]-12-oxidanyl-octadec-9-enamide" "9-octadecenamide, 12-hydroxy-n-[2-[(2-hydroxyethyl)amino]ethyl]-, (9z,12r)-" "(z)-12-hydroxy-n-[2-(2-hydroxyethylamino)ethyl]octadec-9-enamide" );
gibbsFormation
{
    dHf_298   -695570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1206.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11640.0
    phase     gas;
}
