/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methyl-n,n-bis(7-methyloctyl)octan-1-amine  (C27H57N, CAS 18198-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7MethylNNBis7MethyloctylOctan1Amine;
formula     C27H57N;
CAS         18198-40-8;
InChIKey    YGLJGOMFUHQSBN-UHFFFAOYSA-N;
MW          395.76;      // g/mol [origin=calculated method=formula-sum]
Tc          1014.38;      // K   [origin=predictive method=joback]
Pc          6.969;      // bar [origin=predictive method=joback]
omega       0.6388;      // -   [origin=predictive method=lee-kesler]
Tb          828.48;      // K   [origin=predictive method=joback]
HvapTb      76575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.392 2.71052 -0.0015672 3.46e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 17; } { group CH; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 18; } { group CH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-octanamine, 7-methyl-n,n-bis(7-methyloctyl)-" "triisononylamine" "triisononylamine;" "7,7',7''-trimethyltrioctylamine" "isononanamine,n,n-diisononyl- (9ci)" "trioctylamine, 7,7',7''-trimethyl-" );
gibbsFormation
{
    dHf_298   -548920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1195.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=279920.0
    phase     gas;
}
