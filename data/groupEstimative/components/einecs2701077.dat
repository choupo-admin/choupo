/*--------------------------------*- Choupo -*-----------------------*\
  Component: einecs 270-107-7  (C8H14Cl2O3, CAS 68411-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        einecs2701077;
formula     C8H14Cl2O3;
CAS         68411-17-6;
InChIKey    SVZNDHYAUMYQRT-UHFFFAOYSA-N;
MW          229.097;      // g/mol [origin=calculated method=formula-sum]
Tc          859.76;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       1.3878;      // -   [origin=predictive method=lee-kesler]
Tb          674.68;      // K   [origin=predictive method=joback]
HvapTb      80386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (115.856 0.4262 0.00010494 -1.7142e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 2; } { group CH2O; count 1; } { group CH2Cl; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group tC; count 2; } { group Cl; count 2; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-yne-1,4-diol;1-chloranyl-2-(2-chloroethyloxy)ethane" "but-2-yne-1,4-diol; 1-chloro-2-(2-chloroethoxy)ethane" );
standardThermochemistry
{
    dHf_298   -515930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     726.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287980.0
}
