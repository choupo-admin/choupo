/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethylphenyl isocyanate  (C9H9NO, CAS 28556-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DimethylphenylIsocyanate;
formula     C9H9NO;
CAS         28556-81-2;
InChIKey    YQLRKXVEALTVCZ-UHFFFAOYSA-N;
MW          147.177;      // g/mol [origin=calculated method=formula-sum]
Tc          728.78;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.5160;      // -   [origin=predictive method=lee-kesler]
Tb          508.83;      // K   [origin=predictive method=joback]
HvapTb      48760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 2; } { group dCd; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-isocyanato-1,3-dimethyl-benzene" "2-isocyanato-1,3-dimethylbenzene" "benzene, 2-isocyanato-1,3-dimethyl-" "isocyanic acid 2,6-dimethylphenyl ester" "2,6-dimethylbenzenisocyanate" "benzene,2-isocyanato-1,3-dimethyl-" );
