/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-isopropylacetophenone  (C11H14O, CAS 645-13-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropylacetophenone;
formula     C11H14O;
CAS         645-13-6;
InChIKey    PDLCCNYKIIUWHA-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          753.78;      // K   [origin=predictive method=joback]
Pc          28.084;      // bar [origin=predictive method=joback]
omega       0.5303;      // -   [origin=predictive method=lee-kesler]
Tb          536.37;      // K   [origin=predictive method=joback]
HvapTb      49376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.04 0.88836 -0.00052326 1.1076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-propan-2-ylphenyl)ethanone" "p-isopropylacetophenone" "4-isopropylacetophenone" "acetophenone, 4'-isopropyl-" "cuminone" "ethanone, 1-[4-(1-methylethyl)phenyl]-" "1-acetyl-4-(methylethyl)benzene" "ethanone, 1-(4-(1-methylethyl)phenyl)-" "acetylcumene, p-" "p-iso-propylacetophenone" "4-isopropyl acetophenone" "4'-isopropyl acetophenone" );
standardThermochemistry
{
    dHf_298   -163170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13160.0
}
