/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, polymer with butyl 2-propenoate and isooctyl 2-propenoate  (C21H36O6, CAS 63793-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcidPolymerWithButyl2PropenoateAndIsooctyl2Propeno;
formula     C21H36O6;
CAS         63793-44-2;
InChIKey    CFWSRINOMBYLFK-UHFFFAOYSA-N;
MW          384.513;      // g/mol [origin=calculated method=formula-sum]
Tc          1144.86;      // K   [origin=predictive method=joback]
Pc          9.908;      // bar [origin=predictive method=joback]
omega       0.9513;      // -   [origin=predictive method=lee-kesler]
Tb          934.43;      // K   [origin=predictive method=joback]
HvapTb      92508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (110.198 1.47356 -0.0002443 -2.302e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group CH2=CH; count 3; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;6-methylheptyl prop-2-enoate;prop-2-enoic acid" "butyl prop-2-enoate; 6-methylheptyl prop-2-enoate; prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1313830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1321.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-787150.0
    phase     gas;
}
