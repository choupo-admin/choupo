/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7-diazabicyclo[5.3.3]tridecane  (C11H22N2, CAS 84904-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Diazabicyclo533Tridecane;
formula     C11H22N2;
CAS         84904-98-3;
InChIKey    VBTHWDNQHNQCRK-UHFFFAOYSA-N;
MW          182.311;      // g/mol [origin=calculated method=formula-sum]
Tc          741.12;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.4864;      // -   [origin=predictive method=lee-kesler]
Tb          520.33;      // K   [origin=predictive method=joback]
HvapTb      45470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.46 1.6034 -0.001119 3e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,7-diazabicyclo(5.3.3)tridecane" );
gibbsFormation
{
    dHf_298   20170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=339720.0
    phase     gas;
}
