/*--------------------------------*- Choupo -*-----------------------*\
  Component: acrylamide, acrylonitrile, butyl acrylate, ethyl acrylate, itaconic acid polymer  (C23H34N2O9, CAS 51329-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acrylamideAcrylonitrileButylAcrylateEthylAcrylateItaconicAci;
formula     C23H34N2O9;
CAS         51329-93-2;
InChIKey    XSYKKQSDNJJPOV-UHFFFAOYSA-N;
MW          482.53;      // g/mol [origin=calculated method=formula-sum]
Tc          1686.52;      // K   [origin=predictive method=joback]
Pc          9.295;      // bar [origin=predictive method=joback]
omega       0.7008;      // -   [origin=predictive method=lee-kesler]
Tb          1350.66;      // K   [origin=predictive method=joback]
HvapTb      141705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (221.475 1.22464 0.0003653 -5.8004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2=CH; count 3; } { group CH2=C; count 1; } { group COOH; count 2; } { group ACRY; count 1; } { group COO; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH2; count 5; } { group dCH; count 4; } { group dC; count 1; } { group CdO; count 1; } { group COOH; count 2; } { group COO; count 2; } { group NH2; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;ethyl prop-2-enoate;2-methylidenebutanedioic acid;prop-2-enamide;prop-2-enenitrile" "butyl prop-2-enoate; ethyl prop-2-enoate; 2-methylidenebutanedioic acid; prop-2-enamide; prop-2-enenitrile" "butanedioic acid, 2-methylene-, polymer with butyl 2-propenoate, ethyl 2-propenoate, 2-propenamide and 2-propenenitrile" "butanedioic acid, methylene-, polymer with butyl 2-propenoate, ethyl 2-propenoate, 2-propenamide and 2-propenenitrile" "butanedioic acid, methylene-, polymer with butyl 2-propenoate, ethyl 2-propenoate, 2-propenamide and 2-propenenitrile;acrylamide, acrylonitrile, butyl acrylate, ethyl acrylate, itaconicacid polymer" );
gibbsFormation
{
    dHf_298   -1596180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1748.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1083460.0
    phase     gas;
}
