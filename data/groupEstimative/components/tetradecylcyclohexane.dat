/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecylcyclohexane  (C20H40, CAS 1795-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecylcyclohexane;
formula     C20H40;
CAS         1795-18-2;
InChIKey    NQAVPKIJZCHUNS-UHFFFAOYSA-N;
MW          280.54;      // g/mol [origin=calculated method=formula-sum]
Tc          855.51;      // K   [origin=predictive method=joback]
Pc          11.625;      // bar [origin=predictive method=joback]
omega       0.7634;      // -   [origin=predictive method=lee-kesler]
Tb          676.75;      // K   [origin=predictive method=joback]
HvapTb      60543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.897 2.02592 -0.0011452 2.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, tetradecyl-" "1-cyclohexyltetradecane" "myristylcyclohexane" );
standardThermochemistry
{
    dHf_298   -401810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     904.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141970.0
}
