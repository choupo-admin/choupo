/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanoic acid;n,n,n',n'-tetramethylethane-1,2-diamine  (C8H20N2O4, CAS 128023-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H20N2O4 (delta H+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methanoicAcidNNNNTetramethylethane12Diamine;
formula     C8H20N2O4;
CAS         128023-58-5;
InChIKey    ILPMVMXIMKESDW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          208.258;      // g/mol [origin=calculated method=formula-sum]
Tc          899.35;      // K   [origin=predictive method=joback]
Pc          25.925;      // bar [origin=predictive method=joback]
omega       1.1855;      // -   [origin=predictive method=lee-kesler]
Tb          699.94;      // K   [origin=predictive method=joback]
HvapTb      72110.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.252 0.90708 -0.000367 -2.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH3N; count 2; } { group HCOOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group COOH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "formic acid, compd. with n,n,n',n'-tetramethyl-1,2-ethanediamine (2:1)" "formic acid, compd. with n,n,n,n-tetramethyl-1,2-ethanediamine (2:1)" "formic acid, compd. with n1,n1,n2,n2-tetramethyl-1,2-ethanediamine (2:1)" );
standardThermochemistry
{
    dHf_298   -885550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     844.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-554540.0
}
