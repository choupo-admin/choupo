/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetoxypropanoic acid  (C5H8O4, CAS 535-17-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AcetoxypropanoicAcid;
formula     C5H8O4;
CAS         535-17-1;
InChIKey    WTLNOANVTIKPEE-UHFFFAOYSA-N;
MW          132.115;      // g/mol [origin=calculated method=formula-sum]
Tc          718.19;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.7653;      // -   [origin=predictive method=lee-kesler]
Tb          517.29;      // K   [origin=predictive method=joback]
HvapTb      50907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.67 0.48074 -0.0002294 1.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-acetyloxypropanoic acid" "acetolactate" "o-acetyllactic acid" "alpha-acetolactate" "lactic acid, acetate" "alpha-acetoxypropionic acid" ".alpha.-acetoxypropionic acid" "(+/-)-2-acetoxypropionic acid" "propanoic acid, 2-(acetyloxy)-" "o-acetyl-l-lactic acid" "2-acetoxypropionic acid" "lactic acid, acetate (8ci)" );
standardThermochemistry
{
    dHf_298   -819360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-665500.0
}
