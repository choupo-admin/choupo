/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-decynoic acid  (C10H16O2, CAS 1642-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9DecynoicAcid;
formula     C10H16O2;
CAS         1642-49-5;
InChIKey    KHOZXYSECXUORA-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          756.24;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.8120;      // -   [origin=predictive method=lee-kesler]
Tb          564.03;      // K   [origin=predictive method=joback]
HvapTb      54876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.177 0.9107 -0.00058873 1.5419e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group COOH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group tCH; count 1; } { group tC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-9-ynoic acid" );
gibbsFormation
{
    dHf_298   -308100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87520.0
    phase     gas;
}
