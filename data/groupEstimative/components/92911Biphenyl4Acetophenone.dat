/*--------------------------------*- Choupo -*-----------------------*\
  Component: 92-91-1 biphenyl-4-acetophenone  (C20H16O, CAS 27644-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        92911Biphenyl4Acetophenone;
formula     C20H16O;
CAS         27644-00-4;
InChIKey    HZXXIQLDHPWKLO-UHFFFAOYSA-N;
MW          272.347;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.94;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.7912;      // -   [origin=predictive method=lee-kesler]
Tb          796.09;      // K   [origin=predictive method=joback]
HvapTb      74350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.349 1.5796 -0.00107206 2.6936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 4; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-2-(4-phenylphenyl)ethanone" "alpha,alpha-diphenyl acetophenone" "st023" "2-(biphenyl-4-yl)-1-phenylethanone" "2-([1,1'-biphenyl]-4-yl)-1-phenylethanone" );
standardThermochemistry
{
    dHf_298   129410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316200.0
}
