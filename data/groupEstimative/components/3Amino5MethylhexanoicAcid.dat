/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-5-methylhexanoic acid  (C7H15NO2, CAS 3653-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino5MethylhexanoicAcid;
formula     C7H15NO2;
CAS         3653-34-7;
InChIKey    MLYMSIKVLAPCAK-UHFFFAOYSA-N;
MW          145.202;      // g/mol [origin=calculated method=formula-sum]
Tc          781.48;      // K   [origin=predictive method=joback]
Pc          33.490;      // bar [origin=predictive method=joback]
omega       0.8622;      // -   [origin=predictive method=lee-kesler]
Tb          576.92;      // K   [origin=predictive method=joback]
HvapTb      58205.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.252 0.79334 -0.0004794 1.101e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-5-methyl-hexanoic acid" "3-amino-5-methyl-hexanoic acid" "dl-beta-homoleucine" "(r)-3-amino-5-methyl-hexanoicacid" "(s)-3-amino-5-methyl-hexanoicacid" "d,l-beta-homoleucine" "3-amino-5-methylhexanoicacid" "()-3-amino-5-methylcaproic acid" "()-3-amino-5-methylhexanoic acid" "(+/-)-3-amino-5-methylcaproic acid" "(+/-)-3-amino-5-methylhexanoic acid" );
gibbsFormation
{
    dHf_298   -514850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-274280.0
    phase     gas;
}
