/*--------------------------------*- Choupo -*-----------------------*\
  Component: guaiacol, camphenated, hydrogenated  (C17H24O2, CAS 70955-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        guaiacolCamphenatedHydrogenated;
formula     C17H24O2;
CAS         70955-70-3;
InChIKey    APKSVDDENNTSHL-UHFFFAOYSA-N;
MW          260.377;      // g/mol [origin=calculated method=formula-sum]
Tc          973.11;      // K   [origin=predictive method=joback]
Pc          21.453;      // bar [origin=predictive method=joback]
omega       0.7556;      // -   [origin=predictive method=lee-kesler]
Tb          732.16;      // K   [origin=predictive method=joback]
HvapTb      70127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-116.44 1.86526 -0.00144156 4.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethyl-2-methylidene-bicyclo[2.2.1]heptane;2-methoxyphenol" "3,3-dimethyl-2-methylidenebicyclo[2.2.1]heptane; 2-methoxyphenol" "phenol, 2-methoxy-, reaction products with 2,2-dimethyl-3-methylenebicyclo(2.2.1)heptane" );
gibbsFormation
{
    dHf_298   -360250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-10430.0
    phase     gas;
}
