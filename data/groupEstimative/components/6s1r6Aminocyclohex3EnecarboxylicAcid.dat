/*--------------------------------*- Choupo -*-----------------------*\
  Component: (6s,1r)-6-aminocyclohex-3-enecarboxylic acid  (C7H11NO2, CAS 54162-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6s1r6Aminocyclohex3EnecarboxylicAcid;
formula     C7H11NO2;
CAS         54162-90-2;
InChIKey    CQINMZNDBYQHKR-RITPCOANSA-N;
MW          141.17;      // g/mol [origin=calculated method=formula-sum]
Tc          827.18;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       0.7574;      // -   [origin=predictive method=lee-kesler]
Tb          591.84;      // K   [origin=predictive method=joback]
HvapTb      59393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.27 0.8211 -0.00048588 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,6s)-6-azanylcyclohex-3-ene-1-carboxylic acid" "aa004" "(1r,6s)-6-aminocyclohex-3-ene-1-carboxylic acid" "3-cyclohexene-1-carboxylic acid, 6-amino-, (1r,6s)-" "3-cyclohexene-1-carboxylicacid, 6-amino-, (1r,6s)-" "3-cyclohexene-1-carboxylicacid, 6-amino-, (1r-cis)-; (1r,2s)-2-amino-4-cyclohexene-1-carboxylic acid;cis-(1r,2s)-2-amino-4-cyclohexene-1-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -412530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222700.0
}
