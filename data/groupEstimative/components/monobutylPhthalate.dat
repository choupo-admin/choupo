/*--------------------------------*- Choupo -*-----------------------*\
  Component: monobutyl phthalate  (C12H14O4, CAS 131-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monobutylPhthalate;
formula     C12H14O4;
CAS         131-70-4;
InChIKey    YZBOVSFWWNVKRJ-UHFFFAOYSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          925.06;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       1.0409;      // -   [origin=predictive method=lee-kesler]
Tb          709.55;      // K   [origin=predictive method=joback]
HvapTb      69815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.383 1.00142 -0.00057116 1.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxycarbonylbenzoic acid" "mono-n-butyl phthalate" "butyl hydrogen phthalate" "phthalic acid, monobutyl ester" "2-(butoxycarbonyl)benzoic acid" "1,2-benzenedicarboxylic acid, monobutyl ester" "phthalic acid monobutyl ester" "1,2-benzenedicarboxylic acid, 1-butyl ester" "mbp" "monobutylphthalate" "mnbp" "-n-butyl-phthalate" );
gibbsFormation
{
    dHf_298   -733500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-501340.0
    phase     gas;
}
