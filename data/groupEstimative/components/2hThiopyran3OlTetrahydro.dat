/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-thiopyran-3-ol, tetrahydro-  (C5H10OS, CAS 22072-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hThiopyran3OlTetrahydro;
formula     C5H10OS;
CAS         22072-19-1;
InChIKey    ZHHOMIAGFRSWCU-UHFFFAOYSA-N;
MW          118.194;      // g/mol [origin=calculated method=formula-sum]
Tc          685.05;      // K   [origin=predictive method=joback]
Pc          50.514;      // bar [origin=predictive method=joback]
omega       0.6245;      // -   [origin=predictive method=lee-kesler]
Tb          473.56;      // K   [origin=predictive method=joback]
HvapTb      49644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.15 0.64931 -0.0003783 7.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thian-3-ol" "tetrahydrothiopyran-3-ol" "3-thia-1-cyclohexanol" "2h-thiopyran-3-ol,tetrahydro-" );
standardThermochemistry
{
    dHf_298   -199180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81290.0
}
