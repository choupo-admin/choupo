/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,5-dimethyl-2-vinyl-4-hexenoate  (C11H18O2, CAS 66052-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl25Dimethyl2Vinyl4Hexenoate;
formula     C11H18O2;
CAS         66052-32-2;
InChIKey    XMOTZXPRFDJZPA-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          699.65;      // K   [origin=predictive method=joback]
Pc          21.613;      // bar [origin=predictive method=joback]
omega       0.5082;      // -   [origin=predictive method=lee-kesler]
Tb          506.99;      // K   [origin=predictive method=joback]
HvapTb      45559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.039 1.11978 -0.0007608 2.011e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-ethenyl-2,5-dimethyl-hex-4-enoate" "methyl 2,5-dimethyl-2-vinylhex-4-enoate" "methyl 2-ethenyl-2,5-dimethylhex-4-enoate" "4-hexenoic acid, 2-ethenyl-2,5-dimethyl-, methyl ester" );
standardThermochemistry
{
    dHf_298   -363540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106280.0
}
