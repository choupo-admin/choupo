/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexene-1-methanol, 3(or 4)-(4-methyl-3-pentenyl)-  (C13H22O, CAS 72403-68-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexene1Methanol3Or44Methyl3Pentenyl;
formula     C13H22O;
CAS         72403-68-0;
InChIKey    OCWPZKYJUSNHGL-ZDUSSCGKSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          809.69;      // K   [origin=predictive method=joback]
Pc          22.871;      // bar [origin=predictive method=joback]
omega       0.8977;      // -   [origin=predictive method=lee-kesler]
Tb          616.95;      // K   [origin=predictive method=joback]
HvapTb      62632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.037 1.29934 -0.00080114 1.914e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1s)-3-(4-methylpent-3-enyl)cyclohex-3-en-1-yl]methanol" "3-cyclohexene-1-methanol, 3(or 4)-(4-methyl-3-penten-1-yl)-" );
gibbsFormation
{
    dHf_298   -255820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38210.0
    phase     gas;
}
