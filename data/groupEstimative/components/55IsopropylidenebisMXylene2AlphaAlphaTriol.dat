/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5'-isopropylidenebis(m-xylene-2,alpha,alpha'-triol)  (C19H24O6, CAS 3957-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55IsopropylidenebisMXylene2AlphaAlphaTriol;
formula     C19H24O6;
CAS         3957-22-0;
InChIKey    ZRIRUWWYQXWRNY-UHFFFAOYSA-N;
MW          348.395;      // g/mol [origin=calculated method=formula-sum]
Tc          1538.10;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       1.7486;      // -   [origin=predictive method=lee-kesler]
Tb          1234.33;      // K   [origin=predictive method=joback]
HvapTb      156536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.146 1.98404 -0.00161016 5.436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group ACCH2; count 4; } { group OH; count 4; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-[3,5-bis(hydroxymethyl)-4-oxidanyl-phenyl]propan-2-yl]-2,6-bis(hydroxymethyl)phenol" "5,5'-(1-methylethylidene)bis(2-hydroxy-1,3-benzenedimethanol)" "1,3-benzenedimethanol, 5,5'-(1-methylethylidene)bis(2-hydroxy-" "1,3-benzenedimethanol, 5,5'-(1-methylethylidene)bis[2-hydroxy-" "4,4'-propane-2,2-diylbis[2,6-bis(hydroxymethyl)phenol]" "1,3-benzenedimethanol, 5,5-(1-methylethylidene)bis(2-hydroxy-" "4-[2-[4-hydroxy-3,5-bis(hydroxymethyl)phenyl]propan-2-yl]-2,6-bis(hydroxymethyl)phenol" );
gibbsFormation
{
    dHf_298   -980600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     876.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-558280.0
    phase     gas;
}
