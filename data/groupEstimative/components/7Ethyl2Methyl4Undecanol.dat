/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-ethyl-2-methyl-4-undecanol  (C14H30O, CAS 103-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Ethyl2Methyl4Undecanol;
formula     C14H30O;
CAS         103-20-8;
InChIKey    JKKBSZCOVNFRCQ-UHFFFAOYSA-N;
MW          214.393;      // g/mol [origin=calculated method=formula-sum]
Tc          775.36;      // K   [origin=predictive method=joback]
Pc          16.714;      // bar [origin=predictive method=joback]
omega       0.9959;      // -   [origin=predictive method=lee-kesler]
Tb          610.78;      // K   [origin=predictive method=joback]
HvapTb      62273.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.593 1.38558 -0.0007778 1.637e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-ethyl-2-methyl-undecan-4-ol" "7-ethyl-2-methylundecan-4-ol" "4-undecanol, 7-ethyl-2-methyl-" "7-ethyl-2-methyl-4-hendecanol" "4-undecanol,7-ethyl-2-methyl-" );
gibbsFormation
{
    dHf_298   -500360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77140.0
    phase     gas;
}
