/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dibromo-2,3-dichloroaniline  (C6H3Br2Cl2N, CAS 113571-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dibromo23Dichloroaniline;
formula     C6H3Br2Cl2N;
CAS         113571-15-6;
InChIKey    IPWGDMQXLGFBLC-UHFFFAOYSA-N;
MW          319.805;      // g/mol [origin=calculated method=formula-sum]
Tc          937.62;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       0.7663;      // -   [origin=predictive method=lee-kesler]
Tb          663.19;      // K   [origin=predictive method=joback]
HvapTb      66155.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.38 0.4088 -0.00029264 8.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 2; } { group ACNH2; count 1; } { group ACCl; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 2; } { group Br; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6-bis(bromanyl)-2,3-bis(chloranyl)aniline" "4,6-dibromo-2,3-dichlorophenylamine" "4,6-dibromo-2,3-dichloro-phenylamine" "benzenamine,4,6-dibromo-2,3-dichloro-" );
gibbsFormation
{
    dHf_298   78450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144760.0
    phase     gas;
}
