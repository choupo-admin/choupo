/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorobenzyl alcohol  (C7H7ClO, CAS 17849-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChlorobenzylAlcohol;
formula     C7H7ClO;
CAS         17849-38-6;
InChIKey    MBYQPPXEXWRMQC-UHFFFAOYSA-N;
MW          142.582;      // g/mol [origin=calculated method=formula-sum]
Tc          727.76;      // K   [origin=predictive method=joback]
Pc          43.340;      // bar [origin=predictive method=joback]
omega       0.7721;      // -   [origin=predictive method=lee-kesler]
Tb          521.03;      // K   [origin=predictive method=joback]
HvapTb      55178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.899 0.5712 -0.00037196 9.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-chlorophenyl)methanol" "benzenemethanol, 2-chloro-" "benzyl alcohol, o-chloro-" "(2-chlorophenyl)methan-1-ol" "2-chlorobenzenemethanol" "o-chlorobenzyl alcohol" "(2-chlorophenyl)-methanol" "2-chloro-benzenemethanol" "2-chlorobenzenemethanol;(2-chlorophenyl)methanol;o-chlorobenzyl alcohol;benzylalcohol, o-chloro- (6ci,8ci);" );
standardThermochemistry
{
    dHf_298   -130720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37910.0
}
