/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-diacetyloxypropyl octadec-9-enoate  (C25H44O6, CAS 55401-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DiacetyloxypropylOctadec9Enoate;
formula     C25H44O6;
CAS         55401-64-4;
InChIKey    KXLSJQTXSAYFDL-UHFFFAOYSA-N;
MW          440.621;      // g/mol [origin=calculated method=formula-sum]
Tc          1166.43;      // K   [origin=predictive method=joback]
Pc          7.966;      // bar [origin=predictive method=joback]
omega       0.7316;      // -   [origin=predictive method=lee-kesler]
Tb          949.98;      // K   [origin=predictive method=joback]
HvapTb      93035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.526 2.24036 -0.0011394 1.619e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3COO; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } { group dCH; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-diacetyloxypropyl (z)-octadec-9-enoate" "9-octadecenoic acid (9z)-, 2,3-bis(acetyloxy)propyl ester" "9-octadecenoic acid (9z)-, ester with 1,2,3-propanetriol diacetate" );
gibbsFormation
{
    dHf_298   -1399230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1267.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-693710.0
    phase     gas;
}
