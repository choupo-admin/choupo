/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-cyclobutanedicarboxylic acid  (C6H8O4, CAS 5445-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11CyclobutanedicarboxylicAcid;
formula     C6H8O4;
CAS         5445-51-2;
InChIKey    CCQPAEQGAVNNIA-UHFFFAOYSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          872.38;      // K   [origin=predictive method=joback]
Pc          49.874;      // bar [origin=predictive method=joback]
omega       1.0145;      // -   [origin=predictive method=lee-kesler]
Tb          639.15;      // K   [origin=predictive method=joback]
HvapTb      62212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.72 1.1086 -0.0011542 4.836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group C_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutane-1,1-dicarboxylic acid" "cyclobutanedicarbonic acid" "1,1-cyclobutanedicarboxylicacid" "1,1-cyclobutane dicarboxylic acid" "1,1-cyclobutanedicarboxylate" );
gibbsFormation
{
    dHf_298   -785830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-645020.0
    phase     gas;
}
