/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipropylene glycol, azelaic acid polymer  (C15H30O7, CAS 70811-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipropyleneGlycolAzelaicAcidPolymer;
formula     C15H30O7;
CAS         70811-78-8;
InChIKey    KXBZVMKDYRZZOC-UHFFFAOYSA-N;
MW          322.398;      // g/mol [origin=calculated method=formula-sum]
Tc          1287.47;      // K   [origin=predictive method=joback]
Pc          17.347;      // bar [origin=predictive method=joback]
omega       1.3417;      // -   [origin=predictive method=lee-kesler]
Tb          1042.00;      // K   [origin=predictive method=joback]
HvapTb      119374.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.353 1.329 -0.0004724 -2.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group OH; count 2; } { group CH2O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 13; } { group OH; count 2; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanedioic acid;3-(3-oxidanylpropoxy)propan-1-ol" "nonanedioic acid, polymer with oxybis(propanol)" );
gibbsFormation
{
    dHf_298   -1601770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1067.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1095800.0
    phase     gas;
}
