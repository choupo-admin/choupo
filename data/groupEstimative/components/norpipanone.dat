/*--------------------------------*- Choupo -*-----------------------*\
  Component: norpipanone  (C23H29NO, CAS 561-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norpipanone;
formula     C23H29NO;
CAS         561-48-8;
InChIKey    WCDSHELZWCOTMI-UHFFFAOYSA-N;
MW          335.491;      // g/mol [origin=calculated method=formula-sum]
Tc          1104.15;      // K   [origin=predictive method=joback]
Pc          16.378;      // bar [origin=predictive method=joback]
omega       0.8957;      // -   [origin=predictive method=lee-kesler]
Tb          862.23;      // K   [origin=predictive method=joback]
HvapTb      79403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.057 2.41092 -0.0017383 4.8146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-diphenyl-6-piperidin-1-yl-hexan-3-one" "3-hexanone, 4,4-diphenyl-6-(1-piperidinyl)-" "norpipanona" "norpipanonum" "norpipanonum [inn-latin]" "norpipanone [inn:ban:dcf]" "4,4-diphenyl-6-piperidino-3-hexanon" "6-piperidino-4,4-diphenyl-3-hexanon" "4,4-diphenyl-6-piperidin-1-ylhexan-3-one" "4,4-diphenyl-6-(1-piperidyl)-3-hexanone" );
standardThermochemistry
{
    dHf_298   -17970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     834.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=396560.0
}
