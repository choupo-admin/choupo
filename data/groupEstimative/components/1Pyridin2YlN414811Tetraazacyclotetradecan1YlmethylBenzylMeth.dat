/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(pyridin-2-yl)-n-[4-(1,4,8,11-tetraazacyclotetradecan-1-ylmethyl)benzyl]methanamine  (C24H38N6, CAS 18718-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pyridin2YlN414811Tetraazacyclotetradecan1YlmethylBenzylMeth;
formula     C24H38N6;
CAS         18718-10-0;
InChIKey    CWJJHESJXJQCJA-UHFFFAOYSA-N;
MW          410.61;      // g/mol [origin=calculated method=formula-sum]
Tc          1401.15;      // K   [origin=predictive method=joback]
Pc          17.729;      // bar [origin=predictive method=joback]
omega       1.2368;      // -   [origin=predictive method=lee-kesler]
Tb          1123.13;      // K   [origin=predictive method=joback]
HvapTb      111137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.907 2.34156 -0.00107742 8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2NH; count 4; } { group CH2N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 10; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group NH; count 1; } { group NH_ring; count 3; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(pyridin-2-ylmethyl)-1-[4-(1,4,8,11-tetrazacyclotetradec-1-ylmethyl)phenyl]methanamine" "amd3465 (*hexahydrobromide*)" "amd 3465 (*hexahydrobromide*)" "amd-3465 (*hexahydrobromide*)" "2-pyridinemethanamine, n-((4-(1,4,8,11-tetraazacyclotetradec-1-ylmethyl)phenyl)methyl)-" );
gibbsFormation
{
    dHf_298   221660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1073.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=854200.0
    phase     gas;
}
