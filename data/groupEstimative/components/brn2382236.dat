/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2382236  (C25H16, CAS 2869-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2382236;
formula     C25H16;
CAS         2869-60-5;
InChIKey    HMJAFTKDWIHACO-UHFFFAOYSA-N;
MW          316.403;      // g/mol [origin=calculated method=formula-sum]
Tc          1174.71;      // K   [origin=predictive method=joback]
Pc          20.236;      // bar [origin=predictive method=joback]
omega       0.9714;      // -   [origin=predictive method=lee-kesler]
Tb          910.38;      // K   [origin=predictive method=joback]
HvapTb      84394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.0 2.05912 -0.00182132 6.484e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 10; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 11; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-1,2,3,4-dibenzopyrene" "dibenzo(def,p)chrysene, 10-methyl-" "14-methylnaphtho[1,2,3,4-pqr]tetraphene" );
gibbsFormation
{
    dHf_298   529740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=751370.0
    phase     gas;
}
