/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-bis(bromomethyl)pentane  (C7H14Br2, CAS 67969-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33BisBromomethylPentane;
formula     C7H14Br2;
CAS         67969-84-0;
InChIKey    ZIQNZEFIQWBNHV-UHFFFAOYSA-N;
MW          257.997;      // g/mol [origin=calculated method=formula-sum]
Tc          700.86;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       0.4978;      // -   [origin=predictive method=lee-kesler]
Tb          488.85;      // K   [origin=predictive method=joback]
HvapTb      42750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.566 0.87104 -0.0006716 2.122e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dibromo-2,2-diethylpropane" "pentane, 3,3-bis(bromomethyl)-" "2,2-diethyl-1,3-dibromopropane" );
standardThermochemistry
{
    dHf_298   -143900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39540.0
}
