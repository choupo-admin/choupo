/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorobenzotrifluoride  (C7H4ClF3, CAS 98-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chlorobenzotrifluoride;
formula     C7H4ClF3;
CAS         98-56-6;
InChIKey    QULYNCCPRWKEMF-UHFFFAOYSA-N;
MW          180.553;      // g/mol [origin=calculated method=formula-sum]
Tc          623.18;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.3744;      // -   [origin=predictive method=lee-kesler]
Tb          423.43;      // K   [origin=predictive method=joback]
HvapTb      34752.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.39 0.6984 -0.00056256 1.704e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-(trifluoromethyl)benzene" "p-chlorobenzotrifluoride" "1-chloro-4-(trifluoromethyl)benzene" "benzene, 1-chloro-4-(trifluoromethyl)-" "p-chloro-a,a,a-trifluorotoluene" "4-chloro-alpha,alpha,alpha-trifluorotoluene" "4-chlorotrifluorotoluene" "(p-chlorophenyl)trifluoromethane" "p-chlorotrifluoromethylbenzene" "4-trifluoromethylchlorobenzene" "pcbtf" "p-trifluoromethylphenyl chloride" );
gibbsFormation
{
    dHf_298   -575570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-482680.0
    phase     gas;
}
