/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-n,n-bis(2-hydroxyethyl)butanamide  (C8H17NO4, CAS 66857-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxyNNBis2HydroxyethylButanamide;
formula     C8H17NO4;
CAS         66857-22-5;
InChIKey    VLVFFKKUHQEBBU-UHFFFAOYSA-N;
MW          191.227;      // g/mol [origin=calculated method=formula-sum]
Tc          894.04;      // K   [origin=predictive method=joback]
Pc          36.776;      // bar [origin=predictive method=joback]
omega       2.0355;      // -   [origin=predictive method=lee-kesler]
Tb          725.49;      // K   [origin=predictive method=joback]
HvapTb      92228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.157 0.9617 -0.0005965 1.4176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group OH; count 3; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group OH; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-hydroxyethyl)-4-oxidanyl-butanamide" "4-hydroxy-n,n-bis(2-hydroxyethyl)butyramide" "butanamide, 4-hydroxy-n,n-bis(2-hydroxyethyl)-" "bis(2-hydroxyethyl)-4-hydroxybutyramide" );
gibbsFormation
{
    dHf_298   -710190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     663.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-412120.0
    phase     gas;
}
