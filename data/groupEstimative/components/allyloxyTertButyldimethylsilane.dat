/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyloxy-tert-butyldimethylsilane  (C9H20OSi, CAS 105875-75-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H20OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        allyloxyTertButyldimethylsilane;
formula     C9H20OSi;
CAS         105875-75-0;
InChIKey    DHWVPYLVNAKSEU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          172.343;      // g/mol [origin=calculated method=formula-sum]
Tc          606.15;      // K   [origin=predictive method=joback]
Pc          21.473;      // bar [origin=predictive method=joback]
omega       0.3100;      // -   [origin=predictive method=lee-kesler]
Tb          422.79;      // K   [origin=predictive method=joback]
HvapTb      36366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.561 0.6953 -0.0001347 -8.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl-dimethyl-prop-2-enoxy-silane" "allyloxy-t-butyldimethylsilane" "(allyloxy)(tert-butyl)dimethylsilane" "allyloxy(tert-butyl)dimethylsilane" "silane, (1,1-dimethylethyl)dimethyl(2-propenyloxy)-" "tert-butyl-dimethyl-prop-2-enoxysilane" "allyl oxy-tert butyl dimethylsilane" );
gibbsFormation
{
    dHf_298   -356250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94180.0
    phase     gas;
}
