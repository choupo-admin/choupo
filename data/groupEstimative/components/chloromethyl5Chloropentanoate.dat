/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl 5-chloropentanoate  (C6H10Cl2O2, CAS 80482-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethyl5Chloropentanoate;
formula     C6H10Cl2O2;
CAS         80482-35-5;
InChIKey    VQDRONCNGCJOGI-UHFFFAOYSA-N;
MW          185.044;      // g/mol [origin=calculated method=formula-sum]
Tc          657.19;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.5708;      // -   [origin=predictive method=lee-kesler]
Tb          469.96;      // K   [origin=predictive method=joback]
HvapTb      45127.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.625 0.5326 -0.0002488 2.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2COO; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl 5-chloranylpentanoate" "5-chloropentanoic acid, chloromethyl ester" "pentanoic acid, 5-chloro-, chloromethyl ester" );
gibbsFormation
{
    dHf_298   -515930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-334590.0
    phase     gas;
}
