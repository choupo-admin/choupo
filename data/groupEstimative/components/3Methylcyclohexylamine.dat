/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylcyclohexylamine  (C7H15N, CAS 6850-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylcyclohexylamine;
formula     C7H15N;
CAS         6850-35-7;
InChIKey    JYDYHSHPBDZRPU-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          664.80;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.3599;      // -   [origin=predictive method=lee-kesler]
Tb          447.17;      // K   [origin=predictive method=joback]
HvapTb      41937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.65 0.82632 -0.000426 6.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylcyclohexan-1-amine" "3-methylcyclohexanamine" "(3-methylcyclohexyl)amine" "3-methylcyclohexylamine,c&t" "1-amino-3-methylcyclohexane" "cyclohexanamine, 3-methyl-, trans-" "3-methyl cyclohexanamine" "cyclohexanamine, 3-methyl-" "agn-pc-03cz3l" "3-methylcyclohexylamine, mixed isomers" "3-methylcyclohexylamine (cis- and trans- mixture)" "3-aminophenylmethane;3-aminotoluen;m-aminotoluene;3-amino-1-methylbenzene;1-amino-3-methylbenzene;3-methylbenzenamine;meta toluidine;3-methylalanine;meta toluidine (mt);benzenamine, 3-methyl-;3-methylaniline;m-tolylamine;m-methylaniline;m-methylbenzenamine;aniline, 3-methyl-;3-toluidine;3-aminotoluene;" );
standardThermochemistry
{
    dHf_298   -120040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91250.0
}
