/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylamine, n,n-bis(trimethylsilyl)methyl]-  (C10H27NSi2, CAS 17988-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H27NSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethylamineNNBisTrimethylsilylMethyl;
formula     C10H27NSi2;
CAS         17988-70-4;
InChIKey    AOPUIYWQICJKPO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          217.503;      // g/mol [origin=calculated method=formula-sum]
Tc          615.67;      // K   [origin=predictive method=joback]
Pc          17.075;      // bar [origin=predictive method=joback]
omega       0.3608;      // -   [origin=predictive method=lee-kesler]
Tb          443.64;      // K   [origin=predictive method=joback]
HvapTb      40485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.743 0.66544 0.0001968 -2.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 2; } { group CH2N; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(trimethylsilylmethyl)ethanamine" "ethylamine, n,n-bis(trimethylsilyl)methyl)-" );
standardThermochemistry
{
    dHf_298   -405440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     814.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65420.0
}
