/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tribromo-2-(2,3-dibromopropoxy)benzene  (C9H7Br5O, CAS 35109-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Tribromo223DibromopropoxyBenzene;
formula     C9H7Br5O;
CAS         35109-60-5;
InChIKey    QXWYPAKUEHGJSG-UHFFFAOYSA-N;
MW          530.674;      // g/mol [origin=calculated method=formula-sum]
Tc          1076.39;      // K   [origin=predictive method=joback]
Pc          46.913;      // bar [origin=predictive method=joback]
omega       1.1035;      // -   [origin=predictive method=lee-kesler]
Tb          799.92;      // K   [origin=predictive method=joback]
HvapTb      74087.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.472 0.7351 -0.00054508 1.619e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH2O; count 1; } { group Br; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3-bis(bromanyl)propoxy]-1,3,5-tris(bromanyl)benzene" "benzene, 1,3,5-tribromo-2-(2,3-dibromopropoxy)-" "2,3-dibromopropyl 2,4,6-tribromophenyl ether" "propane, 1-(2,4,6-tribromophenoxy)-2,3-dibromo-" "bromkal 73-5pe" "2,4,6-tribromophenyl 2,3-dibromopropyl ether" "benzene,1,3,5-tribromo-2-(2,3-dibromopropoxy)-" "2,3-dibromopropyl2,4,6-tribromophenyl ether; 2,4,6-tribromophenyl 2,3-dibromopropyl ether;bromkal 73-5pe" );
standardThermochemistry
{
    dHf_298   -32820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72580.0
}
