/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanethiol, 2-(p-fluoroanilino)-  (C8H10FNS, CAS 20295-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanethiol2PFluoroanilino;
formula     C8H10FNS;
CAS         20295-60-7;
InChIKey    XDVPEFZFQHGYDA-UHFFFAOYSA-N;
MW          171.233;      // g/mol [origin=calculated method=formula-sum]
Tc          750.70;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.5775;      // -   [origin=predictive method=lee-kesler]
Tb          526.60;      // K   [origin=predictive method=joback]
HvapTb      48696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.218 0.7407 -0.00046296 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH2NH; count 1; } { group CH2SH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group NH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4-fluorophenyl)amino]ethanethiol" "2-(4-fluoroanilino)ethanethiol" );
gibbsFormation
{
    dHf_298   -87550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43230.0
    phase     gas;
}
