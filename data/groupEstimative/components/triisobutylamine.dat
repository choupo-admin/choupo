/*--------------------------------*- Choupo -*-----------------------*\
  Component: triisobutylamine  (C12H27N, CAS 1116-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triisobutylamine;
formula     C12H27N;
CAS         1116-40-1;
InChIKey    IIFFFBSAXDNJHX-UHFFFAOYSA-N;
MW          185.355;      // g/mol [origin=calculated method=formula-sum]
Tc          654.79;      // K   [origin=predictive method=joback]
Pc          18.139;      // bar [origin=predictive method=joback]
omega       0.5535;      // -   [origin=predictive method=lee-kesler]
Tb          485.28;      // K   [origin=predictive method=joback]
HvapTb      43185.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.757 1.28552 -0.0007512 1.675e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-n,n-bis(2-methylpropyl)propan-1-amine" "1-propanamine, 2-methyl-n,n-bis(2-methylpropyl)-" "tris(2-methylpropyl)amine" "triisobutylamine(6ci,7ci,8ci)" "n,n-diisobutyl-2-methylpropan-1-amine" );
standardThermochemistry
{
    dHf_298   -239320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153620.0
}
