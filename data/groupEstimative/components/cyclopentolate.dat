/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentolate  (C17H25NO3, CAS 512-15-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentolate;
formula     C17H25NO3;
CAS         512-15-2;
InChIKey    SKYSRIRYMSLOIN-UHFFFAOYSA-N;
MW          291.391;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.08;      // K   [origin=predictive method=joback]
Pc          20.831;      // bar [origin=predictive method=joback]
omega       1.2023;      // -   [origin=predictive method=lee-kesler]
Tb          793.16;      // K   [origin=predictive method=joback]
HvapTb      80559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.618 2.07254 -0.0016438 5.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethyl 2-(1-oxidanylcyclopentyl)-2-phenyl-ethanoate" "ciclopentolato" "cyclopentolatum" "cyclogyl" "mydrilate" "cylate" "ocu-pentolate" "cyclopentolatum [inn-latin]" "cyclopentoiate" "cyclopentylate" "diopentolate" "bell pentolate" );
standardThermochemistry
{
    dHf_298   -489220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     839.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103120.0
}
