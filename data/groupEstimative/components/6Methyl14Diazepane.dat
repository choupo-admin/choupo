/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyl-[1,4]diazepane  (C6H14N2, CAS 89582-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyl14Diazepane;
formula     C6H14N2;
CAS         89582-17-2;
InChIKey    VMJOIXFVKVPLRQ-UHFFFAOYSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          688.89;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.3759;      // -   [origin=predictive method=lee-kesler]
Tb          457.80;      // K   [origin=predictive method=joback]
HvapTb      43067.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.45 0.65952 -0.000216 -2.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group NH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-1,4-diazepane" "1h-1,4-diazepine,hexahydro-6-methyl-" "6h-1,4-diazepine, hexahydro-6-methyl-," "6-methyl-1,4-diazepane;" );
standardThermochemistry
{
    dHf_298   -43390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     366.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187410.0
}
