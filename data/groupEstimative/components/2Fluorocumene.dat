/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluorocumene  (C9H11F, CAS 2022-67-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluorocumene;
formula     C9H11F;
CAS         2022-67-5;
InChIKey    ICTCCOUARBGHFR-UHFFFAOYSA-N;
MW          138.185;      // g/mol [origin=calculated method=formula-sum]
Tc          638.10;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.3657;      // -   [origin=predictive method=lee-kesler]
Tb          436.01;      // K   [origin=predictive method=joback]
HvapTb      37361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.49 0.73814 -0.00044956 1.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-2-propan-2-yl-benzene" "2-isopropylfluorobenzene" "1-fluoro-2-propan-2-ylbenzene" "benzene,1-fluoro-2-(1-methylethyl)-" "cumene,o-fluoro- (7ci,8ci); 1-fluoro-2-isopropylbenzene; o-fluorocumene;o-isopropylfluorobenzene" );
standardThermochemistry
{
    dHf_298   -205420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69570.0
}
