/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2737221  (C11H13Br2NO2, CAS 2045-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2737221;
formula     C11H13Br2NO2;
CAS         2045-18-3;
InChIKey    PDMWTJJWTBLAOZ-UHFFFAOYSA-N;
MW          351.038;      // g/mol [origin=calculated method=formula-sum]
Tc          1007.94;      // K   [origin=predictive method=joback]
Pc          33.297;      // bar [origin=predictive method=joback]
omega       1.2021;      // -   [origin=predictive method=lee-kesler]
Tb          773.21;      // K   [origin=predictive method=joback]
HvapTb      75095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.426 1.1615 -0.00086676 2.539e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH2N; count 1; } { group COOH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[bis(2-bromoethyl)amino]benzoic acid" "benzoic acid, p-(bis(2-bromoethyl)amino)-" );
standardThermochemistry
{
    dHf_298   -275390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-59970.0
}
