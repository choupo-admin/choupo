/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dichloro-2-hydroxy-2-methylpropionic acid  (C4H6Cl2O3, CAS 31340-44-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dichloro2Hydroxy2MethylpropionicAcid;
formula     C4H6Cl2O3;
CAS         31340-44-0;
InChIKey    XCVHSKXPYCQSMA-UHFFFAOYSA-N;
MW          172.989;      // g/mol [origin=calculated method=formula-sum]
Tc          807.20;      // K   [origin=predictive method=joback]
Pc          46.403;      // bar [origin=predictive method=joback]
omega       1.0993;      // -   [origin=predictive method=lee-kesler]
Tb          600.00;      // K   [origin=predictive method=joback]
HvapTb      65427.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.77 0.61392 -0.0005126 1.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group OH; count 1; } { group COOH; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group Cl; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(chloranyl)-2-methyl-2-oxidanyl-propanoic acid" );
standardThermochemistry
{
    dHf_298   -673900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-521390.0
}
