/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylcyclohexanol  (C7H14O, CAS 583-59-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylcyclohexanol;
formula     C7H14O;
CAS         583-59-5;
InChIKey    NDVWOBYBJYUSMF-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          659.38;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.6376;      // -   [origin=predictive method=lee-kesler]
Tb          466.82;      // K   [origin=predictive method=joback]
HvapTb      47975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.85 0.79842 -0.000413 6.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylcyclohexan-1-ol" "cyclohexanol, 2-methyl-" "1-methyl-2-cyclohexanol" "2-methyl-1-cyclohexanol" "cis-2-methylcyclohexanol" "o-methylcyclohexanol" "cyclohexanol, o-methyl-" "2-methylcyclohexyl alcohol" "'methylhexaline'" "cyclohexanol, 2-methyl-, cis-" "2-methylcyclohexanol, mixed isomers" "cis-2-methylcyclohexan-1-ol" );
standardThermochemistry
{
    dHf_298   -306060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112020.0
}
