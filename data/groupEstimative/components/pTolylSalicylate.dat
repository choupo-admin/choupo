/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-tolyl salicylate  (C14H12O3, CAS 607-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pTolylSalicylate;
formula     C14H12O3;
CAS         607-88-5;
InChIKey    AMYKXJAXRJCLCV-UHFFFAOYSA-N;
MW          228.247;      // g/mol [origin=calculated method=formula-sum]
Tc          966.44;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.8812;      // -   [origin=predictive method=lee-kesler]
Tb          717.10;      // K   [origin=predictive method=joback]
HvapTb      72393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.86 1.21632 -0.00089492 2.575e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methylphenyl) 2-oxidanylbenzoate" "p-cresyl salicylate" "4-methylphenyl salicylate" "salicylic acid, p-tolyl ester" "benzoic acid, 2-hydroxy-, 4-methylphenyl ester" "4-methylphenyl 2-hydroxybenzoate" "salicylic acid p-tolyl ester" "(4-methylphenyl) 2-hydroxybenzoate" "salicylic acid 4-methylphenyl ester" "benzoic acid,2-hydroxy-, 4-methylphenyl ester" );
gibbsFormation
{
    dHf_298   -365290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-182800.0
    phase     gas;
}
