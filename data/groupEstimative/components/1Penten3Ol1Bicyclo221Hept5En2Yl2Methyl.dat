/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-penten-3-ol, 1-bicyclo[2.2.1]hept-5-en-2-yl-2-methyl-  (C13H20O, CAS 68975-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Penten3Ol1Bicyclo221Hept5En2Yl2Methyl;
formula     C13H20O;
CAS         68975-77-9;
InChIKey    JSPADDRGYBHRBS-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          800.72;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       0.8692;      // -   [origin=predictive method=lee-kesler]
Tb          605.06;      // K   [origin=predictive method=joback]
HvapTb      60842.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.079 1.50834 -0.00112898 3.467e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 4; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5-bicyclo[2.2.1]hept-2-enyl)-2-methyl-pent-1-en-3-ol" );
gibbsFormation
{
    dHf_298   -184850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122640.0
    phase     gas;
}
