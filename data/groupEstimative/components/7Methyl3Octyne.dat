/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methyl-3-octyne  (C9H16, CAS 37050-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methyl3Octyne;
formula     C9H16;
CAS         37050-06-9;
InChIKey    ZDXUMWBWHSCWBK-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          604.53;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.3291;      // -   [origin=predictive method=lee-kesler]
Tb          414.08;      // K   [origin=predictive method=joback]
HvapTb      37392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.583 0.71496 -0.00037686 7.438e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methyloct-3-yne" "3-octyne, 7-methyl-" "7-methyl-3-octyne;" "zdxumwbwhscwbk-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   37930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225260.0
}
