/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-diaminofluorene  (C13H12N2, CAS 525-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Diaminofluorene;
formula     C13H12N2;
CAS         525-64-4;
InChIKey    SNCJAJRILVFXAE-UHFFFAOYSA-N;
MW          196.253;      // g/mol [origin=calculated method=formula-sum]
Tc          979.42;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       0.8692;      // -   [origin=predictive method=lee-kesler]
Tb          718.25;      // K   [origin=predictive method=joback]
HvapTb      72892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.5 1.1634 -0.00093284 3.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9h-fluorene-2,7-diamine" "2,7-fluorenediamine" "fluorene-2,7-diamine" "2,7-fluoroenediamine" "2,7-diamino-fluorene" "fluorene-2,7-diyldiamine" "2,7-diamino-fluoren" "9h-fluorene-2,7-diamine (9ci)" "5178-56-3 (mono-hydrochloride)" "l134" );
gibbsFormation
{
    dHf_298   288570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=470440.0
    phase     gas;
}
