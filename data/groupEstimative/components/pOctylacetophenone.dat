/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-octylacetophenone  (C16H24O, CAS 10541-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pOctylacetophenone;
formula     C16H24O;
CAS         10541-56-7;
InChIKey    GARQDIVXKVBJFP-UHFFFAOYSA-N;
MW          232.367;      // g/mol [origin=calculated method=formula-sum]
Tc          848.75;      // K   [origin=predictive method=joback]
Pc          17.729;      // bar [origin=predictive method=joback]
omega       0.7936;      // -   [origin=predictive method=lee-kesler]
Tb          651.21;      // K   [origin=predictive method=joback]
HvapTb      60894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.903 1.35744 -0.00079206 1.7076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-octylphenyl)ethanone" "4'-n-octylacetophenone" "4'-octylacetophenone" "p-n-octylacetophenone" "4-n-octylacetophenone" "ethanone, 1-(4-octylphenyl)-" "acetophenone, 4'-octyl-" "1-acetyl-4-octylbenzene" "1-(4-octylphenyl)-ethanon" );
standardThermochemistry
{
    dHf_298   -261090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57700.0
}
