/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-homoestra-1,3,5(10),6,8-pentaen-17a-one,3-methoxy-  (C20H22O2, CAS 1232-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dHomoestra1351068Pentaen17aOne3Methoxy;
formula     C20H22O2;
CAS         1232-90-2;
InChIKey    CDRSYMMICFCUFM-UHFFFAOYSA-N;
MW          294.394;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.04;      // K   [origin=predictive method=joback]
Pc          20.037;      // bar [origin=predictive method=joback]
omega       0.8347;      // -   [origin=predictive method=lee-kesler]
Tb          830.30;      // K   [origin=predictive method=joback]
HvapTb      71692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.53 1.98574 -0.0015562 5.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methoxy-12a-methyl-1,3,4,4a,11,12-hexahydrochrysen-2-one" "d-homoestra-1,3,5(10),6,8-pentaen-17a-one, 3-methoxy-" "8-methoxy-12a-methyl-3,4,4a,11,12,12a-hexahydrochrysen-2(1h)-one" "d-homoestra-1,3,5(10),6,8-pentaen-17a-one, 3-methoxy-, (14beta)-" "d-homoestra-1,3,5(10),6,8-pentaen-17a-one,3-methoxy-,(14.beta.)-" );
gibbsFormation
{
    dHf_298   -184340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171910.0
    phase     gas;
}
