/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylidenecyclohexane  (C8H14, CAS 1003-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylidenecyclohexane;
formula     C8H14;
CAS         1003-64-1;
InChIKey    BPBOWYWUOUJKLO-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          622.96;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.2810;      // -   [origin=predictive method=lee-kesler]
Tb          413.50;      // K   [origin=predictive method=joback]
HvapTb      34927.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.83 0.83492 -0.0005163 1.227e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, ethylidene-" "ethylidene-cyclohexane" "cyclohexane,ethylidene-" );
standardThermochemistry
{
    dHf_298   -57760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94100.0
}
