/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-butanediol  (C4H10O2, CAS 513-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Butanediol;
formula     C4H10O2;
CAS         513-85-9;
InChIKey    OWBTYPJTUOEWEK-UHFFFAOYSA-N;
MW          90.122;      // g/mol [origin=calculated method=formula-sum]
Tc          639.52;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       1.1362;      // -   [origin=predictive method=lee-kesler]
Tb          474.60;      // K   [origin=predictive method=joback]
HvapTb      57080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.47 0.46364 -0.000261 5.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-2,3-diol" "2,3-butylene glycol" "2,3-dihydroxybutane" "dimethylene glycol" "dimethylethylene glycol" "pseudobutylene glycol" "dl-2,3-butanediol" "sym-dimethylethylene glycol" "levo-butane-2,3-diol" "2,3-butanediol, [r-(r*,r*)]-" "2,3-butanediol, [s-(r*,r*)]-" "2,3-butanediol, (r*,r*)-(.+/-.)-" );
standardThermochemistry
{
    dHf_298   -440910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295720.0
}
