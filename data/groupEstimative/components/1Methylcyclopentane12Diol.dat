/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylcyclopentane-1,2-diol  (C6H12O2, CAS 20557-45-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylcyclopentane12Diol;
formula     C6H12O2;
CAS         20557-45-3;
InChIKey    CVZBNRSGTBIHPO-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          717.26;      // K   [origin=predictive method=joback]
Pc          49.733;      // bar [origin=predictive method=joback]
omega       1.1203;      // -   [origin=predictive method=lee-kesler]
Tb          532.09;      // K   [origin=predictive method=joback]
HvapTb      61105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.52 1.03892 -0.000968 3.891e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-cyclopentanediol, 1-methyl-, trans-" "1,2-cyclopentanediol, 1-methyl-" );
standardThermochemistry
{
    dHf_298   -416250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-250650.0
}
