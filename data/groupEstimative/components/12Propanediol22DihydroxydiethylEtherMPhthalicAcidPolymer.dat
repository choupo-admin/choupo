/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-propanediol, 2,2'-dihydroxydiethyl ether, m-phthalic acid polymer  (C15H24O9, CAS 54975-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Propanediol22DihydroxydiethylEtherMPhthalicAcidPolymer;
formula     C15H24O9;
CAS         54975-08-5;
InChIKey    HUNDIMLTHSHTAI-UHFFFAOYSA-N;
MW          348.348;      // g/mol [origin=calculated method=formula-sum]
Tc          1601.60;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       1.2848;      // -   [origin=predictive method=lee-kesler]
Tb          1258.98;      // K   [origin=predictive method=joback]
HvapTb      155576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (105.465 1.05832 -8.576e-05 -2.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 3; } { group COOH; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 4; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;2-(2-hydroxyethyloxy)ethanol;propane-1,2-diol" "1,2-propanediol polymer with 2,2'-oxybis(ethanol) and 1,3-benzenedicarboxylic acid" "1,2-propanediol, 2,2'-oxybis(ethanol), 1,3-benzenedicarboxylic acid polymer" "1,3-benzenedicarboxylic acid, polymer with 2,2'-oxybis(ethanol) and 1,2-propanediol" "benzene-1,3-dicarboxylic acid; 2-(2-hydroxyethoxy)ethanol; propane-1,2-diol" );
gibbsFormation
{
    dHf_298   -1798070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1154.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1373860.0
    phase     gas;
}
