/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorobenzotrifluoride  (C7H4F4, CAS 402-44-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Fluorobenzotrifluoride;
formula     C7H4F4;
CAS         402-44-8;
InChIKey    UNNNAIWPDLRVRN-UHFFFAOYSA-N;
MW          164.101;      // g/mol [origin=calculated method=formula-sum]
Tc          566.65;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       0.3737;      // -   [origin=predictive method=lee-kesler]
Tb          385.27;      // K   [origin=predictive method=joback]
HvapTb      29550.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.19 0.7034 -0.00055856 1.67e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-4-(trifluoromethyl)benzene" "1-fluoro-4-(trifluoromethyl)benzene" "p-fluorobenzotrifluoride" "alpha,alpha,alpha,4-tetrafluorotoluene" "fxffr df" "benzene, 1-fluoro-4-(trifluoromethyl)-" "p-fluorotrifluoromethylbenzene" "p-(trifluoromethyl)fluorobenzene" "a,a,a,4-tetrafluorotoluene" "4-(trifluoromethyl)fluorobenzene" "4-fluoro-1-(trifluoromethyl)benzene" "4-flourobenzotrifluoride" );
standardThermochemistry
{
    dHf_298   -755940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-665560.0
}
