/*--------------------------------*- Choupo -*-----------------------*\
  Component: propionitrile, 3-decyloxy-2,2-diethoxyl-  (C17H33NO3, CAS 70289-41-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propionitrile3Decyloxy22Diethoxyl;
formula     C17H33NO3;
CAS         70289-41-7;
InChIKey    KTNQESBFWIQMRW-UHFFFAOYSA-N;
MW          299.455;      // g/mol [origin=calculated method=formula-sum]
Tc          936.14;      // K   [origin=predictive method=joback]
Pc          11.680;      // bar [origin=predictive method=joback]
omega       1.0040;      // -   [origin=predictive method=lee-kesler]
Tb          757.90;      // K   [origin=predictive method=joback]
HvapTb      71144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (80.935 1.36402 -0.000537 2.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2O; count 3; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group O; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(2-decoxyethoxy)ethoxy]propanenitrile" "propionitrile, 3-decyloxy-2,2-diethoxy/-," );
standardThermochemistry
{
    dHf_298   -625990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     858.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89560.0
}
