/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromohexanenitrile  (C6H10BrN, CAS 6621-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Bromohexanenitrile;
formula     C6H10BrN;
CAS         6621-59-6;
InChIKey    PHOSWLARCIBBJZ-UHFFFAOYSA-N;
MW          176.057;      // g/mol [origin=calculated method=formula-sum]
Tc          710.32;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.5965;      // -   [origin=predictive method=lee-kesler]
Tb          505.12;      // K   [origin=predictive method=joback]
HvapTb      45863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.625 0.5468 -0.000343 8.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group Br; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanylhexanenitrile" "6-bromocapronitrile" "hexanenitrile, 6-bromo-" "6-bromohexanonitrile" "5-bromopentyl cyanide" "phoswlarcibbjz-uhfffaoysa-" "behenyl alcohol, tech., 80%" );
standardThermochemistry
{
    dHf_298   24040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147140.0
}
