/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-bis(2-aminoethyl)-1,3-propanediamine  (C7H20N4, CAS 4741-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2Aminoethyl13Propanediamine;
formula     C7H20N4;
CAS         4741-99-5;
InChIKey    UWMHHZFHBCYGCV-UHFFFAOYSA-N;
MW          160.265;      // g/mol [origin=calculated method=formula-sum]
Tc          798.42;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       1.0716;      // -   [origin=predictive method=lee-kesler]
Tb          605.16;      // K   [origin=predictive method=joback]
HvapTb      65330.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.087 0.945 -0.000541 1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2NH2; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group NH2; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-bis(2-azanylethyl)propane-1,3-diamine" "2,3,2-tetramine" "1,4,8,11-tetraazaundecane" "n,n'-bis(2-aminoethyl)propane-1,3-diamine" "ethylenetrimethyleneethylenetetramine" "1,3-propanediamine, n,n'-bis(2-aminoethyl)-" "1,4,8,11-tetrazaundecane" "1,9-diamino-3,7-diazanonane" "3,7-diaza-1,9-nonanediamine" "n,n'-bis(2-aminoethyl)propan-1,3-diamin" "n,n-bis(2-aminoethyl)-1,3-propanediamine" "1,3-propanediamine, n,n-bis(2-aminoethyl)-" );
gibbsFormation
{
    dHf_298   -13290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=319740.0
    phase     gas;
}
