/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-(pentadecyloxy)ethoxy)ethanol  (C19H40O3, CAS 56049-80-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22PentadecyloxyEthoxyEthanol;
formula     C19H40O3;
CAS         56049-80-0;
InChIKey    BBRRSEMXTGVTOC-UHFFFAOYSA-N;
MW          316.526;      // g/mol [origin=calculated method=formula-sum]
Tc          944.82;      // K   [origin=predictive method=joback]
Pc          11.231;      // bar [origin=predictive method=joback]
omega       1.0677;      // -   [origin=predictive method=lee-kesler]
Tb          771.34;      // K   [origin=predictive method=joback]
HvapTb      79387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.908 1.71642 -0.0008182 1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-pentadecoxyethoxy)ethanol" "ethanol, 2-(2-(pentadecyloxy)ethoxy)-" "ethanol, 2-[2-(pentadecyloxy)ethoxy]-" );
standardThermochemistry
{
    dHf_298   -852160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     969.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237720.0
}
