/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethanolamine myristyl aminopropionate  (C23H50N2O5, CAS 61791-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethanolamineMyristylAminopropionate;
formula     C23H50N2O5;
CAS         61791-98-8;
InChIKey    PVCNGYDTTQPFPJ-UHFFFAOYSA-N;
MW          434.662;      // g/mol [origin=calculated method=formula-sum]
Tc          1503.43;      // K   [origin=predictive method=joback]
Pc          9.951;      // bar [origin=predictive method=joback]
omega       0.3792;      // -   [origin=predictive method=lee-kesler]
Tb          1146.53;      // K   [origin=predictive method=joback]
HvapTb      136826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.199 2.22154 -0.0009684 6.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 18; } { group OH; count 3; } { group CHNH2; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group CH; count 1; } { group OH; count 3; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethanol;tetradecyl 2-azanylpropanoate" "tea-myristaminopropionate" "n-myristyl-beta-aminopropionic acid, triethanolamine salt" "2-[bis(2-hydroxyethyl)amino]ethanol; tetradecyl 2-aminopropanoate" "n-tetradecyl-beta-alanine, compound with 2,2',2''-nitrilotriethanol (1:1)" "beta-alanine, n-tetradecyl-, compd. with 2,2',2''-nitrilotris(ethanol) (1:1)" "n-tetradecyl-beta-alanine, compd. with 2,2',2''-nitrilotris(ethanol) (1:1)" );
standardThermochemistry
{
    dHf_298   -1307600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1421.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-508020.0
}
