/*--------------------------------*- Choupo -*-----------------------*\
  Component: nerolidol  (C15H26O, CAS 7212-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nerolidol;
formula     C15H26O;
CAS         7212-44-4;
InChIKey    FQTLCLSUCSAZDY-SDNWHVSQSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          817.85;      // K   [origin=predictive method=joback]
Pc          17.492;      // bar [origin=predictive method=joback]
omega       0.9106;      // -   [origin=predictive method=lee-kesler]
Tb          636.51;      // K   [origin=predictive method=joback]
HvapTb      63773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.666 1.60848 -0.0011895 3.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6e)-3,7,11-trimethyldodeca-1,6,10-trien-3-ol" "trans-nerolidol" "3,7,11-trimethyldodeca-1,6,10-trien-3-ol" ".beta.-nerolidol" ".alpha.-nerolidol" "nerolidol (natural)" ".+/-.-trans-nerolidol" "fci 119b" "peruviol" "methylvinylhomogeranyl carbinol" "(+)-nerolidol" "3-hydroxy-3,7,11-trimethyl-1,6,10-dodecatriene" );
gibbsFormation
{
    dHf_298   -173620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     726.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172620.0
    phase     gas;
}
