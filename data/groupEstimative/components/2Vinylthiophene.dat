/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-vinylthiophene  (C6H6S, CAS 1918-82-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Vinylthiophene;
formula     C6H6S;
CAS         1918-82-7;
InChIKey    ORNUPNRNNSVZTC-UHFFFAOYSA-N;
MW          110.174;      // g/mol [origin=calculated method=formula-sum]
Tc          629.79;      // K   [origin=predictive method=joback]
Pc          45.164;      // bar [origin=predictive method=joback]
omega       0.2576;      // -   [origin=predictive method=lee-kesler]
Tb          404.64;      // K   [origin=predictive method=joback]
HvapTb      35904.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.3 0.55491 -0.00043452 1.376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethenylthiophene" "thiophene, 2-ethenyl-" "2-vinyl-thiophene" );
gibbsFormation
{
    dHf_298   188430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221890.0
    phase     gas;
}
