/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentane, heneicosyl-  (C26H52, CAS 6703-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentaneHeneicosyl;
formula     C26H52;
CAS         6703-82-8;
InChIKey    GNECQVKDNNGLCG-UHFFFAOYSA-N;
MW          364.702;      // g/mol [origin=calculated method=formula-sum]
Tc          993.15;      // K   [origin=predictive method=joback]
Pc          8.007;      // bar [origin=predictive method=joback]
omega       0.7475;      // -   [origin=predictive method=lee-kesler]
Tb          809.76;      // K   [origin=predictive method=joback]
HvapTb      73727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.23 2.60552 -0.001518 3.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 24; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "henicosylcyclopentane" "heneicosane, 1-cyclopentyl-" "n-heneicosylcyclopentane" );
standardThermochemistry
{
    dHf_298   -519490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1118.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204590.0
}
