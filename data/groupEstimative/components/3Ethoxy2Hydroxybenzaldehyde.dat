/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethoxy-2-hydroxybenzaldehyde  (C9H10O3, CAS 492-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H10O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Ethoxy2Hydroxybenzaldehyde;
formula     C9H10O3;
CAS         492-88-6;
InChIKey    OFQBYHLLIJGMNP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          737.65;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.5947;      // -   [origin=predictive method=lee-kesler]
Tb          516.64;      // K   [origin=predictive method=joback]
HvapTb      51617.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.819 0.81992 -0.00072832 2.715e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxy-2-oxidanyl-benzaldehyde" "3-ethoxysalicylaldehyde" "o-ethylvanillin" "benzaldehyde, 3-ethoxy-2-hydroxy-" "novovanillin" "salicylaldehyde, 3-ethoxy-" "benzaldehyde,3-ethoxy-2-hydroxy-" "salicylaldehyde, 3-ethoxy- (8ci)" );
gibbsFormation
{
    dHf_298   -237110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87980.0
    phase     gas;
}
