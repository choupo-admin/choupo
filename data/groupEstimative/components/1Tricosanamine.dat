/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tricosanamine  (C23H49N, CAS 14130-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tricosanamine;
formula     C23H49N;
CAS         14130-07-5;
InChIKey    ASLXNOZOXWPTNG-UHFFFAOYSA-N;
MW          339.652;      // g/mol [origin=calculated method=formula-sum]
Tc          978.39;      // K   [origin=predictive method=joback]
Pc          8.810;      // bar [origin=predictive method=joback]
omega       0.8424;      // -   [origin=predictive method=lee-kesler]
Tb          798.37;      // K   [origin=predictive method=joback]
HvapTb      77433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.528 2.25072 -0.0012708 2.735e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 22; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricosan-1-amine" );
gibbsFormation
{
    dHf_298   -484260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1103.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209230.0
    phase     gas;
}
