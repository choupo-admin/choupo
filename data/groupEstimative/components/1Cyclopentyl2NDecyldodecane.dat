/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclopentyl-2-n-decyldodecane  (C27H54, CAS 6703-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclopentyl2NDecyldodecane;
formula     C27H54;
CAS         6703-79-3;
InChIKey    BVCMEVKMWDECGG-UHFFFAOYSA-N;
MW          378.729;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.73;      // K   [origin=predictive method=joback]
Pc          7.623;      // bar [origin=predictive method=joback]
omega       0.7125;      // -   [origin=predictive method=lee-kesler]
Tb          832.20;      // K   [origin=predictive method=joback]
HvapTb      75565.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.821 2.70644 -0.0015756 3.491e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-decyldodecylcyclopentane" "cyclopentane, (2-decyldodecyl)-" "heneicosane, 11-(cyclopentylmethyl)-" "11-(cyclopentylmethyl)henicosane" "11-(cyclopentylmethyl)heneicosane" );
gibbsFormation
{
    dHf_298   -545410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1147.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210570.0
    phase     gas;
}
