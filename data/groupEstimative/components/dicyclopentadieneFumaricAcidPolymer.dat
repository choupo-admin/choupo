/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclopentadiene, fumaric acid polymer  (C14H16O4, CAS 61114-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclopentadieneFumaricAcidPolymer;
formula     C14H16O4;
CAS         61114-77-0;
InChIKey    IGNJNZQBBPFVND-WLHGVMLRSA-N;
MW          248.278;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.75;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       1.1808;      // -   [origin=predictive method=lee-kesler]
Tb          834.64;      // K   [origin=predictive method=joback]
HvapTb      81524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.35 1.5538 -0.00108536 2.898e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 3; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butenedioic acid (2e)-, polymer with 3a,4,7,7a-tetrahydro-4,7-methano-1h-indene" );
gibbsFormation
{
    dHf_298   -719770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-423000.0
    phase     gas;
}
