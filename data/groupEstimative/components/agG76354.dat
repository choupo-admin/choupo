/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-76354  (C32H67NO2, CAS 70715-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG76354;
formula     C32H67NO2;
CAS         70715-12-7;
InChIKey    PTFXSPOKTOSTLD-UHFFFAOYSA-N;
MW          497.893;      // g/mol [origin=calculated method=formula-sum]
Tc          1391.13;      // K   [origin=predictive method=joback]
Pc          5.431;      // bar [origin=predictive method=joback]
omega       0.1351;      // -   [origin=predictive method=lee-kesler]
Tb          1091.11;      // K   [origin=predictive method=joback]
HvapTb      106327.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.527 3.01238 -0.0014874 2.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 27; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 27; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyldodecan-1-amine;octadecanoic acid" "octadecanoic acid, compd. with n,n-dimethyl-1-dodecanamine(1:1)" "octadecanoic acid compd. with n,n-dimethyl-1-dodecanamine (1:1)" "lauryldimethylamine stearate" "stearic acid, compound with n,n-dimethyldodecylamine (1:1)" "n,n-dimethyldodecan-1-amine; octadecanoic acid" "octadecanoic acid - n,n-dimethyldodecan-1-amine (1:1)" );
gibbsFormation
{
    dHf_298   -1098170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1579.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119330.0
    phase     gas;
}
