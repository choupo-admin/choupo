/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r,3r,5s)-3-pinanamine  (C10H19N, CAS 69460-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2r3r5s3Pinanamine;
formula     C10H19N;
CAS         69460-11-3;
InChIKey    VPTSZLVPZCTAHZ-BZNPZCIMSA-N;
MW          153.269;      // g/mol [origin=calculated method=formula-sum]
Tc          722.10;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       0.4358;      // -   [origin=predictive method=lee-kesler]
Tb          504.91;      // K   [origin=predictive method=joback]
HvapTb      46415.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.49 1.52036 -0.001324 5.009e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 3; } { group C; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group C_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,3r,4r,5r)-4,6,6-trimethylbicyclo[3.1.1]heptan-3-amine" "(1r,2r,3r,5s)-(-)-isopinocampheylamine" "lsr-2-007d" "(-)-isopinocampheylamine; (1r,2r,3r,5s)-3-pinanamine" "(1r,2r,3r,5s)-2,6,6-trimethyl-bicyclo[3.1.1]heptan-3-amine" );
standardThermochemistry
{
    dHf_298   -122280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180550.0
}
