/*--------------------------------*- Choupo -*-----------------------*\
  Component: dadt  (C14H13Cl3N2, CAS 4485-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dadt;
formula     C14H13Cl3N2;
CAS         4485-25-0;
InChIKey    TYYIOZHLPIBQCJ-UHFFFAOYSA-N;
MW          315.622;      // g/mol [origin=calculated method=formula-sum]
Tc          1114.39;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.8919;      // -   [origin=predictive method=lee-kesler]
Tb          836.92;      // K   [origin=predictive method=joback]
HvapTb      85387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.55 1.3329 -0.00098912 2.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group ACNH2; count 2; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 3; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-(4-aminophenyl)-2,2,2-tris(chloranyl)ethyl]aniline" "p,p'-amino-ddt" "p,p'-nh2-ddt" "p,p'-diaminodiphenyltrichloroethane" "2,2-bis(p-aniline)-1,1,1-trichloroethane" "2,2-bis(p-aminophenyl)-1,1,1-trichloroethane" "aniline, 4,4'-(2,2,2-trichloroethylidene)di-" "benzenamine, 4,4'-(2,2,2-trichloroethylidene)bis-" "2,2-bis(p-aminophenyl)-1,1,1-trichloro ethane" "ethane, 2,2-bis(p-aminophenyl)-1,1,1-trichloro-" "p,p'-(2,2,2-trichloroethylidene)dianiline" "aniline,4'-(2,2,2-trichloroethylidene)di-" );
gibbsFormation
{
    dHf_298   124160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=370070.0
    phase     gas;
}
