/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, 1,3-butadiene-1,4-diylbis[trimethyl-  (C10H22Si2, CAS 22430-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H22Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane13Butadiene14DiylbisTrimethyl;
formula     C10H22Si2;
CAS         22430-47-3;
InChIKey    KTDRTOYQXRJJTE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          198.456;      // g/mol [origin=calculated method=formula-sum]
Tc          630.69;      // K   [origin=predictive method=joback]
Pc          18.676;      // bar [origin=predictive method=joback]
omega       0.2465;      // -   [origin=predictive method=lee-kesler]
Tb          439.52;      // K   [origin=predictive method=joback]
HvapTb      38358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.07 0.58152 0.0001418 -2.318e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH=CH; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(4-trimethylsilylbuta-1,3-dienyl)silane" "(1e,3e)-1,4-bis(trimethylsilyl)-1,3-butadiene" "silane,1,1'-[(1e,3e)-1,3-butadiene-1,4-diyl]bis[1,1,1-trimethyl-" "2,7-disilaocta-3,5-diene,2,2,7,7-tetramethyl-, (e,e)- (8ci); silane, (1e,3e)-1,3-butadiene-1,4-diylbis[trimethyl-(9ci); silane, 1,3-butadiene-1,4-diylbis[trimethyl-, (e,e)-" );
standardThermochemistry
{
    dHf_298   -238530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     785.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15760.0
}
