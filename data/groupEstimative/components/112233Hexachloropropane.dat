/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2,3,3-hexachloropropane  (C3H2Cl6, CAS 15600-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112233Hexachloropropane;
formula     C3H2Cl6;
CAS         15600-01-8;
InChIKey    HVCSXHFGNRDDQR-UHFFFAOYSA-N;
MW          250.749;      // g/mol [origin=calculated method=formula-sum]
Tc          726.81;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.3443;      // -   [origin=predictive method=lee-kesler]
Tb          488.71;      // K   [origin=predictive method=joback]
HvapTb      46510.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.67 0.4672 -0.00044 1.494e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl2; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group C; count 1; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,3-hexakis(chloranyl)propane" "hvcsxhfgnrddqr-uhfffaoysa-" "propane,1,1,2,2,3,3-hexachloro-" "propane, 1,1,2,2,3,3-hexachloro-" );
gibbsFormation
{
    dHf_298   -219000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99240.0
    phase     gas;
}
