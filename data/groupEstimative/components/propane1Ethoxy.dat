/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane, 1-ethoxy-  (C5H12O, CAS 628-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane1Ethoxy;
formula     C5H12O;
CAS         628-32-0;
InChIKey    NVJUHMXYKCUMQA-UHFFFAOYSA-N;
MW          88.15;      // g/mol [origin=calculated method=formula-sum]
Tc          500.78;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.3309;      // -   [origin=predictive method=lee-kesler]
Tb          336.42;      // K   [origin=predictive method=joback]
HvapTb      29134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.843 0.41564 -0.0001372 -6.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxypropane" "ethyl propyl ether" "ether, ethyl propyl" "ethyl n-propyl ether" "propyl ethyl ether" "3-ethoxypropane" "agn-pc-0cqjxk" "propane, 1-ethoxy- (9ci)" "nvjuhmxykcumqa-uhfffaoysa-" "ether,ethyl propyl (6ci,7ci,8ci); 1-ethoxypropane; ethyl n-propyl ether; ethyl propylether; propyl ethyl ether" );
gibbsFormation
{
    dHf_298   -278750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113780.0
    phase     gas;
}
