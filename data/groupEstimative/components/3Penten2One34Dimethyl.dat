/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-penten-2-one, 3,4-dimethyl-  (C7H12O, CAS 684-94-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Penten2One34Dimethyl;
formula     C7H12O;
CAS         684-94-6;
InChIKey    IZHBYIAZXCYIMS-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          610.63;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.3859;      // -   [origin=predictive method=lee-kesler]
Tb          417.55;      // K   [origin=predictive method=joback]
HvapTb      38040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.68 0.66068 -0.0004267 1.1406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethylpent-3-en-2-one" "3,4-dimethyl-3-penten-2-one" "3,4-dimethyl-3-pentene-2-one" );
standardThermochemistry
{
    dHf_298   -202750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57740.0
}
