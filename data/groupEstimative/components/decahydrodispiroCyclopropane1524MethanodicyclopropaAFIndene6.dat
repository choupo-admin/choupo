/*--------------------------------*- Choupo -*-----------------------*\
  Component: decahydrodispiro[cyclopropane-1,5'-[2,4]methanodicyclopropa[a,f]indene-6',1''-cyclopropane]  (C16H20, CAS 86301-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decahydrodispiroCyclopropane1524MethanodicyclopropaAFIndene6;
formula     C16H20;
CAS         86301-94-2;
InChIKey    IKKIJQHYEJHDIU-UHFFFAOYSA-N;
MW          212.336;      // g/mol [origin=calculated method=formula-sum]
Tc          806.52;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       0.5262;      // -   [origin=predictive method=lee-kesler]
Tb          577.98;      // K   [origin=predictive method=joback]
HvapTb      46512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-419.91 3.1324 -0.003519 1.5352e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 8; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 8; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dispiro(cyclopropane-6,1'-pentacyclo(6.3.1.0(2,7).0(3,5).0(9,11))-dodecane-12,1-cyclopropane)" ""dispiro{cyclopropane-6,1'-pentacyclo[6.3.1.0(2,7).0(3,5).0(9,11)]-dodecane-12,1""-cyclopropane}"" );
gibbsFormation
{
    dHf_298   136290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     59.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=535480.0
    phase     gas;
}
