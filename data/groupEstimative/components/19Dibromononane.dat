/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,9-dibromononane  (C9H18Br2, CAS 4549-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        19Dibromononane;
formula     C9H18Br2;
CAS         4549-33-1;
InChIKey    WGAXVZXBFBHLMC-UHFFFAOYSA-N;
MW          286.051;      // g/mol [origin=calculated method=formula-sum]
Tc          731.63;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.7043;      // -   [origin=predictive method=lee-kesler]
Tb          537.84;      // K   [origin=predictive method=joback]
HvapTb      48498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.089 0.9352 -0.0006086 1.641e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,9-bis(bromanyl)nonane" "nonane, 1,9-dibromo-" "nonamethylene dibromide" "nonamethylene bromide" "1,9-dibromnonane" "nonane,9-dibromo-" "1,9-dibromnonan;1,9-dibromo-nonan;nonane,1,9-dibromo-" );
standardThermochemistry
{
    dHf_298   -176430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53540.0
}
