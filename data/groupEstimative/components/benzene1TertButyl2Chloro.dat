/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1-tert-butyl-2-chloro-  (C10H13Cl, CAS 7073-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene1TertButyl2Chloro;
formula     C10H13Cl;
CAS         7073-98-5;
InChIKey    HMRNLPCZVBVKLZ-UHFFFAOYSA-N;
MW          168.664;      // g/mol [origin=calculated method=formula-sum]
Tc          720.44;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.3504;      // -   [origin=predictive method=lee-kesler]
Tb          494.26;      // K   [origin=predictive method=joback]
HvapTb      43881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.39 0.94806 -0.00067656 1.893e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-2-chloranyl-benzene" "1-tert-butyl-2-chlorobenzene" "benzene, chloro(1,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   -49160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127010.0
    phase     gas;
}
