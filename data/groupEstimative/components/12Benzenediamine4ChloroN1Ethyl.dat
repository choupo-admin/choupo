/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-benzenediamine, 4-chloro-n1-ethyl-  (C8H11ClN2, CAS 62476-15-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Benzenediamine4ChloroN1Ethyl;
formula     C8H11ClN2;
CAS         62476-15-7;
InChIKey    BYXHQRLOVDLFCT-UHFFFAOYSA-N;
MW          170.64;      // g/mol [origin=calculated method=formula-sum]
Tc          809.38;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       0.6916;      // -   [origin=predictive method=lee-kesler]
Tb          579.41;      // K   [origin=predictive method=joback]
HvapTb      58464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.481 0.71082 -0.00042092 9.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2NH; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-n1-ethyl-benzene-1,2-diamine" "5-chloro-2-(ethylamino)aniline" "4-chloro-1-n-ethylbenzene-1,2-diamine" "(2-amino-4-chlorophenyl)ethylamine" "4-chloro-n-ethylbenzene-1,2-diamine" "1,2-benzenediamine,4-chloro-n1-ethyl-" );
gibbsFormation
{
    dHf_298   76660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253540.0
    phase     gas;
}
