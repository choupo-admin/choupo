/*--------------------------------*- Choupo -*-----------------------*\
  Component: mifepristone  (C29H35NO2, CAS 84371-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mifepristone;
formula     C29H35NO2;
CAS         84371-65-3;
InChIKey    VKHAHZOOUSRJNA-GCNJZUOMSA-N;
MW          429.604;      // g/mol [origin=calculated method=formula-sum]
Tc          1397.52;      // K   [origin=predictive method=joback]
Pc          14.006;      // bar [origin=predictive method=joback]
omega       1.1848;      // -   [origin=predictive method=lee-kesler]
Tb          1133.60;      // K   [origin=predictive method=joback]
HvapTb      108678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-256.65 3.28268 -0.00275686 9.9688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group C; count 2; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CH3N; count 1; } { group C_C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group tC; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group OH; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,11r,13s,14s,17s)-11-[4-(dimethylamino)phenyl]-13-methyl-17-oxidanyl-17-prop-1-ynyl-1,2,6,7,8,11,12,14,15,16-decahydrocyclopenta[a]phenanthren-3-one" "mifegyne" "mifeprex" "corlux" "mifepriston" "mifepristona" "mifepristonum" "korlym" "mifepristonum [latin]" "ru486" "pictovir" "mifeprex (tn)" );
gibbsFormation
{
    dHf_298   -15240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     874.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=545090.0
    phase     gas;
}
