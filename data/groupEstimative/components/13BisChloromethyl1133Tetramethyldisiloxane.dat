/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(chloromethyl)-1,1,3,3-tetramethyldisiloxane  (C6H16Cl2OSi2, CAS 2362-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16Cl2OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13BisChloromethyl1133Tetramethyldisiloxane;
formula     C6H16Cl2OSi2;
CAS         2362-10-9;
InChIKey    NBGGEWGFZUDQKZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          231.263;      // g/mol [origin=calculated method=formula-sum]
Tc          629.67;      // K   [origin=predictive method=joback]
Pc          22.145;      // bar [origin=predictive method=joback]
omega       0.3005;      // -   [origin=predictive method=lee-kesler]
Tb          436.96;      // K   [origin=predictive method=joback]
HvapTb      40718.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (130.352 0.11188 0.0005972 -4.11e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2Cl; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl-[chloromethyl(dimethyl)silyl]oxy-dimethyl-silane" "1,3-bis(chloromethyl)tetramethyldisiloxane" "bis(chloromethyl)tetramethyldisiloxane" "disiloxane, 1,3-bis(chloromethyl)-1,1,3,3-tetramethyl-" "tetramethylbis(chloromethyl)disiloxane" "tetramethyl-1,3-bis(chloromethyl)disiloxane" "disiloxane,3-bis(chloromethyl)-1,1,3,3-tetramethyl-" "k869" "chloromethyl-[chloromethyl(dimethyl)silyl]oxy-dimethylsilane" "(chloromethyl)({[(chloromethyl)dimethylsilyl]oxy})dimethylsilane" );
gibbsFormation
{
    dHf_298   -554110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-338740.0
    phase     gas;
}
