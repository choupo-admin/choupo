/*--------------------------------*- Choupo -*-----------------------*\
  Component: dehydroabietic acid  (C20H28O2, CAS 1740-19-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dehydroabieticAcid;
formula     C20H28O2;
CAS         1740-19-8;
InChIKey    NFWKVWVWBFBAOV-UHFFFAOYSA-N;
MW          300.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1098.74;      // K   [origin=predictive method=joback]
Pc          17.758;      // bar [origin=predictive method=joback]
omega       0.9391;      // -   [origin=predictive method=lee-kesler]
Tb          856.74;      // K   [origin=predictive method=joback]
HvapTb      78049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-222.45 2.60258 -0.00239452 9.366e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4a-dimethyl-7-propan-2-yl-2,3,4,9,10,10a-hexahydrophenanthrene-1-carboxylic acid" "podocarpa-8,11,13-trien-15-oic acid, 13-isopropyl-" "1-phenanthrenecarboxylic acid, 1,2,3,4,4a,9,10,10a-octahydro-1,4a-dimethyl-7-(1-methylethyl)-, (1r,4as,10ar)-" "podocarpa-8,11,13-trien-16-oic acid, 13-isopropyl-" "1,4a-dimethyl-7-(methylethyl)-1,2,3,4,9,10,10a,4a-octahydrophenanthrenecarboxy lic acid" "(1r,4as)-7-isopropyl-1,4a-dimethyl-1,2,3,4,4a,9,10,10a-octahydrophenanthrene-1-carboxylic acid" "1-phenanthrenecarboxylic acid, 1,2,3,4,4a,9,10,10a-octahydro-1,4a-dimethyl-7-(1-methylethyl)-, [1r-(1.alpha.,4a.beta.,10a.alpha.)]-" "1-phenanthrenecarboxylic acid, 1,2,3,4,4a,9,10,10a-octahydro-1,4a-dimethyl-7-(1-methylethyl)-, [1s-(1.alpha.,4a.alpha.,10a.beta.)]-" );
standardThermochemistry
{
    dHf_298   -454670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     815.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57070.0
}
