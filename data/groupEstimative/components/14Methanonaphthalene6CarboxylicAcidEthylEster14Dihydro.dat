/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-methanonaphthalene-6-carboxylic acid ethyl ester, 1,4-dihydro-  (C14H14O2, CAS 56136-20-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Methanonaphthalene6CarboxylicAcidEthylEster14Dihydro;
formula     C14H14O2;
CAS         56136-20-0;
InChIKey    VSHAPUJEHFCURQ-UHFFFAOYSA-N;
MW          214.264;      // g/mol [origin=calculated method=formula-sum]
Tc          845.91;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.6964;      // -   [origin=predictive method=lee-kesler]
Tb          623.15;      // K   [origin=predictive method=joback]
HvapTb      57711.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.319 1.33652 -0.0010144 3.067e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -226440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13340.0
}
