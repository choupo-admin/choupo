/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(trichloromethyl)pyridine  (C6H4Cl3N, CAS 4377-37-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TrichloromethylPyridine;
formula     C6H4Cl3N;
CAS         4377-37-1;
InChIKey    KAQJMEHRXVENSF-UHFFFAOYSA-N;
MW          196.455;      // g/mol [origin=calculated method=formula-sum]
Tc          790.60;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.3647;      // -   [origin=predictive method=lee-kesler]
Tb          526.32;      // K   [origin=predictive method=joback]
HvapTb      49295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.21 0.67486 -0.00057606 1.864e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Cl; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-trichloromethyl pyridine" "2-(trichloromethyl)pyridine;" "pyridine,2-(trichloromethyl)-" "pyridine, 2-(trichloromethyl)-" );
gibbsFormation
{
    dHf_298   46180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156150.0
    phase     gas;
}
