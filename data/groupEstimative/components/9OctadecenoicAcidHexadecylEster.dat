/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenoic acid, hexadecyl ester  (C34H66O2, CAS 22393-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenoicAcidHexadecylEster;
formula     C34H66O2;
CAS         22393-86-8;
InChIKey    JYTMDBGMUIAIQH-UHFFFAOYSA-N;
MW          506.9;      // g/mol [origin=calculated method=formula-sum]
Tc          1318.53;      // K   [origin=predictive method=joback]
Pc          5.107;      // bar [origin=predictive method=joback]
omega       0.1208;      // -   [origin=predictive method=lee-kesler]
Tb          1039.90;      // K   [origin=predictive method=joback]
HvapTb      98643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.791 3.19904 -0.001815 3.837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 28; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 29; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl octadec-9-enoate" "9-octadecenoic acid (9z)-, hexadecyl ester" );
gibbsFormation
{
    dHf_298   -945150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1525.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5250.0
    phase     gas;
}
