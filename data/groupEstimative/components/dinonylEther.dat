/*--------------------------------*- Choupo -*-----------------------*\
  Component: dinonyl ether  (C18H38O, CAS 2456-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dinonylEther;
formula     C18H38O;
CAS         2456-27-1;
InChIKey    DKZRLCHWDNEKRH-UHFFFAOYSA-N;
MW          270.501;      // g/mol [origin=calculated method=formula-sum]
Tc          793.76;      // K   [origin=predictive method=joback]
Pc          11.390;      // bar [origin=predictive method=joback]
omega       0.8372;      // -   [origin=predictive method=lee-kesler]
Tb          633.86;      // K   [origin=predictive method=joback]
HvapTb      58072.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.026 1.65064 -0.0008444 1.482e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-nonoxynonane" "nonane, 1-(nonyloxy)-" "nonane,1,1'-oxybis- (9ci);nonyl ether (6ci,7ci,8ci);di-n-nonyl ether;dinonyl ether;" );
standardThermochemistry
{
    dHf_298   -547070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     868.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4320.0
}
