/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diazabicyclo[3.3.1]nonane  (C7H14N2, CAS 281-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diazabicyclo331Nonane;
formula     C7H14N2;
CAS         281-17-4;
InChIKey    HYTQTNKKOHXGKR-UHFFFAOYSA-N;
MW          126.203;      // g/mol [origin=calculated method=formula-sum]
Tc          611.43;      // K   [origin=predictive method=joback]
Pc          42.002;      // bar [origin=predictive method=joback]
omega       0.4198;      // -   [origin=predictive method=lee-kesler]
Tb          411.73;      // K   [origin=predictive method=joback]
HvapTb      35878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.34 1.2618 -0.001087 3.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-diazabicyclo(3.3.1)nonane" );
standardThermochemistry
{
    dHf_298   127370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=354440.0
}
