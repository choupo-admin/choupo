/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dimethylamino)cyclohexan-1-ol  (C8H17NO, CAS 30727-29-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DimethylaminoCyclohexan1Ol;
formula     C8H17NO;
CAS         30727-29-8;
InChIKey    UFUVLAQFZSUWHR-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          690.26;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.7568;      // -   [origin=predictive method=lee-kesler]
Tb          502.14;      // K   [origin=predictive method=joback]
HvapTb      52244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.45 1.01734 -0.00058 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexanol, 2-(dimethylamino)-, cis-" "2-(dimethylamino)cyclohexanol" "cis-2-(dimethylamino)cyclohexanol" "2-dimethylamino-cyclohexanol" "agn-pc-00po9c" "2-dimethylaminocyclohexan-1-ol" "cyclohexanol,2-(dimethylamino)-" "cyclohexanol,2-(dimethylamino)-,trans-" "cyclohexanol, 2-(dimethylamino)-, trans-" );
gibbsFormation
{
    dHf_298   -259170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7180.0
    phase     gas;
}
