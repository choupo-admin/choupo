/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propylphenol  (C9H12O, CAS 644-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propylphenol;
formula     C9H12O;
CAS         644-35-9;
InChIKey    LCHYEKKJCUJAKN-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          735.07;      // K   [origin=predictive method=joback]
Pc          38.965;      // bar [origin=predictive method=joback]
omega       0.5662;      // -   [origin=predictive method=lee-kesler]
Tb          512.82;      // K   [origin=predictive method=joback]
HvapTb      50918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.118 0.93452 -0.00075336 2.545e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o-propylphenol" "phenol, 2-propyl-" "phenol, o-propyl-" "2-n-propylphenol" "1-hydroxy-2-n-propylbenzene" "1-(2-hydroxyphenyl)propane" "phenol, propyl-" "1-hydroxy-2-propylbenzene" "jz4" );
gibbsFormation
{
    dHf_298   -169870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17310.0
    phase     gas;
}
