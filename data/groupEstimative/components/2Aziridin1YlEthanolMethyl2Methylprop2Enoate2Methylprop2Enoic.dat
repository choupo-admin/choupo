/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(aziridin-1-yl)ethanol;methyl 2-methylprop-2-enoate;2-methylprop-2-enoic acid  (C13H23NO5, CAS 67874-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Aziridin1YlEthanolMethyl2Methylprop2Enoate2Methylprop2Enoic;
formula     C13H23NO5;
CAS         67874-93-5;
InChIKey    DAISTSZCIPZGKU-UHFFFAOYSA-N;
MW          273.329;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.99;      // K   [origin=predictive method=joback]
Pc          20.181;      // bar [origin=predictive method=joback]
omega       1.3629;      // -   [origin=predictive method=lee-kesler]
Tb          808.45;      // K   [origin=predictive method=joback]
HvapTb      87283.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.892 1.12716 -0.0003472 -7.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2=C; count 2; } { group OH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group CH2_ring; count 2; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, polymer with methyl 2-methyl-2-propenoate, compd. with 1-aziridineethanol" "2-(aziridin-1-yl)ethanol; methyl 2-methylprop-2-enoate; 2-methylprop-2-enoic acid" "methyl methacrylate, methacrylic acid polymer, n-(2-hydroxyethyl)ethyleneimine salt" );
gibbsFormation
{
    dHf_298   -956560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     963.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-592120.0
    phase     gas;
}
