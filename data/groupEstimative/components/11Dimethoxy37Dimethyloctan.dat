/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxy-3,7-dimethyloctan  (C12H26O2, CAS 137250-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxy37Dimethyloctan;
formula     C12H26O2;
CAS         137250-78-3;
InChIKey    YKJOVWRPIHPSDM-UHFFFAOYSA-N;
MW          202.338;      // g/mol [origin=calculated method=formula-sum]
Tc          687.95;      // K   [origin=predictive method=joback]
Pc          17.654;      // bar [origin=predictive method=joback]
omega       0.6410;      // -   [origin=predictive method=lee-kesler]
Tb          517.68;      // K   [origin=predictive method=joback]
HvapTb      45962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.934 1.0352 -0.0004166 2.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 3; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxy-3,7-dimethyl-octane" "1,1-dimethoxy-3,7-dimethyloctane" "octane, 1,1-dimethoxy-3,7-dimethyl-" "dihydro citronellal dimethyl acetal" "3,7-dimethyloctanal, dimethyl acetal" );
gibbsFormation
{
    dHf_298   -571290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167160.0
    phase     gas;
}
