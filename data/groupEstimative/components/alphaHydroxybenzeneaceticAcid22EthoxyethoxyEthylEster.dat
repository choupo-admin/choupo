/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-hydroxybenzeneacetic acid 2-(2-ethoxyethoxy)ethyl ester  (C14H20O5, CAS 66267-67-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaHydroxybenzeneaceticAcid22EthoxyethoxyEthylEster;
formula     C14H20O5;
CAS         66267-67-2;
InChIKey    CJYLPNJTRIHDKM-UHFFFAOYSA-N;
MW          268.309;      // g/mol [origin=calculated method=formula-sum]
Tc          932.14;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       1.2936;      // -   [origin=predictive method=lee-kesler]
Tb          741.40;      // K   [origin=predictive method=joback]
HvapTb      77552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.275 1.11362 -0.000486 2.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-ethoxyethoxy)ethyl 2-oxidanyl-2-phenyl-ethanoate" "benzeneacetic acid, alpha-hydroxy-, 2-(2-ethoxyethoxy)ethyl ester" "2-(2-ethoxyethoxy)ethyl 2-hydroxy-2-phenylacetate" );
standardThermochemistry
{
    dHf_298   -834990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     710.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-480220.0
}
