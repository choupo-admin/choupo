/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydroxypropyl 3-(hexylthio)propionate  (C12H24O4S, CAS 67859-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dihydroxypropyl3HexylthioPropionate;
formula     C12H24O4S;
CAS         67859-56-7;
InChIKey    SXNLGWZJZFAJAR-UHFFFAOYSA-N;
MW          264.38;      // g/mol [origin=calculated method=formula-sum]
Tc          967.59;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       1.5639;      // -   [origin=predictive method=lee-kesler]
Tb          785.08;      // K   [origin=predictive method=joback]
HvapTb      89500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.889 1.15731 -0.0005582 6.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 2; } { group CH2COO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group OH; count 2; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)propyl 3-hexylsulfanylpropanoate" "propanoic acid, 3-(hexylthio)-, 2,3-dihydroxypropyl ester" "2,3-dihydroxypropyl-3-(hexylthio)propionate" "2,3-dihydroxypropyl 3'-(hexylthio)propionate" "2,3-dihydroxypropyl 3-hexylsulfanylpropanoate" );
standardThermochemistry
{
    dHf_298   -876160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-503170.0
}
