/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bibenzylcarboxylic acid  (C15H14O2, CAS 4890-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BibenzylcarboxylicAcid;
formula     C15H14O2;
CAS         4890-85-1;
InChIKey    IOHPVZBSOKLVMN-UHFFFAOYSA-N;
MW          226.275;      // g/mol [origin=calculated method=formula-sum]
Tc          989.13;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.9210;      // -   [origin=predictive method=lee-kesler]
Tb          746.65;      // K   [origin=predictive method=joback]
HvapTb      71362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.658 1.2623 -0.00086016 2.214e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-phenylethyl)benzoic acid" "2-phenethylbenzoic acid" "o-phenethylbenzoic acid" "2-phenylethylbenzoic acid" "benzoic acid,2-(2-phenylethyl)-" "benzoic acid, 2-(2-phenylethyl)-" "benzoicacid, o-phenethyl- (6ci,7ci,8ci);2-(2-phenethyl)benzoic acid;2-(2-phenylethyl)benzoic acid;2-(phenethyl)benzoic acid;o-phenethylbenzoic acid;" );
standardThermochemistry
{
    dHf_298   -241610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53300.0
}
