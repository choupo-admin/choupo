/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-chloroacetate  (C6H11ClO2, CAS 590-02-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2Chloroacetate;
formula     C6H11ClO2;
CAS         590-02-3;
InChIKey    YJRGMUWRPCPLNH-UHFFFAOYSA-N;
MW          150.602;      // g/mol [origin=calculated method=formula-sum]
Tc          613.42;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.5099;      // -   [origin=predictive method=lee-kesler]
Tb          432.53;      // K   [origin=predictive method=joback]
HvapTb      40742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.734 0.52582 -0.0002284 1.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2-chloranylethanoate" "butyl chloroacetate" "n-butyl chloroacetate" "acetic acid, chloro-, butyl ester" "acetic acid, 2-chloro-, butyl ester" "n-butyl-chloroacetate" "chloroacetic acid butyl ester" "2-chloroacetic acid butyl ester" "u415" );
gibbsFormation
{
    dHf_298   -500190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-322660.0
    phase     gas;
}
