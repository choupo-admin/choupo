/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanal,4-(octahydro-4,7-methano-5h-inden-5-ylidene)-  (C14H20O, CAS 30168-23-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanal4Octahydro47Methano5hInden5Ylidene;
formula     C14H20O;
CAS         30168-23-1;
InChIKey    WFEISWUNAJPLRX-UHFFFAOYSA-N;
MW          204.313;      // g/mol [origin=calculated method=formula-sum]
Tc          806.33;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.6595;      // -   [origin=predictive method=lee-kesler]
Tb          595.04;      // K   [origin=predictive method=joback]
HvapTb      53867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.248 1.6474 -0.0012581 3.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 4; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanal, 4-(octahydro-4,7-methano-5h-inden-5-ylidene)-" "agn-pc-03k3ny" "4-(tricyclo[5.2.1.02,6]dec-8-ylidene)butyraldehyde;4-(tricyclo[5.2.1.02,6]decylidene-8)butanal;dupical;" );
gibbsFormation
{
    dHf_298   -149940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175380.0
    phase     gas;
}
