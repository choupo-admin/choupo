/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-allyl-1-cyclohexene  (C9H14, CAS 13511-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Allyl1Cyclohexene;
formula     C9H14;
CAS         13511-13-2;
InChIKey    GTUOTYSUNDPMPS-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          638.10;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.3210;      // -   [origin=predictive method=lee-kesler]
Tb          430.56;      // K   [origin=predictive method=joback]
HvapTb      36650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.749 0.8719 -0.00054534 1.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enylcyclohexene" "cyclohexene,1-(2-propenyl)-" "1-allylcyclohexene" "cyclohexene, 1-(2-propenyl)-" "cyclohexene,1-(2-propen-1-yl)-" "cyclohexene,1-(2-propenyl)- (9ci); cyclohexene, 1-allyl- (7ci,8ci); 1-allyl-1-cyclohexene;1-allylcyclohexene" );
gibbsFormation
{
    dHf_298   17310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165230.0
    phase     gas;
}
