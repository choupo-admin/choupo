/*--------------------------------*- Choupo -*-----------------------*\
  Component: anthracene-9,10-dicarbaldehyde  (C16H10O2, CAS 7044-91-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H10O2 (delta C+2H+2O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        anthracene910Dicarbaldehyde;
formula     C16H10O2;
CAS         7044-91-9;
InChIKey    SBRUFOSORMQHES-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          234.254;      // g/mol [origin=calculated method=formula-sum]
Tc          845.75;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       0.4947;      // -   [origin=predictive method=lee-kesler]
Tb          598.10;      // K   [origin=predictive method=joback]
HvapTb      54006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.55 1.2752 -0.00125612 4.856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 6; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-anthracenedicarboxaldehyde" "anthracene-9,10-dicarboxaldehyde" "9,10-diformylanthracene" "anthracene-9,10-dialdehyde" "9,10-anthracene dicarboxyaldehyde" );
gibbsFormation
{
    dHf_298   363590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=468580.0
    phase     gas;
}
