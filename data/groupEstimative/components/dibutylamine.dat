/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutylamine  (C8H19N, CAS 111-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylamine;
formula     C8H19N;
CAS         111-92-2;
InChIKey    JQVDAXLFBXTEQA-UHFFFAOYSA-N;
MW          129.247;      // g/mol [origin=calculated method=formula-sum]
Tc          601.26;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       0.5546;      // -   [origin=predictive method=lee-kesler]
Tb          432.81;      // K   [origin=predictive method=joback]
HvapTb      39838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.594 0.84004 -0.00046 9.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butylbutan-1-amine" "di-n-butylamine" "1-butanamine, n-butyl-" "n-butyl-1-butanamine" "dibutilamina" "n-dibutylamine" "di-(n-butyl)amine" "dibutilamina [romanian]" "dibutylamine acetate" "dibutyl-amine" "6287-40-7 (hydrochloride)" "71230-78-9 (phosphate[3:1])" );
gibbsFormation
{
    dHf_298   -154980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105870.0
    phase     gas;
}
