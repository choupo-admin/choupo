/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tribromo-2,4,6-trimethylbenzene  (C9H9Br3, CAS 608-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Tribromo246Trimethylbenzene;
formula     C9H9Br3;
CAS         608-72-0;
InChIKey    LTSSSVHTLGQZAQ-UHFFFAOYSA-N;
MW          356.883;      // g/mol [origin=calculated method=formula-sum]
Tc          913.20;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.7293;      // -   [origin=predictive method=lee-kesler]
Tb          655.58;      // K   [origin=predictive method=joback]
HvapTb      60519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.87 0.59706 -0.000376 9.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 3; } { group ACCH3; count 3; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC_ring; count 6; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(bromanyl)-2,4,6-trimethyl-benzene" "benzene,1,3,5-tribromo-2,4,6-trimethyl-" );
standardThermochemistry
{
    dHf_298   29080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132120.0
}
