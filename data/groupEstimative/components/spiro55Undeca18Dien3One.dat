/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[5.5]undeca-1,8-dien-3-one  (C11H14O, CAS 30834-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro55Undeca18Dien3One;
formula     C11H14O;
CAS         30834-47-0;
InChIKey    WFZMDPXIOJHKJV-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          816.90;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.4019;      // -   [origin=predictive method=lee-kesler]
Tb          557.16;      // K   [origin=predictive method=joback]
HvapTb      44755.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.14 1.3407 -0.00110156 3.904e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[5.5]undeca-4,9-dien-3-one" "spiro(5.5)undeca-1,8-dien-3-one" "agn-pc-03e9gq" "spiro[5.5]undeca-1,8-dien-3-on" "spiro[5.5]undeca-3,10-dien-9-one" );
standardThermochemistry
{
    dHf_298   -142130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42290.0
}
