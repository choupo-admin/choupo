/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,2,6,6-pentamethyl-4-piperidinol  (C10H21NO, CAS 2403-89-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12266Pentamethyl4Piperidinol;
formula     C10H21NO;
CAS         2403-89-6;
InChIKey    NWHNXXMYEICZAT-UHFFFAOYSA-N;
MW          171.284;      // g/mol [origin=calculated method=formula-sum]
Tc          730.77;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.7677;      // -   [origin=predictive method=lee-kesler]
Tb          539.44;      // K   [origin=predictive method=joback]
HvapTb      53913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-160.19 1.7743 -0.001745 7.341e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2,6,6-pentamethylpiperidin-4-ol" "4-hydroxy-1,2,2,6,6-pentamethylpiperidine" "4-piperidinol, 1,2,2,6,6-pentamethyl-" "hopemp" "1,2,2,6,6-pentamethyl-4-hydroxypiperidine" "pentamethylpiperidinol;1,2,2,6,6-tetramethyl-4-piperidinol-ol;paaol;pentamethyl piperidinol;1,2,2,6,6-pentamethylpiperidin-4-ol;1,2,2,6,6-pentamethyl-4,5-dihydro-3h-pyridin-4-ol;4-piperidinol, 1,2,2,6,6-pentamethyl-;" );
standardThermochemistry
{
    dHf_298   -284150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17430.0
}
