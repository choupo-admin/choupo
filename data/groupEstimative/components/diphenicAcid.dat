/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenic acid  (C14H10O4, CAS 482-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenicAcid;
formula     C14H10O4;
CAS         482-05-3;
InChIKey    GWZCCUDJHOGOSO-UHFFFAOYSA-N;
MW          242.23;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.33;      // K   [origin=predictive method=joback]
Pc          32.579;      // bar [origin=predictive method=joback]
omega       1.3147;      // -   [origin=predictive method=lee-kesler]
Tb          874.26;      // K   [origin=predictive method=joback]
HvapTb      86962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.85 1.1586 -0.00081132 2.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-carboxyphenyl)benzoic acid" "2,2'-biphenyldicarboxylic acid" "biphenyl-2,2'-dicarboxylic acid" "2,2'-bibenzoic acid" "2,2'-dicarboxybiphenyl" "[1,1'-biphenyl]-2,2'-dicarboxylic acid" "2,2'-diphenic acid" "o,o'-diphenic acid" "o,o'-bibenzoic acid" "2,2'-diphenyldicarboxylic acid" "(1,1'-biphenyl)-2,2'-dicarboxylic acid" "diphenic acid (8ci)" );
standardThermochemistry
{
    dHf_298   -582710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-415260.0
}
