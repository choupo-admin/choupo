/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethylquinuclidine  (C9H17N, CAS 45732-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethylquinuclidine;
formula     C9H17N;
CAS         45732-65-8;
InChIKey    ZLPCABMSTVWUGB-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          646.94;      // K   [origin=predictive method=joback]
Pc          33.763;      // bar [origin=predictive method=joback]
omega       0.3878;      // -   [origin=predictive method=lee-kesler]
Tb          440.62;      // K   [origin=predictive method=joback]
HvapTb      36827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-177.519 1.59332 -0.0015604 6.282e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 6; } { group C_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyl-1-azabicyclo[2.2.2]octane" "1-azabicyclo[2.2.2]octane, 4-ethyl-" "1-azabicyclo(2.2.2)octane, 4-ethyl-" );
gibbsFormation
{
    dHf_298   13460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247300.0
    phase     gas;
}
