/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[2-(2-hydroxyethoxy)ethoxy]-4-oxobutanoic acid  (C8H14O6, CAS 9050-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        422HydroxyethoxyEthoxy4OxobutanoicAcid;
formula     C8H14O6;
CAS         9050-18-4;
InChIKey    SJIWUNNSRFWATG-UHFFFAOYSA-N;
MW          206.194;      // g/mol [origin=calculated method=formula-sum]
Tc          882.83;      // K   [origin=predictive method=joback]
Pc          30.289;      // bar [origin=predictive method=joback]
omega       1.5411;      // -   [origin=predictive method=lee-kesler]
Tb          700.97;      // K   [origin=predictive method=joback]
HvapTb      77062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.416 0.7306 -0.0003088 9.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2COO; count 1; } { group COOH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group OH; count 1; } { group O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(2-hydroxyethyloxy)ethoxy]-4-oxidanylidene-butanoic acid" "4-[2-(2-hydroxyethoxy)ethoxy]-4-oxo-butanoic acid" "agn-pc-0d6mnj" "4-oxo-4-[2-(2-tritiooxyethoxy)ethoxy]butanoic acid" );
gibbsFormation
{
    dHf_298   -1160450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-879620.0
    phase     gas;
}
