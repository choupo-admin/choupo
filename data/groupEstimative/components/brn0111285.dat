/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 0111285  (C7H9NS, CAS 69966-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn0111285;
formula     C7H9NS;
CAS         69966-44-5;
InChIKey    DMBKVOYJOGETRJ-UHFFFAOYSA-N;
MW          139.216;      // g/mol [origin=calculated method=formula-sum]
Tc          758.58;      // K   [origin=predictive method=joback]
Pc          42.111;      // bar [origin=predictive method=joback]
omega       0.4041;      // -   [origin=predictive method=lee-kesler]
Tb          508.92;      // K   [origin=predictive method=joback]
HvapTb      46479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.719 0.61807 -0.00035726 7.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group C5H4N; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(methylsulfanylmethyl)pyridine" "pyridine, 3-((methylthio)methyl)-" );
gibbsFormation
{
    dHf_298   123380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230640.0
    phase     gas;
}
