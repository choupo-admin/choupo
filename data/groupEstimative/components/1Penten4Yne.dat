/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-penten-4-yne  (C5H6, CAS 871-28-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Penten4Yne;
formula     C5H6;
CAS         871-28-3;
InChIKey    LKOBTUTURSPCEE-UHFFFAOYSA-N;
MW          66.103;      // g/mol [origin=calculated method=formula-sum]
Tc          479.10;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       0.1739;      // -   [origin=predictive method=lee-kesler]
Tb          300.80;      // K   [origin=predictive method=joback]
HvapTb      25912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.131 0.3649 -0.00026703 8.409e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-en-4-yne" "ch2=chch2c.equiv.ch" "allyl acetylene" "1-penten-4-yne(6ci,7ci,8ci,9ci)" "4-penten-1-yne;allylacetylene; vinyl(ethynyl)methane" );
standardThermochemistry
{
    dHf_298   270800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=302130.0
}
