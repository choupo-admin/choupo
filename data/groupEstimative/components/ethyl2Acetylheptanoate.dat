/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-acetylheptanoate  (C11H20O3, CAS 24317-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Acetylheptanoate;
formula     C11H20O3;
CAS         24317-94-0;
InChIKey    XIGZBCUFFUBWDM-UHFFFAOYSA-N;
MW          200.278;      // g/mol [origin=calculated method=formula-sum]
Tc          742.98;      // K   [origin=predictive method=joback]
Pc          20.699;      // bar [origin=predictive method=joback]
omega       0.7887;      // -   [origin=predictive method=lee-kesler]
Tb          562.93;      // K   [origin=predictive method=joback]
HvapTb      53845.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.975 0.97196 -0.0004645 5.306e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-ethanoylheptanoate" "ethyl 2-amylacetoacetate" "heptanoic acid, 2-acetyl-, ethyl ester" "2-acetylheptanoic acid ethyl ester" "ethyl 2-pentylacetoacetate" "ethyl amylacetoacetate" "2-amylacetoacetic acid ethyl ester" "heptanoic acid,2-acetyl-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -705510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399990.0
}
