/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanethiol, 2-bromo-  (C2H5BrS, CAS 6982-46-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanethiol2Bromo;
formula     C2H5BrS;
CAS         6982-46-3;
InChIKey    NISIKGZIQILZRC-UHFFFAOYSA-N;
MW          141.026;      // g/mol [origin=calculated method=formula-sum]
Tc          591.10;      // K   [origin=predictive method=joback]
Pc          61.322;      // bar [origin=predictive method=joback]
omega       0.3010;      // -   [origin=predictive method=lee-kesler]
Tb          374.38;      // K   [origin=predictive method=joback]
HvapTb      33218.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.152 0.2593 -0.0001788 5.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2SH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Br; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylethanethiol" "2-bromoethanethiol" );
standardThermochemistry
{
    dHf_298   -19800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9670.0
}
