/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-74165  (C7H14O, CAS 70220-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG74165;
formula     C7H14O;
CAS         70220-06-3;
InChIKey    KUPODEXLSGEWFR-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          559.28;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.3927;      // -   [origin=predictive method=lee-kesler]
Tb          386.34;      // K   [origin=predictive method=joback]
HvapTb      33544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.843 0.62564 -0.0003298 6.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxyhex-3-ene" "3-hexene,1-methoxy-, (z)-" "3-hexene, 1-methoxy-,(3z)-" );
standardThermochemistry
{
    dHf_298   -202810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16720.0
}
