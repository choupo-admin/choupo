/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.3.1.1(2,5)]undecane, 10-methoxy-, stereoisomer  (C12H20O, CAS 85538-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo431125Undecane10MethoxyStereoisomer;
formula     C12H20O;
CAS         85538-50-7;
InChIKey    FZLYZEQLJWOGIF-UHFFFAOYSA-N;
MW          180.291;      // g/mol [origin=calculated method=formula-sum]
Tc          729.32;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       0.4400;      // -   [origin=predictive method=lee-kesler]
Tb          516.00;      // K   [origin=predictive method=joback]
HvapTb      44181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.61 1.46112 -0.000975 2.585e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 5; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(4.3.1.12,5)undecane, 10-methoxy-, stereoisomer" "10-methoxytricyclo[4.3.1.12,5]undecane" );
gibbsFormation
{
    dHf_298   -257830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87790.0
    phase     gas;
}
