/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorobenzotrichloride  (C7H4Cl4, CAS 2136-89-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorobenzotrichloride;
formula     C7H4Cl4;
CAS         2136-89-2;
InChIKey    MFHPYLFZSCSNST-UHFFFAOYSA-N;
MW          229.909;      // g/mol [origin=calculated method=formula-sum]
Tc          793.23;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.3764;      // -   [origin=predictive method=lee-kesler]
Tb          537.91;      // K   [origin=predictive method=joback]
HvapTb      50358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.01 0.6834 -0.00057456 1.806e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CCl3; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-(trichloromethyl)benzene" "1-chloro-2-(trichloromethyl)benzene" "o-chlorobenzotrichloride" "benzene, 1-chloro-2-(trichloromethyl)-" "o-chlorobenzylidyne chloride" "o-chlorophenyltrichloromethane" "chlorophenyltrichloromethane" "alpha,alpha,alpha,2-tetrachlorotoluene" "alpha,alpha,alpha,ar-tetrachlorotoluene" "toluene, alpha,alpha,alpha,ar-tetrachloro-" "toluene, o,.alpha.,.alpha.,.alpha.-tetrachloro-" "chlorobenzotrichloride" );
gibbsFormation
{
    dHf_298   -34460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65960.0
    phase     gas;
}
