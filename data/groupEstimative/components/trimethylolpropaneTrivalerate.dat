/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane trivalerate  (C21H38O6, CAS 78-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneTrivalerate;
formula     C21H38O6;
CAS         78-15-9;
InChIKey    YHDXJOHRSLAGNZ-UHFFFAOYSA-N;
MW          386.529;      // g/mol [origin=calculated method=formula-sum]
Tc          1043.59;      // K   [origin=predictive method=joback]
Pc          9.766;      // bar [origin=predictive method=joback]
omega       0.9347;      // -   [origin=predictive method=lee-kesler]
Tb          851.51;      // K   [origin=predictive method=joback]
HvapTb      83265.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.553 1.96028 -0.0010066 1.393e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group C; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 13; } { group C; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(pentanoyloxymethyl)butyl pentanoate" "2-ethyl-2-[[(1-oxopentyl)oxy]methyl]propane-1,3-diyl divalerate" "2-ethyl-2-(((1-oxopentyl)oxy)methyl)propane-1,3-diyl divalerate" "pentanoic acid, 1,1'-(2-ethyl-2-(((1-oxopentyl)oxy)methyl)-1,3-propanediyl) ester" "pentanoic acid, 1,1'-[2-ethyl-2-[[(1-oxopentyl)oxy]methyl]-1,3-propanediyl] ester" "pentanoic acid, 2-ethyl-2-(((1-oxopentyl)oxy)methyl)-1,3-propanediyl ester" "pentanoic acid,1,1'-[2-ethyl-2-[[(1-oxopentyl)oxy]methyl]-1,3-propanediyl] ester" "pentanoicacid, 2-ethyl-2-[[(1-oxopentyl)oxy]methyl]-1,3-propanediyl ester (9ci); valericacid, triester with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol (8ci);1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-, trivalerate (8ci);trimethylolpropane trivalerate" );
standardThermochemistry
{
    dHf_298   -1437360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1088.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-802330.0
}
