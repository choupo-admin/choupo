/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4s,5s)-n,2,2-trimethyl-4-phenyl-1,3-dioxan-5-amine  (C13H19NO2, CAS 124686-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4s5sN22Trimethyl4Phenyl13Dioxan5Amine;
formula     C13H19NO2;
CAS         124686-47-1;
InChIKey    OLDLOVICBLVDFQ-RYUDHWBXSA-N;
MW          221.3;      // g/mol [origin=calculated method=formula-sum]
Tc          876.13;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       0.6371;      // -   [origin=predictive method=lee-kesler]
Tb          638.24;      // K   [origin=predictive method=joback]
HvapTb      60924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.12 1.59116 -0.0012382 4.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s,5s)-(+)-2,2-dimethyl-5-methylamino-4-phenyl-1,3-dioxane" "((4s,5s)-2,2-dimethyl-4-phenyl(1,3-dioxan-5-yl))methylamine" "1,3-dioxan-5-amine,n,2,2-trimethyl-4-phenyl-, (4s,5s)-" "1,3-dioxan-5-amine,n,2,2-trimethyl-4-phenyl-, (4s-cis)-" "(4s,5s)-()-2,2-dimethyl-5-methylamino-4-phenyl-1,3-dioxane" );
gibbsFormation
{
    dHf_298   -256770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91680.0
    phase     gas;
}
