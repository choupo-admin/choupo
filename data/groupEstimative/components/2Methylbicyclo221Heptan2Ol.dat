/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbicyclo[2.2.1]heptan-2-ol  (C8H14O, CAS 3212-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylbicyclo221Heptan2Ol;
formula     C8H14O;
CAS         3212-15-5;
InChIKey    QBAQBGVSOIIKBF-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          686.82;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.6778;      // -   [origin=predictive method=lee-kesler]
Tb          488.14;      // K   [origin=predictive method=joback]
HvapTb      48619.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.75 1.35542 -0.001313 5.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbicyclo[2.2.1]heptan-3-ol" "endo-2-methyl-2-norborneol" "endo-2-methyl-2-norbornanol" "2-norbornanol, stereoisomer" "2-methyl-endo-norbornanol" "agn-pc-00hory" "2-endo-methyl-exo-fenchol" "exo-2-methyl-2-norborneol" "exo-2-methyl-2-norbornanol" "2-exo-methyl-endo-camphenilol" "2-bicyclo[2.2.1]heptanol, 2-methyl-" "2-methylbicyclo[2.2.1]heptan-endo-2-ol" );
standardThermochemistry
{
    dHf_298   -226340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24140.0
}
