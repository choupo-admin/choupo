/*--------------------------------*- Choupo -*-----------------------*\
  Component: 18-homoestriol  (C19H26O3, CAS 19882-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Homoestriol;
formula     C19H26O3;
CAS         19882-03-2;
InChIKey    KMVJBESLNMZCAQ-JKTFQODYSA-N;
MW          302.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1170.94;      // K   [origin=predictive method=joback]
Pc          24.826;      // bar [origin=predictive method=joback]
omega       1.6235;      // -   [origin=predictive method=lee-kesler]
Tb          945.95;      // K   [origin=predictive method=joback]
HvapTb      105203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-225.469 2.53892 -0.00222532 8.197e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,14s,16r,17r)-13-ethyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthrene-3,16,17-triol" "18-homo-estriol" "18-homo-oestriol" "gona-1,3,5(10)-triene-3,16-alpha,17-beta-triol, 13-ethyl-" );
standardThermochemistry
{
    dHf_298   -531900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86950.0
}
