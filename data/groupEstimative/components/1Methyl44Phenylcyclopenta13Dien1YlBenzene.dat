/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-4-(4-phenylcyclopenta-1,3-dien-1-yl)benzene  (C18H16, CAS 7144-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl44Phenylcyclopenta13Dien1YlBenzene;
formula     C18H16;
CAS         7144-81-2;
InChIKey    SBTSZWISTFQAHI-UHFFFAOYSA-N;
MW          232.326;      // g/mol [origin=calculated method=formula-sum]
Tc          957.78;      // K   [origin=predictive method=joback]
Pc          23.935;      // bar [origin=predictive method=joback]
omega       0.5945;      // -   [origin=predictive method=lee-kesler]
Tb          698.01;      // K   [origin=predictive method=joback]
HvapTb      63350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.25 1.42372 -0.00097404 2.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 2; } { group ACH; count 9; } { group AC; count 2; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene,1-methyl-4-(4-phenyl-1,3-cyclopentadien-1-yl)-" );
standardThermochemistry
{
    dHf_298   220180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=400790.0
}
