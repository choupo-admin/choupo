/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 4,4',4''-(1-methyl-1-propanyl-3-ylidene)tris(2-cyclohexyl-5-methyl-  (C43H58O3, CAS 136602-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol4441Methyl1Propanyl3YlideneTris2Cyclohexyl5Methyl;
formula     C43H58O3;
CAS         136602-17-0;
InChIKey    PRMDDINQJXOMDC-MHZLTWQESA-N;
MW          622.934;      // g/mol [origin=calculated method=formula-sum]
Tc          1976.95;      // K   [origin=predictive method=joback]
Pc          8.831;      // bar [origin=predictive method=joback]
omega       0.7161;      // -   [origin=predictive method=lee-kesler]
Tb          1592.99;      // K   [origin=predictive method=joback]
HvapTb      161665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-279.059 4.33708 -0.00302524 8.547e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 6; } { group AC; count 1; } { group ACCH3; count 3; } { group ACCH; count 5; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CH2_ring; count 15; } { group CH_ring; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 12; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(2s)-4,4-bis(5-cyclohexyl-2-methyl-4-oxidanyl-phenyl)butan-2-yl]-2-cyclohexyl-5-methyl-phenol" "4-[(2s)-4,4-bis(5-cyclohexyl-4-hydroxy-2-methyl-phenyl)butan-2-yl]-2-cyclohexyl-5-methyl-phenol" "4-[(2s)-4,4-bis(5-cyclohexyl-4-hydroxy-2-methylphenyl)butan-2-yl]-2-cyclohexyl-5-methylphenol" );
standardThermochemistry
{
    dHf_298   -669610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1443.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=195240.0
}
