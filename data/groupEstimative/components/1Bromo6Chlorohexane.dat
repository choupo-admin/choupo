/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-6-chlorohexane  (C6H12BrCl, CAS 6294-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo6Chlorohexane;
formula     C6H12BrCl;
CAS         6294-17-3;
InChIKey    JTYUIAOHIYZBPB-UHFFFAOYSA-N;
MW          199.516;      // g/mol [origin=calculated method=formula-sum]
Tc          631.43;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.4841;      // -   [origin=predictive method=lee-kesler]
Tb          440.47;      // K   [origin=predictive method=joback]
HvapTb      39770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.516 0.6188 -0.0003944 1.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2Cl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-6-chloranyl-hexane" "6-chlorohexyl bromide" "hexane, 1-bromo-6-chloro-" "1-chloro-6-bromohexane" "hexyl bromide, 6-chloro-" "6-bromohexyl chloride" "jtyuiaohiyzbpb-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -156580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2030.0
    phase     gas;
}
