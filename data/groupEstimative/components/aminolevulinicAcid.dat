/*--------------------------------*- Choupo -*-----------------------*\
  Component: aminolevulinic acid  (C5H9NO3, CAS 106-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aminolevulinicAcid;
formula     C5H9NO3;
CAS         106-60-5;
InChIKey    ZGXJTSGNIOSYLO-UHFFFAOYSA-N;
MW          131.131;      // g/mol [origin=calculated method=formula-sum]
Tc          796.16;      // K   [origin=predictive method=joback]
Pc          45.104;      // bar [origin=predictive method=joback]
omega       0.9979;      // -   [origin=predictive method=lee-kesler]
Tb          585.91;      // K   [origin=predictive method=joback]
HvapTb      61275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.793 0.5635 -0.0003455 7.826e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2CO; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-azanyl-4-oxidanylidene-pentanoic acid" "5-aminolevulinic acid" "5-amino-4-oxopentanoic acid" "5-aminolevulinate" "delta-aminolevulinic acid" "aminolevulinate" "kerastick" "aladerm" "pentanoic acid, 5-amino-4-oxo-" "5-amino-4-oxovaleric acid" "5-amino-levulinate" "aminolevulinic" );
gibbsFormation
{
    dHf_298   -575590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-415160.0
    phase     gas;
}
