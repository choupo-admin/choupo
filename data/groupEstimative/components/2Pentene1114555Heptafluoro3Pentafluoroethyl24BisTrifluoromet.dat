/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentene, 1,1,1,4,5,5,5-heptafluoro-3-(pentafluoroethyl)-2,4-bis(trifluoromethyl)-  (C9F18, CAS 30320-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentene1114555Heptafluoro3Pentafluoroethyl24BisTrifluoromet;
formula     C9F18;
CAS         30320-26-4;
InChIKey    KJIGYKCIAQBHEL-UHFFFAOYSA-N;
MW          450.063;      // g/mol [origin=calculated method=formula-sum]
Tc          484.25;      // K   [origin=predictive method=joback]
Pc          13.748;      // bar [origin=predictive method=joback]
omega       0.6726;      // -   [origin=predictive method=lee-kesler]
Tb          373.69;      // K   [origin=predictive method=joback]
HvapTb      11968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.53 1.9716 -0.002052 7.51e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C=C; count 1; } { group CF3; count 5; } { group CF2; count 1; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 7; } { group dC; count 2; } { group F; count 18; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,4,4,5,5,5-octakis(fluoranyl)-3-[1,1,1,2,3,3,3-heptakis(fluoranyl)propan-2-yl]-2-(trifluoromethyl)pent-2-ene" "1,1,1,4,5,5,5-heptafluoro-3-(pentafluoroethyl)-2,4-bis(trifluoromethyl)pent-2-ene" "1,1,1,4,4,5,5,5-octafluoro-3-(1,1,1,2,3,3,3-heptafluoropropan-2-yl)-2-(trifluoromethyl)pent-2-ene" "2-pentene,1,1,1,4,5,5,5-heptafluoro-3-(1,1,2,2,2-pentafluoroethyl)-2,4-bis(trifluoromethyl)-" "2-pentene,1,1,1,4,5,5,5-heptafluoro-3-(pentafluoroethyl)-2,4-bis(trifluoromethyl)-(8ci,9ci);1,1,1,4,5,5,5-heptafluoro-3-(pentafluoroethyl)-2,4-bis(trifluoromethyl)pent-2-ene;hexafluoropropylene trimer; perfluoro(2,4-dimethyl-3-ethyl-2-pentene);perfluoro(2-methyl-3-isopropyl-2-pentene); perfluoro(3-isopropyl-2-methyl-2-pentene);perfluoro-3-ethyl-2,4-dimethyl-2-pentene" );
standardThermochemistry
{
    dHf_298   -3722680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     790.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3398680.0
}
