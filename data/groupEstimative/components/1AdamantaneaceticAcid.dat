/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-adamantaneacetic acid  (C12H18O2, CAS 4942-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1AdamantaneaceticAcid;
formula     C12H18O2;
CAS         4942-47-6;
InChIKey    AOTQGWFNFTVXNQ-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          868.82;      // K   [origin=predictive method=joback]
Pc          29.092;      // bar [origin=predictive method=joback]
omega       0.7666;      // -   [origin=predictive method=lee-kesler]
Tb          639.73;      // K   [origin=predictive method=joback]
HvapTb      57921.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-203.319 1.9031 -0.001793 6.974e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 3; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-adamantyl)ethanoic acid" "1-adamantylacetic acid" "adamantan-1-ylacetic acid" "2-(1-adamantyl)acetic acid" "1-(carboxymethyl)adamantane" "2-(adamantan-1-yl)acetic acid" "2-adamantanylacetic acid" "tricyclo[3.3.1.13,7]decane-1-acetic acid" "tricyclo[3.3.1.1(3,7)-]decane-1-acetic acid" "tricyclo(3.3.1.13,7)dec-1-ylacetic acid" "tricyclo[3.3.1.13,7]dec-1-ylacetic acid" "tricyclo[3.3.1.1~3,7~]dec-1-ylacetic acid" );
gibbsFormation
{
    dHf_298   -434140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-136800.0
    phase     gas;
}
