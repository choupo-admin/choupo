/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetrahydro-1-naphthylamine  (C10H13N, CAS 2217-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetrahydro1Naphthylamine;
formula     C10H13N;
CAS         2217-40-5;
InChIKey    JRZGPXSSNPTNMA-UHFFFAOYSA-N;
MW          147.221;      // g/mol [origin=calculated method=formula-sum]
Tc          786.61;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.4913;      // -   [origin=predictive method=lee-kesler]
Tb          543.60;      // K   [origin=predictive method=joback]
HvapTb      51518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.68 1.0186 -0.00070156 1.888e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrahydronaphthalen-1-amine" "1-aminotetralin" "2-aminotetralin" "tetrahydro-beta-naphthylamine" "1-amino-1,2,3,4-tetrahydro-naphthalene" "beta-1,2,3,4-tetrahydronaphthylamine" "1,2,3,4-tetrahydro-1-naphthalenamine" "1-amino-1,2,3,4-tetrahydronaphthalene" "1-naphthalenamine, 1,2,3,4-tetrahydro-" "2-naphthylamine, 1,2,3,4-tetrahydro-" "1,2,3,4-tetrahydronaphthylamine" "aminotetralin" );
gibbsFormation
{
    dHf_298   75760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251200.0
    phase     gas;
}
