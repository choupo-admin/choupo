/*--------------------------------*- Choupo -*-----------------------*\
  Component: nsc 408021  (C14H20O4, CAS 13846-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nsc408021;
formula     C14H20O4;
CAS         13846-31-6;
InChIKey    HEBKPAWCVUSXMB-UHFFFAOYSA-N;
MW          252.31;      // g/mol [origin=calculated method=formula-sum]
Tc          846.76;      // K   [origin=predictive method=joback]
Pc          18.970;      // bar [origin=predictive method=joback]
omega       0.7725;      // -   [origin=predictive method=lee-kesler]
Tb          644.60;      // K   [origin=predictive method=joback]
HvapTb      60352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.668 1.2798 -0.00062 5.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH2=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(prop-2-enyl) cyclohexane-1,2-dicarboxylate" "cyclohexane-1,2-dicarboxylic acid, diallyl ester, (e)-" "1,2-cyclohexanedicarboxylic acid, 1,2-di-2-propen-1-yl ester" "1,2-cyclohexanedicarboxylic acid, di-2-propenyl ester, trans-" "diallyl hexahydrophthalate" "1, di-2-propenyl ester, trans-" "cyclohexane-1, diallyl ester, (e)-" "1,2-cyclohexanedicarboxylic acid, di-2-propenyl ester, trans- (9ci)" );
standardThermochemistry
{
    dHf_298   -682010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361320.0
}
