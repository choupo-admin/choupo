/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(decyloxy)decan-1-ol  (C20H42O2, CAS 67923-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1DecyloxyDecan1Ol;
formula     C20H42O2;
CAS         67923-56-2;
InChIKey    AHTIKRKNSPTMBE-UHFFFAOYSA-N;
MW          314.554;      // g/mol [origin=calculated method=formula-sum]
Tc          945.13;      // K   [origin=predictive method=joback]
Pc          10.715;      // bar [origin=predictive method=joback]
omega       1.0215;      // -   [origin=predictive method=lee-kesler]
Tb          771.36;      // K   [origin=predictive method=joback]
HvapTb      78815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.817 1.88054 -0.0009868 1.813e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-decoxydecan-1-ol" "1-(decyloxy)decanol" "1-decanol, 1-(decyloxy)-" "decyl aldehyde monodecyl acetal" );
gibbsFormation
{
    dHf_298   -745860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     987.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126740.0
    phase     gas;
}
