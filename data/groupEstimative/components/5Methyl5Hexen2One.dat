/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-5-hexen-2-one  (C7H12O, CAS 3240-09-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl5Hexen2One;
formula     C7H12O;
CAS         3240-09-3;
InChIKey    VBCIOOKAKHGVMI-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          594.11;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.4242;      // -   [origin=predictive method=lee-kesler]
Tb          410.19;      // K   [origin=predictive method=joback]
HvapTb      37332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.202 0.62074 -0.0003635 8.226e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhex-5-en-2-one" "5-hexen-2-one, 5-methyl-" "5-hexen-2-one,5-methyl-" );
gibbsFormation
{
    dHf_298   -184750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41570.0
    phase     gas;
}
