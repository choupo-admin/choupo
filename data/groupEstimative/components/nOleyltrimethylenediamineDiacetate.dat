/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-oleyltrimethylenediamine, diacetate  (C25H52N2O4, CAS 7173-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nOleyltrimethylenediamineDiacetate;
formula     C25H52N2O4;
CAS         7173-67-3;
InChIKey    RYWKPLKIXPVEKP-TTWKNDKESA-N;
MW          444.701;      // g/mol [origin=calculated method=formula-sum]
Tc          1494.43;      // K   [origin=predictive method=joback]
Pc          8.191;      // bar [origin=predictive method=joback]
omega       0.5656;      // -   [origin=predictive method=lee-kesler]
Tb          1192.28;      // K   [origin=predictive method=joback]
HvapTb      123195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.098 2.22616 -0.0008276 -2.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 16; } { group CH=CH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 18; } { group dCH; count 2; } { group COOH; count 2; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;n'-[(e)-octadec-9-enyl]propane-1,3-diamine" "1,3-propanediamine, n-(9z)-9-octadecenyl-, diacetate" "1,3-propanediamine, n1-(9z)-9-octadecen-1-yl-, acetate (1:2)" "(z)-1-(octadec-9-enylammonio)propane-3-ammonium diacetate" "acetic acid; n'-[(e)-octadec-9-enyl]propane-1,3-diamine" );
gibbsFormation
{
    dHf_298   -1278630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1537.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-501660.0
    phase     gas;
}
