/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-3-methylbutane  (C5H11Br, CAS 18295-25-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo3Methylbutane;
formula     C5H11Br;
CAS         18295-25-5;
InChIKey    BLGVDCMNIAOLHA-UHFFFAOYSA-N;
MW          151.047;      // g/mol [origin=calculated method=formula-sum]
Tc          573.37;      // K   [origin=predictive method=joback]
Pc          38.435;      // bar [origin=predictive method=joback]
omega       0.3124;      // -   [origin=predictive method=lee-kesler]
Tb          379.28;      // K   [origin=predictive method=joback]
HvapTb      32383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.17 0.52886 -0.000326 8.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-3-methyl-butane" "butane, 2-bromo-3-methyl" "agn-pc-0dbdtw" "2-bromo-3-methyl butane" "butane,2-bromo-3-methyl-" "butane, 2-bromo-3-methyl-" );
standardThermochemistry
{
    dHf_298   -130760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=660.0
}
