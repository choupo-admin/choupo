/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallyl sebacate  (C16H26O4, CAS 3137-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diallylSebacate;
formula     C16H26O4;
CAS         3137-00-6;
InChIKey    NUVBFTZPEYQYGI-UHFFFAOYSA-N;
MW          282.38;      // g/mol [origin=calculated method=formula-sum]
Tc          850.05;      // K   [origin=predictive method=joback]
Pc          14.133;      // bar [origin=predictive method=joback]
omega       0.9579;      // -   [origin=predictive method=lee-kesler]
Tb          675.48;      // K   [origin=predictive method=joback]
HvapTb      64684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.18 1.3742 -0.0007032 9.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2=CH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(prop-2-enyl) decanedioate" "decanedioic acid, di-2-propenyl ester" "decanedioic acid, 1,10-di-2-propen-1-yl ester" "sebacic acid, diallyl ester" "sebacic acid, diallyl ester (8ci)" "decanedioic acid,1,10-di-2-propen-1-yl ester" );
gibbsFormation
{
    dHf_298   -757270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361220.0
    phase     gas;
}
