/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, (benzyloxy)trimethyl-  (C10H16OSi, CAS 14642-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H16OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneBenzyloxyTrimethyl;
formula     C10H16OSi;
CAS         14642-79-6;
InChIKey    AOKMFXQCRBQJOP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          180.322;      // g/mol [origin=calculated method=formula-sum]
Tc          689.20;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.3642;      // -   [origin=predictive method=lee-kesler]
Tb          478.90;      // K   [origin=predictive method=joback]
HvapTb      42834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.211 0.60556 -2.56e-05 -1.387e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(phenylmethoxy)silane" "benzyloxytrimethylsilane" "silane, trimethyl(phenylmethoxy)-" "agn-pc-00a6ob" "benzene,[[(trimethylsilyl)oxy]methyl]-" "silane,(benzyloxy)trimethyl- (6ci,7ci,8ci);silane, trimethyl(phenylmethoxy)- (9ci);(benzyloxy)trimethylsilane;benzyl alcohol trimethylsilyl ether;benzyltrimethylsilyl ether;phenyl(trimethylsiloxy)methane;trimethyl(benzyloxy)silane;trimethyl(phenylmethoxy)silane;" );
standardThermochemistry
{
    dHf_298   -257040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-64030.0
}
