/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-glyceraldehyde  (C3H6O3, CAS 453-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dGlyceraldehyde;
formula     C3H6O3;
CAS         453-17-8;
InChIKey    MNQZXJOMYWMBOU-VKHMYHEASA-N;
MW          90.078;      // g/mol [origin=calculated method=formula-sum]
Tc          668.98;      // K   [origin=predictive method=joback]
Pc          65.036;      // bar [origin=predictive method=joback]
omega       1.3605;      // -   [origin=predictive method=lee-kesler]
Tb          500.82;      // K   [origin=predictive method=joback]
HvapTb      61962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.461 0.3372 -0.0001964 4.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2,3-bis(oxidanyl)propanal" "d-(+)-glyceraldehyde" "triose" "(2r)-2,3-dihydroxypropanal" "propanal, 2,3-dihydroxy-, (r)-" "propanal, 2,3-dihydroxy-, (r)- (9ci)" "d-aldotriose" "d-glycerose" "3gr" "d-2,3-dihydroxypropanal" "d-2,3-dihydroxypropionaldehyde" "glycerald" );
gibbsFormation
{
    dHf_298   -500570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-401220.0
    phase     gas;
}
