/*--------------------------------*- Choupo -*-----------------------*\
  Component: diiodoacetylene  (C2I2, CAS 624-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diiodoacetylene;
formula     C2I2;
CAS         624-74-8;
InChIKey    XANKMCMFEJCODV-UHFFFAOYSA-N;
MW          277.822;      // g/mol [origin=calculated method=formula-sum]
Tc          733.58;      // K   [origin=predictive method=joback]
Pc          59.722;      // bar [origin=predictive method=joback]
omega       0.1305;      // -   [origin=predictive method=lee-kesler]
Tb          440.64;      // K   [origin=predictive method=joback]
HvapTb      40944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.01 0.122 -0.00015566 7.138e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(iodanyl)ethyne" "1,2-diiodoethyne" "ic.equiv.ci" "acetylene, diiodo-" "diiodoacetylene [forbidden]" );
standardThermochemistry
{
    dHf_298   341430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     316.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285000.0
}
