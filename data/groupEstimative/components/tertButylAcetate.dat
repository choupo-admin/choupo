/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl acetate  (C6H12O2, CAS 540-88-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylAcetate;
formula     C6H12O2;
CAS         540-88-5;
InChIKey    WMOVHXAZOJBABW-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          577.18;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.3520;      // -   [origin=predictive method=lee-kesler]
Tb          391.87;      // K   [origin=predictive method=joback]
HvapTb      35061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.63 0.64488 -0.0003798 7.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl ethanoate" "t-butyl acetate" "acetic acid, tert-butyl ester" "acetic acid, 1,1-dimethylethyl ester" "texaco lead appreciator" "acetic acid tert-butyl ester" "1,1-dimethyl acetate" "1,1-dimethylethyl acetate" "tert-butylacetat" "tert butyl acetate" "tert.-butyl acetate" "t-butylacetate" );
standardThermochemistry
{
    dHf_298   -493200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307890.0
}
