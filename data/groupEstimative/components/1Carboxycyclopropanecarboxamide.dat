/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-carboxycyclopropanecarboxamide  (C5H7NO3, CAS 6914-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Carboxycyclopropanecarboxamide;
formula     C5H7NO3;
CAS         6914-74-5;
InChIKey    SDHXFKBMHSJXHA-UHFFFAOYSA-N;
MW          129.115;      // g/mol [origin=calculated method=formula-sum]
Tc          827.62;      // K   [origin=predictive method=joback]
Pc          57.917;      // bar [origin=predictive method=joback]
omega       0.9148;      // -   [origin=predictive method=lee-kesler]
Tb          592.89;      // K   [origin=predictive method=joback]
HvapTb      60037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.44 1.0063 -0.0010983 4.7556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group COOH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-aminocarbonylcyclopropane-1-carboxylic acid" "1-carbamoylcyclopropane-1-carboxylic acid" "1-(aminocarbonyl)-1-cyclopropanecarboxylic acid" "cyclopropane, 5" "1-carbamoylcyclopropanecarboxylic acid" "cyclopropanecarboxylicacid, 1-(aminocarbonyl)-" );
standardThermochemistry
{
    dHf_298   -487550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-359900.0
}
