/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl ethyl allenolic acid methyl ether  (C16H18O3, CAS 63944-10-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylEthylAllenolicAcidMethylEther;
formula     C16H18O3;
CAS         63944-10-5;
InChIKey    SMKLZXIWNMEXSQ-UHFFFAOYSA-N;
MW          258.317;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.48;      // K   [origin=predictive method=joback]
Pc          22.313;      // bar [origin=predictive method=joback]
omega       0.9975;      // -   [origin=predictive method=lee-kesler]
Tb          786.00;      // K   [origin=predictive method=joback]
HvapTb      74728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.779 1.43566 -0.00101384 2.811e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 6; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(6-methoxynaphthalen-2-yl)-2,2-dimethyl-propanoic acid" "3-(6-methoxynaphthalen-2-yl)-2,2-dimethylpropanoic acid" "acide dimethyl-ethyl-allenolique ether methylique [french]" "propionic acid, alpha,alpha-dimethyl-2-(6-methoxynaphthyl)-" "acide dimethyl-ethyl-allenolique ether methylique" );
gibbsFormation
{
    dHf_298   -460150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162430.0
    phase     gas;
}
