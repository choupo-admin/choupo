/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethoxybenzoic acid  (C9H10O4, CAS 1466-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DimethoxybenzoicAcid;
formula     C9H10O4;
CAS         1466-76-8;
InChIKey    MBIZFBDREVRUHY-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          852.81;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.9000;      // -   [origin=predictive method=lee-kesler]
Tb          632.51;      // K   [origin=predictive method=joback]
HvapTb      61212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.0 0.58534 -0.00021352 -1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 2,6-dimethoxy-" "benzoic acid,6-dimethoxy-" "2,6-dimethoxy-benzoic acid" "benzoicacid, 2,6-dimethoxy-" "benzoicacid,2,6-dimethoxy-;2,6-dimethoxybenzoic" );
gibbsFormation
{
    dHf_298   -630210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-435860.0
    phase     gas;
}
