/*--------------------------------*- Choupo -*-----------------------*\
  Component: t-butyldiphenylmethanol  (C17H20O, CAS 1657-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tButyldiphenylmethanol;
formula     C17H20O;
CAS         1657-60-9;
InChIKey    YOVSPPKJDDWJML-UHFFFAOYSA-N;
MW          240.346;      // g/mol [origin=calculated method=formula-sum]
Tc          959.70;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.8752;      // -   [origin=predictive method=lee-kesler]
Tb          727.64;      // K   [origin=predictive method=joback]
HvapTb      72075.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.03 1.74666 -0.0013374 3.957e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-1,1-diphenyl-propan-1-ol" "tert-butyldiphenylmethanol" "2,2-dimethyl-1,1-diphenylpropan-1-ol" "2,2-dimethyl-1,1-diphenyl-1-propanol" "tert-butyldiphenyl-methanol" "benzenemethanol, " "a-(1,1-dimethylethyl)-" "a-phenyl-" "benzhydrol,a-tert-butyl- (7ci,8ci);1,1-diphenyl-2,2-dimethylpropanol;2,2-dimethyl-1,1-diphenyl-1-propanol;2,2-dimethyl-1,1-diphenylpropanol;tert-butyldiphenylmethanol;" );
gibbsFormation
{
    dHf_298   -90880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185940.0
    phase     gas;
}
