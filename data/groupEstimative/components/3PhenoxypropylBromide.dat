/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenoxypropyl bromide  (C9H11BrO, CAS 588-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenoxypropylBromide;
formula     C9H11BrO;
CAS         588-63-6;
InChIKey    NIDWUZTTXGJFNN-UHFFFAOYSA-N;
MW          215.09;      // g/mol [origin=calculated method=formula-sum]
Tc          742.98;      // K   [origin=predictive method=joback]
Pc          34.643;      // bar [origin=predictive method=joback]
omega       0.5412;      // -   [origin=predictive method=lee-kesler]
Tb          520.78;      // K   [origin=predictive method=joback]
HvapTb      46749.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.507 0.7549 -0.0004574 1.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylpropoxybenzene" "(3-bromopropoxy)benzene" "benzene, (3-bromopropoxy)-" "3-bromopropyl phenyl ether" "1-bromo-3-phenoxypropane" "3-bromopropoxybenzene" "ether, 3-bromopropyl phenyl" "3-phenoxybromopropane" "3-bromo-propoxy-benzene" "3-bromo-1-phenoxypropane" "gamma-phenoxypropyl bromide" ".gamma.-phenoxypropyl bromide" );
gibbsFormation
{
    dHf_298   -98450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46630.0
    phase     gas;
}
