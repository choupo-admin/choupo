/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2660504  (C17H18F3N, CAS 62064-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2660504;
formula     C17H18F3N;
CAS         62064-66-8;
InChIKey    FSLXHGVLOIOQJK-UHFFFAOYSA-N;
MW          293.332;      // g/mol [origin=calculated method=formula-sum]
Tc          903.75;      // K   [origin=predictive method=joback]
Pc          18.937;      // bar [origin=predictive method=joback]
omega       0.8097;      // -   [origin=predictive method=lee-kesler]
Tb          691.21;      // K   [origin=predictive method=joback]
HvapTb      60951.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.168 1.64482 -0.00116916 3.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 2; } { group CHNH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)-1-[3-(trifluoromethyl)phenyl]propan-2-amine" "n-benzyl-alpha-methyl-m-trifluoromethylphenethylamine" "phenethylamine, n-benzyl-alpha-methyl-m-trifluoromethyl-" "agn-pc-03vh0w" "n-benzyl-1-[3-(trifluoromethyl)phenyl]propan-2-amine" "n-benzyl-alpha-methyl-m-trifluoromethyl phenethylamine" );
gibbsFormation
{
    dHf_298   -481510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187190.0
    phase     gas;
}
