/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diphenylbutan-1-ol  (C16H18O, CAS 5331-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenylbutan1Ol;
formula     C16H18O;
CAS         5331-17-9;
InChIKey    DGOVPDXJOQTUQI-UHFFFAOYSA-N;
MW          226.319;      // g/mol [origin=calculated method=formula-sum]
Tc          932.07;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       0.9381;      // -   [origin=predictive method=lee-kesler]
Tb          707.99;      // K   [origin=predictive method=joback]
HvapTb      71145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.648 1.52582 -0.0011112 3.119e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzhydrol, alpha-propyl-" "benzhydrol, .alpha.-propyl-," "1,1-diphenyl-1-butanol" "benzenemethanol, a-phenyl-a-propyl-" );
standardThermochemistry
{
    dHf_298   -61490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174680.0
}
