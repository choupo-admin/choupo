/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3,3,3-pentafluoro-1-propanol  (C3H3F5O, CAS 422-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22333Pentafluoro1Propanol;
formula     C3H3F5O;
CAS         422-05-9;
InChIKey    PSQZJKGXDGNDFP-UHFFFAOYSA-N;
MW          150.046;      // g/mol [origin=calculated method=formula-sum]
Tc          490.62;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.7047;      // -   [origin=predictive method=lee-kesler]
Tb          350.31;      // K   [origin=predictive method=joback]
HvapTb      32274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.039 0.6334 -0.0005954 2.061e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group F; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,3-pentakis(fluoranyl)propan-1-ol" "pfpoh" "pentafluoro-1-propanol" "2,2,3,3,3-pentafluoropropan-1-ol" "pentafluoropropanol" "1,1-dihydroperfluoropropanol" "perfluorodihydropropanol" "1h,1h-pentafluoro-1-propanol" "2,2,3,3,3-pentafluoropropanol" "1h,1h-pentafluoropropanol" "1-propanol, 2,2,3,3,3-pentafluoro-" "1h,1h-pentafluoropropanol-1" );
standardThermochemistry
{
    dHf_298   -1255530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1130810.0
}
