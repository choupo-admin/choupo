/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)octanamide  (C12H25NO3, CAS 68955-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxyethylOctanamide;
formula     C12H25NO3;
CAS         68955-44-2;
InChIKey    FZQAYFWUOCXLKJ-UHFFFAOYSA-N;
MW          231.336;      // g/mol [origin=calculated method=formula-sum]
Tc          893.77;      // K   [origin=predictive method=joback]
Pc          22.145;      // bar [origin=predictive method=joback]
omega       1.5822;      // -   [origin=predictive method=lee-kesler]
Tb          724.83;      // K   [origin=predictive method=joback]
HvapTb      84453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.77 1.30772 -0.0007837 1.7956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "caprylic diethanolamide" "caprylic acid, diethanolamide" "amides, c8-18 and c18-unsatd., n,n-bis(hydroxyethyl)" "octanamide, n,n-bis(2-hydroxyethyl)-" "(c8-c18) and c18 unsaturated alkylcarboxylic acid amide diethanol" "amides, c8-18 and c18-unsatd, n,n-bis(hydroxyethyl)" "(c8-c18) and c18 unsaturated alkylcarboxylic acid amide" "(c8-c18 and c18)unsaturated alkyl carboxylic acid diethanolamide" "(c8-c18) and c18 unsatured alkylcarboxylic acid amide diethanol" "(c8-c18) and (c18)unsaturated alkylcarboxylic acid, diethanolamide" "(c8-c18) and c18 unsaturated alkyl carboxylic acid amide diethanol" "(c8-c18) and c18 unsaturated alkylcarboxylic acid, diethanolamide" );
standardThermochemistry
{
    dHf_298   -640520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-241620.0
}
