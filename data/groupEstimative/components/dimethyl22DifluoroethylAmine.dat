/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl(2,2-difluoroethyl)amine  (C4H8F3N, CAS 819-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl22DifluoroethylAmine;
formula     C4H8F3N;
CAS         819-06-7;
InChIKey    PVSHBYHMVOHXIM-UHFFFAOYSA-N;
MW          127.109;      // g/mol [origin=calculated method=formula-sum]
Tc          442.64;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.3396;      // -   [origin=predictive method=lee-kesler]
Tb          298.14;      // K   [origin=predictive method=joback]
HvapTb      22794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.639 0.66894 -0.0005274 1.625e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH3N; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group F; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)-n,n-dimethyl-ethanamine" "(ch3)2nch2cf3" "2,2,2-trifluoro-n,n-dimethylethanamine" );
standardThermochemistry
{
    dHf_298   -655440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-488010.0
}
