/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-methylundecyl)cyclohexane  (C18H36, CAS 13151-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethylundecylCyclohexane;
formula     C18H36;
CAS         13151-82-1;
InChIKey    ICUZQSKSUXWHFE-UHFFFAOYSA-N;
MW          252.486;      // g/mol [origin=calculated method=formula-sum]
Tc          814.10;      // K   [origin=predictive method=joback]
Pc          13.388;      // bar [origin=predictive method=joback]
omega       0.6841;      // -   [origin=predictive method=lee-kesler]
Tb          630.55;      // K   [origin=predictive method=joback]
HvapTb      55703.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.761 1.84184 -0.0010396 2.121e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecan-2-ylcyclohexane" "dodecane, 2-cyclohexyl-" "2-cyclohexyldodecane" );
standardThermochemistry
{
    dHf_298   -365810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122690.0
}
