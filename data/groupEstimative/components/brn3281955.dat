/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3281955  (C21H18, CAS 63020-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3281955;
formula     C21H18;
CAS         63020-32-6;
InChIKey    QGWIPEGNNFCEEH-UHFFFAOYSA-N;
MW          270.375;      // g/mol [origin=calculated method=formula-sum]
Tc          1025.79;      // K   [origin=predictive method=joback]
Pc          20.419;      // bar [origin=predictive method=joback]
omega       0.7951;      // -   [origin=predictive method=lee-kesler]
Tb          778.64;      // K   [origin=predictive method=joback]
HvapTb      71522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.538 1.73032 -0.00135884 4.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 11; } { group AC; count 6; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 11; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-propylbenzo[c]phenanthrene" "2-n-propyl-3:4-benzphenanthrene" "benzo(c)phenanthrene, 5-propyl-" );
standardThermochemistry
{
    dHf_298   298560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=529410.0
}
