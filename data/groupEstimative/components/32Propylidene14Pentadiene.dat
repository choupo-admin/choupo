/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-propylidene)-1,4-pentadiene  (C8H12, CAS 83615-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32Propylidene14Pentadiene;
formula     C8H12;
CAS         83615-93-4;
InChIKey    VXYFNRFSCLOJBD-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          566.62;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.2712;      // -   [origin=predictive method=lee-kesler]
Tb          379.92;      // K   [origin=predictive method=joback]
HvapTb      32180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.93 0.74364 -0.0005456 1.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethenyl-4-methyl-penta-1,3-diene" "3-ethenyl-4-methylpenta-1,3-diene" );
gibbsFormation
{
    dHf_298   140050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255280.0
    phase     gas;
}
