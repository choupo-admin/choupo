/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoethyl dodecanoate  (C14H27BrO2, CAS 6309-50-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromoethylDodecanoate;
formula     C14H27BrO2;
CAS         6309-50-8;
InChIKey    OJTJEBDBHVSJBW-UHFFFAOYSA-N;
MW          307.272;      // g/mol [origin=calculated method=formula-sum]
Tc          821.46;      // K   [origin=predictive method=joback]
Pc          16.155;      // bar [origin=predictive method=joback]
omega       0.9278;      // -   [origin=predictive method=lee-kesler]
Tb          644.30;      // K   [origin=predictive method=joback]
HvapTb      60600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.762 1.31722 -0.0007146 1.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanoic acid,2-bromoethyl ester" );
standardThermochemistry
{
    dHf_298   -623240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     803.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229050.0
}
