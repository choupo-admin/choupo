/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 1-, 3-piperidino-2-ethoxy-1-propynyl-  (C16H27NO2, CAS 16464-43-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol13Piperidino2Ethoxy1Propynyl;
formula     C16H27NO2;
CAS         16464-43-0;
InChIKey    MHSBNUQSODCZBO-UHFFFAOYSA-N;
MW          265.397;      // g/mol [origin=calculated method=formula-sum]
Tc          954.77;      // K   [origin=predictive method=joback]
Pc          22.871;      // bar [origin=predictive method=joback]
omega       1.0135;      // -   [origin=predictive method=lee-kesler]
Tb          736.79;      // K   [origin=predictive method=joback]
HvapTb      74029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.078 2.01442 -0.00152746 4.9768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group tC; count 2; } { group CH2_ring; count 9; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-piperidin-1-ylethoxy)-1-prop-1-ynyl-cyclohexan-1-ol" "3-(2-piperidin-1-ylethoxy)-1-prop-1-ynylcyclohexan-1-ol" "1-cyclohexanol, 3-[2-(1-piperidinyl)ethoxy]-1-(1-propynyl)-" "3-[2-(piperidin-1-yl)ethoxy]-1-(prop-1-yn-1-yl)cyclohexanol" );
gibbsFormation
{
    dHf_298   -188150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=211110.0
    phase     gas;
}
