/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-indanone, hexahydro-3a-methyl-, cis-  (C10H16O, CAS 13351-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IndanoneHexahydro3aMethylCis;
formula     C10H16O;
CAS         13351-29-6;
InChIKey    AMBOSHXMUMOHBF-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          763.58;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.3922;      // -   [origin=predictive method=lee-kesler]
Tb          522.75;      // K   [origin=predictive method=joback]
HvapTb      41292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.61 1.35042 -0.00111 4.017e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7a-methyl-3,3a,4,5,6,7-hexahydro-1h-inden-2-one" "2h-inden-2-one, octahydro-3a-methyl-, cis-" "2h-inden-2-one, octahydro-3a-methyl-, trans-" "2-indanone, hexahydro-3a-methyl-, trans-" "3a-methyloctahydro-2h-inden-2-one" "2h-inden-2-one, octahydro-3a-methyl-" );
standardThermochemistry
{
    dHf_298   -245070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     415.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9560.0
}
