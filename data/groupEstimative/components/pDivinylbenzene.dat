/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-divinylbenzene  (C10H10, CAS 105-06-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pDivinylbenzene;
formula     C10H10;
CAS         105-06-6;
InChIKey    WEERVPDNCOGWJF-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          668.86;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.3419;      // -   [origin=predictive method=lee-kesler]
Tb          453.42;      // K   [origin=predictive method=joback]
HvapTb      39452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.79 0.7754 -0.00053016 1.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(ethenyl)benzene" "1,4-divinylbenzene" "benzene, 1,4-diethenyl-" "1,4-divinyl-benzene" "1,4-diethenylbenzene" "10.14272/weervpdncogwjf-uhfffaoysa-n" "doi:10.14272/weervpdncogwjf-uhfffaoysa-n" "p-vinylstyrene;benzene,p-divinyl- (8ci);1,4-diethenylbenzene;1,4-divinylbenzene;4-vinylstyrene;p-divinylbenzene;" );
gibbsFormation
{
    dHf_298   226190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=311780.0
    phase     gas;
}
