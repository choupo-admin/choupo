/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicine  (C6H13NO4, CAS 150-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicine;
formula     C6H13NO4;
CAS         150-25-4;
InChIKey    FSVCELGFZIQNCK-UHFFFAOYSA-N;
MW          163.173;      // g/mol [origin=calculated method=formula-sum]
Tc          853.12;      // K   [origin=predictive method=joback]
Pc          43.112;      // bar [origin=predictive method=joback]
omega       1.8553;      // -   [origin=predictive method=lee-kesler]
Tb          679.19;      // K   [origin=predictive method=joback]
HvapTb      81515.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.925 0.8165 -0.0005486 1.452e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 2; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group OH; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethanoic acid" "n,n-bis(2-hydroxyethyl)glycine" "diethylolglycine" "dihydroxyethylglycine" "diethanol glycine" "bicene" "n,n-dihydroxyethylglycine" "n,n-di(2-hydroxyethyl)glycine" "n,n-dihydroxyethyl glycine" "fe-3-specific" "bis(2-hydroxyethyl)glycine" "dheg" );
standardThermochemistry
{
    dHf_298   -754370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-507130.0
}
