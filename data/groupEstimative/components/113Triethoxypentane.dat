/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-triethoxypentane  (C11H24O3, CAS 39595-61-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Triethoxypentane;
formula     C11H24O3;
CAS         39595-61-4;
InChIKey    PWKMTQDJPIKIPC-UHFFFAOYSA-N;
MW          204.31;      // g/mol [origin=calculated method=formula-sum]
Tc          685.55;      // K   [origin=predictive method=joback]
Pc          18.757;      // bar [origin=predictive method=joback]
omega       0.7026;      // -   [origin=predictive method=lee-kesler]
Tb          517.66;      // K   [origin=predictive method=joback]
HvapTb      46534.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.025 0.87108 -0.000248 -4.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane, 1,1,3-triethoxy-" "1,1,3-triethoxy-pentane" );
standardThermochemistry
{
    dHf_298   -677590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-278140.0
}
