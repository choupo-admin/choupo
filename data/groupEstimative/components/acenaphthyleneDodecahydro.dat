/*--------------------------------*- Choupo -*-----------------------*\
  Component: acenaphthylene, dodecahydro-  (C12H20, CAS 2146-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acenaphthyleneDodecahydro;
formula     C12H20;
CAS         2146-36-3;
InChIKey    FZDZWLDRELLWNN-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          726.50;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.3627;      // -   [origin=predictive method=lee-kesler]
Tb          502.52;      // K   [origin=predictive method=joback]
HvapTb      42252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-168.17 1.5412 -0.001095 3.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,3a,4,5,5a,6,7,8,8a,8b-dodecahydroacenaphthylene" "dodecahydroacenaphthylene" "perhydroacenaphthene" "agn-pc-00ne0y" "cis,cis,cis-perhydroacenaphtene" );
standardThermochemistry
{
    dHf_298   -111430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188400.0
}
