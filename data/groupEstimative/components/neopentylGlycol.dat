/*--------------------------------*- Choupo -*-----------------------*\
  Component: neopentyl glycol  (C5H12O2, CAS 126-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neopentylGlycol;
formula     C5H12O2;
CAS         126-30-7;
InChIKey    SLCVBVWXLSEKPL-UHFFFAOYSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          661.61;      // K   [origin=predictive method=joback]
Pc          44.742;      // bar [origin=predictive method=joback]
omega       1.1405;      // -   [origin=predictive method=lee-kesler]
Tb          495.13;      // K   [origin=predictive method=joback]
HvapTb      58786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.548 0.67264 -0.0004808 1.398e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropane-1,3-diol" "2,2-dimethyl-1,3-propanediol" "dimethylolpropane" "1,3-propanediol, 2,2-dimethyl-" "neopentanediol" "neopentylene glycol" "hydroxypivalyl alcohol" "neopentylglycol" "neol" "dimethyltrimethylene glycol" "2,2-dimethyltrimethylene glycol" "2,2-dimethyl-1,3 propanediol" );
standardThermochemistry
{
    dHf_298   -459740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279580.0
}
