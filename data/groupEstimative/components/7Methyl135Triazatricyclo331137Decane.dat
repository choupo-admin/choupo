/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methyl-1,3,5-triazatricyclo[3.3.1.13,7]decane  (C8H15N3, CAS 38705-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methyl135Triazatricyclo331137Decane;
formula     C8H15N3;
CAS         38705-10-1;
InChIKey    VMLZAFNEMDCWNF-UHFFFAOYSA-N;
MW          153.229;      // g/mol [origin=calculated method=formula-sum]
Tc          637.74;      // K   [origin=predictive method=joback]
Pc          42.111;      // bar [origin=predictive method=joback]
omega       0.5537;      // -   [origin=predictive method=lee-kesler]
Tb          441.22;      // K   [origin=predictive method=joback]
HvapTb      38393.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-238.81 1.95232 -0.002146 9.083e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group C_ring; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-triazatricyclo(3.3.1.13,7)decane, 7-methyl-" "1,3,5-triazatricyclo[3.3.1.13,7]decane, 7-methyl-" );
gibbsFormation
{
    dHf_298   280780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=565200.0
    phase     gas;
}
