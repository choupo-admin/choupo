/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-hexene, 5-chloro-  (C6H11Cl, CAS 927-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Hexene5Chloro;
formula     C6H11Cl;
CAS         927-54-8;
InChIKey    XPCQFYOMEFDDOT-UHFFFAOYSA-N;
MW          118.604;      // g/mol [origin=calculated method=formula-sum]
Tc          550.77;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.3089;      // -   [origin=predictive method=lee-kesler]
Tb          370.55;      // K   [origin=predictive method=joback]
HvapTb      32277.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.652 0.56652 -0.0003491 8.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranylhex-1-ene" );
standardThermochemistry
{
    dHf_298   -62760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73110.0
}
