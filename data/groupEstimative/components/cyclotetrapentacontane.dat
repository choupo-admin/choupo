/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotetrapentacontane  (C54H108, CAS 297-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclotetrapentacontane;
formula     C54H108;
CAS         297-63-2;
InChIKey    TWDMOALNFRHCRC-UHFFFAOYSA-N;
MW          757.458;      // g/mol [origin=calculated method=formula-sum]
Tc          2045.85;      // K   [origin=predictive method=joback]
Pc          4.058;      // bar [origin=predictive method=joback]
omega       0.1206;      // -   [origin=predictive method=lee-kesler]
Tb          1664.30;      // K   [origin=predictive method=joback]
HvapTb      144792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-363.55 4.8216 -0.000823 -7.66e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 54; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 54; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1378910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     3227.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144840.0
    phase     gas;
}
