/*--------------------------------*- Choupo -*-----------------------*\
  Component: centalun  (C11H12O2, CAS 2033-94-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        centalun;
formula     C11H12O2;
CAS         2033-94-5;
InChIKey    GQOXDWHRXDPZJK-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          852.98;      // K   [origin=predictive method=joback]
Pc          39.856;      // bar [origin=predictive method=joback]
omega       1.2288;      // -   [origin=predictive method=lee-kesler]
Tb          648.77;      // K   [origin=predictive method=joback]
HvapTb      73888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.81 1.07572 -0.00083753 2.5459e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1-phenyl-but-3-yne-1,2-diol" "3,4-dihydroxy-3-methyl-4-phenyl-1-butyne" "3-methyl-4-phenyl-1-butyne-3,4-diol" "3-butyne-1,2-diol, 2-methyl-1-phenyl-" "3-methyl-3,4-dihydroxy-4-phenyl-1-butyne" "2-methyl-1-phenyl-3-butyne-1,2-diol" "3-methyl-3,4-dihydroxy-4-phenyl-butin-1 [german]" "dl-centalun" "1-fenyl-2-methyl-3-butin-1,2-diol" "2-methyl-1-phenylbut-3-yne-1,2-diol" "3-methyl-3,4-dihydroxy-4-phenyl-butin-1" );
standardThermochemistry
{
    dHf_298   -60430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103980.0
}
