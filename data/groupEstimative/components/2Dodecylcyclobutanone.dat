/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-dodecylcyclobutanone  (C16H30O, CAS 35493-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Dodecylcyclobutanone;
formula     C16H30O;
CAS         35493-46-0;
InChIKey    VVKRFZDUZMLMQM-UHFFFAOYSA-N;
MW          238.415;      // g/mol [origin=calculated method=formula-sum]
Tc          829.65;      // K   [origin=predictive method=joback]
Pc          15.211;      // bar [origin=predictive method=joback]
omega       0.7968;      // -   [origin=predictive method=lee-kesler]
Tb          644.51;      // K   [origin=predictive method=joback]
HvapTb      55542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.589 1.49682 -0.0007764 1.356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dodecylcyclobutan-1-one" "2-dodecyl cyclobutanone" "cyclobutanone,2-dodecyl-" "cyclobutanone, 2-dodecyl-" );
gibbsFormation
{
    dHf_298   -444630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9900.0
    phase     gas;
}
