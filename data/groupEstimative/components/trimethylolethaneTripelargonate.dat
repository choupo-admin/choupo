/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolethane tripelargonate  (C32H60O6, CAS 10535-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolethaneTripelargonate;
formula     C32H60O6;
CAS         10535-50-9;
InChIKey    JMYBRXSQFQZFFB-UHFFFAOYSA-N;
MW          540.826;      // g/mol [origin=calculated method=formula-sum]
Tc          1405.44;      // K   [origin=predictive method=joback]
Pc          5.521;      // bar [origin=predictive method=joback]
omega       0.1514;      // -   [origin=predictive method=lee-kesler]
Tb          1103.19;      // K   [origin=predictive method=joback]
HvapTb      107751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.554 3.00528 -0.001605 2.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 21; } { group C; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 24; } { group C; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-methyl-3-nonanoyloxy-2-(nonanoyloxymethyl)propyl] nonanoate" "trimethylolethane trinonanoate" "nonanoic acid, 1,1'-(2-methyl-2-(((1-oxononyl)oxy)methyl)-1,3-propanediyl) ester" "nonanoic acid, 1,1'-[2-methyl-2-[[(1-oxononyl)oxy]methyl]-1,3-propanediyl] ester" "2-methyl-3-(nonanoyloxy)-2-[(nonanoyloxy)methyl]propyl nonanoate" "2-methyl-2-(((1-oxononyl)oxy)methyl)propane-1,3-diyl dinonan-1-oate" "nonanoic acid, 2-methyl-2-(((1-oxononyl)oxy)methyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -1664400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1517.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-709710.0
    phase     gas;
}
