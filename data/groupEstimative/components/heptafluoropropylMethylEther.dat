/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptafluoropropyl methyl ether  (C4H3F7O, CAS 375-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptafluoropropylMethylEther;
formula     C4H3F7O;
CAS         375-03-1;
InChIKey    NOPJRYAFUXTDLX-UHFFFAOYSA-N;
MW          200.053;      // g/mol [origin=calculated method=formula-sum]
Tc          431.94;      // K   [origin=predictive method=joback]
Pc          28.384;      // bar [origin=predictive method=joback]
omega       0.3887;      // -   [origin=predictive method=lee-kesler]
Tb          298.74;      // K   [origin=predictive method=joback]
HvapTb      17301.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.03 0.78062 -0.000713 2.365e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 1; } { group CF3; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 3; } { group F; count 7; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2,3,3-heptakis(fluoranyl)-3-methoxy-propane" "1,1,1,2,2,3,3-heptafluoro-3-methoxypropane" "propane, 1,1,1,2,2,3,3-heptafluoro-3-methoxy-" "perfluoropropyl methyl ether" "r-e 347mcc1" "heptafluoro-1-methoxypropane" "1,1,2,2,3,3,3-heptafluoro-1-methoxypropane" "propane,1,1,1,2,2,3,3-heptafluoro-3-methoxy-" "ether,heptafluoropropyl methyl (7ci,8ci); 1,1,1,2,2,3,3-heptafluoro-3-methoxypropane;1,1,2,2,3,3,3-heptafluoro-1-methoxypropane;1-methoxy-1,1,2,2,3,3,3-heptafluoropropane; 1-methoxyperfluoropropane; e 347;hfe 301; hfe 347; hfe 347mcc; hfe 7000; heptafluoropropyl methyl ether; methylheptafluoropropyl ether; methyl perfluoropropyl ether; novec hfe 7000;perfluoropropyl methyl ether; r-e 347mcc1" );
standardThermochemistry
{
    dHf_298   -1657130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1477350.0
}
