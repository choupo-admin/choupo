/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl bis(beta-cyanoethyl)amine  (C7H11N3, CAS 1555-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylBisBetaCyanoethylAmine;
formula     C7H11N3;
CAS         1555-58-4;
InChIKey    NPMCIHCQSNHBDX-UHFFFAOYSA-N;
MW          137.186;      // g/mol [origin=calculated method=formula-sum]
Tc          778.61;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.7548;      // -   [origin=predictive method=lee-kesler]
Tb          576.36;      // K   [origin=predictive method=joback]
HvapTb      54175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.834 0.66232 -0.0004076 9.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3N; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group N; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-cyanoethyl(methyl)amino]propanenitrile" "n-methyl-3,3'-iminodipropionitrile" "propanenitrile, 3,3'-(methylimino)bis-" "3,3'-(methylimino)bispropiononitrile" "propionitrile, 3,3'-(methylimino)di-" "3,3'-methylimino-di-propionitrile" "3-[(2-cyanoethyl)(methyl)amino]propanenitrile" "di(2-cianoetil)metilammina" "bis(2-cyanoethyl)methylamine" "methyl bis(" "a-cyanoethyl)amine" "n-methyl-bis-(2-kyanethyl)amin" "methyl bis(.beta.-cyanoethyl)amine" );
gibbsFormation
{
    dHf_298   209480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=385200.0
    phase     gas;
}
