/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadeca-9,12-dienal  (C18H32O, CAS 2541-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadeca912Dienal;
formula     C18H32O;
CAS         2541-61-9;
InChIKey    HXLZULGRVFOIDK-UHFFFAOYSA-N;
MW          264.453;      // g/mol [origin=calculated method=formula-sum]
Tc          842.19;      // K   [origin=predictive method=joback]
Pc          13.052;      // bar [origin=predictive method=joback]
omega       0.8838;      // -   [origin=predictive method=lee-kesler]
Tb          668.42;      // K   [origin=predictive method=joback]
HvapTb      62298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.438 1.72832 -0.001116 2.957e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH=CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group dCH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -265990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     862.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161600.0
    phase     gas;
}
