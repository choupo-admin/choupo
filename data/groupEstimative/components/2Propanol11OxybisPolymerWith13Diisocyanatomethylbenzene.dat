/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1,1'-oxybis-, polymer with 1,3-diisocyanatomethylbenzene  (C15H20N2O5, CAS 59942-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol11OxybisPolymerWith13Diisocyanatomethylbenzene;
formula     C15H20N2O5;
CAS         59942-19-7;
InChIKey    YHVAHNFOTSBAJL-UHFFFAOYSA-N;
MW          308.334;      // g/mol [origin=calculated method=formula-sum]
Tc          1130.22;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       1.6488;      // -   [origin=predictive method=lee-kesler]
Tb          920.08;      // K   [origin=predictive method=joback]
HvapTb      106934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group dCd; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group O; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diisocyanato-2-methyl-benzene;1-(2-oxidanylpropoxy)propan-2-ol" "1,3-diisocyanato-2-methylbenzene; 1-(2-hydroxypropoxy)propan-2-ol" );
