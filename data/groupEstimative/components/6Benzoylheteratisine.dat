/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-benzoylheteratisine  (C29H37NO6, CAS 99759-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Benzoylheteratisine;
formula     C29H37NO6;
CAS         99759-48-5;
InChIKey    XVVZJDDPRFFKTQ-UPWHZOCASA-N;
MW          495.616;      // g/mol [origin=calculated method=formula-sum]
Tc          1404.15;      // K   [origin=predictive method=joback]
Pc          12.200;      // bar [origin=predictive method=joback]
omega       1.1483;      // -   [origin=predictive method=lee-kesler]
Tb          1146.82;      // K   [origin=predictive method=joback]
HvapTb      112678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-403.069 4.32326 -0.0041162 1.6163e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 8; } { group C; count 3; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 8; } { group C_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-o-benzoylheteratisine" "heteratisine 6-benzoate" "heteratisan-14-one, 6-(benzoyloxy)-20-ethyl-8-hydroxy-1-methoxy-4-methyl-, (1alpha,6beta)-" "8h-13,3,6a-ethanylylidene-7,10-methanooxepino(3,4-i)-1-benzazocin-8-one, tetradecahydro-14-(benzoyloxy)-1-ethyl-12a-hydroxy-6-methoxy-3-methyl-, (3r-(3-alpha,6-beta,6a-alpha,7-beta,7a-alpha,10-beta,12a-alpha,13-alpha,13a-beta,14s*,15r*))-" "heteratisan-14-one, 6-(benzoyloxy)-2-o-ethyl-8-hydroxy-1-methoxy-4-methyl-, (1-alpha,6-beta)-" );
gibbsFormation
{
    dHf_298   -869860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124490.0
    phase     gas;
}
