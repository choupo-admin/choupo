/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenamine, 4-(diphenylmethyl)-  (C19H17N, CAS 603-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenamine4Diphenylmethyl;
formula     C19H17N;
CAS         603-38-3;
InChIKey    IVKMZPOWNVXFFH-UHFFFAOYSA-N;
MW          259.352;      // g/mol [origin=calculated method=formula-sum]
Tc          1063.73;      // K   [origin=predictive method=joback]
Pc          25.025;      // bar [origin=predictive method=joback]
omega       0.7601;      // -   [origin=predictive method=lee-kesler]
Tb          791.43;      // K   [origin=predictive method=joback]
HvapTb      75631.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.99 1.5804 -0.00108296 2.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 2; } { group ACCH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(diphenylmethyl)aniline" );
gibbsFormation
{
    dHf_298   291140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=500710.0
    phase     gas;
}
