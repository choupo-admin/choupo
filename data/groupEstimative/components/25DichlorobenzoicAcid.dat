/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dichlorobenzoic acid  (C7H4Cl2O2, CAS 50-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DichlorobenzoicAcid;
formula     C7H4Cl2O2;
CAS         50-79-3;
InChIKey    QVTQYSFCFOGITD-UHFFFAOYSA-N;
MW          191.007;      // g/mol [origin=calculated method=formula-sum]
Tc          859.44;      // K   [origin=predictive method=joback]
Pc          40.364;      // bar [origin=predictive method=joback]
omega       0.7541;      // -   [origin=predictive method=lee-kesler]
Tb          616.77;      // K   [origin=predictive method=joback]
HvapTb      60710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.6 0.5353 -0.00036752 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(chloranyl)benzoic acid" "benzoic acid, 2,5-dichloro-" "2,5-dichloro-benzoic acid" "benzoic acid,2,5-dichloro" "2,4(or 2,5)-dichlorobenzoic acid" "h610" "2,5-dichlorobenzoate;2, 5-dichlorobenzoic acid;benzoic acid, 2,5-dichloro-;" );
gibbsFormation
{
    dHf_298   -355970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-266560.0
    phase     gas;
}
