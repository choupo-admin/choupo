/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butylidene-1-cyclohexanone  (C10H16O, CAS 7153-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butylidene1Cyclohexanone;
formula     C10H16O;
CAS         7153-14-2;
InChIKey    MYSLPKPAMDRDGE-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          748.08;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.4817;      // -   [origin=predictive method=lee-kesler]
Tb          527.08;      // K   [origin=predictive method=joback]
HvapTb      43626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.218 0.85662 -0.0003811 3.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butylidenecyclohexan-1-one" );
standardThermochemistry
{
    dHf_298   -236740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11650.0
}
