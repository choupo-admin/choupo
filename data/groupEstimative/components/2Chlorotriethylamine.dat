/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chlorotriethylamine  (C6H14ClN, CAS 100-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chlorotriethylamine;
formula     C6H14ClN;
CAS         100-35-6;
InChIKey    YMDNODNLFSHHCV-UHFFFAOYSA-N;
MW          135.635;      // g/mol [origin=calculated method=formula-sum]
Tc          557.76;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.4206;      // -   [origin=predictive method=lee-kesler]
Tb          386.75;      // K   [origin=predictive method=joback]
HvapTb      35378.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.366 0.70454 -0.0004356 1.066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n,n-diethyl-ethanamine" "triethylamine, 2-chloro-" "2-(diethylamino)ethyl chloride" "n,n-diethyl-2-chloroethylamine" "beta-chlorotriethylamine" "2-chloroethyldiethylamine" "diethylaminoethyl chloride" "n-diethylaminoethyl chloride" "(2-chloroethyl)diethylamine" "diethyl(2-chloroethyl)amine" "2-(diethylamino)chloroethane" "n-(2-chloroethyl)diethylamine" );
standardThermochemistry
{
    dHf_298   -115380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98490.0
}
