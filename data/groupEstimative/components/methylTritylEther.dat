/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl trityl ether  (C20H18O, CAS 596-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylTritylEther;
formula     C20H18O;
CAS         596-31-6;
InChIKey    IRMNIXXVOOMKKP-UHFFFAOYSA-N;
MW          274.363;      // g/mol [origin=calculated method=formula-sum]
Tc          1023.63;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       0.6347;      // -   [origin=predictive method=lee-kesler]
Tb          756.43;      // K   [origin=predictive method=joback]
HvapTb      68056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.98 1.72972 -0.0012186 3.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[methoxy(diphenyl)methyl]benzene" "trityl methyl ether" "ether, methyl trityl" "methoxytriphenylmethane" "methyl triphenylmethyl ether" "triphenylmethyl methyl ether" "benzene, 1,1',1''-(methoxymethylidyne)tris-" "(methoxydiphenylmethyl)benzene" "triphenylmethyl-containing compound, 14" "1,1',1''-(methoxymethylidyne)trisbenzene" "benzene,1',1''-(methoxymethylidyne)tris-" );
gibbsFormation
{
    dHf_298   112490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=352590.0
    phase     gas;
}
