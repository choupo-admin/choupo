/*--------------------------------*- Choupo -*-----------------------*\
  Component: mexiletine  (C11H17NO, CAS 31828-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mexiletine;
formula     C11H17NO;
CAS         31828-71-4;
InChIKey    VLPIATFUUWWMKC-UHFFFAOYSA-N;
MW          179.263;      // g/mol [origin=calculated method=formula-sum]
Tc          798.93;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.6582;      // -   [origin=predictive method=lee-kesler]
Tb          582.43;      // K   [origin=predictive method=joback]
HvapTb      56343.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.891 0.85556 -0.00040732 5.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2O; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,6-dimethylphenoxy)propan-2-amine" "mexiletina" "mexiletinum" "mexiletene" "mexityl" "mexiletinum [inn-latin]" "2-propanamine, 1-(2,6-dimethylphenoxy)-" "mexiletine hcl" "mexilitine" "mexiletine (inn)" "ethylamine, 1-methyl-2-(2,6-xylyloxy)-" "mexiletine [inn:ban]" );
gibbsFormation
{
    dHf_298   -160490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93900.0
    phase     gas;
}
