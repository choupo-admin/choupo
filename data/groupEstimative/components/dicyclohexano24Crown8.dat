/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclohexano-24-crown-8  (C24H44O8, CAS 17455-23-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclohexano24Crown8;
formula     C24H44O8;
CAS         17455-23-1;
InChIKey    QMLGNDFKJAFKGZ-UHFFFAOYSA-N;
MW          460.608;      // g/mol [origin=calculated method=formula-sum]
Tc          1360.03;      // K   [origin=predictive method=joback]
Pc          14.112;      // bar [origin=predictive method=joback]
omega       0.9316;      // -   [origin=predictive method=lee-kesler]
Tb          1078.08;      // K   [origin=predictive method=joback]
HvapTb      108484.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.93 2.4652 -0.0007086 -2.132e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 4; } { group FCH2O; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 20; } { group CH_ring; count 4; } { group O_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclohexyl 24-crown-8" "tetracosahydrodibenzo[b,n][1,4,7,10,13,16,19,22]octaoxacyclotetracosine" "2,3,14,15-dicyclohexano-1,4,7,10,13,16,19,22-octaoxacyclotetracosane" "2,5,8,11,18,21,24,27-octaoxatricyclo[26.4.0.012.17]dotriacontane" "dibenz(b,n)(1,4,7,10,13,16,19,22)octaoxacyclotetracosin, tetracosahydro-" "tetracosahydrodibenz(b,n)(1,4,7,10,13,16,19,22)octaoxacyclotetracosin" "agn-pc-00hrdg" "dicyclohexano-24-crown-8 ether" "2,5,8,11,18,21,24,27-octaoxatricyclo[26.4.0.0<12,17>]dotriacontane" );
gibbsFormation
{
    dHf_298   -1538310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     825.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-641520.0
    phase     gas;
}
