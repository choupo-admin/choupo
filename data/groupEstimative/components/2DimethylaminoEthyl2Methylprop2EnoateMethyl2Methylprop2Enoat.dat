/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(dimethylamino)ethyl 2-methylprop-2-enoate;methyl 2-methylprop-2-enoate;methyl prop-2-enoate  (C17H29NO6, CAS 50862-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DimethylaminoEthyl2Methylprop2EnoateMethyl2Methylprop2Enoat;
formula     C17H29NO6;
CAS         50862-66-3;
InChIKey    VIXZLWCANHPMKY-UHFFFAOYSA-N;
MW          343.42;      // g/mol [origin=calculated method=formula-sum]
Tc          960.03;      // K   [origin=predictive method=joback]
Pc          12.081;      // bar [origin=predictive method=joback]
omega       0.9060;      // -   [origin=predictive method=lee-kesler]
Tb          768.26;      // K   [origin=predictive method=joback]
HvapTb      76438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.252 1.10582 2.65e-05 -3.214e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group CH3N; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group COO; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, polymer with methyl 2-methyl-2-propenoate and methyl 2-propenoate" "2-dimethylaminoethyl 2-methylprop-2-enoate; methyl 2-methylprop-2-enoate; methyl prop-2-enoate" );
gibbsFormation
{
    dHf_298   -1145050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1181.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-691170.0
    phase     gas;
}
