/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-norbornene-2-ol  (C7H10O, CAS 13080-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Norbornene2Ol;
formula     C7H10O;
CAS         13080-90-5;
InChIKey    MKOSBHNWXFSHSW-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          659.05;      // K   [origin=predictive method=joback]
Pc          43.858;      // bar [origin=predictive method=joback]
omega       0.6729;      // -   [origin=predictive method=lee-kesler]
Tb          464.18;      // K   [origin=predictive method=joback]
HvapTb      47836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.07 0.9125 -0.00071328 2.266e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]hept-2-en-5-ol" "5-norbornen-2-ol" "bicyclo[2.2.1]hept-5-en-2-ol" "exo-2-norbornenol" "bicyclo(2.2.1)hept-5-en-2-ol" "5-exo-norbornenol" "endo-2-norbornenol" "exo-dehydronorborneol" "5-norbornen-2-ol, mixture of endo and exo" "endo-dehydronorborneol" "agn-pc-00gilj" "5-norbornen-2-ol, exo-" );
gibbsFormation
{
    dHf_298   -163160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     239.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=2890.0
    phase     gas;
}
