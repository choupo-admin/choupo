/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl acetylenedicarboxylate  (C8H10O4, CAS 762-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylAcetylenedicarboxylate;
formula     C8H10O4;
CAS         762-21-0;
InChIKey    STRNXFOUBFLVIN-UHFFFAOYSA-N;
MW          170.164;      // g/mol [origin=calculated method=formula-sum]
Tc          708.86;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.6090;      // -   [origin=predictive method=lee-kesler]
Tb          508.08;      // K   [origin=predictive method=joback]
HvapTb      50368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.992 0.50444 -0.00013006 -5.122e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C_C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group tC; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl but-2-ynedioate" "2-butynedioic acid, diethyl ester" "diethyl 2-butynedioate" "diethylbut-2-indioat" "acetylenedicarboxylic acid, diethyl ester" "acetylenedicarboxylic acid diethyl ester" "diethyl but-2-yne-1,4-dioate" "diethyl acetylenedicarboxyate" "bis-(ethoxycarbonyl)acetylene" "1,4-diethyl but-2-ynedioate" "di-ethyl acetylenedicarboxylate" "diethyl acetylene dicarboxylate" );
gibbsFormation
{
    dHf_298   -570710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-401460.0
    phase     gas;
}
