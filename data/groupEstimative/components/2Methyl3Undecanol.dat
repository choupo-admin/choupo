/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-undecanol  (C12H26O, CAS 60671-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3Undecanol;
formula     C12H26O;
CAS         60671-36-5;
InChIKey    YOZVHCUUMOCJNG-UHFFFAOYSA-N;
MW          186.339;      // g/mol [origin=calculated method=formula-sum]
Tc          728.31;      // K   [origin=predictive method=joback]
Pc          19.544;      // bar [origin=predictive method=joback]
omega       0.9649;      // -   [origin=predictive method=lee-kesler]
Tb          565.46;      // K   [origin=predictive method=joback]
HvapTb      58209.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.093 1.18966 -0.0006658 1.404e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylundecan-3-ol" "3-undecanol, 2-methyl-" );
standardThermochemistry
{
    dHf_298   -453800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91540.0
}
