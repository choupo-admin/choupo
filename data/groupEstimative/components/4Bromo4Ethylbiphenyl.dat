/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-4'-ethylbiphenyl  (C14H13Br, CAS 58743-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo4Ethylbiphenyl;
formula     C14H13Br;
CAS         58743-79-6;
InChIKey    OARBGVNQCYYPKT-UHFFFAOYSA-N;
MW          261.162;      // g/mol [origin=calculated method=formula-sum]
Tc          903.72;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       0.6009;      // -   [origin=predictive method=lee-kesler]
Tb          649.40;      // K   [origin=predictive method=joback]
HvapTb      59069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.859 1.09522 -0.00073752 1.907e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-(4-ethylphenyl)benzene" "4-bromo-4'-ethyl-1,1'-biphenyl" "1-bromo-4-(4-ethylphenyl)benzene" "1,1'-biphenyl,4-bromo-4'-ethyl-" "1,1'-biphenyl, 4-bromo-4'-ethyl-" "4-bromo-4'-ethylbiphenyl;4-ethyl-4'-bromobiphenyl;" );
standardThermochemistry
{
    dHf_298   144160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=286880.0
}
