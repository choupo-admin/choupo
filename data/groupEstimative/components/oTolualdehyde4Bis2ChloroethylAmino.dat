/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-tolualdehyde, 4-(bis(2-chloroethyl)amino)-  (C12H15Cl2NO, CAS 26459-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H15Cl2NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        oTolualdehyde4Bis2ChloroethylAmino;
formula     C12H15Cl2NO;
CAS         26459-95-0;
InChIKey    ZQIAXDULHBLZJE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          260.158;      // g/mol [origin=calculated method=formula-sum]
Tc          782.50;      // K   [origin=predictive method=joback]
Pc          22.654;      // bar [origin=predictive method=joback]
omega       0.6133;      // -   [origin=predictive method=lee-kesler]
Tb          574.52;      // K   [origin=predictive method=joback]
HvapTb      54346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.736 1.09152 -0.00083252 2.594e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CHO; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[bis(2-chloroethyl)amino]-2-methyl-benzaldehyde" "4-n,n-bis(2-chloroethyl)amino-2-tolualdehyde" "4-nn-bis(2-chloroethyl)amino-2-tolualdehyde" "4-[bis(2-chloroethyl)amino]-2-methylbenzaldehyde" );
gibbsFormation
{
    dHf_298   35080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     668.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274190.0
    phase     gas;
}
