/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-methoxyethoxy)benzene  (C9H12O2, CAS 41532-81-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyethoxyBenzene;
formula     C9H12O2;
CAS         41532-81-4;
InChIKey    IFQVEYUAIINTRX-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          681.44;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.4914;      // -   [origin=predictive method=lee-kesler]
Tb          477.04;      // K   [origin=predictive method=joback]
HvapTb      42724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.802 0.65352 -0.000275 1.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethoxybenzene" "benzene, (2-methoxyethoxy)-" "1-methoxy-2-phenoxyethane" "2-methoxyethyl phenyl ether" );
gibbsFormation
{
    dHf_298   -257000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72690.0
    phase     gas;
}
