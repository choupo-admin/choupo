/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methylphenyl)adamantane  (C17H22, CAS 1459-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14MethylphenylAdamantane;
formula     C17H22;
CAS         1459-55-8;
InChIKey    RFQXTZGKFOTWFL-UHFFFAOYSA-N;
MW          226.363;      // g/mol [origin=calculated method=formula-sum]
Tc          885.53;      // K   [origin=predictive method=joback]
Pc          22.525;      // bar [origin=predictive method=joback]
omega       0.5160;      // -   [origin=predictive method=lee-kesler]
Tb          640.28;      // K   [origin=predictive method=joback]
HvapTb      54825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-232.07 2.18892 -0.00195656 7.295e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-(1-adamantyl)toluene" "1-(p-tolyl)adamantane" "p-(adamantyl-1)toluene" "1-p-tolyl-adamantane" "1-adamantanyl-4-methylbenzene" "ambap1459-55-8" "1-(4-methylphenyl)tricyclo[3.3.1.1~3,7~]decane" );
gibbsFormation
{
    dHf_298   37990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=351990.0
    phase     gas;
}
