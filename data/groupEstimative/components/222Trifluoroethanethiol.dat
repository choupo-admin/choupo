/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trifluoroethanethiol  (C2H3F3S, CAS 1544-53-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trifluoroethanethiol;
formula     C2H3F3S;
CAS         1544-53-2;
InChIKey    RYRLLAOLJVDVNN-UHFFFAOYSA-N;
MW          116.1;      // g/mol [origin=calculated method=formula-sum]
Tc          473.14;      // K   [origin=predictive method=joback]
Pc          46.785;      // bar [origin=predictive method=joback]
omega       0.2549;      // -   [origin=predictive method=lee-kesler]
Tb          302.80;      // K   [origin=predictive method=joback]
HvapTb      23036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.761 0.3823 -0.0003284 1.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2SH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group F; count 3; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)ethanethiol" "ethanethiol,2,2,2-trifluoro-" );
gibbsFormation
{
    dHf_298   -643210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-586240.0
    phase     gas;
}
