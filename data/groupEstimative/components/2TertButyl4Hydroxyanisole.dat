/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-tert-butyl-4-hydroxyanisole  (C11H16O2, CAS 88-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2TertButyl4Hydroxyanisole;
formula     C11H16O2;
CAS         88-32-4;
InChIKey    IMOYOUMVYICGCA-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          809.35;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.6418;      // -   [origin=predictive method=lee-kesler]
Tb          582.75;      // K   [origin=predictive method=joback]
HvapTb      57146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.61 1.12768 -0.00085592 2.705e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tert-butyl-4-methoxy-phenol" "3-tert-butyl-4-methoxyphenol" "2-bha" "phenol, 3-(1,1-dimethylethyl)-4-methoxy-" "phenol, 3-tert-butyl-4-methoxy-" "butylated hydroxyanisole ii (d)" "3-butyl-4-hydroxyanisole" "4-methoxy-3-tert-butyl-phenol" "4-methoxy-3-tert-butylphenol" "3-tert-butylated hydroxyanisole" "2-tert-butyl-4-hydroxy anisole" "3-(tert-butyl)-4-methoxyphenol" );
standardThermochemistry
{
    dHf_298   -363590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-112260.0
}
