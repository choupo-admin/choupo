/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,3,3,3-hexafluoro-2-methylpropan-2-ol  (C4H4F6O, CAS 1515-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111333Hexafluoro2Methylpropan2Ol;
formula     C4H4F6O;
CAS         1515-14-6;
InChIKey    FQDXJYBXPOMIBX-UHFFFAOYSA-N;
MW          182.063;      // g/mol [origin=calculated method=formula-sum]
Tc          511.27;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.7080;      // -   [origin=predictive method=lee-kesler]
Tb          369.23;      // K   [origin=predictive method=joback]
HvapTb      32387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.33 0.86602 -0.000838 2.955e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group OH; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 3; } { group F; count 6; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,3,3,3-hexakis(fluoranyl)-2-methyl-propan-2-ol" "1,1,1,3,3,3-hexafluoro-2-methyl-2-propanol" "2-propanol, 1,1,1,3,3,3-hexafluoro-2-methyl-" "hexafluoro-tert-butanol" "(cf3)2c(oh)ch3" "fqdxjybxpomibx-uhfffaoysa-" "1,1,1,3,3,3-hexafluoro-2-methylisopropanol" "1,1,1,3,3,3-hexafluoro-2-hydroxy-2-methylpropane" "1,1,1,3,3,3-hexafluoro-2-hydroxy-2-methylpropane;1,1,1,3,3,3-hexafluoro-2-methyl-2-propanol;1,1,1-trifluoro-2-trifluoromethyl-2-propanol;1,1-bis(trifluoromethyl)ethanol;2-methylhexafluoro-2-propanol;hexafluoro-tert-butanol;hexafluoro-tert-butyl alcohol;" );
standardThermochemistry
{
    dHf_298   -1481030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1314360.0
}
