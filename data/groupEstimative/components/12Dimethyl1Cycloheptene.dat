/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethyl-1-cycloheptene  (C9H16, CAS 20053-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dimethyl1Cycloheptene;
formula     C9H16;
CAS         20053-89-8;
InChIKey    RNUMLXRVXVCOAQ-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          655.85;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.3131;      // -   [origin=predictive method=lee-kesler]
Tb          443.13;      // K   [origin=predictive method=joback]
HvapTb      38154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.58 0.82284 -0.000409 5.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethylcycloheptene" "cycloheptene, 1,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -125750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55660.0
    phase     gas;
}
