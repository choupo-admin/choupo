/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyltetrahydrofuran  (C5H10O, CAS 96-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyltetrahydrofuran;
formula     C5H10O;
CAS         96-47-9;
InChIKey    JWUJQDFVADABEY-UHFFFAOYSA-N;
MW          86.134;      // g/mol [origin=calculated method=formula-sum]
Tc          553.65;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.2462;      // -   [origin=predictive method=lee-kesler]
Tb          356.23;      // K   [origin=predictive method=joback]
HvapTb      31491.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.82 0.60752 -0.0003617 7.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyloxolane" "tetrahydro-2-methylfuran" "furan, tetrahydro-2-methyl-" "methyltetrahydrofuran" "tetrahydrosylvan" "furan, 2-methyl-tetrahydro-" "tetrahydrosilvan" "2-methyl-tetrahydrofuran" "furan, tetrahydromethyl-" "methyltetrahydrofurane" "2-methyl tetrahydrofuran" "agn-pc-0cq6lc" );
standardThermochemistry
{
    dHf_298   -218050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     249.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58350.0
}
