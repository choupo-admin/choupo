/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-decyn-1-ol, 10-chloro-  (C10H17ClO, CAS 71317-65-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Decyn1Ol10Chloro;
formula     C10H17ClO;
CAS         71317-65-2;
InChIKey    LWJWRDWOFZCMDJ-UHFFFAOYSA-N;
MW          188.695;      // g/mol [origin=calculated method=formula-sum]
Tc          748.13;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.9300;      // -   [origin=predictive method=lee-kesler]
Tb          567.01;      // K   [origin=predictive method=joback]
HvapTb      61070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.538 0.8448 -0.00047886 1.0558e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group OH; count 1; } { group CH2Cl; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group tC; count 2; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-chloranyldec-3-yn-1-ol" "10-chlorodec-3-yn-1-ol" );
gibbsFormation
{
    dHf_298   -145400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87370.0
    phase     gas;
}
