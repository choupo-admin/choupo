/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-formyl-12-methylanthanthrene  (C24H14O, CAS 63040-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H14O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        6Formyl12Methylanthanthrene;
formula     C24H14O;
CAS         63040-58-4;
InChIKey    GPTXUWVDFMQENI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          318.375;      // g/mol [origin=calculated method=formula-sum]
Tc          1117.47;      // K   [origin=predictive method=joback]
Pc          20.965;      // bar [origin=predictive method=joback]
omega       0.9429;      // -   [origin=predictive method=lee-kesler]
Tb          861.20;      // K   [origin=predictive method=joback]
HvapTb      79821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.83 1.98792 -0.0019584 7.639e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 11; } { group ACCH3; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyldibenzo(def,mno)chrysene-12-carboxaldehyde" "dibenzo(def,mno)chrysene-12-carboxaldehyde, 6-methyl-" );
standardThermochemistry
{
    dHf_298   569900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=771520.0
}
