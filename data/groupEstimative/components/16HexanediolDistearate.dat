/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-hexanediol distearate  (C42H82O4, CAS 26730-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16HexanediolDistearate;
formula     C42H82O4;
CAS         26730-92-7;
InChIKey    TWXPKKOLCJDQBY-UHFFFAOYSA-N;
MW          651.114;      // g/mol [origin=calculated method=formula-sum]
Tc          1858.44;      // K   [origin=predictive method=joback]
Pc          3.642;      // bar [origin=predictive method=joback]
omega       -0.4700;      // -   [origin=predictive method=lee-kesler]
Tb          1277.00;      // K   [origin=predictive method=joback]
HvapTb      123900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.528 3.88424 -0.0020718 3.744e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 36; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 38; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-octadecanoyloxyhexyl octadecanoate" "hexane-1,6-diyl dioctadecanoate" "octadecanoic acid, 1,1'-(1,6-hexanediyl) ester" "hexanediol distearate" "hexamethylene distearate" "1,6-hexanediol stearic acid diester" "1,6-hexanediol, octadecanoic acid ester" "octadecanoic acid, 1,6-hexanediyl ester" );
standardThermochemistry
{
    dHf_298   -1544770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1894.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-317980.0
}
