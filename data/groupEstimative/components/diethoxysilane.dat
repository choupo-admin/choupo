/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethoxysilane  (C4H10O2Si, CAS 18165-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H10O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diethoxysilane;
formula     C4H10O2Si;
CAS         18165-68-9;
InChIKey    SOPZLXDKMICEMF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          118.207;      // g/mol [origin=calculated method=formula-sum]
Tc          501.29;      // K   [origin=predictive method=joback]
Pc          35.942;      // bar [origin=predictive method=joback]
omega       0.3414;      // -   [origin=predictive method=lee-kesler]
Tb          335.96;      // K   [origin=predictive method=joback]
HvapTb      29318.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.252 0.25744 2.82e-05 -7.32e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethoxysilicon" "silane, diethoxy-" );
standardThermochemistry
{
    dHf_298   -390330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-227200.0
}
