/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentylcyclohexane  (C11H20, CAS 1606-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentylcyclohexane;
formula     C11H20;
CAS         1606-08-2;
InChIKey    WVABZRMBCQFXBK-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          713.49;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.3165;      // -   [origin=predictive method=lee-kesler]
Tb          486.11;      // K   [origin=predictive method=joback]
HvapTb      40766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.2 1.3026 -0.000783 1.688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexylcyclopentane" "cyclopentyl cyclohexane" "cyclohexane,cyclopentyl-" "cyclohexane, cyclopentyl-" );
standardThermochemistry
{
    dHf_298   -155570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102740.0
}
