/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-oxocyclopentanecarboxylic acid  (C6H8O3, CAS 98-78-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3OxocyclopentanecarboxylicAcid;
formula     C6H8O3;
CAS         98-78-2;
InChIKey    RDSNBKRWKBMPOP-UHFFFAOYSA-N;
MW          128.127;      // g/mol [origin=calculated method=formula-sum]
Tc          800.92;      // K   [origin=predictive method=joback]
Pc          45.043;      // bar [origin=predictive method=joback]
omega       0.7000;      // -   [origin=predictive method=lee-kesler]
Tb          565.49;      // K   [origin=predictive method=joback]
HvapTb      50618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.02 0.588 -0.0002586 1.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylidenecyclopentane-1-carboxylic acid" "3-oxo-cyclopentane-carboxylic acid" "3-oxo-1-cyclopentanecarboxylic acid" "3-oxocyclopentane-1-carboxylic acid" "3-oxo cyclopentane 1-carboxylic acid" "cyclopentanecarboxylic acid, 3-oxo-" "3-oxo-1-cyclo pentanecarboxylic acid" "3-carboxycyclopentanone" "3-ketocyclopentanecarboxylic acid" "cyclopentanone-3-carboxylic acid" "cyclopentanecarboxylicacid, 3-oxo-" );
gibbsFormation
{
    dHf_298   -594660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     313.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-430310.0
    phase     gas;
}
