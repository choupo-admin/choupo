/*--------------------------------*- Choupo -*-----------------------*\
  Component: malonic acid, phenylpropyl-, diethyl ester  (C16H22O4, CAS 19846-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        malonicAcidPhenylpropylDiethylEster;
formula     C16H22O4;
CAS         19846-06-1;
InChIKey    POTCINDZGKHYPS-UHFFFAOYSA-N;
MW          278.348;      // g/mol [origin=calculated method=formula-sum]
Tc          911.35;      // K   [origin=predictive method=joback]
Pc          17.448;      // bar [origin=predictive method=joback]
omega       0.8609;      // -   [origin=predictive method=lee-kesler]
Tb          705.57;      // K   [origin=predictive method=joback]
HvapTb      67004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.216 1.46116 -0.0008604 1.624e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-phenyl-2-propyl-propanedioate" "diethyl 2-phenyl-2-propylpropanedioate" );
standardThermochemistry
{
    dHf_298   -780350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     736.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-421650.0
}
