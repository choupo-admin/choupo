/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin 355  (C15H14F3NO2, CAS 68975-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin355;
formula     C15H14F3NO2;
CAS         68975-49-5;
InChIKey    FNGKJWDTEBDTNX-UHFFFAOYSA-N;
MW          297.276;      // g/mol [origin=calculated method=formula-sum]
Tc          874.19;      // K   [origin=predictive method=joback]
Pc          21.374;      // bar [origin=predictive method=joback]
omega       0.9371;      // -   [origin=predictive method=lee-kesler]
Tb          672.35;      // K   [origin=predictive method=joback]
HvapTb      60175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.399 1.65062 -0.00137912 4.513e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2N; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group F; count 3; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-ethyl-4-(trifluoromethyl)-7,8-dihydro-6h-pyrano[3,2-g]quinolin-2-one" "9-ethyl-4-(trifluoromethyl)-6,7,8,9-tetrahydro-2h-pyrano[3,2-g]quinolin-2-one" "2h-pyrano(3,2-g)quinolin-2-one, 9-ethyl-6,7,8,9-tetrahydro-4-(trifluoromethyl)-" "2h-pyrano[3,2-g]quinolin-2-one, 9-ethyl-6,7,8,9-tetrahydro-4-(trifluoromethyl)-" "2h-pyrano[3, 9-ethyl-6,7,8,9-tetrahydro-4-(trifluoromethyl)-" "9-ethyl-6,7,8,9-tetrahydro-4-(trifluoromethyl)-2h-pyrano(3,2-g)quinolin-2-one" "9-ethyl-6,8,9-tetrahydro-4-(trifluoromethyl)-2h-pyrano(3,2-g)quinolin-2-one" );
gibbsFormation
{
    dHf_298   -758890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-452890.0
    phase     gas;
}
