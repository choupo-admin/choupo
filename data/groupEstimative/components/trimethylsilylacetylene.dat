/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilylacetylene  (C5H10Si, CAS 1066-54-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H10Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylacetylene;
formula     C5H10Si;
CAS         1066-54-2;
InChIKey    CWMFRHBXRUITQE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          98.22;      // g/mol [origin=calculated method=formula-sum]
Tc          487.16;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.1113;      // -   [origin=predictive method=lee-kesler]
Tb          305.52;      // K   [origin=predictive method=joback]
HvapTb      26876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.94 0.17876 0.00017067 -1.5051e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethynyl(trimethyl)silane" "ethynyltrimethylsilane" "(trimethylsilyl)acetylene" "silane, ethynyltrimethyl-" "ethynyl-trimethyl-silane" "trimethylsilyl acetylene" "ethynyltrimethyl silane" "trimethylsilyl-acetylene" "tms acetylene" "agn-pc-0d7cfa" "silane, ethynyltrimethyl-;" );
gibbsFormation
{
    dHf_298   33750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109530.0
    phase     gas;
}
