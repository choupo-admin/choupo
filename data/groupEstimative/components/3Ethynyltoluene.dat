/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethynyltoluene  (C9H8, CAS 766-82-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethynyltoluene;
formula     C9H8;
CAS         766-82-5;
InChIKey    RENYIDZOAFFNHC-UHFFFAOYSA-N;
MW          116.163;      // g/mol [origin=calculated method=formula-sum]
Tc          652.41;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.2723;      // -   [origin=predictive method=lee-kesler]
Tb          427.30;      // K   [origin=predictive method=joback]
HvapTb      38424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.12 0.62652 -0.00042589 1.1489e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethynyl-3-methyl-benzene" "1-ethynyl-3-methylbenzene" "3-methylphenylacetylene" "m-tolylacetylene" "3'-methylphenylacetylene" "3'-methylphenyl acetylene" "3-methyl phenylacetylene" "agn-pc-0cqhgh" "3-ethynyl-1-methylbenzene" "benzene,1-ethynyl-3-methyl-" "benzene, 1-ethynyl-3-methyl-" "renyidzoaffnhc-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   287870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=350750.0
}
