/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzvalene  (C6H6, CAS 659-85-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzvalene;
formula     C6H6;
CAS         659-85-8;
InChIKey    VMQPMGHYRISRHO-UHFFFAOYSA-N;
MW          78.114;      // g/mol [origin=calculated method=formula-sum]
Tc          527.15;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       0.2636;      // -   [origin=predictive method=lee-kesler]
Tb          338.78;      // K   [origin=predictive method=joback]
HvapTb      28156.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.21 0.9728 -0.00103428 4.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3.1.0.02,6]hex-3-ene" "tricyclo(2.1.1.05,6)hex-2-ene" "tricyclo(3.1.0,02,6)hex-3-ene" );
gibbsFormation
{
    dHf_298   107150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -20.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=240440.0
    phase     gas;
}
