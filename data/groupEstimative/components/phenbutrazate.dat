/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenbutrazate  (C23H29NO3, CAS 4378-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenbutrazate;
formula     C23H29NO3;
CAS         4378-36-3;
InChIKey    BAQKJENAVQLANS-UHFFFAOYSA-N;
MW          367.489;      // g/mol [origin=calculated method=formula-sum]
Tc          1117.27;      // K   [origin=predictive method=joback]
Pc          14.624;      // bar [origin=predictive method=joback]
omega       0.9746;      // -   [origin=predictive method=lee-kesler]
Tb          886.98;      // K   [origin=predictive method=joback]
HvapTb      84864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.017 2.20824 -0.0013691 2.959e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group ACH; count 10; } { group ACCH; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methyl-2-phenyl-morpholin-4-yl)ethyl 2-phenylbutanoate" "fenbutrazate" "fenbutrazatum" "phenbutrazatum" "nethanol" "fenbutrazatum [inn-latin]" "2-(3-methyl-2-phenylmorpholino)ethyl 2-phenylbutyrate" "2-(3-methyl-2-phenylmorpholin-4-yl)ethyl 2-phenylbutanoate" "alpha-phenylbutyric acid, 2-(3-methyl-2-phenylmorpholino)ethyl ester" "butyric acid, 2-phenyl-, 2-(3-methyl-2-phenylmorpholino)ethyl ester" "fenbutrazato" "fenbutrazate [inn]" );
standardThermochemistry
{
    dHf_298   -391880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108290.0
}
