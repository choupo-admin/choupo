/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyleicosane  (C21H44, CAS 1560-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyleicosane;
formula     C21H44;
CAS         1560-84-5;
InChIKey    MLKZKPUBHSWMNA-UHFFFAOYSA-N;
MW          296.583;      // g/mol [origin=calculated method=formula-sum]
Tc          842.91;      // K   [origin=predictive method=joback]
Pc          9.609;      // bar [origin=predictive method=joback]
omega       0.7935;      // -   [origin=predictive method=lee-kesler]
Tb          679.64;      // K   [origin=predictive method=joback]
HvapTb      61952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.883 2.00476 -0.0011218 2.382e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylicosane" "eicosane, 2-methyl-" "isoheneicosane" "eicosane, 2-methyl" "19-methyleicosane;2-methyleicosane" );
standardThermochemistry
{
    dHf_298   -482050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     964.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123500.0
}
