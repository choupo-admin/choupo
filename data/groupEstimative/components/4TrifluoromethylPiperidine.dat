/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(trifluoromethyl)piperidine  (C6H10F3N, CAS 657-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TrifluoromethylPiperidine;
formula     C6H10F3N;
CAS         657-36-3;
InChIKey    RDRQUUWCJTYHCT-UHFFFAOYSA-N;
MW          153.147;      // g/mol [origin=calculated method=formula-sum]
Tc          592.42;      // K   [origin=predictive method=joback]
Pc          35.431;      // bar [origin=predictive method=joback]
omega       0.3630;      // -   [origin=predictive method=lee-kesler]
Tb          399.56;      // K   [origin=predictive method=joback]
HvapTb      32390.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.45 0.8437 -0.000544 1.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2NH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group F; count 3; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-trifluoromethylpiperidine" "4-trifluoromethyl-piperidine" );
gibbsFormation
{
    dHf_298   -672120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-469790.0
    phase     gas;
}
