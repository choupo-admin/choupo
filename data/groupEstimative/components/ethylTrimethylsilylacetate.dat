/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl trimethylsilylacetate  (C7H16O2Si, CAS 4071-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H16O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethylTrimethylsilylacetate;
formula     C7H16O2Si;
CAS         4071-88-9;
InChIKey    QQFBQBDINHJDMN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          160.288;      // g/mol [origin=calculated method=formula-sum]
Tc          598.20;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       0.3975;      // -   [origin=predictive method=lee-kesler]
Tb          419.38;      // K   [origin=predictive method=joback]
HvapTb      38877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.752 0.40788 0.0001524 -2.022e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-trimethylsilylethanoate" "ethyl (trimethylsilyl)acetate" "etsa" "(trimethylsilyl)acetic acid ethyl ester" "ethyl(trimethylsilyl)acetate" "ethyl 2-trimethylsilylacetate" "ethyl (2-trimethylsilyl)acetate" "ethyl ((trimethylsilyl)acetate" "ethyl 2-(trimethylsilyl)acetate" "qqfbqbdinhjdmn-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -616710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407070.0
}
