/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorobutanol  (C4H7Cl3O, CAS 57-15-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorobutanol;
formula     C4H7Cl3O;
CAS         57-15-8;
InChIKey    OSASVXMJTNOKOY-UHFFFAOYSA-N;
MW          177.449;      // g/mol [origin=calculated method=formula-sum]
Tc          694.41;      // K   [origin=predictive method=joback]
Pc          39.906;      // bar [origin=predictive method=joback]
omega       0.6314;      // -   [origin=predictive method=lee-kesler]
Tb          489.13;      // K   [origin=predictive method=joback]
HvapTb      51740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.73 0.68984 -0.000629 2.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group OH; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 2; } { group Cl; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(chloranyl)-2-methyl-propan-2-ol" "chlorbutol" "chloretone" "acetonchloroform" "1,1,1-trichloro-2-methyl-2-propanol" "acetochlorone" "chlorbutanol" "coliquifilm" "chloreton" "chlortran" "clortran" "dentalone" );
standardThermochemistry
{
    dHf_298   -342840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184130.0
}
