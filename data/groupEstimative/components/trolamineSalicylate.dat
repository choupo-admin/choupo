/*--------------------------------*- Choupo -*-----------------------*\
  Component: trolamine salicylate  (C13H21NO6, CAS 2174-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trolamineSalicylate;
formula     C13H21NO6;
CAS         2174-16-5;
InChIKey    UEVAMYPIMMOEFW-UHFFFAOYSA-N;
MW          287.312;      // g/mol [origin=calculated method=formula-sum]
Tc          1275.40;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       2.0600;      // -   [origin=predictive method=lee-kesler]
Tb          1040.23;      // K   [origin=predictive method=joback]
HvapTb      129360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.154 1.385 -0.00083256 1.797e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 3; } { group ACOH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 3; } { group OH_phenol; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethanol;2-oxidanylbenzoic acid" "triethanolamine salicylate" "tea-salicylate" "arthricream (tn)" "salicylic acid trolamine" "trolamine salicylate (usp)" "salicylic acid triethanolamine" "2-[bis(2-hydroxyethyl)amino]ethanol; 2-hydroxybenzoic acid" "2-hydroxybenzoic acid, 2-[bis(2-hydroxyethyl)amino]ethan-1-ol" "salicylic acid, compound with 2,2',2''-nitrilotriethanol (1:1)" "salicylic acid, compound with 2,2',2''-nitrilotriethanol (1:1);" "2-hydroxybenzoic acid, compd. with 2,2',2''-nitrilotris(ethanol) (1:1)" );
standardThermochemistry
{
    dHf_298   -1103480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     911.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-731980.0
}
