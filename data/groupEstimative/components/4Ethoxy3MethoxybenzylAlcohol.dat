/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethoxy-3-methoxybenzyl alcohol  (C10H14O3, CAS 61813-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethoxy3MethoxybenzylAlcohol;
formula     C10H14O3;
CAS         61813-58-9;
InChIKey    PMSHVORCBMOTBP-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          793.67;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       1.0317;      // -   [origin=predictive method=lee-kesler]
Tb          602.06;      // K   [origin=predictive method=joback]
HvapTb      62953.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.782 0.66354 -0.00022572 -1.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-ethoxy-3-methoxy-phenyl)methanol" "(4-ethoxy-3-methoxyphenyl)methanol" "benzenemethanol, 4-ethoxy-3-methoxy-" "benzenemethanol,4-ethoxy-3-methoxy-" "(4-ethoxy-3-methoxyphenyl)methan-1-ol" "(4-ethoxy-3-methoxyphenyl)methanol;4-ethoxy-3-methoxybenzyl alcohol" );
gibbsFormation
{
    dHf_298   -452810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-220350.0
    phase     gas;
}
