/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxyphenyl octanoate  (C14H20O3, CAS 63133-91-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxyphenylOctanoate;
formula     C14H20O3;
CAS         63133-91-5;
InChIKey    LFSWQJOBXQBXAT-UHFFFAOYSA-N;
MW          236.311;      // g/mol [origin=calculated method=formula-sum]
Tc          892.80;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.9740;      // -   [origin=predictive method=lee-kesler]
Tb          685.44;      // K   [origin=predictive method=joback]
HvapTb      69455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.254 1.35472 -0.00093076 2.569e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-hydroxyphenyl) octanoate" "octanoic acid, 4-hydroxyphenyl ester" "4-(octanoyloxy)phenol" "octanoic acid 4-hydroxyphenyl ester" );
standardThermochemistry
{
    dHf_298   -590350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-285580.0
}
