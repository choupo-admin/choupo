/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydrodicyclopentadiene  (C10H14, CAS 4488-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydrodicyclopentadiene;
formula     C10H14;
CAS         4488-57-7;
InChIKey    HANKSFAYJLDDKP-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          663.32;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.3280;      // -   [origin=predictive method=lee-kesler]
Tb          447.38;      // K   [origin=predictive method=joback]
HvapTb      37748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.33 1.3144 -0.00106628 3.518e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "steriochemistry unspecified" "tricyclo(5.2.1.0(2,6))dec-4-ene" "3a,4,5,6,7,7a-hexahydro-4,7-methano-1h-indene" "3a,4,5,6,7,7a-hexahydro-4,7-methanoindene" "4,7-methano-1h-indene, 3a,4,5,6,7,7a-hexahydro-" "tricyclo(5.2.1.0(2,6))dec-3-ene" "tricyclo[5.2.1.0(2,6)]dec-3-ene" "tricyclo[5.2.1.0(2,6)]dec-4-ene" "5,6-dihydrodicyclopentadiene" "agn-pc-00fs08" "endo-8,9-dihydrodicyclopentadiene" "3a,4,7,7a-tetrahydro-4,7-methanoindan" );
gibbsFormation
{
    dHf_298   -50.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     214.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225720.0
    phase     gas;
}
