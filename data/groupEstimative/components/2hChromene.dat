/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-chromene  (C9H8O, CAS 254-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hChromene;
formula     C9H8O;
CAS         254-04-6;
InChIKey    KYNSBQPICQTCGU-UHFFFAOYSA-N;
MW          132.162;      // g/mol [origin=calculated method=formula-sum]
Tc          716.32;      // K   [origin=predictive method=joback]
Pc          41.570;      // bar [origin=predictive method=joback]
omega       0.3849;      // -   [origin=predictive method=lee-kesler]
Tb          478.97;      // K   [origin=predictive method=joback]
HvapTb      43762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.1 0.8292 -0.00063254 1.896e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "delta-3-chromene" "2h-1-benzopyran" "1,2-benzopyran" "benzopyran" "3-chromene" "1,2-chromene" "chromene" "benzopyran (6ci)" "1,3-benzopyran(4ci); benzopyran (6ci); 1,2-benzopyran; 1,2-chromene; 2h-chromene; 3-chromene;d-3-chromene" );
standardThermochemistry
{
    dHf_298   8730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     277.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127880.0
}
