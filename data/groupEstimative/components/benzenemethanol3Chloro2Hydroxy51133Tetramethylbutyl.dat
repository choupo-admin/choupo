/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenemethanol, 3-chloro-2-hydroxy-5-(1,1,3,3-tetramethylbutyl)-  (C15H23ClO2, CAS 16372-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenemethanol3Chloro2Hydroxy51133Tetramethylbutyl;
formula     C15H23ClO2;
CAS         16372-99-9;
InChIKey    DZWNZYZSYZYMEO-UHFFFAOYSA-N;
MW          270.797;      // g/mol [origin=calculated method=formula-sum]
Tc          997.84;      // K   [origin=predictive method=joback]
Pc          22.355;      // bar [origin=predictive method=joback]
omega       1.1720;      // -   [origin=predictive method=lee-kesler]
Tb          783.21;      // K   [origin=predictive method=joback]
HvapTb      84070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.738 1.678 -0.00134008 4.387e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-6-(hydroxymethyl)-4-(2,4,4-trimethylpentan-2-yl)phenol" "benzyl alcohol, 3-chloro-2-hydroxy-5-(1,1,3,3-tetramethylbutyl)-" "2-chloro-6-(hydroxymethyl)-4-(2,4,4-trimethylpentan-2-yl)phenol" "3-chloro-2-hydroxy-5-(1,1,3,3-tetramethylbutyl)benzenemethanol" );
standardThermochemistry
{
    dHf_298   -502120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     654.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129120.0
}
