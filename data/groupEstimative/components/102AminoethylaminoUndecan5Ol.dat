/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-(2-aminoethylamino)undecan-5-ol  (C13H30N2O, CAS 68413-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        102AminoethylaminoUndecan5Ol;
formula     C13H30N2O;
CAS         68413-38-7;
InChIKey    ZLKVYSQMCGZAFX-UHFFFAOYSA-N;
MW          230.396;      // g/mol [origin=calculated method=formula-sum]
Tc          887.08;      // K   [origin=predictive method=joback]
Pc          19.102;      // bar [origin=predictive method=joback]
omega       1.2974;      // -   [origin=predictive method=lee-kesler]
Tb          711.04;      // K   [origin=predictive method=joback]
HvapTb      77512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.721 1.42274 -0.0008122 1.738e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 2; } { group OH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 2; } { group OH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-(2-azanylethylamino)undecan-5-ol" "10-[(2-aminoethyl)amino]undecan-5-ol" "alcohols, c10-secondary, beta-((2-aminoethyl)amino)" );
gibbsFormation
{
    dHf_298   -387180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     786.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72720.0
    phase     gas;
}
