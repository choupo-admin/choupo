/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutylene dichloride  (C4H8Cl2, CAS 598-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutyleneDichloride;
formula     C4H8Cl2;
CAS         598-76-5;
InChIKey    JVHKSSIDGAUKGK-UHFFFAOYSA-N;
MW          127.008;      // g/mol [origin=calculated method=formula-sum]
Tc          556.21;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.2631;      // -   [origin=predictive method=lee-kesler]
Tb          365.10;      // K   [origin=predictive method=joback]
HvapTb      32492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.67 0.40924 -0.000241 5.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)-2-methyl-propane" "1,1-dichloroisobutane" "1,1-dichloro-2-methylpropane" "propane, 1,1-dichloro-2-methyl-" "1,1-dichloro-2-methyl-propane" );
gibbsFormation
{
    dHf_298   -167930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45940.0
    phase     gas;
}
