/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-3-(trimethylsilyl)allyl alcohol  (C6H14OSi, CAS 59376-64-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trans3TrimethylsilylAllylAlcohol;
formula     C6H14OSi;
CAS         59376-64-6;
InChIKey    BRTBTJVSPJZQIT-GQCTYLIASA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          130.262;      // g/mol [origin=calculated method=formula-sum]
Tc          609.13;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.6059;      // -   [origin=predictive method=lee-kesler]
Tb          434.62;      // K   [origin=predictive method=joback]
HvapTb      45881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.361 0.42166 -2e-06 -9.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-trimethylsilylprop-2-en-1-ol" "trimethylsilyl-2-propen-1-ol" "(e)-3-(trimethylsilyl)prop-2-en-1-ol" "2-propen-1-ol, 3-(trimethylsilyl)-" "(e)-3-trimethylsilyl-2-propen-1-ol" "(2e)-3-(trimethylsilyl)-2-propen-1-ol" "trans-(3-hydroxy-2-propen-1-yl)trimethylsilane; trans-3-(trimethylsilyl)-2-propen-1-ol" );
standardThermochemistry
{
    dHf_298   -313800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161720.0
}
