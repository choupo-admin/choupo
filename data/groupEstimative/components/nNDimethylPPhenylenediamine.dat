/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-p-phenylenediamine  (C8H12N2, CAS 99-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylPPhenylenediamine;
formula     C8H12N2;
CAS         99-98-9;
InChIKey    BZORFPDSXLZWJF-UHFFFAOYSA-N;
MW          136.198;      // g/mol [origin=calculated method=formula-sum]
Tc          720.33;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.5244;      // -   [origin=predictive method=lee-kesler]
Tb          499.27;      // K   [origin=predictive method=joback]
HvapTb      49024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.19 0.81124 -0.00053156 1.33e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH3N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n4,n4-dimethylbenzene-1,4-diamine" "p-aminodimethylaniline" "n,n-dimethyl-1,4-phenylenediamine" "4-(dimethylamino)aniline" "dmpd" "p-amino-n,n-dimethylaniline" "4-amino-n,n-dimethylaniline" "p-(dimethylamino)aniline" "dimethyl-p-phenylenediamine" "1,4-benzenediamine, n,n-dimethyl-" "4-aminodimethylaniline" "p-dimethylaminophenylamine" );
standardThermochemistry
{
    dHf_298   117930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=296490.0
}
