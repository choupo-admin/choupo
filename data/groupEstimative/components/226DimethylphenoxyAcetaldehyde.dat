/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,6-dimethylphenoxy)acetaldehyde  (C10H12O2, CAS 72102-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        226DimethylphenoxyAcetaldehyde;
formula     C10H12O2;
CAS         72102-89-7;
InChIKey    SQGVKVASMZKZSW-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          745.95;      // K   [origin=predictive method=joback]
Pc          30.190;      // bar [origin=predictive method=joback]
omega       0.6235;      // -   [origin=predictive method=lee-kesler]
Tb          536.12;      // K   [origin=predictive method=joback]
HvapTb      50584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.391 0.66724 -0.00029932 2.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CHO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,6-dimethylphenoxy)ethanal" "acetaldehyde, (2,6-dimethylphenoxy)-" "acetaldehyde, 2-(2,6-dimethylphenoxy)-" );
gibbsFormation
{
    dHf_298   -253940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-78050.0
    phase     gas;
}
