/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-adamantanemethanol  (C11H18O, CAS 770-71-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Adamantanemethanol;
formula     C11H18O;
CAS         770-71-8;
InChIKey    MDVGOOIANLZFCP-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          768.31;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.7968;      // -   [origin=predictive method=lee-kesler]
Tb          563.52;      // K   [origin=predictive method=joback]
HvapTb      55210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-201.719 1.7913 -0.0016964 6.673e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-adamantylmethanol" "1-(hydroxymethyl)adamantane" "adamantan-1-ylmethanol" "adamantanylmethan-1-ol" "1-hydroxymethyl-adamantane" "1-adamantane methanol" "(adamant-1-yl)methanol" "1-hydroxymethyladamantane" "ambap770-71-8" "(r)-2-(4-chlorophenyl)piperazine" "adamantane-1-methyl alcohol" "k340" );
gibbsFormation
{
    dHf_298   -215460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61870.0
    phase     gas;
}
