/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylcyclopentanamine  (C6H13N, CAS 41223-14-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylcyclopentanamine;
formula     C6H13N;
CAS         41223-14-7;
InChIKey    TYDMZADCGUWTCH-UHFFFAOYSA-N;
MW          99.177;      // g/mol [origin=calculated method=formula-sum]
Tc          631.67;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.3435;      // -   [origin=predictive method=lee-kesler]
Tb          420.02;      // K   [origin=predictive method=joback]
HvapTb      39539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.62 0.74092 -0.000418 8.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylcyclopentan-1-amine" "cyclopentanamine, 2-methyl-" "2-methylcyclopentane-1-amine" "2-methylcyclopentylamine" "2-methyl cyclopentanamine" "agn-pc-00gqek" );
gibbsFormation
{
    dHf_298   -93240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94930.0
    phase     gas;
}
