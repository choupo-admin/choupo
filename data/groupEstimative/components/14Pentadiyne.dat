/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-pentadiyne  (C5H4, CAS 24442-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Pentadiyne;
formula     C5H4;
CAS         24442-69-1;
InChIKey    MDROPVLMRLHTDK-UHFFFAOYSA-N;
MW          64.087;      // g/mol [origin=calculated method=formula-sum]
Tc          481.96;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       0.1331;      // -   [origin=predictive method=lee-kesler]
Tb          294.24;      // K   [origin=predictive method=joback]
HvapTb      26440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.901 0.291 -0.00024006 8.508e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "penta-1,4-diyne" "ch.equiv.cch2c.equiv.ch" "diethynylmethane;propargylacetylene" "1,4-pentadiyne(7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   437270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=437360.0
    phase     gas;
}
