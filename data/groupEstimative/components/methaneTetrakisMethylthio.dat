/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, tetrakis(methylthio)-  (C5H12S4, CAS 6156-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneTetrakisMethylthio;
formula     C5H12S4;
CAS         6156-25-8;
InChIKey    VIKWCIAIVDLETK-UHFFFAOYSA-N;
MW          200.391;      // g/mol [origin=calculated method=formula-sum]
Tc          863.42;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.4221;      // -   [origin=predictive method=lee-kesler]
Tb          585.89;      // K   [origin=predictive method=joback]
HvapTb      52696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.27 0.58224 -0.0002592 9.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH3S; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group S; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(methylsulfanyl)methane" "tetrakis(methylthio)methane" "orthocarbonic acid, tetramethyl ester" "orthocarbonic acid, tetrathio-, tetramethyl ester" );
standardThermochemistry
{
    dHf_298   12200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126540.0
}
