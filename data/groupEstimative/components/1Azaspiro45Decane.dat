/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azaspiro[4.5]decane  (C9H17N, CAS 176-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azaspiro45Decane;
formula     C9H17N;
CAS         176-80-7;
InChIKey    LGKNCSVHCNCJQG-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          732.46;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.3517;      // -   [origin=predictive method=lee-kesler]
Tb          489.54;      // K   [origin=predictive method=joback]
HvapTb      42058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.27 1.4272 -0.001248 4.682e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group C_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azaspiro(4.5)decane" "2,2-pentamethylenepyrrolidine" "4-azaspiro[4.5]decane" "{1-azaspiro[4.5]decane}" );
gibbsFormation
{
    dHf_298   -34740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187930.0
    phase     gas;
}
