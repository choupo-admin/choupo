/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylphenethylsilane  (C10H15Si, CAS 17873-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H15Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethylphenethylsilane;
formula     C10H15Si;
CAS         17873-13-1;
InChIKey    IOKFJYJJRJYRCZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          163.315;      // g/mol [origin=calculated method=formula-sum]
Tc          664.07;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.3341;      // -   [origin=predictive method=lee-kesler]
Tb          455.78;      // K   [origin=predictive method=joback]
HvapTb      40277.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.698 0.77184 -0.000344 2.47e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl(2-phenylethyl)silicon" "agn-pc-03zffi" );
gibbsFormation
{
    dHf_298   -69010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93350.0
    phase     gas;
}
