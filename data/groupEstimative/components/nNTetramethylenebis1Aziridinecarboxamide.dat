/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-tetramethylenebis(1-aziridinecarboxamide)  (C10H18N4O2, CAS 6611-01-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNTetramethylenebis1Aziridinecarboxamide;
formula     C10H18N4O2;
CAS         6611-01-4;
InChIKey    MOURVDBXDGXQCF-UHFFFAOYSA-N;
MW          226.28;      // g/mol [origin=calculated method=formula-sum]
Tc          868.92;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       1.3331;      // -   [origin=predictive method=lee-kesler]
Tb          675.64;      // K   [origin=predictive method=joback]
HvapTb      68404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.406 1.672 -0.0014492 5.0032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH; count 2; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group CdO; count 2; } { group NH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[4-(aziridin-1-ylcarbonylamino)butyl]aziridine-1-carboxamide" "1-aziridinecarboxamide, n,n'-1,4-butanediylbis-" "1-aziridinecarboxamide, n,n'-(1,4-butanediyl)bis-" "1-aziridinecarboxamide, n,n'-tetramethylenebis-" "n,n'-tetramethylenebis-1-aziridine-carboxamide" "n-[4-(aziridine-1-carbonylamino)butyl]aziridine-1-carboxamide" );
standardThermochemistry
{
    dHf_298   -34290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=336940.0
}
