/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8,15,22-tricosatetrayne  (C23H32, CAS 4641-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        181522Tricosatetrayne;
formula     C23H32;
CAS         4641-78-5;
InChIKey    GXFDRUIKMBUYRC-UHFFFAOYSA-N;
MW          308.509;      // g/mol [origin=calculated method=formula-sum]
Tc          923.77;      // K   [origin=predictive method=joback]
Pc          12.664;      // bar [origin=predictive method=joback]
omega       0.7451;      // -   [origin=predictive method=lee-kesler]
Tb          724.08;      // K   [origin=predictive method=joback]
HvapTb      70812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.655 1.7014 -0.00103498 2.5724e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 15; } { group CH_C; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 15; } { group tCH; count 2; } { group tC; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricosa-1,8,15,22-tetrayne" "1,15,22-tricosatetrayne" );
standardThermochemistry
{
    dHf_298   610350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     934.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=994520.0
}
