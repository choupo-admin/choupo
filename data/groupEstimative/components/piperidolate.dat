/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidolate  (C21H25NO2, CAS 82-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidolate;
formula     C21H25NO2;
CAS         82-98-4;
InChIKey    KTHVBAZBLKXIHZ-UHFFFAOYSA-N;
MW          323.436;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.16;      // K   [origin=predictive method=joback]
Pc          17.639;      // bar [origin=predictive method=joback]
omega       0.8736;      // -   [origin=predictive method=lee-kesler]
Tb          818.94;      // K   [origin=predictive method=joback]
HvapTb      76211.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.459 2.04772 -0.0013296 3.09e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-ethylpiperidin-3-yl) 2,2-diphenylethanoate" "dactil" "piperidolate [inn:ban]" "piperidolatum [inn-latin]" "n-ethyl-3-piperidyl diphenylacetate" "1-ethyl-3-piperidyl diphenylacetate" "1-ethylpiperidin-3-yl 2,2-diphenylacetate" "diphenylacetic acid, 1-ethyl-3-piperidyl ester" "3-piperidinol, 1-ethyl-, diphenylacetate (ester)" "benzeneacetic acid, .alpha.-phenyl-, 1-ethyl-3-piperidinyl ester" "piperidolato" "piperidolatum" );
gibbsFormation
{
    dHf_298   -198260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     768.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185280.0
    phase     gas;
}
