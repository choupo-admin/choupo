/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-dimethyl-1,3-propanediamine  (C5H14N2, CAS 111-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl13Propanediamine;
formula     C5H14N2;
CAS         111-33-1;
InChIKey    UQUPIHHYKUEXQD-UHFFFAOYSA-N;
MW          102.181;      // g/mol [origin=calculated method=formula-sum]
Tc          590.10;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.5648;      // -   [origin=predictive method=lee-kesler]
Tb          414.34;      // K   [origin=predictive method=joback]
HvapTb      39596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.077 0.63124 -0.0003454 6.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH3NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-dimethylpropane-1,3-diamine" "1,3-propanediamine, n1,n3-dimethyl-" "1,3-bis(methylamino)propane" "n,n'-dimethylpropan-1,3-diamin" "n1,n3-dimethylpropane-1,3-diamine" "1,3-propanediamine, n,n'-dimethyl-" "2,6-diazaheptane" "n,n'-dimethyltrimethylenediamine" "methyl[3-(methylamino)propyl]amine" "1,3-propanediamine,n,n'-dimethyl- (6ci,7ci,8ci,9ci);1,3-bis(methylamino)propane;n,n'-dimethyl-1,3-diaminopropane;n,n'-dimethyl-1,3-propylenediamine;n,n'-dimethylpropanediamine;n,n'-dimethylpropylenediamine;n,n'-dimethyltrimethylenediamine;" );
gibbsFormation
{
    dHf_298   -39590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170000.0
    phase     gas;
}
