/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-1,3-pentanediol  (C8H18O2, CAS 144-19-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl13Pentanediol;
formula     C8H18O2;
CAS         144-19-4;
InChIKey    JCTXKRPTIMZBJT-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          732.33;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       1.1970;      // -   [origin=predictive method=lee-kesler]
Tb          562.89;      // K   [origin=predictive method=joback]
HvapTb      64688.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.639 0.96948 -0.0006504 1.745e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4-trimethylpentane-1,3-diol" "tmpd" "1,3-pentanediol, 2,2,4-trimethyl-" "tmpd (alcohol)" "2,4-trimethyl-1,3-pentanediol" "2,2,4-trimethyl pentanediol-1,3" );
gibbsFormation
{
    dHf_298   -532220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-259200.0
    phase     gas;
}
