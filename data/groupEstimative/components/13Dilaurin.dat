/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dilaurin  (C27H52O5, CAS 539-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dilaurin;
formula     C27H52O5;
CAS         539-93-5;
InChIKey    KUVAEMGNHJQSMH-UHFFFAOYSA-N;
MW          456.708;      // g/mol [origin=calculated method=formula-sum]
Tc          1290.24;      // K   [origin=predictive method=joback]
Pc          7.305;      // bar [origin=predictive method=joback]
omega       0.4456;      // -   [origin=predictive method=lee-kesler]
Tb          1025.54;      // K   [origin=predictive method=joback]
HvapTb      106801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.772 2.49914 -0.0012894 2.052e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 20; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 22; } { group CH; count 1; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-dodecanoyloxy-2-oxidanyl-propyl) dodecanoate" "1,3-dilauroylglycerol" "2-hydroxypropane-1,3-diyl didodecanoate" "dodecanoic acid, 2-hydroxy-1,3-propanediyl ester" "dodecanoic acid, 1,1'-(2-hydroxy-1,3-propanediyl) ester" "alpha,alpha'-dilaurin" "glycerol 1,3-dilaurate" "glyceryl 1,3-dilaurate" "1,3-didodecanoylglycerol" "glycerol alpha,alpha'-dilaurate" "glyceryl dilaurate, tech" "2-hydroxypropane-1,3-diyl dilaurate" );
gibbsFormation
{
    dHf_298   -1392680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1351.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-583540.0
    phase     gas;
}
