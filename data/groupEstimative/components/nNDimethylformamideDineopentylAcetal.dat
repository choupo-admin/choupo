/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylformamide dineopentyl acetal  (C13H29NO2, CAS 4909-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylformamideDineopentylAcetal;
formula     C13H29NO2;
CAS         4909-78-8;
InChIKey    KEXFRBIOHPDZQM-UHFFFAOYSA-N;
MW          231.38;      // g/mol [origin=calculated method=formula-sum]
Tc          726.50;      // K   [origin=predictive method=joback]
Pc          16.578;      // bar [origin=predictive method=joback]
omega       0.6131;      // -   [origin=predictive method=lee-kesler]
Tb          547.42;      // K   [origin=predictive method=joback]
HvapTb      48415.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.248 1.49396 -0.0009208 2.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH; count 1; } { group C; count 2; } { group CH2O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(2,2-dimethylpropoxy)-n,n-dimethyl-methanamine" "1,1-dineopentyloxytrimethylamine" "1,1-bis(2,2-dimethylpropoxy)-n,n-dimethylmethanamine" "methanamine, 1,1-bis(2,2-dimethylpropoxy)-n,n-dimethyl-" "1,1-dineopentyloxy-n,n-dimethylmethylamine" "[bis(2,2-dimethylpropoxy)methyl]dimethylamine" "1,1-bis(2,2-dimethylpropoxy)-n,n,n-trimethylamine" "methanamine,1,1-bis(2,2-dimethylpropoxy)-n,n-dimethyl-" );
gibbsFormation
{
    dHf_298   -531340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37400.0
    phase     gas;
}
