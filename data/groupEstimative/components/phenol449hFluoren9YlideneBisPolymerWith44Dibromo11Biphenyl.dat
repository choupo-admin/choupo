/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 4,4'-(9h-fluoren-9-ylidene)bis-, polymer with 4,4'-dibromo-1,1'-biphenyl  (C37H26Br2O2, CAS 188432-91-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol449hFluoren9YlideneBisPolymerWith44Dibromo11Biphenyl;
formula     C37H26Br2O2;
CAS         188432-91-9;
InChIKey    CFVSWDWYDFZODZ-UHFFFAOYSA-N;
MW          662.421;      // g/mol [origin=calculated method=formula-sum]
Tc          1863.21;      // K   [origin=predictive method=joback]
Pc          17.788;      // bar [origin=predictive method=joback]
omega       1.4703;      // -   [origin=predictive method=lee-kesler]
Tb          1519.56;      // K   [origin=predictive method=joback]
HvapTb      151870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-227.61 3.4488 -0.00299436 1.0568e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 24; } { group AC; count 10; } { group ACOH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 24; } { group dC_ring; count 12; } { group Br; count 2; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-(4-bromophenyl)benzene;4-[9-(4-hydroxyphenyl)fluoren-9-yl]phenol" );
gibbsFormation
{
    dHf_298   253070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1136.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=590700.0
    phase     gas;
}
