/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl p-octylbenzoate  (C16H24O2, CAS 54256-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylPOctylbenzoate;
formula     C16H24O2;
CAS         54256-51-8;
InChIKey    NKSKNAWLKUQLNY-UHFFFAOYSA-N;
MW          248.366;      // g/mol [origin=calculated method=formula-sum]
Tc          849.56;      // K   [origin=predictive method=joback]
Pc          16.893;      // bar [origin=predictive method=joback]
omega       0.8101;      // -   [origin=predictive method=lee-kesler]
Tb          655.56;      // K   [origin=predictive method=joback]
HvapTb      61555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.853 1.33064 -0.00071616 1.227e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-octylbenzoate" "benzoic acid, 4-octyl-, methyl ester" "4-octyl-benzoic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -465790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123750.0
}
