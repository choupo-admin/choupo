/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-4-hydroxybenzaldehyde  (C9H10O2, CAS 70547-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H10O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        26Dimethyl4Hydroxybenzaldehyde;
formula     C9H10O2;
CAS         70547-87-4;
InChIKey    XXTRGLCPRZQPHJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          723.93;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       0.5117;      // -   [origin=predictive method=lee-kesler]
Tb          499.20;      // K   [origin=predictive method=joback]
HvapTb      49869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.02 0.82364 -0.00077228 3.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACOH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyl-4-oxidanyl-benzaldehyde" "4-hydroxy-2,6-dimethylbenzaldehyde" "2,6-dimethyl-4-hydrobenzaldehyde" "3,5-dimethyl-4-formylphenol" "2.6-dimethyl-4-hydroxybenzaldehyde" "4-hydroxy-2,6-dimethylbenzaldehyde;" "1,3-dimethyl-2-formyl-5-hydroxybenzene" );
gibbsFormation
{
    dHf_298   -116360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7390.0
    phase     gas;
}
