/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane-2-methanamine, n-(2,6-dimethylphenyl)-  (C12H17NO2, CAS 54237-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane2MethanamineN26Dimethylphenyl;
formula     C12H17NO2;
CAS         54237-83-1;
InChIKey    GGNYAVVATITVAW-UHFFFAOYSA-N;
MW          207.273;      // g/mol [origin=calculated method=formula-sum]
Tc          857.74;      // K   [origin=predictive method=joback]
Pc          27.877;      // bar [origin=predictive method=joback]
omega       0.7278;      // -   [origin=predictive method=lee-kesler]
Tb          630.15;      // K   [origin=predictive method=joback]
HvapTb      61619.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.379 1.14784 -0.00067432 1.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group FCH2O; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(1,3-dioxolan-2-ylmethyl)-2,6-dimethyl-aniline" "n-(1,3-dioxolan-2-ylmethyl)-2,6-dimethylaniline" );
standardThermochemistry
{
    dHf_298   -227470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97010.0
}
