/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-tributyl-1,3,5-triazinane  (C15H33N3, CAS 13036-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Tributyl135Triazinane;
formula     C15H33N3;
CAS         13036-83-4;
InChIKey    OIQDTXAPPNRLAS-UHFFFAOYSA-N;
MW          255.45;      // g/mol [origin=calculated method=formula-sum]
Tc          757.46;      // K   [origin=predictive method=joback]
Pc          15.987;      // bar [origin=predictive method=joback]
omega       0.8790;      // -   [origin=predictive method=lee-kesler]
Tb          591.53;      // K   [origin=predictive method=joback]
HvapTb      55335.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.001 1.97796 -0.0014056 4.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH2_ring; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-triazine, 1,3,5-tributylhexahydro-" "1,3,5-tributylhexahydro-1,3,5-triazine" "s-triazine, 1,3,5-tributylhexahydro-" "1,3,5-triazine,1,3,5-tributylhexahydro-" "s-triazine,1,3,5-tributylhexahydro- (6ci,7ci,8ci); 1,3,5-tributylhexahydro-1,3,5-triazine;1,3,5-tributylhexahydro-s-triazine" );
standardThermochemistry
{
    dHf_298   -57200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     740.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=476220.0
}
