/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl terephthalate, 1,6-hexanediol, 1,4-butanediol polymer  (C20H34O8, CAS 50987-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylTerephthalate16Hexanediol14ButanediolPolymer;
formula     C20H34O8;
CAS         50987-86-5;
InChIKey    YDXRTKUDIONMEJ-UHFFFAOYSA-N;
MW          402.484;      // g/mol [origin=calculated method=formula-sum]
Tc          1506.43;      // K   [origin=predictive method=joback]
Pc          14.568;      // bar [origin=predictive method=joback]
omega       0.8159;      // -   [origin=predictive method=lee-kesler]
Tb          1176.82;      // K   [origin=predictive method=joback]
HvapTb      145170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (118.72 1.37944 -0.00013116 -2.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;dimethyl benzene-1,4-dicarboxylate;hexane-1,6-diol" "butane-1,4-diol; dimethyl benzene-1,4-dicarboxylate; hexane-1,6-diol" "1,4-benzenedicarboxylic acid, dimethyl ester, polymer with 1,4-butanediol and 1,6-hexanediol" "1,4-benzenedicarboxylic acid, 1,4-dimethyl ester, polymer with 1,4-butanediol and 1,6-hexanediol" );
gibbsFormation
{
    dHf_298   -1697790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1343.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1157240.0
    phase     gas;
}
