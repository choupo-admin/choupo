name        agG75246;
formula     C25H28O6;
CAS         70495-39-5;
InChIKey    LVNXEJDNUXFDEC-UHFFFAOYSA-N;
MW          424.493;      // g/mol [origin=calculated method=formula-sum]
Tc          1216.48;      // K   [origin=predictive method=joback]
Pc          11.809;      // bar [origin=predictive method=joback]
omega       1.0587;      // -   [origin=predictive method=lee-kesler]
Tb          988.68;      // K   [origin=predictive method=joback]
HvapTb      94638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.423 1.83784 -0.00090552 9.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH2=CH; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[[2-(2-prop-2-enoyloxypropoxy)phenyl]methyl]phenoxy]propan-2-yl prop-2-enoate" "methylenebis(2,1-phenyleneoxy(1-methyl-2,1-ethanediyl)) diacrylate" "methylenebis[2,1-phenyleneoxy(1-methyl-2,1-ethanediyl)] diacrylate" "2-propenoic acid, 1,1'-(methylenebis(2,1-phenyleneoxy(1-methyl-2,1-ethanediyl))) ester" "2-propenoic acid, 1,1'-[methylenebis[2,1-phenyleneoxy(1-methyl-2,1-ethanediyl)]] ester" "2-propenoic acid, methylenebis(2,1-phenyleneoxy(1-methyl-2,1-ethanediyl)) ester" "2-propenoic acid, methylenebis[2,1-phenyleneoxy(1-methyl-2,1-ethanediyl)] ester" "2-propenoic acid,1,1'-[methylenebis[2,1-phenyleneoxy(1-methyl-2,1-ethanediyl)]] ester" "2-propenoicacid, methylenebis[2,1-phenyleneoxy(1-methyl-2,1-ethanediyl)] ester (9ci)" );
standardThermochemistry
