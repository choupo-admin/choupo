/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(hydroxymethyl)cyclohexanol  (C7H14O2, CAS 15753-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1HydroxymethylCyclohexanol;
formula     C7H14O2;
CAS         15753-47-6;
InChIKey    BGZGQDDKQNYZID-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          753.31;      // K   [origin=predictive method=joback]
Pc          47.171;      // bar [origin=predictive method=joback]
omega       1.1738;      // -   [origin=predictive method=lee-kesler]
Tb          563.91;      // K   [origin=predictive method=joback]
HvapTb      63812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.489 1.1508 -0.0010314 3.993e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(hydroxymethyl)cyclohexan-1-ol" "1-methylolcyclohexan-1-ol" "1-hydroxycyclohexanemethanol" "cyclohexanemethanol,1-hydroxy-" "1-(hydroxymethyl)-1-cyclohexanol" "1-(hydroxymethyl)-cyclohexan-1-ol" );
gibbsFormation
{
    dHf_298   -422710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246620.0
    phase     gas;
}
