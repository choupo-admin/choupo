/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzylamine acetate  (C16H19NO2, CAS 72088-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzylamineAcetate;
formula     C16H19NO2;
CAS         72088-84-7;
InChIKey    MTZKXRGZXUJKIU-UHFFFAOYSA-N;
MW          257.333;      // g/mol [origin=calculated method=formula-sum]
Tc          1056.99;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       1.0271;      // -   [origin=predictive method=lee-kesler]
Tb          816.12;      // K   [origin=predictive method=joback]
HvapTb      79656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.258 1.28682 -0.0006154 5.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;1-phenyl-n-(phenylmethyl)methanamine" "benzenemethanamine, n-(phenylmethyl)-, acetate" "n-(phenylmethyl)benzenemethanamide acetate" "benzenemethanamide, n-(phenylmethyl)-, acetate" "103-49-1 (parent)" "acetic acid; dibenzyl amine" "benzenemethanamine, n-(phenylmethyl)-, acetate (1:1)" "dibenzylamine monoacetate" "acetic acid; n-benzyl-1-phenylmethanamine" "n-benzyl-1-phenylmethanamine acetate (1:1)" );
gibbsFormation
{
    dHf_298   -308930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50620.0
    phase     gas;
}
