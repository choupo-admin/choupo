/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumatetralyl  (C19H16O3, CAS 5836-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumatetralyl;
formula     C19H16O3;
CAS         5836-29-3;
InChIKey    ULSLJYXHZDTLQK-UHFFFAOYSA-N;
MW          292.334;      // g/mol [origin=calculated method=formula-sum]
Tc          1115.57;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       1.0880;      // -   [origin=predictive method=lee-kesler]
Tb          858.77;      // K   [origin=predictive method=joback]
HvapTb      85274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.45 1.8446 -0.00151592 4.982e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 6; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanyl-3-(1,2,3,4-tetrahydronaphthalen-1-yl)chromen-2-one" "endrocid" "endrocide" "racumin" "rodentin" "endox" "raucumin 57" "coumatetralyl [bsi:iso]" "cumatetralyl [german, dutch]" "3-(alpha-tetral)-4-oxycoumarin" "3-(d-tetralyl)-4-hydroxycoumarin" "2h-1-benzopyran-2-one, 4-hydroxy-3-(1,2,3,4-tetrahydro-1-naphthalenyl)-" );
standardThermochemistry
{
    dHf_298   -267710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-790.0
}
