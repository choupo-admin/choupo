/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dibromomesitylene  (C9H10Br2, CAS 6942-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dibromomesitylene;
formula     C9H10Br2;
CAS         6942-99-0;
InChIKey    CIHJFEWFZJQTFE-UHFFFAOYSA-N;
MW          277.987;      // g/mol [origin=calculated method=formula-sum]
Tc          828.62;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.5898;      // -   [origin=predictive method=lee-kesler]
Tb          584.44;      // K   [origin=predictive method=joback]
HvapTb      53422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.38 0.61836 -0.00037164 9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 3; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(bromanyl)-1,3,5-trimethyl-benzene" "2,4-dibromo-1,3,5-trimethylbenzene" "mesitylene, 2,4-dibromo-" "benzene, 2,4-dibromo-1,3,5-trimethyl-" "mesitylene,4-dibromo-" "benzene,4-dibromo-1,3,5-trimethyl-" );
standardThermochemistry
{
    dHf_298   14220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127430.0
}
