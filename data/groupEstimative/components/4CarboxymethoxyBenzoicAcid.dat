/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(carboxymethoxy)benzoic acid  (C9H8O5, CAS 19360-67-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4CarboxymethoxyBenzoicAcid;
formula     C9H8O5;
CAS         19360-67-9;
InChIKey    LABJFIBQJFPXHZ-UHFFFAOYSA-N;
MW          196.158;      // g/mol [origin=calculated method=formula-sum]
Tc          980.96;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       1.2748;      // -   [origin=predictive method=lee-kesler]
Tb          750.62;      // K   [origin=predictive method=joback]
HvapTb      75304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.801 0.7588 -0.00046416 9.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-hydroxy-2-oxoethyloxy)benzoic acid" "4-carboxyphenoxyacetic acid" "p-carboxyphenoxyacetic acid" "a-carboxy-p-anisic acid" "4-(carboxymethyloxy)benzoic acid" "benzoic acid,4-(carboxymethoxy)-" "benzoic acid, 4-(carboxymethoxy)-" );
gibbsFormation
{
    dHf_298   -836790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-665140.0
    phase     gas;
}
