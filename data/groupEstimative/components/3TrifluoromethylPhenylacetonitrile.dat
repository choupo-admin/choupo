/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(trifluoromethyl)phenylacetonitrile  (C9H6F3N, CAS 2338-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TrifluoromethylPhenylacetonitrile;
formula     C9H6F3N;
CAS         2338-76-3;
InChIKey    JOIYKSLWXLFGGR-UHFFFAOYSA-N;
MW          185.148;      // g/mol [origin=calculated method=formula-sum]
Tc          742.39;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.5814;      // -   [origin=predictive method=lee-kesler]
Tb          533.84;      // K   [origin=predictive method=joback]
HvapTb      45297.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.099 0.8164 -0.00061996 1.789e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH2CN; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3-(trifluoromethyl)phenyl]ethanenitrile" "3-trifluoromethylbenzylcyanide" "3-(trifluoromethyl)benzyl cyanide" "benzeneacetonitrile, 3-(trifluoromethyl)-" "m-trifluoromethylbenzyl cyanide" "3-trifluoromethylphenylacetonitrile" "nc1r cxfff" "3-trifluoromethylbenzylnitrile" "2-[3-(trifluoromethyl)phenyl]acetonitrile" "m-(trifluoromethyl)phenylacetonitrile" "3-trifluormethylbenzylcyanide" "1-(3-(trifluoromethyl)phenyl)acetonitrile" );
standardThermochemistry
{
    dHf_298   -436230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-320730.0
}
