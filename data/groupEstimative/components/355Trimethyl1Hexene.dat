/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5,5-trimethyl-1-hexene  (C9H18, CAS 4316-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        355Trimethyl1Hexene;
formula     C9H18;
CAS         4316-65-8;
InChIKey    JTXUVHFRSRTSAT-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          579.87;      // K   [origin=predictive method=joback]
Pc          24.678;      // bar [origin=predictive method=joback]
omega       0.3032;      // -   [origin=predictive method=lee-kesler]
Tb          398.53;      // K   [origin=predictive method=joback]
HvapTb      33274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.439 0.97058 -0.0006637 1.847e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethylhex-1-ene" "1-hexene, 3,5,5-trimethyl-" "agn-pc-04t8ss" "1-hexene,3,5,5-trimethyl-" );
gibbsFormation
{
    dHf_298   -117690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113140.0
    phase     gas;
}
