/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-di(o-tolyl)ethylenediamine  (C16H20N2, CAS 94-92-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiOTolylEthylenediamine;
formula     C16H20N2;
CAS         94-92-8;
InChIKey    ZQMPWXFHAUDENN-UHFFFAOYSA-N;
MW          240.35;      // g/mol [origin=calculated method=formula-sum]
Tc          957.49;      // K   [origin=predictive method=joback]
Pc          22.762;      // bar [origin=predictive method=joback]
omega       0.8920;      // -   [origin=predictive method=lee-kesler]
Tb          729.34;      // K   [origin=predictive method=joback]
HvapTb      69958.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.288 1.39944 -0.00087212 2.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-bis(2-methylphenyl)ethane-1,2-diamine" "1,2-ethanediamine, n,n'-bis(2-methylphenyl)-" "1,2-ethanediamine, n1,n2-bis(2-methylphenyl)-" "(2-methylphenyl){2-[(2-methylphenyl)amino]ethyl}amine" "n,n'-ethylenedi-o-toluidine" "2-methyl-n-{2-[(2-methylphenyl)amino]ethyl}aniline" );
gibbsFormation
{
    dHf_298   183490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=468180.0
    phase     gas;
}
