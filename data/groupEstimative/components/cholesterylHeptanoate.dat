/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesteryl heptanoate  (C34H58O2, CAS 1182-07-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterylHeptanoate;
formula     C34H58O2;
CAS         1182-07-6;
InChIKey    KXWDMNPRHKRGKB-DYQRUOQXSA-N;
MW          498.836;      // g/mol [origin=calculated method=formula-sum]
Tc          1314.67;      // K   [origin=predictive method=joback]
Pc          6.911;      // bar [origin=predictive method=joback]
omega       0.6316;      // -   [origin=predictive method=lee-kesler]
Tb          1073.78;      // K   [origin=predictive method=joback]
HvapTb      96146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-292.632 4.13532 -0.00320564 1.0737e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 15; } { group CH; count 7; } { group C; count 2; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 8; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] heptanoate" "cholesterol heptanoate" "cholesteryl enanthate" "cholesteryl heptylate" "cholesterol enanthate" "enanthic acid cholesterol ester" "heptanoic acid cholesterol ester" "5-cholesten-3" "a-ol 3-heptanoate" "5-cholesten-3beta-ol 3-heptanoate" "cholest-5-ene-3-beta-yl heptanoate" "3" "a-hydroxy-5-cholestene 3-heptanoate" "3beta-hydroxy-5-cholestene 3-heptanoate" );
standardThermochemistry
{
    dHf_298   -796760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1219.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88870.0
}
