/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-diethoxyethyl)dimethylamine  (C8H19NO2, CAS 3616-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DiethoxyethylDimethylamine;
formula     C8H19NO2;
CAS         3616-56-6;
InChIKey    SSFAUOAQOOISRQ-UHFFFAOYSA-N;
MW          161.245;      // g/mol [origin=calculated method=formula-sum]
Tc          605.93;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       0.5798;      // -   [origin=predictive method=lee-kesler]
Tb          439.48;      // K   [origin=predictive method=joback]
HvapTb      39877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.243 0.76728 -0.0003052 1.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2O; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethoxy-n,n-dimethyl-ethanamine" "2,2-diethoxy-n,n-dimethylethanamine" "2,2-diethoxy-n,n-dimethylethylamine" "(dimethylamino)acetaldehyde diethyl acetal" "dimethylaminoacetaldehyde diethyl acetal" "dimethylamino acetaldehyde diethyl acetal" "ethanamine, 2,2-diethoxy-n,n-dimethyl-" "tpc-i026" "ssfauoaqooisrq-uhfffaoysa-" "n-(2,2-diethoxyethyl)dimethylamine" );
standardThermochemistry
{
    dHf_298   -410640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85180.0
}
