/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenylbicyclo[2.2.1]hept-2-ene  (C13H14, CAS 6143-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenylbicyclo221Hept2Ene;
formula     C13H14;
CAS         6143-30-2;
InChIKey    PGNNHYNYFLXKDZ-UHFFFAOYSA-N;
MW          170.255;      // g/mol [origin=calculated method=formula-sum]
Tc          775.24;      // K   [origin=predictive method=joback]
Pc          29.313;      // bar [origin=predictive method=joback]
omega       0.4001;      // -   [origin=predictive method=lee-kesler]
Tb          535.96;      // K   [origin=predictive method=joback]
HvapTb      46789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.72 1.3696 -0.00104048 3.137e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-norbornene-2-phenyl" "5-phenylbicyclo(2.2.1)-2-heptene" "5-phenyl-2-norbornene" "bicyclo[2.2.1]hept-2-ene, 5-phenyl-" );
gibbsFormation
{
    dHf_298   101760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=302640.0
    phase     gas;
}
