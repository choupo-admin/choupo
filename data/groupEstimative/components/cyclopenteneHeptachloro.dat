/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene, heptachloro-  (C5HCl7, CAS 62111-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopenteneHeptachloro;
formula     C5HCl7;
CAS         62111-47-1;
InChIKey    AJUXFTIOMRYFRL-UHFFFAOYSA-N;
MW          309.213;      // g/mol [origin=calculated method=formula-sum]
Tc          860.62;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.4182;      // -   [origin=predictive method=lee-kesler]
Tb          591.55;      // K   [origin=predictive method=joback]
HvapTb      56372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.63 1.0139 -0.001326 6.448e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl; count 1; } { group CCl2; count 2; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group C_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,3,4,4,5-heptakis(chloranyl)cyclopentene" "heptachlorocyclopentene" "1,2,3,3,4,4,5-heptachlorocyclopentene" );
gibbsFormation
{
    dHf_298   -171590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71440.0
    phase     gas;
}
