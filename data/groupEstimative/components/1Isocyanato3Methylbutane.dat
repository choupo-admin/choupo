/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isocyanato-3-methylbutane  (C6H11NO, CAS 1611-65-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isocyanato3Methylbutane;
formula     C6H11NO;
CAS         1611-65-0;
InChIKey    UQNAQAROTUILLB-UHFFFAOYSA-N;
MW          113.16;      // g/mol [origin=calculated method=formula-sum]
Tc          585.19;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.4451;      // -   [origin=predictive method=lee-kesler]
Tb          403.11;      // K   [origin=predictive method=joback]
HvapTb      38094.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-3-methyl-butane" "isocyanic acid, isopentyl ester" "butane,1-isocyanato-3-methyl-" "butane, 1-isocyanato-3-methyl-" "isocyanicacid, isopentyl ester (7ci,8ci); 3-methylbutyl isocyanate; isopentyl isocyanate" );
