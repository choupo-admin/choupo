/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzo(a)pyrenetetrol i 2  (C20H16O4, CAS 62697-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoAPyrenetetrolI2;
formula     C20H16O4;
CAS         62697-16-9;
InChIKey    KWFVZAJQUSRMCC-HAGHYFMRSA-N;
MW          320.344;      // g/mol [origin=calculated method=formula-sum]
Tc          1372.74;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       1.9611;      // -   [origin=predictive method=lee-kesler]
Tb          1118.76;      // K   [origin=predictive method=joback]
HvapTb      135196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.25 1.8488 -0.00147212 4.756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 8; } { group AC; count 6; } { group ACCH; count 2; } { group OH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 8; } { group OH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(7s,8r,9s,10s)-7,8,9,10-tetrahydrobenzo[a]pyrene-7,8,9,10-tetrol" "benzo(a)pyrene-7-beta,8-alpha,9-alpha,10-alpha-tetraol" "r-7,t-8,t-9,t-10-tetrahydroxy-7,8,9,10-tetrahydrobenzo(a)pyrene" "7-beta,8-alpha,9-beta,10-beta-tetrahydroxy-7,8,9,10-tetrahydrobenzo(a)pyrene" "benzo(a)pyrene, 7,8,9,10-tetrahydro-7-beta,8-alpha,9-alpha,10-alpha-tetrahydroxy-" "benzo(a)pyrene, 7-beta,8-alpha,9-alpha,10-alpha-tetrahydroxy-7,8,9,10-tetrahydro-" );
standardThermochemistry
{
    dHf_298   -341030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16160.0
}
