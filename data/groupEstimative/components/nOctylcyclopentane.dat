/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-octylcyclopentane  (C13H26, CAS 1795-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nOctylcyclopentane;
formula     C13H26;
CAS         1795-20-6;
InChIKey    HARXDULSBROLME-UHFFFAOYSA-N;
MW          182.351;      // g/mol [origin=calculated method=formula-sum]
Tc          695.89;      // K   [origin=predictive method=joback]
Pc          19.136;      // bar [origin=predictive method=joback]
omega       0.5405;      // -   [origin=predictive method=lee-kesler]
Tb          512.32;      // K   [origin=predictive method=joback]
HvapTb      44789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.413 1.37052 -0.0008108 1.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octylcyclopentane" "cyclopentane, octyl-" );
standardThermochemistry
{
    dHf_298   -251170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     611.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95130.0
}
