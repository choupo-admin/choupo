/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butenoic acid  (C4H6O2, CAS 625-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ButenoicAcid;
formula     C4H6O2;
CAS         625-38-7;
InChIKey    PVEOYINWKBTPIZ-UHFFFAOYSA-N;
MW          86.09;      // g/mol [origin=calculated method=formula-sum]
Tc          630.74;      // K   [origin=predictive method=joback]
Pc          46.214;      // bar [origin=predictive method=joback]
omega       0.5544;      // -   [origin=predictive method=lee-kesler]
Tb          433.31;      // K   [origin=predictive method=joback]
HvapTb      40992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.861 0.4146 -0.0002893 8.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-3-enoic acid" "vinylacetic acid" "vinyl acetic acid" ".beta.-butenoic acid" "beta-butenoic acid" "acetic acid, ethenyl-" "allylic acid" "vinylessigsaeure" "ethenylacetic acid" "3-buten-1-oic acid" "2-propenylcarboxylic acid" "c4:1n-1" );
standardThermochemistry
{
    dHf_298   -350730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273270.0
}
