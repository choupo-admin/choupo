/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromoquinolin-8-ol  (C9H6BrNO, CAS 1198-14-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromoquinolin8Ol;
formula     C9H6BrNO;
CAS         1198-14-7;
InChIKey    WIIUANWSGSTCLG-UHFFFAOYSA-N;
MW          224.057;      // g/mol [origin=calculated method=formula-sum]
Tc          935.09;      // K   [origin=predictive method=joback]
Pc          58.990;      // bar [origin=predictive method=joback]
omega       0.7854;      // -   [origin=predictive method=lee-kesler]
Tb          656.64;      // K   [origin=predictive method=joback]
HvapTb      65865.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.01 0.94326 -0.0009037 3.466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 1; } { group C5H3N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 5; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanylquinolin-8-ol" "5-bromo-8-hydroxyquinoline" "8-quinolinol, 5-bromo-" "5-bromo-8-quinolinol" "5-bromo-8-oxyquinoline" "5-bromo-8-hydroxy quinoline" "r344" );
standardThermochemistry
{
    dHf_298   68850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171080.0
}
