/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4',4''(5'')-di-tert-butyldicyclohexano-18-crown-6  (C28H52O6, CAS 223719-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        445DiTertButyldicyclohexano18Crown6;
formula     C28H52O6;
CAS         223719-29-7;
InChIKey    SHJRQDXUSZYABF-UHFFFAOYSA-N;
MW          484.718;      // g/mol [origin=calculated method=formula-sum]
Tc          1335.92;      // K   [origin=predictive method=joback]
Pc          9.729;      // bar [origin=predictive method=joback]
omega       0.7774;      // -   [origin=predictive method=lee-kesler]
Tb          1074.28;      // K   [origin=predictive method=joback]
HvapTb      104126.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-187.55 3.10752 -0.0014652 1.186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 8; } { group CH; count 6; } { group C; count 2; } { group FCH2O; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group CH2_ring; count 14; } { group CH_ring; count 6; } { group O_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( ""4',4""(5"")-di-tert-butyldicyclohexano-18-crown-6"" "4 inverted exclamation marka,4 inverted exclamation marka(5 inverted exclamation marka)-di-tert-butyldicyclohexano-18-crown-6" );
standardThermochemistry
{
    dHf_298   -1378090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-372740.0
}
