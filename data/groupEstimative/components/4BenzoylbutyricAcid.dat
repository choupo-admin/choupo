/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-benzoylbutyric acid  (C11H12O3, CAS 1501-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BenzoylbutyricAcid;
formula     C11H12O3;
CAS         1501-05-9;
InChIKey    SHKWSBAVRQZYLE-UHFFFAOYSA-N;
MW          192.214;      // g/mol [origin=calculated method=formula-sum]
Tc          900.01;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.9796;      // -   [origin=predictive method=lee-kesler]
Tb          677.34;      // K   [origin=predictive method=joback]
HvapTb      66266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.057 0.9927 -0.0006597 1.6416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-oxidanylidene-5-phenyl-pentanoic acid" "5-oxo-5-phenylpentanoic acid" "5-oxo-5-phenylvaleric acid" "benzenepentanoic acid, .delta.-oxo-" "4-benzoyl-butyric acid" "5-keto-5-phenyl-valeric acid" "shkwsbavrqzyle-uhfffaoysa-" "benzenepentanoic acid, delta-oxo- (9ci)" "brd-k86245308-001-01-0" );
gibbsFormation
{
    dHf_298   -496690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-318680.0
    phase     gas;
}
