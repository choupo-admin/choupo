/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, 1,2-dimethoxy-, cis-  (C8H16O2, CAS 29887-60-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane12DimethoxyCis;
formula     C8H16O2;
CAS         29887-60-3;
InChIKey    BSGBGTJQKZSUTQ-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          641.23;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.3895;      // -   [origin=predictive method=lee-kesler]
Tb          442.36;      // K   [origin=predictive method=joback]
HvapTb      38342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.05 0.73304 -0.000215 -4.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethoxycyclohexane" "cyclohexane, 1,2-dimethoxy-, trans-" "cis-1,2-dimethoxycyclohexane" "trans-1,2-dimethoxycyclohexane" "agn-pc-00k7to" "cyclohexane, 1,2-dimethoxy-" );
gibbsFormation
{
    dHf_298   -438910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-176780.0
    phase     gas;
}
