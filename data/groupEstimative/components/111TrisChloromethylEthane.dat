/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-tris(chloromethyl)ethane  (C5H9Cl3, CAS 1067-09-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111TrisChloromethylEthane;
formula     C5H9Cl3;
CAS         1067-09-0;
InChIKey    BYXOMFFBGDPXHB-UHFFFAOYSA-N;
MW          175.477;      // g/mol [origin=calculated method=formula-sum]
Tc          624.62;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.3330;      // -   [origin=predictive method=lee-kesler]
Tb          423.06;      // K   [origin=predictive method=joback]
HvapTb      38583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.543 0.62502 -0.0004812 1.472e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group CH2Cl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-2-(chloromethyl)-2-methyl-propane" "1,3-dichloro-2-(chloromethyl)-2-methylpropane" "2-chloromethyl-1,3-dichloro-2-methylpropane" "2-(chloromethyl)-1,3-dichloro-2-methylpropane" "1,1,1-trichloropentane" "pentane, 1,1,1-trichloro-" "propane,1,3-dichloro-2-(chloromethyl)-2-methyl-" );
standardThermochemistry
{
    dHf_298   -202500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41730.0
}
