/*--------------------------------*- Choupo -*-----------------------*\
  Component: mono-methyl sebacate  (C11H20O4, CAS 818-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monoMethylSebacate;
formula     C11H20O4;
CAS         818-88-2;
InChIKey    OSYQOBUUFRGFNG-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          839.00;      // K   [origin=predictive method=joback]
Pc          21.042;      // bar [origin=predictive method=joback]
omega       1.0714;      // -   [origin=predictive method=lee-kesler]
Tb          655.01;      // K   [origin=predictive method=joback]
HvapTb      64651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.898 1.04482 -0.0005526 9.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-methoxy-10-oxidanylidene-decanoic acid" "sebacic acid monomethyl ester" "10-methoxy-10-oxodecanoic acid" "methyl hydrogen sebacate" "monomethyl sebacate" "decanoic acid, monomethyl ester" "9-(methoxycarbonyl)nonanoic acid" "decanedioic acid monomethyl ester" );
standardThermochemistry
{
    dHf_298   -937920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-612540.0
}
