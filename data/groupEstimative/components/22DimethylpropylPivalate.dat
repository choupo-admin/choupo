/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylpropyl pivalate  (C10H20O2, CAS 5340-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DimethylpropylPivalate;
formula     C10H20O2;
CAS         5340-26-1;
InChIKey    KEVRVUAKQLMNFS-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          670.61;      // K   [origin=predictive method=joback]
Pc          21.938;      // bar [origin=predictive method=joback]
omega       0.4483;      // -   [origin=predictive method=lee-kesler]
Tb          480.16;      // K   [origin=predictive method=joback]
HvapTb      42669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.739 1.15072 -0.0007692 1.945e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropyl 2,2-dimethylpropanoate" "neopentyl pivalate" "2, 2,2-dimethylpropyl ester" "2,2-dimethylpropyl 2,2-dimethylpropionate" "2,2-dimethyl-propionic acid 2,2-dimethyl-propyl ester" "propanoic acid,2,2-dimethyl-, 2,2-dimethylpropyl ester" );
standardThermochemistry
{
    dHf_298   -584510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271370.0
}
