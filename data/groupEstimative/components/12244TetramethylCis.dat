/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1, 2,2,4,4-tetramethyl-, cis-  (C8H16O2, CAS 3010-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12244TetramethylCis;
formula     C8H16O2;
CAS         3010-96-6;
InChIKey    FQXGHZNSUOHCLO-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          745.94;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       1.1239;      // -   [origin=predictive method=lee-kesler]
Tb          564.48;      // K   [origin=predictive method=joback]
HvapTb      63616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.33 1.47748 -0.001545 6.844e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH_ring; count 2; } { group C_ring; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4-tetramethylcyclobutane-1,3-diol" "2,2,4,4-tetramethyl-1,3-cyclobutanediol" "1,3-cyclobutanediol, 2,2,4,4-tetramethyl-" "1,1,3,3-tetramethylcyclobutanediol" "tetramethyl-1,3-cyclobutanediol" "2,2,4,4-tetramethylcyclobutane-1,3-diol, cis" "2,2,4,4-tetramethylcyclobutane-1,3-diol, mixed isomers" "2,2,4,4-tetramethyl-1,3-cyclobutanediol, mixture of isomers" "fqxghznsuohclo-uhfffaoysa-" "1,3,3-tetramethylcyclobutanediol" "2,4,4-tetramethyl-1,3-cyclobutanediol" "1,1,3,3-tetramethyl-2,4-cyclobutanediol" );
gibbsFormation
{
    dHf_298   -476810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242620.0
    phase     gas;
}
