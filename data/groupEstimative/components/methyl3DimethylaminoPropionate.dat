/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-(dimethylamino)propionate  (C6H13NO2, CAS 3853-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3DimethylaminoPropionate;
formula     C6H13NO2;
CAS         3853-06-3;
InChIKey    VSFJOMFYABROHQ-UHFFFAOYSA-N;
MW          131.175;      // g/mol [origin=calculated method=formula-sum]
Tc          579.74;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.5106;      // -   [origin=predictive method=lee-kesler]
Tb          407.54;      // K   [origin=predictive method=joback]
HvapTb      38400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.152 0.64296 -0.0003206 4.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(dimethylamino)propanoate" "methyl beta-(dimethylamino)propionate" "n,n-dimethyl-beta-alanine methyl ester" "beta-alanine, n,n-dimethyl-, methyl ester" "methyl 3-dimethylaminopropionate" "methyl 3-dimethylaminopropanoate" "vsfjomfyabrohq-uhfffaoysa-" "b-alanine, n,n-dimethyl-, methylester" "methyl n,n-dimethyl-.beta.-aminopropionate" );
gibbsFormation
{
    dHf_298   -416920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199950.0
    phase     gas;
}
