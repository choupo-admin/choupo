/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-bromo-1-pentene  (C5H9Br, CAS 1119-51-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Bromo1Pentene;
formula     C5H9Br;
CAS         1119-51-3;
InChIKey    LPNANKDXVBMDKE-UHFFFAOYSA-N;
MW          149.031;      // g/mol [origin=calculated method=formula-sum]
Tc          565.80;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.3516;      // -   [origin=predictive method=lee-kesler]
Tb          376.84;      // K   [origin=predictive method=joback]
HvapTb      32489.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.543 0.497 -0.0003425 9.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanylpent-1-ene" "1-bromo-4-pentene" "5-bromopent-1-ene" "1-pentene, 5-bromo-" "5-bromopentene-1" "4-pentenyl bromide" "5-bromo-1-amylene" "5-bromo-pent-1-ene" "bromo(5-)-1-pentene" "(pent-4-en-1yl) bromide" "1-bromo-4-pentene; 4-pentenyl bromide; 5-bromo-1-pentene" "1-bromo-4-pentene;4-pentenyl bromide;1-pentene, 5-bromo-;" );
gibbsFormation
{
    dHf_298   5230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=93380.0
    phase     gas;
}
