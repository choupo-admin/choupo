/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-hydroxy-gamma-butyrolactone  (C4H6O3, CAS 19444-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaHydroxyGammaButyrolactone;
formula     C4H6O3;
CAS         19444-84-9;
InChIKey    FWIBCWKHNZBDLS-UHFFFAOYSA-N;
MW          102.089;      // g/mol [origin=calculated method=formula-sum]
Tc          632.10;      // K   [origin=predictive method=joback]
Pc          52.893;      // bar [origin=predictive method=joback]
omega       0.8012;      // -   [origin=predictive method=lee-kesler]
Tb          448.26;      // K   [origin=predictive method=joback]
HvapTb      48497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.29 0.5139 -0.0003498 8.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanyloxolan-2-one" "2-hydroxy-gamma-butyrolactone" "2(3h)-furanone, dihydrohydroxy-" "3-hydroxydihydro-2(3h)-furanone" "4,5-dihydro-3-hydroxy-2(3h)-furanone" "(3s)-3-hydroxydihydrofuran-2(3h)-one" "(r)-dihydro-3-hydroxyfuran-2(3h)-one" "3-hydroxyoxolan-2-one" "agn-pc-0cqeoa" "a-hydroxy-" "a-butyrolactone" "3-hydroxytetrahydrofuran-2-one" "(s)-?-hydroxy-?-butyrolactone" );
gibbsFormation
{
    dHf_298   -522600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     323.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403640.0
    phase     gas;
}
