/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-chlorophenoxy)butanoic acid  (C10H11ClO3, CAS 3547-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44ChlorophenoxyButanoicAcid;
formula     C10H11ClO3;
CAS         3547-07-7;
InChIKey    SIYAHZSHQIPQLY-UHFFFAOYSA-N;
MW          214.645;      // g/mol [origin=calculated method=formula-sum]
Tc          886.94;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.9293;      // -   [origin=predictive method=lee-kesler]
Tb          665.42;      // K   [origin=predictive method=joback]
HvapTb      64751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.183 0.8098 -0.00046636 9.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-chloranylphenoxy)butanoic acid" "4-(p-chlorophenoxy)butyric acid" "4-(4-chloro-phenoxy)-butyric acid" ".gamma.-(4-chlorophenoxy)butyric acid" "4-cpb" "4-(4-chlorophenoxy)butyric acid" "butanoic acid, 4-(4-chlorophenoxy)-" "4-(4-cpb)" "butyric acid, 4-(p-chlorophenoxy)-" "4-(4-chlorophenoxy) butyric acid" "4-(4-chlorophenoxy)butyric acid;4-(4-chlorophenoxy)butanoic acid;4-(p-chlorophenoxy)butyric acid;4-cpb;" );
standardThermochemistry
{
    dHf_298   -522900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-324740.0
}
