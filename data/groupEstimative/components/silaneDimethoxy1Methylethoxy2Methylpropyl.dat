/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, dimethoxy(1-methylethoxy)(2-methylpropyl)-  (C9H22O3Si, CAS 118337-12-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H22O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneDimethoxy1Methylethoxy2Methylpropyl;
formula     C9H22O3Si;
CAS         118337-12-5;
InChIKey    DJLMUFUQIWJXSO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          206.357;      // g/mol [origin=calculated method=formula-sum]
Tc          648.97;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       0.5061;      // -   [origin=predictive method=lee-kesler]
Tb          473.30;      // K   [origin=predictive method=joback]
HvapTb      42376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (108.661 0.47492 0.0002756 -2.867e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 2; } { group CH-O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethoxy-(2-methylpropyl)-propan-2-yloxy-silane" "dimethoxy(2-methylpropyl)(propan-2-yloxy)silane" "dimethoxy-(2-methylpropyl)-propan-2-yloxysilane" );
standardThermochemistry
{
    dHf_298   -747930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-399740.0
}
