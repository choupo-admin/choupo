/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-oxooctanoic acid  (C8H14O3, CAS 14112-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7OxooctanoicAcid;
formula     C8H14O3;
CAS         14112-98-2;
InChIKey    OSAHCBHKCKPJGI-UHFFFAOYSA-N;
MW          158.197;      // g/mol [origin=calculated method=formula-sum]
Tc          775.14;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.9318;      // -   [origin=predictive method=lee-kesler]
Tb          582.02;      // K   [origin=predictive method=joback]
HvapTb      57312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.575 0.78662 -0.0004653 1.0296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-oxidanylideneoctanoic acid" "octanoic acid, 7-oxo-" "7-ketooctanoic acid" "7-oxo-octanoic acid" "7-keto-n-caprylic acid" );
gibbsFormation
{
    dHf_298   -671300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-456350.0
    phase     gas;
}
