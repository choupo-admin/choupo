/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethyl-6-propylcyclohex-3-ene-1-carbaldehyde  (C12H20O, CAS 68140-54-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethyl6Propylcyclohex3Ene1Carbaldehyde;
formula     C12H20O;
CAS         68140-54-5;
InChIKey    APHMNJONLCSFTD-UHFFFAOYSA-N;
MW          180.291;      // g/mol [origin=calculated method=formula-sum]
Tc          736.31;      // K   [origin=predictive method=joback]
Pc          21.918;      // bar [origin=predictive method=joback]
omega       0.5557;      // -   [origin=predictive method=lee-kesler]
Tb          537.17;      // K   [origin=predictive method=joback]
HvapTb      49791.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.268 1.07196 -0.00051244 6.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethyl-6-propyl-cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 3,5-dimethyl-6-propyl-" );
standardThermochemistry
{
    dHf_298   -316640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20000.0
}
