/*--------------------------------*- Choupo -*-----------------------*\
  Component: cremophor a  (C20H40O3, CAS 9004-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cremophorA;
formula     C20H40O3;
CAS         9004-99-3;
InChIKey    RFVNOJDQRGSOEL-UHFFFAOYSA-N;
MW          328.537;      // g/mol [origin=calculated method=formula-sum]
Tc          988.77;      // K   [origin=predictive method=joback]
Pc          10.814;      // bar [origin=predictive method=joback]
omega       1.0390;      // -   [origin=predictive method=lee-kesler]
Tb          807.60;      // K   [origin=predictive method=joback]
HvapTb      84200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.408 1.88302 -0.001 1.795e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hydroxyethyl octadecanoate" "polyethylene glycol monostearate" "cerasynt m" "clearate g" "cerasynt mn" "cithrol ps" "cithrol 10ms" "lactine" "polystate" "glycol stearate" "myrj" "polyoxyl 40 stearate" );
standardThermochemistry
{
    dHf_298   -925640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1037.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-329670.0
}
