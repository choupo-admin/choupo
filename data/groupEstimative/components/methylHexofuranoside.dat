/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl hexofuranoside  (C7H14O6, CAS 56654-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylHexofuranoside;
formula     C7H14O6;
CAS         56654-39-8;
InChIKey    ZSQBOIUCEISYSW-UHFFFAOYSA-N;
MW          194.183;      // g/mol [origin=calculated method=formula-sum]
Tc          957.73;      // K   [origin=predictive method=joback]
Pc          46.977;      // bar [origin=predictive method=joback]
omega       2.2866;      // -   [origin=predictive method=lee-kesler]
Tb          778.68;      // K   [origin=predictive method=joback]
HvapTb      103754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.161 0.79672 -0.0003181 2.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group OH; count 4; } { group CH3O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH_ring; count 4; } { group OH; count 4; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1,2-bis(oxidanyl)ethyl]-5-methoxy-oxolane-3,4-diol" "alpha-methylglucofuranoside" "agn-pc-00dzwt" ".alpha.-methylglucofuranoside" ".alpha.-methyl mannofuranoside" ".beta.-d-mannofuranoside, methyl" ".alpha.-d-mannofuranoside, methyl" "2-(1,2-dihydroxyethyl)-5-methoxyoxolane-3,4-diol" "(2s,3r,4r,5r)-2-(1,2-dihydroxyethyl)-5-methoxyoxolane-3,4-diol" );
standardThermochemistry
{
    dHf_298   -1066770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-719360.0
}
