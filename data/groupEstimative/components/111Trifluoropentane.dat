/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trifluoropentane  (C5H9F3, CAS 406-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trifluoropentane;
formula     C5H9F3;
CAS         406-82-6;
InChIKey    GENRYAJRHIWOJI-UHFFFAOYSA-N;
MW          126.121;      // g/mol [origin=calculated method=formula-sum]
Tc          454.70;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       0.3312;      // -   [origin=predictive method=lee-kesler]
Tb          308.58;      // K   [origin=predictive method=joback]
HvapTb      22977.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.857 0.64002 -0.0004692 1.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(fluoranyl)pentane" "1,1-trifluoropentane" "pentane,1,1-trifluoro-" "pentane,1,1,1-trifluoro-" );
gibbsFormation
{
    dHf_298   -743610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-590370.0
    phase     gas;
}
