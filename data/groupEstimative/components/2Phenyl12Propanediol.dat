/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-1,2-propanediol  (C9H12O2, CAS 4217-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl12Propanediol;
formula     C9H12O2;
CAS         4217-66-7;
InChIKey    LNCZPZFNQQFXPT-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          807.50;      // K   [origin=predictive method=joback]
Pc          41.731;      // bar [origin=predictive method=joback]
omega       1.2434;      // -   [origin=predictive method=lee-kesler]
Tb          613.33;      // K   [origin=predictive method=joback]
HvapTb      69966.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.089 0.97372 -0.0007296 2.129e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylpropane-1,2-diol" "1,2-propanediol, 2-phenyl-" "dl-2-phenyl-1,2-propanediol" "2-phenyl-propane-1,2-diol" "1,2-propanediol,2-phenyl-" "dl-2-phenylpropane-1,2-diol" );
gibbsFormation
{
    dHf_298   -305770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133490.0
    phase     gas;
}
