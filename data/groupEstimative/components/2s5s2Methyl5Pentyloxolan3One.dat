/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,5s)-2-methyl-5-pentyloxolan-3-one  (C10H18O2, CAS 71820-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s5s2Methyl5Pentyloxolan3One;
formula     C10H18O2;
CAS         71820-40-1;
InChIKey    XLPAUDSMYFHMHV-IUCAKERBSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          738.17;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       0.5658;      // -   [origin=predictive method=lee-kesler]
Tb          533.78;      // K   [origin=predictive method=joback]
HvapTb      46559.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.996 0.88774 -0.0003343 -2.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2CO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,5s)-2-methyl-5-pentyl-oxolan-3-one" "2-methyl-5-pentyl-4,5-dihydro-3(2h)-furanone" );
standardThermochemistry
{
    dHf_298   -479290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146550.0
}
