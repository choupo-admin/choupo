/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,6-difluorobenzoate  (C8H6F2O2, CAS 13671-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl26Difluorobenzoate;
formula     C8H6F2O2;
CAS         13671-00-6;
InChIKey    QNPFLTKQLFSKBY-UHFFFAOYSA-N;
MW          172.13;      // g/mol [origin=calculated method=formula-sum]
Tc          672.84;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.5567;      // -   [origin=predictive method=lee-kesler]
Tb          476.04;      // K   [origin=predictive method=joback]
HvapTb      42775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.9 0.53472 -0.00024672 1.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACF; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,6-bis(fluoranyl)benzoate" "2,6-difluorobenzoic acid, methyl ester" "methyl 2,6-difluorobenzoate," "2-(methoxycarbonyl)-1,3-difluorobenzene" "2,6-difluorobenzoicacid methyl ester; methyl 2,6-difluorobenzoate" );
standardThermochemistry
{
    dHf_298   -704360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-590360.0
}
