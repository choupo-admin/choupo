/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluorobenzene  (C6HF5, CAS 363-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentafluorobenzene;
formula     C6HF5;
CAS         363-72-4;
InChIKey    WACNXHCZHTVBJM-UHFFFAOYSA-N;
MW          168.064;      // g/mol [origin=calculated method=formula-sum]
Tc          545.58;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.4807;      // -   [origin=predictive method=lee-kesler]
Tb          379.83;      // K   [origin=predictive method=joback]
HvapTb      29789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.18 0.3159 -0.00014764 1.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(fluoranyl)benzene" "1,2,3,4,5-pentafluorobenzene" "benzene, pentafluoro-" "2,3,4,5,6-pentafluorobenzene" "1,2,3,4,5-pentafluoro-benzene" "benzene, 1,2,3,4,5-pentafluoro-" "benzenepentafluoride" "1,3,4,5-pentafluorobenzene" "wacnxhczhtvbjm-uhfffaoysa-" "benzene, pentafluoro-;1,2,3,4,5-pentafluorobenzene;" "f5b" );
gibbsFormation
{
    dHf_298   -957070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-900520.0
    phase     gas;
}
