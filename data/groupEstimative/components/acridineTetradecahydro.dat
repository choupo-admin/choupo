/*--------------------------------*- Choupo -*-----------------------*\
  Component: acridine, tetradecahydro-  (C13H23N, CAS 16726-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acridineTetradecahydro;
formula     C13H23N;
CAS         16726-19-5;
InChIKey    IXTPCSZJZAKJTO-UHFFFAOYSA-N;
MW          193.334;      // g/mol [origin=calculated method=formula-sum]
Tc          823.37;      // K   [origin=predictive method=joback]
Pc          26.057;      // bar [origin=predictive method=joback]
omega       0.4642;      // -   [origin=predictive method=lee-kesler]
Tb          582.49;      // K   [origin=predictive method=joback]
HvapTb      51580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-162.4 1.6036 -0.000996 2.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 3; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group CH_ring; count 4; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,4a,5,6,7,8,8a,9,9a,10,10a-tetradecahydroacridine" "agn-pc-00pno4" "4a alpha,8a beta,9a beta,10a alpha-tetradecahydroacridine" "4aalpha,8abeta,9aalpha,10aalpha-tetradecahydroacridine" "4aalpha,8abeta,9abeta,10aalpha-tetradecahydroacridine" "4a alpha,8a beta,9a alpha,10a alpha-tetradecahydroacridine" );
gibbsFormation
{
    dHf_298   -106580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=260330.0
    phase     gas;
}
