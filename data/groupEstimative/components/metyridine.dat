/*--------------------------------*- Choupo -*-----------------------*\
  Component: metyridine  (C8H11NO, CAS 114-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        metyridine;
formula     C8H11NO;
CAS         114-91-0;
InChIKey    QRBVCAWHUSTDOT-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          705.07;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       0.4623;      // -   [origin=predictive method=lee-kesler]
Tb          485.44;      // K   [origin=predictive method=joback]
HvapTb      44298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.728 0.65548 -0.00034086 5.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methoxyethyl)pyridine" "methyridine" "mintic" "pyridine, 2-(2-methoxyethyl)-" "emthyridine" "methydrine" "prominthic" "farmintic" "metiridin" "minthic" "2-pyridyl-2-methoxyethane" "2-(2-pyridyl)ethyl methyl ether" );
gibbsFormation
{
    dHf_298   -71350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100940.0
    phase     gas;
}
