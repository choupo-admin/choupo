/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(hydroxymethylene)cyclohexanone  (C7H10O2, CAS 823-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxymethyleneCyclohexanone;
formula     C7H10O2;
CAS         823-45-0;
InChIKey    ORTWDKQPXZLPCA-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          765.85;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.8158;      // -   [origin=predictive method=lee-kesler]
Tb          550.62;      // K   [origin=predictive method=joback]
HvapTb      53627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.2 0.6056 -0.0002483 7.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(oxidanylmethylidene)cyclohexan-1-one" "cyclohexanone, 2-(hydroxymethylene)-" "cyclohexanone,2-(hydroxymethylene)-" "(2e)-2-(hydroxymethylene)cyclohexanone" "2-(hydroxymethylene)cyclohexanone;a-(hydroxymethylene)cyclohexanone;" );
gibbsFormation
{
    dHf_298   -327050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-173730.0
    phase     gas;
}
