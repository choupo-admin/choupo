/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetonitrile, (methylimino)di-  (C5H7N3, CAS 5423-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetonitrileMethyliminoDi;
formula     C5H7N3;
CAS         5423-24-5;
InChIKey    ODHFXNCHFIWUCX-UHFFFAOYSA-N;
MW          109.132;      // g/mol [origin=calculated method=formula-sum]
Tc          739.10;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.6543;      // -   [origin=predictive method=lee-kesler]
Tb          530.60;      // K   [origin=predictive method=joback]
HvapTb      49723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.652 0.47232 -0.0002988 7.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3N; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group N; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[cyanomethyl(methyl)amino]ethanenitrile" "2,2'-(methylimino)diacetonitrile" "2-[cyanomethyl(methyl)amino]acetonitrile" );
gibbsFormation
{
    dHf_298   250760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368360.0
    phase     gas;
}
