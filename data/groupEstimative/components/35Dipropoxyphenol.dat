/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dipropoxyphenol  (C12H18O3, CAS 28334-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dipropoxyphenol;
formula     C12H18O3;
CAS         28334-99-8;
InChIKey    SHZCHGMKOUMNAW-UHFFFAOYSA-N;
MW          210.273;      // g/mol [origin=calculated method=formula-sum]
Tc          838.92;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.8842;      // -   [origin=predictive method=lee-kesler]
Tb          631.28;      // K   [origin=predictive method=joback]
HvapTb      63078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.454 1.03364 -0.00062752 1.557e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 3,5-dipropoxy-" );
standardThermochemistry
{
    dHf_298   -507700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-211680.0
}
