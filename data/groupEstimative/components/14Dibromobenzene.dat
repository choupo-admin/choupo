/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromobenzene  (C6H4Br2, CAS 106-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromobenzene;
formula     C6H4Br2;
CAS         106-37-6;
InChIKey    SWJPEBQEEAHIGZ-UHFFFAOYSA-N;
MW          235.906;      // g/mol [origin=calculated method=formula-sum]
Tc          757.53;      // K   [origin=predictive method=joback]
Pc          55.692;      // bar [origin=predictive method=joback]
omega       0.4400;      // -   [origin=predictive method=lee-kesler]
Tb          500.86;      // K   [origin=predictive method=joback]
HvapTb      44758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.79 0.5118 -0.00040956 1.29e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)benzene" "p-dibromobenzene" "benzene, 1,4-dibromo-" "benzene, p-dibromo-" "p-bromophenyl bromide" "p-benzene dibromide" "1,4-dibromo benzene" "1,4-dibromo-benzene" "p-dibromo benzene" "benzene,4-dibromo-" "dibromobenzene, 1,4-" );
gibbsFormation
{
    dHf_298   110550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131060.0
    phase     gas;
}
