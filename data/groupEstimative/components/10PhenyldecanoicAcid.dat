/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-phenyldecanoic acid  (C16H24O2, CAS 18017-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10PhenyldecanoicAcid;
formula     C16H24O2;
CAS         18017-73-7;
InChIKey    IISIYJPTBDSIFM-UHFFFAOYSA-N;
MW          248.366;      // g/mol [origin=calculated method=formula-sum]
Tc          939.82;      // K   [origin=predictive method=joback]
Pc          18.357;      // bar [origin=predictive method=joback]
omega       1.0310;      // -   [origin=predictive method=lee-kesler]
Tb          737.87;      // K   [origin=predictive method=joback]
HvapTb      70650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.961 1.4957 -0.0009504 2.327e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenedecanoic acid" "omega-phenyl decyclic acid" );
standardThermochemistry
{
    dHf_298   -487310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     725.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147660.0
}
