/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromocyclohexene  (C6H9Br, CAS 1521-51-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromocyclohexene;
formula     C6H9Br;
CAS         1521-51-3;
InChIKey    AJKDUJRRWLQXHM-UHFFFAOYSA-N;
MW          161.042;      // g/mol [origin=calculated method=formula-sum]
Tc          650.63;      // K   [origin=predictive method=joback]
Pc          45.408;      // bar [origin=predictive method=joback]
omega       0.2912;      // -   [origin=predictive method=lee-kesler]
Tb          421.75;      // K   [origin=predictive method=joback]
HvapTb      36106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.2 0.6781 -0.00044228 1.081e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylcyclohexene" "3-bromocyclohex-1-ene" "cyclohexene, 3-bromo-" "1-bromo-2-cyclohexene" "1,2,3,4-tetrahydrobromobenzene" "3-bromo-cyclohexene" "2-cyclohexen-1-yl bromide" "r943" "1-bromo-2-cyclohexene;2-cyclohexenyl bromide;3-bromocyclohexene;3-bromocyclohex-1-ene;" );
gibbsFormation
{
    dHf_298   -28740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68370.0
    phase     gas;
}
