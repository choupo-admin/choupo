/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1,3-cyclopentanedione  (C6H8O2, CAS 765-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl13Cyclopentanedione;
formula     C6H8O2;
CAS         765-69-5;
InChIKey    HXZILEQYFQYQCE-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          724.96;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.4158;      // -   [origin=predictive method=lee-kesler]
Tb          487.80;      // K   [origin=predictive method=joback]
HvapTb      37701.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.81 0.36892 5.8e-05 -1.263e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylcyclopentane-1,3-dione" "2-methyl-1,3-cyclopentadione" "1,3-cyclopentanedione, 2-methyl-" "benzil-related compound, 46" "ghl.pd_mitscher_leg0.841" "2-methyl-1,3-dioxocyclopentane" "2-methyl-cyclopentane-1,3-dione" "h067" );
gibbsFormation
{
    dHf_298   -382090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     181.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-208990.0
    phase     gas;
}
