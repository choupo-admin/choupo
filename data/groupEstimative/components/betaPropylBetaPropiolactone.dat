/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-propyl-beta-propiolactone  (C6H10O2, CAS 15964-17-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaPropylBetaPropiolactone;
formula     C6H10O2;
CAS         15964-17-7;
InChIKey    RDILZTZKTCONPZ-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          578.71;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.4453;      // -   [origin=predictive method=lee-kesler]
Tb          397.57;      // K   [origin=predictive method=joback]
HvapTb      36098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.278 0.67952 -0.0004746 1.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propyloxetan-2-one" );
standardThermochemistry
{
    dHf_298   -405490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237880.0
}
