/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxydecane  (C12H26O, CAS 16979-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxydecane;
formula     C12H26O;
CAS         16979-29-6;
InChIKey    LOLANUHFGPZTLQ-UHFFFAOYSA-N;
MW          186.339;      // g/mol [origin=calculated method=formula-sum]
Tc          657.67;      // K   [origin=predictive method=joback]
Pc          17.551;      // bar [origin=predictive method=joback]
omega       0.6620;      // -   [origin=predictive method=lee-kesler]
Tb          496.58;      // K   [origin=predictive method=joback]
HvapTb      44716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.48 1.08064 -0.000518 7.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "alcohols, c10-12, ethoxylated propoxylated" "decyl ethyl ether" "ethyl decyl ether" "alcohols, c1o-12, ethoxylated propoxylated" "(c10-c12) alkyl alcohol, ethoxylate, propoxylate" );
gibbsFormation
{
    dHf_298   -423230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54840.0
    phase     gas;
}
