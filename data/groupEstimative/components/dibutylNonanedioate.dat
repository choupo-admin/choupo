/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutyl nonanedioate  (C17H32O4, CAS 2917-73-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylNonanedioate;
formula     C17H32O4;
CAS         2917-73-9;
InChIKey    RISLXYINQFKFRL-UHFFFAOYSA-N;
MW          300.439;      // g/mol [origin=calculated method=formula-sum]
Tc          876.68;      // K   [origin=predictive method=joback]
Pc          12.398;      // bar [origin=predictive method=joback]
omega       0.9794;      // -   [origin=predictive method=lee-kesler]
Tb          705.00;      // K   [origin=predictive method=joback]
HvapTb      68250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.253 1.50924 -0.0007118 7.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "azelaic acid, dibutyl ester" "dibutyl azelate" "nonanedioic acid, dibutyl ester" "1,9-di-n-butyl nonanedioate" "nonanedioic acid, 1,9-dibutyl ester" "dibutyl azelaate" "ergoplast azdb" "nonanedioic acid,1,9-dibutyl ester" "azelaic acid, dibutyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -1028770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     920.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-528480.0
    phase     gas;
}
