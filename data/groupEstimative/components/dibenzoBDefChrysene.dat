/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzo[b,def]chrysene  (C24H14, CAS 189-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzoBDefChrysene;
formula     C24H14;
CAS         189-64-0;
InChIKey    RXUSYFJGDZFVND-UHFFFAOYSA-N;
MW          302.376;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.64;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       0.9353;      // -   [origin=predictive method=lee-kesler]
Tb          882.52;      // K   [origin=predictive method=joback]
HvapTb      81506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.39 2.0236 -0.00183396 6.614e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 10; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 14; } { group dC_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo[a,h]pyrene" "dibenzo(a,h)pyrene" "3,4:8,9-dibenzopyrene" "dibenzo(b,def)chrysene" "db(a,h)p" "3,4,8,9-dibenzpyrene" "1,2,6,7-dibenzopyrene" "3,4,8,9-dibenzopyrene" "dibenzo(a,h)pyrene [polycyclic aromatic compounds]" "dibenzo(a,h)pyrene [polycyclic aromatic hydrocarbons]" "dibenzo[c,pqr]tetraphene" "3,4:8,9-dibenzpyrene" );
gibbsFormation
{
    dHf_298   561850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=752580.0
    phase     gas;
}
