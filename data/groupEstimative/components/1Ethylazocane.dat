/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethylazocane  (C9H19N, CAS 73676-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethylazocane;
formula     C9H19N;
CAS         73676-23-0;
InChIKey    ZWPXCDPVWYPZKE-UHFFFAOYSA-N;
MW          141.258;      // g/mol [origin=calculated method=formula-sum]
Tc          651.44;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.3712;      // -   [origin=predictive method=lee-kesler]
Tb          446.45;      // K   [origin=predictive method=joback]
HvapTb      38581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.649 1.12172 -0.0006684 1.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 7; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octahydroazocine, 1-ethyl-" "1-ethyl-azocane" "azocine,1-ethyloctahydro-" );
standardThermochemistry
{
    dHf_298   -93060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155740.0
}
