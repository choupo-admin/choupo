/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-cyclohexylaniline  (C12H17N, CAS 6373-50-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Cyclohexylaniline;
formula     C12H17N;
CAS         6373-50-8;
InChIKey    JLNMBIKJQAKQBH-UHFFFAOYSA-N;
MW          175.275;      // g/mol [origin=calculated method=formula-sum]
Tc          848.27;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.5246;      // -   [origin=predictive method=lee-kesler]
Tb          597.90;      // K   [origin=predictive method=joback]
HvapTb      56314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.74 1.1894 -0.00071756 1.528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group ACCH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzenamine, 4-cyclohexyl-" "aniline, p-cyclohexyl-" "4-cyclohexylphenylamine" "p-cyclohexylaniline, hydrobromide" );
gibbsFormation
{
    dHf_298   22160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243840.0
    phase     gas;
}
