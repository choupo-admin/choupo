/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dimethyl-3-ethylpentane  (C9H20, CAS 1068-87-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dimethyl3Ethylpentane;
formula     C9H20;
CAS         1068-87-7;
InChIKey    VLHAGZNBWKUMRW-UHFFFAOYSA-N;
MW          128.259;      // g/mol [origin=calculated method=formula-sum]
Tc          578.64;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.3576;      // -   [origin=predictive method=lee-kesler]
Tb          404.20;      // K   [origin=predictive method=joback]
HvapTb      34464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.339 0.8766 -0.0004754 9.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-2,4-dimethyl-pentane" "3-ethyl-2,4-dimethylpentane" "pentane, 3-ethyl-2,4-dimethyl-" "2,4-dimethyl-3-ethyl pentane" "pentane,3-ethyl-2,4-dimethyl-" "pentane, 3-ethyl-2,4-dimethyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -244930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17580.0
}
