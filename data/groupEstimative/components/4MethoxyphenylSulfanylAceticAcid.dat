/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(4-methoxyphenyl)sulfanyl]acetic acid  (C9H10O3S, CAS 34262-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethoxyphenylSulfanylAceticAcid;
formula     C9H10O3S;
CAS         34262-88-9;
InChIKey    WPRFIGTZKOUYRL-UHFFFAOYSA-N;
MW          198.236;      // g/mol [origin=calculated method=formula-sum]
Tc          912.84;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.8948;      // -   [origin=predictive method=lee-kesler]
Tb          673.89;      // K   [origin=predictive method=joback]
HvapTb      64957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.801 0.70241 -0.00035136 4.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methoxyphenyl)sulfanylethanoic acid" "[(4-methoxyphenyl)thio]acetic acid" "2-(4-methoxyphenylthio)acetic acid" "2-((4-methoxyphenyl)thio)acetic acid" "(4-methoxy-phenylsulfanyl)-acetic acid" "2-(4-methoxyphenyl)sulfanylacetic acid" "aceticacid, [(4-methoxyphenyl)thio]- (9ci); acetic acid, [(p-methoxyphenyl)thio]-(6ci,7ci,8ci); (p-methoxyphenylthio)acetic acid;s-(p-methoxyphenyl)mercaptoacetic acid; [(4-methoxyphenyl)sulfanyl]acetic acid;[(4-methoxyphenyl)thio]acetic acid" );
gibbsFormation
{
    dHf_298   -444650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-288110.0
    phase     gas;
}
