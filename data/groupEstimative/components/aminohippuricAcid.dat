/*--------------------------------*- Choupo -*-----------------------*\
  Component: aminohippuric acid  (C9H10N2O3, CAS 61-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aminohippuricAcid;
formula     C9H10N2O3;
CAS         61-78-9;
InChIKey    HSMNQINEKMPTIC-UHFFFAOYSA-N;
MW          194.19;      // g/mol [origin=calculated method=formula-sum]
Tc          994.70;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       1.2982;      // -   [origin=predictive method=lee-kesler]
Tb          759.26;      // K   [origin=predictive method=joback]
HvapTb      79553.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.659 0.8813 -0.00057586 1.3696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(4-aminophenyl)carbonylamino]ethanoic acid" "p-aminohippuric acid" "4-aminohippuric acid" "n-(4-aminobenzoyl)glycine" "para-aminohippuric acid" "glycine, n-(4-aminobenzoyl)-" "nefrotest" "paha" "n-(p-aminobenzoyl)glycine" "aminohippurate" "p-aminohippurate" "para-aminohippurate" );
standardThermochemistry
{
    dHf_298   -379620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189310.0
}
