/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-octyn-1-ol  (C8H14O, CAS 871-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Octyn1Ol;
formula     C8H14O;
CAS         871-91-0;
InChIKey    ATCNYMVVGBLQMQ-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          634.70;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.7930;      // -   [origin=predictive method=lee-kesler]
Tb          464.94;      // K   [origin=predictive method=joback]
HvapTb      49939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.686 0.7039 -0.00043773 1.1219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oct-7-yn-1-ol" "8-hydroxy-1-octyne;oct-7-yn-1-ol;octane-7-yne-1-ol;" );
standardThermochemistry
{
    dHf_298   -68780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102730.0
}
