/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-dimethylaminomethyl-1-(m-methoxyphenyl)cyclohexanol  (C16H25NO2, CAS 2914-77-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Dimethylaminomethyl1MMethoxyphenylCyclohexanol;
formula     C16H25NO2;
CAS         2914-77-4;
InChIKey    TVYLLZQTGLZFBW-UHFFFAOYSA-N;
MW          263.381;      // g/mol [origin=calculated method=formula-sum]
Tc          949.89;      // K   [origin=predictive method=joback]
Pc          21.674;      // bar [origin=predictive method=joback]
omega       1.0634;      // -   [origin=predictive method=lee-kesler]
Tb          739.50;      // K   [origin=predictive method=joback]
HvapTb      74249.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.819 1.86766 -0.00140096 4.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 1; } { group CH3O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(dimethylamino)methyl]-1-(3-methoxyphenyl)cyclohexan-1-ol" "cyclohexanol, 2-(dimethylaminomethyl)-1-(m-methoxyphenyl)-" "2-((dimethylamino)methyl)-1-(3-methoxyphenyl)cyclohexan-1-ol" "cyclohexanol, 2-[(dimethylamino)methyl]-1-(3-methoxyphenyl)-" "2-(dimethylaminomethyl)-1-(3-methoxyphenyl)cyclohexan-1-ol" "agn-pc-01lvlw" "(+)-trans-2-(dimethylaminomethyl)-1-(m-methoxyphenyl)cyclohexanol" "(-)-trans-2-(dimethylaminomethyl)-1-(m-methoxyphenyl)cyclohexanol" "cyclohexanol,2-[(dimethylamino)methyl]-1-(3-methoxyphenyl)-" "cyclohexanol, 2-(dimethylaminomethyl)-1-(m-methoxyphenyl)-, (+)-(e)-" "cyclohexanol, 2-(dimethylaminomethyl)-1-(m-methoxyphenyl)-, (-)-(e)-" "cyclohexanol, 2-((dimethylamino)methyl)-1-(m-methoxyphenyl)-, (+,-)-trans-" );
gibbsFormation
{
    dHf_298   -316210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66830.0
    phase     gas;
}
