/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8,9-trihydroxyanthracene  (C14H10O3, CAS 480-22-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        189Trihydroxyanthracene;
formula     C14H10O3;
CAS         480-22-8;
InChIKey    YUTJCNNFTOIOGT-UHFFFAOYSA-N;
MW          226.231;      // g/mol [origin=calculated method=formula-sum]
Tc          1104.41;      // K   [origin=predictive method=joback]
Pc          58.361;      // bar [origin=predictive method=joback]
omega       1.3546;      // -   [origin=predictive method=lee-kesler]
Tb          831.40;      // K   [origin=predictive method=joback]
HvapTb      92018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.09 1.6518 -0.00174448 7.175e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 4; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 7; } { group dC_ring; count 7; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anthracene-1,8,9-triol" "1,8,9-anthracenetriol" "lasan" "dioxyanthranol" "dermaline" "derobin" "1,8,9-anthratriol" "1,8-dihydroxyanthranol" "1,8-dihydroxy-9-anthranol" "psoriacide" "batidrol" "cygnolin" );
gibbsFormation
{
    dHf_298   -257020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80780.0
    phase     gas;
}
