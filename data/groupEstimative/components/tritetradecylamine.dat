/*--------------------------------*- Choupo -*-----------------------*\
  Component: tritetradecylamine  (C42H87N, CAS 27911-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tritetradecylamine;
formula     C42H87N;
CAS         27911-72-4;
InChIKey    WFVLGDMOCAFNNS-UHFFFAOYSA-N;
MW          606.165;      // g/mol [origin=calculated method=formula-sum]
Tc          1632.94;      // K   [origin=predictive method=joback]
Pc          3.625;      // bar [origin=predictive method=joback]
omega       -0.4036;      // -   [origin=predictive method=lee-kesler]
Tb          1173.00;      // K   [origin=predictive method=joback]
HvapTb      111129.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.981 4.11776 -0.0023736 5.26e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 38; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 39; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-di(tetradecyl)tetradecan-1-amine" "1-tetradecanamine,n,n-ditetradecyl-" "tritetradecylamine(8ci); ttda; trimyristylamine" );
gibbsFormation
{
    dHf_298   -842680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1808.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=413540.0
    phase     gas;
}
