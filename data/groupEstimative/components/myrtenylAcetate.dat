/*--------------------------------*- Choupo -*-----------------------*\
  Component: myrtenyl acetate  (C12H18O2, CAS 1079-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        myrtenylAcetate;
formula     C12H18O2;
CAS         1079-01-2;
InChIKey    BKATZVAUANSCKN-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          757.83;      // K   [origin=predictive method=joback]
Pc          23.865;      // bar [origin=predictive method=joback]
omega       0.5654;      // -   [origin=predictive method=lee-kesler]
Tb          549.84;      // K   [origin=predictive method=joback]
HvapTb      49205.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.189 1.53116 -0.00132584 4.923e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6,6-dimethyl-4-bicyclo[3.1.1]hept-3-enyl)methyl ethanoate" "(-)-myrtenyl acetate" "2-pinen-10-yl acetate" "2-pinen-10-ol, acetate" "2-pinen-10-ol, acetate (6ci,7ci,8ci)" "(1r)-6,6-dimethylbicyclo[3.1.1]hept-2-ene-2-methyl acetate" "(1s)-6,6-dimethylbicyclo(3.1.1)hept-2-ene-2-methanol acetate" "(1s)-(6,6-dimethylbicyclo(3.1.1)hept-2-en-2-yl)methyl acetate" "bicyclo(3.1.1)hept-2-ene-2-methanol, 6,6-dimethyl-, acetate, (1s,5r)-" "(1r)-(6,6-dimethylbicyclo(3.1.1)hept-2-en-2-yl)methyl acetate" "bicyclo[3.1.1]hept-2-ene-2-methanol, 6,6-dimethyl-, acetate, (1s)-" "bicyclo[3.1.1]hept-2-ene-2-methanol, 6,6-dimethyl-, acetate, (1s,5r)-" );
standardThermochemistry
{
    dHf_298   -427640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143680.0
}
