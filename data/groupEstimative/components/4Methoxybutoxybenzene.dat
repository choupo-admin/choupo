/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxybutoxybenzene  (C11H16O2, CAS 20636-14-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxybutoxybenzene;
formula     C11H16O2;
CAS         20636-14-0;
InChIKey    JZDHXBGNBZJRFK-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          721.65;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.5912;      // -   [origin=predictive method=lee-kesler]
Tb          522.80;      // K   [origin=predictive method=joback]
HvapTb      47176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.984 0.84352 -0.0003838 3.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene,(4-methoxybutoxy)-" "benzene, (4-methoxybutoxy)-" );
gibbsFormation
{
    dHf_298   -298280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55850.0
    phase     gas;
}
