/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-2,6-dimethylanisole  (C9H11BrO, CAS 14804-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo26Dimethylanisole;
formula     C9H11BrO;
CAS         14804-38-7;
InChIKey    MMARFGDTMJBIBK-UHFFFAOYSA-N;
MW          215.09;      // g/mol [origin=calculated method=formula-sum]
Tc          761.43;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.5388;      // -   [origin=predictive method=lee-kesler]
Tb          535.72;      // K   [origin=predictive method=joback]
HvapTb      48735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.39 0.57646 -0.00025628 2.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-bromanyl-2-methoxy-1,3-dimethyl-benzene" "5-bromo-2-methoxy-1,3-dimethylbenzene" "5-bromo-2-methoxy-m-xylene" "4-brom-2,6-dimethylanisole" "1-bromo-3,5-dimethyl-4-methoxybenzene" "4-bromo-2,6-dimethyl-methoxybenzene" );
standardThermochemistry
{
    dHf_298   -132860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17740.0
}
