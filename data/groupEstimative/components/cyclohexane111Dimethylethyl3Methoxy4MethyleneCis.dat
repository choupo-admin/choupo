/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane,1-(1,1-dimethylethyl)-3-methoxy-4-methylene-cis-  (C12H22O, CAS 68211-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane111Dimethylethyl3Methoxy4MethyleneCis;
formula     C12H22O;
CAS         68211-39-2;
InChIKey    DUVGSEXMTVWEHI-UHFFFAOYSA-N;
MW          182.307;      // g/mol [origin=calculated method=formula-sum]
Tc          711.89;      // K   [origin=predictive method=joback]
Pc          21.100;      // bar [origin=predictive method=joback]
omega       0.4059;      // -   [origin=predictive method=lee-kesler]
Tb          507.39;      // K   [origin=predictive method=joback]
HvapTb      43699.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.37 1.18458 -0.000623 1.01e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butyl-2-methoxy-1-methylidene-cyclohexane" "4-tert-butyl-2-methoxy-1-methylidenecyclohexane" "agn-pc-00odnu" "(2r,4s)-4-tert-butyl-2-methoxy-1-methylidenecyclohexane" "cyclohexane, 1-(1,1-dimethylethyl)-3-methoxy-4-methylene-, trans-" "cyclohexane,1-(1,1-dimethylethyl)-3-methoxy-4-methylene-trans-" );
standardThermochemistry
{
    dHf_298   -313760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=17820.0
}
