/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-1-methyl-2-(piperidinomethyl)pyrrolidine  (C11H22N2, CAS 84466-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s1Methyl2PiperidinomethylPyrrolidine;
formula     C11H22N2;
CAS         84466-85-3;
InChIKey    VCVPSRADUBPOKJ-NSHDSACASA-N;
MW          182.311;      // g/mol [origin=calculated method=formula-sum]
Tc          712.09;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.5236;      // -   [origin=predictive method=lee-kesler]
Tb          507.12;      // K   [origin=predictive method=joback]
HvapTb      44817.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.279 1.59612 -0.0011564 3.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[[(2s)-1-methylpyrrolidin-2-yl]methyl]piperidine" "(s)-1-((1-methylpyrrolidin-2-yl)methyl)piperidine" "(s)-1-[(1-methyl-2-pyrrolidinyl)methyl]piperidine" "(s)-(-)-1-[(1-methyl-2-pyrrolidinyl)methyl]piperidine" "(s)-(-)-1-methyl-2-(1-piperidinomethyl)pyrrolidine" "piperidine,1-[[(2s)-1-methyl-2-pyrrolidinyl]methyl]-" "piperidine,1-[(1-methyl-2-pyrrolidinyl)methyl]-, (s)-;(s)-(-)-1-methyl-2-(1-piperidinomethyl)pyrrolidine; (s)-1-methyl-2-(piperidinomethyl)pyrrolidine" );
gibbsFormation
{
    dHf_298   12150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356210.0
    phase     gas;
}
