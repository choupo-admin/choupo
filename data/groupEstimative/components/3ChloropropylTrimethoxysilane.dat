/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-chloropropyl)trimethoxysilane  (C6H15ClO3Si, CAS 2530-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H15ClO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3ChloropropylTrimethoxysilane;
formula     C6H15ClO3Si;
CAS         2530-87-2;
InChIKey    OXYZDRAJMHGSMW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          198.718;      // g/mol [origin=calculated method=formula-sum]
Tc          621.51;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.4842;      // -   [origin=predictive method=lee-kesler]
Tb          442.97;      // K   [origin=predictive method=joback]
HvapTb      40859.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (127.643 0.18486 0.0004248 -3.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3O; count 3; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropyl(trimethoxy)silane" "3-chloropropyltrimethoxysilane" "silane, (3-chloropropyl)trimethoxy-" "3-chloropropyltrimethyoxysilane" "cps-m" "silane (3-chloropropyl)tris(methoxy)-" "3-chloropropyl(trimethoxy)silane" "trimethoxy(3-chloropropyl)silane" "3-(trimethoxysilyl)propyl chloride" "(gamma-chloropropyl)trimethoxysilane" "3-chloropropyl-trimethoxysilane" "3-chloropropyl trimethoxysilane" );
standardThermochemistry
{
    dHf_298   -691190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-432050.0
}
