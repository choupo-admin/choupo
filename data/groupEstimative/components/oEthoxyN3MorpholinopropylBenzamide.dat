/*--------------------------------*- Choupo -*-----------------------*\
  Component: o-ethoxy-n-(3-morpholinopropyl)benzamide  (C16H24N2O3, CAS 78109-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oEthoxyN3MorpholinopropylBenzamide;
formula     C16H24N2O3;
CAS         78109-88-3;
InChIKey    YZBWJKXWVHZMER-UHFFFAOYSA-N;
MW          292.379;      // g/mol [origin=calculated method=formula-sum]
Tc          998.57;      // K   [origin=predictive method=joback]
Pc          21.100;      // bar [origin=predictive method=joback]
omega       1.1210;      // -   [origin=predictive method=lee-kesler]
Tb          783.14;      // K   [origin=predictive method=joback]
HvapTb      76859.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.406 1.64952 -0.00101116 2.2286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group O_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-n-(3-morpholin-4-ylpropyl)benzamide" "benzamide, o-ethoxy-n-(3-morpholinopropyl)-" "2-ethoxy-n-[3-(morpholin-4-yl)propyl]benzamide" "(2-ethoxyphenyl)-n-(3-morpholin-4-ylpropyl)carboxamide" );
gibbsFormation
{
    dHf_298   -323490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111010.0
    phase     gas;
}
