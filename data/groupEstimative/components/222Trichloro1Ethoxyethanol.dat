/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,2-trichloro-1-ethoxyethanol  (C4H7Cl3O2, CAS 515-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222Trichloro1Ethoxyethanol;
formula     C4H7Cl3O2;
CAS         515-83-3;
InChIKey    DLHWKJDYXPNWAI-UHFFFAOYSA-N;
MW          193.448;      // g/mol [origin=calculated method=formula-sum]
Tc          710.03;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       0.7956;      // -   [origin=predictive method=lee-kesler]
Tb          514.34;      // K   [origin=predictive method=joback]
HvapTb      55058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.561 0.50672 -0.0003494 8.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group Cl; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)-1-ethoxy-ethanol" "chloral alcoholate" "chloral semiacetal" "chloral ethylalcoholate" "chloral, ethyl hemiacetal" "ethanol chloral hemiacetal" "ethanol, 2,2,2-trichloro-1-ethoxy-" "trichloroacetaldehyde monoethylacetal" "1-ethoxy-2,2,2-trichloroethanol" "ethanol, 1-ethoxy-2,2,2-trichloro-" "chloralalkoholat" "2,2-trichloro-1-ethoxyethanol" );
gibbsFormation
{
    dHf_298   -471590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-294410.0
    phase     gas;
}
