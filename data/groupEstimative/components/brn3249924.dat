/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3249924  (C11H17NO, CAS 63918-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3249924;
formula     C11H17NO;
CAS         63918-85-4;
InChIKey    KQERCLGZXVLCKZ-UHFFFAOYSA-N;
MW          179.263;      // g/mol [origin=calculated method=formula-sum]
Tc          814.63;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       1.0527;      // -   [origin=predictive method=lee-kesler]
Tb          619.87;      // K   [origin=predictive method=joback]
HvapTb      65083.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.617 1.08602 -0.000688 1.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-phenylpropan-2-ylamino)ethanol" "alpha-phenyl-beta-oxyethylaminopropane" "1-phenyl-2-(beta-hydroxyethyl)aminopropane" "ethanol, 2-(alpha-methylphenethyl)amino-" "1-phenyl-2-beta-oxy-aethyl-amino-propan [german]" "2-[(1-phenylpropan-2-yl)amino]ethanol" "1-phenyl-2-beta-oxy-aethyl-amino-propan" );
standardThermochemistry
{
    dHf_298   -137880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104280.0
}
