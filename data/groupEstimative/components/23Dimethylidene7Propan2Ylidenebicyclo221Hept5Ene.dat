/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylidene-7-propan-2-ylidenebicyclo[2.2.1]hept-5-ene  (C12H14, CAS 36439-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylidene7Propan2Ylidenebicyclo221Hept5Ene;
formula     C12H14;
CAS         36439-83-5;
InChIKey    JEUQAURIFGGRPV-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          704.71;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.4286;      // -   [origin=predictive method=lee-kesler]
Tb          495.91;      // K   [origin=predictive method=joback]
HvapTb      43781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.86 1.06744 -0.00079628 2.49e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 2; } { group dC; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylidene-7-propan-2-ylidene-bicyclo[2.2.1]hept-5-ene" "bicyclo(2.2.1)hept-2-ene, 5,6-bis(methylene)-7-(1-methylethylidene)-" );
standardThermochemistry
{
    dHf_298   140930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=332590.0
}
