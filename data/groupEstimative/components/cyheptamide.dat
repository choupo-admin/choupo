/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyheptamide  (C16H15NO, CAS 7199-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyheptamide;
formula     C16H15NO;
CAS         7199-29-3;
InChIKey    APBVLLORZMAWKI-UHFFFAOYSA-N;
MW          237.302;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.99;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.8600;      // -   [origin=predictive method=lee-kesler]
Tb          762.14;      // K   [origin=predictive method=joback]
HvapTb      74386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.26 1.4318 -0.00101982 2.8166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 2; } { group ACCH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,11-dihydro-5h-dibenzo[1,2-a:1',2'-e][7]annulene-11-carboxamide" "cyheptamidum [inn-latin]" "10,11-dihydro-5h-dibenzo(a,d)cycloheptene-5-carboxamide" "dibenzo(a,d)cycloheptadiene-5-carboxamide" "dibenzo(a,d)(1,4)-cycloheptadiene-5-carboxamide" "10,11-dihydro-5h-dibenzocycloheptene-5-carboxamide" "5h-dibenzo(a,d)cycloheptene-5-carboxamide, 10,11-dihydro-" "5h-dibenzo[a,d]cycloheptene-5-carboxamide, 10,11-dihydro-" "10,11-dihydro-5h-dibenzo[a,d]cycloheptene-5-carboxamide" "carbamazepam" "ciheptamida" "cyheptamidum" );
standardThermochemistry
{
    dHf_298   70560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=287680.0
}
