/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutyl suberate  (C16H30O4, CAS 16090-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylSuberate;
formula     C16H30O4;
CAS         16090-77-0;
InChIKey    LBXQUCHUHCBNTC-UHFFFAOYSA-N;
MW          286.412;      // g/mol [origin=calculated method=formula-sum]
Tc          853.11;      // K   [origin=predictive method=joback]
Pc          13.281;      // bar [origin=predictive method=joback]
omega       0.9736;      // -   [origin=predictive method=lee-kesler]
Tb          682.12;      // K   [origin=predictive method=joback]
HvapTb      66024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.162 1.41424 -0.0006574 6.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutyl octanedioate" "suberic acid, dibutyl ester" "octanedioic acid, dibutyl ester" "octanedioic acid,1,8-dibutyl ester" "octanedioicacid, dibutyl ester (9ci);suberic acid, dibutyl ester (8ci);di-n-butylsuberate;dibutyl suberate;" );
gibbsFormation
{
    dHf_298   -1008130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     881.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-536900.0
    phase     gas;
}
