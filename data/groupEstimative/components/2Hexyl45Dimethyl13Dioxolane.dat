/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyl-4,5-dimethyl-1,3-dioxolane  (C11H22O2, CAS 6454-22-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexyl45Dimethyl13Dioxolane;
formula     C11H22O2;
CAS         6454-22-4;
InChIKey    MTNLKAOONWIMIT-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          697.30;      // K   [origin=predictive method=joback]
Pc          21.081;      // bar [origin=predictive method=joback]
omega       0.5647;      // -   [origin=predictive method=lee-kesler]
Tb          511.12;      // K   [origin=predictive method=joback]
HvapTb      48739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.075 1.12156 -0.0005634 8.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH_ring; count 3; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-hexyl-4,5-dimethyl-" "1, 2-hexyl-4,5-dimethyl-" "1, 4,5-dimethyl-2-hexyl-" "1,3-dioxolane, 4,5-dimethyl-2-hexyl-" );
standardThermochemistry
{
    dHf_298   -514570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-109370.0
}
