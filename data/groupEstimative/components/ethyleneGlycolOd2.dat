/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene glycol-(od)2  (C2H4D2O2, CAS 2219-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C2H4D2O2 (delta D+2H-2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethyleneGlycolOd2;
formula     C2H4D2O2;
CAS         2219-52-5;
InChIKey    LYCAIKOWRPUZTN-NMQOAUCRSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          64.08;      // g/mol [origin=calculated method=formula-sum]
Tc          589.55;      // K   [origin=predictive method=joback]
Pc          66.530;      // bar [origin=predictive method=joback]
omega       1.1211;      // -   [origin=predictive method=lee-kesler]
Tb          429.72;      // K   [origin=predictive method=joback]
HvapTb      53404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.652 0.2618 -0.0001458 3.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dideuteriooxyethane" );
standardThermochemistry
{
    dHf_298   -389070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307680.0
}
