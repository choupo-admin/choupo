/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-03ee1n  (C8H7Br3, CAS 57137-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc03ee1n;
formula     C8H7Br3;
CAS         57137-10-7;
InChIKey    RFAGRXAUMFHADO-UHFFFAOYSA-N;
MW          342.856;      // g/mol [origin=calculated method=formula-sum]
Tc          884.69;      // K   [origin=predictive method=joback]
Pc          44.862;      // bar [origin=predictive method=joback]
omega       0.6795;      // -   [origin=predictive method=lee-kesler]
Tb          622.74;      // K   [origin=predictive method=joback]
HvapTb      56969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.181 0.62102 -0.00045568 1.371e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(bromanyl)-4-ethyl-benzene" "1,2,3-tribromo-4-ethylbenzene" "benzene, tribromoethenyl-, homopolymer" "benzene, ethenyl-, tribromo deriv., homopolymer" );
standardThermochemistry
{
    dHf_298   72660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142960.0
}
