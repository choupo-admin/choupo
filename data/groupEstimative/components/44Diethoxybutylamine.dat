/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-diethoxybutylamine  (C8H19NO2, CAS 6346-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diethoxybutylamine;
formula     C8H19NO2;
CAS         6346-09-4;
InChIKey    GFLPSABXBDCMCN-UHFFFAOYSA-N;
MW          161.245;      // g/mol [origin=calculated method=formula-sum]
Tc          679.41;      // K   [origin=predictive method=joback]
Pc          26.164;      // bar [origin=predictive method=joback]
omega       0.6999;      // -   [origin=predictive method=lee-kesler]
Tb          499.57;      // K   [origin=predictive method=joback]
HvapTb      48475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.425 0.70524 -0.000236 -1.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-diethoxybutan-1-amine" "4-aminobutyraldehyde diethyl acetal" "1-butanamine, 4,4-diethoxy-" "agn-pc-0d2xpt" "butyraldehyde,4-amino-, diethyl acetal (6ci,7ci,8ci);butylamine, 4,4-diethoxy- (8ci);4,4-diethoxy-1-butanamine;4-aminobutanal diethylacetal;4-aminobutyraldehyde diethyl acetal;" );
standardThermochemistry
{
    dHf_298   -444380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-129510.0
}
