/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-chlorobenzyl)-4-methylphenol  (C14H13ClO, CAS 5419-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Chlorobenzyl4Methylphenol;
formula     C14H13ClO;
CAS         5419-81-8;
InChIKey    BFNMPNQQHUFVKD-UHFFFAOYSA-N;
MW          232.707;      // g/mol [origin=calculated method=formula-sum]
Tc          954.20;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.7742;      // -   [origin=predictive method=lee-kesler]
Tb          701.29;      // K   [origin=predictive method=joback]
HvapTb      70033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.079 1.21842 -0.00094288 2.987e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-chlorophenyl)methyl]-4-methyl-phenol" "2-[(2-chlorophenyl)methyl]-4-methylphenol" );
gibbsFormation
{
    dHf_298   -75220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=106010.0
    phase     gas;
}
