/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-diallyltartramide  (C10H16N2O4, CAS 28843-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiallyltartramide;
formula     C10H16N2O4;
CAS         28843-34-7;
InChIKey    ZRKLEAHGBNDKHM-UHFFFAOYSA-N;
MW          228.248;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.65;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       1.9162;      // -   [origin=predictive method=lee-kesler]
Tb          813.32;      // K   [origin=predictive method=joback]
HvapTb      95460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.332 1.09 -0.000693 1.6412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH2=CH; count 2; } { group OH; count 2; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 2; } { group CdO; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)-n,n'-bis(prop-2-enyl)butanediamide" "n,n'-diallyltartardiamide" "datd" "butanediamide, 2,3-dihydroxy-n,n'-di-2-propenyl-" "n,n'-diallyl-2,3-dihydroxysuccinamide" "2,3-dihydroxy-n-prop-2-enyl-n'-prop-2-enylbutane-1,4-diamide" "(+)-n,n'-diallyl-l-tartardiamide" "n,n'-diallyl tartardiamide" "butanediamide, 2,3-dihydroxy-n,n'-di-2-propenyl-, (2r,3r)-" "butanediamide, 2,3-dihydroxy-n1,n4-di-2-propen-1-yl-, (2r,3r)-" "(+)-n,n'-diallyltartardiamide" "zrkleahgbndkhm-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -432110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148580.0
    phase     gas;
}
