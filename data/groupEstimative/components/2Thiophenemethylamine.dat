/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-thiophenemethylamine  (C5H7NS, CAS 27757-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Thiophenemethylamine;
formula     C5H7NS;
CAS         27757-85-3;
InChIKey    FKKJJPMGAWGYPN-UHFFFAOYSA-N;
MW          113.178;      // g/mol [origin=calculated method=formula-sum]
Tc          695.45;      // K   [origin=predictive method=joback]
Pc          52.739;      // bar [origin=predictive method=joback]
omega       0.4004;      // -   [origin=predictive method=lee-kesler]
Tb          457.61;      // K   [origin=predictive method=joback]
HvapTb      44989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.909 0.54181 -0.00040062 1.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH2; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group NH2; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophen-2-ylmethanamine" "2-(aminomethyl)thiophene" "2-thienylmethylamine" "2-thiophenemethanamine" "2-aminomethylthiophene" "thiophene-2-methylamine" "(thiophen-2-yl)methylamine" "thiophenemethanamine" "(2-thienylmethyl)amine" "2-(thienyl)methylamine" "2-thenyl amine" "thiophen-2-yl-methyl-amine" );
standardThermochemistry
{
    dHf_298   117430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192080.0
}
