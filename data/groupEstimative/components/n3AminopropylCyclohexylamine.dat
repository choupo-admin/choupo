/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(3-aminopropyl)cyclohexylamine  (C9H20N2, CAS 3312-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3AminopropylCyclohexylamine;
formula     C9H20N2;
CAS         3312-60-5;
InChIKey    ITZPOSYADVYECJ-UHFFFAOYSA-N;
MW          156.273;      // g/mol [origin=calculated method=formula-sum]
Tc          759.92;      // K   [origin=predictive method=joback]
Pc          30.626;      // bar [origin=predictive method=joback]
omega       0.6489;      // -   [origin=predictive method=lee-kesler]
Tb          547.77;      // K   [origin=predictive method=joback]
HvapTb      53134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.617 1.119 -0.0006388 1.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-cyclohexylpropane-1,3-diamine" "n-cyclohexyl-1,3-propanediamine" "n1-cyclohexylpropane-1,3-diamine" "n-cyclohexylpropylene 1,3-diamine" "3-cyclohexylaminopropylamin" "n-cyclohexyltrimethylendiamin" "3-(aminopropyl)cyclohexylamine" "cyclohexyl-1,3-propanediamine" "3-cyclohexylamino-1-propylamine" "n-cyclohexyl-1,3-diaminopropane" "n-cyclohexyl-1,3-propylenediamine" "3-(cyclohexylamino)-1-propylamine" );
gibbsFormation
{
    dHf_298   -87510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205190.0
    phase     gas;
}
