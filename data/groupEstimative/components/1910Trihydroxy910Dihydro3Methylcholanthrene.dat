/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,9,10-trihydroxy-9,10-dihydro-3-methylcholanthrene  (C21H18O3, CAS 65831-43-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1910Trihydroxy910Dihydro3Methylcholanthrene;
formula     C21H18O3;
CAS         65831-43-8;
InChIKey    HCAPYAKTGHZBKU-UHFFFAOYSA-N;
MW          318.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1296.93;      // K   [origin=predictive method=joback]
Pc          25.925;      // bar [origin=predictive method=joback]
omega       1.8318;      // -   [origin=predictive method=lee-kesler]
Tb          1059.11;      // K   [origin=predictive method=joback]
HvapTb      121714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.09 1.87682 -0.00148448 4.81e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 5; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 2; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 9; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1,2,9,10-tetrahydrobenzo[j]aceanthrylene-1,9,10-triol" "cholanthrene-1,9,10-triol, 9,10-dihydro-3-methyl-" "benz(j)aceanthrylene-1,9,10-triol, 1,2,9,10-tetrahydro-3-methyl-" "(1r,9s,10s)-3-methyl-1,2,9,10-tetrahydrocyclopenta[ij]tetraphene-1,9,10-triol" );
gibbsFormation
{
    dHf_298   -200570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127160.0
    phase     gas;
}
