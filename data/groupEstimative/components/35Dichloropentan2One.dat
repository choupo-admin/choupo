/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dichloropentan-2-one  (C5H8Cl2O, CAS 58371-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dichloropentan2One;
formula     C5H8Cl2O;
CAS         58371-98-5;
InChIKey    NOSBOKVYSXXKFL-UHFFFAOYSA-N;
MW          155.018;      // g/mol [origin=calculated method=formula-sum]
Tc          640.41;      // K   [origin=predictive method=joback]
Pc          34.561;      // bar [origin=predictive method=joback]
omega       0.4631;      // -   [origin=predictive method=lee-kesler]
Tb          442.29;      // K   [origin=predictive method=joback]
HvapTb      41852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.802 0.47032 -0.0002735 5.676e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Cl; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-bis(chloranyl)pentan-2-one" "2-pentanone, 3,5-dichloro-" );
gibbsFormation
{
    dHf_298   -295870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164000.0
    phase     gas;
}
