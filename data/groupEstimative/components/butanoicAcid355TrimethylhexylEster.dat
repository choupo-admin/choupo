/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanoic acid 3,5,5-trimethylhexyl ester  (C13H26O2, CAS 72939-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanoicAcid355TrimethylhexylEster;
formula     C13H26O2;
CAS         72939-68-5;
InChIKey    HUSIKNOPTGNAOC-UHFFFAOYSA-N;
MW          214.349;      // g/mol [origin=calculated method=formula-sum]
Tc          729.48;      // K   [origin=predictive method=joback]
Pc          16.879;      // bar [origin=predictive method=joback]
omega       0.6490;      // -   [origin=predictive method=lee-kesler]
Tb          551.59;      // K   [origin=predictive method=joback]
HvapTb      50255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.675 1.3158 -0.0007638 1.578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethylhexyl butanoate" "butanoic acid, 3,5,5-trimethylhexyl ester" "3,5,5-trimethylhexyl butyrate" );
standardThermochemistry
{
    dHf_298   -642960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251390.0
}
