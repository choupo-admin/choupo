/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diphenylethylene  (C14H12, CAS 530-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenylethylene;
formula     C14H12;
CAS         530-48-3;
InChIKey    ZMYIIHDQURVDRB-UHFFFAOYSA-N;
MW          180.25;      // g/mol [origin=calculated method=formula-sum]
Tc          819.83;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.4233;      // -   [origin=predictive method=lee-kesler]
Tb          569.84;      // K   [origin=predictive method=joback]
HvapTb      50720.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.33 1.1559 -0.0008254 2.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylethenylbenzene" "benzene, 1,1'-ethenylidenebis-" "1,1-diphenylethene" "(1-phenylvinyl)benzene" "ethylene, 1,1-diphenyl-" "alpha-phenylstyrene" "as-diphenylethylene" ".alpha.-phenylstyrene" "ethylene,1-diphenyl-" "1-phenyl-vinyl-benzene" "ethene-1,1-diyldibenzene" "alpha,alpha-diphenylethylene" );
gibbsFormation
{
    dHf_298   256410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=371110.0
    phase     gas;
}
