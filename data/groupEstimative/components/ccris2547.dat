/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 2547  (C22H12O, CAS 99520-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris2547;
formula     C22H12O;
CAS         99520-58-8;
InChIKey    ZDFADKWBHKVUIB-UHFFFAOYSA-N;
MW          292.337;      // g/mol [origin=calculated method=formula-sum]
Tc          1177.91;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       1.1804;      // -   [origin=predictive method=lee-kesler]
Tb          909.68;      // K   [origin=predictive method=joback]
HvapTb      89432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.03 2.0634 -0.00208704 8.263e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 10; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 11; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "indeno(1,2,3-cd)pyren-8-ol" "8-hydroxyindeno(1,2,3-cd)pyrene" );
gibbsFormation
{
    dHf_298   380360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=575360.0
    phase     gas;
}
