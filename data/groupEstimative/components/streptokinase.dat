/*--------------------------------*- Choupo -*-----------------------*\
  Component: streptokinase  (C11H19NO2, CAS 9002-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        streptokinase;
formula     C11H19NO2;
CAS         9002-01-1;
InChIKey    XRZWVSXEDRYQGC-UHFFFAOYSA-N;
MW          197.278;      // g/mol [origin=calculated method=formula-sum]
Tc          917.47;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.7931;      // -   [origin=predictive method=lee-kesler]
Tb          675.50;      // K   [origin=predictive method=joback]
HvapTb      64379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.74 1.3135 -0.0007396 1.357e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 3; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclohexylpyrrolidine-2-carboxylic acid" "agn-pc-01zh43" "l-proline,4-cyclohexyl-, (4s)-" "4-cyclohexyl-2-pyrrolidinecarboxylic acid" "(2s)-4-cyclohexylpyrrolidine-2-carboxylic acid" );
standardThermochemistry
{
    dHf_298   -488370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161170.0
}
