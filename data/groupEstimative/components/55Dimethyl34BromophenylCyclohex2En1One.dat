/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-(4-bromophenyl)-cyclohex-2-en-1-one  (C14H15BrO, CAS 72036-54-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl34BromophenylCyclohex2En1One;
formula     C14H15BrO;
CAS         72036-54-5;
InChIKey    JISPPFBRAMZBSM-UHFFFAOYSA-N;
MW          279.177;      // g/mol [origin=calculated method=formula-sum]
Tc          979.84;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.6431;      // -   [origin=predictive method=lee-kesler]
Tb          709.49;      // K   [origin=predictive method=joback]
HvapTb      60610.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.34 1.36384 -0.0010632 3.64e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group Br; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-bromophenyl)-5,5-dimethyl-cyclohex-2-en-1-one" "5,5-dimethyl-3-(4-bromophenyl)-cyclohex-2-enone" "3-(4-bromophenyl)-5,5-dimethyl-2-cyclohexenone" "2-cyclohexen-1-one,3-(4-bromophenyl)-5,5-dimethyl-" "3-(4-bromophenyl)-5,5-dimethylcyclohex-2-en-1-one" "5,5-dimethyl-3-(4-bromophenyl)cyclohex-2-en-1-one" );
gibbsFormation
{
    dHf_298   -102730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100800.0
    phase     gas;
}
