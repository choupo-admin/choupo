/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,10,14-trimethylpentadecan-2-one  (C18H36O, CAS 502-69-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        61014Trimethylpentadecan2One;
formula     C18H36O;
CAS         502-69-2;
InChIKey    WHWDWIHXSPCOKZ-UHFFFAOYSA-N;
MW          268.485;      // g/mol [origin=calculated method=formula-sum]
Tc          837.45;      // K   [origin=predictive method=joback]
Pc          12.234;      // bar [origin=predictive method=joback]
omega       0.8240;      // -   [origin=predictive method=lee-kesler]
Tb          663.99;      // K   [origin=predictive method=joback]
HvapTb      61244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.161 1.7036 -0.0009463 1.9246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 9; } { group CH; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentadecanone, 6,10,14-trimethyl-" "hexahydrofarnesyl acetone" "fitone" "hexahydrofarnesylacetone" "hexahydrofarnezylacetone" "(6r,10r)-6,10,14-trimethylpentadecan-2-one" "2-pentadecanone,6,10,14-trimethyl-" "6,10,14-trimethyl-2-pentadecanone" "(?a'a a'a currency)-phytone; 6,10,14-trimethylpentadecane-2-one; 6,10,14-trimethyl-2-pentadecanone; hexahydrofarnesylacetone; perhydrofarnesyl acetone" );
gibbsFormation
{
    dHf_298   -543270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     855.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35560.0
    phase     gas;
}
