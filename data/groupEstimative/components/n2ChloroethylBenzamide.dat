/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-chloroethyl)benzamide  (C9H10ClNO, CAS 26385-07-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2ChloroethylBenzamide;
formula     C9H10ClNO;
CAS         26385-07-9;
InChIKey    FYQJUYCGPLFWQR-UHFFFAOYSA-N;
MW          183.635;      // g/mol [origin=calculated method=formula-sum]
Tc          796.95;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.6928;      // -   [origin=predictive method=lee-kesler]
Tb          573.67;      // K   [origin=predictive method=joback]
HvapTb      55471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.158 0.8349 -0.0005473 1.3186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2Cl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzamide, n-(2-chloroethyl)-" "fyqjuycgplfwqr-uhfffaoysa-" "n-(2-chloroethyl)benzenecarboxamide" );
standardThermochemistry
{
    dHf_298   -67410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85850.0
}
