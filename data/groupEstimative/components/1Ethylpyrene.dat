/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethylpyrene  (C18H14, CAS 17088-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethylpyrene;
formula     C18H14;
CAS         17088-22-1;
InChIKey    ZWAMZDRREBOHIO-UHFFFAOYSA-N;
MW          230.31;      // g/mol [origin=calculated method=formula-sum]
Tc          947.96;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.7223;      // -   [origin=predictive method=lee-kesler]
Tb          702.30;      // K   [origin=predictive method=joback]
HvapTb      64208.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.349 1.52052 -0.00130116 4.527e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 6; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyrene, 1-ethyl-" "ethylpyrene" "pyrene, ethyl-" "1-ethylpyrene;3-ethylpyrene" );
gibbsFormation
{
    dHf_298   315020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=498390.0
    phase     gas;
}
