/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecyl trifluoroacetate  (C20H37F3O2, CAS 79392-43-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecylTrifluoroacetate;
formula     C20H37F3O2;
CAS         79392-43-1;
InChIKey    YZVKTRPQHJKFOD-UHFFFAOYSA-N;
MW          366.508;      // g/mol [origin=calculated method=formula-sum]
Tc          872.96;      // K   [origin=predictive method=joback]
Pc          9.473;      // bar [origin=predictive method=joback]
omega       0.8717;      // -   [origin=predictive method=lee-kesler]
Tb          710.00;      // K   [origin=predictive method=joback]
HvapTb      63774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.917 2.01022 -0.0011906 2.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group C; count 1; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecyl 2,2,2-tris(fluoranyl)ethanoate" "octadecyl 2,2,2-trifluoroacetate" "trifluoroacetic acid, n-octadecyl ester" "acetic acid, trifluoro-, octadecyl ester" );
gibbsFormation
{
    dHf_298   -1370490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1042.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-774440.0
    phase     gas;
}
