/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-t-butylcyclohexyl caproate  (C16H30O2, CAS 68797-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pTButylcyclohexylCaproate;
formula     C16H30O2;
CAS         68797-74-0;
InChIKey    BSARXNDZALPCHW-UHFFFAOYSA-N;
MW          254.414;      // g/mol [origin=calculated method=formula-sum]
Tc          832.63;      // K   [origin=predictive method=joback]
Pc          15.283;      // bar [origin=predictive method=joback]
omega       0.6572;      // -   [origin=predictive method=lee-kesler]
Tb          635.55;      // K   [origin=predictive method=joback]
HvapTb      57441.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.386 1.69048 -0.0009494 1.754e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-tert-butylcyclohexyl) hexanoate" "4-tert-butylcyclohexyl hexanoate" "hexanoic acid 4-(tert-butyl)cyclohexyl ester" "hexanoic acid, 4-(1,1-dimethylethyl)cyclohexyl ester" "4-(isobutyl)cyclohexyl hexanoate" "hexanoic acid,1-dimethylethyl)cyclohexyl ester" );
gibbsFormation
{
    dHf_298   -665620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206950.0
    phase     gas;
}
