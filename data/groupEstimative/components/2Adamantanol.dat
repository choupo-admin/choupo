/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-adamantanol  (C10H16O, CAS 700-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Adamantanol;
formula     C10H16O;
CAS         700-57-2;
InChIKey    FOWDOWQYRZXQDP-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          735.53;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.7577;      // -   [origin=predictive method=lee-kesler]
Tb          535.73;      // K   [origin=predictive method=joback]
HvapTb      53826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.88 1.3779 -0.001054 3.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 5; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "adamantan-2-ol" "2-hydroxyadamantane" "tricyclo[3.3.1.13,7]decan-2-ol" "tricyclo(3.3.1.13,7)decan-2-ol" "k181" "tricyclo[3.3.1.1<3,7>]decan-2-ol" "tricyclo[3.3.1.1~3,7~]decan-2-ol" "tricyclo[3.3.1.13,7]decan-2-ol;2-ad-oh;tricyclo(3.3.1.13,7)decan-2-ol;2-hydroxyadamantane;adamantan-2-ol;" );
standardThermochemistry
{
    dHf_298   -230400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     260.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51230.0
}
