/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-alpha-(dimethylamino)-o-cresol  (C9H12BrNO, CAS 42313-79-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromoAlphaDimethylaminoOCresol;
formula     C9H12BrNO;
CAS         42313-79-1;
InChIKey    VKWZAKOXYMCAER-UHFFFAOYSA-N;
MW          230.105;      // g/mol [origin=calculated method=formula-sum]
Tc          830.18;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.7760;      // -   [origin=predictive method=lee-kesler]
Tb          596.40;      // K   [origin=predictive method=joback]
HvapTb      60058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.319 1.03714 -0.00087032 3.011e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-2-[(dimethylamino)methyl]phenol" "4-bromo-2-(dimethylaminomethyl)phenol" "phenol, 4-bromo-2-[(dimethylamino)methyl]-" );
standardThermochemistry
{
    dHf_298   -87480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=98160.0
}
