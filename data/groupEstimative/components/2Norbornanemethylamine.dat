/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-norbornanemethylamine  (C8H15N, CAS 14370-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Norbornanemethylamine;
formula     C8H15N;
CAS         14370-50-4;
InChIKey    HWMZHVLJBQTGOL-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          683.32;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.4365;      // -   [origin=predictive method=lee-kesler]
Tb          468.25;      // K   [origin=predictive method=joback]
HvapTb      43732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.559 1.0914 -0.0007934 2.355e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bicyclo[2.2.1]heptanylmethanamine" "bicyclo[2.2.1]heptane-2-methanamine" "norbornylmethylamine" "norbornane, 2-(aminomethyl)-" "2-aminomethylnorbornane" "(2,5-endomethylenecyclohexylmethyl)amine" "2-aminomethylbicyclo(2.2.1)heptane" "bicyclo[2.2.1]heptan-2-ylmethanamine" "2-norbornanemethylamine (6ci,7ci,8ci)" "1-(bicyclo[2.2.1]hept-2-yl)methanamine" "bicyclo[2.2.1]hept-2-ylmethylamine" "bicyclo(2.2.1)heptane-2-methanamine" );
gibbsFormation
{
    dHf_298   -55560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     316.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184620.0
    phase     gas;
}
