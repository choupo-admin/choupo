/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-carboxyvinyl)benzoic acid  (C10H8O4, CAS 19675-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42CarboxyvinylBenzoicAcid;
formula     C10H8O4;
CAS         19675-63-9;
InChIKey    HAEJSGLKJYIYTB-UHFFFAOYSA-N;
MW          192.17;      // g/mol [origin=calculated method=formula-sum]
Tc          992.97;      // K   [origin=predictive method=joback]
Pc          37.546;      // bar [origin=predictive method=joback]
omega       1.1916;      // -   [origin=predictive method=lee-kesler]
Tb          755.24;      // K   [origin=predictive method=joback]
HvapTb      75078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.79 0.937 -0.00071336 2.118e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-oxidanyl-3-oxidanylidene-prop-1-enyl)benzoic acid" "benzoic acid,4-(2-carboxyethenyl)-" "benzoic acid, 4-[(1e)-2-carboxyethenyl]-" "4-(3-hydroxy-3-oxoprop-1-enyl)benzoic acid" "cinnamicacid, p-carboxy- (7ci,8ci);4-(2-carboxyethenyl)benzoic acid;4-carboxycinnamicacid;p-carboxycinnamic acid;" );
standardThermochemistry
{
    dHf_298   -607990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-471500.0
}
