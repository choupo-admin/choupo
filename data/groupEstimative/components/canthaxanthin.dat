/*--------------------------------*- Choupo -*-----------------------*\
  Component: canthaxanthin  (C40H52O2, CAS 514-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        canthaxanthin;
formula     C40H52O2;
CAS         514-78-3;
InChIKey    FDSDTBUPSURDBL-DKLMTRRASA-N;
MW          564.854;      // g/mol [origin=calculated method=formula-sum]
Tc          1651.64;      // K   [origin=predictive method=joback]
Pc          6.288;      // bar [origin=predictive method=joback]
omega       0.5203;      // -   [origin=predictive method=lee-kesler]
Tb          1345.22;      // K   [origin=predictive method=joback]
HvapTb      114858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-245.45 4.125 -0.0033612 1.1966e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 2; } { group C; count 2; } { group CH=CH; count 5; } { group CH=C; count 4; } { group CH2CO; count 2; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group dCH; count 14; } { group dC; count 4; } { group CH2_ring; count 4; } { group C_ring; count 2; } { group dC_ring; count 4; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,4-trimethyl-3-[(1e,3e,5e,7e,9e,11e,13e,15e,17e)-3,7,12,16-tetramethyl-18-(2,6,6-trimethyl-3-oxidanylidene-cyclohexen-1-yl)octadeca-1,3,5,7,9,11,13,15,17-nonaenyl]cyclohex-2-en-1-one" "orobronze" "carophyll red" "food orange 8" "cantaxanthin" "canthaxanthine" "roxanthin red 10" "cantaxanthine" "beta,beta-carotene-4,4'-dione" "4,4'-dioxo-beta-carotene" "l-orange 7" "canthaxanthin (trans)" );
gibbsFormation
{
    dHf_298   80290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1459.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=787840.0
    phase     gas;
}
