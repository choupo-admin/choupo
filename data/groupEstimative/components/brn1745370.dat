/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1745370  (C4H6Cl2O, CAS 10141-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1745370;
formula     C4H6Cl2O;
CAS         10141-22-7;
InChIKey    HWRRRIKZPDRSFG-UHFFFAOYSA-N;
MW          140.991;      // g/mol [origin=calculated method=formula-sum]
Tc          614.57;      // K   [origin=predictive method=joback]
Pc          39.906;      // bar [origin=predictive method=joback]
omega       0.3749;      // -   [origin=predictive method=lee-kesler]
Tb          411.41;      // K   [origin=predictive method=joback]
HvapTb      38692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.961 0.49772 -0.0003994 1.242e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(chloranyl)-2-methyl-propanal" "2,3-dichloro-2-methylpropanal" "2,3-dichloro-2-methylpropionaldehyde" "propanal, 2,3-dichloro-2-methyl-" );
standardThermochemistry
{
    dHf_298   -251700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-137740.0
}
