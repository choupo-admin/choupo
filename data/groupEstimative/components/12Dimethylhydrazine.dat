/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethylhydrazine  (C2H8N2, CAS 540-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dimethylhydrazine;
formula     C2H8N2;
CAS         540-73-8;
InChIKey    DIIIISSCIXVANO-UHFFFAOYSA-N;
MW          60.1;      // g/mol [origin=calculated method=formula-sum]
Tc          523.36;      // K   [origin=predictive method=joback]
Pc          52.207;      // bar [origin=predictive method=joback]
omega       0.4133;      // -   [origin=predictive method=lee-kesler]
Tb          345.70;      // K   [origin=predictive method=joback]
HvapTb      32918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.35 0.34624 -0.0001822 3.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethyldiazane" "hydrazomethane" "sym-dimethylhydrazine" "n,n'-dimethylhydrazine" "sdmh" "hydrazine, 1,2-dimethyl-" "1,2-dimethyl-hydrazine" "symmetrical-dimethylhydrazine" "1,2-dimethylhydrazin" "1,2-dmh" "1,2-dimethylhydrazin [german]" "symetryczna dwumetylohydrazyna [polish]" );
gibbsFormation
{
    dHf_298   22330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     315.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144740.0
    phase     gas;
}
