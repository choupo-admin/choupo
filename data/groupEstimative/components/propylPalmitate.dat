/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl palmitate  (C19H38O2, CAS 2239-78-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylPalmitate;
formula     C19H38O2;
CAS         2239-78-3;
InChIKey    BEKZXQKGTDVSKX-UHFFFAOYSA-N;
MW          298.511;      // g/mol [origin=calculated method=formula-sum]
Tc          859.20;      // K   [origin=predictive method=joback]
Pc          10.842;      // bar [origin=predictive method=joback]
omega       0.8920;      // -   [origin=predictive method=lee-kesler]
Tb          692.54;      // K   [origin=predictive method=joback]
HvapTb      65295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.026 1.75404 -0.0009152 1.578e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl hexadecanoate" "hexadecanoic acid, propyl ester" "palmitic acid propyl ester" );
gibbsFormation
{
    dHf_298   -752770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     947.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201270.0
    phase     gas;
}
