/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-2,2-bis(2,4,6-trimethylphenyl)ethenol  (C26H28O, CAS 77787-80-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl22Bis246TrimethylphenylEthenol;
formula     C26H28O;
CAS         77787-80-5;
InChIKey    GOOGGQIASMCXAL-UHFFFAOYSA-N;
MW          356.509;      // g/mol [origin=calculated method=formula-sum]
Tc          1239.44;      // K   [origin=predictive method=joback]
Pc          14.165;      // bar [origin=predictive method=joback]
omega       1.1349;      // -   [origin=predictive method=lee-kesler]
Tb          1000.50;      // K   [origin=predictive method=joback]
HvapTb      101067.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.94 1.93402 -0.00120076 2.861e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } { group ACCH3; count 6; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dC; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 9; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenol, 1-phenyl-2,2-bis(2,4,6-trimethylphenyl)-" "benzenemethanol, a-[bis(2,4,6-trimethylphenyl)methylene]-" );
gibbsFormation
{
    dHf_298   6210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     848.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=373790.0
    phase     gas;
}
