/*--------------------------------*- Choupo -*-----------------------*\
  Component: isometheptene  (C9H19N, CAS 503-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isometheptene;
formula     C9H19N;
CAS         503-01-5;
InChIKey    XVQUOJBERHHONY-UHFFFAOYSA-N;
MW          141.258;      // g/mol [origin=calculated method=formula-sum]
Tc          641.64;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       0.5072;      // -   [origin=predictive method=lee-kesler]
Tb          459.29;      // K   [origin=predictive method=joback]
HvapTb      41714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.058 0.96088 -0.0006037 1.551e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,6-dimethylhept-5-en-2-amine" "5-hepten-2-amine, n,6-dimethyl-" "octanil" "octinum" "isonyl" "octin" "octon" "methyloctenylamine" "4-hexenylamine, n,1,5-trimethyl-" "methylisooctenylamine" "isometheptene [inn:ban]" "isometheptenum [inn-latin]" );
standardThermochemistry
{
    dHf_298   -73470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183520.0
}
