/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichloroacetic acid  (C2HCl3O2, CAS 76-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichloroaceticAcid;
formula     C2HCl3O2;
CAS         76-03-9;
InChIKey    YNJBWRMUSHSURL-UHFFFAOYSA-N;
MW          163.378;      // g/mol [origin=calculated method=formula-sum]
Tc          731.50;      // K   [origin=predictive method=joback]
Pc          50.086;      // bar [origin=predictive method=joback]
omega       0.5594;      // -   [origin=predictive method=lee-kesler]
Tb          499.93;      // K   [origin=predictive method=joback]
HvapTb      49069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.87 0.3908 -0.0003906 1.395e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group Cl; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)ethanoic acid" "acetic acid, trichloro-" "trichloroethanoic acid" "aceto-caustin" "trichloressigsaeure" "konesta" "acide trichloracetique" "trichloracetic acid" "acido tricloroacetico" "tca" "amchem grass killer" "tecane" );
standardThermochemistry
{
    dHf_298   -490850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-410900.0
}
