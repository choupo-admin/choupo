/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethylhex-1-ene  (C8H16, CAS 7116-86-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethylhex1Ene;
formula     C8H16;
CAS         7116-86-1;
InChIKey    KZJIOVQKSAOPOP-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          554.06;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.2864;      // -   [origin=predictive method=lee-kesler]
Tb          376.09;      // K   [origin=predictive method=joback]
HvapTb      31436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.848 0.86966 -0.0006061 1.733e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-hexene, 5,5-dimethyl-" "5,5-dimethyl-1-hexene" "5,5-dimethylhexene-1" "agn-pc-00kzio" "5,5-dimethyl-hex-1-ene" );
standardThermochemistry
{
    dHf_298   -91770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107160.0
}
