/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-naphthalenemethanol  (C11H10O, CAS 1592-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Naphthalenemethanol;
formula     C11H10O;
CAS         1592-38-7;
InChIKey    MFGWMAAZYZSWMY-UHFFFAOYSA-N;
MW          158.2;      // g/mol [origin=calculated method=formula-sum]
Tc          810.32;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.8777;      // -   [origin=predictive method=lee-kesler]
Tb          594.10;      // K   [origin=predictive method=joback]
HvapTb      61337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.869 0.9407 -0.00070588 2.112e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-2-ylmethanol" "2-naphthylmethanol" "naphthalen-2-yl-methanol" "2-hydroxymethylnaphthalene" "2-naphthalene methanol" "(2-naphthyl)methanol" "(naphthalen-2-yl)methanol" "2-naphthylmethan-1-ol" "2na" "2-naphthalene methonal" "2-(hydroxymethyl)naphthalene" "l317" );
gibbsFormation
{
    dHf_298   -6470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114350.0
    phase     gas;
}
