/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-1,2-bis(chloranyl)cyclopropane  (C3H4Cl2, CAS 39199-87-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2r12BisChloranylCyclopropane;
formula     C3H4Cl2;
CAS         39199-87-6;
InChIKey    YYQKBUMQNFGUGI-PWNYCUMCSA-N;
MW          110.965;      // g/mol [origin=calculated method=formula-sum]
Tc          544.10;      // K   [origin=predictive method=joback]
Pc          45.469;      // bar [origin=predictive method=joback]
omega       0.2166;      // -   [origin=predictive method=lee-kesler]
Tb          345.17;      // K   [origin=predictive method=joback]
HvapTb      30646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.36 0.4268 -0.000345 1.136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -84270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     207.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=3560.0
    phase     gas;
}
