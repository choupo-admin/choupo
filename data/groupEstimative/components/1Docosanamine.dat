/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-docosanamine  (C22H47N, CAS 14130-06-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Docosanamine;
formula     C22H47N;
CAS         14130-06-4;
InChIKey    VPNOHCYAOXWMAR-UHFFFAOYSA-N;
MW          325.625;      // g/mol [origin=calculated method=formula-sum]
Tc          952.01;      // K   [origin=predictive method=joback]
Pc          9.335;      // bar [origin=predictive method=joback]
omega       0.8754;      // -   [origin=predictive method=lee-kesler]
Tb          775.49;      // K   [origin=predictive method=joback]
HvapTb      75207.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.619 2.15572 -0.0012164 2.616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 20; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "docosan-1-amine" "docosylamine" "docosylamine(6ci,7ci,8ci); 1-aminodocosane; 1-docosylamine; behenylamine; kemamine p 298d;n-docosylamine" );
standardThermochemistry
{
    dHf_298   -463620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1064.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200810.0
}
