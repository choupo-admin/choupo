/*--------------------------------*- Choupo -*-----------------------*\
  Component: exo-5-chlorobicyclo(2.2.1)hept-2-ene  (C7H9Cl, CAS 3721-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        exo5Chlorobicyclo221Hept2Ene;
formula     C7H9Cl;
CAS         3721-19-5;
InChIKey    PSCJIEZOAFAQRM-UHFFFAOYSA-N;
MW          128.599;      // g/mol [origin=calculated method=formula-sum]
Tc          622.61;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.2786;      // -   [origin=predictive method=lee-kesler]
Tb          409.43;      // K   [origin=predictive method=joback]
HvapTb      35542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.47 0.8853 -0.00070328 2.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-chloranylbicyclo[2.2.1]hept-2-ene" "exo-5-chlorobicyclo[2.2.1]hept-2-ene" "endo-5-chlorobicyclo(2.2.1)hept-2-ene" "endo-5-chlorobicyclo[2.2.1]hept-2-ene" "5-chlorobicyclo[2.2.1]hept-2-ene" "6-chlorobicyclo[2.2.1]hept-2-ene" "bicyclo[2.2.1]hept-2-ene, 5-chloro-" );
gibbsFormation
{
    dHf_298   -26670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     221.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127780.0
    phase     gas;
}
