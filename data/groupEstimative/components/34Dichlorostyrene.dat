/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dichlorostyrene  (C8H6Cl2, CAS 2039-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dichlorostyrene;
formula     C8H6Cl2;
CAS         2039-83-0;
InChIKey    BJQFWAQRPATHTR-UHFFFAOYSA-N;
MW          173.036;      // g/mol [origin=calculated method=formula-sum]
Tc          721.74;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.3827;      // -   [origin=predictive method=lee-kesler]
Tb          490.82;      // K   [origin=predictive method=joback]
HvapTb      45102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.1 0.5595 -0.00037222 9.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-4-ethenyl-benzene" "1,2-dichloro-4-vinylbenzene" "1,2-dichloro-4-ethenylbenzene" "benzene, 1,2-dichloro-4-ethenyl-" "ambap2039-83-0" "benzene,1,2-dichloro-4-ethenyl-" "3,4-dichlorostyrene;1,2-dichloro-4-ethenylbenzene;" );
standardThermochemistry
{
    dHf_298   99090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173610.0
}
