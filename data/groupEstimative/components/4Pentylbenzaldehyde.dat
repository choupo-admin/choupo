/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentylbenzaldehyde  (C12H16O, CAS 6853-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H16O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Pentylbenzaldehyde;
formula     C12H16O;
CAS         6853-57-2;
InChIKey    NQVZPRUSNWNSQH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          682.11;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.4375;      // -   [origin=predictive method=lee-kesler]
Tb          482.24;      // K   [origin=predictive method=joback]
HvapTb      42871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.126 1.01352 -0.00074616 2.289e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzaldehyde, 4-pentyl-" "4-n-pentylbenzaldehyde" "p-pentylbenzaldehyde" "p-pentyl-benzaldehyde" "p-pentylbenzaldehyde, i" "p-amylbenzaldehyde" "4-n-pentylbenzaldehyde;4-pentylbenzaldehyde;p-pentylbenzaldehyde;p-amylbenzaldehyde;" );
gibbsFormation
{
    dHf_298   10500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196900.0
    phase     gas;
}
