/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-sulfanylethyl) 3,3'-sulfanediyldipropanoate  (C10H18O4S3, CAS 67874-44-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2Sulfanylethyl33Sulfanediyldipropanoate;
formula     C10H18O4S3;
CAS         67874-44-6;
InChIKey    FZSIEPOWYMJQCT-UHFFFAOYSA-N;
MW          298.43;      // g/mol [origin=calculated method=formula-sum]
Tc          960.53;      // K   [origin=predictive method=joback]
Pc          24.435;      // bar [origin=predictive method=joback]
omega       1.0329;      // -   [origin=predictive method=lee-kesler]
Tb          739.34;      // K   [origin=predictive method=joback]
HvapTb      72959.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.998 0.89319 -0.0003356 -2.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2COO; count 2; } { group CH2SH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group COO; count 2; } { group SH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-sulfanylethyl 3-[3-oxidanylidene-3-(2-sulfanylethoxy)propyl]sulfanylpropanoate" "bis(2-mercaptoethyl) 3,3'-thiodipropionate" "propanoic acid, 3,3'-thiobis-, 1,1'-bis(2-mercaptoethyl) ester" "bis(2-mercaptoethyl) 3,3'-thiobispropionate" "bis(2-mercaptoethyl ester) 3,3'-thiodipropionic acid" "propanoic acid, 3,3'-thiobis-, bis(2-mercaptoethyl) ester" "2-sulfanylethyl 3-[3-oxo-3-(2-sulfanylethoxy)propyl]sulfanylpropanoate" );
standardThermochemistry
{
    dHf_298   -765460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     834.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-495520.0
}
