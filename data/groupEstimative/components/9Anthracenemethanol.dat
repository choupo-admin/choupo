/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-anthracenemethanol  (C15H12O, CAS 1468-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Anthracenemethanol;
formula     C15H12O;
CAS         1468-95-7;
InChIKey    JCJNNHDZTLRSGN-UHFFFAOYSA-N;
MW          208.26;      // g/mol [origin=calculated method=formula-sum]
Tc          937.14;      // K   [origin=predictive method=joback]
Pc          31.740;      // bar [origin=predictive method=joback]
omega       1.0447;      // -   [origin=predictive method=lee-kesler]
Tb          709.58;      // K   [origin=predictive method=joback]
HvapTb      72543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.649 1.2575 -0.00099316 3.15e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 4; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "anthracen-9-ylmethanol" "9-anthrylcarbinol" "9-hydroxymethylanthracene" "9-methylolanthracene" "9-(hydroxymethyl)anthracene" "9-hydroxymethylantracene" "9-anthrylmethanol" "anthracene-9-carbinol" "9-anthrylmethan-1-ol" "9-anthracenylmethanol" "jcjnnhdztlrsgn-uhfffaoysa-" "9-anthracene methyl carbinol" );
gibbsFormation
{
    dHf_298   90570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245050.0
    phase     gas;
}
