/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butyl-n,n-dimethylaniline  (C12H19N, CAS 2909-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylNNDimethylaniline;
formula     C12H19N;
CAS         2909-79-7;
InChIKey    SJDILFZCXQHCRB-UHFFFAOYSA-N;
MW          177.291;      // g/mol [origin=calculated method=formula-sum]
Tc          725.52;      // K   [origin=predictive method=joback]
Pc          24.100;      // bar [origin=predictive method=joback]
omega       0.4466;      // -   [origin=predictive method=lee-kesler]
Tb          515.03;      // K   [origin=predictive method=joback]
HvapTb      45991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.79 1.2552 -0.00087756 2.415e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butyl-n,n-dimethyl-aniline" "n,n-dimethyl-4-t-butylaniline" "n,n-dimethyl-4-t-butylbenzeneamine" "[4-(tert-butyl)phenyl]dimethylamine" "benzeneamine, 4-(1,1-dimethylethyl)-n,n-dimethyl-" "aniline,p-tert-butyl-n,n-dimethyl- (6ci,7ci,8ci); 4-tert-butyl-n,n-dimethylaniline;n,n-dimethyl-p-tert-butylaniline; p-tert-butyl-n,n-dimethylaniline" );
gibbsFormation
{
    dHf_298   -7170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266560.0
    phase     gas;
}
