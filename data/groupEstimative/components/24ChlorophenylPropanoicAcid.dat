/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-chlorophenyl)propanoic acid  (C9H9ClO2, CAS 938-95-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24ChlorophenylPropanoicAcid;
formula     C9H9ClO2;
CAS         938-95-4;
InChIKey    YOZILQVNIWNPFP-UHFFFAOYSA-N;
MW          184.619;      // g/mol [origin=calculated method=formula-sum]
Tc          853.31;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.7554;      // -   [origin=predictive method=lee-kesler]
Tb          619.68;      // K   [origin=predictive method=joback]
HvapTb      59727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.09 0.78392 -0.00052616 1.33e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloro-alpha-methylphenylacetic acid" "dl-4-chloro-alpha-methylphenylacetic acid" "dl-p-chloro-.alpha.-methylphenylacetic acid" "benzeneacetic acid, 4-chloro-.alpha.-methyl-" "dl-2-(4-chlorophenyl)propanoic acid" "4-chloro methylphenylacetic acid" "yozilqvniwnpfp-uhfffaoysa-" "4-chloro-a-methylphenylacetic acid" "2-(4-chlorophenyl)-propionic acid" "4-chloro phenyl propionic acid" "dl-4-chloro-" "a-methylphenylacetic acid" "k708" );
standardThermochemistry
{
    dHf_298   -375320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230600.0
}
