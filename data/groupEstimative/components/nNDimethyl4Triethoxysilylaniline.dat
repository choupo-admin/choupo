/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-4-triethoxysilylaniline  (C14H25NO3Si, CAS 18418-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H25NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nNDimethyl4Triethoxysilylaniline;
formula     C14H25NO3Si;
CAS         18418-79-6;
InChIKey    ZDAMOIHILBVHMU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          283.443;      // g/mol [origin=calculated method=formula-sum]
Tc          826.54;      // K   [origin=predictive method=joback]
Pc          17.089;      // bar [origin=predictive method=joback]
omega       0.7506;      // -   [origin=predictive method=lee-kesler]
Tb          632.68;      // K   [origin=predictive method=joback]
HvapTb      59263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.183 0.9236 -6.676e-05 -1.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 3; } { group CH3N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-4-triethoxysilyl-aniline" "n,n-dimethyl-4-(triethoxysilyl)aniline" "benzenamine, n,n-dimethyl-4-(triethoxysilyl)-" "p-dimethylaminophenyltriethoxysilane" "n,n-dimethyl-p-triethoxysilylaniline" "benzenamine,n,n-dimethyl-4-(triethoxysilyl)-" "aniline,n,n-dimethyl-p-(triethoxysilyl)- (8ci)" );
gibbsFormation
{
    dHf_298   -547980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     765.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-139200.0
    phase     gas;
}
