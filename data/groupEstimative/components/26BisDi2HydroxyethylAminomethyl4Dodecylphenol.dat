/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-bis(di(2-hydroxyethyl)aminomethyl)-4-dodecylphenol  (C28H52N2O5, CAS 67845-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26BisDi2HydroxyethylAminomethyl4Dodecylphenol;
formula     C28H52N2O5;
CAS         67845-80-1;
InChIKey    OULHAICTILGDPH-UHFFFAOYSA-N;
MW          496.733;      // g/mol [origin=calculated method=formula-sum]
Tc          1958.52;      // K   [origin=predictive method=joback]
Pc          10.460;      // bar [origin=predictive method=joback]
omega       -0.0324;      // -   [origin=predictive method=lee-kesler]
Tb          1351.10;      // K   [origin=predictive method=joback]
HvapTb      165338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.009 3.00432 -0.00199968 5.448e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group ACH; count 2; } { group ACCH2; count 3; } { group OH; count 4; } { group ACOH; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 4; } { group OH_phenol; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis[[bis(2-hydroxyethyl)amino]methyl]-4-dodecyl-phenol" "2,6-bis[[bis(2-hydroxyethyl)amino]methyl]-4-dodecylphenol" "2,6-bis((bis(2-hydroxyethyl)amino)methyl)-4-dodecylphenol" "phenol, 2,6-bis((bis(2-hydroxyethyl)amino)methyl)-4-dodecyl-" "phenol, 2,6-bis[[bis(2-hydroxyethyl)amino]methyl]-4-dodecyl-" );
gibbsFormation
{
    dHf_298   -1058830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1390.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202310.0
    phase     gas;
}
