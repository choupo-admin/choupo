/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-fluorobenzaldehyde  (C7H5FO, CAS 459-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H5FO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Fluorobenzaldehyde;
formula     C7H5FO;
CAS         459-57-4;
InChIKey    UOQXIWFBQSVDPP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          124.114;      // g/mol [origin=calculated method=formula-sum]
Tc          565.91;      // K   [origin=predictive method=joback]
Pc          40.312;      // bar [origin=predictive method=joback]
omega       0.2552;      // -   [origin=predictive method=lee-kesler]
Tb          367.11;      // K   [origin=predictive method=joback]
HvapTb      30924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.49 0.5503 -0.00049056 1.75e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CHO; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-fluoranylbenzaldehyde" "p-fluorobenzaldehyde" "benzaldehyde, 4-fluoro-" "p-fluorbenzaldehyde" "4-fluoro-benzaldehyde" "fluorobenzaldehyde(4-)" "benzaldehyde, p-fluoro-" "pfad" "4-fluorobenzal dehyde" "para fluoro benzaldehyde" "4-fluorbenzaldehyde" "p-fluoro benzaldehyde" );
gibbsFormation
{
    dHf_298   -82410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40010.0
    phase     gas;
}
