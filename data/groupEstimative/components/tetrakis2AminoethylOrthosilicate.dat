/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrakis(2-aminoethyl) orthosilicate  (C8H24N4O4Si, CAS 7057-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H24N4O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetrakis2AminoethylOrthosilicate;
formula     C8H24N4O4Si;
CAS         7057-73-0;
InChIKey    MEIYXMYVJKNCGO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          268.389;      // g/mol [origin=calculated method=formula-sum]
Tc          968.17;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       1.3547;      // -   [origin=predictive method=lee-kesler]
Tb          763.84;      // K   [origin=predictive method=joback]
HvapTb      85900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (164.398 0.5524 0.0002738 -3.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2O; count 4; } { group CH2NH2; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group O; count 4; } { group NH2; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(2-azanylethyl) silicate" "tetrakis(" "a-aminoethoxy)silane" "tetrakis(.beta.-aminoethoxy)silane" "silicic acid (h4sio4), tetrakis(2-aminoethyl) ester" "ethanol, silicate (ester)" "tetrakis(2-aminoethyl) silicate" "tetrakis(beta-aminoethoxy)silane" "ethanol, 2-amino-, silicate (ester)" "ethanol, 2-amino-, tetraester with silicic acid (h4sio4)" );
standardThermochemistry
{
    dHf_298   -713790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     845.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242480.0
}
