/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentyl benzyl succinate  (C16H22O4, CAS 119450-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentylBenzylSuccinate;
formula     C16H22O4;
CAS         119450-13-4;
InChIKey    GVUYTZKKCMNYGB-UHFFFAOYSA-N;
MW          278.348;      // g/mol [origin=calculated method=formula-sum]
Tc          905.55;      // K   [origin=predictive method=joback]
Pc          17.175;      // bar [origin=predictive method=joback]
omega       0.9521;      // -   [origin=predictive method=lee-kesler]
Tb          708.80;      // K   [origin=predictive method=joback]
HvapTb      68300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.257 1.33532 -0.0006886 9.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-pentyl o4-(phenylmethyl) butanedioate" "1-benzyl 4-pentyl succinate" "butanedioic acid, pentyl phenylmethyl ester" "4-o-benzyl 1-o-pentyl butanedioate" );
standardThermochemistry
{
    dHf_298   -771600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-424490.0
}
