/*--------------------------------*- Choupo -*-----------------------*\
  Component: icosyl acrylate  (C23H44O2, CAS 48076-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        icosylAcrylate;
formula     C23H44O2;
CAS         48076-38-6;
InChIKey    NGYRYRBDIPYKTL-UHFFFAOYSA-N;
MW          352.603;      // g/mol [origin=calculated method=formula-sum]
Tc          957.45;      // K   [origin=predictive method=joback]
Pc          8.758;      // bar [origin=predictive method=joback]
omega       0.8295;      // -   [origin=predictive method=lee-kesler]
Tb          780.74;      // K   [origin=predictive method=joback]
HvapTb      73529.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.399 2.11402 -0.0011557 2.228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosyl prop-2-enoate" "2-propenoic acid, eicosyl ester" );
standardThermochemistry
{
    dHf_298   -709900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1098.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-79750.0
}
