/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7h-benzocyclohept-7-one,2,3-dimethyl-  (C13H16O, CAS 55027-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7hBenzocyclohept7One23Dimethyl;
formula     C13H16O;
CAS         55027-90-2;
InChIKey    CXCATVOZSHFPSU-UHFFFAOYSA-N;
MW          188.27;      // g/mol [origin=calculated method=formula-sum]
Tc          870.92;      // K   [origin=predictive method=joback]
Pc          26.791;      // bar [origin=predictive method=joback]
omega       0.5703;      // -   [origin=predictive method=lee-kesler]
Tb          626.43;      // K   [origin=predictive method=joback]
HvapTb      53607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.93 0.97134 -0.00045228 4.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethyl-5,6,8,9-tetrahydrobenzo[7]annulen-7-one" "2,3-dimethyl-5,6,8,9-tetrahydro-7h-benzo[7]annulen-7-one" );
standardThermochemistry
{
    dHf_298   -166410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63770.0
}
