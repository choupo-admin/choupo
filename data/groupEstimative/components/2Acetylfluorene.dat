/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetylfluorene  (C15H12O, CAS 781-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetylfluorene;
formula     C15H12O;
CAS         781-73-7;
InChIKey    IBASEVZORZFIIH-UHFFFAOYSA-N;
MW          208.26;      // g/mol [origin=calculated method=formula-sum]
Tc          912.56;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.7171;      // -   [origin=predictive method=lee-kesler]
Tb          667.84;      // K   [origin=predictive method=joback]
HvapTb      62146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.24 1.26112 -0.00100318 3.2186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 4; } { group ACCH2; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(9h-fluoren-2-yl)ethanone" "ethanone, 1-(9h-fluoren-2-yl)-" "2-acetofluorene" "2-fluorenyl methyl ketone" "fluoren-2-yl methyl ketone" "ketone, fluoren-2-yl methyl" "ethanone, 1-(9h-fluoren-2-yl)" "1-(9h-fluoren-2-yl)-ethanone" "l148" "ethanone, 1-(9h-fluoren-2-yl)- (9ci)" );
gibbsFormation
{
    dHf_298   78600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235090.0
    phase     gas;
}
