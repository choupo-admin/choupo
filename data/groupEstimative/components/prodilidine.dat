/*--------------------------------*- Choupo -*-----------------------*\
  Component: prodilidine  (C15H21NO2, CAS 3734-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prodilidine;
formula     C15H21NO2;
CAS         3734-17-6;
InChIKey    LUKSBMJXPCFBKO-UHFFFAOYSA-N;
MW          247.338;      // g/mol [origin=calculated method=formula-sum]
Tc          866.00;      // K   [origin=predictive method=joback]
Pc          21.493;      // bar [origin=predictive method=joback]
omega       0.7010;      // -   [origin=predictive method=lee-kesler]
Tb          646.72;      // K   [origin=predictive method=joback]
HvapTb      59335.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.349 1.82576 -0.0014924 5.123e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1,2-dimethyl-3-phenyl-pyrrolidin-3-yl) propanoate" "prodilidine [inn]" "1,2-dimethyl-3-phenyl-3-pyrrolidyl propionate" "prodilidinum [inn-latin]" "3-pyrrolidinol, 1,2-dimethyl-3-phenyl-, propionate" "1,2-dimethyl-3-phenyl-3-pyrrolidinol propionate (ester)" "propionic acid, 1,2-methyl-3-phenyl-3-pyrrolidinyl ester" "prodilidina" "prodilidinum" "(1,2-dimethyl-3-phenylpyrrolidin-3-yl) propanoate" );
standardThermochemistry
{
    dHf_298   -304610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23690.0
}
