name        agG82958;
formula     C29H62N2O4;
CAS         72018-18-9;
InChIKey    HFQZXLHPHQMYGX-UHFFFAOYSA-N;
MW          502.825;      // g/mol [origin=calculated method=formula-sum]
Tc          1648.53;      // K   [origin=predictive method=joback]
Pc          6.907;      // bar [origin=predictive method=joback]
omega       0.0082;      // -   [origin=predictive method=lee-kesler]
Tb          1218.39;      // K   [origin=predictive method=joback]
HvapTb      134274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.781 2.9311 -0.001504 2.381e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 20; } { group CH; count 2; } { group OH; count 2; } { group CH3N; count 1; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 21; } { group CH; count 2; } { group OH; count 2; } { group COOH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-(dimethylamino)propyl-(2-oxidanylpropyl)amino]propan-2-ol;octadecanoic acid" "octadecanoic acid compd. with 1,1'-[[3-(dimethylamino)propyl]imino]bis[2-propanol] (1:1)" "octadecanoic acid, compd. with 1,1'-((3-(dimethylamino)propyl)imino)bis(2-propanol) (1:1)" );
gibbsFormation
{
    dHf_298   -1283740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1561.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312330.0
    phase     gas;
}
