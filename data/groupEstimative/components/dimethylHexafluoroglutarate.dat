/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl hexafluoroglutarate  (C7H6F6O4, CAS 1513-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylHexafluoroglutarate;
formula     C7H6F6O4;
CAS         1513-62-8;
InChIKey    PJZVBCPDYSZAJU-UHFFFAOYSA-N;
MW          268.109;      // g/mol [origin=calculated method=formula-sum]
Tc          621.85;      // K   [origin=predictive method=joback]
Pc          22.828;      // bar [origin=predictive method=joback]
omega       0.7000;      // -   [origin=predictive method=lee-kesler]
Tb          462.13;      // K   [origin=predictive method=joback]
HvapTb      37200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.47 1.00744 -0.0007816 2.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CF2; count 3; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 3; } { group F; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2,2,3,3,4,4-hexakis(fluoranyl)pentanedioate" "dimethyl hexafluoropentanedioate" "hexafluoroglutaric acid dimethyl ester" "hfgde" "dimethyl perfluoroglutarate" "perfluoroglutaric acid dimethyl ester" "hexafluoropentanedioic acid dimethyl ester" "dimethyl 2,2,3,3,4,4-hexafluoropentanedioate" "pentanedioic acid, hexafluoro-, dimethyl ester" "1,5-dimethyl 2,2,3,3,4,4-hexafluoropentanedioate" "2,2,3,3,4,4-hexafluoropentanedioic acid dimethyl ester" "2,2,3,3,4,4-hexafluoro-pentanedioic acid dimethyl ester" );
gibbsFormation
{
    dHf_298   -2025280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1773020.0
    phase     gas;
}
