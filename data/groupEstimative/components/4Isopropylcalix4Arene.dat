/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-isopropylcalix[4]arene  (C40H48O4, CAS 97998-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Isopropylcalix4Arene;
formula     C40H48O4;
CAS         97998-55-5;
InChIKey    UHLRPXXFPYMCAE-UHFFFAOYSA-N;
MW          592.82;      // g/mol [origin=calculated method=formula-sum]
Tc          1995.07;      // K   [origin=predictive method=joback]
Pc          10.835;      // bar [origin=predictive method=joback]
omega       0.8254;      // -   [origin=predictive method=lee-kesler]
Tb          1597.76;      // K   [origin=predictive method=joback]
HvapTb      169932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-158.41 3.82216 -0.00300812 9.956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group ACH; count 8; } { group AC; count 4; } { group ACCH2; count 4; } { group ACCH; count 4; } { group ACOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 16; } { group OH_phenol; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,11,17,23-tetraisopropylpentacyclo[19.3.1.13,7.19,13.115,19]octacosa-1(25),3(28),4,6,9(27),10,12,15(26),16,18,21,23-dodecaene-25,26,27,28-tetrol" "5,11,17,23-tetraisopropylpentacyclo[19.3.1.1~3,7~.1~9,13~.1~15,19~]octacosa-1(25),3(28),4,6,9(27),10,12,15(26),16,18,21,23-dodecaene-25,26,27,28-tetrol" "5,11,17,23-tetrakis(methylethyl)pentacyclo[19.3.1.1<3,7>.1<9,13>.1<15,19>]octa cosa-1(24),3,5,7(26),9,11,13(27),15,17,19(28),21(25),22-dodecaene-25,26,27,28- tetraol" );
standardThermochemistry
{
    dHf_298   -657950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1278.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86640.0
}
