/*--------------------------------*- Choupo -*-----------------------*\
  Component: iridolactone  (C10H16O2, CAS 59121-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iridolactone;
formula     C10H16O2;
CAS         59121-25-4;
InChIKey    LYEFRAMOOLOUKA-XGEHTFHBSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          697.60;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.4829;      // -   [origin=predictive method=lee-kesler]
Tb          495.03;      // K   [origin=predictive method=joback]
HvapTb      44641.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.52 1.13824 -0.0007088 1.63e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s,4ar,7r,7as)-4,7-dimethyl-4,4a,5,6,7,7a-hexahydro-1h-cyclopenta[c]pyran-3-one" "isoiridomyrmecin" "(4s,4ar,7r,7as)-4,7-dimethylhexahydrocyclopenta[c]pyran-3(1h)-one" "cyclopenta(c)pyran-3(1h)-one, hexahydro-4,7-dimethyl-, (4s-(4-alpha,4a-alpha,7-alpha,7a-alpha))-" );
standardThermochemistry
{
    dHf_298   -468250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183070.0
}
