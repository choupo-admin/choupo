/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dichloroterephthalic acid  (C8H4Cl2O4, CAS 13799-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DichloroterephthalicAcid;
formula     C8H4Cl2O4;
CAS         13799-90-1;
InChIKey    LMOSYFZLPBHEOW-UHFFFAOYSA-N;
MW          235.016;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.15;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       1.2662;      // -   [origin=predictive method=lee-kesler]
Tb          790.14;      // K   [origin=predictive method=joback]
HvapTb      80762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.59 0.6216 -0.00042748 1.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group COOH; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(chloranyl)terephthalic acid" "2,5-dichlorobenzene-1,4-dicarboxylic acid" "terephthalic acid,5-dichloro-" "2,5-dichloro-terephthalic acid" "1,4-benzenedicarboxylicacid, 2,5-dichloro-" "1,4-benzenedicarboxylic acid, 2,5-dichloro-" );
gibbsFormation
{
    dHf_298   -738350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-611680.0
    phase     gas;
}
