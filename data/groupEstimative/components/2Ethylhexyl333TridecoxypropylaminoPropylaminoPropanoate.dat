/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl 3-[3-(3-tridecoxypropylamino)propylamino]propanoate  (C30H62N2O3, CAS 70776-25-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylhexyl333TridecoxypropylaminoPropylaminoPropanoate;
formula     C30H62N2O3;
CAS         70776-25-9;
InChIKey    GTOJKYWGQZTNST-UHFFFAOYSA-N;
MW          498.837;      // g/mol [origin=calculated method=formula-sum]
Tc          1355.17;      // K   [origin=predictive method=joback]
Pc          6.019;      // bar [origin=predictive method=joback]
omega       0.2306;      // -   [origin=predictive method=lee-kesler]
Tb          1066.54;      // K   [origin=predictive method=joback]
HvapTb      104675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.425 2.89416 -0.001503 2.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 21; } { group CH; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 25; } { group CH; count 1; } { group O; count 1; } { group COO; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "beta-alanine, n-(3-((3-(tridecyloxy)propyl)amino)propyl)-, 2-ethylhexyl ester" ".beta.-alanine, n-[3-[[3-(tridecyloxy)propyl]amino]propyl]-, 2-ethylhexyl ester" "3-((3-(3-tridecyloxypropyl)amino)propylamino)propionic acid, 2-ethylhexyl ester" );
gibbsFormation
{
    dHf_298   -1010370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1458.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37310.0
    phase     gas;
}
