/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-undecadien-2-one  (C11H18O, CAS 68973-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Undecadien2One;
formula     C11H18O;
CAS         68973-20-6;
InChIKey    RCFOEQFXUGQOMT-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          700.29;      // K   [origin=predictive method=joback]
Pc          22.525;      // bar [origin=predictive method=joback]
omega       0.6016;      // -   [origin=predictive method=lee-kesler]
Tb          513.47;      // K   [origin=predictive method=joback]
HvapTb      46742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.116 1.06084 -0.0007235 2.0546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undeca-3,5-dien-2-one" );
standardThermochemistry
{
    dHf_298   -148510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73260.0
}
