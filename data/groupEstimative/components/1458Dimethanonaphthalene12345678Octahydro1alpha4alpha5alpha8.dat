/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4:5,8-dimethanonaphthalene, 1,2,3,4,5,6,7,8-octahydro-, (1alpha,4alpha,5alpha,8alpha)-  (C12H16, CAS 73321-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458Dimethanonaphthalene12345678Octahydro1alpha4alpha5alpha8;
formula     C12H16;
CAS         73321-28-5;
InChIKey    WNOQFKCATWEQFU-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          731.30;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.4462;      // -   [origin=predictive method=lee-kesler]
Tb          510.24;      // K   [origin=predictive method=joback]
HvapTb      43574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-172.61 1.5724 -0.001363 4.832e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4:5,8-dimethano-4a,8a-(methanoxymethano)naphthalene-9,11-dione, octahydro-(1.alpha.,4.alpha.,4a.beta.,5.beta.,8.alpha.,8a.beta.)" "1,4:5,8-dimethano-4a,8a-(methanoxymethano)naphthalene-9,11-dione, octahydro-(1alpha,4alpha,4abeta,5beta,8alpha,8abeta)-" "1,4:5,8-dimethanonaphthalene, 1,2,3,4,5,6,7,8-octahydro-, (1.alpha.,4.alpha.,5.alpha.,8.alpha)-" "1,4:5,8-dimethanonaphthalene-, 1,2,3,4,5,6,7,8-octahydro-(1.alpha.,4.alpha.,5.beta.,8.beta.)" );
gibbsFormation
{
    dHf_298   35030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     212.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=303860.0
    phase     gas;
}
