/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-6-iodohexane  (C6H12ClI, CAS 34683-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro6Iodohexane;
formula     C6H12ClI;
CAS         34683-73-3;
InChIKey    QTJHNJCILMMRIQ-UHFFFAOYSA-N;
MW          246.512;      // g/mol [origin=calculated method=formula-sum]
Tc          674.49;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.4091;      // -   [origin=predictive method=lee-kesler]
Tb          467.45;      // K   [origin=predictive method=joback]
HvapTb      42708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.016 0.6196 -0.0004044 1.091e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2Cl; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-6-iodanyl-hexane" "hexamethylene chloroiodide" "hexane, 1-chloro-6-iodo-" "1-chloro-6-iodohexane;1-iodo-6-chlorohexane" );
standardThermochemistry
{
    dHf_298   -106040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45830.0
}
