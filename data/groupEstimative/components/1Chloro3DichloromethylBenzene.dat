/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-(dichloromethyl)benzene  (C7H5Cl3, CAS 15145-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro3DichloromethylBenzene;
formula     C7H5Cl3;
CAS         15145-69-4;
InChIKey    ACNQJGLSENYFQJ-UHFFFAOYSA-N;
MW          195.467;      // g/mol [origin=calculated method=formula-sum]
Tc          742.80;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.3843;      // -   [origin=predictive method=lee-kesler]
Tb          503.27;      // K   [origin=predictive method=joback]
HvapTb      46881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.91 0.5567 -0.00038556 9.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CHCl2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(chloranyl)methyl]-3-chloranyl-benzene" "3-chlorobenzal chloride" "alpha,alpha,3-trichlorotoluene" "1-(dichloromethyl)-3-chlorobenzene" "benzene,1-chloro-3-(dichloromethyl)-" "toluene,m,a,a-trichloro- (8ci);3-chlorobenzal chloride;3-chlorobenzylidene chloride;m,a,a-trichlorotoluene;m-chlorobenzal chloride;" );
standardThermochemistry
{
    dHf_298   -15250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72610.0
}
