/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethylcyclopentadiene  (C9H14, CAS 4249-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetramethylcyclopentadiene;
formula     C9H14;
CAS         4249-10-9;
InChIKey    VNPQQEYMXYCAEZ-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          644.93;      // K   [origin=predictive method=joback]
Pc          28.999;      // bar [origin=predictive method=joback]
omega       0.3731;      // -   [origin=predictive method=lee-kesler]
Tb          443.71;      // K   [origin=predictive method=joback]
HvapTb      39426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.04 0.66708 -0.000355 7.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 1; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetramethylcyclopenta-1,3-diene" "1,2,3,4-tetramethyl-1,3-cyclopentadiene" "1,2,3,4-tetramethylcyclopentadiene" "1,3-cyclopentadiene, tetramethyl-" );
gibbsFormation
{
    dHf_298   -78590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90560.0
    phase     gas;
}
