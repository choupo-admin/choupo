/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylstilbestrol dipalmitate  (C50H80O4, CAS 63019-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylstilbestrolDipalmitate;
formula     C50H80O4;
CAS         63019-08-9;
InChIKey    JUHYOIKJCUMOSQ-QJGAVIKSSA-N;
MW          745.186;      // g/mol [origin=calculated method=formula-sum]
Tc          2279.91;      // K   [origin=predictive method=joback]
Pc          3.541;      // bar [origin=predictive method=joback]
omega       -0.5095;      // -   [origin=predictive method=lee-kesler]
Tb          1527.28;      // K   [origin=predictive method=joback]
HvapTb      147702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.52 4.38728 -0.00252372 5.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 28; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 30; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[(e)-4-(4-hexadecanoyloxyphenyl)hex-3-en-3-yl]phenyl] hexadecanoate" "4,4'-dihydroxy-alpha,beta-diethylstilbene palmitate" "4,4'-stilbenediol, alpha,alpha'-diethyl-, dipalmitate" "4-{4-[4-(hexadecanoyloxy)phenyl]hex-3-en-3-yl}phenyl hexadecanoate" );
gibbsFormation
{
    dHf_298   -1162130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1966.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18060.0
    phase     gas;
}
