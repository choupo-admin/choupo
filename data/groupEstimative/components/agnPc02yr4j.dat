/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-02yr4j  (C11H15Cl, CAS 4830-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc02yr4j;
formula     C11H15Cl;
CAS         4830-95-9;
InChIKey    JRIPTFISENCJRO-UHFFFAOYSA-N;
MW          182.691;      // g/mol [origin=calculated method=formula-sum]
Tc          733.23;      // K   [origin=predictive method=joback]
Pc          25.328;      // bar [origin=predictive method=joback]
omega       0.4636;      // -   [origin=predictive method=lee-kesler]
Tb          519.93;      // K   [origin=predictive method=joback]
HvapTb      47015.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.508 0.92314 -0.00056236 1.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-(3-methylbutyl)benzene" "3-chloro-3-methylbutylbenzene" "1-chloro-3-(3-methylbutyl)benzene" );
gibbsFormation
{
    dHf_298   -66330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130150.0
    phase     gas;
}
