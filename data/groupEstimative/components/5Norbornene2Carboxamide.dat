/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-norbornene-2-carboxamide  (C8H11NO, CAS 95-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Norbornene2Carboxamide;
formula     C8H11NO;
CAS         95-17-0;
InChIKey    ZTUUVDYQBLRAAC-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          748.69;      // K   [origin=predictive method=joback]
Pc          40.159;      // bar [origin=predictive method=joback]
omega       0.5682;      // -   [origin=predictive method=lee-kesler]
Tb          521.28;      // K   [origin=predictive method=joback]
HvapTb      50770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.42 1.0074 -0.00076198 2.3066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]hept-2-ene-5-carboxamide" "bicyclo[2.2.1]hept-5-ene-2-carboxamide" "2-norbornene-5-exo-carboxamide" "2-norbornene-5-endo-carboxamide" "bicyclo(2.2.1)-5-heptene-2-carboxamide" "bicyclo[2.2.1]-5-heptene-2-carboxamide" "bicyclo(2.2.1)hept-5-ene-2-carboxamide, exo-" "bicyclo[2.2.1]hept-5-ene-2-carboxamide, exo-" "bicyclo(2.2.1)hept-5-ene-2-carboxamide, endo-" "bicyclo[2.2.1]hept-5-ene-2-carboxamide, endo-" "agn-pc-00hmr7" "sdccgmls-0065889.p001" );
gibbsFormation
{
    dHf_298   -110360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85660.0
    phase     gas;
}
