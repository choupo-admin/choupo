/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-1,1,1-trichloropropane  (C3H4BrCl3, CAS 13749-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo111Trichloropropane;
formula     C3H4BrCl3;
CAS         13749-37-6;
InChIKey    PUNXOOKBNWKKKR-UHFFFAOYSA-N;
MW          226.319;      // g/mol [origin=calculated method=formula-sum]
Tc          669.68;      // K   [origin=predictive method=joback]
Pc          42.775;      // bar [origin=predictive method=joback]
omega       0.3542;      // -   [origin=predictive method=lee-kesler]
Tb          443.46;      // K   [origin=predictive method=joback]
HvapTb      40566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.552 0.4732 -0.0004438 1.575e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CCl3; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group Cl; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-1,1,1-tris(chloranyl)propane" "propane, 3-bromo-1,1,1-trichloro-" "1,1,1-trichloro-3-bromopropane" "3-bromo-1,1,1-trichloro propane" );
gibbsFormation
{
    dHf_298   -134890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-44250.0
    phase     gas;
}
