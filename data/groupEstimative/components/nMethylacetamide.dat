/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylacetamide  (C3H7NO, CAS 79-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylacetamide;
formula     C3H7NO;
CAS         79-16-3;
InChIKey    OHLUUHNLEMFGTQ-UHFFFAOYSA-N;
MW          73.095;      // g/mol [origin=calculated method=formula-sum]
Tc          557.98;      // K   [origin=predictive method=joback]
Pc          48.902;      // bar [origin=predictive method=joback]
omega       0.4341;      // -   [origin=predictive method=lee-kesler]
Tb          372.28;      // K   [origin=predictive method=joback]
HvapTb      35454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.31 0.33704 -0.0001693 2.596e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylethanamide" "methylacetamide" "acetamide, n-methyl-" "monomethylacetamide" "acetylmethylamine" "methyl acetamide" "n-methyl acetamide" "n-methyl-acetamide" "acetamide, methyl-" "n-monomethylacetamide" "n-acetyl-n-methylamine" "x 44" );
gibbsFormation
{
    dHf_298   -164360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65150.0
    phase     gas;
}
