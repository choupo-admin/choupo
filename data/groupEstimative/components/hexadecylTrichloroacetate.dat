/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecyl trichloroacetate  (C18H33Cl3O2, CAS 74339-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexadecylTrichloroacetate;
formula     C18H33Cl3O2;
CAS         74339-54-1;
InChIKey    CCFJXGUHYQBXDT-UHFFFAOYSA-N;
MW          387.81;      // g/mol [origin=calculated method=formula-sum]
Tc          964.86;      // K   [origin=predictive method=joback]
Pc          10.871;      // bar [origin=predictive method=joback]
omega       0.9081;      // -   [origin=predictive method=lee-kesler]
Tb          778.72;      // K   [origin=predictive method=joback]
HvapTb      74928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.135 1.80522 -0.0010938 2.448e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group C; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecyl 2,2,2-tris(chloranyl)ethanoate" "trichloroacetic acid, hexadecyl ester" "hexadecyl 2,2,2-trichloroacetate" "acetic acid,2,2,2-trichloro-, hexadecyl ester" "aceticacid, trichloro-, hexadecyl ester (6ci,9ci); hexadecyl trichloroacetate" );
gibbsFormation
{
    dHf_298   -788100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     969.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242640.0
    phase     gas;
}
