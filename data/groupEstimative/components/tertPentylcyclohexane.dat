/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-pentylcyclohexane  (C11H22, CAS 31797-64-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertPentylcyclohexane;
formula     C11H22;
CAS         31797-64-5;
InChIKey    HEOYZKPYPRYIAR-UHFFFAOYSA-N;
MW          154.297;      // g/mol [origin=calculated method=formula-sum]
Tc          675.12;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.3220;      // -   [origin=predictive method=lee-kesler]
Tb          467.60;      // K   [origin=predictive method=joback]
HvapTb      39213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.189 1.29676 -0.0008274 2.012e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbutan-2-ylcyclohexane" "cyclohexane, tert-pentyl-" "tert-amylcyclohexane" "2-cyclohexyl-2-methylbutane" "cyclohexane, (1,1-dimethylpropyl)-" "2-methyl-2-cyclohexylbutane" "cyclohexane,1-dimethylpropyl)-" "(2-methylbutan-2-yl)cyclohexane" );
gibbsFormation
{
    dHf_298   -224800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69030.0
    phase     gas;
}
