/*--------------------------------*- Choupo -*-----------------------*\
  Component: firemaster 680  (C14H8Br6O2, CAS 37853-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        firemaster680;
formula     C14H8Br6O2;
CAS         37853-59-1;
InChIKey    YATIGPZCMOYEGE-UHFFFAOYSA-N;
MW          687.64;      // g/mol [origin=calculated method=formula-sum]
Tc          1334.71;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       1.5374;      // -   [origin=predictive method=lee-kesler]
Tb          1044.96;      // K   [origin=predictive method=joback]
HvapTb      98712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (108.292 0.9218 -0.00060436 1.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 8; } { group CH2O; count 2; } { group Br; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Br; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(bromanyl)-2-[2-[2,4,6-tris(bromanyl)phenoxy]ethoxy]benzene" "1,2-bis(tribromophenoxy)ethane" "benzene, 1,1'-[1,2-ethanediylbis(oxy)]bis[2,4,6-tribromo-" "ethane, 1,2-bis(2,4,6-tribromophenoxy)-" "1,1'-(ethane-1,2-diylbisoxy)bis(2,4,6-tribromobenzene)" "1,1'-(1,2-ethanediylbis(oxy))bis(2,4,6-tribromobenzene)" "benzene, 1,1'-(1,2-ethanediylbis(oxy))bis(2,4,6-tribromo-" "1,1'-[ethane-1,2-diylbis(oxy)]bis(2,4,6-tribromobenzene)" "btbpe" "1,2-bis2,4,6-tribromophenoxy;ethane" "1,2-bis(2,4,6-tribromo-phenoxy)ethane" "bis-1,2-(2,4,6-tribromophenoxy)ethane" );
gibbsFormation
{
    dHf_298   -34510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109960.0
    phase     gas;
}
