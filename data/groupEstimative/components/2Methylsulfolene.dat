/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylsulfolene  (C5H8O2S, CAS 6007-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H8O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Methylsulfolene;
formula     C5H8O2S;
CAS         6007-71-2;
InChIKey    GQKSMJWYXJEVRA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          132.177;      // g/mol [origin=calculated method=formula-sum]
Tc          462.26;      // K   [origin=predictive method=joback]
Pc          50.948;      // bar [origin=predictive method=joback]
omega       0.3750;      // -   [origin=predictive method=lee-kesler]
Tb          303.17;      // K   [origin=predictive method=joback]
HvapTb      38919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.6 0.60332 -0.00038388 8.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CH2SuCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-2,5-dihydrothiophene 1,1-dioxide" "2-methylsulfol-3-ene" "2,5-dihydro-2-methylthiophene 1,1-dioxide" "thiophene, 2,5-dihydro-2-methyl-, 1,1-dioxide" "2-methyl-2,5-dihydrothiophene-1,1-dione" "2,5-dihydro-2-methyl-thiophene 1,1-dioxide" );
gibbsFormation
{
    dHf_298   -517330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-431830.0
    phase     gas;
}
