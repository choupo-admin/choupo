/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-but-2-enedioic acid; 1,2,3,4,7,7-hexachlorobicyclo[2.2.1]hept-2-ene-5,6-dicarboxylic acid; propane-1,2-diol  (C16H16Cl6O10, CAS 52182-13-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eBut2EnedioicAcid123477Hexachlorobicyclo221Hept2Ene56Dicarbo;
formula     C16H16Cl6O10;
CAS         52182-13-5;
InChIKey    HDGHPLOYOUVPSI-JITBQSAISA-N;
MW          580.994;      // g/mol [origin=calculated method=formula-sum]
Tc          2015.68;      // K   [origin=predictive method=joback]
Pc          20.199;      // bar [origin=predictive method=joback]
omega       1.0625;      // -   [origin=predictive method=lee-kesler]
Tb          1576.76;      // K   [origin=predictive method=joback]
HvapTb      176926.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.939 2.36272 -0.0022564 9.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 3; } { group CH=CH; count 1; } { group OH; count 2; } { group COOH; count 4; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group OH; count 2; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;1,2,3,4,7,7-hexakis(chloranyl)bicyclo[2.2.1]hept-2-ene-5,6-dicarboxylic acid;propane-1,2-diol" "bicyclo(2.2.1)hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-, polymer with (2e)-2-butenedioic acid and 1,2-propanediol" );
gibbsFormation
{
    dHf_298   -2125870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1364.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1688260.0
    phase     gas;
}
