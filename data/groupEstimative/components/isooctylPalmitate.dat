/*--------------------------------*- Choupo -*-----------------------*\
  Component: isooctyl palmitate  (C24H48O2, CAS 1341-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isooctylPalmitate;
formula     C24H48O2;
CAS         1341-38-4;
InChIKey    CJSPFDQEYQBDNN-UHFFFAOYSA-N;
MW          368.646;      // g/mol [origin=calculated method=formula-sum]
Tc          987.72;      // K   [origin=predictive method=joback]
Pc          8.121;      // bar [origin=predictive method=joback]
omega       0.7754;      // -   [origin=predictive method=lee-kesler]
Tb          806.50;      // K   [origin=predictive method=joback]
HvapTb      76037.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.799 2.23496 -0.0011904 2.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 19; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methylheptyl hexadecanoate" "6-methylheptyl palmitate" "palmitic acid, isooctyl ester" "usaf ke-1" "hexadecanoic acid isooctyl ester" "o-16" "palmitic acid, iso octyl ester" "palmitic acid, isooctyl ester (8ci)" "o207" "palmiticacid, isooctyl ester (8ci);hexadecanoic acid,isooctyl ester;o 16;" );
standardThermochemistry
{
    dHf_298   -861250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1132.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161610.0
}
