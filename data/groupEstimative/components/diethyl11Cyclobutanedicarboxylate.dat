/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 1,1-cyclobutanedicarboxylate  (C10H16O4, CAS 3779-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl11Cyclobutanedicarboxylate;
formula     C10H16O4;
CAS         3779-29-1;
InChIKey    JPNJEJSZSMXWSV-UHFFFAOYSA-N;
MW          200.234;      // g/mol [origin=calculated method=formula-sum]
Tc          756.63;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.6896;      // -   [origin=predictive method=lee-kesler]
Tb          556.09;      // K   [origin=predictive method=joback]
HvapTb      51602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.738 1.27744 -0.0010374 3.61e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl cyclobutane-1,1-dicarboxylate" "1,1-cyclobutanedicarboxylic acid, diethyl ester" "cyclobutane-1,1-dicarboxylic acid diethyl ester" "1,1-diethyl cyclobutane-1,1-dicarboxylate" "1,1-cyclobutanedicarboxylic acid, 1,1-diethyl ester" "ethyl 1-(ethoxycarbonyl)cyclobutanecarboxylate" "o990" "1,1-cyclobutanedicarboxylic acid diethyl ester" );
standardThermochemistry
{
    dHf_298   -802410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     647.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-544260.0
}
