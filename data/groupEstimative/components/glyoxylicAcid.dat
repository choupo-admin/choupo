/*--------------------------------*- Choupo -*-----------------------*\
  Component: glyoxylic acid  (C2H2O3, CAS 298-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glyoxylicAcid;
formula     C2H2O3;
CAS         298-12-4;
InChIKey    HHLFWLYXYJOTON-UHFFFAOYSA-N;
MW          74.035;      // g/mol [origin=calculated method=formula-sum]
Tc          643.33;      // K   [origin=predictive method=joback]
Pc          64.308;      // bar [origin=predictive method=joback]
omega       0.6564;      // -   [origin=predictive method=lee-kesler]
Tb          439.53;      // K   [origin=predictive method=joback]
HvapTb      43930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.07 0.2191 -0.0001506 3.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group OdCH_al; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxaldehydic acid" "oxoacetic acid" "oxoethanoic acid" "formylformic acid" "acetic acid, oxo-" "glyoxalic acid" "oxalaldehydic acid" "glyoxylate" "alpha-ketoacetic acid" "glyoxalate" "formic acid, formyl-" "2-oxoacetic acid" );
standardThermochemistry
{
    dHf_298   -520460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-477470.0
}
