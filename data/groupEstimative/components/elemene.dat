/*--------------------------------*- Choupo -*-----------------------*\
  Component: elemene  (C15H24, CAS 100762-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        elemene;
formula     C15H24;
CAS         100762-52-5;
InChIKey    OPFTUNCRGUEPRZ-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          754.41;      // K   [origin=predictive method=joback]
Pc          18.294;      // bar [origin=predictive method=joback]
omega       0.3891;      // -   [origin=predictive method=lee-kesler]
Tb          543.05;      // K   [origin=predictive method=joback]
HvapTb      45794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.82 1.72966 -0.0013683 4.743e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-1-methyl-2,4-bis(prop-1-en-2-yl)cyclohexane" "beta-elemene, (-)-" "beta-elemen" "levo-beta-elemene" "(-)-beta-elemene" "cyclohexane, 2,4-diisopropenyl-1-methyl-1-vinyl-, (1s,2s,4r)-" "cyclohexane, 1-ethenyl-1-methyl-2,4-bis(1-methylethenyl)-, (1r,2r,4s)-rel-" "cyclohexane, 1-ethenyl-1-methyl-2,4-bis(1-methylethenyl)-, (1s-(1-alpha,2-beta,4-beta))-" "2,4-diisopropenyl-1-methyl-1-vinylcyclohexane" "(- )-bete-elemene" "cyclohexane, 2,4-diisopropenyl-1-methyl-1-vinyl-, (1s,2r,4r)- (-)-" "cyclohexane, 1-ethenyl-1-methyl-2,4-bis(1-methylethenyl)-, [1s-(1.alpha.,2.beta.,4.beta.)]-" );
gibbsFormation
{
    dHf_298   32660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=325380.0
    phase     gas;
}
