/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl(e,z)-decadienoate  (C12H20O2, CAS 3025-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylEZDecadienoate;
formula     C12H20O2;
CAS         3025-30-7;
InChIKey    OPCRGEVPIBLWAY-QNRZBPGKSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          721.75;      // K   [origin=predictive method=joback]
Pc          19.561;      // bar [origin=predictive method=joback]
omega       0.6694;      // -   [origin=predictive method=lee-kesler]
Tb          540.70;      // K   [origin=predictive method=joback]
HvapTb      49629.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.975 1.12904 -0.000702 1.693e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH=CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (2e,4z)-deca-2,4-dienoate" "ethyl 2-trans-4-cis-decadienoate" "ethyl trans-2,cis-4-decadienoate" "ethyl (2e,4z)-decadienoate" "ethyl-2-trans-4-cis-decadienoate" "ethyl (2e,4z)-2,4-decadienoate" "ethyl 2,4-decadienoate, (e,z)-" "2,4-decadienoic acid, ethyl ester, (2e,4z)-" "ethyl 2e,4z-decadienoate" "ethyl trans-2-cis-4-decandienoate" "ethyl 2,4-decadienoate, (2e,4z)-" "(2e,4z)-2,4-decadienoic acid, ethyl ester" );
standardThermochemistry
{
    dHf_298   -373850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99770.0
}
