/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenediol, polymer with 2-propen-1-ol  (C9H12O3, CAS 42425-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenediolPolymerWith2Propen1Ol;
formula     C9H12O3;
CAS         42425-45-6;
InChIKey    DVYYBJAZNUJPRQ-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          903.37;      // K   [origin=predictive method=joback]
Pc          51.609;      // bar [origin=predictive method=joback]
omega       1.2618;      // -   [origin=predictive method=lee-kesler]
Tb          678.72;      // K   [origin=predictive method=joback]
HvapTb      79573.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.219 0.9564 -0.00071526 2.225e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 4; } { group OH; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-diol;prop-2-en-1-ol" "benzene-1,3-diol; prop-2-en-1-ol" );
standardThermochemistry
{
    dHf_298   -474130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-316040.0
}
