/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-62308  (C8H8, CAS 68344-46-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG62308;
formula     C8H8;
CAS         68344-46-7;
InChIKey    LYOVKFLAWXSXHW-UHFFFAOYSA-N;
MW          104.152;      // g/mol [origin=calculated method=formula-sum]
Tc          651.65;      // K   [origin=predictive method=joback]
Pc          43.511;      // bar [origin=predictive method=joback]
omega       0.2094;      // -   [origin=predictive method=lee-kesler]
Tb          414.18;      // K   [origin=predictive method=joback]
HvapTb      36876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.81 0.6506 -0.00043022 1.0918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloocta-1,5-dien-3-yne" );
standardThermochemistry
{
    dHf_298   254070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=311360.0
}
