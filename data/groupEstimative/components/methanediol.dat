/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanediol  (CH4O2, CAS 463-57-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methanediol;
formula     CH4O2;
CAS         463-57-0;
InChIKey    CKFGINPQOCXMAZ-UHFFFAOYSA-N;
MW          48.041;      // g/mol [origin=calculated method=formula-sum]
Tc          567.16;      // K   [origin=predictive method=joback]
Pc          78.315;      // bar [origin=predictive method=joback]
omega       1.0694;      // -   [origin=predictive method=lee-kesler]
Tb          406.84;      // K   [origin=predictive method=joback]
HvapTb      51178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.561 0.1668 -9.14e-05 2.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dihydroxymethane" "ketone hydrates" "methanediol-" "aldehyde hydrates" "methylene glycol;" "formaldehyde hydrate" "methanediol(6ci,7ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   -368430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     296.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-316100.0
    phase     gas;
}
