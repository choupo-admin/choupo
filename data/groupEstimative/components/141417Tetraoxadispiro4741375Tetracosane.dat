/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,14,17-tetraoxadispiro[4.7.4^{13}.7^{5}]tetracosane  (C20H36O4, CAS 38734-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        141417Tetraoxadispiro4741375Tetracosane;
formula     C20H36O4;
CAS         38734-12-2;
InChIKey    LAGFFXOAJQCRNL-UHFFFAOYSA-N;
MW          340.504;      // g/mol [origin=calculated method=formula-sum]
Tc          1136.45;      // K   [origin=predictive method=joback]
Pc          19.136;      // bar [origin=predictive method=joback]
omega       0.6824;      // -   [origin=predictive method=lee-kesler]
Tb          854.42;      // K   [origin=predictive method=joback]
HvapTb      78480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-279.47 2.8108 -0.0020938 6.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 14; } { group C; count 2; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 18; } { group C_ring; count 2; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -807310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     939.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229480.0
    phase     gas;
}
