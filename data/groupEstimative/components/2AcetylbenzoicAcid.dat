/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetylbenzoic acid  (C9H8O3, CAS 577-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AcetylbenzoicAcid;
formula     C9H8O3;
CAS         577-56-0;
InChIKey    QDAWXRKTSATEOP-UHFFFAOYSA-N;
MW          164.16;      // g/mol [origin=calculated method=formula-sum]
Tc          868.71;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.8781;      // -   [origin=predictive method=lee-kesler]
Tb          636.56;      // K   [origin=predictive method=joback]
HvapTb      62476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.94 0.74322 -0.00048386 1.1546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethanoylbenzoic acid" "o-acetylbenzoic acid" "2-acetylbenzoicacid" "acetophenone-2-carboxylic acid" "2-acetyl-benzoic acid" "benzoic acid, 2-acetyl-" "2'-acetophenonecarboxylic acid" "3-hydroxy-3-methylphthalide; acetophenone-2-carboxylic acid" );
gibbsFormation
{
    dHf_298   -466880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-345150.0
    phase     gas;
}
