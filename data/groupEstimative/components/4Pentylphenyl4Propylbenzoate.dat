/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentylphenyl 4-propylbenzoate  (C21H26O2, CAS 50649-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentylphenyl4Propylbenzoate;
formula     C21H26O2;
CAS         50649-60-0;
InChIKey    WNBFPAKRCJNBBS-UHFFFAOYSA-N;
MW          310.437;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.41;      // K   [origin=predictive method=joback]
Pc          14.827;      // bar [origin=predictive method=joback]
omega       0.9089;      // -   [origin=predictive method=lee-kesler]
Tb          801.62;      // K   [origin=predictive method=joback]
HvapTb      75623.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.004 1.66724 -0.00095232 1.828e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-pentylphenyl) 4-propylbenzoate" "benzoic acid, 4-propyl-, 4-pentylphenyl ester" "4-propylbenzoic acid (4-pentylphenyl) ester" "4-(n-propyl)benzoic acid-4'-(n-pentyl)phenol ester" );
standardThermochemistry
{
    dHf_298   -343930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     800.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21130.0
}
