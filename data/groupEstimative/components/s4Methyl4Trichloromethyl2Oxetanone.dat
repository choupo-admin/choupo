/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-4-methyl-4-(trichloromethyl)-2-oxetanone  (C5H5Cl3O2, CAS 93206-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s4Methyl4Trichloromethyl2Oxetanone;
formula     C5H5Cl3O2;
CAS         93206-60-1;
InChIKey    MIYJBPXTAZJPGX-BYPYZUCNSA-N;
MW          203.443;      // g/mol [origin=calculated method=formula-sum]
Tc          710.23;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       0.4303;      // -   [origin=predictive method=lee-kesler]
Tb          483.99;      // K   [origin=predictive method=joback]
HvapTb      44580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.16 1.02262 -0.0011858 5.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group CH2COO; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group CH2_ring; count 1; } { group C_ring; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s)-4-methyl-4-(trichloromethyl)oxetan-2-one" "(s)-(-)-4-methyl-4-(trichloromethyl)-2-oxetanone" "(s)-(-)-3-hydroxy-3-methyl-4,4,4-trichlorobutyric " "a-lactone" );
standardThermochemistry
{
    dHf_298   -425580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-284740.0
}
