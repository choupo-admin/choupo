/*--------------------------------*- Choupo -*-----------------------*\
  Component: adiphenine  (C20H25NO2, CAS 64-95-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adiphenine;
formula     C20H25NO2;
CAS         64-95-9;
InChIKey    JGOAIQNSOGZNBX-UHFFFAOYSA-N;
MW          311.425;      // g/mol [origin=calculated method=formula-sum]
Tc          998.50;      // K   [origin=predictive method=joback]
Pc          16.458;      // bar [origin=predictive method=joback]
omega       0.9119;      // -   [origin=predictive method=lee-kesler]
Tb          780.78;      // K   [origin=predictive method=joback]
HvapTb      73728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.066 1.82104 -0.0011478 2.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 2,2-diphenylethanoate" "spasmolytin" "difacil" "diphacyl" "trasentine" "transentine" "adiphenin" "diphacil" "patrovine" "tranzetil" "trasentin" "vegantine" );
standardThermochemistry
{
    dHf_298   -238100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140310.0
}
