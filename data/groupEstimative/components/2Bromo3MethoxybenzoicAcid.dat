/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-3-methoxybenzoic acid  (C8H7BrO3, CAS 88377-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo3MethoxybenzoicAcid;
formula     C8H7BrO3;
CAS         88377-29-1;
InChIKey    AOGGEUOQUYCZAH-UHFFFAOYSA-N;
MW          231.045;      // g/mol [origin=calculated method=formula-sum]
Tc          892.93;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.9136;      // -   [origin=predictive method=lee-kesler]
Tb          653.37;      // K   [origin=predictive method=joback]
HvapTb      63011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.6 0.59172 -0.00034152 6.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-3-methoxy-benzoic acid" "2-bromo-3-methoxybenzoicacid" "benzoic acid,2-bromo-3-methoxy-" );
standardThermochemistry
{
    dHf_298   -451020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-324960.0
}
