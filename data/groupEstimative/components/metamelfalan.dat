/*--------------------------------*- Choupo -*-----------------------*\
  Component: metamelfalan  (C13H18Cl2N2O2, CAS 1088-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        metamelfalan;
formula     C13H18Cl2N2O2;
CAS         1088-78-4;
InChIKey    QDGAVODICPCDMU-UHFFFAOYSA-N;
MW          305.199;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.49;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       1.2507;      // -   [origin=predictive method=lee-kesler]
Tb          833.60;      // K   [origin=predictive method=joback]
HvapTb      85700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.035 1.3565 -0.00092016 2.38e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHNH2; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COOH; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-[3-[bis(2-chloroethyl)amino]phenyl]propanoic acid" "m-dl-sarcolysin" "m-dl-sarcolysine" "m-l-sarcolysin" "metamelfalanum [inn-latin]" "3-(bis(2-chloroethyl)amino)-l-phenylalanine" "3-(bis(2-chloroethyl)amino)-dl-phenylalanine" "l-3-(m-(bis(2-chloroethyl)amino)phenyl)alanine" "3-(m-(bis(2-chloroethyl)amino)phenyl)-l-alanine" "3-(m-(bis(2-chloroethyl)amino)phenyl)-dl-alanine" "dl-alanine, 3-(m-(bis(2-chloroethyl)amino)phenyl)-" "alanine, 3-(m-(bis(2-chloroethyl)amino)phenyl)-, l-" );
gibbsFormation
{
    dHf_298   -372300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     727.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31620.0
    phase     gas;
}
