/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-butoxypropyl)-2-methylpiperidine  (C13H27NO, CAS 65000-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butoxypropyl2Methylpiperidine;
formula     C13H27NO;
CAS         65000-33-1;
InChIKey    QJOAUKVCMSZLOA-UHFFFAOYSA-N;
MW          213.365;      // g/mol [origin=calculated method=formula-sum]
Tc          727.84;      // K   [origin=predictive method=joback]
Pc          18.822;      // bar [origin=predictive method=joback]
omega       0.6721;      // -   [origin=predictive method=lee-kesler]
Tb          547.18;      // K   [origin=predictive method=joback]
HvapTb      49242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.604 1.43124 -0.0008124 1.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-butoxypropyl)-2-methyl-piperidine" "1-(3'-butoxy)propyl-2-methylpiperidine" "piperidine, 1-(3'-butoxy)propyl-2-methyl-" );
standardThermochemistry
{
    dHf_298   -315860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100910.0
}
