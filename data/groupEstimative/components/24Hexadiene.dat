/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-hexadiene  (C6H10, CAS 592-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Hexadiene;
formula     C6H10;
CAS         592-46-1;
InChIKey    APPOKADJQUIAHP-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          527.31;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.2412;      // -   [origin=predictive method=lee-kesler]
Tb          345.20;      // K   [origin=predictive method=joback]
HvapTb      28866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.93 0.61384 -0.0004702 1.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-2,4-diene" "2,4-hexadiene, (2e)-" "cis-2-trans-4-hexadiene" "2,4-hexadiene, (2e,4e)-" "agn-pc-03pmqo" "agn-pc-0cz8oc" "2,4-hexadiene, (2e,4z)-" "2,4-hexadiene, (2z,4z)-" "2,4-hexadiene,(z,z)- (8ci,9ci); (z,z)-2,4-hexadiene; cis,cis-2,4-hexadiene" "2,4-hexadiene,(e,e)- (8ci,9ci);(2e,4e)-2,4-hexadiene;(2e,4e)-hexadiene;(e,e)-2,4-hexadiene;trans,trans-1,4-dimethyl-1,3-butadiene;trans,trans-2,4-hexadiene;(2e,4e)-hexa-2,4-diene;2,4-hexadiene, (e,z)-;" "2,4-hexadiene,(e,z)- (8ci,9ci);(2e,4z)-2,4-hexadiene;(2e,4z)-hexadiene;(e,z)-2,4-hexadiene;2-cis-4-trans-hexadiene;cis,trans-2,4-hexadiene;cis-2-trans-4-hexadiene;trans,cis-2,4-hexadiene;trans-2-cis-4-hexadiene;" );
gibbsFormation
{
    dHf_298   67270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160080.0
    phase     gas;
}
