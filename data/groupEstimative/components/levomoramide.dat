/*--------------------------------*- Choupo -*-----------------------*\
  Component: levomoramide  (C25H32N2O2, CAS 13013-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        levomoramide;
formula     C25H32N2O2;
CAS         13013-15-5;
InChIKey    INUNXTSAACVKJS-UHFFFAOYSA-N;
MW          392.543;      // g/mol [origin=calculated method=formula-sum]
Tc          1213.85;      // K   [origin=predictive method=joback]
Pc          16.285;      // bar [origin=predictive method=joback]
omega       1.0464;      // -   [origin=predictive method=lee-kesler]
Tb          962.62;      // K   [origin=predictive method=joback]
HvapTb      90414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-238.229 2.89552 -0.0021782 6.3106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 8; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-4-morpholin-4-yl-2,2-diphenyl-1-pyrrolidin-1-yl-butan-1-one" "dextromoramide" "racemoramide" "levoramide" "levomoramidum [inn-latin]" "palfium" "palphium" "(-)-2,2-diphenyl-3-methyl-4-morpholinobutyrylpyrrolidine" "(-)-4-(2-methyl-4-oxo-3,3-diphenyl-4-(1-pyrrolidinyl)butyl)morpholine" "pyrrolidine, 1-(2,2-diphenyl-3-methyl-4-morpholinobutyryl)-, (-)-" "pyrrolidine, 1-[3-methyl-4-(4-morpholinyl)-1-oxo-2,2-diphenylbutyl]-, (.+/-.)-" "pyrrolidine, 1-[3-methyl-4-(4-morpholinyl)-1-oxo-2,2-diphenylbutyl]-, (r)-" );
gibbsFormation
{
    dHf_298   -42020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     840.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=491980.0
    phase     gas;
}
