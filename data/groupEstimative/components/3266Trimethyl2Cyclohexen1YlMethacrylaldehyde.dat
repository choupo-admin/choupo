/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2,6,6-trimethyl-2-cyclohexen-1-yl)methacrylaldehyde  (C13H20O, CAS 67801-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3266Trimethyl2Cyclohexen1YlMethacrylaldehyde;
formula     C13H20O;
CAS         67801-14-3;
InChIKey    LAGYWBZWJKHOOJ-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          785.95;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.5282;      // -   [origin=predictive method=lee-kesler]
Tb          569.00;      // K   [origin=predictive method=joback]
HvapTb      51213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.98 1.50528 -0.00124094 4.493e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-(2,6,6-trimethylcyclohex-2-en-1-yl)prop-2-enal" "2-propenal, 2-methyl-3-(2,6,6-trimethyl-2-cyclohexen-1-yl)-" "(z)-2-methyl-3-(2,6,6-trimethylcyclohex-2-en-1-yl)prop-2-enal" );
standardThermochemistry
{
    dHf_298   -194270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62310.0
}
