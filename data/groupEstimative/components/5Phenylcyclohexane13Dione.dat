/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenylcyclohexane-1,3-dione  (C12H12O2, CAS 493-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenylcyclohexane13Dione;
formula     C12H12O2;
CAS         493-72-1;
InChIKey    UPPYKNLSSLIIAZ-UHFFFAOYSA-N;
MW          188.226;      // g/mol [origin=calculated method=formula-sum]
Tc          925.17;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.5725;      // -   [origin=predictive method=lee-kesler]
Tb          656.03;      // K   [origin=predictive method=joback]
HvapTb      53505.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.67 0.8504 -0.0002532 -5.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-phenyl-1,3-cyclohexanedione" "1,3-dioxo-5-phenylcyclohexane" "1,3-cyclohexanedione,5-phenyl-" "5-phenyl-cyclohexane-1,3-dione" );
gibbsFormation
{
    dHf_298   -275560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58160.0
    phase     gas;
}
