/*--------------------------------*- Choupo -*-----------------------*\
  Component: stearonitrile  (C18H35N, CAS 638-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        stearonitrile;
formula     C18H35N;
CAS         638-65-3;
InChIKey    RHSBIGNQEIPSCT-UHFFFAOYSA-N;
MW          265.485;      // g/mol [origin=calculated method=formula-sum]
Tc          888.28;      // K   [origin=predictive method=joback]
Pc          11.329;      // bar [origin=predictive method=joback]
omega       0.8925;      // -   [origin=predictive method=lee-kesler]
Tb          713.52;      // K   [origin=predictive method=joback]
HvapTb      66140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.526 1.64862 -0.0009244 1.967e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecanenitrile" "heptadecyl cyanide" "1-cyanoheptadecane" "octadecanonitrile" "nitril kyseliny stearove" "octadecanoic acid, nitrile" "stearinsaeurenitril [german]" "oktadekannitril" "stearinsaeurenitril" );
gibbsFormation
{
    dHf_298   -249970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233860.0
    phase     gas;
}
