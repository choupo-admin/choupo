/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-pentanol  (C6H14O, CAS 565-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2Pentanol;
formula     C6H14O;
CAS         565-60-6;
InChIKey    ZXNBBWHRUSXUFZ-UHFFFAOYSA-N;
MW          102.177;      // g/mol [origin=calculated method=formula-sum]
Tc          596.39;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.6908;      // -   [origin=predictive method=lee-kesler]
Tb          428.18;      // K   [origin=predictive method=joback]
HvapTb      44853.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.639 0.61966 -0.0003394 6.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpentan-2-ol" "2-pentanol, 3-methyl-" "threo-3-methylpentan-2-ol" "2-pentanol, 3-methyl-, (2s,3r)-" "3-methyl-4-pentanol" "sec-butyl methyl carbinol" "agn-pc-04rw2i" "sec-butyl methylcarbinol" "zxnbbwhrusxufz-uhfffaoysa-" "2-pentanol, 3-methyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -329960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142060.0
}
