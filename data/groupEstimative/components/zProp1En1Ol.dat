/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-prop-1-en-1-ol  (C3H6O, CAS 57642-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zProp1En1Ol;
formula     C3H6O;
CAS         57642-95-2;
InChIKey    DOKHEARVIDLSFF-UHFFFAOYSA-N;
MW          58.08;      // g/mol [origin=calculated method=formula-sum]
Tc          535.35;      // K   [origin=predictive method=joback]
Pc          53.907;      // bar [origin=predictive method=joback]
omega       0.5697;      // -   [origin=predictive method=lee-kesler]
Tb          364.58;      // K   [origin=predictive method=joback]
HvapTb      38909.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.73 0.34282 -0.0002536 8.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-1-en-1-ol" "1-propen-1-ol" );
standardThermochemistry
{
    dHf_298   -140260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     317.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82220.0
}
