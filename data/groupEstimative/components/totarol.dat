/*--------------------------------*- Choupo -*-----------------------*\
  Component: totarol  (C20H30O, CAS 511-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        totarol;
formula     C20H30O;
CAS         511-15-9;
InChIKey    ZRVDANDJSTYELM-FXAWDEMLSA-N;
MW          286.459;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.97;      // K   [origin=predictive method=joback]
Pc          18.692;      // bar [origin=predictive method=joback]
omega       0.8043;      // -   [origin=predictive method=lee-kesler]
Tb          791.85;      // K   [origin=predictive method=joback]
HvapTb      73899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-235.97 2.7064 -0.00257828 1.0417e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4bs,8as)-4b,8,8-trimethyl-1-propan-2-yl-5,6,7,8a,9,10-hexahydrophenanthren-2-ol" "(+)-totarol" "(4bs)-trans-8,8-trimethyl-4b,5,6,7,8,8a,9,10-octahydro-1-isopropylphenanthren-2-ol" "ambap511-15-9" "4b,5,6,7,8,8a,9,10-octahydro-4b,8,8-trimethyl-1-(1-methylethyl)-2-phenanthrenol" "4bs-trans-8,8-trimethyl-4b,5,6,7,8,8a,9,10-octahydro-1-isopropyl-phenanthren-2-ol" );
gibbsFormation
{
    dHf_298   -281710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     789.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132220.0
    phase     gas;
}
