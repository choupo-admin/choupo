/*--------------------------------*- Choupo -*-----------------------*\
  Component: (triisopropylsilyl)acetylene  (C11H22Si, CAS 89343-06-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H22Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triisopropylsilylAcetylene;
formula     C11H22Si;
CAS         89343-06-6;
InChIKey    KZGWPHUWNWRTEP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          182.382;      // g/mol [origin=calculated method=formula-sum]
Tc          632.07;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.2911;      // -   [origin=predictive method=lee-kesler]
Tb          441.48;      // K   [origin=predictive method=joback]
HvapTb      39068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.44 0.76652 -0.00016533 -8.061e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 3; } { group CH_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethynyl-tri(propan-2-yl)silane" "ethynyltriisopropylsilane" "triisopropylsilylacetylene" "(tri-iso-propylsilyl)acetylene" "ethynyl[tris(isopropyl)]silane" "ethynyl[tris(prop-2-yl)]silane" "ethynyltriisopropylsilane;ethynyltris(1-methylethyl)silane;ethynyltris(triisopropyl)silane;triisopropylacetylene;triisopropylsilylacetylene;triisopropylsilylethyne;" );
standardThermochemistry
{
    dHf_298   -105930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152730.0
}
