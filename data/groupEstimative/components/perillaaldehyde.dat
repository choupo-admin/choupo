/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-perillaaldehyde  (C10H14O, CAS 18031-40-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perillaaldehyde;
formula     C10H14O;
CAS         18031-40-8;
InChIKey    RUMOYJJNUMEFDD-SNVBAGLBSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          711.16;      // K   [origin=predictive method=joback]
Pc          29.828;      // bar [origin=predictive method=joback]
omega       0.4637;      // -   [origin=predictive method=lee-kesler]
Tb          497.31;      // K   [origin=predictive method=joback]
HvapTb      45367.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.01 0.91482 -0.00053964 1.138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s)-4-prop-1-en-2-ylcyclohexene-1-carbaldehyde" "(s)-(-)-perillaldehyde" "(s)-p-mentha-1,8-dien-7-al" "(s)-4-(prop-1-en-2-yl)cyclohex-1-enecarbaldehyde" "(s)-4-isopropenyl-cyclohexene-1-carboxaldehyde" "s(-)-perillaldehyde" "rumoyjjnumefdd-uhfffaoysa-" "(4s)-4-(1-methylvinyl)cyclohex-1-enecarbaldehyde" "(4s)-4-(prop-1-en-2-yl)cyclohex-1-ene-1-carbaldehyde" "(-)-perillaaldehyde; (s)-p-mentha-1,8-dien-7-al; (s)-4-isopropenyl-cyclohexene-1-carboxaldehyde" );
standardThermochemistry
{
    dHf_298   -119040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57870.0
}
