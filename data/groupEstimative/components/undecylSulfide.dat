/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecyl sulfide  (C22H46S, CAS 35599-82-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecylSulfide;
formula     C22H46S;
CAS         35599-82-7;
InChIKey    RDOYGXODZMRGKD-UHFFFAOYSA-N;
MW          342.67;      // g/mol [origin=calculated method=formula-sum]
Tc          949.65;      // K   [origin=predictive method=joback]
Pc          9.111;      // bar [origin=predictive method=joback]
omega       0.8284;      // -   [origin=predictive method=lee-kesler]
Tb          771.74;      // K   [origin=predictive method=joback]
HvapTb      71383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.49 2.08823 -0.0011328 2.23e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 20; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-undecylsulfanylundecane" "1-(undecylsulfanyl)undecane" "undecane,1-(undecylthio)-" );
standardThermochemistry
{
    dHf_298   -455540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1074.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167480.0
}
