/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxypropyl)undec-10-enamide  (C14H27NO2, CAS 68052-41-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxypropylUndec10Enamide;
formula     C14H27NO2;
CAS         68052-41-5;
InChIKey    ZHAGPVPJSARSIL-UHFFFAOYSA-N;
MW          241.375;      // g/mol [origin=calculated method=formula-sum]
Tc          886.79;      // K   [origin=predictive method=joback]
Pc          18.201;      // bar [origin=predictive method=joback]
omega       1.2855;      // -   [origin=predictive method=lee-kesler]
Tb          712.38;      // K   [origin=predictive method=joback]
HvapTb      75561.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.071 1.40192 -0.0008242 1.8356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-oxidanylpropyl)undec-10-enamide" "10-undecenamide, n-(2-hydroxypropyl)-" "10-undecylenic acid isopropanolamide" "n-(2-hydroxypropyl)-10-undecenamide" );
standardThermochemistry
{
    dHf_298   -423480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     805.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23950.0
}
