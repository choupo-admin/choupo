/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-corey lactone diol  (C8H12O4, CAS 32233-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coreyLactoneDiol;
formula     C8H12O4;
CAS         32233-40-2;
InChIKey    VYTZWRCSPHQSFX-GBNDHIKLSA-N;
MW          172.18;      // g/mol [origin=calculated method=formula-sum]
Tc          809.57;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       1.4558;      // -   [origin=predictive method=lee-kesler]
Tb          629.36;      // K   [origin=predictive method=joback]
HvapTb      73375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.999 1.0258 -0.0007072 1.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group OH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3ar,4s,5r,6as)-4-(hydroxymethyl)-5-oxidanyl-3,3a,4,5,6,6a-hexahydrocyclopenta[b]furan-2-one" "(-)-corey lactone" "(-)-corey diol (corey lactone)" "(3ar,4s,5r,6as)-(-)-hexahydro-5-hydroxy-4-(hydroxymethyl)-2h-cyclopenta[b]furan-2-one" "(-)-6beta-hydroxymethyl-7alpha-hydroxy-cis-2-oxabicyclo[3.3.0]octan-3-one" "(1s,6s,5r,7r)-7-hydroxy-6-(hydroxymethyl)-2-oxabicyclo[3.3.0]octan-3-one" "(3ar,4s,5r,6as)-5-hydroxy-4-(hydroxymethyl)hexahydro-2h-cyclopenta[b]furan-2-one" "(3ar,4s,5r,6as)-5-hydroxy-4-(hydroxymethyl)-3,3a,4,5,6,6a-hexahydrocyclopenta[b]furan-2-one" );
gibbsFormation
{
    dHf_298   -725270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-461450.0
    phase     gas;
}
