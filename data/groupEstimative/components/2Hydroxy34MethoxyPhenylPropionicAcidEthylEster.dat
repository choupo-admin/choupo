/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-3-(4-methoxy-phenyl)-propionic acid ethyl ester  (C12H16O4, CAS 55301-58-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy34MethoxyPhenylPropionicAcidEthylEster;
formula     C12H16O4;
CAS         55301-58-1;
InChIKey    DRMAXCVIVGDCGQ-UHFFFAOYSA-N;
MW          224.256;      // g/mol [origin=calculated method=formula-sum]
Tc          872.93;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       1.1656;      // -   [origin=predictive method=lee-kesler]
Tb          678.20;      // K   [origin=predictive method=joback]
HvapTb      71352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.892 0.92734 -0.00042116 2.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-(4-methoxyphenyl)-2-oxidanyl-propanoate" "ethyl 2-hydroxy-3-(4-methoxyphenyl)propanoate" "lactic acid, 3-(p-methoxyphenyl)-, ethyl ester, d-" "2-hydroxy-3-(4-methoxy-phenyl)-propionic acid ethyl ester;benzenepropanoic acid, alpha-hydroxy-4-methoxy-, methyl ester;methyl 2-hydroxy-3-(4-methoxyphenyl)propanoate" );
gibbsFormation
{
    dHf_298   -672960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-401690.0
    phase     gas;
}
