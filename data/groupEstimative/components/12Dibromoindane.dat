/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromoindane  (C9H8Br2, CAS 20357-79-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromoindane;
formula     C9H8Br2;
CAS         20357-79-3;
InChIKey    BCGMAKWNCGCULT-UHFFFAOYSA-N;
MW          275.971;      // g/mol [origin=calculated method=formula-sum]
Tc          831.82;      // K   [origin=predictive method=joback]
Pc          42.663;      // bar [origin=predictive method=joback]
omega       0.5232;      // -   [origin=predictive method=lee-kesler]
Tb          571.57;      // K   [origin=predictive method=joback]
HvapTb      51040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.82 0.9212 -0.00073756 2.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-2,3-dihydro-1h-indene" "1h-indene, 1,2-dibromo-2,3-dihydro-" "agn-pc-03fcbc" "1,2-dibromo-2,3-dihydro-1h-indene" );
standardThermochemistry
{
    dHf_298   101090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209360.0
}
