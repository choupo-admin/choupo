/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.2]octane  (C8H14, CAS 280-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo222Octane;
formula     C8H14;
CAS         280-33-1;
InChIKey    GPRLTFBKWDERLU-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          614.68;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.2674;      // -   [origin=predictive method=lee-kesler]
Tb          404.66;      // K   [origin=predictive method=joback]
HvapTb      33572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.11 1.0464 -0.000759 2.228e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-endoethylenecyclohexane" "bicyclo(2.2.2)octane" "cyclohexane, 1,4-endo-(1,2-ethanediyl)-" "agn-pc-01zzd8" "bicyclo[2.2.2]octa-1,3,5-triene" "1,4-endoethylenecyclohexane;cyclohexane, 1,4-endo-(1,2-ethanediyl)-" );
gibbsFormation
{
    dHf_298   -75170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113780.0
    phase     gas;
}
