/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16,16-diethoxyhexadec-5-ene  (C20H40O2, CAS 71393-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1616Diethoxyhexadec5Ene;
formula     C20H40O2;
CAS         71393-92-5;
InChIKey    JAOYXKSQTHADHX-UHFFFAOYSA-N;
MW          312.538;      // g/mol [origin=calculated method=formula-sum]
Tc          874.71;      // K   [origin=predictive method=joback]
Pc          10.326;      // bar [origin=predictive method=joback]
omega       0.8613;      // -   [origin=predictive method=lee-kesler]
Tb          705.76;      // K   [origin=predictive method=joback]
HvapTb      64504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.844 1.80336 -0.0009292 1.641e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-16,16-diethoxyhexadec-5-ene" "5-hexadecene, 16,16-diethoxy-, (5z)-" );
gibbsFormation
{
    dHf_298   -608630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     941.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14700.0
    phase     gas;
}
