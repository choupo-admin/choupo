/*--------------------------------*- Choupo -*-----------------------*\
  Component: tribromoethylbenzene  (C8H7Br3, CAS 31195-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tribromoethylbenzene;
formula     C8H7Br3;
CAS         31195-17-2;
InChIKey    BZQONKLQDOHILP-UHFFFAOYSA-N;
MW          342.856;      // g/mol [origin=calculated method=formula-sum]
Tc          881.32;      // K   [origin=predictive method=joback]
Pc          48.971;      // bar [origin=predictive method=joback]
omega       0.5699;      // -   [origin=predictive method=lee-kesler]
Tb          604.57;      // K   [origin=predictive method=joback]
HvapTb      53687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.189 0.9253 -0.0008286 2.837e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(bromanyl)ethylbenzene" "(2,2,2-tribromoethyl)benzene" "benzene, tribromoethyl-" "ar-tribromoethylbenzene" "2,2,2-tribromoethylbenzene" "1-(2,2,2-tribromoethyl)benzene" );
standardThermochemistry
{
    dHf_298   98320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=174690.0
}
