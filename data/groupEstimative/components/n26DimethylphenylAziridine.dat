/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2,6-dimethylphenyl)aziridine  (C10H13N, CAS 78376-90-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n26DimethylphenylAziridine;
formula     C10H13N;
CAS         78376-90-6;
InChIKey    MPWKDJKOBYTMQV-UHFFFAOYSA-N;
MW          147.221;      // g/mol [origin=calculated method=formula-sum]
Tc          697.92;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.4708;      // -   [origin=predictive method=lee-kesler]
Tb          484.62;      // K   [origin=predictive method=joback]
HvapTb      43547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.26 1.06684 -0.00085192 2.783e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,6-dimethylphenyl)aziridine" );
standardThermochemistry
{
    dHf_298   130690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     375.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=317810.0
}
