/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumalic acid  (C6H4O4, CAS 500-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumalicAcid;
formula     C6H4O4;
CAS         500-05-0;
InChIKey    ORGPJDKNYMVLFL-UHFFFAOYSA-N;
MW          140.094;      // g/mol [origin=calculated method=formula-sum]
Tc          780.79;      // K   [origin=predictive method=joback]
Pc          47.236;      // bar [origin=predictive method=joback]
omega       0.8205;      // -   [origin=predictive method=lee-kesler]
Tb          559.59;      // K   [origin=predictive method=joback]
HvapTb      55161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.0 0.5661 -0.00041732 1.122e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH=C; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-oxidanylidenepyran-3-carboxylic acid" "2-oxo-2h-pyran-5-carboxylic acid" "cumalic acid" "2h-pyran-5-carboxylic acid, 2-oxo-" "2-oxopyran-5-carboxylic acid" ".alpha.-pyrone-5-carboxylic acid" "2-pyrone-5-carboxylic acid" "6-oxopyran-3-carboxylic acid" "alpha-pyrone-5-carboxylic acid" "5-carboxy-2-pyrone" "6-oxo-pyran-3-carboxylic acid" "2h-pyran-5-carboxylicacid, 2-oxo-" );
standardThermochemistry
{
    dHf_298   -643650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-547990.0
}
