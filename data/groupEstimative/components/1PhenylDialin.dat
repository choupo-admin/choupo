/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl dialin  (C16H14, CAS 7469-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PhenylDialin;
formula     C16H14;
CAS         7469-40-1;
InChIKey    JKTVTLYXBAHXCW-UHFFFAOYSA-N;
MW          206.288;      // g/mol [origin=calculated method=formula-sum]
Tc          903.91;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.5305;      // -   [origin=predictive method=lee-kesler]
Tb          643.84;      // K   [origin=predictive method=joback]
HvapTb      57772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.39 1.3588 -0.0009914 2.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-1,2-dihydronaphthalene" "naphthalene, 1,2-dihydro-4-phenyl-" "1,2-dihydro-4-phenylnaphthalene" "3,4-dihydro-1-phenylnaphthalene" "naphthalene,2-dihydro-4-phenyl-" "1-phenyl-3,4-dihydronaphthalene" "4-phenyl-1,2-dihydro-naphthalene" "naphthalene,1,2-dihydro-4-phenyl-" );
gibbsFormation
{
    dHf_298   221310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=375720.0
    phase     gas;
}
