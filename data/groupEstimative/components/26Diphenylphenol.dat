/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-diphenylphenol  (C18H14O, CAS 2432-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Diphenylphenol;
formula     C18H14O;
CAS         2432-11-3;
InChIKey    ATGFTMUSEPZNJD-UHFFFAOYSA-N;
MW          246.309;      // g/mol [origin=calculated method=formula-sum]
Tc          1052.69;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       0.8058;      // -   [origin=predictive method=lee-kesler]
Tb          777.08;      // K   [origin=predictive method=joback]
HvapTb      76166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.81 1.5722 -0.00123832 3.877e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 4; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 13; } { group dC_ring; count 5; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[m-terphenyl]-2'-ol" "[1,1':3',1''-terphenyl]-2'-ol" "m-terphenyl-2'-ol" "2,6-di(phenyl)phenol" "2'-hydroxy-m-terphenyl" );
standardThermochemistry
{
    dHf_298   105960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=273660.0
}
