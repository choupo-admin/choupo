/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl 2-chloroethylsulfide  (C5H9ClS, CAS 19155-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allyl2Chloroethylsulfide;
formula     C5H9ClS;
CAS         19155-35-2;
InChIKey    OLEMZWBORONVDW-UHFFFAOYSA-N;
MW          136.637;      // g/mol [origin=calculated method=formula-sum]
Tc          619.44;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.3556;      // -   [origin=predictive method=lee-kesler]
Tb          416.89;      // K   [origin=predictive method=joback]
HvapTb      37256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.843 0.45999 -0.0002513 4.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2Cl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-chloroethylsulfanyl)prop-1-ene" "sulfide, allyl 2-chloroethyl" "allyl 2-chloroethyl sulfide" );
gibbsFormation
{
    dHf_298   5030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100250.0
    phase     gas;
}
