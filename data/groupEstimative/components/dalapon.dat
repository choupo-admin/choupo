/*--------------------------------*- Choupo -*-----------------------*\
  Component: dalapon  (C3H4Cl2O2, CAS 75-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dalapon;
formula     C3H4Cl2O2;
CAS         75-99-0;
InChIKey    NDUPDOJHUQKPAG-UHFFFAOYSA-N;
MW          142.963;      // g/mol [origin=calculated method=formula-sum]
Tc          707.50;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       0.5467;      // -   [origin=predictive method=lee-kesler]
Tb          485.38;      // K   [origin=predictive method=joback]
HvapTb      46910.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.07 0.47902 -0.0004246 1.424e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group COOH; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)propanoic acid" "2,2-dichloropropionic acid" "2,2-dichloropropanoic acid" "kenapon" "liropon" "proprop" "alatex" "unipon" "sys-omnidel" "d-granulat" "dawpon-rae" "basinex p" );
gibbsFormation
{
    dHf_298   -495750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-390550.0
    phase     gas;
}
