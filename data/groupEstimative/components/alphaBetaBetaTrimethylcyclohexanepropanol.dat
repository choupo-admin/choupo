/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha,beta,beta-trimethylcyclohexanepropanol  (C12H24O, CAS 72727-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaBetaBetaTrimethylcyclohexanepropanol;
formula     C12H24O;
CAS         72727-60-7;
InChIKey    OUINQRJSUSXKFQ-UHFFFAOYSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          778.15;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       0.7760;      // -   [origin=predictive method=lee-kesler]
Tb          582.22;      // K   [origin=predictive method=joback]
HvapTb      57730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.489 1.43166 -0.0009154 2.224e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclohexyl-3,3-dimethyl-butan-2-ol" "4-cyclohexyl-3,3-dimethylbutan-2-ol" "cyclohexanepropanol, alpha,beta,beta-trimethyl-" );
gibbsFormation
{
    dHf_298   -402950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-61810.0
    phase     gas;
}
