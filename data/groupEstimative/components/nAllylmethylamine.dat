/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-allylmethylamine  (C4H9N, CAS 627-37-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nAllylmethylamine;
formula     C4H9N;
CAS         627-37-2;
InChIKey    IOXXVNYDGIXMIP-UHFFFAOYSA-N;
MW          71.123;      // g/mol [origin=calculated method=formula-sum]
Tc          511.96;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.3335;      // -   [origin=predictive method=lee-kesler]
Tb          337.97;      // K   [origin=predictive method=joback]
HvapTb      30264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.949 0.44002 -0.0002653 6.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylprop-2-en-1-amine" "n-methylallylamine" "allylmethylamine" "methylallylamine" "2-propen-1-amine, n-methyl-" "n-allyl-n-methylamine" "n-methyl-2-propen-1-amine" "allylamine, n-methyl- (7ci,8ci)" "3-(methylamino)prop-1-ene" "methyl(prop-2-en-1-yl)amine" "2-propen-1-amine, n-methyl- (9ci)" "allylamine, n-methyl- (7ci,8ci);allylmethylamine;methylallylamine;n-allyl-n-methylamine;n-allylmethylamine;n-methyl-2-propen-1-amine;n-methyl-n-allylamine;n-methylallylamine;n-methylprop-2-enamine;" );
gibbsFormation
{
    dHf_298   53010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     347.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160030.0
    phase     gas;
}
