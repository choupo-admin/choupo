/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimetacrine  (C20H26N2, CAS 4757-55-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimetacrine;
formula     C20H26N2;
CAS         4757-55-5;
InChIKey    RYQOGSFEJBUZBX-UHFFFAOYSA-N;
MW          294.442;      // g/mol [origin=calculated method=formula-sum]
Tc          961.91;      // K   [origin=predictive method=joback]
Pc          17.580;      // bar [origin=predictive method=joback]
omega       0.8555;      // -   [origin=predictive method=lee-kesler]
Tb          743.84;      // K   [origin=predictive method=joback]
HvapTb      68494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.877 2.33688 -0.00206332 7.599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(9,9-dimethylacridin-10-yl)-n,n-dimethyl-propan-1-amine" "dimetacrino" "dimetacrinum" "dimethacrin" "dimethacrine" "dimetacrine [inn]" "dimetacrina [dcit]" "dimetacrinum [inn-latin]" "dimetacrine (inn)" "acridan, 10-(3-(dimethylamino)propyl)-9,9-dimethyl-" "n,n,9,9-tetramethyl-10(9h)-acridinepropanamine" "10-(3-(dimethylamino)propyl)-9,9-dimethylacridan" );
gibbsFormation
{
    dHf_298   229410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     681.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=624100.0
    phase     gas;
}
