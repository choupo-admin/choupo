/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorophthalic acid  (C8H5ClO4, CAS 89-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorophthalicAcid;
formula     C8H5ClO4;
CAS         89-20-3;
InChIKey    DVIPPHSQIBKWSA-UHFFFAOYSA-N;
MW          200.574;      // g/mol [origin=calculated method=formula-sum]
Tc          988.87;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       1.2015;      // -   [origin=predictive method=lee-kesler]
Tb          747.73;      // K   [origin=predictive method=joback]
HvapTb      75715.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.4 0.6743 -0.00047412 1.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group COOH; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylphthalic acid" "1,2-benzenedicarboxylic acid, 4-chloro-" "phthalic acid, 4-chloro-" "phthalic acid, 4-chloro- (8ci)" "p-chlorophthalic acid, 55%" "4-chlorobenzene-1,2-dicarboxylic acid" "1,2-benzenedicarboxylicacid, 4-chloro-" "k587" );
standardThermochemistry
{
    dHf_298   -711140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-590120.0
}
