/*--------------------------------*- Choupo -*-----------------------*\
  Component: sorbic alcohol  (C6H10O, CAS 17102-64-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sorbicAlcohol;
formula     C6H10O;
CAS         17102-64-6;
InChIKey    MEIRRNXMZYDVDW-MQQKCMAXSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          614.33;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.6881;      // -   [origin=predictive method=lee-kesler]
Tb          437.38;      // K   [origin=predictive method=joback]
HvapTb      45545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.639 0.64782 -0.0005006 1.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e)-hexa-2,4-dien-1-ol" "sorbyl alcohol" "2,4-hexadien-1-ol" "hexacose" "hexadenol" "hexakose" "hexenol" "sorbinic alcohol" "hexene-ol" "2,4-hexadienol" "(e,e)-2,4-hexadien-1-ol" "trans,trans-2,4-hexadien-1-ol" );
standardThermochemistry
{
    dHf_298   -84960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23260.0
}
