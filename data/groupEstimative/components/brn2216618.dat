/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2216618  (C17H23NO2, CAS 4618-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2216618;
formula     C17H23NO2;
CAS         4618-24-0;
InChIKey    AITWWMQZEHPPKO-UHFFFAOYSA-N;
MW          273.376;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.81;      // K   [origin=predictive method=joback]
Pc          20.793;      // bar [origin=predictive method=joback]
omega       1.3117;      // -   [origin=predictive method=lee-kesler]
Tb          803.53;      // K   [origin=predictive method=joback]
HvapTb      83151.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.715 1.52962 -0.00097308 2.378e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 7; } { group AC; count 3; } { group CH2NH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group OH; count 1; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(butylamino)-3-naphthalen-1-yloxy-propan-2-ol" "2-propanol, 1-butylamino-3-(naphthyloxy)-" "2-propanol, 1-(butylamino)-3-(1-naphthalenyloxy)-, (s)-" "1-(butylamino)-3-naphthalen-1-yloxypropan-2-ol" );
standardThermochemistry
{
    dHf_298   -214340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146820.0
}
