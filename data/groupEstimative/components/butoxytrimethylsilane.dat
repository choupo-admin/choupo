/*--------------------------------*- Choupo -*-----------------------*\
  Component: butoxytrimethylsilane  (C7H18OSi, CAS 1825-65-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H18OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        butoxytrimethylsilane;
formula     C7H18OSi;
CAS         1825-65-6;
InChIKey    YTJUXOIAXOQWBV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          146.305;      // g/mol [origin=calculated method=formula-sum]
Tc          553.92;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.3305;      // -   [origin=predictive method=lee-kesler]
Tb          383.58;      // K   [origin=predictive method=joback]
HvapTb      33880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.843 0.39948 0.0001688 -1.999e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butoxy(trimethyl)silane" "silane, butoxytrimethyl-" );
standardThermochemistry
{
    dHf_298   -431650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-201700.0
}
