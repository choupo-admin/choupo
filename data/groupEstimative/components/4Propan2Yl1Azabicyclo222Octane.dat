/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-propan-2-yl-1-azabicyclo[2.2.2]octane  (C10H19N, CAS 45842-68-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Propan2Yl1Azabicyclo222Octane;
formula     C10H19N;
CAS         45842-68-0;
InChIKey    LWTAOQAZHABQRV-UHFFFAOYSA-N;
MW          153.269;      // g/mol [origin=calculated method=formula-sum]
Tc          671.59;      // K   [origin=predictive method=joback]
Pc          30.558;      // bar [origin=predictive method=joback]
omega       0.4046;      // -   [origin=predictive method=lee-kesler]
Tb          463.06;      // K   [origin=predictive method=joback]
HvapTb      38665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.11 1.69424 -0.001618 6.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 6; } { group C_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo(2.2.2)octane, 4-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -12460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253280.0
}
