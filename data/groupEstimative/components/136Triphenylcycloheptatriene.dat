/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,6-triphenylcycloheptatriene  (C25H20, CAS 17760-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        136Triphenylcycloheptatriene;
formula     C25H20;
CAS         17760-68-8;
InChIKey    GYYCHVGZUPXXKV-UHFFFAOYSA-N;
MW          320.435;      // g/mol [origin=calculated method=formula-sum]
Tc          1174.97;      // K   [origin=predictive method=joback]
Pc          18.920;      // bar [origin=predictive method=joback]
omega       0.7540;      // -   [origin=predictive method=lee-kesler]
Tb          892.55;      // K   [origin=predictive method=joback]
HvapTb      81844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.98 1.9346 -0.00128052 3.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 3; } { group ACH; count 15; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 18; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,6-triphenylcyclohepta-1,3,5-triene" );
gibbsFormation
{
    dHf_298   357690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=577900.0
    phase     gas;
}
