/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-cyclohexadiene, 1,5-dimethyl-  (C8H12, CAS 1453-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Cyclohexadiene15Dimethyl;
formula     C8H12;
CAS         1453-17-4;
InChIKey    KIHPDGGDZZCYBT-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          612.34;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.2699;      // -   [origin=predictive method=lee-kesler]
Tb          405.49;      // K   [origin=predictive method=joback]
HvapTb      35077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.13 0.71444 -0.00039992 7.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-dimethylcyclohexa-1,3-diene" "agn-pc-00ox4d" );
gibbsFormation
{
    dHf_298   -50040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91220.0
    phase     gas;
}
