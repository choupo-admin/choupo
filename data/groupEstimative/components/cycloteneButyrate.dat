/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclotene butyrate  (C10H14O3, CAS 68227-51-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloteneButyrate;
formula     C10H14O3;
CAS         68227-51-0;
InChIKey    SUJWBOKDKMEAOQ-UHFFFAOYSA-N;
MW          182.219;      // g/mol [origin=calculated method=formula-sum]
Tc          797.26;      // K   [origin=predictive method=joback]
Pc          27.155;      // bar [origin=predictive method=joback]
omega       0.6878;      // -   [origin=predictive method=lee-kesler]
Tb          583.51;      // K   [origin=predictive method=joback]
HvapTb      51690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.592 0.71394 -0.0002176 -4.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2CO; count 1; } { group CH2COO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group dC_ring; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-5-oxidanylidene-cyclopenten-1-yl) butanoate" "2-methyl-5-oxocyclopent-1-en-1-yl butyrate" "2-methyl-5-oxo-1-cyclopenten-1-yl butyrate" "butanoic acid, 2-methyl-5-oxo-1-cyclopenten-1-yl ester" "(2-methyl-5-oxocyclopenten-1-yl) butanoate" "3-methyl-2-hydroxy-2-cyclopenten-1-one, butyrate" "butanoic acid (2-methyl-5-oxo-1-cyclopentenyl) ester" "butanoic acid 2-methyl-5-oxo-1-cyclopenten-1-yl ester" "(2-methyl-5-oxo-1-cyclopentenyl) butanoate;cyclotene butyrate;3-methyl-2-hydroxy-2-cyclopenten-1-one, butyrate;2-methyl-5-oxo-1-cyclopenten-1-yl butyrate;" );
gibbsFormation
{
    dHf_298   -589050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-344680.0
    phase     gas;
}
