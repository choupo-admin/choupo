/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexen-1-one, 5-methyl-4-(3-methyl-2-butenyl)-  (C12H18O, CAS 71820-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexen1One5Methyl43Methyl2Butenyl;
formula     C12H18O;
CAS         71820-50-3;
InChIKey    CGASAKPGTGHEIM-QWRGUYRKSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          782.21;      // K   [origin=predictive method=joback]
Pc          23.338;      // bar [origin=predictive method=joback]
omega       0.4778;      // -   [origin=predictive method=lee-kesler]
Tb          560.06;      // K   [origin=predictive method=joback]
HvapTb      47003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.349 1.03506 -0.00048398 5.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,5s)-5-methyl-4-(3-methylbut-2-enyl)cyclohex-2-en-1-one" "2-cyclohexen-1-one, 5-methyl-4-(3-methyl-2-buten-1-yl)-" "4-(3-methyl-2-butenyl)-5-methyl-2-cyclohexen-1-one" );
standardThermochemistry
{
    dHf_298   -229520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45940.0
}
