/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylidenecholest-4-ene  (C28H46, CAS 4561-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylidenecholest4Ene;
formula     C28H46;
CAS         4561-75-5;
InChIKey    DRCYUNZSUMDTCY-UHFFFAOYSA-N;
MW          382.676;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.43;      // K   [origin=predictive method=joback]
Pc          9.883;      // bar [origin=predictive method=joback]
omega       0.7170;      // -   [origin=predictive method=lee-kesler]
Tb          882.11;      // K   [origin=predictive method=joback]
HvapTb      75851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-296.237 3.5291 -0.00293684 1.0585e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 6; } { group C; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group dCH2; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10,13-dimethyl-17-(6-methylheptan-2-yl)-3-methylidene-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthrene" "agn-pc-00kqs1" "(8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-3-methylidene-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthrene" );
gibbsFormation
{
    dHf_298   -251060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     950.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=409510.0
    phase     gas;
}
