/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-thiatridecane  (C12H26S, CAS 7289-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Thiatridecane;
formula     C12H26S;
CAS         7289-44-3;
InChIKey    HDOADYQJIBYVGE-UHFFFAOYSA-N;
MW          202.4;      // g/mol [origin=calculated method=formula-sum]
Tc          721.42;      // K   [origin=predictive method=joback]
Pc          18.062;      // bar [origin=predictive method=joback]
omega       0.6555;      // -   [origin=predictive method=lee-kesler]
Tb          542.94;      // K   [origin=predictive method=joback]
HvapTb      49123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.58 1.13823 -0.0005888 1.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylsulfanylundecane" "methyl undecyl sulfide" "undecane, 1-(methylthio)-" );
gibbsFormation
{
    dHf_298   -249140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83280.0
    phase     gas;
}
