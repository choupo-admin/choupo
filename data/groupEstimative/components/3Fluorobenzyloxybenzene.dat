/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluorobenzyloxybenzene  (C13H11FO, CAS 19962-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Fluorobenzyloxybenzene;
formula     C13H11FO;
CAS         19962-21-1;
InChIKey    CZGNXONBQOCVJM-UHFFFAOYSA-N;
MW          202.228;      // g/mol [origin=calculated method=formula-sum]
Tc          807.04;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.5612;      // -   [origin=predictive method=lee-kesler]
Tb          577.07;      // K   [origin=predictive method=joback]
HvapTb      51339.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.849 0.9701 -0.00058416 1.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group CH2O; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-3-(phenoxymethyl)benzene" "[(3-fluorophenyl)methoxy]benzene" "1-fluoro-3-(phenoxymethyl)benzene" );
gibbsFormation
{
    dHf_298   -178390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26040.0
    phase     gas;
}
