/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(4-amino-2-chlorophenyl)-n,n-diethylamine  (C10H15ClN2, CAS 68155-76-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n4Amino2ChlorophenylNNDiethylamine;
formula     C10H15ClN2;
CAS         68155-76-0;
InChIKey    JLPRWBZGPHCRIH-UHFFFAOYSA-N;
MW          198.694;      // g/mol [origin=calculated method=formula-sum]
Tc          806.46;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.6887;      // -   [origin=predictive method=lee-kesler]
Tb          587.44;      // K   [origin=predictive method=joback]
HvapTb      58523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.818 0.94854 -0.00059372 1.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n1,n1-diethyl-benzene-1,4-diamine" "1,4-benzenediamine, 2-chloro-n1,n1-diethyl-" "2-chloro-1-n,1-n-diethylbenzene-1,4-diamine" "n,n-diethyl-2-chloro-4-amino aniline" "2-chloro-n,n-diethylbenzene-1,4-diamine" "(4-amino-2-chlorophenyl)diethylamine" "2-chloro-n1,n1-diethylbenzene-1,4-diamine" );
standardThermochemistry
{
    dHf_298   49440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291770.0
}
