/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenyl-2-butyl acetate  (C12H16O2, CAS 10415-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenyl2ButylAcetate;
formula     C12H16O2;
CAS         10415-88-0;
InChIKey    IVEWTAOGAGBQGG-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          766.52;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.6036;      // -   [origin=predictive method=lee-kesler]
Tb          558.62;      // K   [origin=predictive method=joback]
HvapTb      51601.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.198 1.01604 -0.0005688 9.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbutan-2-yl ethanoate" "2-butanol, 4-phenyl-, acetate" "benzenepropanol, .alpha.-methyl-, acetate" "phenylpropanol, .alpha.-methyl, acetate" "phenylethyl methyl carbinyl acetate" "1-phenyl-3-acetoxybutane" "4-phenylbut-2-yl acetate" "4-phenylbutan-2-yl acetate" "4-phenyl-2-butanol acetate" "1-methyl-3-phenylpropyl acetate" "alpha-methylbenzenepropanol acetate" "benzenepropanol, ?-methyl-, acetate" );
standardThermochemistry
{
    dHf_298   -377040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150240.0
}
