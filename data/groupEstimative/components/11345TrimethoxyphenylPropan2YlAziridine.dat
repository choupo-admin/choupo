/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[1-(3,4,5-trimethoxyphenyl)propan-2-yl]aziridine  (C14H21NO3, CAS 36266-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11345TrimethoxyphenylPropan2YlAziridine;
formula     C14H21NO3;
CAS         36266-38-3;
InChIKey    ZSVSXKYSXIIVQN-UHFFFAOYSA-N;
MW          251.326;      // g/mol [origin=calculated method=formula-sum]
Tc          848.14;      // K   [origin=predictive method=joback]
Pc          20.984;      // bar [origin=predictive method=joback]
omega       0.8657;      // -   [origin=predictive method=lee-kesler]
Tb          647.94;      // K   [origin=predictive method=joback]
HvapTb      59955.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.221 1.20368 -0.00067268 1.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-(3,4,5-trimethoxyphenyl)-2-propyl)aziridine" "1-(1-methyl-2-(3,4,5-trimethoxyphenyl)ethyl)aziridine" "aziridine, 1-(1-methyl-2-(3,4,5-trimethoxyphenyl)ethyl)-" );
standardThermochemistry
{
    dHf_298   -365280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24420.0
}
