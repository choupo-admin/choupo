/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1-hexene  (C7H14, CAS 6094-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl1Hexene;
formula     C7H14;
CAS         6094-02-6;
InChIKey    IRUDSQHLKGNCGF-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          526.73;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.3057;      // -   [origin=predictive method=lee-kesler]
Tb          356.32;      // K   [origin=predictive method=joback]
HvapTb      30586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.157 0.64874 -0.0003822 9.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylhex-1-ene" "1-hexene, 2-methyl-" "isohexenes" "hexene, 2-methyl-" "agn-pc-0cwspy" );
gibbsFormation
{
    dHf_298   -72170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87350.0
    phase     gas;
}
