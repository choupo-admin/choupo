/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butyl-2-methylcyclopropane  (C8H16, CAS 2511-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butyl2Methylcyclopropane;
formula     C8H16;
CAS         2511-92-4;
InChIKey    IWTBNPKBPXCCIV-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          561.71;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.3391;      // -   [origin=predictive method=lee-kesler]
Tb          384.71;      // K   [origin=predictive method=joback]
HvapTb      33006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.687 0.88824 -0.0005762 1.551e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butyl-2-methyl-cyclopropane" "trans-1-butyl-2-methylcyclopropane" "cis-1-butyl-2-methylcyclopropane" "cyclopropane, 1-butyl-2-methyl-" );
gibbsFormation
{
    dHf_298   -155990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     335.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69520.0
    phase     gas;
}
