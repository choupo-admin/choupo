/*--------------------------------*- Choupo -*-----------------------*\
  Component: 281-44-7  (C6H16Si4, CAS 281-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16Si4 (delta H+4Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        281447;
formula     C6H16Si4;
CAS         281-44-7;
InChIKey    HWZWWWKPVZVMFC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          200.534;      // g/mol [origin=calculated method=formula-sum]
Tc          565.72;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.1137;      // -   [origin=predictive method=lee-kesler]
Tb          361.10;      // K   [origin=predictive method=joback]
HvapTb      29688.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.11 0.7224 -0.000439 9.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group SiH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -92510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     738.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31800.0
    phase     gas;
}
