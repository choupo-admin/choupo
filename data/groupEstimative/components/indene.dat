/*--------------------------------*- Choupo -*-----------------------*\
  Component: indene  (C9H8, CAS 95-13-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        indene;
formula     C9H8;
CAS         95-13-6;
InChIKey    YBYIRNPNPLQARY-UHFFFAOYSA-N;
MW          116.163;      // g/mol [origin=calculated method=formula-sum]
Tc          677.36;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.3298;      // -   [origin=predictive method=lee-kesler]
Tb          447.75;      // K   [origin=predictive method=joback]
HvapTb      39080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.3 0.8418 -0.00069284 2.282e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1h-indene" "indonaphthene" "inden" "indenyl radical" "1h-inden" "benzocyclopentadiene" "indene, reag" );
standardThermochemistry
{
    dHf_298   146890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     308.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226100.0
}
