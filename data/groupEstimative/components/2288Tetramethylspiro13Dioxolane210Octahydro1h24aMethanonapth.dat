/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',2',8',8'-tetramethylspiro[1,3-dioxolane-2,10'-octahydro-1h-2,4a-methanonapthalene]  (C17H28O2, CAS 154171-76-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2288Tetramethylspiro13Dioxolane210Octahydro1h24aMethanonapth;
formula     C17H28O2;
CAS         154171-76-3;
InChIKey    RTPMDRYHLHGFGT-UHFFFAOYSA-N;
MW          264.409;      // g/mol [origin=calculated method=formula-sum]
Tc          923.58;      // K   [origin=predictive method=joback]
Pc          21.453;      // bar [origin=predictive method=joback]
omega       0.5451;      // -   [origin=predictive method=lee-kesler]
Tb          673.85;      // K   [origin=predictive method=joback]
HvapTb      57402.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-382.34 3.30228 -0.0036344 1.6168e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C; count 4; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[1,3-dioxolane-2,8'(5'h)-[2h-2,4a]methanonaphthalene], hexahydro-1',1',5',5'-tetramethyl-" );
gibbsFormation
{
    dHf_298   -365210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89340.0
    phase     gas;
}
