/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilyl decanoate  (C13H28O2Si, CAS 55494-15-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H28O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylDecanoate;
formula     C13H28O2Si;
CAS         55494-15-0;
InChIKey    FGTNBYWFNITQJR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          244.45;      // g/mol [origin=calculated method=formula-sum]
Tc          727.31;      // K   [origin=predictive method=joback]
Pc          15.011;      // bar [origin=predictive method=joback]
omega       0.6663;      // -   [origin=predictive method=lee-kesler]
Tb          556.66;      // K   [origin=predictive method=joback]
HvapTb      52233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.298 0.97788 -0.000174 -1.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanoic acid, trimethylsilyl ester" "decanoic acid trimethylsilyl ester" );
standardThermochemistry
{
    dHf_298   -740550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     840.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-356550.0
}
