/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetic acid, bromochloro-, ethyl ester  (C4H6BrClO2, CAS 22524-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aceticAcidBromochloroEthylEster;
formula     C4H6BrClO2;
CAS         22524-32-9;
InChIKey    ROKCSLROOSHJSM-UHFFFAOYSA-N;
MW          201.444;      // g/mol [origin=calculated method=formula-sum]
Tc          659.28;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.5038;      // -   [origin=predictive method=lee-kesler]
Tb          452.49;      // K   [origin=predictive method=joback]
HvapTb      42337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.061 0.37992 -0.0001942 2.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CHCl; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-bromanyl-2-chloranyl-ethanoate" "agn-pc-00l0g6" );
gibbsFormation
{
    dHf_298   -437860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327620.0
    phase     gas;
}
