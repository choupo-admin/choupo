/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl chrysanthemate  (C12H20O2, CAS 97-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylChrysanthemate;
formula     C12H20O2;
CAS         97-41-6;
InChIKey    VIMXTGUGWLAOFZ-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          729.93;      // K   [origin=predictive method=joback]
Pc          20.680;      // bar [origin=predictive method=joback]
omega       0.5433;      // -   [origin=predictive method=lee-kesler]
Tb          534.06;      // K   [origin=predictive method=joback]
HvapTb      47895.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.839 1.4988 -0.0012625 4.646e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "ethyl chrysanthemumate" "ethylchrysanthemate" "cyclopropanecarboxylic acid, 2,2-dimethyl-3-(2-methyl-1-propenyl)-, ethyl ester" "chrysanthemic acid ethyl ester" "ethyl 2,2-dimethyl-3-(2-methyl-1-propenyl)cyclopropane-1-carboxylate" "chrysanthemum monocarboxylic acid ethyl ester" "ethyl 2,2-dimethyl-3-(2-methylpropenyl)cyclopropanecarboxylate" "ethyl 2,2-dimethyl-3-(2-methyl-1-propenyl)cyclopropanecarboxylate" "ethyl 2,2-dimethyl-3-(2-methylprop-1-en-1-yl)cyclopropanecarboxylate" "2,2-dimethyl-3-(2-methylpropenyl)cyclopropanecarboxylic acid ethyl ester" "cyclopropanecarboxylic acid, 2,2-dimethyl-3-(2-methyl-1-propen-1-yl)-, ethyl ester" );
gibbsFormation
{
    dHf_298   -453500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148700.0
    phase     gas;
}
