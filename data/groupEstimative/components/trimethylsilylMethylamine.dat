/*--------------------------------*- Choupo -*-----------------------*\
  Component: (trimethylsilyl)methylamine  (C4H13NSi, CAS 18166-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H13NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilylMethylamine;
formula     C4H13NSi;
CAS         18166-02-4;
InChIKey    YVWPNDBYAAEZBF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          103.24;      // g/mol [origin=calculated method=formula-sum]
Tc          553.78;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.2769;      // -   [origin=predictive method=lee-kesler]
Tb          365.05;      // K   [origin=predictive method=joback]
HvapTb      35433.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.561 0.23956 0.0001776 -1.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2NH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilylmethanamine" "(aminomethyl)trimethylsilane" "trimethylsilylmethylamine" "(trimethylsilyl)methanamine" "1-(trimethylsilyl)methanamine" "1-(trimethylsilyl)methylamine" "methylamine, 1-(trimethylsilyl)-," "u651" );
gibbsFormation
{
    dHf_298   -203720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55510.0
    phase     gas;
}
