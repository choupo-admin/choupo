/*--------------------------------*- Choupo -*-----------------------*\
  Component: halacrinate  (C12H7BrClNO2, CAS 34462-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        halacrinate;
formula     C12H7BrClNO2;
CAS         34462-96-9;
InChIKey    YDNLKBDXQCHOTH-UHFFFAOYSA-N;
MW          312.547;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.74;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.8819;      // -   [origin=predictive method=lee-kesler]
Tb          746.95;      // K   [origin=predictive method=joback]
HvapTb      71975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.09 0.88666 -0.00062516 1.687e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 1; } { group AC; count 2; } { group C5H3N; count 1; } { group ACCl; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 5; } { group Cl; count 1; } { group Br; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(7-bromanyl-5-chloranyl-quinolin-8-yl) prop-2-enoate" "halacrinate [iso]" "2-propenoic acid, 7-bromo-5-chloro-8-quinolinyl ester" "7-bromo-5-chloroquinolin-8-yl acrylate" "8-acryloyloxy-7-bromo-5-chloroquinoline" "5-chloro-7-bromo-8-quinolyl vinyl carbonate" "(7-bromo-5-chloroquinolin-8-yl) prop-2-enoate" );
standardThermochemistry
{
    dHf_298   -46290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97240.0
}
