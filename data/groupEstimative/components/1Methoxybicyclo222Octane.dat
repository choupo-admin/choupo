/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxybicyclo[2.2.2]octane  (C9H16O, CAS 7697-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxybicyclo222Octane;
formula     C9H16O;
CAS         7697-14-5;
InChIKey    RIYARDQGQOVCPK-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          665.95;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.3448;      // -   [origin=predictive method=lee-kesler]
Tb          450.20;      // K   [origin=predictive method=joback]
HvapTb      37057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.51 1.37012 -0.001235 4.779e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxybicyclo[2.2.2]octane" "bicyclo[2.2.2]octane,1-methoxy-" "bicyclo(2.2.2)octane, 1-methoxy-" );
gibbsFormation
{
    dHf_298   -212790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11710.0
    phase     gas;
}
