/*--------------------------------*- Choupo -*-----------------------*\
  Component: carbomethoxydihydroisophorone  (C11H18O3, CAS 54576-10-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        carbomethoxydihydroisophorone;
formula     C11H18O3;
CAS         54576-10-2;
InChIKey    ZYRYVGBRDTVCMK-UHFFFAOYSA-N;
MW          198.262;      // g/mol [origin=calculated method=formula-sum]
Tc          809.37;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.5695;      // -   [origin=predictive method=lee-kesler]
Tb          587.77;      // K   [origin=predictive method=joback]
HvapTb      50394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.99 1.18678 -0.0007388 2.008e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,4,4-trimethyl-6-oxidanylidene-cyclohexane-1-carboxylate" "methyl 2,4,4-trimethyl-6-oxocyclohexanecarboxylate" "cyclohexanecarboxylic acid, 2,4,4-trimethyl-6-oxo-, methyl ester" "methyl 2,4,4-trimethyl-6-oxocyclohexane-1-carboxylate" "2,4,4-trimethyl-6-oxocyclohexanecarboxylic acid methyl ester" );
gibbsFormation
{
    dHf_298   -696470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-387680.0
    phase     gas;
}
