name        nNBis3TrimethoxysilylPropylEthylenediamine;
formula     C14H36N2O6Si2;
CAS         68845-16-9;
InChIKey    HZGIOLNCNORPKR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          384.62;      // g/mol [origin=calculated method=formula-sum]
Tc          936.15;      // K   [origin=predictive method=joback]
Pc          12.073;      // bar [origin=predictive method=joback]
omega       1.0277;      // -   [origin=predictive method=lee-kesler]
Tb          757.58;      // K   [origin=predictive method=joback]
HvapTb      74678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (222.378 0.69472 0.0006606 -5.868e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH3O; count 6; } { group CH2NH; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
