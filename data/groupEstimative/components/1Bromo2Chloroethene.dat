/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-chloroethene  (C2H2BrCl, CAS 3018-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Chloroethene;
formula     C2H2BrCl;
CAS         3018-09-5;
InChIKey    LYFQYPSHMWBHFG-UHFFFAOYSA-N;
MW          141.392;      // g/mol [origin=calculated method=formula-sum]
Tc          561.02;      // K   [origin=predictive method=joback]
Pc          56.874;      // bar [origin=predictive method=joback]
omega       0.2570;      // -   [origin=predictive method=lee-kesler]
Tb          353.11;      // K   [origin=predictive method=joback]
HvapTb      30824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.97 0.2588 -0.0002606 1.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group Br; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-chloranyl-ethene" "agn-pc-00prpw" "ethene, 1-bromo-2-chloro-, (e)-" "ethene, 1-bromo-2-chloro-, (z)-" );
standardThermochemistry
{
    dHf_298   43200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     311.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48570.0
}
