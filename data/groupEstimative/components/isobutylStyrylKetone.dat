/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyl styryl ketone  (C13H16O, CAS 2892-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylStyrylKetone;
formula     C13H16O;
CAS         2892-18-4;
InChIKey    LLVCDRTZBYXKII-UHFFFAOYSA-N;
MW          188.27;      // g/mol [origin=calculated method=formula-sum]
Tc          799.75;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.5941;      // -   [origin=predictive method=lee-kesler]
Tb          581.31;      // K   [origin=predictive method=joback]
HvapTb      53124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.339 1.15784 -0.0007829 2.0686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-1-phenyl-hex-1-en-3-one" "1-hexen-3-one,5-methyl-1-phenyl-" "1-hexen-3-one, 5-methyl-1-phenyl-, (1e)-" );
gibbsFormation
{
    dHf_298   -75760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119850.0
    phase     gas;
}
