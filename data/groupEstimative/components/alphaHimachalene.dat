/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-alpha-himachalene  (C15H24, CAS 3853-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaHimachalene;
formula     C15H24;
CAS         3853-83-6;
InChIKey    ZJSIKVDEOWWVEH-KBPBESRZSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          802.34;      // K   [origin=predictive method=joback]
Pc          20.272;      // bar [origin=predictive method=joback]
omega       0.4293;      // -   [origin=predictive method=lee-kesler]
Tb          576.50;      // K   [origin=predictive method=joback]
HvapTb      49323.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.52 1.71506 -0.00130564 4.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4as,9ar)-3,5,5-trimethyl-9-methylidene-2,4a,6,7,8,9a-hexahydro-1h-benzo[7]annulene" "alpha-cis-himachalene" "himachal-4,11-diene" "alpha-himachalene, (-)-" "(-)-2,7(14)-himachaladiene" "(4as,9ar)-3,5,5-trimethyl-9-methylene-2,4a,5,6,7,8,9,9a-octahydro-1h-benzo[7]annulene" "(4as,9ar)-3,5,5-trimethyl-9-methylidene-2,4a,5,6,7,8,9,9a-octahydro-1h-benzo[7]annulene" "1h-benzocycloheptene, 2,4a,5,6,7,8,9,9a-octahydro-3,5,5-trimethyl-9-methylene-, (4as,9ar)-" );
standardThermochemistry
{
    dHf_298   -112680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196630.0
}
