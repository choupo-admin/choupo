/*--------------------------------*- Choupo -*-----------------------*\
  Component: oenanthotoxin  (C17H22O2, CAS 20311-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oenanthotoxin;
formula     C17H22O2;
CAS         20311-78-8;
InChIKey    UPXPHJXYZGEBCW-SRFVWEJJSA-N;
MW          258.361;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.88;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       1.3733;      // -   [origin=predictive method=lee-kesler]
Tb          802.96;      // K   [origin=predictive method=joback]
HvapTb      90584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.095 1.45312 -0.00103212 3.1036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 3; } { group OH; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 6; } { group tC; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,8e,10e,14r)-heptadeca-2,8,10-trien-4,6-diyne-1,14-diol" "enanthotoxin" );
gibbsFormation
{
    dHf_298   192310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     834.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=462440.0
    phase     gas;
}
