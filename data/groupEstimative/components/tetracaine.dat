/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetracaine  (C15H24N2O2, CAS 94-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetracaine;
formula     C15H24N2O2;
CAS         94-24-6;
InChIKey    GKCBAIGFKIBETG-UHFFFAOYSA-N;
MW          264.369;      // g/mol [origin=calculated method=formula-sum]
Tc          890.50;      // K   [origin=predictive method=joback]
Pc          18.483;      // bar [origin=predictive method=joback]
omega       0.9803;      // -   [origin=predictive method=lee-kesler]
Tb          695.29;      // K   [origin=predictive method=joback]
HvapTb      67808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.845 1.43576 -0.00082296 1.587e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2NH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethyl 4-(butylamino)benzoate" "amethocaine" "dicaine" "pontocaine" "tetracaina" "tetracainum" "tetrakain" "uromucaesthin" "anetain" "contralgin" "fissucain" "intercain" );
gibbsFormation
{
    dHf_298   -324150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     735.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68000.0
    phase     gas;
}
