/*--------------------------------*- Choupo -*-----------------------*\
  Component: actane  (C9H21N3O3, CAS 4719-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        actane;
formula     C9H21N3O3;
CAS         4719-04-4;
InChIKey    HUHGPYXAVBJSJV-UHFFFAOYSA-N;
MW          219.285;      // g/mol [origin=calculated method=formula-sum]
Tc          899.50;      // K   [origin=predictive method=joback]
Pc          36.776;      // bar [origin=predictive method=joback]
omega       2.0563;      // -   [origin=predictive method=lee-kesler]
Tb          730.79;      // K   [origin=predictive method=joback]
HvapTb      92016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.674 1.5099 -0.0011704 3.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group OH; count 3; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH2_ring; count 3; } { group OH; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3,5-bis(2-hydroxyethyl)-1,3,5-triazinan-1-yl]ethanol" "grotan" "grotan b" "grotan bk" "kalpur te" "grotan hd" "1,3,5-triazine-1,3,5(2h,4h,6h)-triethanol" "rancidity control agent" "roksol t 1-7" "km 200 (alcohol)" "eta 75" "hexahydro-1,3,5-tris(2-hydroxyethyl)-s-triazine" );
standardThermochemistry
{
    dHf_298   -390050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     659.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15240.0
}
