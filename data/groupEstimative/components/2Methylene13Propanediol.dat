/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylene-1,3-propanediol  (C4H8O2, CAS 3513-81-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylene13Propanediol;
formula     C4H8O2;
CAS         3513-81-3;
InChIKey    JFFYKITVXPZLQS-UHFFFAOYSA-N;
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          636.17;      // K   [origin=predictive method=joback]
Pc          53.202;      // bar [origin=predictive method=joback]
omega       1.1598;      // -   [origin=predictive method=lee-kesler]
Tb          472.04;      // K   [origin=predictive method=joback]
HvapTb      57266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.152 0.4317 -0.0002798 7.52e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylidenepropane-1,3-diol" "2-methylenepropane-1,3-diol" "1,3-propanediol, 2-methylene-" "1,3-dihydroxy-2-methylenepropane" "1,3-dihydroxy-2-methylidenepropane" "1,3-propanediol,2-methylene-" "h638" );
gibbsFormation
{
    dHf_298   -314710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-211550.0
    phase     gas;
}
