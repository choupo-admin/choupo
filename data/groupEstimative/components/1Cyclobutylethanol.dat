/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclobutylethanol  (C6H12O, CAS 7515-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclobutylethanol;
formula     C6H12O;
CAS         7515-29-9;
InChIKey    PFGPCAYJUYSJJS-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          624.38;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.6542;      // -   [origin=predictive method=lee-kesler]
Tb          439.63;      // K   [origin=predictive method=joback]
HvapTb      45326.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.32 0.75502 -0.00051 1.389e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclobutyl-ethanol" "1-cyclobutylethan-1-ol" "1-hydroxyethylcyclobutane" "1-methyl-cyclobutanemethanol" "alpha-methylcyclobutanemethanol" "cyclobutanemethanol, .alpha.-methyl-" "cyclobutanemethanol, 1-methyl-" );
gibbsFormation
{
    dHf_298   -258040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-90970.0
    phase     gas;
}
