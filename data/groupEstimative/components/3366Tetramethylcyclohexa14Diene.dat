/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,6,6-tetramethylcyclohexa-1,4-diene  (C10H16, CAS 2223-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3366Tetramethylcyclohexa14Diene;
formula     C10H16;
CAS         2223-54-3;
InChIKey    IDFBAZYYEXBGJO-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          661.14;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.2589;      // -   [origin=predictive method=lee-kesler]
Tb          442.08;      // K   [origin=predictive method=joback]
HvapTb      36256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-150.29 1.52128 -0.00158556 6.936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C_ring; count 2; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-cyclohexadiene, 3,3,6,6-tetramethyl-" "3,3,6,6-tetramethyl-cyclohexa-1,4-diene" );
standardThermochemistry
{
    dHf_298   -69710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99000.0
}
