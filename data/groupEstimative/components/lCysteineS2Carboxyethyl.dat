/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-cysteine,s-(2-carboxyethyl)-  (C6H11NO4S, CAS 4033-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lCysteineS2Carboxyethyl;
formula     C6H11NO4S;
CAS         4033-46-9;
InChIKey    FBPINGSGHKXIQA-BYPYZUCNSA-N;
MW          193.217;      // g/mol [origin=calculated method=formula-sum]
Tc          997.65;      // K   [origin=predictive method=joback]
Pc          42.496;      // bar [origin=predictive method=joback]
omega       1.4117;      // -   [origin=predictive method=lee-kesler]
Tb          768.77;      // K   [origin=predictive method=joback]
HvapTb      80348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.043 0.73759 -0.0004542 9.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CHNH2; count 1; } { group COOH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group COOH; count 2; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanyl-3-(3-hydroxy-3-oxopropylsulfanyl)propanoic acid" "aminocarboxyethylsulfanylpropanoicacid" "(2r)-2-amino-3-[(2-carboxyethyl)sulfanyl]propanoic acid" "alanine,3-[(2-carboxyethyl)thio]-, l- (8ci); 2-amino-4-thiaheptanedioic acid;3-(2-carboxyethylthio)alanine; s-(2-carboxyethyl)cysteine;s-2-carboxyethyl-l-cysteine; s-carboxyethyl-l-cysteine; s-carboxyethylcysteine" );
standardThermochemistry
{
    dHf_298   -797330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-591050.0
}
