/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxybis((3-aminopropyl)dimethylsilane)  (C10H28N2OSi2, CAS 2469-55-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H28N2OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        oxybis3AminopropylDimethylsilane;
formula     C10H28N2OSi2;
CAS         2469-55-8;
InChIKey    GPXCORHXFPYJEH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.517;      // g/mol [origin=calculated method=formula-sum]
Tc          792.27;      // K   [origin=predictive method=joback]
Pc          18.563;      // bar [origin=predictive method=joback]
omega       0.7018;      // -   [origin=predictive method=lee-kesler]
Tb          598.68;      // K   [origin=predictive method=joback]
HvapTb      62134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (113.916 0.60208 0.0003336 -3.594e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH2NH2; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group O; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[[3-azanylpropyl(dimethyl)silyl]oxy-dimethyl-silyl]propan-1-amine" "1,3-bis(3-aminopropyl)-1,1,3,3-tetramethyldisiloxane" "tetramethyl-1,3-bis(3-aminopropyl)disiloxane" "1,3-bis(3-aminopropyl)tetramethyldisiloxane" "bis(3-aminopropyl)tetramethyl disiloxane" "silane, oxybis((3-aminopropyl)dimethyl-" "bis(gamma-aminopropyl)tetramethyldisiloxane" "1-propanamine, 3,3'-(1,1,3,3-tetramethyl-1,3-disiloxanediyl)bis-" "3,3'-(1,1,3,3-tetramethyldisiloxane-1,3-diyl)bis(propan-1-amine)" "3,3'-(1,1,3,3-tetramethyldisiloxane-1,3-diyl)bispropylamine" "disiloxane, 1,3-bis(3-aminopropyl)-1,1,3,3-tetramethyl-" "5-oxa-4,6-disilanonane-1,9-diamine, 4,4,6,6-tetramethyl- (6ci,7ci,8ci)" );
standardThermochemistry
{
    dHf_298   -537610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     912.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148300.0
}
