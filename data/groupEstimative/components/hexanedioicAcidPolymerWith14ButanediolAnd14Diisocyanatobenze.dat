\*---------------------------------------------------------------------------*/

name        hexanedioicAcidPolymerWith14ButanediolAnd14Diisocyanatobenze;
formula     C18H24N2O8;
CAS         70714-86-2;
InChIKey    QAEWCCSJRRYRPK-UHFFFAOYSA-N;
MW          396.396;      // g/mol [origin=calculated method=formula-sum]
Tc          1564.18;      // K   [origin=predictive method=joback]
Pc          18.970;      // bar [origin=predictive method=joback]
omega       1.3002;      // -   [origin=predictive method=lee-kesler]
Tb          1254.62;      // K   [origin=predictive method=joback]
HvapTb      145938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 8; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 8; } { group dCd; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,4-diol;1,4-diisocyanatobenzene;hexanedioic acid" "1,4-butanediol, hexanedioic acid, 1,4-diisocyanatobenzene polymer" );
