/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(4-nonylphenoxy)-2-propanol  (C33H52O3, CAS 14795-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Bis4Nonylphenoxy2Propanol;
formula     C33H52O3;
CAS         14795-55-2;
InChIKey    GZHMCMAVIFKXEJ-UHFFFAOYSA-N;
MW          496.776;      // g/mol [origin=calculated method=formula-sum]
Tc          1444.67;      // K   [origin=predictive method=joback]
Pc          7.352;      // bar [origin=predictive method=joback]
omega       0.4931;      // -   [origin=predictive method=lee-kesler]
Tb          1154.54;      // K   [origin=predictive method=joback]
HvapTb      116039.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.712 2.77554 -0.00151132 2.824e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 18; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(4-nonylphenoxy)propan-2-ol" "2-propanol, 1,3-bis(4-nonylphenoxy)-" );
gibbsFormation
{
    dHf_298   -696280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1280.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=83280.0
    phase     gas;
}
