/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-heptyloxyaniline  (C13H21NO, CAS 39905-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Heptyloxyaniline;
formula     C13H21NO;
CAS         39905-44-7;
InChIKey    LTGYTOOKQWFTQG-UHFFFAOYSA-N;
MW          207.317;      // g/mol [origin=calculated method=formula-sum]
Tc          828.17;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.7897;      // -   [origin=predictive method=lee-kesler]
Tb          623.65;      // K   [origin=predictive method=joback]
HvapTb      60521.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.456 1.09912 -0.00057996 1.003e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-heptoxyaniline" "p-heptyloxyaniline" "4-n-heptyloxyaniline" "4-(heptyloxy)aniline" "4-heptyloxyphenylamine" "p-(heptyloxy)aniline" "benzenamine,4-(heptyloxy)-" "4-(heptyloxy)aniline;4-(heptyloxy)benzenamine;p-heptyloxyaniline;" );
gibbsFormation
{
    dHf_298   -185020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122810.0
    phase     gas;
}
