/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylethyl acrylate  (C11H12O2, CAS 3530-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylethylAcrylate;
formula     C11H12O2;
CAS         3530-36-7;
InChIKey    HPSGLFKWHYAKSF-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          743.95;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.5635;      // -   [origin=predictive method=lee-kesler]
Tb          532.86;      // K   [origin=predictive method=joback]
HvapTb      49093.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.598 0.8951 -0.0005341 1.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethyl prop-2-enoate" "2-propenoic acid, 2-phenylethyl ester" "phenethyl acrylate" "phenethyl prop-2-enoate" "acrylic acid, 2-phenylethyl ester" "2-propenoic acid,2-phenylethyl ester" "(hydroxymethyl)-cyclopentane;cyclopentylmethyl alcohol" "acrylicacid, phenethyl ester (7ci,8ci);phenethyl alcohol, acrylate (5ci);2-phenylethyl acrylate;phenethyl acrylate;2-phenylethyl prop-2-enoate;acrylic acid, 2-phenylethyl ester;acrylic acid phenethyl ester;" );
gibbsFormation
{
    dHf_298   -225690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68380.0
    phase     gas;
}
