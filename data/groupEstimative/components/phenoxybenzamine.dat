/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenoxybenzamine  (C18H22ClNO, CAS 59-96-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenoxybenzamine;
formula     C18H22ClNO;
CAS         59-96-1;
InChIKey    QZVCTJOXCFMACW-UHFFFAOYSA-N;
MW          303.83;      // g/mol [origin=calculated method=formula-sum]
Tc          959.55;      // K   [origin=predictive method=joback]
Pc          18.388;      // bar [origin=predictive method=joback]
omega       0.8223;      // -   [origin=predictive method=lee-kesler]
Tb          736.65;      // K   [origin=predictive method=joback]
HvapTb      68664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.266 1.62942 -0.001043 2.451e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-chloroethyl)-1-phenoxy-n-(phenylmethyl)propan-2-amine" "dibenyline" "dibenzyran" "bensylyt" "benzylyt" "dibenylene" "dibenylin" "fenoxibenzamina" "dibenziran" "dibenzylin" "fenossibenzamina" "phenoxybenzaminum" );
gibbsFormation
{
    dHf_298   -27500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316910.0
    phase     gas;
}
