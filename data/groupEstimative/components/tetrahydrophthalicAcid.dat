/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrophthalic acid  (C8H10O4, CAS 88-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrophthalicAcid;
formula     C8H10O4;
CAS         88-98-2;
InChIKey    ILUAAIDVFMVTAU-UHFFFAOYSA-N;
MW          170.164;      // g/mol [origin=calculated method=formula-sum]
Tc          920.16;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       1.0501;      // -   [origin=predictive method=lee-kesler]
Tb          687.70;      // K   [origin=predictive method=joback]
HvapTb      68142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.07 0.905 -0.00056948 1.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohex-4-ene-1,2-dicarboxylic acid" "1,2,3,6-tetrahydrophthalic acid" "4-cyclohexene-1,2-dicarboxylic acid" "hn 200" "rikacid th-w" "δ4-tetrahydrophthalic acid" "4-cyclohexene-1,2-dicarboxylicacid" "trans-4-cyclohexene-1,2-dicarboxylic acid" "delta4-tetrahydrophthalic acid" "cyclohex-3-ene-1,6-dicarboxylic acid" "1,2,3,6-tetrahydrophthalic acid; hn 200; nsc 239116; rikacid th-w; tetrahydrophthalic acid; ?4-tetrahydrophthalic acid" "tetrahydrophthalsaure" );
standardThermochemistry
{
    dHf_298   -817230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-624640.0
}
