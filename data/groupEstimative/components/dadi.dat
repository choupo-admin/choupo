name        dadi;
formula     C16H12N2O4;
CAS         91-93-0;
InChIKey    QZWKEPYTBWZJJA-UHFFFAOYSA-N;
MW          296.282;      // g/mol [origin=calculated method=formula-sum]
Tc          1052.41;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       1.1094;      // -   [origin=predictive method=lee-kesler]
Tb          817.14;      // K   [origin=predictive method=joback]
HvapTb      82294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 6; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group dCd; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group O; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-(4-isocyanato-3-methoxy-phenyl)-2-methoxy-benzene" "3,3'-dimethoxybenzidine-4,4'-diisocyanate" "dianisidine diisocyanate" "4,4'-diisocyanato-3,3'-dimethoxybiphenyl" "3,3'-dimethoxy-4,4'-biphenylene diisocyanate" "1,1'-biphenyl, 4,4'-diisocyanato-3,3'-dimethoxy-" "isocyanic acid, ester with o,o'-dimethoxybiphenyl" "dimethoxybenzidine-4,4'-diisocyanate" "isocyanic acid, 3,3'-dimethoxy-4,4'-biphenylylene ester" "3,3'-dimethoxy-4,4'-diphenylyl isocyanate" "3,3'-dimethoxy-4,4'-biphenylylene isocyanate" "4,4'-diisocyanato-3,3'-dimethoxy-1,1'-biphenyl" );
