/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetophenone diethyl ketal  (C12H18O2, CAS 4316-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetophenoneDiethylKetal;
formula     C12H18O2;
CAS         4316-37-4;
InChIKey    BWZAUXRKSMJLMH-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          750.61;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.5383;      // -   [origin=predictive method=lee-kesler]
Tb          542.45;      // K   [origin=predictive method=joback]
HvapTb      48106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.398 1.06436 -0.00061 1.194e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxyethylbenzene" );
standardThermochemistry
{
    dHf_298   -327670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-44590.0
}
