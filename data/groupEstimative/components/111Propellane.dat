/*--------------------------------*- Choupo -*-----------------------*\
  Component: [1.1.1]propellane  (C5H6, CAS 35634-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Propellane;
formula     C5H6;
CAS         35634-10-7;
InChIKey    ZTXSPLGEGCABFL-UHFFFAOYSA-N;
MW          66.103;      // g/mol [origin=calculated method=formula-sum]
Tc          520.17;      // K   [origin=predictive method=joback]
Pc          60.561;      // bar [origin=predictive method=joback]
omega       0.2238;      // -   [origin=predictive method=lee-kesler]
Tb          322.29;      // K   [origin=predictive method=joback]
HvapTb      23782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-237.82 1.5802 -0.002215 1.09e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1.1.1)propellane" );
gibbsFormation
{
    dHf_298   147330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     181.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218600.0
    phase     gas;
}
