/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-1-(trimethylsilyl)-1-propyne  (C6H11BrSi, CAS 38002-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H11BrSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Bromo1Trimethylsilyl1Propyne;
formula     C6H11BrSi;
CAS         38002-45-8;
InChIKey    GAPRPFRDVCCCHR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          191.143;      // g/mol [origin=calculated method=formula-sum]
Tc          632.57;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.2374;      // -   [origin=predictive method=lee-kesler]
Tb          413.44;      // K   [origin=predictive method=joback]
HvapTb      37831.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.001 0.25606 0.00013294 -1.4392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group Br; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group tC; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylprop-1-ynyl(trimethyl)silane" "3-(trimethylsilyl)propargyl bromide" "3-bromoprop-1-ynyl(trimethyl)silane" "(3-bromoprop-1-yn-1-yl)trimethylsilane" "silane, (3-bromo-1-propynyl)trimethyl-" "(3-bromo-1-propynyl)trimethylsilane" "(3-bromoprop-1-yn-1-yl)(trimethyl)silane" "3-(trimethylsilyl)propargyl bromide; 3-bromo-1-(trimethylsilyl)-1-propyne" );
standardThermochemistry
{
    dHf_298   19840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112000.0
}
