/*--------------------------------*- Choupo -*-----------------------*\
  Component: decanedioic acid; 2-(2-hydroxyethoxy)ethanol; propane-1,2,3-triol  (C17H36O10, CAS 63150-11-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decanedioicAcid22HydroxyethoxyEthanolPropane123Triol;
formula     C17H36O10;
CAS         63150-11-8;
InChIKey    LUEQRFVXODADPE-UHFFFAOYSA-N;
MW          400.465;      // g/mol [origin=calculated method=formula-sum]
Tc          1954.64;      // K   [origin=predictive method=joback]
Pc          17.405;      // bar [origin=predictive method=joback]
omega       0.2258;      // -   [origin=predictive method=lee-kesler]
Tb          1365.26;      // K   [origin=predictive method=joback]
HvapTb      173769.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (128.544 1.4207 -0.0002608 -1.936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group CH; count 1; } { group OH; count 4; } { group COOH; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 14; } { group CH; count 1; } { group OH; count 5; } { group O; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanedioic acid;2-(2-hydroxyethyloxy)ethanol;propane-1,2,3-triol" );
standardThermochemistry
{
    dHf_298   -2216640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1395.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1596620.0
}
