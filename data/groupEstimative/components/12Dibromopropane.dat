/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromopropane  (C3H6Br2, CAS 78-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromopropane;
formula     C3H6Br2;
CAS         78-75-1;
InChIKey    XFNJYAKDBJUJAJ-UHFFFAOYSA-N;
MW          201.889;      // g/mol [origin=calculated method=formula-sum]
Tc          614.09;      // K   [origin=predictive method=joback]
Pc          54.066;      // bar [origin=predictive method=joback]
omega       0.3683;      // -   [origin=predictive method=lee-kesler]
Tb          400.12;      // K   [origin=predictive method=joback]
HvapTb      34754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.861 0.37112 -0.0002854 9.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)propane" "propylene dibromide" "propane, 1,2-dibromo-" "propylene bromide" "2,3-dibromopropane" "propane, 1,2-dibromo-, (r)-" "propane, 1,2-dibromo-, (s)-" "2,3-dibromopropane;propylene dibromide;" );
standardThermochemistry
{
    dHf_298   -57870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=580.0
}
