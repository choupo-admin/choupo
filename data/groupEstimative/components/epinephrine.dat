/*--------------------------------*- Choupo -*-----------------------*\
  Component: epinephrine  (C9H13NO3, CAS 51-43-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        epinephrine;
formula     C9H13NO3;
CAS         51-43-4;
InChIKey    UCTWMZQNUQWSLP-VIFPVBQESA-N;
MW          183.207;      // g/mol [origin=calculated method=formula-sum]
Tc          953.75;      // K   [origin=predictive method=joback]
Pc          55.692;      // bar [origin=predictive method=joback]
omega       1.5984;      // -   [origin=predictive method=lee-kesler]
Tb          735.35;      // K   [origin=predictive method=joback]
HvapTb      86659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.639 1.20522 -0.00109192 4.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 2; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(1r)-2-(methylamino)-1-oxidanyl-ethyl]benzene-1,2-diol" "l-adrenaline" "adrenaline" "adrenalin" "l-epinephrine" "levoepinephrine" "epinefrina" "twinject" "adrenal" "epifrin" "epipen" "medihaler-epi" );
standardThermochemistry
{
    dHf_298   -451220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-221800.0
}
