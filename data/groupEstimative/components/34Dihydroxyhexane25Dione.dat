/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dihydroxyhexane-2,5-dione  (C6H10O4, CAS 25566-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dihydroxyhexane25Dione;
formula     C6H10O4;
CAS         25566-16-9;
InChIKey    RQDWELNLPMBYMA-UHFFFAOYSA-N;
MW          146.142;      // g/mol [origin=calculated method=formula-sum]
Tc          807.45;      // K   [origin=predictive method=joback]
Pc          46.403;      // bar [origin=predictive method=joback]
omega       1.5859;      // -   [origin=predictive method=lee-kesler]
Tb          628.10;      // K   [origin=predictive method=joback]
HvapTb      75024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.37 0.59764 -0.0003324 6.072e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group OH; count 2; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group OH; count 2; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(oxidanyl)hexane-2,5-dione" "1,6-dideoxyhexo-2,5-diulose" "threo-2,5-hexodiulose, 1,6-dideoxy-" "erythro-2,5-hexodiulose, 1,6-dideoxy-" "2,5-hexanedione,3,4-dihydroxy- (8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -707350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-536720.0
}
