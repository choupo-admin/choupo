/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromophenethylamine  (C8H10BrN, CAS 73918-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromophenethylamine;
formula     C8H10BrN;
CAS         73918-56-6;
InChIKey    ZSZCXAOQVBEPME-UHFFFAOYSA-N;
MW          200.079;      // g/mol [origin=calculated method=formula-sum]
Tc          793.05;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.5950;      // -   [origin=predictive method=lee-kesler]
Tb          552.99;      // K   [origin=predictive method=joback]
HvapTb      53416.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.308 0.7255 -0.00049036 1.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2NH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-bromophenyl)ethanamine" "2-(4-bromophenyl)ethylamine" "p-bromophenethylamine" "2-(4-bromo-phenyl)-ethylamine" "benzeneethanamine, 4-bromo-" "2-(4-bromophenyl)ethan-1-amine" "1-amino-2-(4-bromophenyl)ethane" "2-(4-bromophenyl)ethan-1-amine hydrobromide" "4-bromophenylethylamine" "2-(4-bromophenyl)-ethylamine" "4-bromo-benzeneethanamine" "i333" );
standardThermochemistry
{
    dHf_298   76730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200030.0
}
