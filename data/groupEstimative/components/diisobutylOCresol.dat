/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisobutyl-o-cresol  (C15H24O, CAS 66027-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisobutylOCresol;
formula     C15H24O;
CAS         66027-98-3;
InChIKey    SOGRWPBNEICCRE-UHFFFAOYSA-N;
MW          220.356;      // g/mol [origin=calculated method=formula-sum]
Tc          870.36;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       0.7889;      // -   [origin=predictive method=lee-kesler]
Tb          659.18;      // K   [origin=predictive method=joback]
HvapTb      64822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.338 1.3974 -0.00095208 2.751e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group ACH; count 2; } { group ACCH3; count 1; } { group ACCH2; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4,6-bis(2-methylpropyl)phenol" "phenol, 2-methylbis(2-methylpropyl)-" "diisobutylorthocresol" );
gibbsFormation
{
    dHf_298   -327210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9070.0
    phase     gas;
}
