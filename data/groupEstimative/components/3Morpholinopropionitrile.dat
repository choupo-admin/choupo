/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-morpholinopropionitrile  (C7H12N2O, CAS 4542-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Morpholinopropionitrile;
formula     C7H12N2O;
CAS         4542-47-6;
InChIKey    WXVKGHVDWWXBJX-UHFFFAOYSA-N;
MW          140.186;      // g/mol [origin=calculated method=formula-sum]
Tc          735.13;      // K   [origin=predictive method=joback]
Pc          34.079;      // bar [origin=predictive method=joback]
omega       0.5983;      // -   [origin=predictive method=lee-kesler]
Tb          521.18;      // K   [origin=predictive method=joback]
HvapTb      48773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.268 0.8827 -0.0006075 1.622e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group FCH2O; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-morpholin-4-ylpropanenitrile" "4-morpholinepropanenitrile" "4-morpholinepropionitrile" "3-(morpholin-4-yl)propanenitrile" "n-(2-cyanoethyl)morpholine" "cyanoethylmorpholine" "3-(4-morpholino)propionitrile" "propionitrile, 3-morpholino-" ".beta.-morpholinopropionitrile" "3-morpholinopropiononitrile" "beta-morpholinopropionitrile" "3-(4-morpholinyl)propanenitrile" );
standardThermochemistry
{
    dHf_298   -6580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=210160.0
}
