/*--------------------------------*- Choupo -*-----------------------*\
  Component: bibenzyl  (C14H14, CAS 103-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bibenzyl;
formula     C14H14;
CAS         103-29-7;
InChIKey    QWUWMCYKGHVNAV-UHFFFAOYSA-N;
MW          182.266;      // g/mol [origin=calculated method=formula-sum]
Tc          812.95;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.4748;      // -   [origin=predictive method=lee-kesler]
Tb          573.28;      // K   [origin=predictive method=joback]
HvapTb      51310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.648 1.176 -0.0008002 2.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethylbenzene" "1,2-diphenylethane" "dibenzyl" "s-diphenylethane" "dibenzil" "1,2-dihydrostilbene" "sym-diphenylethane" "dihydrostilbene" "benzene, 1,1'-(1,2-ethanediyl)bis-" "(2-phenylethyl)benzene" "1,2-diphenylethane, s" "ethane, 1,2-diphenyl-" );
gibbsFormation
{
    dHf_298   140770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291820.0
    phase     gas;
}
