/*--------------------------------*- Choupo -*-----------------------*\
  Component: duogynon  (C46H58O5, CAS 8000-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        duogynon;
formula     C46H58O5;
CAS         8000-03-1;
InChIKey    MVNXVUVQPCKKIA-YMDAVDRCSA-N;
MW          690.965;      // g/mol [origin=calculated method=formula-sum]
Tc          2086.45;      // K   [origin=predictive method=joback]
Pc          6.977;      // bar [origin=predictive method=joback]
omega       0.3822;      // -   [origin=predictive method=lee-kesler]
Tb          1652.14;      // K   [origin=predictive method=joback]
HvapTb      156099.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-454.51 5.31708 -0.00417826 1.39716e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 7; } { group C; count 3; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 14; } { group CH_ring; count 8; } { group C_ring; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group OH; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,10r,13s,14s,17s)-17-ethanoyl-10,13-dimethyl-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-3-one;[(8r,9s,13s,14s,17s)-13-methyl-17-oxidanyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-3-yl] benzoate" "limovanil" "duogynon forte" "duogynon simplex" "estroprogyn" "jephagynon" "klimovan" "menstrogen forte" "synovex c" "tonevex s" "implus s" "implus-c" );
gibbsFormation
{
    dHf_298   -896910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1383.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52110.0
    phase     gas;
}
