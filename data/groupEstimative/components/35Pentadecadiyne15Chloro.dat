/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-pentadecadiyne, 15-chloro-  (C15H23Cl, CAS 71317-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Pentadecadiyne15Chloro;
formula     C15H23Cl;
CAS         71317-68-5;
InChIKey    QLSTWVRRDLEVRU-UHFFFAOYSA-N;
MW          238.799;      // g/mol [origin=calculated method=formula-sum]
Tc          798.99;      // K   [origin=predictive method=joback]
Pc          17.729;      // bar [origin=predictive method=joback]
omega       0.6084;      // -   [origin=predictive method=lee-kesler]
Tb          598.23;      // K   [origin=predictive method=joback]
HvapTb      57673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.26 1.13602 -0.00062832 1.3426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2Cl; count 1; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group tC; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "15-chloranylpentadeca-3,5-diyne" "15-chloropentadeca-3,5-diyne" );
standardThermochemistry
{
    dHf_298   175930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=469090.0
}
