/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7-dimethylocta-2,6-dienyl but-2-enoate  (C14H22O2, CAS 56172-46-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        37Dimethylocta26DienylBut2Enoate;
formula     C14H22O2;
CAS         56172-46-4;
InChIKey    MQTAGIYIVBMTBT-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          780.78;      // K   [origin=predictive method=joback]
Pc          17.492;      // bar [origin=predictive method=joback]
omega       0.6706;      // -   [origin=predictive method=lee-kesler]
Tb          590.38;      // K   [origin=predictive method=joback]
HvapTb      54199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.357 1.33888 -0.0008992 2.441e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH=CH; count 1; } { group CH=C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH; count 4; } { group dC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butenoic acid (2e)-3,7-dimethyl-2,6-octadienyl ester" "(,z)-3,7-dimethyl-2,6-octadienyl 2-butenoate" "(z)-3,7-dimethyl-2,6-octadienyl 2-butenoate" "2-butenoic acid, (2e)-3,7-dimethyl-2,6-octadien-1-yl ester" "2-butenoic acid,(2e)-3,7-dimethyl-2,6-octadien-1-yl ester" "2-butenoic acid,3,7-dimethyl-2,6-octadienyl ester, (?,z)- (9ci)" "2-butenoicacid, (2e)-3,7-dimethyl-2,6-octadienyl ester (9ci); 2-butenoic acid,3,7-dimethyl-2,6-octadienyl ester, (?,e)-; geranyl crotonate" );
standardThermochemistry
{
    dHf_298   -317490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-19810.0
}
