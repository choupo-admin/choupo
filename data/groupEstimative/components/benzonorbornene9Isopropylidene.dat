/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzonorbornene, 9-isopropylidene-  (C14H16, CAS 7350-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzonorbornene9Isopropylidene;
formula     C14H16;
CAS         7350-77-8;
InChIKey    LKPODQYMUXPGQW-UHFFFAOYSA-N;
MW          184.282;      // g/mol [origin=calculated method=formula-sum]
Tc          795.89;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.4965;      // -   [origin=predictive method=lee-kesler]
Tb          567.31;      // K   [origin=predictive method=joback]
HvapTb      50217.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.4 1.42924 -0.00115956 3.872e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   110770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     355.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=340290.0
    phase     gas;
}
