/*--------------------------------*- Choupo -*-----------------------*\
  Component: dioctyl maleate  (C20H36O4, CAS 2915-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dioctylMaleate;
formula     C20H36O4;
CAS         2915-53-9;
InChIKey    TVWTZAGVNBPXHU-NXVVXOECSA-N;
MW          340.504;      // g/mol [origin=calculated method=formula-sum]
Tc          957.62;      // K   [origin=predictive method=joback]
Pc          10.569;      // bar [origin=predictive method=joback]
omega       0.9535;      // -   [origin=predictive method=lee-kesler]
Tb          777.80;      // K   [origin=predictive method=joback]
HvapTb      74886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.344 1.81424 -0.0009588 1.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dioctyl (z)-but-2-enedioate" "di-n-octyl maleate" "bis(1-octyl) maleate" "2-butenedioic acid (2z)-, dioctyl ester" "maleic acid, dioctyl ester" "2-butenedioic acid (z)-, dioctyl ester" "2-butenedioic acid (2z)-, 1,4-dioctyl ester" "dioctyl (2z)-but-2-enedioate" "o647" "2-butenedioic acid (z)-, dioctyl ester (9ci)" );
gibbsFormation
{
    dHf_298   -973470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1031.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-423000.0
    phase     gas;
}
