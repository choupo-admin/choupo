/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-heneicosene  (C21H42, CAS 27400-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Heneicosene;
formula     C21H42;
CAS         27400-79-9;
InChIKey    JTOGFHAZQVDOAO-UHFFFAOYSA-N;
MW          294.567;      // g/mol [origin=calculated method=formula-sum]
Tc          839.66;      // K   [origin=predictive method=joback]
Pc          9.815;      // bar [origin=predictive method=joback]
omega       0.8075;      // -   [origin=predictive method=lee-kesler]
Tb          676.76;      // K   [origin=predictive method=joback]
HvapTb      61670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.192 1.97882 -0.0011415 2.561e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "henicos-1-ene" "henicosene" "heneicosene" "n-heneicosene" "heneicosene-" );
gibbsFormation
{
    dHf_298   -351340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     969.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213780.0
    phase     gas;
}
