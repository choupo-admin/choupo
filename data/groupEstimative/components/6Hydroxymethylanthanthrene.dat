/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-hydroxymethylanthanthrene  (C23H14O, CAS 105708-72-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Hydroxymethylanthanthrene;
formula     C23H14O;
CAS         105708-72-3;
InChIKey    YWJXFEXZVZQIRV-UHFFFAOYSA-N;
MW          306.364;      // g/mol [origin=calculated method=formula-sum]
Tc          1191.38;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       1.4152;      // -   [origin=predictive method=lee-kesler]
Tb          949.10;      // K   [origin=predictive method=joback]
HvapTb      95985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.429 1.9783 -0.00184844 6.9e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 10; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 11; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo(def,mno)chrysene-6-methanol" "dibenzo[def,mno]chrysene-6-methanol" );
standardThermochemistry
{
    dHf_298   373330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=591950.0
}
