/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-2-hydroxypropanoic acid  (C3H5ClO3, CAS 1713-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro2HydroxypropanoicAcid;
formula     C3H5ClO3;
CAS         1713-85-5;
InChIKey    OSLCJYYQMKPZHU-UHFFFAOYSA-N;
MW          124.52;      // g/mol [origin=calculated method=formula-sum]
Tc          737.23;      // K   [origin=predictive method=joback]
Pc          54.546;      // bar [origin=predictive method=joback]
omega       1.1059;      // -   [origin=predictive method=lee-kesler]
Tb          542.92;      // K   [origin=predictive method=joback]
HvapTb      60112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.261 0.3863 -0.000266 7.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2-oxidanyl-propanoic acid" "3-chlorolactic acid" "beta-chlorolactic acid" "3-chloro-2-hydroxypropionic acid" "propanoic acid, 3-chloro-2-hydroxy-" "3-chlorolactate" "chlorolactic acid" "(2r)-3-chloro-2-hydroxypropanoic acid" "(2s)-3-chloro-2-hydroxypropanoic acid" "a-chlorolactic acid" "3-chloro-lactic acid" "dl-3-chlorolactic acid" );
gibbsFormation
{
    dHf_298   -628770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520720.0
    phase     gas;
}
