/*--------------------------------*- Choupo -*-----------------------*\
  Component: decahydroquinoline  (C9H17N, CAS 2051-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decahydroquinoline;
formula     C9H17N;
CAS         2051-28-7;
InChIKey    POTIYWUALSJREP-UHFFFAOYSA-N;
MW          139.242;      // g/mol [origin=calculated method=formula-sum]
Tc          716.80;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.3660;      // -   [origin=predictive method=lee-kesler]
Tb          484.63;      // K   [origin=predictive method=joback]
HvapTb      42900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-109.34 1.1088 -0.00066 1.42e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,4a,5,6,7,8,8a-decahydroquinoline" "trans-decahydroquinoline" "quinoline, decahydro-" "cis-decahydroquinoline" "quinoline, decahydro-, cis-" "perhydroquinoline" "quinoline, decahydro-, trans-" "decahydroquinoline, mixture of cis and trans" "2-azabicyclo[4.4.0]decane" "(4ar,8ar)-decahydroquinoline" "quinoline, decahydro-, (4ar,8as)-rel-" "agn-pc-0cxswt" );
standardThermochemistry
{
    dHf_298   -70320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185710.0
}
