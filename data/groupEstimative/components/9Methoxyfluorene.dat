/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-methoxyfluorene  (C14H12O, CAS 19126-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Methoxyfluorene;
formula     C14H12O;
CAS         19126-15-9;
InChIKey    JGLHXBNHKQAROV-UHFFFAOYSA-N;
MW          196.249;      // g/mol [origin=calculated method=formula-sum]
Tc          842.71;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.5809;      // -   [origin=predictive method=lee-kesler]
Tb          603.86;      // K   [origin=predictive method=joback]
HvapTb      54613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.55 1.16392 -0.00086812 2.609e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-methoxy-9h-fluorene" "9h-fluoren-9-yl methyl ether" "9h-fluorene, 9-methoxy-" );
gibbsFormation
{
    dHf_298   70730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252510.0
    phase     gas;
}
