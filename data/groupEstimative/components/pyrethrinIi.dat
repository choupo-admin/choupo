/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrethrin ii  (C22H28O5, CAS 121-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrethrinIi;
formula     C22H28O5;
CAS         121-29-9;
InChIKey    VJFUPGQZSXIULQ-UHFFFAOYSA-N;
MW          372.461;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.42;      // K   [origin=predictive method=joback]
Pc          12.407;      // bar [origin=predictive method=joback]
omega       0.9735;      // -   [origin=predictive method=lee-kesler]
Tb          914.14;      // K   [origin=predictive method=joback]
HvapTb      82970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.369 2.1824 -0.0015552 4.722e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 3; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 4; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methyl-4-oxidanylidene-3-penta-2,4-dienyl-cyclopent-2-en-1-yl) 3-(3-methoxy-2-methyl-3-oxidanylidene-prop-1-enyl)-2,2-dimethyl-cyclopropane-1-carboxylate" "agn-pc-0dbfyd" "cyclopropanecarboxylic acid, 3-[(1e)-3-methoxy-2-methyl-3-oxo-1-propen-1-yl]-2,2-dimethyl-, (1s)-2-methyl-4-oxo-3-(2z)-2,4-pentadien-1-yl-2-cyclopenten-1-yl ester, (1r,3r)-" "(2-methyl-4-oxo-3-penta-2,4-dienylcyclopent-2-en-1-yl) 3-(3-methoxy-2-methyl-3-oxoprop-1-enyl)-2,2-dimethylcyclopropane-1-carboxylate" "[(1s)-2-methyl-4-oxo-3-[(2z)-penta-2,4-dienyl]cyclopent-2-en-1-yl] 3-[(e)-3-methoxy-2-methyl-3-oxoprop-1-enyl]-2,2-dimethylcyclopropane-1-carboxylate" "cyclopropaneacrylicacid, 3-carboxy-a,2,2-trimethyl-,1-methyl ester, ester with4-hydroxy-3-methyl-2-(2,4-pentadienyl)-2-cyclopenten-1-one (7ci,8ci);cyclopropanecarboxylic acid,3-(3-methoxy-2-methyl-3-oxo-1-propenyl)-2,2-dimethyl-, 2-methyl-4-oxo-3-(2,4-pentadienyl)-2-cyclopenten-1-ylester, [1r-[1a[s*(z)],3b(e)]]-; cyclopropanecarboxylicacid, 3-[(1e)-3-methoxy-2-methyl-3-oxo-1-propenyl]-2,2-dimethyl-,(1s)-2-methyl-4-oxo-3-(2z)-2,4-pentadienyl-2-cyclopenten-1-yl ester, (1r,3r)-(9ci); pyrethrin ii (6ci); (+)-pyrethronyl (+)-pyrethrate; biospray s;pyrethrin; pyrethrin 2; pyrethrum mist" "cyclopropanecarboxylicacid, 3-[(1e)-3-methoxy-2-methyl-3-oxo-1-propen-1-yl]-2,2-dimethyl-,(1s)-2-methyl-4-oxo-3-(2z)-2,4-pentadien-1-yl-2-cyclopenten-1-yl ester,(1r,3r)-" );
gibbsFormation
{
    dHf_298   -776910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     809.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-282150.0
    phase     gas;
}
