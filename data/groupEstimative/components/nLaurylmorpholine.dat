/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-laurylmorpholine  (C16H33NO, CAS 1541-81-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nLaurylmorpholine;
formula     C16H33NO;
CAS         1541-81-7;
InChIKey    ZRIILUSQBDFVNY-UHFFFAOYSA-N;
MW          255.446;      // g/mol [origin=calculated method=formula-sum]
Tc          802.08;      // K   [origin=predictive method=joback]
Pc          15.355;      // bar [origin=predictive method=joback]
omega       0.8307;      // -   [origin=predictive method=lee-kesler]
Tb          625.02;      // K   [origin=predictive method=joback]
HvapTb      58329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.449 1.80292 -0.0011281 2.756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-dodecylmorpholine" "morpholine, 4-dodecyl-" "n-dodecylmorpholine" "dodecyl morpholine" "4-dodecyl-morpholine" "4-(n-dodecyl)morpholine;4-dodecylmorpholine; 4-laurylmorpholine; busan 2180; busperse 2180; ddm;n-dodecylmorpholine; n-laurylmorpholine" );
standardThermochemistry
{
    dHf_298   -357220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     735.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152760.0
}
