/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-(4-phenylphenyl)cyclohex-2-en-1-one  (C20H20O, CAS 72036-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl34PhenylphenylCyclohex2En1One;
formula     C20H20O;
CAS         72036-53-4;
InChIKey    KZFBORHKRNSIDA-UHFFFAOYSA-N;
MW          276.379;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.41;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       0.6969;      // -   [origin=predictive method=lee-kesler]
Tb          807.29;      // K   [origin=predictive method=joback]
HvapTb      69807.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.89 1.81674 -0.0013494 4.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-(p-phenylphenyl)cyclohex-2-en-1-one" "5,5-dimethyl-3-(p-phenylphenyl)-cyclohex-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -16370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249410.0
}
