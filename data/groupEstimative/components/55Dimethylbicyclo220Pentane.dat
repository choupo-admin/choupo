/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethylbicyclo[2.2.0]pentane  (C7H12, CAS 71805-64-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethylbicyclo220Pentane;
formula     C7H12;
CAS         71805-64-6;
InChIKey    RRXLWLMOBNGNIB-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          558.93;      // K   [origin=predictive method=joback]
Pc          37.045;      // bar [origin=predictive method=joback]
omega       0.2467;      // -   [origin=predictive method=lee-kesler]
Tb          364.54;      // K   [origin=predictive method=joback]
HvapTb      29370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.89 1.24564 -0.001321 5.704e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethylbicyclo[2.1.0]pentane" "5,5-dimethylbicyclo(2.2.0)pentane" );
gibbsFormation
{
    dHf_298   -41150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     255.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128460.0
    phase     gas;
}
