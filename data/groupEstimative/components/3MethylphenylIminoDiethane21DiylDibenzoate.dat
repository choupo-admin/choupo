/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(3-methylphenyl)imino]diethane-2,1-diyl dibenzoate  (C25H25NO4, CAS 35473-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylphenylIminoDiethane21DiylDibenzoate;
formula     C25H25NO4;
CAS         35473-24-6;
InChIKey    OKHLRTNFXBTUBG-UHFFFAOYSA-N;
MW          403.478;      // g/mol [origin=calculated method=formula-sum]
Tc          1223.91;      // K   [origin=predictive method=joback]
Pc          14.435;      // bar [origin=predictive method=joback]
omega       1.1211;      // -   [origin=predictive method=lee-kesler]
Tb          985.50;      // K   [origin=predictive method=joback]
HvapTb      95591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.126 2.09692 -0.00128616 2.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 14; } { group AC; count 3; } { group ACCH3; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(3-methylphenyl)-[2-(phenylcarbonyloxy)ethyl]amino]ethyl benzoate" "ethanol, 2,2'-((3-methylphenyl)imino)bis-, 1,1'-dibenzoate" "ethanol, 2,2'-[(3-methylphenyl)imino]bis-, 1,1'-dibenzoate" "ethanol, 2,2'-((3-methylphenyl)imino)bis-, dibenzoate (ester)" "ethanol, 2,2'-[(3-methylphenyl)imino]bis-, dibenzoate (ester)" "benzoic acid, (m-tolylimino)diethylene ester" "2-[n-(2-benzoyloxyethyl)-3-methylanilino]ethyl benzoate" );
standardThermochemistry
{
    dHf_298   -428240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     923.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22740.0
}
