/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-3,5-dimethoxy-4-hydroxy cinnamaldehyde  (C11H12O4, CAS 4206-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans35Dimethoxy4HydroxyCinnamaldehyde;
formula     C11H12O4;
CAS         4206-58-0;
InChIKey    CDICDSOGTRCHMG-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          888.84;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.9834;      // -   [origin=predictive method=lee-kesler]
Tb          666.20;      // K   [origin=predictive method=joback]
HvapTb      68192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.88 0.87364 -0.00058288 1.642e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CHO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,5-dimethoxy-4-oxidanyl-phenyl)prop-2-enal" "2-propenal, 3-(4-hydroxy-3,5-dimethoxyphenyl)-" "3-(4-hydroxy-3,5-dimethoxyphenyl)prop-2-enal" "2-propenal,3-(4-hydroxy-3,5-dimethoxyphenyl)-, (e)-;cinnamaldehyde,4-hydroxy-3,5-dimethoxy- (6ci,7ci,8ci);(e)-3,5-dimethoxy-4-hydroxyphenylpropenaldehyde;sinapaldehyde;sinapicaldehyde;sinapyl aldehyde;trans-sinapaldehyde;" );
standardThermochemistry
{
    dHf_298   -466890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-249030.0
}
