/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol,3-methyl-5-[(2,2,3-trimethyl-3-cyclopenten-1-yl)methyl]-  (C16H28O, CAS 71820-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol3Methyl5223Trimethyl3Cyclopenten1YlMethyl;
formula     C16H28O;
CAS         71820-51-4;
InChIKey    QIKFHKJUSSWJJF-UHFFFAOYSA-N;
MW          236.399;      // g/mol [origin=calculated method=formula-sum]
Tc          887.72;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       0.8545;      // -   [origin=predictive method=lee-kesler]
Tb          683.06;      // K   [origin=predictive method=joback]
HvapTb      67451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.549 1.90858 -0.00137204 4.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-5-[(2,2,3-trimethylcyclopent-3-en-1-yl)methyl]cyclohexan-1-ol" "3-methyl-5-[(2,2,3-trimethyl-3-cyclopenten-1-yl)methyl]cyclohexan-1-ol" "3-methyl-5-((2,2,3-trimethyl-3-cyclopenten-1-yl)methyl)cyclohexan-1-ol" "cyclohexanol, 3-methyl-5-((2,2,3-trimethyl-3-cyclopenten-1-yl)methyl)-" "cyclohexanol, 3-methyl-5-[(2,2,3-trimethyl-3-cyclopenten-1-yl)methyl]-" "3-((2,2,3-trimethyl-3-cyclopenten-1-yl)methyl)-5-methyl-1-cyclohexanol" );
gibbsFormation
{
    dHf_298   -410470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     648.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270.0
    phase     gas;
}
