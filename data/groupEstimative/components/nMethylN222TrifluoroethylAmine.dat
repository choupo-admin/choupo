/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-n-(2,2,2-trifluoroethyl)amine  (C3H6F3N, CAS 2730-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylN222TrifluoroethylAmine;
formula     C3H6F3N;
CAS         2730-67-8;
InChIKey    XZYJNHZNHGUSNY-UHFFFAOYSA-N;
MW          113.082;      // g/mol [origin=calculated method=formula-sum]
Tc          465.48;      // K   [origin=predictive method=joback]
Pc          38.627;      // bar [origin=predictive method=joback]
omega       0.3821;      // -   [origin=predictive method=lee-kesler]
Tb          312.99;      // K   [origin=predictive method=joback]
HvapTb      24961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.249 0.52622 -0.000409 1.237e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3NH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group F; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(fluoranyl)-n-methyl-ethanamine" "2,2,2-trifluoro-n-methylethanamine" "n-methyl-2,2,2-trifluoroethylamine" "methyl-(2,2,2-trifluoro-ethyl)-amine" );
standardThermochemistry
{
    dHf_298   -648860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     369.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-517820.0
}
