/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-2-octyl-1,3-dioxane  (C14H28O2, CAS 6974-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl2Octyl13Dioxane;
formula     C14H28O2;
CAS         6974-80-7;
InChIKey    UBZVSDZJBLSIJG-UHFFFAOYSA-N;
MW          228.376;      // g/mol [origin=calculated method=formula-sum]
Tc          781.76;      // K   [origin=predictive method=joback]
Pc          17.909;      // bar [origin=predictive method=joback]
omega       0.6578;      // -   [origin=predictive method=lee-kesler]
Tb          588.94;      // K   [origin=predictive method=joback]
HvapTb      54747.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.853 1.71536 -0.0012682 4.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -547070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     595.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93990.0
}
