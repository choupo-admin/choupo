/*--------------------------------*- Choupo -*-----------------------*\
  Component: buprenorphine  (C29H41NO4, CAS 52485-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buprenorphine;
formula     C29H41NO4;
CAS         52485-79-7;
InChIKey    RMRJXGBAOAMLHD-IHFGGWKQSA-N;
MW          467.65;      // g/mol [origin=calculated method=formula-sum]
Tc          1416.02;      // K   [origin=predictive method=joback]
Pc          14.590;      // bar [origin=predictive method=joback]
omega       1.3033;      // -   [origin=predictive method=lee-kesler]
Tb          1155.86;      // K   [origin=predictive method=joback]
HvapTb      115184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-484.469 4.8327 -0.00502538 2.0916e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 3; } { group C; count 5; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH; count 1; } { group OH_phenol; count 1; } { group O; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "temgesic" "buprenex" "buprenorfina" "buprenorphinum" "probuphine" "buprenophine" "(-)-buprenorphine" "subutex" "butrans" "buprenorphinum [inn-latin]" "buprel" "norspan" );
standardThermochemistry
{
    dHf_298   -497530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     727.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=284870.0
}
