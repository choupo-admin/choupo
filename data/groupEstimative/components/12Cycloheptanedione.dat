/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-cycloheptanedione  (C7H10O2, CAS 3008-39-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Cycloheptanedione;
formula     C7H10O2;
CAS         3008-39-7;
InChIKey    SLOCIJOTBVAMAJ-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          775.38;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.4283;      // -   [origin=predictive method=lee-kesler]
Tb          523.89;      // K   [origin=predictive method=joback]
HvapTb      40580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.28 0.4712 4.1e-05 -1.46e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloheptane-1,2-dione" );
standardThermochemistry
{
    dHf_298   -394710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-217060.0
}
