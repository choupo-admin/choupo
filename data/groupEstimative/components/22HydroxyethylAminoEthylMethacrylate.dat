/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-((2-hydroxyethyl)amino)ethyl methacrylate  (C8H15NO3, CAS 51706-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22HydroxyethylAminoEthylMethacrylate;
formula     C8H15NO3;
CAS         51706-72-0;
InChIKey    HVWSSABJCTUASX-UHFFFAOYSA-N;
MW          173.212;      // g/mol [origin=calculated method=formula-sum]
Tc          753.69;      // K   [origin=predictive method=joback]
Pc          29.893;      // bar [origin=predictive method=joback]
omega       1.1598;      // -   [origin=predictive method=lee-kesler]
Tb          579.77;      // K   [origin=predictive method=joback]
HvapTb      63334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.424 0.79912 -0.000421 6.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=C; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group OH; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethylamino)ethyl 2-methylprop-2-enoate" "methacrylic acid 2-[(2-hydroxyethyl)amino]ethyl ester" "2-[(2-hydroxyethyl)amino]ethyl methacrylate" "2-propenoic acid, 2-methyl-, 2-((2-hydroxyethyl)amino)ethyl ester" "2-propenoic acid, 2-methyl-, 2-[(2-hydroxyethyl)amino]ethyl ester" );
gibbsFormation
{
    dHf_298   -508850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262030.0
    phase     gas;
}
