/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tetracosene  (C24H48, CAS 10192-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tetracosene;
formula     C24H48;
CAS         10192-32-2;
InChIKey    ZDLBWMYNYNATIW-UHFFFAOYSA-N;
MW          336.648;      // g/mol [origin=calculated method=formula-sum]
Tc          915.09;      // K   [origin=predictive method=joback]
Pc          8.257;      // bar [origin=predictive method=joback]
omega       0.7654;      // -   [origin=predictive method=lee-kesler]
Tb          745.40;      // K   [origin=predictive method=joback]
HvapTb      68348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.919 2.26382 -0.0013047 2.918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 21; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 21; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetracos-1-ene" "tetracosene" "tetracosene;1-tetracosene" "alkenes, c24-28 alpha-" );
gibbsFormation
{
    dHf_298   -413260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1086.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=239040.0
    phase     gas;
}
