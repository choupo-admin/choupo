/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-vetivone  (C15H22O, CAS 15764-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaVetivone;
formula     C15H22O;
CAS         15764-04-2;
InChIKey    NIIPDXITZPFFTE-ABAIWWIYSA-N;
MW          218.34;      // g/mol [origin=calculated method=formula-sum]
Tc          891.95;      // K   [origin=predictive method=joback]
Pc          21.374;      // bar [origin=predictive method=joback]
omega       0.5556;      // -   [origin=predictive method=lee-kesler]
Tb          652.08;      // K   [origin=predictive method=joback]
HvapTb      54415.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.79 1.62278 -0.00122664 4.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r,4as)-4,4a-dimethyl-6-propan-2-ylidene-4,5,7,8-tetrahydro-3h-naphthalen-2-one" "isonootkatone" "isonootkaton" "2(3h)-naphthalenone, 4,4a,5,6,7,8-hexahydro-4,4a-dimethyl-6-(1-methylethylidene)-, (4r,4as)-" " inverted exclamation mark-vetivone" "(4r-cis)-4,4a,5,6,7,8-hexahydro-4,4a-dimethyl-6-(1-methylethylidene)naphthalen-2(3h)-one" );
standardThermochemistry
{
    dHf_298   -241880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77680.0
}
