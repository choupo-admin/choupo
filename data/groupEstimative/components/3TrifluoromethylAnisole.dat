/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(trifluoromethyl)anisole  (C8H7F3O, CAS 454-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TrifluoromethylAnisole;
formula     C8H7F3O;
CAS         454-90-0;
InChIKey    XHONYVFDZSPELQ-UHFFFAOYSA-N;
MW          176.137;      // g/mol [origin=calculated method=formula-sum]
Tc          621.32;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       0.4399;      // -   [origin=predictive method=lee-kesler]
Tb          431.30;      // K   [origin=predictive method=joback]
HvapTb      35003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.69 0.72342 -0.00048556 1.185e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-3-(trifluoromethyl)benzene" "3-methoxybenzotrifluoride" "3-trifluoromethylanisole" "3-methoxy-1-(trifluoromethyl)benzene" "m-(trifluoromethyl)anisole" "m-trifluoromethylmethoxybenzene" "methyl 3-(trifluoromethyl)phenyl ether" );
gibbsFormation
{
    dHf_298   -712690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-567330.0
    phase     gas;
}
