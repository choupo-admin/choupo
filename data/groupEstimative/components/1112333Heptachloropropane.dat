/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,2,3,3,3-heptachloropropane  (C3HCl7, CAS 3849-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1112333Heptachloropropane;
formula     C3HCl7;
CAS         3849-33-0;
InChIKey    LZOUTMTXULWVSU-UHFFFAOYSA-N;
MW          285.191;      // g/mol [origin=calculated method=formula-sum]
Tc          777.62;      // K   [origin=predictive method=joback]
Pc          33.841;      // bar [origin=predictive method=joback]
omega       0.3367;      // -   [origin=predictive method=lee-kesler]
Tb          523.35;      // K   [origin=predictive method=joback]
HvapTb      49987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.77 0.5939 -0.000629 2.308e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl; count 1; } { group CCl3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 2; } { group Cl; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,3,3,3-heptakis(chloranyl)propane" "propane, 1,1,1,2,3,3,3-heptachloro-" "lzoutmtxulwvsu-uhfffaoysa-" "propane,1,1,1,2,3,3,3-heptachloro-" );
standardThermochemistry
{
    dHf_298   -238210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105890.0
}
