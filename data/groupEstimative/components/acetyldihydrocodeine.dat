/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetyldihydrocodeine  (C20H25NO4, CAS 3861-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetyldihydrocodeine;
formula     C20H25NO4;
CAS         3861-72-1;
InChIKey    LGGDXXJAGWBUSL-BKRJIHRRSA-N;
MW          343.423;      // g/mol [origin=calculated method=formula-sum]
Tc          1063.37;      // K   [origin=predictive method=joback]
Pc          17.834;      // bar [origin=predictive method=joback]
omega       1.0373;      // -   [origin=predictive method=lee-kesler]
Tb          837.11;      // K   [origin=predictive method=joback]
HvapTb      78766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-188.66 2.52796 -0.00219178 7.913e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3COO; count 1; } { group CH3O; count 1; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(4r,4ar,7s,7ar,12bs)-9-methoxy-3-methyl-2,4,4a,5,6,7,7a,13-octahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7-yl] ethanoate" "dihydrothebacone" "codeine, acetyldihydro-" "dihydrocodeine 6-acetate" "7,8-dihydrocodeine acetate" "codeine, dihydro-, acetate" "4,5alpha-epoxy-3-methoxy-17-methylmorphinan-6alpha-yl acetat" "(5alpha,6alpha)-4,5-epoxy-3-methoxy-17-methylmorphinan-6-yl acetate" "morphinan-6-alpha-ol, 4,5-alpha-epoxy-3-methoxy-17-methyl-, acetate" "morphinan-6-alpha-ol, 4,5-epoxy-3-methoxy-17-methyl-, acetate (ester), (5alpha,6alpha)-" "acetyldihydrokodein" );
standardThermochemistry
{
    dHf_298   -475720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52230.0
}
