/*--------------------------------*- Choupo -*-----------------------*\
  Component: octafluorodichlorocyclohexene  (C6Cl2F8, CAS 336-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octafluorodichlorocyclohexene;
formula     C6Cl2F8;
CAS         336-19-6;
InChIKey    BICOGOBTBGYGFA-UHFFFAOYSA-N;
MW          294.95;      // g/mol [origin=calculated method=formula-sum]
Tc          593.96;      // K   [origin=predictive method=joback]
Pc          26.680;      // bar [origin=predictive method=joback]
omega       0.4919;      // -   [origin=predictive method=lee-kesler]
Tb          421.52;      // K   [origin=predictive method=joback]
HvapTb      27698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.43 1.717 -0.002373 1.1944e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Cl_C=C_; count 2; } { group C=C; count 1; } { group CF2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 4; } { group dC_ring; count 2; } { group F; count 8; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-3,3,4,4,5,5,6,6-octakis(fluoranyl)cyclohexene" "1,2-dichlorooctafluorocyclohex-1-ene" "1,2-dichloro-3,3,4,4,5,5,6,6-octafluorocyclohexene" "1,2-dichlorooctafluorocyclohexene" "1,2-dichloroperfluorocyclohexene" "1,2-dichlorooctafluorocyclohexene-1" "cyclohexene, 1,2-dichlorooctafluoro-" "cyclohexene, 1,2-dichloro-3,3,4,4,5,5,6,6-octafluoro-" "1,2-dichlorooctafluoro-1-cyclohexene" "octafluoro-1,2-dichlorocyclohexene-1" "1,2-dichloro-3,3,4,4,5,5,6,6-octafluorocyclohex-1-ene" "cyclohexene,1,2-dichloro-3,3,4,4,5,5,6,6-octafluoro-" );
standardThermochemistry
{
    dHf_298   -1678430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1592640.0
}
