/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-(2-methylpropoxy)but-1-ene  (C9H18O, CAS 56798-16-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl22MethylpropoxyBut1Ene;
formula     C9H18O;
CAS         56798-16-4;
InChIKey    DIZHLKGDDLADCI-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          601.01;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.4106;      // -   [origin=predictive method=lee-kesler]
Tb          423.62;      // K   [origin=predictive method=joback]
HvapTb      36672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.161 0.78738 -0.0003864 5.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH2=C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -256230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5690.0
}
