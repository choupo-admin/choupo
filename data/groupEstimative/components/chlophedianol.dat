/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlophedianol  (C17H20ClNO, CAS 791-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlophedianol;
formula     C17H20ClNO;
CAS         791-35-5;
InChIKey    WRCHFMBCVFFYEQ-UHFFFAOYSA-N;
MW          289.803;      // g/mol [origin=calculated method=formula-sum]
Tc          1007.21;      // K   [origin=predictive method=joback]
Pc          22.021;      // bar [origin=predictive method=joback]
omega       1.0955;      // -   [origin=predictive method=lee-kesler]
Tb          785.72;      // K   [origin=predictive method=joback]
HvapTb      80461.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.058 1.69204 -0.00123156 3.453e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 9; } { group AC; count 2; } { group OH; count 1; } { group CH3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-chlorophenyl)-3-(dimethylamino)-1-phenyl-propan-1-ol" "clofedanol" "chlofedanol" "dencyl" "tussistop" "clophedianol base" "calmotusin" "clofedano" "ulo base" "clofedanolum" "clofedianolo" "sl 501 base" );
standardThermochemistry
{
    dHf_298   -41810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     660.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272320.0
}
