/*--------------------------------*- Choupo -*-----------------------*\
  Component: dcvc  (C5H7Cl2NO2S, CAS 13419-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dcvc;
formula     C5H7Cl2NO2S;
CAS         13419-46-0;
InChIKey    PJIHCWJOTSJIPQ-RJRFIUFISA-N;
MW          216.076;      // g/mol [origin=calculated method=formula-sum]
Tc          924.39;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.9471;      // -   [origin=predictive method=lee-kesler]
Tb          679.28;      // K   [origin=predictive method=joback]
HvapTb      69766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.261 0.62529 -0.0004541 1.264e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group Cl_C=C_; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 2; } { group COOH; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-[(e)-1,2-bis(chloranyl)ethenyl]sulfanyl-propanoic acid" "s-(trans-1,2-dichlorovinyl)-l-cysteine" "(e)-s-(1,2-dichloroethenyl)-l-cysteine" "l-cysteine, s-((1e)-1,2-dichloroethenyl)-" "alanine, 3-((1,2-dichlorovinyl)thio)-, (e)-l-" "l-cysteine, s-(1,2-dichloroethenyl)-, (e)-" "l-cysteine, s-(1,2-dichloroethenyl)-, (e)- (9ci)" "2-amino-3-[(e)-1,2-dichloroethenyl]sulfanylpropanoic acid" );
gibbsFormation
{
    dHf_298   -350470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207750.0
    phase     gas;
}
