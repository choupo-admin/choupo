/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dibromo-4-fluoroaniline  (C6H4Br2FN, CAS 344-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dibromo4Fluoroaniline;
formula     C6H4Br2FN;
CAS         344-18-3;
InChIKey    VHPLZFGCNLDYQH-UHFFFAOYSA-N;
MW          268.911;      // g/mol [origin=calculated method=formula-sum]
Tc          836.54;      // K   [origin=predictive method=joback]
Pc          54.225;      // bar [origin=predictive method=joback]
omega       0.6976;      // -   [origin=predictive method=lee-kesler]
Tb          582.62;      // K   [origin=predictive method=joback]
HvapTb      55906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.39 0.4665 -0.00033528 9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACNH2; count 1; } { group Br; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Br; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(bromanyl)-4-fluoranyl-aniline" "1-amino-2,6-dibromo-4-fluorobenzene" "2,6-dibromo-4-fluorophenylamine" );
gibbsFormation
{
    dHf_298   -74710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16560.0
    phase     gas;
}
