/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-octylphenyl salicylate  (C21H26O3, CAS 2512-56-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4OctylphenylSalicylate;
formula     C21H26O3;
CAS         2512-56-3;
InChIKey    VNFXPOAMRORRJJ-UHFFFAOYSA-N;
MW          326.436;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.88;      // K   [origin=predictive method=joback]
Pc          16.893;      // bar [origin=predictive method=joback]
omega       1.1284;      // -   [origin=predictive method=lee-kesler]
Tb          877.26;      // K   [origin=predictive method=joback]
HvapTb      87975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.223 1.88132 -0.00127572 3.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-octylphenyl) 2-oxidanylbenzoate" "salicylic acid, p-octylphenyl ester" "4-n-octylphenylsalicylate" "(4-octylphenyl) 2-hydroxybenzoate" "salicylic acid 4-octylphenyl ester" "benzoic acid,2-hydroxy-, 4-octylphenyl ester" );
gibbsFormation
{
    dHf_298   -509770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     832.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-123860.0
    phase     gas;
}
