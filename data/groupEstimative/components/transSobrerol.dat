/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-sobrerol  (C10H18O2, CAS 42370-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transSobrerol;
formula     C10H18O2;
CAS         42370-41-2;
InChIKey    OMDMTHRBGUBUCO-BDAKNGLRSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          817.25;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       1.1924;      // -   [origin=predictive method=lee-kesler]
Tb          628.55;      // K   [origin=predictive method=joback]
HvapTb      70990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.68 1.12776 -0.00069864 1.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,5r)-2-methyl-5-(2-oxidanylpropan-2-yl)cyclohex-2-en-1-ol" "p-menth-6-en-2,8-diol, trans" "sobrerol, (-)-trans-" "trans-p-menth-1-ene-6,8-diol" "(1s,5r)-5-(2-hydroxypropan-2-yl)-2-methylcyclohex-2-en-1-ol" "trans-5-hydroxy-alpha,alpha,4-trimethyl-3-cyclohexene-1-methanol" "3-cyclohexene-1-methanol,5-hydroxy-a,a,4-trimethyl-, trans-; (?a'a a'a currency)-trans-5-hydroxy-a,a,4-trimethyl-3-cyclohexene-1-methanol; (?a'a a'a currency)-trans-sobrerol; dl-trans-p-menth-6-ene-2,8-diol;d,l-trans-sobrerol; dl-sobrerol; trans-6-hydroxy-a-terpineol; trans-sobrerol" );
standardThermochemistry
{
    dHf_298   -482650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200410.0
}
