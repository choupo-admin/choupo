/*--------------------------------*- Choupo -*-----------------------*\
  Component: quinovic acid  (C30H46O5, CAS 465-74-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        quinovicAcid;
formula     C30H46O5;
CAS         465-74-7;
InChIKey    OJUYFGQEMPENCE-DPKHZRJYSA-N;
MW          486.693;      // g/mol [origin=calculated method=formula-sum]
Tc          1607.27;      // K   [origin=predictive method=joback]
Pc          11.452;      // bar [origin=predictive method=joback]
omega       1.0665;      // -   [origin=predictive method=lee-kesler]
Tb          1310.11;      // K   [origin=predictive method=joback]
HvapTb      127495.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-489.19 4.86182 -0.00481084 1.9989e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 9; } { group CH; count 6; } { group C; count 5; } { group CH=C; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 9; } { group CH_ring; count 6; } { group C_ring; count 5; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2r,4as,6ar,6ar,6br,8ar,10s,12ar,14bs)-1,2,6b,9,9,12a-hexamethyl-10-oxidanyl-2,3,4,5,6,6a,7,8,8a,10,11,12,13,14b-tetradecahydro-1h-picene-4a,6a-dicarboxylic acid" "quinovaic acid" "chinovic acid" "chinova acid" "3-beta-hydroxyurs-12-ene-27,28-dioic acid" "urs-12-ene-27,28-dioic acid, 3-beta-hydroxy-" "(3-beta)-3-hydroxyurs-12-ene-27,28-dioic acid" "urs-12-ene-27,28-dioic acid, 3-hydroxy-, (3-beta)-" "urs-12-ene-27,28-dioic acid, 3-hydroxy-, (3-beta)- (9ci)" "(1s,2r,4as,6ar,6ar,6br,8ar,10s,12ar,14bs)-10-hydroxy-1,2,6b,9,9,12a-hexamethyl-2,3,4,5,6,6a,7,8,8a,10,11,12,13,14b-tetradecahydro-1h-picene-4a,6a-dicarboxylic acid" );
standardThermochemistry
{
    dHf_298   -1193950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1219.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-457250.0
}
