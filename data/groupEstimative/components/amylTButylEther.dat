/*--------------------------------*- Choupo -*-----------------------*\
  Component: amyl-t-butyl ether  (C9H20O, CAS 10100-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amylTButylEther;
formula     C9H20O;
CAS         10100-95-5;
InChIKey    BWRSHLROMAZEBM-UHFFFAOYSA-N;
MW          144.258;      // g/mol [origin=calculated method=formula-sum]
Tc          598.29;      // K   [origin=predictive method=joback]
Pc          23.114;      // bar [origin=predictive method=joback]
omega       0.4274;      // -   [origin=predictive method=lee-kesler]
Tb          424.71;      // K   [origin=predictive method=joback]
HvapTb      36742.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.266 0.92148 -0.0005266 1.13e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(2-methylpropan-2-yl)oxy]pentane" );
gibbsFormation
{
    dHf_298   -370060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77260.0
    phase     gas;
}
