/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(1-methoxyethoxy)prop-1-ene  (C6H12O2, CAS 60812-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        31MethoxyethoxyProp1Ene;
formula     C6H12O2;
CAS         60812-41-1;
InChIKey    AAYPCZZQEAJUGH-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          550.69;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.3971;      // -   [origin=predictive method=lee-kesler]
Tb          377.96;      // K   [origin=predictive method=joback]
HvapTb      32712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.761 0.43334 -0.0001067 -3.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -311460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124960.0
}
