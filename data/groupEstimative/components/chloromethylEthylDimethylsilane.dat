/*--------------------------------*- Choupo -*-----------------------*\
  Component: (chloromethyl)(ethyl)dimethylsilane  (C5H13ClSi, CAS 3121-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H13ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloromethylEthylDimethylsilane;
formula     C5H13ClSi;
CAS         3121-77-5;
InChIKey    BCZCLPJVTSRZLR-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          136.694;      // g/mol [origin=calculated method=formula-sum]
Tc          531.99;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.2241;      // -   [origin=predictive method=lee-kesler]
Tb          352.83;      // K   [origin=predictive method=joback]
HvapTb      31403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.052 0.27946 0.0001462 -1.599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl-ethyl-dimethyl-silane" "chloromethyl-ethyl-dimethylsilane" "(chloromethyl)dimethylethylsilane" "(chloromethyl)dimethyl ethylsilane" "silane,(chloromethyl)ethyldimethyl-" );
gibbsFormation
{
    dHf_298   -273890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-125470.0
    phase     gas;
}
