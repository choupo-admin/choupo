name        1AdamantylIsocyanate;
formula     C11H15NO;
CAS         4411-25-0;
InChIKey    VBHCPGFCIQDXGZ-UHFFFAOYSA-N;
MW          177.247;      // g/mol [origin=calculated method=formula-sum]
Tc          766.74;      // K   [origin=predictive method=joback]
Pc          31.811;      // bar [origin=predictive method=joback]
omega       0.5096;      // -   [origin=predictive method=lee-kesler]
Tb          538.01;      // K   [origin=predictive method=joback]
HvapTb      48063.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanatoadamantane" "1-isocyantoadamantane" "1-isocyanato-adamantane" "adamantanisocyanate" "adamantane, 1-isocyanato-" "1-isocyanatotricyclo[3.3.1.1~3,7~]decane" "tricyclo[3.3.1.13,7]decane,1-isocyanato-" "isocyanicacid, 1-adamantyl ester (7ci,8ci);1-adamantane isocyanate;1-adamantanylisocyanate;1-adamantyl isocyanate;1-isocyanatoadamantane;adamantylisocyanate;1-isocyanatotricyclo[3.3.1.13,7]decane;1-adamantylisocyanate;1-isocyanatotricyclo[3.3.1.13,7]decane;" );
