/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyltriisopropoxysilane  (C11H24O3Si, CAS 18023-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H24O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        vinyltriisopropoxysilane;
formula     C11H24O3Si;
CAS         18023-33-1;
InChIKey    MABAWBWRUSBLKQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          232.395;      // g/mol [origin=calculated method=formula-sum]
Tc          694.78;      // K   [origin=predictive method=joback]
Pc          17.669;      // bar [origin=predictive method=joback]
omega       0.5437;      // -   [origin=predictive method=lee-kesler]
Tb          515.30;      // K   [origin=predictive method=joback]
HvapTb      45770.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (102.17 0.65082 0.0001407 -2.46e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2=CH; count 1; } { group CH-O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl-tri(propan-2-yloxy)silane" "silane, ethenyltris(1-methylethoxy)-" "silane, triisopropoxyvinyl-" "triisopropyloxyvinylsilane" "triisopropoxy(vinyl)silane" "vinyl triisopropoxy silane" "silane,ethenyltris(1-methylethoxy)-" );
standardThermochemistry
{
    dHf_298   -669060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297500.0
}
