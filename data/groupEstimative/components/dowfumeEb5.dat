/*--------------------------------*- Choupo -*-----------------------*\
  Component: dowfume eb-5  (C5H8Br2Cl6, CAS 53908-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dowfumeEb5;
formula     C5H8Br2Cl6;
CAS         53908-27-3;
InChIKey    QXGMFEYBTCJIFL-UHFFFAOYSA-N;
MW          440.627;      // g/mol [origin=calculated method=formula-sum]
Tc          930.78;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.5756;      // -   [origin=predictive method=lee-kesler]
Tb          670.47;      // K   [origin=predictive method=joback]
HvapTb      65196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (149.234 0.3094 0.0001444 -1.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2Cl; count 2; } { group CCl4; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group C; count 1; } { group Cl; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)ethane;1,2-bis(chloranyl)ethane;tetrakis(chloranyl)methane" "carbon tetrachloride mixt. with 1,2-dichloroethane  and ethylene dibromide" "ethane, 1,2-dibromo-, mixt. with 1,2-dichloroethane and tetrachloromethane" "1,2-dibromoethane; 1,2-dichloroethane; tetrachloromethane" );
gibbsFormation
{
    dHf_298   -420300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     829.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258400.0
    phase     gas;
}
