/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-((2-aminoethyl)thio)ethanol  (C4H11NOS, CAS 24304-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22AminoethylThioEthanol;
formula     C4H11NOS;
CAS         24304-84-5;
InChIKey    ZRZOERYTFAWUQQ-UHFFFAOYSA-N;
MW          121.198;      // g/mol [origin=calculated method=formula-sum]
Tc          719.79;      // K   [origin=predictive method=joback]
Pc          48.494;      // bar [origin=predictive method=joback]
omega       0.9579;      // -   [origin=predictive method=lee-kesler]
Tb          524.61;      // K   [origin=predictive method=joback]
HvapTb      58635.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.634 0.47409 -0.0002274 2.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group CH2NH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-azanylethylsulfanyl)ethanol" "2-[(2-aminoethyl)sulfanyl]ethanol" "2-[(2-aminoethyl)thio]ethan-1-ol" "2-[(2-aminoethyl)thio]ethanol" "2-(2-aminoethylthio)ethan-1-ol" "2-(2-aminoethylsulfanyl)ethanol" "ethanol,2-[(2-aminoethyl)thio]-" "ethanol, 2-[(2-aminoethyl)thio]-" "2-[(2-aminoethyl)sulfanyl]ethan-1-ol" );
standardThermochemistry
{
    dHf_298   -202460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-54450.0
}
