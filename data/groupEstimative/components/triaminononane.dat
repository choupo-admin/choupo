/*--------------------------------*- Choupo -*-----------------------*\
  Component: triaminononane  (C9H23N3, CAS 1572-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triaminononane;
formula     C9H23N3;
CAS         1572-55-0;
InChIKey    HMJBXEZHJUYJQY-UHFFFAOYSA-N;
MW          173.304;      // g/mol [origin=calculated method=formula-sum]
Tc          821.20;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       0.9721;      // -   [origin=predictive method=lee-kesler]
Tb          622.67;      // K   [origin=predictive method=joback]
HvapTb      67163.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.498 1.0504 -0.0005992 1.284e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH2NH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group CH; count 1; } { group NH2; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(aminomethyl)octane-1,8-diamine" "4-(aminomethyl)-1,8-octanediamine" "1,8-octanediamine, 4-(aminomethyl)-" "1,3,6-tri(aminomethyl)hexane" "1,8-diamino-4-aminomethyloctane" "4-aminomethyl-1,8-octanediamine" );
standardThermochemistry
{
    dHf_298   -133000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221810.0
}
