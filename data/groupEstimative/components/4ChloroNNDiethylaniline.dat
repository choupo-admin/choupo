/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-n,n-diethylaniline  (C10H14ClN, CAS 2873-89-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChloroNNDiethylaniline;
formula     C10H14ClN;
CAS         2873-89-4;
InChIKey    LVIXJLIXKMZERD-UHFFFAOYSA-N;
MW          183.679;      // g/mol [origin=calculated method=formula-sum]
Tc          718.80;      // K   [origin=predictive method=joback]
Pc          27.672;      // bar [origin=predictive method=joback]
omega       0.5066;      // -   [origin=predictive method=lee-kesler]
Tb          509.93;      // K   [origin=predictive method=joback]
HvapTb      47220.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.608 0.94614 -0.00061736 1.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-n,n-diethyl-aniline" "n-(4-chlorophenyl)-n,n-diethylamine" "benzenamine, 4-chloro-n,n-diethyl-" "(4-chlorophenyl)diethylamine" );
standardThermochemistry
{
    dHf_298   27120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=234950.0
}
