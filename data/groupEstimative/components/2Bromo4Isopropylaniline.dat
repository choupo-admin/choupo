/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4-isopropylaniline  (C9H12BrN, CAS 51605-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo4Isopropylaniline;
formula     C9H12BrN;
CAS         51605-97-1;
InChIKey    WEMDUNBELVTSRP-UHFFFAOYSA-N;
MW          214.106;      // g/mol [origin=calculated method=formula-sum]
Tc          822.05;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       0.6099;      // -   [origin=predictive method=lee-kesler]
Tb          580.41;      // K   [origin=predictive method=joback]
HvapTb      55916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.4 0.76694 -0.00048092 1.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group ACNH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4-propan-2-yl-aniline" "2-bromo-4-propan-2-ylaniline" "2-bromo-4-isopropyl-phenylamine" "2-bromo-4-(methylethyl)phenylamine" "benzenamine,2-bromo-4-(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   39340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196380.0
}
