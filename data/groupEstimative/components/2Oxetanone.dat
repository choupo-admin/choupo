/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxetanone  (C3H4O2, CAS 57-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Oxetanone;
formula     C3H4O2;
CAS         57-57-8;
InChIKey    VEZXCJBBBCKRPI-UHFFFAOYSA-N;
MW          72.063;      // g/mol [origin=calculated method=formula-sum]
Tc          517.15;      // K   [origin=predictive method=joback]
Pc          53.828;      // bar [origin=predictive method=joback]
omega       0.3279;      // -   [origin=predictive method=lee-kesler]
Tb          333.60;      // K   [origin=predictive method=joback]
HvapTb      29729.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.49 0.421 -0.0003668 1.248e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxetan-2-one" "propiolactone" "beta-propiolactone" "propanolide" "3-propanolide" "betaprone" "1,3-propiolactone" "3-propiolactone" "beta-propionolactone" ".beta.-propiolactone" "hydracrylic acid beta-lactone" "propiolactona" );
gibbsFormation
{
    dHf_298   -323230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     256.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255430.0
    phase     gas;
}
