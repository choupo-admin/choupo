/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-2-amino-1-cyclohexanecarboxamide  (C7H14N2O, CAS 115014-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis2Amino1Cyclohexanecarboxamide;
formula     C7H14N2O;
CAS         115014-77-2;
InChIKey    DXNKJRKPVQVDJW-RITPCOANSA-N;
MW          142.202;      // g/mol [origin=calculated method=formula-sum]
Tc          811.37;      // K   [origin=predictive method=joback]
Pc          42.111;      // bar [origin=predictive method=joback]
omega       0.6772;      // -   [origin=predictive method=lee-kesler]
Tb          573.57;      // K   [origin=predictive method=joback]
HvapTb      59324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.8 0.8602 -0.0004507 6.646e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CHNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-2-azanylcyclohexane-1-carboxamide" "cyclohexanecarboxamide,2-amino-, (1r,2s)-rel-" "(1r,2s)-2-aminocyclohexane-1-carboxamide" "(2s,1r)-2-aminocyclohexanecarboxamide" "cyclohexanecarboxamide,2-amino-, cis- (8ci); cis-2-aminocyclohexanecarboxamide" );
standardThermochemistry
{
    dHf_298   -198830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28780.0
}
