/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxetanone, 4-(8z)-8-heptadecenylidene-3-(7z)-7-hexadecenyl-  (C36H64O2, CAS 56000-16-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Oxetanone48z8Heptadecenylidene37z7Hexadecenyl;
formula     C36H64O2;
CAS         56000-16-9;
InChIKey    YOZPNLKELYIIKS-UHFFFAOYSA-N;
MW          528.906;      // g/mol [origin=calculated method=formula-sum]
Tc          1398.56;      // K   [origin=predictive method=joback]
Pc          5.093;      // bar [origin=predictive method=joback]
omega       0.0982;      // -   [origin=predictive method=lee-kesler]
Tb          1098.93;      // K   [origin=predictive method=joback]
HvapTb      103581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.814 3.49204 -0.0022427 5.85e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 26; } { group CH; count 1; } { group CH=CH; count 2; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group dCH; count 5; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-heptadec-8-enylidene-3-hexadec-7-enyl-oxetan-2-one" );
gibbsFormation
{
    dHf_298   -714220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1458.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=220620.0
    phase     gas;
}
