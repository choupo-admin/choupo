/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptanal  (C7H14O, CAS 111-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptanal;
formula     C7H14O;
CAS         111-71-7;
InChIKey    FXHGMKSSBGDXIY-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          580.22;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.5055;      // -   [origin=predictive method=lee-kesler]
Tb          408.42;      // K   [origin=predictive method=joback]
HvapTb      37896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.925 0.64332 -0.00035 7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptaldehyde" "enanthaldehyde" "n-heptaldehyde" "enanthal" "heptyl aldehyde" "heptanaldehyde" "oenanthaldehyde" "enanthole" "oenanthal" "oenanthol" "n-heptylaldehyde" "enanthic aldehyde" );
standardThermochemistry
{
    dHf_298   -273390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-91460.0
}
