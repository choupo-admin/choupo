/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-3,4-dihydro-2h-1,4-benzoxazine  (C9H11NO, CAS 32329-20-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl34Dihydro2h14Benzoxazine;
formula     C9H11NO;
CAS         32329-20-7;
InChIKey    BSDVKBWLRCKPFB-UHFFFAOYSA-N;
MW          149.193;      // g/mol [origin=calculated method=formula-sum]
Tc          763.66;      // K   [origin=predictive method=joback]
Pc          39.308;      // bar [origin=predictive method=joback]
omega       0.4802;      // -   [origin=predictive method=lee-kesler]
Tb          523.69;      // K   [origin=predictive method=joback]
HvapTb      49919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.02 0.84532 -0.00052926 1.243e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group FCH2O; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3j-356s" "3-methyl-2h,3h,4h-benzo[e]1,4-oxazine" "2h-1,4-benzoxazine,3,4-dihydro-3-methyl-" "3-methyl-3,4-dihydro-2h-benzo[b][1,4]oxazine" "2h-1,4-benzoxazine, 3,4-dihydro-3-methyl" "3-methyl-3,4-dihydro-2h-benzo[1,4]oxazine" "2,3-dihydro-3-methyl-4h-1,4-benzoxazine;3,4-dihydro-3-methyl-2h-1,4-benzoxazine; 3-methyl-3,4-dihydro-2h-1,4-benzoxazine;3-methyl-3,4-dihydro-2h-benzo[1,4]oxazine" );
gibbsFormation
{
    dHf_298   -31580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     266.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177920.0
    phase     gas;
}
