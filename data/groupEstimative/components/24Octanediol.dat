/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-octanediol  (C8H18O2, CAS 90162-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Octanediol;
formula     C8H18O2;
CAS         90162-24-6;
InChIKey    HOWLAKMIIWUJEJ-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          727.92;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       1.3102;      // -   [origin=predictive method=lee-kesler]
Tb          566.12;      // K   [origin=predictive method=joback]
HvapTb      65984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.834 0.84364 -0.0004786 1.026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane-2,4-diol" "agn-pc-00dure" );
gibbsFormation
{
    dHf_298   -523470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262040.0
    phase     gas;
}
