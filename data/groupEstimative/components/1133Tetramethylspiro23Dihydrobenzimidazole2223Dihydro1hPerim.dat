/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'3,3'-tetramethylspiro(2,3-dihydrobenzimidazole-2,2'-(2,3)dihydro(1h)perimidine  (C21H22N4, CAS 99643-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetramethylspiro23Dihydrobenzimidazole2223Dihydro1hPerim;
formula     C21H22N4;
CAS         99643-43-3;
InChIKey    HXZNMYKVHZQIKP-UHFFFAOYSA-N;
MW          330.435;      // g/mol [origin=calculated method=formula-sum]
Tc          1041.09;      // K   [origin=predictive method=joback]
Pc          21.295;      // bar [origin=predictive method=joback]
omega       1.0974;      // -   [origin=predictive method=lee-kesler]
Tb          814.16;      // K   [origin=predictive method=joback]
HvapTb      76814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-246.13 2.82268 -0.0028274 1.12e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 10; } { group AC; count 6; } { group CH3N; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 6; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1',3,3'-tetramethylspiro[benzimidazole-2,2'-perimidine]" "1,1'3,3'-tetramethylspiro[2,3-dihydrobenzimidazole-2,2'-[2,3]dihydro[1h]perimidine" "1,1',3,3'-tetramethyl-1,3-dihydro-1'h,3'h-spiro[benzimidazole-2,2'-perimidine]" );
standardThermochemistry
{
    dHf_298   635050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1055860.0
}
