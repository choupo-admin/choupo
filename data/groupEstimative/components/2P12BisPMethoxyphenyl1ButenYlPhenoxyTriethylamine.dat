/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(p-(1,2-bis(p-methoxyphenyl)-1-buten-yl)phenoxy)triethylamine  (C30H37NO3, CAS 33406-36-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2P12BisPMethoxyphenyl1ButenYlPhenoxyTriethylamine;
formula     C30H37NO3;
CAS         33406-36-9;
InChIKey    YMJZGIHPNOUMNO-UHFFFAOYSA-N;
MW          459.63;      // g/mol [origin=calculated method=formula-sum]
Tc          1306.27;      // K   [origin=predictive method=joback]
Pc          10.136;      // bar [origin=predictive method=joback]
omega       0.9549;      // -   [origin=predictive method=lee-kesler]
Tb          1064.60;      // K   [origin=predictive method=joback]
HvapTb      100579.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.955 2.3928 -0.00136868 2.716e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group ACH; count 12; } { group AC; count 6; } { group CH3O; count 2; } { group CH2O; count 1; } { group CH2N; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 5; } { group dC; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group O; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[1,2-bis(4-methoxyphenyl)but-1-enyl]phenoxy]-n,n-diethyl-ethanamine" );
standardThermochemistry
{
    dHf_298   -218840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1021.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=368960.0
}
