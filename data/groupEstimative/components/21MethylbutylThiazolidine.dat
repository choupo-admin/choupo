/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-methylbutyl)thiazolidine  (C8H17NS, CAS 40790-75-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21MethylbutylThiazolidine;
formula     C8H17NS;
CAS         40790-75-8;
InChIKey    KEJJWLNKKYPOIN-UHFFFAOYSA-N;
MW          159.291;      // g/mol [origin=calculated method=formula-sum]
Tc          713.47;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.4371;      // -   [origin=predictive method=lee-kesler]
Tb          493.86;      // K   [origin=predictive method=joback]
HvapTb      45841.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.808 0.90245 -0.0005001 9.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pentan-2-yl-1,3-thiazolidine" "2-(pentan-2-yl)-1,3-thiazolidine" "thiazolidine, 2-(1-methylbutyl)-" );
gibbsFormation
{
    dHf_298   -70180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178160.0
    phase     gas;
}
