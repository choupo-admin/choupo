/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylbenzo[b]thiophene  (C9H8S, CAS 14315-14-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5MethylbenzoBThiophene;
formula     C9H8S;
CAS         14315-14-1;
InChIKey    DOHZWDWNQFZIKH-UHFFFAOYSA-N;
MW          148.223;      // g/mol [origin=calculated method=formula-sum]
Tc          746.63;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       0.3790;      // -   [origin=predictive method=lee-kesler]
Tb          500.56;      // K   [origin=predictive method=joback]
HvapTb      45554.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.18 0.79673 -0.0006445 2.121e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-1-benzothiophene" "benzo[b]thiophene, 5-methyl-" "5-methylbenzo(b)thiophene" "benzo(b)thiophene, 5-methyl-" "5-methylthianaphthene" "5-methylbenzothiophene" "agn-pc-0cw4qh" "5-methyl benzo[b]thiophene" "5-methyl-benzo[b]thiophene" );
standardThermochemistry
{
    dHf_298   180680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=256330.0
}
