/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-nonynoate  (C11H18O2, CAS 10031-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Nonynoate;
formula     C11H18O2;
CAS         10031-92-2;
InChIKey    BFZNMUGAZYAMTG-UHFFFAOYSA-N;
MW          182.263;      // g/mol [origin=calculated method=formula-sum]
Tc          706.98;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.6021;      // -   [origin=predictive method=lee-kesler]
Tb          518.50;      // K   [origin=predictive method=joback]
HvapTb      49639.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.856 0.84424 -0.00038786 4.158e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl non-2-ynoate" "2-nonynoic acid, ethyl ester" "ethyl-2-nonynoate" "ethyl nonynoate" "ethyl octinecarbonate" "nonynoic acid, ethyl ester" "2-nonynoic acid ethyl ester" "bfznmugazyamtg-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -315350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-65830.0
}
