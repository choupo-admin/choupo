/*--------------------------------*- Choupo -*-----------------------*\
  Component: azelaic acid, dihexyl ester  (C21H40O4, CAS 109-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azelaicAcidDihexylEster;
formula     C21H40O4;
CAS         109-31-9;
InChIKey    MJOKHGMXPJXFTG-UHFFFAOYSA-N;
MW          356.547;      // g/mol [origin=calculated method=formula-sum]
Tc          976.78;      // K   [origin=predictive method=joback]
Pc          9.621;      // bar [origin=predictive method=joback]
omega       0.9144;      // -   [origin=predictive method=lee-kesler]
Tb          796.52;      // K   [origin=predictive method=joback]
HvapTb      77154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.617 1.88924 -0.0009294 1.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dihexyl nonanedioate" "dihexyl azelaate" "nonanedioic acid, dihexyl ester" "di-n-hexyl azelate" "dihexyl azelate" "dnha" "plastolein 9051 dhnz" "nonanedioic acid, 1,9-dihexyl ester" "di-n-hexylester kyseliny azelaove" );
standardThermochemistry
{
    dHf_298   -1111330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1076.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-494800.0
}
