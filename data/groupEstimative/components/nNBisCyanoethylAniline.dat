/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(cyanoethyl)aniline  (C12H13N3, CAS 1555-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBisCyanoethylAniline;
formula     C12H13N3;
CAS         1555-66-4;
InChIKey    NSVHSAUVIFTVPN-UHFFFAOYSA-N;
MW          199.257;      // g/mol [origin=calculated method=formula-sum]
Tc          942.33;      // K   [origin=predictive method=joback]
Pc          22.871;      // bar [origin=predictive method=joback]
omega       0.8908;      // -   [origin=predictive method=lee-kesler]
Tb          717.44;      // K   [origin=predictive method=joback]
HvapTb      67581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.616 1.0584 -0.0007108 1.819e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-cyanoethyl(phenyl)amino]propanenitrile" "nn-bis(2-cyanoethyl)aniline" "n,n-bis(2-cyanoethyl)aniline" "3,3'-(phenylimino)dipropionitrile" "n,n-bis-cyanoethylaniline" "bis(2-cyanoethyl)phenylamine" "propanenitrile, 3,3'-(phenylimino)bis-" "3-[(2-cyanoethyl)(phenyl)amino]propanenitrile" "3-[(2-cyanoethyl)phenylamino]propanenitrile" "aniline,n-dicyanoethyl-" "n-n-bis(cyanoethyl)aniline" "(beta-cyanoethyl)benzylamine" );
gibbsFormation
{
    dHf_298   342810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=539710.0
    phase     gas;
}
