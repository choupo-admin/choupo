/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichloro-n-methyl-3-oxobutanamide  (C5H7Cl2NO2, CAS 20132-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DichloroNMethyl3Oxobutanamide;
formula     C5H7Cl2NO2;
CAS         20132-74-5;
InChIKey    FUSJRPBAYJMLEA-UHFFFAOYSA-N;
MW          184.016;      // g/mol [origin=calculated method=formula-sum]
Tc          761.58;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.6942;      // -   [origin=predictive method=lee-kesler]
Tb          543.54;      // K   [origin=predictive method=joback]
HvapTb      54126.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.16 0.63844 -0.000472 1.3062e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CCl2; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group Cl; count 2; } { group CdO; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)-n-methyl-3-oxidanylidene-butanamide" "2,2-dichloro-n-methyl-3-oxobutyramide" "butanamide, 2,2-dichloro-n-methyl-3-oxo-" "2,2-dichloro-n-methylacetoacetamide" );
standardThermochemistry
{
    dHf_298   -358450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198250.0
}
