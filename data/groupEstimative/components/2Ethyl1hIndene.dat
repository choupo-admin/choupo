/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-1h-indene  (C11H12, CAS 17059-50-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl1hIndene;
formula     C11H12;
CAS         17059-50-6;
InChIKey    BSHJHVHMLRKHBZ-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          722.08;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.4265;      // -   [origin=predictive method=lee-kesler]
Tb          498.49;      // K   [origin=predictive method=joback]
HvapTb      44194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.819 0.97232 -0.0007346 2.271e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-1-h-indene" "2-ethylindene" "1h-indene, 2-ethyl-" "indene,2-ethyl- (7ci,8ci);2-ethylindene;" );
standardThermochemistry
{
    dHf_298   94140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233310.0
}
