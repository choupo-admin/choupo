/*--------------------------------*- Choupo -*-----------------------*\
  Component: hormoslyr 64  (C16H11Cl5O6, CAS 8015-35-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hormoslyr64;
formula     C16H11Cl5O6;
CAS         8015-35-8;
InChIKey    WWPVVPNDJBRXMS-UHFFFAOYSA-N;
MW          476.508;      // g/mol [origin=calculated method=formula-sum]
Tc          1436.57;      // K   [origin=predictive method=joback]
Pc          18.970;      // bar [origin=predictive method=joback]
omega       1.4875;      // -   [origin=predictive method=lee-kesler]
Tb          1168.35;      // K   [origin=predictive method=joback]
HvapTb      120439.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (157.502 0.8715 -0.0001842 -1.201e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 2; } { group CH2O; count 2; } { group COOH; count 2; } { group ACCl; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group Cl; count 5; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(chloranyl)phenoxy]ethanoic acid;2-[2,4,5-tris(chloranyl)phenoxy]ethanoic acid" "2,4-d - 2,4,5-t mixture" "acetic acid, (2,4-dichlorophenoxy)- mixed with acetic acid, (2,4,5-trichlorophenoxy)-, (2:1)" "2,4-d and 2,4,5-t (2:1)" "acetic acid, (2,4-dichlorophenoxy)- mixed with (2,4,5-trichlorophenoxy)acetic acid (2:1)" "2,4-d mixt. with 2,4,5-t" "acetic acid, (2,4-dichlorophenoxy)-, mixt. with (2,4,5-trichlorophenoxy)acetic acid" "2-(2,4-dichlorophenoxy)acetic acid; 2-(2,4,5-trichlorophenoxy)acetic acid" "(2,4,5-trichlorophenoxy)acetic acid - (2,4-dichlorophenoxy)acetic acid (1:1)" );
standardThermochemistry
{
    dHf_298   -1113160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     939.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-801720.0
}
