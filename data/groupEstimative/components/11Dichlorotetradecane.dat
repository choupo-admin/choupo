/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichlorotetradecane  (C14H28Cl2, CAS 4168-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichlorotetradecane;
formula     C14H28Cl2;
CAS         4168-40-5;
InChIKey    ILTTYLXNRDSQCT-UHFFFAOYSA-N;
MW          267.278;      // g/mol [origin=calculated method=formula-sum]
Tc          766.78;      // K   [origin=predictive method=joback]
Pc          14.479;      // bar [origin=predictive method=joback]
omega       0.7437;      // -   [origin=predictive method=lee-kesler]
Tb          594.34;      // K   [origin=predictive method=joback]
HvapTb      55140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.262 1.35332 -0.0007818 1.729e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)tetradecane" );
gibbsFormation
{
    dHf_298   -369050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     758.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40700.0
    phase     gas;
}
