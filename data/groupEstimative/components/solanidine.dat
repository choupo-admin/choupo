/*--------------------------------*- Choupo -*-----------------------*\
  Component: solanidine  (C27H43NO, CAS 80-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        solanidine;
formula     C27H43NO;
CAS         80-78-4;
InChIKey    JVKYZPBMZPJNAJ-OQFNDJACSA-N;
MW          397.647;      // g/mol [origin=calculated method=formula-sum]
Tc          1194.51;      // K   [origin=predictive method=joback]
Pc          12.149;      // bar [origin=predictive method=joback]
omega       1.0138;      // -   [origin=predictive method=lee-kesler]
Tb          965.04;      // K   [origin=predictive method=joback]
HvapTb      91863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-402.32 3.91998 -0.00338564 1.2379e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH; count 9; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 10; } { group CH_ring; count 9; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "solanidin" "solatubin" "solatubine" "22r,25s-solanidanine" "22r,25s-solanidine" "solanid-5-en-3beta-ol" "solanid-5-en-3-beta-ol" "3-beta-solanid-5-en-3-ol" "solanid-5-en-3.beta.-ol" "solanid-5-en-3-ol, (3.beta.)-" "solanid-5-en-3-ol" "solanid-5-en-3b-ol" );
gibbsFormation
{
    dHf_298   -304220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     716.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=425220.0
    phase     gas;
}
