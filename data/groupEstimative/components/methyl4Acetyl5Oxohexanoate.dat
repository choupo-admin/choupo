/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-acetyl-5-oxohexanoate  (C9H14O4, CAS 13984-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Acetyl5Oxohexanoate;
formula     C9H14O4;
CAS         13984-53-7;
InChIKey    XFUDNZLAPUHONL-UHFFFAOYSA-N;
MW          186.207;      // g/mol [origin=calculated method=formula-sum]
Tc          763.20;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.8357;      // -   [origin=predictive method=lee-kesler]
Tb          571.04;      // K   [origin=predictive method=joback]
HvapTb      56139.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.152 0.75396 -0.000337 2.022e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CdO; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-ethanoyl-5-oxidanylidene-hexanoate" "agn-pc-03fp5e" "hexanoic acid,4-acetyl-5-oxo-, methyl ester" "hexanoic acid, 4-acetyl-5-oxo-, methyl ester" );
standardThermochemistry
{
    dHf_298   -776810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-545750.0
}
