/*--------------------------------*- Choupo -*-----------------------*\
  Component: (chloromethyl)triethoxysilane  (C7H17ClO3Si, CAS 15267-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H17ClO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloromethylTriethoxysilane;
formula     C7H17ClO3Si;
CAS         15267-95-5;
InChIKey    ZDOBWJOCPDIBRZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          212.745;      // g/mol [origin=calculated method=formula-sum]
Tc          642.93;      // K   [origin=predictive method=joback]
Pc          22.719;      // bar [origin=predictive method=joback]
omega       0.5327;      // -   [origin=predictive method=lee-kesler]
Tb          465.85;      // K   [origin=predictive method=joback]
HvapTb      43085.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.734 0.27986 0.0003704 -3.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2O; count 3; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl(triethoxy)silane" "silane, (chloromethyl)triethoxy-" "silane, triethoxy(chloromethyl)-" "chlormethyl-triethoxysilan" "chloromethyltriethoxysilane" "silane,(chloromethyl)triethoxy-" "(chloromethyl)triethoxysilane;(triethoxysilyl)methyl chloride;nd 41;triethoxy(chloromethyl)silane;" );
gibbsFormation
{
    dHf_298   -711830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-423630.0
    phase     gas;
}
