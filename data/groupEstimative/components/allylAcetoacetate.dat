/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl acetoacetate  (C7H10O3, CAS 1118-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylAcetoacetate;
formula     C7H10O3;
CAS         1118-84-9;
InChIKey    AXLMPTNTPOWPLT-UHFFFAOYSA-N;
MW          142.154;      // g/mol [origin=calculated method=formula-sum]
Tc          656.01;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.6065;      // -   [origin=predictive method=lee-kesler]
Tb          468.53;      // K   [origin=predictive method=joback]
HvapTb      44659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.302 0.56602 -0.0002666 2.336e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 3-oxidanylidenebutanoate" "allyl acetylacetate" "acetoacetic acid, allyl ester" "butanoic acid, 3-oxo-, 2-propenyl ester" "prop-2-en-1-yl 3-oxobutanoate" "allyl 3-oxobutanoate" "prop-2-enyl 3-oxobutanoate" "acetoacetic acid allyl ester" "(2-propenyl) 3-oxobutanoate" );
standardThermochemistry
{
    dHf_298   -492240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343390.0
}
