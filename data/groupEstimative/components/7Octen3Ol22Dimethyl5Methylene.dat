/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-octen-3-ol, 2,2-dimethyl-5-methylene-  (C11H20O, CAS 42201-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Octen3Ol22Dimethyl5Methylene;
formula     C11H20O;
CAS         42201-32-1;
InChIKey    DKRSOEZYLGQVDF-SNVBAGLBSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          710.48;      // K   [origin=predictive method=joback]
Pc          23.428;      // bar [origin=predictive method=joback]
omega       0.7855;      // -   [origin=predictive method=lee-kesler]
Tb          533.03;      // K   [origin=predictive method=joback]
HvapTb      53815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.648 1.17446 -0.0008281 2.375e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r)-2,2-dimethyl-5-methylidene-oct-7-en-3-ol" "(3r)-2,2-dimethyl-5-methylideneoct-7-en-3-ol" );
gibbsFormation
{
    dHf_298   -195560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=72450.0
    phase     gas;
}
