/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromomethane-d3  (CD3Br, CAS 1111-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula CD3Br (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bromomethaneD3;
formula     CD3Br;
CAS         1111-88-2;
InChIKey    GZUXJHMPEANEGY-FIBGUPNXSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          97.957;      // g/mol [origin=calculated method=formula-sum]
Tc          473.42;      // K   [origin=predictive method=joback]
Pc          64.515;      // bar [origin=predictive method=joback]
omega       0.1921;      // -   [origin=predictive method=lee-kesler]
Tb          288.64;      // K   [origin=predictive method=joback]
HvapTb      24255.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.17 0.13702 -0.000102 3.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanyl(trideuterio)methane" "methyl-d3 bromide" "bromo(2h3)methane" );
standardThermochemistry
{
    dHf_298   -37640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     246.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28140.0
}
