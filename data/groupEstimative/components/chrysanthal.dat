/*--------------------------------*- Choupo -*-----------------------*\
  Component: chrysanthal  (C11H16O, CAS 39067-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chrysanthal;
formula     C11H16O;
CAS         39067-39-5;
InChIKey    RPJGEHBYOXRURE-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          708.81;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       0.5371;      // -   [origin=predictive method=lee-kesler]
Tb          507.51;      // K   [origin=predictive method=joback]
HvapTb      46472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.658 1.20652 -0.00083808 2.341e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 4; } { group CH=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propylbicyclo[2.2.1]hept-5-ene-3-carbaldehyde" "3-propylbicyclo[2.2.1]hept-5-ene-2-carbaldehyde" "2,5-methylene-6-propyl-3-cyclohexenecarboxaldehyde" "3-propylbicyclo(2.2.1)hept-5-ene-2-carbaldehyde" "3-propylbicyclo(2.2.1)hept-5-ene-2-carboxaldehyde" "bicyclo(2.2.1)hept-5-ene-2-carboxaldehyde, 3-propyl-" "bicyclo[2.2.1]hept-5-ene-2-carboxaldehyde, 3-propyl-" "3-propylbicyclo[2.2.1]hept-5-ene-2-carboxaldehyde" "agn-pc-00dus7" "bicyclo[2.2.1]hept-5-ene-2-carboxaldehyde,3-propyl-" );
standardThermochemistry
{
    dHf_298   -199410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66160.0
}
