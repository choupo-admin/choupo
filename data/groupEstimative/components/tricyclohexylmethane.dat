/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclohexylmethane  (C19H34, CAS 1610-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclohexylmethane;
formula     C19H34;
CAS         1610-24-8;
InChIKey    SQDGPLNZHYWEOB-UHFFFAOYSA-N;
MW          262.481;      // g/mol [origin=calculated method=formula-sum]
Tc          937.52;      // K   [origin=predictive method=joback]
Pc          17.089;      // bar [origin=predictive method=joback]
omega       0.5001;      // -   [origin=predictive method=lee-kesler]
Tb          692.53;      // K   [origin=predictive method=joback]
HvapTb      58787.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-212.88 2.181 -0.001256 2.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 15; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 15; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclohexylmethylcyclohexane" "methane, tricyclohexyl-" );
standardThermochemistry
{
    dHf_298   -277810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     795.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180010.0
}
