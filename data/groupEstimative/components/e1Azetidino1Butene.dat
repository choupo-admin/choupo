/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-1-azetidino-1-butene  (C7H13N, CAS 81156-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e1Azetidino1Butene;
formula     C7H13N;
CAS         81156-87-8;
InChIKey    WYIXMLRGSVICKM-HWKANZROSA-N;
MW          111.188;      // g/mol [origin=calculated method=formula-sum]
Tc          574.62;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.3668;      // -   [origin=predictive method=lee-kesler]
Tb          387.77;      // K   [origin=predictive method=joback]
HvapTb      33399.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.529 0.99012 -0.000829 2.844e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(e)-but-1-enyl]azetidine" "(e)-azetidino-1-butene" );
gibbsFormation
{
    dHf_298   90080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=267520.0
    phase     gas;
}
