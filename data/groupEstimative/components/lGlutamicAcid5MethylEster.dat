/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-glutamic acid 5-methyl ester  (C6H11NO4, CAS 1499-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lGlutamicAcid5MethylEster;
formula     C6H11NO4;
CAS         1499-55-4;
InChIKey    ZGEYCCHDTIDZAE-BYPYZUCNSA-N;
MW          161.157;      // g/mol [origin=calculated method=formula-sum]
Tc          819.34;      // K   [origin=predictive method=joback]
Pc          37.408;      // bar [origin=predictive method=joback]
omega       1.0302;      // -   [origin=predictive method=lee-kesler]
Tb          612.70;      // K   [origin=predictive method=joback]
HvapTb      63774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.252 0.63762 -0.0003272 4.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-5-methoxy-5-oxidanylidene-pentanoic acid" "h-glu(ome)-oh" "(2s)-2-amino-5-methoxy-5-oxopentanoic acid" "l-glutamic acid, 5-methyl ester" "polymethylglutamate" "(2s)-2-amino-4-(methoxycarbonyl)butanoic acid" "5-methyl l-glutamate" "beta-methyl-l-glutamate" "(5)-methyl l-glutamate" "l-glutamic acid, 5-methyl ester, homopolymer" "poly-gamma-methyl glutamate" "l-glutamate-5-methyl ester" );
standardThermochemistry
{
    dHf_298   -806210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-590630.0
}
