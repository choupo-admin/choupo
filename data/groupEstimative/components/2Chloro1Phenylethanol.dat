/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1-phenylethanol  (C8H9ClO, CAS 1674-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro1Phenylethanol;
formula     C8H9ClO;
CAS         1674-30-2;
InChIKey    XWCQSILTDPAWDP-UHFFFAOYSA-N;
MW          156.609;      // g/mol [origin=calculated method=formula-sum]
Tc          745.45;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.7879;      // -   [origin=predictive method=lee-kesler]
Tb          538.49;      // K   [origin=predictive method=joback]
HvapTb      56354.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.789 0.7316 -0.0004966 1.278e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1-phenyl-ethanol" "benzenemethanol, .alpha.-(chloromethyl)-" "benzenemethanol, alpha-(chloromethyl)-" "(s)-2-chloro-1-phenyl-ethanol" "styrene chlorohydrin" "2-chloro-1-phenyl-ethanol" "2-chloro-1-phenylethan-1-ol" "benzenemethanol, a-(chloromethyl)-" "benzyl alcohol, .alpha.-(chloromethyl)-" "(+/-)-2-chloro-1-phenylethanol" "(1s)-2-chloro-2,2-dideuterio-1-phenylethanol" "benzylalcohol, a-(chloromethyl)- (6ci,7ci,8ci);(chloromethyl)phenyl carbinol;(?a'a a'a currency)-2-chloro-1-phenylethanol;1-phenyl-2-chloroethanol;2-chloro-1-hydroxy-1-phenylethane;2-chloro-1-phenylethanol;styrenechlorohydrin;styrene b-chlorohydrin;a-(chloromethyl)benzenemethanol;a-(chloromethyl)benzyl alcohol;" );
gibbsFormation
{
    dHf_298   -145170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22300.0
    phase     gas;
}
