/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethyl-4-(3-methyl-2-butenyl)cyclohexanone  (C13H22O, CAS 71820-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethyl43Methyl2ButenylCyclohexanone;
formula     C13H22O;
CAS         71820-44-5;
InChIKey    WRDVCBWZNKZSNG-QWRGUYRKSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          795.22;      // K   [origin=predictive method=joback]
Pc          20.019;      // bar [origin=predictive method=joback]
omega       0.4984;      // -   [origin=predictive method=lee-kesler]
Tb          579.11;      // K   [origin=predictive method=joback]
HvapTb      48628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.099 1.15958 -0.0004957 3.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,5s)-3,5-dimethyl-4-(3-methylbut-2-enyl)cyclohexan-1-one" "cyclohexanone, 3,5-dimethyl-4-(3-methyl-2-butenyl)-" "cyclohexanone, 3,5-dimethyl-4-(3-methyl-2-buten-1-yl)-" );
standardThermochemistry
{
    dHf_298   -328280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=16690.0
}
