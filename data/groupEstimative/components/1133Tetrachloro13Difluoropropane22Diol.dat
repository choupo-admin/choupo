/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3-tetrachloro-1,3-difluoropropane-2,2-diol  (C3H2Cl4F2O2, CAS 677-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetrachloro13Difluoropropane22Diol;
formula     C3H2Cl4F2O2;
CAS         677-70-3;
InChIKey    ADCWDJKTUIBCPQ-UHFFFAOYSA-N;
MW          249.843;      // g/mol [origin=calculated method=formula-sum]
Tc          783.73;      // K   [origin=predictive method=joback]
Pc          44.267;      // bar [origin=predictive method=joback]
omega       1.2099;      // -   [origin=predictive method=lee-kesler]
Tb          591.17;      // K   [origin=predictive method=joback]
HvapTb      67648.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.07 0.785 -0.00083 3.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group OH; count 2; } { group CCl2F; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 2; } { group Cl; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3-tetrakis(chloranyl)-1,3-bis(fluoranyl)propane-2,2-diol" "2,2-propanediol, 1,1,3,3-tetrachloro-1,3-difluoro-" "1,1,3,3-tetrachloro-1,3-difluoro-2,2-propanediol" );
gibbsFormation
{
    dHf_298   -891140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-728080.0
    phase     gas;
}
