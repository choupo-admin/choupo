/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylindan  (C10H12, CAS 767-58-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylindan;
formula     C10H12;
CAS         767-58-8;
InChIKey    FIPKSKMDTAQBDJ-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          690.19;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.3520;      // -   [origin=predictive method=lee-kesler]
Tb          466.80;      // K   [origin=predictive method=joback]
HvapTb      40705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.05 0.96632 -0.00070456 2.077e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2,3-dihydro-1h-indene" "indan, 1-methyl-" "1h-indene, 2,3-dihydro-1-methyl-" "methylindan" "1-methyl-2,3-dihydroindene" "1h-indene, 2,3-dihydromethyl-" "2,3-dihydro-1-methyl-1h-indene" "methylindane" "1h-indene, dihydromethyl-" "agn-pc-00gqt4" "indan, 1-methyl- (8ci)" "1h-indene,3-dihydro-1-methyl-" );
gibbsFormation
{
    dHf_298   48130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196850.0
    phase     gas;
}
