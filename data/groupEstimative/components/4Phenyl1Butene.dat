/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenyl-1-butene  (C10H12, CAS 768-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenyl1Butene;
formula     C10H12;
CAS         768-56-9;
InChIKey    PBGVMIDTGGTBFS-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          661.01;      // K   [origin=predictive method=joback]
Pc          30.693;      // bar [origin=predictive method=joback]
omega       0.3658;      // -   [origin=predictive method=lee-kesler]
Tb          451.76;      // K   [origin=predictive method=joback]
HvapTb      39460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.098 0.8549 -0.0005743 1.507e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-3-enylbenzene" "benzene, 3-butenyl-" "1-butene, 4-phenyl-" "3-butenylbenzene" "4-phenylbutene-1" "1-phenyl-3-butene" "4-phenylbut-1-ene" "but-3-enyl-benzene" "benzene, 3-butenyl- (9ci)" "h333" );
standardThermochemistry
{
    dHf_298   112230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233570.0
}
