/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenedioic acid(2z)-, 1,4-bis(2,2,2-trifluoroethyl) ester  (C8H6F6O4, CAS 352-28-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButenedioicAcid2z14Bis222TrifluoroethylEster;
formula     C8H6F6O4;
CAS         352-28-3;
InChIKey    KZTDZFZLDVZRCF-UHFFFAOYSA-N;
MW          280.12;      // g/mol [origin=calculated method=formula-sum]
Tc          649.69;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       0.8149;      // -   [origin=predictive method=lee-kesler]
Tb          492.40;      // K   [origin=predictive method=joback]
HvapTb      40680.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.852 0.9966 -0.000748 1.946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CF3; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 2; } { group dCH; count 2; } { group F; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[2,2,2-tris(fluoranyl)ethyl] but-2-enedioate" "bis(2,2,2-trifluoroethyl)maleate 97%" "bis(2,2,2-trifluoroethyl) but-2-enedioate" "2-butenedioic acid bis(2,2,2-trifluoroethyl) ester" "2-butenedioicacid (2e)-, bis(2,2,2-trifluoroethyl) ester (9ci); 2-butenedioic acid (e)-,bis(2,2,2-trifluoroethyl) ester; fumaric acid, bis(2,2,2-trifluoroethyl) ester(6ci,8ci); bis(1,1-dihydrotrifluoroethyl) fumarate" "2-butenedioicacid (2z)-, bis(2,2,2-trifluoroethyl) ester (9ci); 2-butenedioic acid (z)-,bis(2,2,2-trifluoroethyl) ester; di(2,2,2-trifluoroethyl) maleate" );
gibbsFormation
{
    dHf_298   -1919950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     676.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1687220.0
    phase     gas;
}
