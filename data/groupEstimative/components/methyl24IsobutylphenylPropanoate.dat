/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-(4-isobutylphenyl)propanoate  (C14H20O2, CAS 61566-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl24IsobutylphenylPropanoate;
formula     C14H20O2;
CAS         61566-34-5;
InChIKey    YNZYUHPFNYBBFF-UHFFFAOYSA-N;
MW          220.312;      // g/mol [origin=calculated method=formula-sum]
Tc          815.55;      // K   [origin=predictive method=joback]
Pc          20.199;      // bar [origin=predictive method=joback]
omega       0.6640;      // -   [origin=predictive method=lee-kesler]
Tb          608.92;      // K   [origin=predictive method=joback]
HvapTb      56327.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.399 1.15248 -0.00061376 9.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-[4-(2-methylpropyl)phenyl]propanoate" "motrin methyl ester" "methyl 2-(4-isobutylphenyl)propionate" "ibuprofen methyl ester" "methyl ester of ibuprofen" "ibuprofen methyl ester, racemic" "2-(4-isobutylphenyl)propionic acid methyl ester" "methyl 2-[4-(2-methylprop-1-yl)phenyl]propanoate" "methyl 2-[4-(2-methylprop-1-yl)phenyl]propionate" "(2r/s)-2-(4-isobutylphenyl)-propionic acid methyl ester" "2-[4-(2-methyl-propyl)-phenyl]-propionic acid methyl ester" "benzeneacetic acid, " "a-methyl-4-(2-methylpropyl)-,methyl ester" );
standardThermochemistry
{
    dHf_298   -435070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145470.0
}
