/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-triisopropylbenzoic acid  (C16H24O2, CAS 49623-71-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246TriisopropylbenzoicAcid;
formula     C16H24O2;
CAS         49623-71-4;
InChIKey    ULVHAZFBJJXIDO-UHFFFAOYSA-N;
MW          248.366;      // g/mol [origin=calculated method=formula-sum]
Tc          965.44;      // K   [origin=predictive method=joback]
Pc          18.031;      // bar [origin=predictive method=joback]
omega       0.9332;      // -   [origin=predictive method=lee-kesler]
Tb          751.49;      // K   [origin=predictive method=joback]
HvapTb      71472.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.11 1.33502 -0.00075888 1.565e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 2; } { group AC; count 1; } { group ACCH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tri(propan-2-yl)benzoic acid" "2,4,6-triisopropyl benzoic acid" "benzoic acid, 2,4,6-tris(1-methylethyl)-" "2,4,6-tris(methylethyl)benzoic acid" "2,4,6-tris(1-methylethyl)benzoic acid" "benzoic acid,2,4,6-tris(1-methylethyl)-" );
standardThermochemistry
{
    dHf_298   -537560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183870.0
}
