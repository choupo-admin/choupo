/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylpropionamide  (C5H11NO, CAS 758-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylpropionamide;
formula     C5H11NO;
CAS         758-96-3;
InChIKey    MBHINSULENHCMF-UHFFFAOYSA-N;
MW          101.149;      // g/mol [origin=calculated method=formula-sum]
Tc          557.18;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       0.4369;      // -   [origin=predictive method=lee-kesler]
Tb          380.31;      // K   [origin=predictive method=joback]
HvapTb      35513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.989 0.57476 -0.0003421 7.666e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylpropanamide" "propanamide, n,n-dimethyl-" "propionamide, n,n-dimethyl-" "dimethylamide of propionic acid" "propionamide, n,n-dimethyl" "mbhinsulenhcmf-uhfffaoysa-" "propionamide,n,n-dimethyl- (6ci,7ci,8ci);dmp;" );
standardThermochemistry
{
    dHf_298   -191580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26920.0
}
