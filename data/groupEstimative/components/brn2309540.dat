/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2309540  (C24H20O4, CAS 63018-62-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2309540;
formula     C24H20O4;
CAS         63018-62-2;
InChIKey    XHCONXDVEAQFIQ-UHFFFAOYSA-N;
MW          372.42;      // g/mol [origin=calculated method=formula-sum]
Tc          1208.68;      // K   [origin=predictive method=joback]
Pc          15.923;      // bar [origin=predictive method=joback]
omega       1.1472;      // -   [origin=predictive method=lee-kesler]
Tb          968.70;      // K   [origin=predictive method=joback]
HvapTb      93676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.148 1.84624 -0.0012658 3.294e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 6; } { group ACCH2; count 2; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[12-(acetyloxymethyl)benzo[a]anthracen-7-yl]methyl ethanoate" "benz(a)anthracene-7,12-dimethanol, diacetate" "acetic acid, benz(a)anthracene-7,12-dimethanol diester" "[12-(acetyloxymethyl)benzo[a]anthracen-7-yl]methyl acetate" );
standardThermochemistry
{
    dHf_298   -409390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     735.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75700.0
}
