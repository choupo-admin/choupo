/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4,5-dimethoxyphenylacetic acid  (C10H11BrO4, CAS 4697-62-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo45DimethoxyphenylaceticAcid;
formula     C10H11BrO4;
CAS         4697-62-5;
InChIKey    MDOLAGJKKZEHHW-UHFFFAOYSA-N;
MW          275.098;      // g/mol [origin=calculated method=formula-sum]
Tc          954.45;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       1.0994;      // -   [origin=predictive method=lee-kesler]
Tb          726.53;      // K   [origin=predictive method=joback]
HvapTb      70535.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.581 0.65904 -0.00027228 1.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 2; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-bromanyl-4,5-dimethoxy-phenyl)ethanoic acid" "2-(2-bromo-4,5-dimethoxyphenyl)acetic acid" "(2-bromo-4,5-dimethoxy-phenyl)-acetic acid" "6-bromo-3,4-dimethoxyphenylacetic acid" "(2-bromo-4,5-dimethoxyphenyl)acetic acid" "benzeneacetic acid,2-bromo-4,5-dimethoxy-" );
gibbsFormation
{
    dHf_298   -635990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-422750.0
    phase     gas;
}
