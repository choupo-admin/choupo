/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzaldehyde dimethyl acetal  (C9H12O2, CAS 1125-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzaldehydeDimethylAcetal;
formula     C9H12O2;
CAS         1125-88-8;
InChIKey    HEVMDQBCAHEHDY-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          685.75;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.4581;      // -   [origin=predictive method=lee-kesler]
Tb          476.60;      // K   [origin=predictive method=joback]
HvapTb      42336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.12 0.65944 -0.0002782 1.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethoxymethylbenzene" "(dimethoxymethyl)benzene" "alpha,alpha-dimethoxytoluene" "benzene, (dimethoxymethyl)-" "dimethoxyphenylmethane" "benzaldehyde, dimethyl acetal" "toluene, alpha,alpha-dimethoxy-" "benzaldehyde dimethylacetal" "benzaldehyde dimethyl acetal (natural)" "dimethoxymethyl-benzene" "a," "a-dimethoxytoluene" ".alpha.,.alpha.-dimethoxytoluene" );
standardThermochemistry
{
    dHf_298   -262280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75130.0
}
