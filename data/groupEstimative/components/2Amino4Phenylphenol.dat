/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-4-phenylphenol  (C12H11NO, CAS 1134-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino4Phenylphenol;
formula     C12H11NO;
CAS         1134-36-7;
InChIKey    IGIDZGNPFWGICD-UHFFFAOYSA-N;
MW          185.226;      // g/mol [origin=calculated method=formula-sum]
Tc          952.51;      // K   [origin=predictive method=joback]
Pc          43.454;      // bar [origin=predictive method=joback]
omega       0.8107;      // -   [origin=predictive method=lee-kesler]
Tb          685.65;      // K   [origin=predictive method=joback]
HvapTb      71175.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.96 1.143 -0.00092412 3.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-4-phenyl-phenol" "3-amino-4-hydroxybiphenyl" "3-aminobiphenyl-4-ol" "2-hydroxy-5-phenylaniline" "4-biphenylol, 3-amino-" "phenol, 2-amino-4-phenyl-" "3-amino-1,1'-biphenyl-4-ol" "(1,1'-biphenyl)-4-ol, 3-amino-" "[1,1'-biphenyl]-4-ol, 3-amino-" "3-amino-biphenyl-4-ol" "[1, 3-amino-" "3-amino-[1,1'-biphenyl]-4-ol" );
standardThermochemistry
{
    dHf_298   27060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177180.0
}
