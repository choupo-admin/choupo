/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanone, 1-(1,4-dihydro-1,4-methanonaphthalen-5-yl)-  (C13H12O, CAS 61346-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanone114Dihydro14Methanonaphthalen5Yl;
formula     C13H12O;
CAS         61346-78-9;
InChIKey    RXNIUFYNIUAMNC-UHFFFAOYSA-N;
MW          184.238;      // g/mol [origin=calculated method=formula-sum]
Tc          828.36;      // K   [origin=predictive method=joback]
Pc          29.828;      // bar [origin=predictive method=joback]
omega       0.6236;      // -   [origin=predictive method=lee-kesler]
Tb          595.92;      // K   [origin=predictive method=joback]
HvapTb      54824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.46 1.26832 -0.0010359 3.4286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -1100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     332.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186370.0
    phase     gas;
}
