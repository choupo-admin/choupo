/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-Iodopropane  (C3H7I, CAS 107-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodopropane;
formula     C3H7I;
CAS         107-08-4;
InChIKey    PVWOIHVRPOBWPI-UHFFFAOYSA-N;
MW          169.989;      // g/mol [origin=calculated method=formula-sum]
Tc          567.14;      // K   [origin=predictive method=joback]
Pc          42.831;      // bar [origin=predictive method=joback]
omega       0.2129;      // -   [origin=predictive method=lee-kesler]
Tb          361.38;      // K   [origin=predictive method=joback]
HvapTb      31645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.852 0.32782 -0.0002208 6.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodopropane" "propane iodide" "propane, 1-iodo-" "propyl iodide" "n-propyl iodide" "propane, iodo-" "1-iodo-propane" "iodopropane" "1-jodpropan" "propyliodide" "1-iodopropane--d5" "1-iodopropane-1,4" );
gibbsFormation
{
    dHf_298   -28380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     328.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32500.0
    phase     gas;
}
