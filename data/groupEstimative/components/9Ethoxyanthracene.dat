/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-ethoxyanthracene  (C16H14O, CAS 6487-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Ethoxyanthracene;
formula     C16H14O;
CAS         6487-28-1;
InChIKey    LSOHZXVUUOEOTL-UHFFFAOYSA-N;
MW          222.287;      // g/mol [origin=calculated method=formula-sum]
Tc          902.61;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.6762;      // -   [origin=predictive method=lee-kesler]
Tb          662.70;      // K   [origin=predictive method=joback]
HvapTb      60500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.349 1.25532 -0.00090616 2.623e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 5; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   89940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=285290.0
}
