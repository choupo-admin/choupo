/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methylmorpholine oleate  (C23H45NO3, CAS 68110-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylmorpholineOleate;
formula     C23H45NO3;
CAS         68110-23-6;
InChIKey    MSDQEXGSUVJLKG-KVVVOXFISA-N;
MW          383.617;      // g/mol [origin=calculated method=formula-sum]
Tc          1146.69;      // K   [origin=predictive method=joback]
Pc          9.945;      // bar [origin=predictive method=joback]
omega       0.9587;      // -   [origin=predictive method=lee-kesler]
Tb          936.25;      // K   [origin=predictive method=joback]
HvapTb      91327.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.576 2.33254 -0.0012505 2.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH=CH; count 1; } { group FCH2O; count 1; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH; count 2; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylmorpholine;(z)-octadec-9-enoic acid" "9-octadecenoic acid (9z)-, compd. with 4-methylmorpholine (1:1)" "4-methylmorpholine; (z)-octadec-9-enoic acid" );
standardThermochemistry
{
    dHf_298   -846370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1162.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156750.0
}
