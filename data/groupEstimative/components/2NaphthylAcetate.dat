/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-naphthyl acetate  (C12H10O2, CAS 1523-11-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NaphthylAcetate;
formula     C12H10O2;
CAS         1523-11-1;
InChIKey    RJNPPEUAJCEUPV-UHFFFAOYSA-N;
MW          186.21;      // g/mol [origin=calculated method=formula-sum]
Tc          816.09;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.5955;      // -   [origin=predictive method=lee-kesler]
Tb          583.02;      // K   [origin=predictive method=joback]
HvapTb      54291.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.66 0.94692 -0.00063528 1.562e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-2-yl ethanoate" "2-naphthalenol, acetate" "naphthalen-2-yl acetate" "2-acetoxynaphthalene" "2-naphthol, acetate" "beta-naphthyl acetate" "naphthalene, 2-acetoxy-" "2-naphthalenol, 2-acetate" "beta-naphthol acetate" "o-acetyl-beta-naphthol" ".beta.-naphthol acetate" ".beta.-naphthyl acetate" );
standardThermochemistry
{
    dHf_298   -192160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50780.0
}
