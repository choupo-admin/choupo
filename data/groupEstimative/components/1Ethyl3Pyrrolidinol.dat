/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-3-pyrrolidinol  (C6H13NO, CAS 30727-14-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl3Pyrrolidinol;
formula     C6H13NO;
CAS         30727-14-1;
InChIKey    IDBNECMSCRAUNU-UHFFFAOYSA-N;
MW          115.176;      // g/mol [origin=calculated method=formula-sum]
Tc          631.33;      // K   [origin=predictive method=joback]
Pc          41.677;      // bar [origin=predictive method=joback]
omega       0.7612;      // -   [origin=predictive method=lee-kesler]
Tb          452.51;      // K   [origin=predictive method=joback]
HvapTb      47757.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.329 0.87302 -0.0006194 1.768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylpyrrolidin-3-ol" "3-pyrrolidinol, 1-ethyl-" "1-ethyl-3-hydroxypyrrolidine" );
gibbsFormation
{
    dHf_298   -185230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22250.0
    phase     gas;
}
