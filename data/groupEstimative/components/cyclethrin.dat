/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclethrin  (C21H28O3, CAS 97-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclethrin;
formula     C21H28O3;
CAS         97-11-0;
InChIKey    YJXNJQHBVKTWCC-UHFFFAOYSA-N;
MW          328.452;      // g/mol [origin=calculated method=formula-sum]
Tc          1080.79;      // K   [origin=predictive method=joback]
Pc          14.501;      // bar [origin=predictive method=joback]
omega       0.8377;      // -   [origin=predictive method=lee-kesler]
Tb          846.64;      // K   [origin=predictive method=joback]
HvapTb      74598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.4 2.2179 -0.00160338 4.963e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-cyclopent-2-en-1-yl-2-methyl-4-oxidanylidene-cyclopent-2-en-1-yl) 2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "cyklethrin" "pypyrethrin" "cyclopentenylrethonyl chrysanthemate" "ent 22,952" "2-cyclopentenyl-4-hydroxy-3-methyl-2-cyclopenten-1-one chrysanthemate" "3-(2-cyclopenten-1-yl)-2-methyl-4-oxo-2-cyclopenten-1-yl chrysanthemumate" "3-(2-cyclopentenyl)-2-methyl-4-oxo-2-cyclopentenyl ester of chrysanthemummonocarboxylic acid" "cyclopropanecarboxylic acid, 2,2-dimethyl-3-(2-methyl-1-propenyl)-, 3-(2-cyclopenten-1-yl)-2-methyl-4-oxo-2-cyclopenten-1-yl ester" "cyclopropanecarboxylic acid, 2,2-dimethyl-3-(2-methylpropenyl)-, ester with 2-(2-cyclopenten-1-yl)-4-hydroxy-3-methyl-2-cyclopenten-1-one" "(3-cyclopent-2-en-1-yl-2-methyl-4-oxocyclopent-2-en-1-yl) 2,2-dimethyl-3-(2-methylprop-1-enyl)cyclopropane-1-carboxylate" "2-methyl-5-oxo-1,1'-bi(cyclopentane)-1,2'-dien-3-yl 2,2-dimethyl-3-(2-methylprop-1-en-1-yl)cyclopropanecarboxylate" );
gibbsFormation
{
    dHf_298   -563380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     642.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-81750.0
    phase     gas;
}
