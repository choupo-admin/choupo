/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-butylbicyclo(4.3.0)non-1-en-3-one  (C13H20O, CAS 72187-24-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Butylbicyclo430Non1En3One;
formula     C13H20O;
CAS         72187-24-7;
InChIKey    JYVGLOXGSKZBJO-GXFFZTMASA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          816.64;      // K   [origin=predictive method=joback]
Pc          23.225;      // bar [origin=predictive method=joback]
omega       0.5805;      // -   [origin=predictive method=lee-kesler]
Tb          595.29;      // K   [origin=predictive method=joback]
HvapTb      50075.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.267 1.22802 -0.00066084 1.187e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(7s,7ar)-7-butyl-1,2,3,6,7,7a-hexahydroinden-5-one" "5h-inden-5-one, 7-butyl-1,2,3,6,7,7a-hexahydro-" );
standardThermochemistry
{
    dHf_298   -275920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41520.0
}
