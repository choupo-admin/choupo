/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecyl nicotinate  (C24H41NO2, CAS 33233-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecylNicotinate;
formula     C24H41NO2;
CAS         33233-29-3;
InChIKey    LCMBGJRROPDVAA-UHFFFAOYSA-N;
MW          375.597;      // g/mol [origin=calculated method=formula-sum]
Tc          1088.84;      // K   [origin=predictive method=joback]
Pc          9.858;      // bar [origin=predictive method=joback]
omega       0.9290;      // -   [origin=predictive method=lee-kesler]
Tb          887.32;      // K   [origin=predictive method=joback]
HvapTb      84911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.363 2.18388 -0.00122766 2.446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group C5H4N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group COO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecyl pyridine-3-carboxylate" "nicotinic acid, octadecyl ester" );
standardThermochemistry
{
    dHf_298   -586650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1048.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30290.0
}
