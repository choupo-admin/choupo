/*--------------------------------*- Choupo -*-----------------------*\
  Component: butethamine  (C13H20N2O2, CAS 2090-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butethamine;
formula     C13H20N2O2;
CAS         2090-89-3;
InChIKey    WDICTQVBXKADBP-UHFFFAOYSA-N;
MW          236.315;      // g/mol [origin=calculated method=formula-sum]
Tc          921.82;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.9996;      // -   [origin=predictive method=lee-kesler]
Tb          709.18;      // K   [origin=predictive method=joback]
HvapTb      71566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.473 1.18964 -0.00064816 1.08e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2NH; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-methylpropylamino)ethyl 4-azanylbenzoate" "ethanol, 2-(isobutylamino)-, p-aminobenzoate (ester)" "ethanol, 2-[(2-methylpropyl)amino]-, 4-aminobenzoate (ester)" "2-(2-methylpropylamino)ethyl 4-aminobenzoate" "2-[(2-methylpropyl)amino]ethyl 4-aminobenzoate" );
standardThermochemistry
{
    dHf_298   -321890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     683.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4390.0
}
