/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichlorooctane  (C8H16Cl2, CAS 20395-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichlorooctane;
formula     C8H16Cl2;
CAS         20395-24-8;
InChIKey    OQYNFBPKTVQOKO-UHFFFAOYSA-N;
MW          183.116;      // g/mol [origin=calculated method=formula-sum]
Tc          638.41;      // K   [origin=predictive method=joback]
Pc          23.749;      // bar [origin=predictive method=joback]
omega       0.4856;      // -   [origin=predictive method=lee-kesler]
Tb          457.06;      // K   [origin=predictive method=joback]
HvapTb      41784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.716 0.78332 -0.0004554 1.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)octane" "1,1-dichloro-octane" );
gibbsFormation
{
    dHf_298   -245210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9820.0
    phase     gas;
}
