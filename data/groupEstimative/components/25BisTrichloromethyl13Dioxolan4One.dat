/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-bis(trichloromethyl)-1,3-dioxolan-4-one  (C5H2Cl6O3, CAS 554-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25BisTrichloromethyl13Dioxolan4One;
formula     C5H2Cl6O3;
CAS         554-21-2;
InChIKey    MURYNVIRLILSCR-UHFFFAOYSA-N;
MW          322.768;      // g/mol [origin=calculated method=formula-sum]
Tc          869.94;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       0.5830;      // -   [origin=predictive method=lee-kesler]
Tb          619.36;      // K   [origin=predictive method=joback]
HvapTb      61963.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.17 0.8378 -0.0007705 2.514e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH-O; count 1; } { group CCl3; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group CH_ring; count 2; } { group Cl; count 6; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolan-4-one, 2,5-bis(trichloromethyl)-, cis-" "1,3-dioxolan-4-one, 2,5-bis-trichloromethyl-" "1,3-dioxolan-4-one, 2,5-bis-trichloromethyl-," );
standardThermochemistry
{
    dHf_298   -655290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-418130.0
}
