/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-amino-3-phenylpropanoic acid  (C9H11NO2, CAS 614-19-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Amino3PhenylpropanoicAcid;
formula     C9H11NO2;
CAS         614-19-7;
InChIKey    UJOYFRCOTPUKAK-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          885.80;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.8977;      // -   [origin=predictive method=lee-kesler]
Tb          649.80;      // K   [origin=predictive method=joback]
HvapTb      65321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.789 0.8985 -0.0006162 1.599e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanyl-3-phenyl-propanoic acid" "3-amino-3-phenylpropionic acid" "dl-3-amino-3-phenylpropionic acid" "dl-beta-phenylalanine" "3-phenyl-dl-beta-alanine" "3 amino-phenylpropionic acid" "benzenepropanoic acid, beta-amino-" "beta-phenyl-beta-alanine" "dl-beta-homophenylglycine" "beta-aminohydrocinnamic acid" "benzenepropanoic acid, 3-amino-" "(r)-3-amino-3-phenylpropionicacid" );
standardThermochemistry
{
    dHf_298   -314320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142590.0
}
