/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethyl-1,6-heptadien-4-ol  (C10H18O, CAS 79604-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethyl16Heptadien4Ol;
formula     C10H18O;
CAS         79604-66-3;
InChIKey    METKJWMTLIYYIQ-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          689.03;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       0.7434;      // -   [origin=predictive method=lee-kesler]
Tb          510.47;      // K   [origin=predictive method=joback]
HvapTb      52057.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.748 1.07346 -0.0007728 2.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-trimethylhepta-1,6-dien-4-ol" "diisobutenyl methyl carbinol" );
standardThermochemistry
{
    dHf_298   -179430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57920.0
}
