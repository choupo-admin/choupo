/*--------------------------------*- Choupo -*-----------------------*\
  Component: tributyl(ethoxy) silane  (C14H32OSi, CAS 4782-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H32OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tributylEthoxySilane;
formula     C14H32OSi;
CAS         4782-00-7;
InChIKey    ZQJYXISBATZORI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          244.494;      // g/mol [origin=calculated method=formula-sum]
Tc          707.74;      // K   [origin=predictive method=joback]
Pc          13.728;      // bar [origin=predictive method=joback]
omega       0.6372;      // -   [origin=predictive method=lee-kesler]
Tb          543.74;      // K   [origin=predictive method=joback]
HvapTb      49462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.48 1.06448 -0.000212 -1.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 9; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 10; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tributyl(ethoxy)silane" "ethyl tributylsilyl ether" "ethoxytributylsilane" "silane, tributylethoxy-" );
standardThermochemistry
{
    dHf_298   -576130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     839.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142760.0
}
