/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 5-bromo-2-chlorobenzoate  (C9H8BrClO2, CAS 76008-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl5Bromo2Chlorobenzoate;
formula     C9H8BrClO2;
CAS         76008-73-6;
InChIKey    AMGWDYLEMSMUIO-UHFFFAOYSA-N;
MW          263.515;      // g/mol [origin=calculated method=formula-sum]
Tc          838.10;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.6820;      // -   [origin=predictive method=lee-kesler]
Tb          603.97;      // K   [origin=predictive method=joback]
HvapTb      57455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.891 0.65112 -0.00036012 5.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCl; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 5-bromanyl-2-chloranyl-benzoate" "5-bromo-2-chlorobenzoic acid ethyl ester" "ethyl5-bromo-2-chlorobenzoate" "ethyl-5-bromo-2-chlorobenzoate" "ethyl 5-bromo2-chlorobenzaldehyde" "5-bromo-2-chlorobenzoicacid ethyl ester;ethyl 5-bromo-2-chlorobenzoate;benzoic acid, 5-bromo-2-chloro-, ethyl ester;" );
gibbsFormation
{
    dHf_298   -322190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189930.0
    phase     gas;
}
