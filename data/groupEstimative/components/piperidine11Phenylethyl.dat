/*--------------------------------*- Choupo -*-----------------------*\
  Component: piperidine, 1-(1-phenylethyl)-  (C13H19N, CAS 7529-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piperidine11Phenylethyl;
formula     C13H19N;
CAS         7529-63-7;
InChIKey    YJRQILVMFCZHHL-UHFFFAOYSA-N;
MW          189.302;      // g/mol [origin=calculated method=formula-sum]
Tc          784.80;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.4888;      // -   [origin=predictive method=lee-kesler]
Tb          555.67;      // K   [origin=predictive method=joback]
HvapTb      49029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.63 1.44792 -0.0010132 2.736e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-phenylethyl)piperidine" );
standardThermochemistry
{
    dHf_298   67950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     554.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=323590.0
}
