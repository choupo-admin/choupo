/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,6-difluorophenyl)ethanol  (C8H8F2O, CAS 87327-65-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        126DifluorophenylEthanol;
formula     C8H8F2O;
CAS         87327-65-9;
InChIKey    SIYWDKQSSDBLOA-UHFFFAOYSA-N;
MW          158.147;      // g/mol [origin=calculated method=formula-sum]
Tc          694.46;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.8491;      // -   [origin=predictive method=lee-kesler]
Tb          509.56;      // K   [origin=predictive method=joback]
HvapTb      51659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.1 0.62942 -0.00037492 8.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,6-bis(fluoranyl)phenyl]ethanol" "1-(2,6-difluorophenyl)ethan-1-ol" "(1s)-1-(2,6-difluorophenyl)ethanol" "agn-pc-00lyua" "2,6-difluoro-alpha-methylbenzyl alcohol" "benzenemethanol,2,6-difluoro-a-methyl-" "1-(2,6-difluorophenyl)ethanol;2,6-difluoro-a-methylbenzenemethanol" );
standardThermochemistry
{
    dHf_298   -544590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-419250.0
}
