/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylacrolein  (C5H8O, CAS 922-63-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylacrolein;
formula     C5H8O;
CAS         922-63-4;
InChIKey    GMLDCZYTIPCVMO-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          539.53;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.3547;      // -   [origin=predictive method=lee-kesler]
Tb          359.22;      // K   [origin=predictive method=joback]
HvapTb      32854.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.061 0.43322 -0.0002664 6.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylidenebutanal" "2-methylenebutanal" "2-ethylpropenal" "butanal, 2-methylene-" "2-ethylacrylaldehyde" "2-methylenebutyraldehyde" "ethacrolein" "ethylacrolein" "2-ethacrolein" "alpha-ethylacrolein" "alpha-ethylacrylaldehyde" "butyraldehyde, 2-methylene-" );
gibbsFormation
{
    dHf_298   -116470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29010.0
    phase     gas;
}
