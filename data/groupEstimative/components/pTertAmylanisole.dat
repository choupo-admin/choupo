/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-tert-amylanisole  (C12H18O, CAS 2050-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pTertAmylanisole;
formula     C12H18O;
CAS         2050-03-5;
InChIKey    BBKHJZSTQDGANW-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          736.41;      // K   [origin=predictive method=joback]
Pc          23.749;      // bar [origin=predictive method=joback]
omega       0.4626;      // -   [origin=predictive method=lee-kesler]
Tb          525.01;      // K   [origin=predictive method=joback]
HvapTb      46358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.599 1.06808 -0.00065396 1.493e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-(2-methylbutan-2-yl)benzene" "p-tert-amylphenyl methyl ether" "benzene,1-dimethylpropyl)-4-methoxy-" "4-(tert-pentyl)anisole" );
gibbsFormation
{
    dHf_298   -206920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50780.0
    phase     gas;
}
