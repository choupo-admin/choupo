/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(diethylamino)propan-2-ol  (C11H26N2O, CAS 3492-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisDiethylaminoPropan2Ol;
formula     C11H26N2O;
CAS         3492-47-5;
InChIKey    CDBMNYGKGNXEIG-UHFFFAOYSA-N;
MW          202.342;      // g/mol [origin=calculated method=formula-sum]
Tc          726.85;      // K   [origin=predictive method=joback]
Pc          21.081;      // bar [origin=predictive method=joback]
omega       1.0807;      // -   [origin=predictive method=lee-kesler]
Tb          567.90;      // K   [origin=predictive method=joback]
HvapTb      60457.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.884 1.33658 -0.0008334 2.038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis-diethylamino-propan-2-ol" "2-propanol, 1,3-bis-diethylamino-" "2-propanol, 1,3-bis-diethylamino-," "[3-(diethylamino)-2-hydroxypropyl]diethylamine" );
standardThermochemistry
{
    dHf_298   -292820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124040.0
}
