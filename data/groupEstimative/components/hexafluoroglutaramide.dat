/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexafluoroglutaramide  (C5H4F6N2O2, CAS 507-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexafluoroglutaramide;
formula     C5H4F6N2O2;
CAS         507-68-6;
InChIKey    WBOGURVAQVCKGX-UHFFFAOYSA-N;
MW          238.087;      // g/mol [origin=calculated method=formula-sum]
Tc          743.66;      // K   [origin=predictive method=joback]
Pc          35.814;      // bar [origin=predictive method=joback]
omega       0.9535;      // -   [origin=predictive method=lee-kesler]
Tb          552.73;      // K   [origin=predictive method=joback]
HvapTb      52708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.83 0.9948 -0.0009114 3.0152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF2; count 3; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 6; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,4,4-hexakis(fluoranyl)pentanediamide" "perfluoroglutaramide" "2,2,3,3,4,4-hexafluoropentanediamide" "1,1,2,2,3,3-hexafluoropropane-1,3-dicarboxamide" "hexafluoropentanediamide" );
gibbsFormation
{
    dHf_298   -1507020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1294060.0
    phase     gas;
}
