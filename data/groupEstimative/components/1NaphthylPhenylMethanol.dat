/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthyl(phenyl)methanol  (C17H14O, CAS 642-28-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1NaphthylPhenylMethanol;
formula     C17H14O;
CAS         642-28-4;
InChIKey    STUPJDVVIONFLI-UHFFFAOYSA-N;
MW          234.298;      // g/mol [origin=calculated method=formula-sum]
Tc          995.66;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       1.0338;      // -   [origin=predictive method=lee-kesler]
Tb          757.62;      // K   [origin=predictive method=joback]
HvapTb      76581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.91 1.4377 -0.00106668 3.076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-1-yl(phenyl)methanol" "1-naphthalenemethanol, a-phenyl-" "1-naphthalenemethanol, .alpha.-phenyl-" );
gibbsFormation
{
    dHf_298   100940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274840.0
    phase     gas;
}
