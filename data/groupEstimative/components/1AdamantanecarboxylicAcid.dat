/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-adamantanecarboxylic acid  (C11H16O2, CAS 828-51-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1AdamantanecarboxylicAcid;
formula     C11H16O2;
CAS         828-51-3;
InChIKey    JIMXXGFJRDUSRO-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          850.55;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.7161;      // -   [origin=predictive method=lee-kesler]
Tb          616.85;      // K   [origin=predictive method=joback]
HvapTb      55695.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-202.41 1.8081 -0.0017386 6.855e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "adamantane-1-carboxylic acid" "1-carboxyadamantane" "adamantanecarboxylic acid" "adamantoic acid" "1-adamantoic acid" "tricyclo[3.3.1.13,7]decane-1-carboxylic acid" "3-adamantanecarboxylic acid" "tricyclo[3.3.1.1~3,7~]decane-1-carboxylic acid" "tricyclo(3.3.1.1'3,7)decane-1-carboxylic acid" "1-adamantylmethanoic acid" "1-admantane carboxylic acid" "1-adamantanecarboxylic acid (8ci)" );
gibbsFormation
{
    dHf_298   -413500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145220.0
    phase     gas;
}
