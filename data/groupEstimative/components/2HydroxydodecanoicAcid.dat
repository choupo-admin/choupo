/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxydodecanoic acid  (C12H24O3, CAS 2984-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxydodecanoicAcid;
formula     C12H24O3;
CAS         2984-55-6;
InChIKey    YDZIJQXINJLRLL-UHFFFAOYSA-N;
MW          216.321;      // g/mol [origin=calculated method=formula-sum]
Tc          888.99;      // K   [origin=predictive method=joback]
Pc          21.023;      // bar [origin=predictive method=joback]
omega       1.3545;      // -   [origin=predictive method=lee-kesler]
Tb          711.41;      // K   [origin=predictive method=joback]
HvapTb      75761.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.189 1.23452 -0.0007352 1.689e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanyldodecanoic acid" "2-hydroxylauric acid" "alpha-hydroxy lauric acid" "2-hydroxy-dodecanoic acid" "2-hydroxy lauric acid" "dodecanoic acid, hydroxy-" "dl-alpha-hydroxylauric acid" "dodecanoic acid, 2-hydroxy-" "2-oh-c12" );
gibbsFormation
{
    dHf_298   -798790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-433010.0
    phase     gas;
}
