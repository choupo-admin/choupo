/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylethyl acetoacetate  (C12H14O3, CAS 40552-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PhenylethylAcetoacetate;
formula     C12H14O3;
CAS         40552-84-9;
InChIKey    GSBJXOIVIOYPOW-UHFFFAOYSA-N;
MW          206.241;      // g/mol [origin=calculated method=formula-sum]
Tc          827.98;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.7381;      // -   [origin=predictive method=lee-kesler]
Tb          612.49;      // K   [origin=predictive method=joback]
HvapTb      58347.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.839 0.98804 -0.0005501 9.046e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylethyl 3-oxidanylidenebutanoate" "1-phenylethyl 3-oxobutanoate" "butanoic acid, 3-oxo-, 1-phenylethyl ester" "alpha-methylbenzyl acetoacetate" "alpha-methyl-benzyl 3-oxobutyrate" );
gibbsFormation
{
    dHf_298   -489620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-279160.0
    phase     gas;
}
