/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorfenprop-methyl  (C10H10Cl2O2, CAS 14437-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorfenpropMethyl;
formula     C10H10Cl2O2;
CAS         14437-17-3;
InChIKey    YJKIALIXRCSISK-UHFFFAOYSA-N;
MW          233.088;      // g/mol [origin=calculated method=formula-sum]
Tc          817.25;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       0.6258;      // -   [origin=predictive method=lee-kesler]
Tb          592.70;      // K   [origin=predictive method=joback]
HvapTb      56581.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.701 0.78012 -0.00043376 6.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group CHCl; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-chloranyl-3-(4-chlorophenyl)propanoate" "bidisin" "chlorfenpropmethyl" "methachlorphenprop" "chlorphenprop-methyl" "chlorophenprop-methyl" "chlorfenprop-methyl [bsi:iso]" "methyl alpha-p-dichlorohydrocinnamate" "methyl alpha,4-dichlorophenylpropanoate" "2-chloro-3-(4-chlorophenyl)-methylpropionate" "methyl 2-chloro-3-(4-chlorophenyl)propionate" "methyl 2-chloro-3-(p-chlorophenyl)propionate" );
gibbsFormation
{
    dHf_298   -378710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200570.0
    phase     gas;
}
