/*--------------------------------*- Choupo -*-----------------------*\
  Component: s-phenyl-l-cysteine  (C9H11NO2S, CAS 34317-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sPhenylLCysteine;
formula     C9H11NO2S;
CAS         34317-61-8;
InChIKey    XYUBQWNJDIAEES-QMMMGPOBSA-N;
MW          197.252;      // g/mol [origin=calculated method=formula-sum]
Tc          970.66;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.9826;      // -   [origin=predictive method=lee-kesler]
Tb          718.58;      // K   [origin=predictive method=joback]
HvapTb      72138.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.189 0.89289 -0.000576 1.323e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanyl-3-phenylsulfanyl-propanoic acid" "l-cysteine, s-phenyl-" "4-thia-l-homophenylalanine" "3-(phenylthio)-l-alanine" "s-phenylcysteine" "3-phenylcysteine" "beta-phenylcysteine" "(2r)-2-amino-3-phenylthiopropanoic acid" "2-amino-3-phenylsulfanyl-propionic acid" "i631" "(2r)-2-amino-3-phenylsulfanylpropanoic acid" );
standardThermochemistry
{
    dHf_298   -272450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-109470.0
}
