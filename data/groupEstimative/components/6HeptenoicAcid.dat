/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-heptenoic acid  (C7H12O2, CAS 1119-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6HeptenoicAcid;
formula     C7H12O2;
CAS         1119-60-4;
InChIKey    RWNJOXUVHRXHSD-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          692.70;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.7099;      // -   [origin=predictive method=lee-kesler]
Tb          501.95;      // K   [origin=predictive method=joback]
HvapTb      47670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.866 0.6996 -0.0004525 1.175e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hept-6-enoic acid" "epsilon-heptenoic acid" "6-heptenoic acids" "hept-6-enoic acids" "epsilon-heptenoic acids" "c7:1n-1" );
standardThermochemistry
{
    dHf_298   -412650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248010.0
}
