/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexane, (3-methylbutyl)-  (C11H22, CAS 54105-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexane3Methylbutyl;
formula     C11H22;
CAS         54105-76-9;
InChIKey    BBCIDAVDQLJDMP-UHFFFAOYSA-N;
MW          154.297;      // g/mol [origin=calculated method=formula-sum]
Tc          669.47;      // K   [origin=predictive method=joback]
Pc          23.542;      // bar [origin=predictive method=joback]
omega       0.3842;      // -   [origin=predictive method=lee-kesler]
Tb          470.39;      // K   [origin=predictive method=joback]
HvapTb      40121.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.398 1.17684 -0.0006588 1.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutylcyclohexane" "isopentylcyclohexane" );
standardThermochemistry
{
    dHf_298   -221330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63750.0
}
