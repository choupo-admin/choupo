/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-2-hexanone  (C8H16O, CAS 26118-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl2Hexanone;
formula     C8H16O;
CAS         26118-38-7;
InChIKey    LJZPWSZYYTUCDP-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          620.08;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.4260;      // -   [origin=predictive method=lee-kesler]
Tb          433.28;      // K   [origin=predictive method=joback]
HvapTb      38852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.498 0.86168 -0.0005645 1.4686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylhexan-2-one" "2-hexanone,3,3-dimethyl-" "2-hexanone, 3,3-dimethyl-" );
standardThermochemistry
{
    dHf_298   -329780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-109600.0
}
