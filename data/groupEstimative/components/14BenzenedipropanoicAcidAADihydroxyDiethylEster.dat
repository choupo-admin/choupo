/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenedipropanoic acid, |a,|a'-dihydroxy-, diethyl ester  (C16H22O6, CAS 63133-89-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BenzenedipropanoicAcidAADihydroxyDiethylEster;
formula     C16H22O6;
CAS         63133-89-1;
InChIKey    YQKIPPOWPUMQJF-UHFFFAOYSA-N;
MW          310.346;      // g/mol [origin=calculated method=formula-sum]
Tc          1100.66;      // K   [origin=predictive method=joback]
Pc          20.145;      // bar [origin=predictive method=joback]
omega       1.5758;      // -   [origin=predictive method=lee-kesler]
Tb          897.26;      // K   [origin=predictive method=joback]
HvapTb      101544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.774 1.35564 -0.00068876 8.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH; count 2; } { group OH; count 2; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-[4-(3-ethoxy-1-oxidanyl-3-oxidanylidene-propyl)phenyl]-3-oxidanyl-propanoate" "diethyl beta,beta'-dihydroxybenzene-1,4-dipropionate" "diethyl 3,3'-benzene-1,4-diylbis(3-hydroxypropanoate)" "1,4-benzenedipropanoic acid, beta,beta'-dihydroxy-, diethyl ester" "1,4-benzenedipropanoic acid, .beta.,.beta.'-dihydroxy-, diethyl ester" "1,4-benzenedipropanoic acid, beta1,beta4-dihydroxy-, 1,4-diethyl ester" "ethyl 3-[4-(3-ethoxy-1-hydroxy-3-oxopropyl)phenyl]-3-hydroxypropanoate" "1,4-benzenedipropanoic acid, .beta.1,.beta.4-dihydroxy-, 1,4-diethyl ester" );
gibbsFormation
{
    dHf_298   -1098090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     851.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-712640.0
    phase     gas;
}
