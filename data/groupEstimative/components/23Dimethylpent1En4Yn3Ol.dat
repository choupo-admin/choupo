/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dimethylpent-1-en-4-yn-3-ol  (C7H10O, CAS 529-32-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dimethylpent1En4Yn3Ol;
formula     C7H10O;
CAS         529-32-8;
InChIKey    DYZLLZCBSQZDBN-UHFFFAOYSA-N;
MW          110.156;      // g/mol [origin=calculated method=formula-sum]
Tc          624.46;      // K   [origin=predictive method=joback]
Pc          39.856;      // bar [origin=predictive method=joback]
omega       0.5726;      // -   [origin=predictive method=lee-kesler]
Tb          435.39;      // K   [origin=predictive method=joback]
HvapTb      45827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.56 0.71464 -0.00058033 1.9139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethyl-1-penten-4-yn-3-ol" "1-penten-4-yn-3-ol, 2,3-dimethyl-" );
gibbsFormation
{
    dHf_298   58750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176440.0
    phase     gas;
}
