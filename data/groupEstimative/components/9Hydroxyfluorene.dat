/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-hydroxyfluorene  (C13H10O, CAS 1689-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Hydroxyfluorene;
formula     C13H10O;
CAS         1689-64-1;
InChIKey    AFMVESZOYKHDBJ-UHFFFAOYSA-N;
MW          182.222;      // g/mol [origin=calculated method=formula-sum]
Tc          876.94;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.9462;      // -   [origin=predictive method=lee-kesler]
Tb          650.74;      // K   [origin=predictive method=joback]
HvapTb      66656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.85 1.1661 -0.00095512 3.136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9h-fluoren-9-ol" "9-fluorenol" "fluoren-9-ol" "9-hydroxy fluorene" "fluorenol" "diphenylene carbinol" "fluorene,9-hydroxy" "9-hydroxyfluorene; 9-fluorenol" "afmveszoykhdbj-uhfffaoysa-" "9h-fluoren-9-ol, 8a,9a-dihydro-" "l899" );
gibbsFormation
{
    dHf_298   71360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212270.0
    phase     gas;
}
