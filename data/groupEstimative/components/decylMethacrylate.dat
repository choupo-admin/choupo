/*--------------------------------*- Choupo -*-----------------------*\
  Component: decyl methacrylate  (C14H26O2, CAS 3179-47-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decylMethacrylate;
formula     C14H26O2;
CAS         3179-47-3;
InChIKey    GTBGXKPAKVYEKJ-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          745.01;      // K   [origin=predictive method=joback]
Pc          15.873;      // bar [origin=predictive method=joback]
omega       0.7656;      // -   [origin=predictive method=lee-kesler]
Tb          574.70;      // K   [origin=predictive method=joback]
HvapTb      53575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.889 1.25894 -0.0006684 1.175e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decyl 2-methylprop-2-enoate" "n-decyl methacrylate" "methacrylic acid, decyl ester" "2-propenoic acid, 2-methyl-, decyl ester" "decyl 2-methylacrylate" "n-decyl methacrylate, pract" );
standardThermochemistry
{
    dHf_298   -533930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164080.0
}
