/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-di-(2,4-dimethyl-benzoyl)-propane  (C21H24O2, CAS 6280-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Di24DimethylBenzoylPropane;
formula     C21H24O2;
CAS         6280-01-9;
InChIKey    GWLPWMUYNCDPJK-UHFFFAOYSA-N;
MW          308.421;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.64;      // K   [origin=predictive method=joback]
Pc          15.923;      // bar [origin=predictive method=joback]
omega       1.0115;      // -   [origin=predictive method=lee-kesler]
Tb          861.10;      // K   [origin=predictive method=joback]
HvapTb      83032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.097 1.54708 -0.00087544 1.7202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 4; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-bis(2,4-dimethylphenyl)pentane-1,5-dione" );
standardThermochemistry
{
    dHf_298   -274750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     789.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54400.0
}
