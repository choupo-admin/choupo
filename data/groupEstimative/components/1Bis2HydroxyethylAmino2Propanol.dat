/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[bis(2-hydroxyethyl)amino]-2-propanol  (C7H17NO3, CAS 6712-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bis2HydroxyethylAmino2Propanol;
formula     C7H17NO3;
CAS         6712-98-7;
InChIKey    ZFECCYLNALETDE-UHFFFAOYSA-N;
MW          163.217;      // g/mol [origin=calculated method=formula-sum]
Tc          807.54;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       1.8987;      // -   [origin=predictive method=lee-kesler]
Tb          648.30;      // K   [origin=predictive method=joback]
HvapTb      82868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.025 0.90062 -0.000564 1.384e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(2-hydroxyethyl)amino]propan-2-ol" "n,n-bis(2-hydroxyethyl)isopropanolamine" "2-propanol, 1-[bis(2-hydroxyethyl)amino]-" "1-(n,n-bis(2-hydroxyethyl)amino)-2-propanol" "1-[n,n-bis(2-hydroxyethyl)amino]-2-propanol" "2-propanol, 1-(bis(2-hydroxyethyl)amino)-" "2-propanol,1-[bis(2-hydroxyethyl)amino]-" "1-(n,n-bis(2-hydroxyethyl)amino)propan-2-ol" );
gibbsFormation
{
    dHf_298   -582250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-294060.0
    phase     gas;
}
