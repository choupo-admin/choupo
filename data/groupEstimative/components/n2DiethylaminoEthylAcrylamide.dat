/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[2-(diethylamino)ethyl]acrylamide  (C9H18N2O, CAS 31014-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2DiethylaminoEthylAcrylamide;
formula     C9H18N2O;
CAS         31014-51-4;
InChIKey    CXSANWNPQKKNJO-UHFFFAOYSA-N;
MW          170.256;      // g/mol [origin=calculated method=formula-sum]
Tc          697.29;      // K   [origin=predictive method=joback]
Pc          25.872;      // bar [origin=predictive method=joback]
omega       0.7772;      // -   [origin=predictive method=lee-kesler]
Tb          518.68;      // K   [origin=predictive method=joback]
HvapTb      50183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.826 1.01094 -0.0006312 1.5216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(diethylamino)ethyl]prop-2-enamide" "n-(2-(diethylamino)ethyl)acrylamide" "2-propenamide, n-(2-(diethylamino)ethyl)-" "2-propenamide, n-[2-(diethylamino)ethyl]-" "n-((2-diethylamino)ethyl)acrylamide" "n-(2-diethylaminoethyl)prop-2-enamide" "n-(2-(diethylamino)ethyl)-2-propenamide" "acrylamide, n-(2-(diethylamino)ethyl)-, homopolymer" "2-propenamide, n-(2-(diethylamino)ethyl)-, homopolymer" );
gibbsFormation
{
    dHf_298   -95240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183990.0
    phase     gas;
}
