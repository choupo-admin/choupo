/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluoro-2-methylbenzaldehyde  (C8H7FO, CAS 147624-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H7FO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Fluoro2Methylbenzaldehyde;
formula     C8H7FO;
CAS         147624-13-3;
InChIKey    HSUCYMJBFHBMTB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          138.141;      // g/mol [origin=calculated method=formula-sum]
Tc          594.06;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.3012;      // -   [origin=predictive method=lee-kesler]
Tb          394.97;      // K   [origin=predictive method=joback]
HvapTb      33812.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.1 0.58582 -0.00047792 1.62e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CHO; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-fluoranyl-2-methyl-benzaldehyde" "2-methyl-3-fluorobenzaldehyde" "3-fluoro-2-methyl-benzaldehyde" "147624-13-3 3-fluoro-2-methylbenzaldehyde" "3-fuoro-2-methylbenzaldehyde;" "wt454" "benzaldehyde, 3-fluoro-2-methyl-" );
gibbsFormation
{
    dHf_298   -114520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41220.0
    phase     gas;
}
