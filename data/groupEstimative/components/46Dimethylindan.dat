/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dimethylindan  (C11H14, CAS 1685-82-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dimethylindan;
formula     C11H14;
CAS         1685-82-1;
InChIKey    BSYQUYXSAFIGLB-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          726.86;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.4272;      // -   [origin=predictive method=lee-kesler]
Tb          504.31;      // K   [origin=predictive method=joback]
HvapTb      44564.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.3 0.96884 -0.00068028 1.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group ACCH3; count 2; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6-dimethyl-2,3-dihydro-1h-indene" "indan, 4,6-dimethyl-" "1h-indene, 2,3-dihydro-4,6-dimethyl-" "4,6-dimethyl-(2,3-dihydroindene)" "indan,6-dimethyl-" "1h-indene,3-dihydro-4,6-dimethyl-" "1h-indene,2,3-dihydro-4,6-dimethyl-" "1h-indene, 2,3-dihydro-4,6-dimethyl- (9ci)" );
standardThermochemistry
{
    dHf_298   24890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=193720.0
}
