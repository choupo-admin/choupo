/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-bis[(dimethylamino)methyl]phenol  (C12H20N2O, CAS 15827-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26BisDimethylaminoMethylPhenol;
formula     C12H20N2O;
CAS         15827-34-6;
InChIKey    VUENIEFVRKDJAS-UHFFFAOYSA-N;
MW          208.305;      // g/mol [origin=calculated method=formula-sum]
Tc          817.67;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.8499;      // -   [origin=predictive method=lee-kesler]
Tb          611.32;      // K   [origin=predictive method=joback]
HvapTb      62344.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.928 1.40788 -0.00107472 3.401e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group ACCH2; count 2; } { group ACOH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(dimethylaminomethyl)phenol" "phenol,2,6-bis[(dimethylamino)methyl]-" "alpha,alpha'-bis(dimethylamino)-2,6-xylenol" "alpha2,alpha6-bis-(dimethylamino)-2,6-xylenol" "alpha^2,alpha^6-bis-(dimethylamino)-2,6-xylenol" );
gibbsFormation
{
    dHf_298   -108200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219880.0
    phase     gas;
}
