/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl isoeugenol  (C11H14O2, CAS 93-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylIsoeugenol;
formula     C11H14O2;
CAS         93-16-3;
InChIKey    NNWHUJCUHAELCL-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          747.12;      // K   [origin=predictive method=joback]
Pc          26.164;      // bar [origin=predictive method=joback]
omega       0.5537;      // -   [origin=predictive method=lee-kesler]
Tb          536.92;      // K   [origin=predictive method=joback]
HvapTb      48458.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.4 0.74456 -0.00033352 3.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethoxy-4-prop-1-enyl-benzene" "3,4-dimethoxypropenylbenzene" "cis-methyl isoeugenol" "iso-eugenol" "4-(1-propenyl)-1,2-dimethoxybenzene" "benzene, 1,2-dimethoxy-4-(1-propenyl)-" "benzene, 1,2-dimethoxy-4-(1-propen-1-yl)-" "1,2-dimethoxy-4-[(1z)-prop-1-en-1-yl]benzene" "1,2-dimethoxy-4-prop-1-enylbenzene" );
standardThermochemistry
{
    dHf_298   -204000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5110.0
}
