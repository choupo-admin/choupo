/*--------------------------------*- Choupo -*-----------------------*\
  Component: triundecanoin  (C36H68O6, CAS 13552-80-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triundecanoin;
formula     C36H68O6;
CAS         13552-80-2;
InChIKey    MBXVIRZWSHICAV-UHFFFAOYSA-N;
MW          596.934;      // g/mol [origin=calculated method=formula-sum]
Tc          1608.12;      // K   [origin=predictive method=joback]
Pc          4.623;      // bar [origin=predictive method=joback]
omega       -0.1884;      // -   [origin=predictive method=lee-kesler]
Tb          1197.50;      // K   [origin=predictive method=joback]
HvapTb      117563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.709 3.26536 -0.001654 2.454e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 26; } { group CH; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 29; } { group CH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-di(undecanoyloxy)propyl undecanoate" "glyceryl triundecanoate" "trihendecanoin" "triundecylin" "n-trihendecanoin" "undecanoin, tri-" "glycerol triundecanoate" "1,2,3-triundecanoylglycerol" "undecanoic acid, 1,2,3-propanetriyl ester" "propane-1,2,3-triyl triundecanoate" "undecanoic acid, 1,1',1''-(1,2,3-propanetriyl) ester" "undecanoicacid, 1,2,3-propanetriyl ester (9ci); undecanoin, tri- (6ci,8ci); captex 822;glyceryl triundecanoate; trihendecanoin; triundecanoin; n-trihendecanoin" );
gibbsFormation
{
    dHf_298   -1743490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1702.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-681310.0
    phase     gas;
}
