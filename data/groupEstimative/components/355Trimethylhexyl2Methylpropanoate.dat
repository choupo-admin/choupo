/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5,5-trimethylhexyl 2-methylpropanoate  (C13H26O2, CAS 67785-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        355Trimethylhexyl2Methylpropanoate;
formula     C13H26O2;
CAS         67785-66-4;
InChIKey    YQQKBMWPUKVLIF-UHFFFAOYSA-N;
MW          214.349;      // g/mol [origin=calculated method=formula-sum]
Tc          732.43;      // K   [origin=predictive method=joback]
Pc          16.991;      // bar [origin=predictive method=joback]
omega       0.6183;      // -   [origin=predictive method=lee-kesler]
Tb          551.15;      // K   [origin=predictive method=joback]
HvapTb      49867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.357 1.32172 -0.000767 1.573e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethylhexyl isobutyrate" "propanoic acid, 2-methyl-, 3,5,5-trimethylhexyl ester" );
standardThermochemistry
{
    dHf_298   -648240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     655.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253830.0
}
