/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethylthio-5,5-dimethyl-cyclohex-2-enone  (C10H16OS, CAS 52735-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethylthio55DimethylCyclohex2Enone;
formula     C10H16OS;
CAS         52735-49-6;
InChIKey    PFUNWSBUPUWAIW-UHFFFAOYSA-N;
MW          184.297;      // g/mol [origin=calculated method=formula-sum]
Tc          835.30;      // K   [origin=predictive method=joback]
Pc          29.061;      // bar [origin=predictive method=joback]
omega       0.4953;      // -   [origin=predictive method=lee-kesler]
Tb          588.93;      // K   [origin=predictive method=joback]
HvapTb      49150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.689 1.07845 -0.00076984 2.541e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethylsulfanyl-5,5-dimethyl-cyclohex-2-en-1-one" "3-ethylsulfanyl-5,5-dimethylcyclohex-2-en-1-one" "3-(ethylsulfanyl)-5,5-dimethylcyclohex-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -229690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16860.0
}
