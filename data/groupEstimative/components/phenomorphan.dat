/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenomorphan  (C24H29NO, CAS 468-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenomorphan;
formula     C24H29NO;
CAS         468-07-5;
InChIKey    CFBQYWXPZVQQTN-QPTUXGOLSA-N;
MW          347.502;      // g/mol [origin=calculated method=formula-sum]
Tc          1180.35;      // K   [origin=predictive method=joback]
Pc          19.441;      // bar [origin=predictive method=joback]
omega       1.0519;      // -   [origin=predictive method=lee-kesler]
Tb          924.85;      // K   [origin=predictive method=joback]
HvapTb      88049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-297.888 3.08 -0.00279292 1.037e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 2; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenomorphane [inn-french]" "phenomorphanum [inn-latin]" "3-hydroxy-n-phenethylmorphinan" "morphinan-3-ol, 17-phenethyl-, (-)-" "2h-10,4a-iminoethanophenanthren-6-ol, 1,3,4,9,10,10a,hexahydro-11-phenethyl-" "fenomorfano" "phenomorphane" "phenomorphanum" "phenomorphan [inn:ban:dcf]" "n-phenethyl-3-hydroxymorphinan" "morphinan, 3-hydroxy-n-phenethyl-" "17-(2-phenylethyl)morphinan-3-ol" );
standardThermochemistry
{
    dHf_298   40600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     733.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=487210.0
}
