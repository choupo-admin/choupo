/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,3-trichloro-2-hydroxypropanoic acid  (C3H3Cl3O3, CAS 599-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Trichloro2HydroxypropanoicAcid;
formula     C3H3Cl3O3;
CAS         599-01-9;
InChIKey    PBXLMODGBAXKQR-UHFFFAOYSA-N;
MW          193.404;      // g/mol [origin=calculated method=formula-sum]
Tc          828.96;      // K   [origin=predictive method=joback]
Pc          50.371;      // bar [origin=predictive method=joback]
omega       1.1213;      // -   [origin=predictive method=lee-kesler]
Tb          614.55;      // K   [origin=predictive method=joback]
HvapTb      67586.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.57 0.5257 -0.0004786 1.607e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group C; count 1; } { group Cl; count 3; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,3-tris(chloranyl)-2-oxidanyl-propanoic acid" "3,3,3-trichlorolactic acid" "propanoic acid,3,3,3-trichloro-2-hydroxy-" );
standardThermochemistry
{
    dHf_298   -669000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-541740.0
}
