/*--------------------------------*- Choupo -*-----------------------*\
  Component: sebacic acid  (C10H18O4, CAS 111-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sebacicAcid;
formula     C10H18O4;
CAS         111-20-6;
InChIKey    CXMXRPHRNRROMY-UHFFFAOYSA-N;
MW          202.25;      // g/mol [origin=calculated method=formula-sum]
Tc          914.31;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       1.2821;      // -   [origin=predictive method=lee-kesler]
Tb          719.42;      // K   [origin=predictive method=joback]
HvapTb      72182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.998 1.0554 -0.0006654 1.638e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanedioic acid" "1,8-octanedicarboxylic acid" "sebacic acids" "decanedicarboxylic acid" "1,10-decanedioic acid" "n-decanedioic acid" "sebacinsaure" "acide sebacique" "usaf hc-1" "sebacate" "sebacinsaure [german]" "acide sebacique [french]" );
standardThermochemistry
{
    dHf_298   -950270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-654500.0
}
