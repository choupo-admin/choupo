/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrothiophene  (C4H8S, CAS 110-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrothiophene;
formula     C4H8S;
CAS         110-01-0;
InChIKey    RAOIDOHSFRTOEL-UHFFFAOYSA-N;
MW          88.168;      // g/mol [origin=calculated method=formula-sum]
Tc          576.38;      // K   [origin=predictive method=joback]
Pc          51.387;      // bar [origin=predictive method=joback]
omega       0.1932;      // -   [origin=predictive method=lee-kesler]
Tb          358.90;      // K   [origin=predictive method=joback]
HvapTb      30876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.35 0.55641 -0.0003953 1.129e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiolane" "thiophane" "tetramethylene sulfide" "thiophene, tetrahydro-" "thiacyclopentane" "thilane" "tetrahydrothiophen" "tetramethylenesulfide" "thiofan" "thiolan" "tetrahydrothiofen" "tetrahydro-thiophene" );
standardThermochemistry
{
    dHf_298   190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66920.0
}
