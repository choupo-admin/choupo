/*--------------------------------*- Choupo -*-----------------------*\
  Component: fomocaine  (C20H25NO2, CAS 17692-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fomocaine;
formula     C20H25NO2;
CAS         17692-39-6;
InChIKey    CVHGCWVMTZWGAY-UHFFFAOYSA-N;
MW          311.425;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.00;      // K   [origin=predictive method=joback]
Pc          18.805;      // bar [origin=predictive method=joback]
omega       0.9104;      // -   [origin=predictive method=lee-kesler]
Tb          797.30;      // K   [origin=predictive method=joback]
HvapTb      74857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.096 1.9024 -0.00123006 2.945e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group O_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[3-[4-(phenoxymethyl)phenyl]propyl]morpholine" "fomocain" "4-{3-[4-(phenoxymethyl)phenyl]propyl}morpholine" "4-(3-(4-(phenoxymethyl)phenyl)propyl)morpholine" "fomocainum" "fomocaina" "fomocaina [dcit]" "fomocainum [inn-latin]" "56583-43-8 (hydrochloride)" "4-(3-(alpha-phenoxy-p-tolyl)propyl)morpholine" "brd-k44942188-001-01-8" );
standardThermochemistry
{
    dHf_298   -110410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=296630.0
}
