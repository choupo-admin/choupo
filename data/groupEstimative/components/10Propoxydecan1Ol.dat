/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-propoxydecan-1-ol  (C13H28O2, CAS 33925-62-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10Propoxydecan1Ol;
formula     C13H28O2;
CAS         33925-62-1;
InChIKey    IJXBLOJMKJMYGR-UHFFFAOYSA-N;
MW          216.365;      // g/mol [origin=calculated method=formula-sum]
Tc          770.23;      // K   [origin=predictive method=joback]
Pc          17.492;      // bar [origin=predictive method=joback]
omega       1.1164;      // -   [origin=predictive method=lee-kesler]
Tb          611.64;      // K   [origin=predictive method=joback]
HvapTb      63621.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.862 1.20962 -0.0006028 9.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-decanol, 10-propoxy-" );
standardThermochemistry
{
    dHf_298   -596100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183240.0
}
