/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butoxyacetic acid  (C6H12O3, CAS 2516-93-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButoxyaceticAcid;
formula     C6H12O3;
CAS         2516-93-0;
InChIKey    AJQOASGWDCBKCJ-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          692.80;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.7695;      // -   [origin=predictive method=lee-kesler]
Tb          504.81;      // K   [origin=predictive method=joback]
HvapTb      48524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.534 0.56142 -0.0002642 3.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethanoic acid" "butoxyacetic acid" "n-butoxyacetic acid" "acetic acid, butoxy-" "acetic acid, 2-butoxy-" "ajqoasgwdcbkcj-uhfffaoysa-" "56637-93-5 (hydrochloride salt)" );
gibbsFormation
{
    dHf_298   -649660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-449270.0
    phase     gas;
}
