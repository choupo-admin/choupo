/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxyphenyl isocyanate  (C8H7NO2, CAS 700-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethoxyphenylIsocyanate;
formula     C8H7NO2;
CAS         700-87-8;
InChIKey    SUVCZZADQDCIEQ-UHFFFAOYSA-N;
MW          149.149;      // g/mol [origin=calculated method=formula-sum]
Tc          723.43;      // K   [origin=predictive method=joback]
Pc          38.435;      // bar [origin=predictive method=joback]
omega       0.5463;      // -   [origin=predictive method=lee-kesler]
Tb          503.39;      // K   [origin=predictive method=joback]
HvapTb      48282.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-2-methoxy-benzene" "1-isocyanato-2-methoxybenzene" "2-methoxyphenylisocyanate" "benzene, 1-isocyanato-2-methoxy-" "2-methoxybenzenisocyanate" "2-isocyanatoanisole" "suvczzadqdcieq-uhfffaoysa-" "benzene,1-isocyanato-2-methoxy-" "isocyanic acid 2-methoxyphenyl ester" "isocyanic acid, 2-methoxyphenyl ester" "isocyanicacid, o-methoxyphenyl ester (6ci,7ci,8ci); 1-isocyanato-2-methoxybenzene;2-methoxyphenyl isocyanate; o-anisyl isocyanate; o-methoxyphenyl isocyanate" );
