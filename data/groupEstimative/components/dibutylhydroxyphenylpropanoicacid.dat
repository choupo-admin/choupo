/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibutylhydroxyphenylpropanoicacid  (C17H26O3, CAS 20170-32-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutylhydroxyphenylpropanoicacid;
formula     C17H26O3;
CAS         20170-32-5;
InChIKey    WPMYUUITDBHVQZ-UHFFFAOYSA-N;
MW          278.392;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.30;      // K   [origin=predictive method=joback]
Pc          19.355;      // bar [origin=predictive method=joback]
omega       1.1074;      // -   [origin=predictive method=lee-kesler]
Tb          844.87;      // K   [origin=predictive method=joback]
HvapTb      84622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.138 1.87802 -0.00147068 4.717e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3,5-ditert-butyl-4-oxidanyl-phenyl)propanoic acid" "fenozan" "3-(3,5-di-tert-butyl-4-hydroxyphenyl)propionic acid" "3-(3,5-di-tert-butyl-4-hydroxyphenyl)propanoic acid" "3,5-di-tert-butyl-4-hydroxyphenylpropionic acid" "3,5-bis(1,1-dimethylethyl)-4-hydroxybenzenepropanoic acid" "benzenepropanoic acid, 3,5-bis(1,1-dimethylethyl)-4-hydroxy-" "3,5-di-tert-butyl-4-hydroxyhydocinnamic acid" "3-[3,5-bis(tert-butyl)-4-hydroxyphenyl]propanoic acid" "4-hydroxy-3,5-di-tert-butylphenylpropionic acid" "3-(3,5-ditert-butyl-4-hydroxyphenyl)propanoic acid" "3-(3,5-ditertbutyl-4-hydroxyphenyl)propionic acid" );
standardThermochemistry
{
    dHf_298   -725700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-307440.0
}
