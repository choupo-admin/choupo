/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylanisole  (C11H16O, CAS 5396-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylanisole;
formula     C11H16O;
CAS         5396-38-3;
InChIKey    MCUPBIBNSTXCPQ-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          716.93;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       0.4143;      // -   [origin=predictive method=lee-kesler]
Tb          502.13;      // K   [origin=predictive method=joback]
HvapTb      44132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.69 0.97308 -0.00059956 1.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-methoxy-benzene" "anisole, p-tert-butyl-" "benzene, 1-(1,1-dimethylethyl)-4-methoxy-" "p-tert-butylanisole" "1-(tert-butyl)-4-methoxybenzene" "1-tert-butyl-4-methoxybenzene" "p-methoxy-tert-butylbenzene" "4-methoxy-tert-butylbenzene" "4-tert-butylphenyl methyl ether" "4-(tert-butyl)anisole" "p-t-butylanisole" "agn-pc-0ct5ft" );
standardThermochemistry
{
    dHf_298   -186280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42360.0
}
