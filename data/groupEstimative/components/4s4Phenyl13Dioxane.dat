/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4s)-4-phenyl-1,3-dioxane  (C10H12O2, CAS 107796-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4s4Phenyl13Dioxane;
formula     C10H12O2;
CAS         107796-30-5;
InChIKey    RCJRILMVFLGCJY-JTQLQIEISA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          773.51;      // K   [origin=predictive method=joback]
Pc          36.290;      // bar [origin=predictive method=joback]
omega       0.4310;      // -   [origin=predictive method=lee-kesler]
Tb          528.53;      // K   [origin=predictive method=joback]
HvapTb      49579.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.07 0.991 -0.0006046 1.255e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 4-phenyl-,(4s)-" "(s)-4-phenyl-1,3-dioxane" "(-)-4-phenyl-1,3-dioxane" );
gibbsFormation
{
    dHf_298   -222880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2060.0
    phase     gas;
}
