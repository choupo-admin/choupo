/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5,7-cyclooctatetraenyl trimethylsilane  (C11H16Si, CAS 55632-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1357CyclooctatetraenylTrimethylsilane;
formula     C11H16Si;
CAS         55632-03-6;
InChIKey    WBBRFTQTMSACOW-QQCYJJBBSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          176.334;      // g/mol [origin=calculated method=formula-sum]
Tc          715.20;      // K   [origin=predictive method=joback]
Pc          25.585;      // bar [origin=predictive method=joback]
omega       0.2791;      // -   [origin=predictive method=lee-kesler]
Tb          487.06;      // K   [origin=predictive method=joback]
HvapTb      43286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.66 0.68856 -8.548e-05 -1.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=CH; count 3; } { group CH=C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclooctatetraenyl(trimethyl)silane" );
gibbsFormation
{
    dHf_298   -100000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55150.0
    phase     gas;
}
