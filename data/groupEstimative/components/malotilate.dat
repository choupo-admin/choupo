/*--------------------------------*- Choupo -*-----------------------*\
  Component: malotilate  (C12H16O4S2, CAS 59937-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        malotilate;
formula     C12H16O4S2;
CAS         59937-28-9;
InChIKey    YPIQVCUJEKAZCP-UHFFFAOYSA-N;
MW          288.376;      // g/mol [origin=calculated method=formula-sum]
Tc          943.16;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.8193;      // -   [origin=predictive method=lee-kesler]
Tb          711.01;      // K   [origin=predictive method=joback]
HvapTb      69693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.84 1.0995 -0.00062448 1.086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C=C; count 1; } { group COO; count 2; } { group CHS; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dC; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } { group COO; count 2; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dipropan-2-yl 2-(1,3-dithiol-2-ylidene)propanedioate" "kantec" "malotilatum [inn-latin]" "diisopropyl 1,3-dithiol-2-ylidenemalonate" "diisopropyl-1,3-dithiol-2-ylidenemalonate" "1,3-dithiol-2-ylidenepropanedioic acid, bis(1-methylethyl) ester" "malonic acid, (1,3-dithiol-2-ylidene)-, diisopropyl ester" "propanedioic acid, 1,3-dithiol-2-ylidene-, bis(1-methylethyl) ester" "malotilato" "malotilatum" "tractal" "kantec (tn)" );
standardThermochemistry
{
    dHf_298   -640770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     729.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-384610.0
}
