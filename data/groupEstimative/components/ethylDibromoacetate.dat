/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl dibromoacetate  (C4H6Br2O2, CAS 617-33-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylDibromoacetate;
formula     C4H6Br2O2;
CAS         617-33-4;
InChIKey    NIJGVVHCUXNSLL-UHFFFAOYSA-N;
MW          245.898;      // g/mol [origin=calculated method=formula-sum]
Tc          699.09;      // K   [origin=predictive method=joback]
Pc          47.497;      // bar [origin=predictive method=joback]
omega       0.5760;      // -   [origin=predictive method=lee-kesler]
Tb          481.22;      // K   [origin=predictive method=joback]
HvapTb      44387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.361 0.41132 -0.0002452 4.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2-bis(bromanyl)ethanoate" "acetic acid, dibromo-, ethyl ester" "dibromoacetic acid, ethyl ester" "acetic acid, 2,2-dibromo-, ethyl ester" "ethyl 2,2-dibromoacetate" "dibromoacetic acid ethyl ester" "ethyl 2,2-dibromoacetate;acetic acid, dibromo-, ethyl ester;ethyl dibromoacetate;" );
gibbsFormation
{
    dHf_298   -395790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-301370.0
    phase     gas;
}
