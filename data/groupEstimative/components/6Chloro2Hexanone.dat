/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-chloro-2-hexanone  (C6H11ClO, CAS 10226-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Chloro2Hexanone;
formula     C6H11ClO;
CAS         10226-30-9;
InChIKey    CMDIDTNMHQUVPE-UHFFFAOYSA-N;
MW          134.603;      // g/mol [origin=calculated method=formula-sum]
Tc          613.21;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.4863;      // -   [origin=predictive method=lee-kesler]
Tb          428.18;      // K   [origin=predictive method=joback]
HvapTb      40081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.684 0.55262 -0.0003043 6.016e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH3CO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-chloranylhexan-2-one" "6-chlorohexan-2-one" "1-chloro-5-hexanone" "1-chlorohexane-5-one" "6-chloro-hexan-2-one" "2-hexanone, 6-chloro-" "4-chlorobutyl methyl ketone" "1-chlorohexan-5-one;4-chlorobutyl methyl ketone; 5-oxohexyl chloride; 6-chloro-2-hexanone" );
standardThermochemistry
{
    dHf_298   -295490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141210.0
}
