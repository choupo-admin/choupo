/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylnonyl methacrylate  (C14H26O2, CAS 67905-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylnonylMethacrylate;
formula     C14H26O2;
CAS         67905-49-1;
InChIKey    HVRYPBMZOOJQMD-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          747.51;      // K   [origin=predictive method=joback]
Pc          15.974;      // bar [origin=predictive method=joback]
omega       0.7360;      // -   [origin=predictive method=lee-kesler]
Tb          574.26;      // K   [origin=predictive method=joback]
HvapTb      53187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.207 1.26486 -0.0006716 1.17e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylnonyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-methylnonyl ester" "methacrylic acid, 2-methylnonyl ester" );
standardThermochemistry
{
    dHf_298   -539210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166520.0
}
