/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl anthranilate  (C13H11NO2, CAS 10268-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylAnthranilate;
formula     C13H11NO2;
CAS         10268-69-6;
InChIKey    ZBFSYQBEXZGTAX-UHFFFAOYSA-N;
MW          213.236;      // g/mol [origin=calculated method=formula-sum]
Tc          938.97;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.7687;      // -   [origin=predictive method=lee-kesler]
Tb          686.13;      // K   [origin=predictive method=joback]
HvapTb      67794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.54 1.0286 -0.00062756 1.235e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl 2-azanylbenzoate" "phenyl 2-aminobenzoate" "benzoic acid, 2-amino-, phenyl ester" "benzoic acid, 2-amino-,phenyl ester" );
gibbsFormation
{
    dHf_298   -133550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29850.0
    phase     gas;
}
