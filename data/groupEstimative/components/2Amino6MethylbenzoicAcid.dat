/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-amino-6-methylbenzoic acid  (C8H9NO2, CAS 4389-50-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Amino6MethylbenzoicAcid;
formula     C8H9NO2;
CAS         4389-50-8;
InChIKey    XHYVBIXKORFHFM-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          875.08;      // K   [origin=predictive method=joback]
Pc          42.220;      // bar [origin=predictive method=joback]
omega       0.8812;      // -   [origin=predictive method=lee-kesler]
Tb          637.32;      // K   [origin=predictive method=joback]
HvapTb      64807.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.4 0.67862 -0.00042452 9.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-6-methyl-benzoic acid" "6-methylanthranilic acid" "6-amino-o-toluic acid" "6-methylanthranilate" "3-amino-2-carboxytoluene" "2-carboxy-3-methylaniline" "6-amino-2-methylbenzoic acid" "2-amino-6-methylbenzoic acid," "benzoic acid, 2-amino-6-methyl-" "amino(2-)-6-methylbenzoic acid" "6m1" );
standardThermochemistry
{
    dHf_298   -311340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167830.0
}
