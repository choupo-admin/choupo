/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-2-methyl-1,3-dioxolane  (C6H12O2, CAS 126-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl2Methyl13Dioxolane;
formula     C6H12O2;
CAS         126-39-6;
InChIKey    UPZFLZYXYGBAPL-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          612.40;      // K   [origin=predictive method=joback]
Pc          39.705;      // bar [origin=predictive method=joback]
omega       0.3357;      // -   [origin=predictive method=lee-kesler]
Tb          406.30;      // K   [origin=predictive method=joback]
HvapTb      37076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.399 0.99144 -0.0009348 3.803e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butanone, cyclic ethylene acetal" "ethyleneacetic acid" "2-ethyl-2-methyldioxolane" "2-methyl-2-ethyldioxolane" "1,3-dioxolane, 2-ethyl-2-methyl-" "2-methyl-2-ethyl-1,3-dioxolane" "2-butanone, cyclic 1,2-ethanediyl acetal" "1,3-dioxolane, ethylmethyl-" "2-butanone,2-ethanediyl acetal" "upzflzyxygbapl-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -355450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141540.0
    phase     gas;
}
