/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-morpholinopropanoate  (C8H15NO3, CAS 33611-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Morpholinopropanoate;
formula     C8H15NO3;
CAS         33611-43-7;
InChIKey    YMSLLIGKMYXCPK-UHFFFAOYSA-N;
MW          173.212;      // g/mol [origin=calculated method=formula-sum]
Tc          697.55;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.6314;      // -   [origin=predictive method=lee-kesler]
Tb          500.20;      // K   [origin=predictive method=joback]
HvapTb      47928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.768 0.98812 -0.0005983 1.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2COO; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-morpholin-4-ylpropanoate" "4-morpholinepropanoic acid, methyl ester" "methyl 3-(4-morpholinyl)propanoate" "methyl 3-(morpholin-4-yl)propanoate" "methyl 3-morpholinopropionate" "methyl 4-morpholinepropionate" "methyl-3-morpholinopropionate" "3-morpholin-4-yl-propionic acid methyl ester" "3-morpholinyl methyl propionate" "methyl 3-(n-morpholino)propionate" "methyl 3-(4-morpholinyl)propanoate;" "4-morpholinepropanoicacid, methyl ester" );
gibbsFormation
{
    dHf_298   -509380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224970.0
    phase     gas;
}
