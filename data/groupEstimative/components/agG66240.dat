/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-66240  (C28H59NO2, CAS 68833-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG66240;
formula     C28H59NO2;
CAS         68833-94-3;
InChIKey    PSMOHQSASCTISF-UHFFFAOYSA-N;
MW          441.785;      // g/mol [origin=calculated method=formula-sum]
Tc          1240.39;      // K   [origin=predictive method=joback]
Pc          6.551;      // bar [origin=predictive method=joback]
omega       0.4656;      // -   [origin=predictive method=lee-kesler]
Tb          999.59;      // K   [origin=predictive method=joback]
HvapTb      97423.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.163 2.63238 -0.0012698 1.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 22; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 23; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylethanamine;docosanoic acid" "docosanoic acid compd. with n,n-diethylethanamine (1:1)" "docosanoic acid, compd. with n,n-diethylethanamine (1:1)" "docosanoic acid, triethylamine salt" );
standardThermochemistry
{
    dHf_298   -1015610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1423.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153010.0
}
