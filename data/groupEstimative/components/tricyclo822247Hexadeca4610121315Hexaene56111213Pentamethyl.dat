/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(8.2.2.24,7)hexadeca-4,6,10,12,13,15-hexaene, 5,6,11,12,13-pentamethyl-  (C21H26, CAS 77897-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo822247Hexadeca4610121315Hexaene56111213Pentamethyl;
formula     C21H26;
CAS         77897-14-4;
InChIKey    ZGMIVDRCSDLWRF-UHFFFAOYSA-N;
MW          278.439;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.51;      // K   [origin=predictive method=joback]
Pc          16.142;      // bar [origin=predictive method=joback]
omega       0.7508;      // -   [origin=predictive method=lee-kesler]
Tb          783.98;      // K   [origin=predictive method=joback]
HvapTb      71920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.22 1.5924 -0.00094092 2.13e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 5; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[8.2.2.24,7]hexadeca-4,6,10,12,13,15-hexaene, 5,6,11,12,13-pentamethyl-" "2,3,5,5',6'-pentamethyl[2.2]paracyclophane" );
standardThermochemistry
{
    dHf_298   2980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=339710.0
}
