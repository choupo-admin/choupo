/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodobenzoic acid  (C7H5IO2, CAS 618-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3IodobenzoicAcid;
formula     C7H5IO2;
CAS         618-51-9;
InChIKey    KVBWBCRPWVKFQT-UHFFFAOYSA-N;
MW          248.015;      // g/mol [origin=calculated method=formula-sum]
Tc          894.42;      // K   [origin=predictive method=joback]
Pc          44.033;      // bar [origin=predictive method=joback]
omega       0.6758;      // -   [origin=predictive method=lee-kesler]
Tb          630.07;      // K   [origin=predictive method=joback]
HvapTb      60651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.79 0.6202 -0.00047516 1.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group COOH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanylbenzoic acid" "benzoic acid, 3-iodo-" "m-iodobenzoic acid" "3-iodo-benzoic acid" "benzoic acid, m-iodo-" "3-carboxyiodobenzene" "m-iodobenzioc acid" "benzoic acid, m-iodo- (8ci)" "618-51-9 3-iodobenzoic acid" "2532-18-5 (hydrochloride salt)" "benzoic acid, 3-iodo-;benzoic acid, m-iodo- (8ci);benzoic acid, m-iodo-;m-iodobenzoic acid;sodium 3-iodobenzoate;sodium m-iodobenzoate;" );
gibbsFormation
{
    dHf_298   -236150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174950.0
    phase     gas;
}
