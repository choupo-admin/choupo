/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-1-indanol  (C11H14O, CAS 38393-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl1Indanol;
formula     C11H14O;
CAS         38393-92-9;
InChIKey    JYSNWEPTBXFJSP-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          789.58;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.7942;      // -   [origin=predictive method=lee-kesler]
Tb          577.43;      // K   [origin=predictive method=joback]
HvapTb      58150.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.72 1.36074 -0.00126656 4.992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethyl-1,2-dihydroinden-1-ol" "1-indanol, 3,3-dimethyl-" "1h-inden-1-ol, 2,3-dihydro-3,3-dimethyl-" "1h-inden-1-ol,2,3-dihydro-3,3-dimethyl-" "1-indanol,3,3-dimethyl- (7ci); 3,3-dimethyl-1-indanol" );
standardThermochemistry
{
    dHf_298   -129840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55250.0
}
