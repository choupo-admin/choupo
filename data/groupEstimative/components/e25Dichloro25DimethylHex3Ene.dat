/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-2,5-dichloro-2,5-dimethyl-hex-3-ene  (C8H14Cl2, CAS 22966-70-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e25Dichloro25DimethylHex3Ene;
formula     C8H14Cl2;
CAS         22966-70-7;
InChIKey    ANSLDRRWTXDPKO-UHFFFAOYSA-N;
MW          181.1;      // g/mol [origin=calculated method=formula-sum]
Tc          666.55;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.2935;      // -   [origin=predictive method=lee-kesler]
Tb          455.20;      // K   [origin=predictive method=joback]
HvapTb      39538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.73 1.04908 -0.0008796 2.932e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(chloranyl)-2,5-dimethyl-hex-3-ene" "(e)-2, 5-dichloro-2, 5-dimethyl-hex-3-ene" "trans-2, 5-dichloror-2, 5-dimethyl-3-hexene;" );
gibbsFormation
{
    dHf_298   -140210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78520.0
    phase     gas;
}
