/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-delta4-tetrahydrophthalic acid  (C8H10O4, CAS 2305-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cisDelta4TetrahydrophthalicAcid;
formula     C8H10O4;
CAS         2305-26-2;
InChIKey    ILUAAIDVFMVTAU-OLQVQODUSA-N;
MW          170.164;      // g/mol [origin=calculated method=formula-sum]
Tc          920.16;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       1.0501;      // -   [origin=predictive method=lee-kesler]
Tb          687.70;      // K   [origin=predictive method=joback]
HvapTb      68142.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.07 0.905 -0.00056948 1.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s)-cyclohex-4-ene-1,2-dicarboxylic acid" "cis-4-cyclohexene-1,2-dicarboxylic acid" "(1r,2s)-rel-cyclohex-4-ene-1,2-dicarboxylic acid" "4-cyclohexene-1,2-dicarboxylicacid, cis- (8ci);1-cyclohexene-4,5-cis-dicarboxylic acid;cis-4-cyclohexene-1,2-dicarboxylic acid;cis-cyclohexene-4,5-dicarboxylic acid;cis-d4-cyclohexene-1,2-dicarboxylicacid;cis-d4-tetrahydrophthalic acid;" );
gibbsFormation
{
    dHf_298   -817230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-624640.0
    phase     gas;
}
