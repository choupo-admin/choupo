/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-hexylethylenediamine  (C8H20N2, CAS 7261-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nHexylethylenediamine;
formula     C8H20N2;
CAS         7261-70-3;
InChIKey    ADKFRZBUXRKWDL-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          685.57;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.7389;      // -   [origin=predictive method=lee-kesler]
Tb          505.34;      // K   [origin=predictive method=joback]
HvapTb      50479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.897 0.90192 -0.0005034 1.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-hexylethane-1,2-diamine" "(2-aminoethyl)hexylamine" "n-hexylethyl enediamine" "(2-aminoethyl)(hexyl)amine" "n-hexyl-ethylene-1,2-diamine" );
gibbsFormation
{
    dHf_298   -121190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172320.0
    phase     gas;
}
