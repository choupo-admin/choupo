/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylsilatrane  (C7H15NO3Si, CAS 2288-13-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H15NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methylsilatrane;
formula     C7H15NO3Si;
CAS         2288-13-3;
InChIKey    DZLQWMNVOBAZGC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          189.286;      // g/mol [origin=calculated method=formula-sum]
Tc          714.73;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.4584;      // -   [origin=predictive method=lee-kesler]
Tb          490.08;      // K   [origin=predictive method=joback]
HvapTb      48003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.11 0.90352 -0.0004251 3.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2O; count 3; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "1-methylsilatrane" "methylsilatran [german]" "1-methyl-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 1-methyl-" "1-methyl-2,8,9-trioxo-5-aza-1-silabicyclo(3.3.3)undecane" "methylsilatran" "1-methyl-2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane" );
standardThermochemistry
{
    dHf_298   -460100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143660.0
}
