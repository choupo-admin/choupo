/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropanecarboxamide  (C4H7NO, CAS 6228-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropanecarboxamide;
formula     C4H7NO;
CAS         6228-73-5;
InChIKey    AIMMVWOEOZMVMS-UHFFFAOYSA-N;
MW          85.106;      // g/mol [origin=calculated method=formula-sum]
Tc          636.78;      // K   [origin=predictive method=joback]
Pc          54.707;      // bar [origin=predictive method=joback]
omega       0.4682;      // -   [origin=predictive method=lee-kesler]
Tb          424.26;      // K   [origin=predictive method=joback]
HvapTb      41798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.14 0.5686 -0.0004387 1.3766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropylcarboxamide" "cyclopropyl carboxamide" "carbamoylcyclopropane" "cyclopropylcarboxamides" "(carbamoyl)cyclopropane" "cyclopropanecarboxylic acid amide" );
standardThermochemistry
{
    dHf_298   -131880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     299.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18920.0
}
