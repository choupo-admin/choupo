/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropanemethanol, 1-methyl-2-((1,2,2-trimethylbicyclo(3.1.0)hex-3-yl)methyl)-  (C15H26O, CAS 198404-98-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropanemethanol1Methyl2122Trimethylbicyclo310Hex3YlMeth;
formula     C15H26O;
CAS         198404-98-7;
InChIKey    OAKFACUIGQLOCA-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          842.86;      // K   [origin=predictive method=joback]
Pc          21.836;      // bar [origin=predictive method=joback]
omega       0.8644;      // -   [origin=predictive method=lee-kesler]
Tb          641.91;      // K   [origin=predictive method=joback]
HvapTb      61022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-288.338 2.71178 -0.0029148 1.2844e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 3; } { group C; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group C_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-methyl-2-[(1,2,2-trimethyl-3-bicyclo[3.1.0]hexanyl)methyl]cyclopropyl]methanol" "agn-pc-03kada" );
standardThermochemistry
{
    dHf_298   -302060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     601.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81250.0
}
