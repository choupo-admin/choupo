/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-o-methylserine  (C4H9NO3, CAS 32620-11-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lOMethylserine;
formula     C4H9NO3;
CAS         32620-11-4;
InChIKey    KNTFCRCCPLEUQZ-VKHMYHEASA-N;
MW          119.12;      // g/mol [origin=calculated method=formula-sum]
Tc          738.82;      // K   [origin=predictive method=joback]
Pc          46.593;      // bar [origin=predictive method=joback]
omega       0.8354;      // -   [origin=predictive method=lee-kesler]
Tb          531.14;      // K   [origin=predictive method=joback]
HvapTb      54325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.161 0.43922 -0.000202 2.01e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3O; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-3-methoxy-propanoic acid" "(s)-2-amino-3-methoxypropanoic acid" "o-methyl-l-serine" "serine, o-methyl-" "dl-serine, o-methyl-" "o-methyl-l-ser" "(2s)-2-amino-3-methoxypropanoic acid" );
standardThermochemistry
{
    dHf_298   -579870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-402100.0
}
