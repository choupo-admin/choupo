/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethylsiletane  (C5H12Si, CAS 2295-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H12Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11Dimethylsiletane;
formula     C5H12Si;
CAS         2295-12-7;
InChIKey    YQQFFTNDQFUNHB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          100.236;      // g/mol [origin=calculated method=formula-sum]
Tc          513.23;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.1620;      // -   [origin=predictive method=lee-kesler]
Tb          326.81;      // K   [origin=predictive method=joback]
HvapTb      27240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.02 0.45004 -0.000109 -4.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "silacyclobutane, 1,1-dimethyl-" "1,1-dimethylsilacyclobutane" "dimethyltrimethylenesilane" "1,1-dimethyl-1-silacyclobutane" "cyclotrimethylenedimethylsilane" "silacyclobutane,1,1-dimethyl-" );
standardThermochemistry
{
    dHf_298   -165010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45080.0
}
