/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,9,12-octadecatrienoic acid, methyl ester, (6z,9z,12e)-  (C19H32O2, CAS 132029-16-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6912OctadecatrienoicAcidMethylEster6z9z12e;
formula     C19H32O2;
CAS         132029-16-4;
InChIKey    JFRWATCOFCPIBM-UHFFFAOYSA-N;
MW          292.463;      // g/mol [origin=calculated method=formula-sum]
Tc          884.30;      // K   [origin=predictive method=joback]
Pc          12.048;      // bar [origin=predictive method=joback]
omega       0.8659;      // -   [origin=predictive method=lee-kesler]
Tb          705.02;      // K   [origin=predictive method=joback]
HvapTb      65169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.52 1.81404 -0.0011666 3e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH=CH; count 3; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl octadeca-6,9,12-trienoate" "methyl .gamma.-linolenate" "6,9,12-octadecatrienoicacid, methyl ester, (6z,9z,12z)-" "6,9,12-octadecatrienoicacid, methyl ester, (z,z,z)-; g-linolenic acid, methyl ester (7ci,8ci); methyl all-cis-6,9,12-octadecatrienoate;methyl octadeca-6,9,12-trienoate; methyl g-linolenate" );
gibbsFormation
{
    dHf_298   -401110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     927.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39390.0
    phase     gas;
}
