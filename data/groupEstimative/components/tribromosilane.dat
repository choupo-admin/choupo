/*--------------------------------*- Choupo -*-----------------------*\
  Component: tribromosilane  (Br3Si, CAS 7789-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula Br3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tribromosilane;
formula     Br3Si;
CAS         7789-57-3;
InChIKey    KRCZLPQTJDWPKN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          267.797;      // g/mol [origin=calculated method=formula-sum]
Tc          642.25;      // K   [origin=predictive method=joback]
Pc          84.633;      // bar [origin=predictive method=joback]
omega       0.3244;      // -   [origin=predictive method=lee-kesler]
Tb          398.78;      // K   [origin=predictive method=joback]
HvapTb      35046.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.87 0.0153 1.7e-05 -1.75e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(bromanyl)silicon" "silane, tribromo-" "tribromosilicon" "sibr3" "silicobromoform" "tribromosilyl" "tribromomonosilane" );
gibbsFormation
{
    dHf_298   -20150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-60300.0
    phase     gas;
}
