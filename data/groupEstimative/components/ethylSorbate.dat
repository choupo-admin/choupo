/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl sorbate  (C8H12O2, CAS 2396-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylSorbate;
formula     C8H12O2;
CAS         2396-84-1;
InChIKey    OZZYKXXGCOLLLO-TWTPFVCWSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          637.94;      // K   [origin=predictive method=joback]
Pc          28.384;      // bar [origin=predictive method=joback]
omega       0.4777;      // -   [origin=predictive method=lee-kesler]
Tb          449.18;      // K   [origin=predictive method=joback]
HvapTb      40725.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.339 0.74904 -0.0004844 1.217e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (2e,4e)-hexa-2,4-dienoate" "sorbic acid, ethyl ester" "ethyl hexa-2,4-dienoate" "ethyl 2,4-hexadienoate" "2,4-hexadienoic acid, ethyl ester" "ethyl (e,e)-2,4-hexadienoate" "ethyl (2e,4e)-2,4-hexadienoate" "ethyl 2,4-hexadienoate, (e,e)-" "2,4-hexadienoic acid, ethyl ester, (e,e)-" "2,4-hexadienoic acid, ethyl ester, (e,e)-)" "2,4-hexadienoic acid, ethyl ester, (2e,4e)-" "ethyl trans,trans-2,4-hexadienoate" );
standardThermochemistry
{
    dHf_298   -291290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133450.0
}
