/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-7-methylindan  (C10H11Cl, CAS 2216-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro7Methylindan;
formula     C10H11Cl;
CAS         2216-63-9;
InChIKey    NTFHYNQQJUEULI-UHFFFAOYSA-N;
MW          166.648;      // g/mol [origin=calculated method=formula-sum]
Tc          750.58;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.4367;      // -   [origin=predictive method=lee-kesler]
Tb          518.86;      // K   [origin=predictive method=joback]
HvapTb      46723.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.5 0.88062 -0.00064628 1.951e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group ACCH3; count 1; } { group ACCH2; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-7-methyl-2,3-dihydro-1h-indene" "4-chloro-7-methylindane" "1h-indene, 4-chloro-2,3-dihydro-7-methyl-" "indan,4-chloro-7-methyl- (4ci)" "4-chloro-7-methyl-2,3-dihydro-1h-indene" "1h-indene,4-chloro-2,3-dihydro-7-methyl-" );
standardThermochemistry
{
    dHf_298   29790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173370.0
}
