/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiazolidine, 2-nonyl-  (C12H25NS, CAS 116112-94-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiazolidine2Nonyl;
formula     C12H25NS;
CAS         116112-94-8;
InChIKey    DOTWLKBBHRRWHT-UHFFFAOYSA-N;
MW          215.399;      // g/mol [origin=calculated method=formula-sum]
Tc          787.55;      // K   [origin=predictive method=joback]
Pc          21.217;      // bar [origin=predictive method=joback]
omega       0.6656;      // -   [origin=predictive method=lee-kesler]
Tb          585.82;      // K   [origin=predictive method=joback]
HvapTb      55133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.762 1.27653 -0.0007145 1.47e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-nonyl-1,3-thiazolidine" "2-nonylthiazolidine" );
standardThermochemistry
{
    dHf_298   -147460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214280.0
}
