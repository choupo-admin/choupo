/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-n-methylaniline  (C14H15N, CAS 614-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzylNMethylaniline;
formula     C14H15N;
CAS         614-30-2;
InChIKey    LXZGVFCKZRHKMU-UHFFFAOYSA-N;
MW          197.281;      // g/mol [origin=calculated method=formula-sum]
Tc          821.35;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.5352;      // -   [origin=predictive method=lee-kesler]
Tb          585.72;      // K   [origin=predictive method=joback]
HvapTb      53353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.339 1.29992 -0.0009128 2.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-n-(phenylmethyl)aniline" "n-methyl-n-benzylaniline" "benzenemethanamine, n-methyl-n-phenyl-" "n-methyl-n-phenylbenzylamine" "methylphenylbenzylamine" "benzyl-methyl-phenyl-amine" "n-benzyl-n-methyl aniline" "n-methyl-n-benzyl-aniline" "benzylamine, n-methyl-n-phenyl-" "benzylamine, n-methyl-n-phenyl- (8ci)" );
standardThermochemistry
{
    dHf_298   208300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=402600.0
}
