/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexakis(1-methylpropoxy)cyclotrisiloxane  (C24H54O9Si3, CAS 70788-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C24H54O9Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexakis1MethylpropoxyCyclotrisiloxane;
formula     C24H54O9Si3;
CAS         70788-47-5;
InChIKey    NEUCMSHRXYCZFK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          570.942;      // g/mol [origin=calculated method=formula-sum]
Tc          1197.40;      // K   [origin=predictive method=joback]
Pc          6.925;      // bar [origin=predictive method=joback]
omega       0.6242;      // -   [origin=predictive method=lee-kesler]
Tb          977.06;      // K   [origin=predictive method=joback]
HvapTb      95784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (242.216 1.49004 0.0003755 -6.076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group CH2; count 6; } { group CH-O; count 6; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 6; } { group CH; count 6; } { group O; count 6; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6-hexa(butan-2-yloxy)-1,3,5,2,4,6-trioxatrisilinane" "cyclotrisiloxane, hexakis(1-methylpropoxy)-" "cyclotrisiloxane, 2,2,4,4,6,6-hexakis(1-methylpropoxy)-" );
gibbsFormation
{
    dHf_298   -2001410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1278.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-997620.0
    phase     gas;
}
