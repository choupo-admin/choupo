/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-furanone,5-(1,1-dimethylethyl)-  (C8H12O2, CAS 19918-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hFuranone511Dimethylethyl;
formula     C8H12O2;
CAS         19918-17-3;
InChIKey    QYZLNRIZJWZODV-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          654.63;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.4381;      // -   [origin=predictive method=lee-kesler]
Tb          453.18;      // K   [origin=predictive method=joback]
HvapTb      40689.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.55 0.89676 -0.00068444 2.056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-tert-butyl-3h-furan-2-one" "2(3h)-furanone, 5-(1,1-dimethylethyl)-" "2(3h)-furanone,5-tert-butyl- (8ci); 5-tert-butyl-2(3h)-furanone" );
gibbsFormation
{
    dHf_298   -395030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202260.0
    phase     gas;
}
