/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-tetradecanediol  (C14H30O2, CAS 25430-48-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Tetradecanediol;
formula     C14H30O2;
CAS         25430-48-2;
InChIKey    GPBDHSIJWBKDLE-UHFFFAOYSA-N;
MW          230.392;      // g/mol [origin=calculated method=formula-sum]
Tc          868.00;      // K   [origin=predictive method=joback]
Pc          17.803;      // bar [origin=predictive method=joback]
omega       1.3898;      // -   [origin=predictive method=lee-kesler]
Tb          703.84;      // K   [origin=predictive method=joback]
HvapTb      79728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.938 1.40772 -0.0008018 1.745e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecane-1,4-diol" );
standardThermochemistry
{
    dHf_298   -642030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     793.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209080.0
}
