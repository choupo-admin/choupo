/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminopropyltriethoxysilane  (C9H23NO3Si, CAS 919-30-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H23NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Aminopropyltriethoxysilane;
formula     C9H23NO3Si;
CAS         919-30-2;
InChIKey    WYTZZXDRDKSJID-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          221.372;      // g/mol [origin=calculated method=formula-sum]
Tc          725.80;      // K   [origin=predictive method=joback]
Pc          20.736;      // bar [origin=predictive method=joback]
omega       0.7442;      // -   [origin=predictive method=lee-kesler]
Tb          546.71;      // K   [origin=predictive method=joback]
HvapTb      53793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (118.516 0.52496 0.0002386 -2.747e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2O; count 3; } { group CH2NH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group O; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-triethoxysilylpropan-1-amine" "(3-aminopropyl)triethoxysilane" "aptes" "1-propanamine, 3-(triethoxysilyl)-" "propylamine, 3-(triethoxysilyl)-" "3-(triethoxysilyl)propan-1-amine" "3-triethoxysilylpropylamine" "silane amg-9" "agm-9" "triethoxy(3-aminopropyl)silane" "gamma-aminopropyltriethoxysilane" "3-(triethoxysilyl)-1-propanamine" );
standardThermochemistry
{
    dHf_298   -703580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-328410.0
}
