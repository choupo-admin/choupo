/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaerythritol  (C5H12O4, CAS 115-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaerythritol;
formula     C5H12O4;
CAS         115-77-5;
InChIKey    WXZMFSXDPGVJKK-UHFFFAOYSA-N;
MW          136.147;      // g/mol [origin=calculated method=formula-sum]
Tc          843.01;      // K   [origin=predictive method=joback]
Pc          58.183;      // bar [origin=predictive method=joback]
omega       2.3082;      // -   [origin=predictive method=lee-kesler]
Tb          679.49;      // K   [origin=predictive method=joback]
HvapTb      92144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.966 0.7406 -0.0005416 1.594e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group OH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group C; count 1; } { group OH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol" "pentek" "pentaerythrite" "auxinutril" "maxinutril" "monopentek" "penetek" "metab-auxil" "hercules p6" "1,3-propanediol, 2,2-bis(hydroxymethyl)-" "tetramethylolmethane" "methane tetramethylol" );
gibbsFormation
{
    dHf_298   -764200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-553220.0
    phase     gas;
}
