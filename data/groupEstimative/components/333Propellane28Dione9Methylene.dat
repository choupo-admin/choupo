/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3.3.3]propellane-2,8-dione, 9-methylene-  (C12H14O2, CAS 112112-58-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        333Propellane28Dione9Methylene;
formula     C12H14O2;
CAS         112112-58-0;
InChIKey    XOUFDVRLVGVXSP-UHFFFAOYSA-N;
MW          190.242;      // g/mol [origin=calculated method=formula-sum]
Tc          909.57;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.5778;      // -   [origin=predictive method=lee-kesler]
Tb          642.87;      // K   [origin=predictive method=joback]
HvapTb      49049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.76 1.7335 -0.001737 7.388e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 2; } { group CH2=C; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 6; } { group C_ring; count 2; } { group dC_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3.3.3)-propellane-2,8-dione, 9-methylene-" );
standardThermochemistry
{
    dHf_298   -225270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12840.0
}
