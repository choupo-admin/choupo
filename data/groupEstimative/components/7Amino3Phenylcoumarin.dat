/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-amino-3-phenylcoumarin  (C15H11NO2, CAS 4108-61-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Amino3Phenylcoumarin;
formula     C15H11NO2;
CAS         4108-61-6;
InChIKey    IJCLOOKYCQWSJA-UHFFFAOYSA-N;
MW          237.258;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.96;      // K   [origin=predictive method=joback]
Pc          30.693;      // bar [origin=predictive method=joback]
omega       0.9040;      // -   [origin=predictive method=lee-kesler]
Tb          748.15;      // K   [origin=predictive method=joback]
HvapTb      73912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.04 1.2306 -0.00091156 2.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 5; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-azanyl-3-phenyl-chromen-2-one" "2h-1-benzopyran-2-one, 7-amino-3-phenyl-" "7-amino-3-phenyl-2-benzopyrone" "7-amino-3-phenylchromen-2-one" "7-amino-3-phenyl-2h-chromen-2-one" "2h-1-benzopyran-2-one,7-amino-3-phenyl-;2h-1-benzopyran-2-one, 7-amino-3-phenyl-;7-amino-3-phenyl-chromen-2-one;coumarin 10;" );
gibbsFormation
{
    dHf_298   -40690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137950.0
    phase     gas;
}
