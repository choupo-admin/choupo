/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-bis(2-methoxystyryl)biphenyl  (C30H26O2, CAS 40470-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Bis2MethoxystyrylBiphenyl;
formula     C30H26O2;
CAS         40470-68-6;
InChIKey    HZAWHDJKNZWAAR-UHFFFAOYSA-N;
MW          418.536;      // g/mol [origin=calculated method=formula-sum]
Tc          1329.67;      // K   [origin=predictive method=joback]
Pc          13.090;      // bar [origin=predictive method=joback]
omega       0.9886;      // -   [origin=predictive method=lee-kesler]
Tb          1065.80;      // K   [origin=predictive method=joback]
HvapTb      98862.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.17 2.21384 -0.00141044 3.334e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group ACH; count 16; } { group AC; count 8; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 4; } { group dCH_ring; count 16; } { group dC_ring; count 8; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-[2-[4-[4-[2-(2-methoxyphenyl)ethenyl]phenyl]phenyl]ethenyl]benzene" "1,1'-biphenyl, 4,4'-bis[2-(2-methoxyphenyl)ethenyl]-" "1,1'-biphenyl,4,4'-bis[2-(2-methoxyphenyl)ethenyl]-" "4,4'-bis(2-methoxystyryl)-1,1'-biphenyl;4,4'-bis(2-methoxystyryl)biphenyl;4,4'-bis(2-methoxystyryl)diphenyl;4,4'-bis[2-(2-methoxyphenyl)ethenyl]-1,1'-biphenyl;uvitex 127;uvitex fp;" );
standardThermochemistry
{
    dHf_298   207710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     883.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=563280.0
}
