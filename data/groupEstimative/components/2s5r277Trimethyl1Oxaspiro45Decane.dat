/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,5r)-2,7,7-trimethyl-1-oxaspiro[4.5]decane  (C12H22O, CAS 73347-75-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s5r277Trimethyl1Oxaspiro45Decane;
formula     C12H22O;
CAS         73347-75-8;
InChIKey    XWTYXXORTSUIMC-CMPLNLGQSA-N;
MW          182.307;      // g/mol [origin=calculated method=formula-sum]
Tc          759.57;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.3707;      // -   [origin=predictive method=lee-kesler]
Tb          527.48;      // K   [origin=predictive method=joback]
HvapTb      44719.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-205.71 1.96156 -0.0018797 7.697e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group C; count 2; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-6-methylene-2,10,10-trimethyl-1-oxaspiro(4.5)decane" "(3s,5r)-3,9,9-trimethyl-4-oxaspiro[4.5]decane" );
gibbsFormation
{
    dHf_298   -291910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18450.0
    phase     gas;
}
