/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,8-cyclododecadien-1-ol, acetate  (C14H22O2, CAS 67923-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        48Cyclododecadien1OlAcetate;
formula     C14H22O2;
CAS         67923-54-0;
InChIKey    SNNVDGLEOWNXND-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          859.08;      // K   [origin=predictive method=joback]
Pc          22.041;      // bar [origin=predictive method=joback]
omega       0.5097;      // -   [origin=predictive method=lee-kesler]
Tb          621.63;      // K   [origin=predictive method=joback]
HvapTb      56210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.2 1.23152 -0.00042036 -6.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CH=CH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclododeca-4,8-dien-1-yl ethanoate" "4,8-cyclododecadien-1-ol, 1-acetate" "[(4z,8z)-cyclododeca-4,8-dien-1-yl] acetate" );
gibbsFormation
{
    dHf_298   -516650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     766.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-231600.0
    phase     gas;
}
