/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibromoacetylene  (C2Br2, CAS 624-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibromoacetylene;
formula     C2Br2;
CAS         624-61-3;
InChIKey    JNFBOWNNNAHVNZ-UHFFFAOYSA-N;
MW          183.83;      // g/mol [origin=calculated method=formula-sum]
Tc          631.22;      // K   [origin=predictive method=joback]
Pc          80.871;      // bar [origin=predictive method=joback]
omega       0.2667;      // -   [origin=predictive method=lee-kesler]
Tb          386.68;      // K   [origin=predictive method=joback]
HvapTb      35068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.01 0.1204 -0.00013566 5.978e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)ethyne" "brc.equiv.cbr" "1,2-dibromoethyne" "acetylene, dibromo-" "dibromoacetylene [forbidden]" );
standardThermochemistry
{
    dHf_298   240350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197400.0
}
