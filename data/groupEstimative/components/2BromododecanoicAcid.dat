/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromododecanoic acid  (C12H23BrO2, CAS 111-56-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromododecanoicAcid;
formula     C12H23BrO2;
CAS         111-56-8;
InChIKey    HXKXBCBZXXQPPD-UHFFFAOYSA-N;
MW          279.218;      // g/mol [origin=calculated method=formula-sum]
Tc          877.70;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       1.0583;      // -   [origin=predictive method=lee-kesler]
Tb          685.39;      // K   [origin=predictive method=joback]
HvapTb      65517.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.089 1.23872 -0.0007762 1.932e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyldodecanoic acid" "2-bromolauric acid" "dodecanoic acid, 2-bromo-" "2-bromo-dodecanoic acid" "2-bromododecanoate" "alpha-bromolauric" ".alpha.-bromolauric" "alpha-bromolauric acid" ".alpha.-bromolauric acid" "dodecanoic acid,2-bromo-" );
standardThermochemistry
{
    dHf_298   -620230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281870.0
}
