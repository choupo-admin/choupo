/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,7-diethoxy-1,2,3,4-tetrahydroisoquinoline-1acetic acid  (C15H21NO4, CAS 336185-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        67Diethoxy1234Tetrahydroisoquinoline1aceticAcid;
formula     C15H21NO4;
CAS         336185-23-0;
InChIKey    CPQONAPPQKFDJS-UHFFFAOYSA-N;
MW          279.336;      // g/mol [origin=calculated method=formula-sum]
Tc          1057.16;      // K   [origin=predictive method=joback]
Pc          21.897;      // bar [origin=predictive method=joback]
omega       1.2182;      // -   [origin=predictive method=lee-kesler]
Tb          834.33;      // K   [origin=predictive method=joback]
HvapTb      82073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.403 1.22374 -0.00058608 7.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2O; count 2; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(6,7-diethoxy-1,2,3,4-tetrahydroisoquinolin-1-yl)ethanoic acid" "6,7-diethoxy-1,2,3,4-tetrahydroisoquinoline-1-acetic acid" "2-(6,7-diethoxy-1,2,3,4-tetrahydroisoquinolin-1-yl)acetic acid" "(6,7-diethoxy-1,2,3,4-tetrahydro-isoquinolin-1-yl)-acetic acid" "2-(6,7-diethoxy-1,2,3,4-tetrahydroisoquinolyl)acetic acid" "aa050" );
gibbsFormation
{
    dHf_298   -661070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258610.0
    phase     gas;
}
