/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluoro-4-methoxyphenylacetic acid  (C9H9FO3, CAS 452-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Fluoro4MethoxyphenylaceticAcid;
formula     C9H9FO3;
CAS         452-14-2;
InChIKey    VURNBRZIFABCRU-UHFFFAOYSA-N;
MW          184.166;      // g/mol [origin=calculated method=formula-sum]
Tc          822.15;      // K   [origin=predictive method=joback]
Pc          32.504;      // bar [origin=predictive method=joback]
omega       0.8769;      // -   [origin=predictive method=lee-kesler]
Tb          609.36;      // K   [origin=predictive method=joback]
HvapTb      57985.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.591 0.66032 -0.00034092 5.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-fluoranyl-4-methoxy-phenyl)ethanoic acid" "2-(3-fluoro-4-methoxyphenyl)acetic acid" "(3-fluoro-4-methoxyphenyl)acetic acid" "3-fluoro-4-methoxyphenylaceticacid" "(3-fluoro-4-methoxy-phenyl)-acetic acid" "452-14-2 3-fluoro-4-methoxyphenylacetic acid" "aceticacid, (3-fluoro-4-methoxyphenyl)- (8ci);(3-fluoro-4-methoxyphenyl)acetic acid;3-fluoro-4-methoxybenzeneacetic acid;(3-fluoro-4-methoxyphenyl)acetic acid;3-fluoro-4-methoxyphenylacetic acid;benzeneacetic acid, 3-fluoro-4-methoxy-;" );
gibbsFormation
{
    dHf_298   -694100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-525670.0
    phase     gas;
}
