/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclizine  (C18H22N2, CAS 82-92-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclizine;
formula     C18H22N2;
CAS         82-92-8;
InChIKey    UVKZSORBKUEBAZ-UHFFFAOYSA-N;
MW          266.388;      // g/mol [origin=calculated method=formula-sum]
Tc          945.95;      // K   [origin=predictive method=joback]
Pc          22.849;      // bar [origin=predictive method=joback]
omega       0.7204;      // -   [origin=predictive method=lee-kesler]
Tb          704.92;      // K   [origin=predictive method=joback]
HvapTb      64306.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.65 1.97752 -0.0014754 4.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(diphenylmethyl)-4-methyl-piperazine" "marezine" "ciclizina" "nautazine" "valoid" "neo-devomit" "cyclizinum" "emoquil" "1-benzhydryl-4-methylpiperazine" "wellcome" "n-benzhydryl-n'-methylpiperazine" "n-methyl-n'-benzhydrylpiperazine" );
standardThermochemistry
{
    dHf_298   274970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=600980.0
}
