/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-diphenylpropane  (C15H16, CAS 5814-85-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Diphenylpropane;
formula     C15H16;
CAS         5814-85-7;
InChIKey    XLWCIHPMASUXPI-UHFFFAOYSA-N;
MW          196.293;      // g/mol [origin=calculated method=formula-sum]
Tc          835.75;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.4913;      // -   [origin=predictive method=lee-kesler]
Tb          595.72;      // K   [origin=predictive method=joback]
HvapTb      53148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.239 1.27692 -0.0008578 2.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylpropan-2-ylbenzene" "bibenzyl, .alpha.-methyl-" "alpha-methyl bibenzyl" "benzene, 1,1'-(1-methyl-1,2-ethanediyl)bis-" "(1-methyl-2-phenylethyl)benzene" "propane,2-diphenyl-" ".alpha.-methylbibenzyl" ".alpha.,.beta.-diphenylpropane" "(1-methyl-2-phenyl-ethyl)-benzene" "benzene,1'-(1-methyl-1,2-ethanediyl)bis-" "benzene,1,1'-(1-methyl-1,2-ethanediyl)bis-" );
gibbsFormation
{
    dHf_298   114850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=297800.0
    phase     gas;
}
