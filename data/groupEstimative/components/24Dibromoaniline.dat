/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dibromoaniline  (C6H5Br2N, CAS 615-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dibromoaniline;
formula     C6H5Br2N;
CAS         615-57-6;
InChIKey    DYSRXWYRUJCNFI-UHFFFAOYSA-N;
MW          250.921;      // g/mol [origin=calculated method=formula-sum]
Tc          845.28;      // K   [origin=predictive method=joback]
Pc          59.354;      // bar [origin=predictive method=joback]
omega       0.6329;      // -   [origin=predictive method=lee-kesler]
Tb          578.37;      // K   [origin=predictive method=joback]
HvapTb      56061.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.0 0.5142 -0.00038592 1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(bromanyl)aniline" "benzenamine, 2,4-dibromo-" "2,4-dibromobenzenamine" "dibromobenzenamine" "2,4-dibromophenylamine" "benzenamine,4-dibromo-" "agn-pc-0dbduu" "2,4-dibromo-phenylamine" "615-57-6 2,4-dibromoaniline" "h254" "2,4-dibromocyclohexa-1,3,5-trien-1-amine" );
gibbsFormation
{
    dHf_298   132870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=187880.0
    phase     gas;
}
