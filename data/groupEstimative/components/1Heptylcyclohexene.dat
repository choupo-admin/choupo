/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-heptylcyclohexene  (C13H24, CAS 15232-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Heptylcyclohexene;
formula     C13H24;
CAS         15232-86-7;
InChIKey    XDUFGMTUKHRHSO-UHFFFAOYSA-N;
MW          180.335;      // g/mol [origin=calculated method=formula-sum]
Tc          718.50;      // K   [origin=predictive method=joback]
Pc          20.530;      // bar [origin=predictive method=joback]
omega       0.5361;      // -   [origin=predictive method=lee-kesler]
Tb          525.40;      // K   [origin=predictive method=joback]
HvapTb      46224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.394 1.27192 -0.00074004 1.606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexene,1-heptyl-" "cyclohexene, 1-heptyl-" );
standardThermochemistry
{
    dHf_298   -190680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111070.0
}
