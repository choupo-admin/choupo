/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl laurate  (C13H25ClO2, CAS 61413-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethylLaurate;
formula     C13H25ClO2;
CAS         61413-67-0;
InChIKey    XCHDYWCWXAASER-UHFFFAOYSA-N;
MW          248.791;      // g/mol [origin=calculated method=formula-sum]
Tc          763.73;      // K   [origin=predictive method=joback]
Pc          16.026;      // bar [origin=predictive method=joback]
omega       0.8237;      // -   [origin=predictive method=lee-kesler]
Tb          592.69;      // K   [origin=predictive method=joback]
HvapTb      56324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.371 1.19082 -0.0006092 9.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl dodecanoate" "dodecanoic acid, chloromethyl ester" );
standardThermochemistry
{
    dHf_298   -644670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-263720.0
}
