/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl (2,5-dimethoxybenzylidene)malonate  (C16H20O6, CAS 7324-87-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl25DimethoxybenzylideneMalonate;
formula     C16H20O6;
CAS         7324-87-0;
InChIKey    SDKURJSMAYMSOF-UHFFFAOYSA-N;
MW          308.33;      // g/mol [origin=calculated method=formula-sum]
Tc          972.78;      // K   [origin=predictive method=joback]
Pc          17.075;      // bar [origin=predictive method=joback]
omega       1.0300;      // -   [origin=predictive method=lee-kesler]
Tb          767.64;      // K   [origin=predictive method=joback]
HvapTb      74482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.982 1.10988 -0.00041862 -1.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-[(2,5-dimethoxyphenyl)methylidene]propanedioate" "diethyl(2,5-dimethoxybenzylidene)malonate" "propanedioic acid, ((2,5-dimethoxyphenyl)methylene)-, diethyl ester" "propanedioic acid, [(2,5-dimethoxyphenyl)methylene]-, diethyl ester" "propanedioic acid, 2-((2,5-dimethoxyphenyl)methylene)-, 1,3-diethyl ester" "propanedioic acid, 2-[(2,5-dimethoxyphenyl)methylene]-, 1,3-diethyl ester" "diethyl 2,5-dimethoxybenzylidene-malonate" "diethyl 2-(2,5-dimethoxybenzylidene)malonate; diethyl 2,5-dimethoxybenzylidene-malonate" );
standardThermochemistry
{
    dHf_298   -951550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     774.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-582080.0
}
