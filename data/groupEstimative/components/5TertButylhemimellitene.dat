/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-tert-butylhemimellitene  (C13H20, CAS 98-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5TertButylhemimellitene;
formula     C13H20;
CAS         98-23-7;
InChIKey    ZQVJKYPEIPJEIP-UHFFFAOYSA-N;
MW          176.303;      // g/mol [origin=calculated method=formula-sum]
Tc          747.87;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       0.4363;      // -   [origin=predictive method=lee-kesler]
Tb          535.43;      // K   [origin=predictive method=joback]
HvapTb      47498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.41 1.10732 -0.00068528 1.662e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-tert-butyl-1,2,3-trimethyl-benzene" "5-tert-butyl-1,2,3-trimethylbenzene" "5-t-butyl-1,2,3-trimethylbenzene" "benzene, 5-(1,1-dimethylethyl)-1,2,3-trimethyl-" "5-(tert-butyl)-1,2,3-trimethylbenzene" "1-tert-butyl-3,4,5-trimethylbenzene" );
standardThermochemistry
{
    dHf_298   -118280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144940.0
}
