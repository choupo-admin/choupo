/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dodecyne  (C12H22, CAS 765-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dodecyne;
formula     C12H22;
CAS         765-03-7;
InChIKey    ZVDBUOGYYYNMQI-UHFFFAOYSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          635.47;      // K   [origin=predictive method=joback]
Pc          20.254;      // bar [origin=predictive method=joback]
omega       0.5237;      // -   [origin=predictive method=lee-kesler]
Tb          464.28;      // K   [origin=predictive method=joback]
HvapTb      42164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.759 1.04992 -0.00062493 1.4999e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-1-yne" "dodec-1-in" "1-c12h22" "decylacetylene;n-decylacetylene;dodec-1-yne;dodec-1-in;dodec-1-yne;decylacetylene;" );
standardThermochemistry
{
    dHf_298   890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=273230.0
}
