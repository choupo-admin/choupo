/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3-benzoyloxypropoxy)propyl 4-methylbenzoate  (C21H24O5, CAS 72138-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33BenzoyloxypropoxyPropyl4Methylbenzoate;
formula     C21H24O5;
CAS         72138-86-4;
InChIKey    KRNMACTUMUDNDH-UHFFFAOYSA-N;
MW          356.418;      // g/mol [origin=calculated method=formula-sum]
Tc          1095.09;      // K   [origin=predictive method=joback]
Pc          14.861;      // bar [origin=predictive method=joback]
omega       1.0859;      // -   [origin=predictive method=lee-kesler]
Tb          877.28;      // K   [origin=predictive method=joback]
HvapTb      84778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.606 1.60872 -0.00081376 9.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 9; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[3-(phenylcarbonyloxy)propoxy]propyl 4-methylbenzoate" "benzoic acid, 4-methyl-, 3-(3-(benzoyloxy)propoxy)propyl ester" "benzoic acid, 4-methyl-, 3-[3-(benzoyloxy)propoxy]propyl ester" "4-methylbenzoic acid 3-[3-(benzoyloxy)propoxy]propyl ester" );
gibbsFormation
{
    dHf_298   -781960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     868.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-384610.0
    phase     gas;
}
