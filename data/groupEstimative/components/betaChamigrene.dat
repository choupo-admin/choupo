/*--------------------------------*- Choupo -*-----------------------*\
  Component: .beta.-chamigrene  (C15H24, CAS 18431-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaChamigrene;
formula     C15H24;
CAS         18431-82-8;
InChIKey    WLNGPDPILFYWKF-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          816.56;      // K   [origin=predictive method=joback]
Pc          21.775;      // bar [origin=predictive method=joback]
omega       0.4154;      // -   [origin=predictive method=lee-kesler]
Tb          581.41;      // K   [origin=predictive method=joback]
HvapTb      48481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-192.45 2.03346 -0.00189364 7.626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group C; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group CH2_ring; count 6; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5,9-trimethyl-1-methylidene-spiro[5.5]undec-9-ene" "3,7,7-trimethyl-11-methylidenespiro[5.5]undec-2-ene" "spiro[5.5]undec-2-ene, 3,7,7-trimethyl-11-methylene-, (-)-" "3,11,11-trimethyl-7-methylidenespiro[5.5]undec-3-ene" "spiro[5.5]undec-2-ene, 3,7,7-trimethyl-11-methylene-" );
gibbsFormation
{
    dHf_298   -77100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198850.0
    phase     gas;
}
