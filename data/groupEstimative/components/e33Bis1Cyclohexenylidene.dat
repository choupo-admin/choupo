/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e) 3,3'-bis-(1-cyclohexenylidene)  (C12H16, CAS 132911-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e33Bis1Cyclohexenylidene;
formula     C12H16;
CAS         132911-34-3;
InChIKey    IMTIYIKRBGNQTQ-VAWYXSNFSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          772.19;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.3806;      // -   [origin=predictive method=lee-kesler]
Tb          530.04;      // K   [origin=predictive method=joback]
HvapTb      45982.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.17 1.154 -0.00072956 1.7e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH=CH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e)-3-cyclohex-2-en-1-ylidenecyclohexene" "(e)-3,3'-bis-(1-cyclohexenylidene)" );
standardThermochemistry
{
    dHf_298   8710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185100.0
}
