/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(chloromethyl)-1,2,4,5-tetramethylbenzene  (C11H15Cl, CAS 7435-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloromethyl1245Tetramethylbenzene;
formula     C11H15Cl;
CAS         7435-83-8;
InChIKey    UGAPPXGBBWAIGT-UHFFFAOYSA-N;
MW          182.691;      // g/mol [origin=calculated method=formula-sum]
Tc          747.31;      // K   [origin=predictive method=joback]
Pc          24.029;      // bar [origin=predictive method=joback]
omega       0.4942;      // -   [origin=predictive method=lee-kesler]
Tb          535.31;      // K   [origin=predictive method=joback]
HvapTb      49389.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.071 0.73878 -0.00035804 5.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group ACCH3; count 4; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(chloromethyl)-1,2,4,5-tetramethyl-benzene" "2,3,5,6-tetramethylbenzyl chloride" "benzene, 3-(chloromethyl)-1,2,4,5-tetramethyl-" "2,3,5,6-tetramethyl-benzyl chloride" "benzene,3-(chloromethyl)-1,2,4,5-tetramethyl-" );
gibbsFormation
{
    dHf_298   -95460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     486.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103700.0
    phase     gas;
}
