/*--------------------------------*- Choupo -*-----------------------*\
  Component: sec-icosylnaphthalene  (C30H48, CAS 135585-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        secIcosylnaphthalene;
formula     C30H48;
CAS         135585-40-9;
InChIKey    IIIXUNDSGHWXBK-UHFFFAOYSA-N;
MW          408.714;      // g/mol [origin=calculated method=formula-sum]
Tc          1146.54;      // K   [origin=predictive method=joback]
Pc          8.030;      // bar [origin=predictive method=joback]
omega       0.7652;      // -   [origin=predictive method=lee-kesler]
Tb          936.20;      // K   [origin=predictive method=joback]
HvapTb      86564.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.113 2.71764 -0.00171228 4.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-icosan-2-ylnaphthalene" "naphthalene, (1-methylnonadecyl)-" );
standardThermochemistry
{
    dHf_298   -251680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1093.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=408710.0
}
