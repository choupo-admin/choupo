/*--------------------------------*- Choupo -*-----------------------*\
  Component: adipic acid, fumaric acid, propylene glycol, diethylene glycol polymer  (C17H32O13, CAS 40798-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adipicAcidFumaricAcidPropyleneGlycolDiethyleneGlycolPolymer;
formula     C17H32O13;
CAS         40798-45-6;
InChIKey    GELJWTDLRUUGQP-WFNHHOHWSA-N;
MW          444.43;      // g/mol [origin=calculated method=formula-sum]
Tc          2317.51;      // K   [origin=predictive method=joback]
Pc          18.154;      // bar [origin=predictive method=joback]
omega       0.1261;      // -   [origin=predictive method=lee-kesler]
Tb          1569.66;      // K   [origin=predictive method=joback]
HvapTb      191670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (159.089 1.30212 -4.46e-05 -3.172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 3; } { group COOH; count 4; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 4; } { group O; count 1; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;hexanedioic acid;2-(2-hydroxyethyloxy)ethanol;propane-1,2-diol" "(e)-but-2-enedioic acid; hexanedioic acid; 2-(2-hydroxyethoxy)ethanol; propane-1,2-diol" "hexanedioic acid, polymer with (2e)-2-butenedioic acid, 2,2'-oxybis(ethanol) and 1,2-propanediol" );
gibbsFormation
{
    dHf_298   -2759350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1552.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2172160.0
    phase     gas;
}
