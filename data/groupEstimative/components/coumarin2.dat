/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin 2  (C13H15NO2, CAS 26078-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin2;
formula     C13H15NO2;
CAS         26078-25-1;
InChIKey    QZXAEJGHNXJTSE-UHFFFAOYSA-N;
MW          217.268;      // g/mol [origin=calculated method=formula-sum]
Tc          871.38;      // K   [origin=predictive method=joback]
Pc          24.925;      // bar [origin=predictive method=joback]
omega       0.8784;      // -   [origin=predictive method=lee-kesler]
Tb          658.33;      // K   [origin=predictive method=joback]
HvapTb      63641.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.719 1.07436 -0.00070972 1.844e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(ethylamino)-4,6-dimethyl-chromen-2-one" "4,6-dimethyl-7-(ethylamino)coumarin" "7-ethylamino-4,6-dimethyl coumarin" "2h-1-benzopyran-2-one, 7-(ethylamino)-4,6-dimethyl-" "7-(ethylamino)-4,6-dimethylchromen-2-one" "7-(ethylamino)-4,6-dimethyl-2h-chromen-2-one" "4,6-dimethyl-7-ethylamino coumarin" "4,6-dimethyl-7-ethylaminocoumarin" "7-ethylamino-4,6-dimethyl-chromen-2-one" "coumarin, 7-(ethylamino)-4,6-dimethyl-" "7-(ethylamino)-4,6-dimethyl-2-benzopyrone" "6-dimethyl-" );
standardThermochemistry
{
    dHf_298   -227730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22010.0
}
