/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-1,3-diethylbenzene  (C10H13Br, CAS 65232-57-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo13Diethylbenzene;
formula     C10H13Br;
CAS         65232-57-7;
InChIKey    FPWGIABDOFXETH-UHFFFAOYSA-N;
MW          213.118;      // g/mol [origin=calculated method=formula-sum]
Tc          754.43;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.5110;      // -   [origin=predictive method=lee-kesler]
Tb          531.20;      // K   [origin=predictive method=joback]
HvapTb      47889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.318 0.79414 -0.00048872 1.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-1,3-diethyl-benzene" "2,6-diethylbromobenzene" "1-bromo-2,6-diethylbenzene" "2,6-diethylphenylbromide" "benzene,2-bromo-1,3-diethyl-" "1-bromo-2,6-diethylbenzene;2,6-diethyl-1-bromobenzene; 2,6-diethylphenyl bromide;2-bromo-1,3-diethylbenzene" );
gibbsFormation
{
    dHf_298   -9810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140790.0
    phase     gas;
}
