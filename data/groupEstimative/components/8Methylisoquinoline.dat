/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methylisoquinoline  (C10H9N, CAS 62882-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methylisoquinoline;
formula     C10H9N;
CAS         62882-00-2;
InChIKey    IEZFKBBOGATCFW-UHFFFAOYSA-N;
MW          143.189;      // g/mol [origin=calculated method=formula-sum]
Tc          781.68;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.4399;      // -   [origin=predictive method=lee-kesler]
Tb          532.74;      // K   [origin=predictive method=joback]
HvapTb      48642.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.19 0.84548 -0.00063034 1.913e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "isoquinoline, 8-methyl-" );
standardThermochemistry
{
    dHf_298   199190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     336.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=319800.0
}
