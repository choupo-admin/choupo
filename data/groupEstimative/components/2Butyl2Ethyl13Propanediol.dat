/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyl-2-ethyl-1,3-propanediol  (C9H20O2, CAS 115-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyl2Ethyl13Propanediol;
formula     C9H20O2;
CAS         115-84-4;
InChIKey    DSKYSDCYIODJPC-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          749.99;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       1.3044;      // -   [origin=predictive method=lee-kesler]
Tb          586.65;      // K   [origin=predictive method=joback]
HvapTb      67690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.184 1.05264 -0.0006984 1.874e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butyl-2-ethyl-propane-1,3-diol" "2-ethyl-2-butyl-1,3-propanediol" "1,3-propanediol, 2-butyl-2-ethyl-" "3,3-bis(hydroxymethyl)heptane" "2-ethyl-2-butyl-1,3-propandeiol" "2-butyl-2-ethylpropanediol" "1, 2-butyl-2-ethyl-" "2-ethyl-2-butylpropanediol-1,3" "2-butyl-2-ethylpropane-1,3-diol" "1,3-propanediol,2-butyl-2-ethyl-" "2-ethyl-2-(hydroxymethyl)-1-hexanol" );
standardThermochemistry
{
    dHf_298   -542300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245900.0
}
