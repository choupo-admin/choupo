/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tritylaniline  (C25H21N, CAS 22948-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Tritylaniline;
formula     C25H21N;
CAS         22948-06-7;
InChIKey    XYHDHXBLSLSXSR-UHFFFAOYSA-N;
MW          335.45;      // g/mol [origin=calculated method=formula-sum]
Tc          1242.73;      // K   [origin=predictive method=joback]
Pc          20.055;      // bar [origin=predictive method=joback]
omega       0.8658;      // -   [origin=predictive method=lee-kesler]
Tb          952.60;      // K   [origin=predictive method=joback]
HvapTb      90355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-159.14 2.1914 -0.00160916 4.463e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 19; } { group AC; count 4; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 19; } { group dC_ring; count 5; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(triphenylmethyl)aniline" "p-tritylaniline" "p-aminotetraphenylmethane" "benzenamine, 4-(triphenylmethyl)-" "4-aminotetraphenylmethane" "4-(trityl)aniline" "triphenyl(p-aminophenyl)methane" "4-(triphenylmethyl)benzenamine" "p-toluidine, alpha,alpha,alpha-triphenyl-" "4-(triphenylmethyl)phenylamine" "p-tritylaniline;" "4-tritylbenzenamine" );
gibbsFormation
{
    dHf_298   400360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     710.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=668920.0
    phase     gas;
}
