/*--------------------------------*- Choupo -*-----------------------*\
  Component: terbufibrol  (C20H24O5, CAS 56488-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        terbufibrol;
formula     C20H24O5;
CAS         56488-59-6;
InChIKey    PXODZCMXOZRVEN-UHFFFAOYSA-N;
MW          344.407;      // g/mol [origin=calculated method=formula-sum]
Tc          1230.84;      // K   [origin=predictive method=joback]
Pc          18.388;      // bar [origin=predictive method=joback]
omega       1.4365;      // -   [origin=predictive method=lee-kesler]
Tb          999.38;      // K   [origin=predictive method=joback]
HvapTb      102969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.768 1.71716 -0.00104852 2.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 1; } { group COOH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[3-(4-tert-butylphenoxy)-2-oxidanyl-propoxy]benzoic acid" "terbufibrolum [inn-latin]" "k-11,267" "4'-(3-(4'-t-butylphenoxy)-2-hydroxypropoxy)benzoic acid" "p-(3-(p-tert-butylphenoxy)-2-hydroxypropoxy)benzoic acid" "4-(3-(4-(1,1-dimethylethyl)phenoxy)-2-hydroxypropoxy)benzoic acid" "benzoic acid, p-(3-(p-tert-butylphenoxy)-2-hydroxypropoxy)-" "benzoic acid, 4-(3-(4-(1,1-dimethylethyl)phenoxy)-2-hydroxypropoxy)-" "terbufibrolum" "terbufibrol [inn]" "4-[3-(4-tert-butylphenoxy)-2-hydroxypropoxy]benzoic acid" );
gibbsFormation
{
    dHf_298   -786980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     788.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367250.0
    phase     gas;
}
