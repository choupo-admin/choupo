/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-heptylbenz(a)anthracene  (C25H26, CAS 63019-32-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8HeptylbenzAAnthracene;
formula     C25H26;
CAS         63019-32-9;
InChIKey    FWAPVMXIDHLCEZ-UHFFFAOYSA-N;
MW          326.483;      // g/mol [origin=calculated method=formula-sum]
Tc          1101.91;      // K   [origin=predictive method=joback]
Pc          14.827;      // bar [origin=predictive method=joback]
omega       0.9311;      // -   [origin=predictive method=lee-kesler]
Tb          870.16;      // K   [origin=predictive method=joback]
HvapTb      80426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.174 2.11032 -0.00157644 4.804e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 11; } { group AC; count 6; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 11; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-heptylbenzo[a]anthracene" "5-n-heptylbenz(1:2)benzanthracene" );
standardThermochemistry
{
    dHf_298   216000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=563090.0
}
