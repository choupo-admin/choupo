/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-4-chloro-2-pentene  (C5H9Cl, CAS 18610-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans4Chloro2Pentene;
formula     C5H9Cl;
CAS         18610-33-8;
InChIKey    FKKCIOTUMHPTSB-UHFFFAOYSA-N;
MW          104.577;      // g/mol [origin=calculated method=formula-sum]
Tc          541.78;      // K   [origin=predictive method=joback]
Pc          35.643;      // bar [origin=predictive method=joback]
omega       0.2521;      // -   [origin=predictive method=lee-kesler]
Tb          355.15;      // K   [origin=predictive method=joback]
HvapTb      30679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.63 0.51154 -0.0003556 1.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylpent-2-ene" "2-pentene, 4-chloro-, (2e)-" "2-pentene, 4-chloro-, (2z)-" );
gibbsFormation
{
    dHf_298   -50330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57070.0
    phase     gas;
}
