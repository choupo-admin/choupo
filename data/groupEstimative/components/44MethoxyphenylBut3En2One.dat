/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-methoxyphenyl)but-3-en-2-one  (C11H12O2, CAS 943-88-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44MethoxyphenylBut3En2One;
formula     C11H12O2;
CAS         943-88-4;
InChIKey    WRRZKDVBPZBNJN-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          783.27;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.6072;      // -   [origin=predictive method=lee-kesler]
Tb          563.39;      // K   [origin=predictive method=joback]
HvapTb      52132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.04 0.83924 -0.00049286 1.0386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trans-4-(4-methoxyphenyl)-3-buten-2-one" "(3z)-4-(4-methoxyphenyl)but-3-en-2-one" "3-buten-2-one,4-(4-methoxyphenyl)-, (3e)-" "3-buten-2-one,4-(4-methoxyphenyl)-, (e)-; 3-buten-2-one, 4-(p-methoxyphenyl)-, trans- (8ci);(2e)-4-(4-methoxyphenyl)-3-buten-2-one; (3e)-4-(4-methoxyphenyl)-3-buten-2-one;(e)-4-(4-methoxyphenyl)but-3-en-2-one; (e)-4-(p-methoxyphenyl)-3-buten-2-one;4-(4-methoxyphenyl)-(3e)-buten-2-one; trans-(4-methoxybenzylidene)acetone" );
gibbsFormation
{
    dHf_298   -172890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9180.0
    phase     gas;
}
