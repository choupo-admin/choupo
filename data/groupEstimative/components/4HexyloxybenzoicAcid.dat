/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexyloxybenzoic acid  (C13H18O3, CAS 1142-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HexyloxybenzoicAcid;
formula     C13H18O3;
CAS         1142-39-8;
InChIKey    HBQUXMZZODHFMJ-UHFFFAOYSA-N;
MW          222.284;      // g/mol [origin=calculated method=formula-sum]
Tc          904.84;      // K   [origin=predictive method=joback]
Pc          23.158;      // bar [origin=predictive method=joback]
omega       0.9995;      // -   [origin=predictive method=lee-kesler]
Tb          696.63;      // K   [origin=predictive method=joback]
HvapTb      67044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.565 1.08802 -0.00060916 1.173e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexoxybenzoic acid" "4-(hexyloxy)benzoic acid" "4-n-hexyloxybenzoic acid" "p-hexyloxybenzoic acid" "p-hexoylbenzoic acid" "benzoic acid, 4-(hexyloxy)-" "p-n-hexyloxybenzoic acid" "p-(hexyloxy)benzoic acid" "p-(n-hexoxy)benzoic acid" "4-n-hexyl-oxybenzoic acid" "benzoic acid, p-(hexyloxy)-" "p-(n-hexyloxy)benzoic acid" );
standardThermochemistry
{
    dHf_298   -569080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287550.0
}
