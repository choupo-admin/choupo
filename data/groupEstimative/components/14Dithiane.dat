/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dithiane  (C4H8S2, CAS 505-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dithiane;
formula     C4H8S2;
CAS         505-29-3;
InChIKey    LOZWAPSEEHRYPG-UHFFFAOYSA-N;
MW          120.228;      // g/mol [origin=calculated method=formula-sum]
Tc          658.29;      // K   [origin=predictive method=joback]
Pc          52.816;      // bar [origin=predictive method=joback]
omega       0.2094;      // -   [origin=predictive method=lee-kesler]
Tb          411.00;      // K   [origin=predictive method=joback]
HvapTb      36860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.65 0.56122 -0.0003676 9.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-dithiane" "1,4-dithiacyclohexane" "diethylene disulfide" "p-dithiin, tetrahydro-" "p-dithane" "1,4-dithiin, tetrahydro-" "para-dithiane" "1,4-dithian" "[1,4]dithiane" "tetrahydro-1,4-dithiin" "u566" );
standardThermochemistry
{
    dHf_298   39290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94680.0
}
