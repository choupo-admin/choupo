/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 1-bromocyclobutanecarboxylate  (C7H11BrO2, CAS 35120-18-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl1Bromocyclobutanecarboxylate;
formula     C7H11BrO2;
CAS         35120-18-4;
InChIKey    UTVNSHXHFRIXMM-UHFFFAOYSA-N;
MW          207.067;      // g/mol [origin=calculated method=formula-sum]
Tc          716.34;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.5122;      // -   [origin=predictive method=lee-kesler]
Tb          495.39;      // K   [origin=predictive method=joback]
HvapTb      43952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.229 1.08542 -0.0010402 4.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-bromanylcyclobutane-1-carboxylate" "ethyl 1-bromocyclobutane-1-carboxylate" "ethyl .alpha.-bromocyclobutanecarboxylate" "cyclobutanecarboxylic acid, 1-bromo-, ethyl ester" "ethyl alpha-bromocyclobutanecarboxylate" "ethyl abromocyclobutanecarboxylate" "cyclobutanecarboxylicacid, 1-bromo-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -396880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244830.0
}
