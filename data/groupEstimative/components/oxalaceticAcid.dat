/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxalacetic acid  (C4H4O5, CAS 328-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxalaceticAcid;
formula     C4H4O5;
CAS         328-42-7;
InChIKey    KHPXUQMNIQBQEV-UHFFFAOYSA-N;
MW          132.071;      // g/mol [origin=calculated method=formula-sum]
Tc          853.36;      // K   [origin=predictive method=joback]
Pc          53.986;      // bar [origin=predictive method=joback]
omega       1.2095;      // -   [origin=predictive method=lee-kesler]
Tb          636.01;      // K   [origin=predictive method=joback]
HvapTb      65572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.811 0.4574 -0.0003203 8.336e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2CO; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CdO; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylidenebutanedioic acid" "oxaloacetic acid" "ketosuccinic acid" "2-oxobutanedioic acid" "2-oxosuccinic acid" "oxosuccinic acid" "oxaloacetate" "2-ketosuccinic acid" "oxobutanedioic acid" "butanedioic acid, oxo-" "oxalacetate" "oxalacetic acetic" );
gibbsFormation
{
    dHf_298   -939010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-833940.0
    phase     gas;
}
