/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane-1,3-diyl bis(4-aminobenzoate)  (C17H18N2O4, CAS 57609-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane13DiylBis4Aminobenzoate;
formula     C17H18N2O4;
CAS         57609-64-0;
InChIKey    YPACMOORZSDQDQ-UHFFFAOYSA-N;
MW          314.341;      // g/mol [origin=calculated method=formula-sum]
Tc          1153.58;      // K   [origin=predictive method=joback]
Pc          22.806;      // bar [origin=predictive method=joback]
omega       1.2869;      // -   [origin=predictive method=lee-kesler]
Tb          913.38;      // K   [origin=predictive method=joback]
HvapTb      95408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.023 1.3562 -0.00072692 1.001e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 8; } { group AC; count 2; } { group ACNH2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-aminophenyl)carbonyloxypropyl 4-azanylbenzoate" "polacure 740m" "trimethylene bis(4-aminobenzoate)" "1,3-propanediol bis(4-aminobenzoate)" "1,3-propanediol, bis(4-aminobenzoate)" "1,3-propanediol, di(p-aminobenzoate)" "trimethylene glycol di(p-aminobenzoate)" "1,3-propanediol, 1,3-bis(4-aminobenzoate)" "propylene glycol bis (4-aminobenzoate) [cua-4]" "1,3-bis(4-aminobenzoyloxy)propane" "1,3-propanediol, di-p-aminobenzoate" "1,3-propanediol,1,3-bis(4-aminobenzoate)" );
standardThermochemistry
{
    dHf_298   -511070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     798.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-190020.0
}
