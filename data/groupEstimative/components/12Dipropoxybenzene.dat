/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dipropoxybenzene  (C12H18O2, CAS 6280-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dipropoxybenzene;
formula     C12H18O2;
CAS         6280-98-4;
InChIKey    XUIKECLBCZBUCM-UHFFFAOYSA-N;
MW          194.274;      // g/mol [origin=calculated method=formula-sum]
Tc          747.85;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.6389;      // -   [origin=predictive method=lee-kesler]
Tb          550.66;      // K   [origin=predictive method=joback]
HvapTb      50064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.374 0.87904 -0.00037116 2.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1,2-dipropoxy-" "xuikeclbczbucm-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -330390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57060.0
    phase     gas;
}
