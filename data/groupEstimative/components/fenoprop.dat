/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenoprop  (C9H7Cl3O3, CAS 93-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenoprop;
formula     C9H7Cl3O3;
CAS         93-72-1;
InChIKey    ZLSWBLPERHFHIS-UHFFFAOYSA-N;
MW          269.502;      // g/mol [origin=calculated method=formula-sum]
Tc          964.33;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.9699;      // -   [origin=predictive method=lee-kesler]
Tb          726.92;      // K   [origin=predictive method=joback]
HvapTb      72231.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (70.79 0.61532 -0.00032188 4.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group CH-O; count 1; } { group COOH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4,5-tris(chloranyl)phenoxy]propanoic acid" "silvex" "2-(2,4,5-trichlorophenoxy)propionic acid" "double strength" "fenormone" "propon" "kuran" "color-set" "aqua-vex" "sta-fast" "2,4,5-tp" "fruitone t" );
gibbsFormation
{
    dHf_298   -561960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-378720.0
    phase     gas;
}
