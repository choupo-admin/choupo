/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dimethoxy-2-propanol  (C5H12O3, CAS 623-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dimethoxy2Propanol;
formula     C5H12O3;
CAS         623-69-8;
InChIKey    ZESKRVSPQJVIMH-UHFFFAOYSA-N;
MW          120.148;      // g/mol [origin=calculated method=formula-sum]
Tc          616.13;      // K   [origin=predictive method=joback]
Pc          37.546;      // bar [origin=predictive method=joback]
omega       0.8514;      // -   [origin=predictive method=lee-kesler]
Tb          450.58;      // K   [origin=predictive method=joback]
HvapTb      47835.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.952 0.39234 -5.98e-05 -5.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dimethoxypropan-2-ol" "2-propanol, 1,3-dimethoxy-" "glycerol 1,3-dimethyl ether" "2-propanol,3-dimethoxy-" "u081" );
standardThermochemistry
{
    dHf_298   -568480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-358040.0
}
