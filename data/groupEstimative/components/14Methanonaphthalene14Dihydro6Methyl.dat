/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-methanonaphthalene, 1,4-dihydro-6-methyl-  (C12H12, CAS 4897-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Methanonaphthalene14Dihydro6Methyl;
formula     C12H12;
CAS         4897-73-8;
InChIKey    OFLDLPDLWOSGIB-UHFFFAOYSA-N;
MW          156.228;      // g/mol [origin=calculated method=formula-sum]
Tc          747.83;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.4427;      // -   [origin=predictive method=lee-kesler]
Tb          519.17;      // K   [origin=predictive method=joback]
HvapTb      45852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.91 1.20132 -0.0010002 3.4e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   132120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     266.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=306870.0
}
