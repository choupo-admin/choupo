/*--------------------------------*- Choupo -*-----------------------*\
  Component: diallyldimethylsilane  (C8H16Si, CAS 1113-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diallyldimethylsilane;
formula     C8H16Si;
CAS         1113-12-8;
InChIKey    ZDSFBVVBFMKMRF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          140.301;      // g/mol [origin=calculated method=formula-sum]
Tc          553.93;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       0.2633;      // -   [origin=predictive method=lee-kesler]
Tb          377.40;      // K   [origin=predictive method=joback]
HvapTb      32356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.452 0.51764 -4.24e-05 -9.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=CH; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl-bis(prop-2-enyl)silane" "silane, dimethyldi-2-propenyl-" "silane, dimethyldi-2-propen-1-yl-" "dimethylbis(prop-2-en-1-yl)silane" );
gibbsFormation
{
    dHf_298   -69210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87400.0
    phase     gas;
}
