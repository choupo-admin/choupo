/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, tris(2-methoxyethoxy)phenyl-  (C15H26O6Si, CAS 17903-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H26O6Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneTris2MethoxyethoxyPhenyl;
formula     C15H26O6Si;
CAS         17903-05-8;
InChIKey    DBXDLSPMDNQBBQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          330.452;      // g/mol [origin=calculated method=formula-sum]
Tc          895.56;      // K   [origin=predictive method=joback]
Pc          15.391;      // bar [origin=predictive method=joback]
omega       0.9337;      // -   [origin=predictive method=lee-kesler]
Tb          705.40;      // K   [origin=predictive method=joback]
HvapTb      66014.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (149.166 0.76456 0.0002574 -3.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 3; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(2-methoxyethoxy)-phenyl-silane" "phenyltris(methoxyethoxy)silane" "2,5,7,10-tetraoxa-6-silaundecane, 6-(2-methoxyethoxy)-6-phenyl-" "6-(2-methoxyethoxy)-6-phenyl-2,5,7,10-tetraoxa-6-silaundecane" "tris(2-methoxyethoxy)-phenylsilane" "silane, tris(2-methoxyethoxy)phenyl- (8ci)" "2,7,10-tetraoxa-6-silaundecane, 6-(2-methoxyethoxy)-6-phenyl-" );
standardThermochemistry
{
    dHf_298   -1021340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     827.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-546930.0
}
