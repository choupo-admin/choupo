/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-thia-5-oxa-4,7-dimethylheptan-7-ol  (C7H16O2S, CAS 72187-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Thia5Oxa47Dimethylheptan7Ol;
formula     C7H16O2S;
CAS         72187-34-9;
InChIKey    WYHWTENYOVYBQX-NKWVEPMBSA-N;
MW          164.263;      // g/mol [origin=calculated method=formula-sum]
Tc          727.26;      // K   [origin=predictive method=joback]
Pc          31.491;      // bar [origin=predictive method=joback]
omega       0.9070;      // -   [origin=predictive method=lee-kesler]
Tb          542.26;      // K   [origin=predictive method=joback]
HvapTb      56306.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.552 0.64585 -0.0002426 -1.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group C2H4O2; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-1-[(2r)-1-methylsulfanylpropan-2-yl]oxypropan-2-ol" "2-propanol, 1-(1-methyl-2-(methylthio)ethoxy)-" );
standardThermochemistry
{
    dHf_298   -440950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205520.0
}
