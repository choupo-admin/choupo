/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-3-(4-methyl-3-pentenyl)cyclohex-3-ene-1-carboxylic acid  (C14H22O2, CAS 65652-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl34Methyl3PentenylCyclohex3Ene1CarboxylicAcid;
formula     C14H22O2;
CAS         65652-27-9;
InChIKey    YFCNEIWVIJVLHW-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          914.48;      // K   [origin=predictive method=joback]
Pc          21.734;      // bar [origin=predictive method=joback]
omega       0.8248;      // -   [origin=predictive method=lee-kesler]
Tb          693.40;      // K   [origin=predictive method=joback]
HvapTb      64192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.628 1.70306 -0.00143034 5.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group CH=C; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-(4-methylpent-3-enyl)cyclohex-3-ene-1-carboxylic acid" "3-cyclohexene-1-carboxylic acid, 1-methyl-3-(4-methyl-3-pentenyl)-" "3-cyclohexene-1-carboxylic acid, 1-methyl-3-(4-methyl-3-penten-1-yl)-" );
gibbsFormation
{
    dHf_298   -459260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     739.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-165950.0
    phase     gas;
}
