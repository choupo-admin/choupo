/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenolphthalein dibutyrate  (C28H26O6, CAS 62625-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenolphthaleinDibutyrate;
formula     C28H26O6;
CAS         62625-15-4;
InChIKey    JKODXQNSKLMPQT-UHFFFAOYSA-N;
MW          458.51;      // g/mol [origin=calculated method=formula-sum]
Tc          1360.42;      // K   [origin=predictive method=joback]
Pc          12.593;      // bar [origin=predictive method=joback]
omega       1.1452;      // -   [origin=predictive method=lee-kesler]
Tb          1108.32;      // K   [origin=predictive method=joback]
HvapTb      107375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.146 2.54624 -0.00195368 6.096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 12; } { group AC; count 6; } { group CH2COO; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[1-(4-butanoyloxyphenyl)-3-oxidanylidene-2-benzofuran-1-yl]phenyl] butanoate" "(3-oxo-1,3-dihydro-2-benzofuran-1,1-diyl)di-4,1-phenylene dibutanoate" "butanoic acid, (3-oxo-1(3h)-isobenzofuranylidene)di-4,1-phenylene ester" "butanoic acid, 1,1'-((3-oxo-1(3h)-isobenzofuranylidene)di-4,1-phenylene) ester" "butanoic acid, 1,1'-[(3-oxo-1(3h)-isobenzofuranylidene)di-4,1-phenylene] ester" "butanoic acid,1-phenylene ester" "(3-oxo-1(3h)-isobenzofurylidene)di-p-phenylene dibutyrate" "[4-[1-(4-butanoyloxyphenyl)-3-oxo-2-benzofuran-1-yl]phenyl] butanoate" "4-{1-[4-(butanoyloxy)phenyl]-3-oxo-2-benzofuran-1-yl}phenyl butanoate" );
gibbsFormation
{
    dHf_298   -797550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1002.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-358430.0
    phase     gas;
}
