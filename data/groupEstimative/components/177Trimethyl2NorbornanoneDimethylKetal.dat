/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,7,7-trimethyl-2-norbornanone dimethyl ketal  (C12H22O2, CAS 109280-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        177Trimethyl2NorbornanoneDimethylKetal;
formula     C12H22O2;
CAS         109280-15-1;
InChIKey    RRCYFCPKYNYACP-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          741.66;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.4572;      // -   [origin=predictive method=lee-kesler]
Tb          528.13;      // K   [origin=predictive method=joback]
HvapTb      43053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-200.72 2.1324 -0.002288 1.0283e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 3; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethoxy-4,7,7-trimethyl-bicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane, 2,2-dimethoxy-1,7,7-trimethyl-, (1r)-" "bicyclo[2.2.1]heptane, 2,2-dimethoxy-1,7,7-trimethyl-, (1s)-" "3,3-dimethoxy-4,7,7-trimethylbicyclo[2.2.1]heptane" );
gibbsFormation
{
    dHf_298   -410970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     609.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-82330.0
    phase     gas;
}
