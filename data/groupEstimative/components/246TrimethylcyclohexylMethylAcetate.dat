/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,4,6-trimethylcyclohexyl)methyl acetate  (C12H22O2, CAS 67634-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246TrimethylcyclohexylMethylAcetate;
formula     C12H22O2;
CAS         67634-05-3;
InChIKey    OZBOTLMHFMZTGA-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          734.33;      // K   [origin=predictive method=joback]
Pc          19.596;      // bar [origin=predictive method=joback]
omega       0.5223;      // -   [origin=predictive method=lee-kesler]
Tb          537.92;      // K   [origin=predictive method=joback]
HvapTb      49215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.399 1.13168 -0.0004492 -5e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,4,6-trimethylcyclohexyl)methyl ethanoate" "2,4,6-trimethylcyclohexylmethyl acetate" "cyclohexanemethanol, 2,4,6-trimethyl-, acetate" "cyclohexanemethanol, 2,4,6-trimethyl-, 1-acetate" );
standardThermochemistry
{
    dHf_298   -614990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258890.0
}
