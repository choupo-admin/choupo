/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-01mp4k  (C9H10O5, CAS 125542-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc01mp4k;
formula     C9H10O5;
CAS         125542-70-3;
InChIKey    WNEFDHCAKLWKAG-UHFFFAOYSA-N;
MW          198.174;      // g/mol [origin=calculated method=formula-sum]
Tc          1050.86;      // K   [origin=predictive method=joback]
Pc          43.742;      // bar [origin=predictive method=joback]
omega       1.3672;      // -   [origin=predictive method=lee-kesler]
Tb          805.24;      // K   [origin=predictive method=joback]
HvapTb      85540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.9 0.82992 -0.00048376 9.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanoic acid;2-oxidanylbenzoic acid" "benzoic acid, 2-hydroxy-, homopolymer, acetate" "acetic acid;2-hydroxybenzoic acid" "salicylic acid, homopolymer, acetate" );
standardThermochemistry
{
    dHf_298   -982030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-809890.0
}
