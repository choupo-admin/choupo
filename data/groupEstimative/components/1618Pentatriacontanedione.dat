/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16,18-pentatriacontanedione  (C35H68O2, CAS 64683-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1618Pentatriacontanedione;
formula     C35H68O2;
CAS         64683-28-9;
InChIKey    WCIZYPZCFNITGM-UHFFFAOYSA-N;
MW          520.927;      // g/mol [origin=calculated method=formula-sum]
Tc          1432.24;      // K   [origin=predictive method=joback]
Pc          5.045;      // bar [origin=predictive method=joback]
omega       0.0134;      // -   [origin=predictive method=lee-kesler]
Tb          1108.14;      // K   [origin=predictive method=joback]
HvapTb      106996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.209 3.27284 -0.0018428 3.8722e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 29; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 31; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentatriacontane-16,18-dione" "palmitoyl stearoyl methane" );
standardThermochemistry
{
    dHf_298   -990890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1572.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14020.0
}
