/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-tert-butyladipic acid  (C10H18O4, CAS 10347-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TertButyladipicAcid;
formula     C10H18O4;
CAS         10347-88-3;
InChIKey    LHSCNQRBIIDZCB-UHFFFAOYSA-N;
MW          202.25;      // g/mol [origin=calculated method=formula-sum]
Tc          922.45;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       1.1471;      // -   [origin=predictive method=lee-kesler]
Tb          715.75;      // K   [origin=predictive method=joback]
HvapTb      70498.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.157 1.18716 -0.0008404 2.352e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tert-butylhexanedioic acid" "3-(tert-butyl)hexanedioic acid" "3-t-butyl-hexanedioic acid" "beta-tert-butyl-adipic acid" "3-tert-butyl-hexanedioic acid" );
gibbsFormation
{
    dHf_298   -964300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-654100.0
    phase     gas;
}
