/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-dimethyl-6-methoxy-7-bromooctanol  (C11H23BrO2, CAS 68527-73-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Dimethyl6Methoxy7Bromooctanol;
formula     C11H23BrO2;
CAS         68527-73-1;
InChIKey    DOOYDTPWMJXOPI-UHFFFAOYSA-N;
MW          267.207;      // g/mol [origin=calculated method=formula-sum]
Tc          811.24;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       1.0404;      // -   [origin=predictive method=lee-kesler]
Tb          627.93;      // K   [origin=predictive method=joback]
HvapTb      63532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.034 1.19548 -0.0007436 1.797e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group OH; count 1; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group Br; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-bromanyl-6-methoxy-2,7-dimethyl-octan-1-ol" "7-bromo-6-methoxy-2,7-dimethyloctan-1-ol" "1-octanol, 7-bromo-6-methoxy-2,7-dimethyl-" );
standardThermochemistry
{
    dHf_298   -547800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-187800.0
}
