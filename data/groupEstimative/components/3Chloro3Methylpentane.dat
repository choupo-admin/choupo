/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-3-methylpentane  (C6H13Cl, CAS 918-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro3Methylpentane;
formula     C6H13Cl;
CAS         918-84-3;
InChIKey    SGWJUIFOPCZXMR-UHFFFAOYSA-N;
MW          120.62;      // g/mol [origin=calculated method=formula-sum]
Tc          555.15;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.2703;      // -   [origin=predictive method=lee-kesler]
Tb          371.08;      // K   [origin=predictive method=joback]
HvapTb      32039.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.148 0.70646 -0.0004948 1.411e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-3-methyl-pentane" "diethylmethylcarbinyl chloride" "pentane, 3-chloro-3-methyl-" );
standardThermochemistry
{
    dHf_298   -191660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9450.0
}
