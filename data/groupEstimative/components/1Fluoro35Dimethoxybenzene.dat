/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-fluoro-3,5-dimethoxybenzene  (C8H9FO2, CAS 52189-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Fluoro35Dimethoxybenzene;
formula     C8H9FO2;
CAS         52189-63-6;
InChIKey    IWFKMNAEFPEIOY-UHFFFAOYSA-N;
MW          156.156;      // g/mol [origin=calculated method=formula-sum]
Tc          662.20;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.4996;      // -   [origin=predictive method=lee-kesler]
Tb          463.39;      // K   [origin=predictive method=joback]
HvapTb      41005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.4 0.45134 -0.00010292 -4.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-3,5-dimethoxy-benzene" "1,3-dimethoxy-5-fluorobenzene" "benzene, 1-fluoro-3,5-dimethoxy-" "3,5-dimethoxy fluoro benzene" "3,5-dimethoxyfluorobenzene" "benzene,1-fluoro-3,5-dimethoxy-" "1-fluoro-3,5-dimethyltoxybenzene;5-fluororesorcinol dimethyl ether;5-fluoro-1,3-dimethoxybenzene" );
gibbsFormation
{
    dHf_298   -455410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295180.0
    phase     gas;
}
