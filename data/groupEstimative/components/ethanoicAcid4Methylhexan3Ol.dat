/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanoic acid;4-methylhexan-3-ol  (C9H20O3, CAS 84612-71-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanoicAcid4Methylhexan3Ol;
formula     C9H20O3;
CAS         84612-71-5;
InChIKey    DZICOLHYDGCZHI-UHFFFAOYSA-N;
MW          176.256;      // g/mol [origin=calculated method=formula-sum]
Tc          829.68;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       1.1466;      // -   [origin=predictive method=lee-kesler]
Tb          643.73;      // K   [origin=predictive method=joback]
HvapTb      68989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.052 0.74928 -0.0001604 -8.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexanol,4-methyl-, acetate, (r*,r*)-" "3-hexanol, 4-methyl-,acetate, (3r,4r)-rel- (9ci)" );
standardThermochemistry
{
    dHf_298   -853770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-565470.0
}
