/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diethylthiophene  (C8H12S, CAS 5069-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Diethylthiophene;
formula     C8H12S;
CAS         5069-23-8;
InChIKey    JQTZGXZYJIJECP-UHFFFAOYSA-N;
MW          140.244;      // g/mol [origin=calculated method=formula-sum]
Tc          674.36;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.3747;      // -   [origin=predictive method=lee-kesler]
Tb          458.70;      // K   [origin=predictive method=joback]
HvapTb      41688.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.828 0.70545 -0.00045338 1.191e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thiophene, 2,5-diethyl-" );
gibbsFormation
{
    dHf_298   10250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141260.0
    phase     gas;
}
