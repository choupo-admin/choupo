/*--------------------------------*- Choupo -*-----------------------*\
  Component: edetic acid  (C10H16N2O8, CAS 60-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        edeticAcid;
formula     C10H16N2O8;
CAS         60-00-4;
InChIKey    KCXVZYZYPLLWCC-UHFFFAOYSA-N;
MW          292.244;      // g/mol [origin=calculated method=formula-sum]
Tc          1268.08;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       1.9605;      // -   [origin=predictive method=lee-kesler]
Tb          1035.32;      // K   [origin=predictive method=joback]
HvapTb      110596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.184 1.4048 -0.0010358 2.946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2N; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group COOH; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[bis(2-hydroxy-2-oxoethyl)amino]ethyl-(2-hydroxy-2-oxoethyl)amino]ethanoic acid" "edta" "ethylenediaminetetraacetic acid" "edathamil" "endrate" "havidote" "titriplex" "versenate" "versene" "edta acid" "cheelox" "sequestrol" );
gibbsFormation
{
    dHf_298   -1515750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     790.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1120760.0
    phase     gas;
}
