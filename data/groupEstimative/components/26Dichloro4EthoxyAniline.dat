/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dichloro-4-ethoxy-aniline  (C8H9Cl2NO, CAS 51225-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dichloro4EthoxyAniline;
formula     C8H9Cl2NO;
CAS         51225-20-8;
InChIKey    YEBYUUOTDWKSKX-UHFFFAOYSA-N;
MW          206.066;      // g/mol [origin=calculated method=formula-sum]
Tc          827.01;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.6670;      // -   [origin=predictive method=lee-kesler]
Tb          594.07;      // K   [origin=predictive method=joback]
HvapTb      59485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.381 0.51872 -0.00021468 9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(chloranyl)-4-ethoxy-aniline" "2,6-dichloro-4-ethoxyaniline" "benzenamine,6-dichloro-4-ethoxy-" "benzenamine,2,6-dichloro-4-ethoxy-" );
standardThermochemistry
{
    dHf_298   -136240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37590.0
}
