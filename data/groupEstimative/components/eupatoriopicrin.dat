/*--------------------------------*- Choupo -*-----------------------*\
  Component: eupatoriopicrin  (C20H26O6, CAS 6856-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eupatoriopicrin;
formula     C20H26O6;
CAS         6856-01-5;
InChIKey    VWJYWGYJIDQUEG-DKDOXNMLSA-N;
MW          362.422;      // g/mol [origin=calculated method=formula-sum]
Tc          1224.00;      // K   [origin=predictive method=joback]
Pc          16.338;      // bar [origin=predictive method=joback]
omega       1.4134;      // -   [origin=predictive method=lee-kesler]
Tb          999.64;      // K   [origin=predictive method=joback]
HvapTb      110768.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.468 1.76094 -0.00092298 1.318e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group CH2=C; count 1; } { group CH=C; count 3; } { group OH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 3; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3ar,4r,6e,10e,11ar)-6,10-dimethyl-3-methylidene-2-oxidanylidene-3a,4,5,8,9,11a-hexahydrocyclodeca[b]furan-4-yl] (e)-2-(hydroxymethyl)-4-oxidanyl-but-2-enoate" "eupatoriopicrine" "[(3ar,4r,6e,10e,11ar)-6,10-dimethyl-3-methylidene-2-oxo-3a,4,5,8,9,11a-hexahydrocyclodeca[b]furan-4-yl] (e)-4-hydroxy-2-(hydroxymethyl)but-2-enoate" );
gibbsFormation
{
    dHf_298   -1016400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     892.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-558160.0
    phase     gas;
}
