/*--------------------------------*- Choupo -*-----------------------*\
  Component: neopentyl t-butyl ketone  (C10H20O, CAS 868-91-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        neopentylTButylKetone;
formula     C10H20O;
CAS         868-91-7;
InChIKey    XUXJQANAPZHLMK-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          670.64;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.4259;      // -   [origin=predictive method=lee-kesler]
Tb          475.81;      // K   [origin=predictive method=joback]
HvapTb      42008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.789 1.17752 -0.0008451 2.4256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group C; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,5,5-tetramethylhexan-3-one" "2,2,5,5-tetramethyl-3-hexanone" );
standardThermochemistry
{
    dHf_298   -379810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-89920.0
}
