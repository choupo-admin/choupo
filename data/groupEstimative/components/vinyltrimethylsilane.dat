/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyltrimethylsilane  (C5H12Si, CAS 754-05-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H12Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        vinyltrimethylsilane;
formula     C5H12Si;
CAS         754-05-2;
InChIKey    GCSJLQSCSDMKTP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          100.236;      // g/mol [origin=calculated method=formula-sum]
Tc          484.78;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.1522;      // -   [origin=predictive method=lee-kesler]
Tb          312.08;      // K   [origin=predictive method=joback]
HvapTb      26348.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.17 0.25266 0.0001437 -1.515e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2=CH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl(trimethyl)silane" "silane, ethenyltrimethyl-" "trimethyl(vinyl)silane" "(trimethylsilyl)ethylene" "trimethylvinylsilane" "ethenyltrimethylsilane" "silane, trimethylvinyl-" "vinyl trimethylsilane" "ethenyl-trimethylsilane" "silane, trimethylvinyl- (8ci)" );
gibbsFormation
{
    dHf_298   -132720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25700.0
    phase     gas;
}
