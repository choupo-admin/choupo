/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-(pentyloxy)acetophenone  (C13H18O2, CAS 5467-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pPentyloxyAcetophenone;
formula     C13H18O2;
CAS         5467-56-1;
InChIKey    KJQMDQDQXJDXJR-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          808.92;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       0.7405;      // -   [origin=predictive method=lee-kesler]
Tb          604.99;      // K   [origin=predictive method=joback]
HvapTb      56626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.324 1.00924 -0.00051786 8.026e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-pentoxyphenyl)ethanone" "1-[4-(pentyloxy)phenyl]ethanone" "ethanone, 1-(4-(pentyloxy)phenyl)-" "ethanone, 1-[4-(pentyloxy)phenyl]-" );
gibbsFormation
{
    dHf_298   -331390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     587.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72560.0
    phase     gas;
}
