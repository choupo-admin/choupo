/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxy-4'-octyloxy-trans-stilbene  (C23H30O2, CAS 35135-46-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxy4OctyloxyTransStilbene;
formula     C23H30O2;
CAS         35135-46-7;
InChIKey    LEYURONIACYWJT-UHFFFAOYSA-N;
MW          338.491;      // g/mol [origin=calculated method=formula-sum]
Tc          1051.30;      // K   [origin=predictive method=joback]
Pc          12.977;      // bar [origin=predictive method=joback]
omega       0.9248;      // -   [origin=predictive method=lee-kesler]
Tb          838.16;      // K   [origin=predictive method=joback]
HvapTb      77446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.413 1.80564 -0.00101752 2.015e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-4-[2-(4-octoxyphenyl)ethenyl]benzene" );
gibbsFormation
{
    dHf_298   -215150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     842.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218560.0
    phase     gas;
}
