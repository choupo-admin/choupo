/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-1,1-di-o-tolyl-2-propanone  (C23H22O, CAS 6324-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl11DiOTolyl2Propanone;
formula     C23H22O;
CAS         6324-65-8;
InChIKey    GMOUGOGLADCJGU-UHFFFAOYSA-N;
MW          314.428;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.97;      // K   [origin=predictive method=joback]
Pc          17.639;      // bar [origin=predictive method=joback]
omega       0.8155;      // -   [origin=predictive method=lee-kesler]
Tb          866.48;      // K   [origin=predictive method=joback]
HvapTb      80394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-108.25 1.93096 -0.00134002 3.5206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 13; } { group AC; count 3; } { group ACCH3; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(2-methylphenyl)-1-phenyl-propan-2-one" "1,1-bis(2-methylphenyl)-1-phenylpropan-2-one" );
standardThermochemistry
{
    dHf_298   47270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     708.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=334670.0
}
