/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodo-4-isopropylbenzene  (C9H11I, CAS 17356-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodo4Isopropylbenzene;
formula     C9H11I;
CAS         17356-09-1;
InChIKey    PQJOSEVTIKYWLH-UHFFFAOYSA-N;
MW          246.087;      // g/mol [origin=calculated method=formula-sum]
Tc          779.09;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.3553;      // -   [origin=predictive method=lee-kesler]
Tb          529.88;      // K   [origin=predictive method=joback]
HvapTb      47551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.89 0.76534 -0.00051456 1.359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-4-propan-2-yl-benzene" "2-(4'-iodophenyl)propane" "4-iodoisopropylbenzene" "p-iodocumene" "4-iodocumene" "p-iodoisopropylbenzene" "4-isopropyliodobenzene" "1-iodo-4-propan-2-ylbenzene" "4-iodo-1-(methylethyl)benzene" "2-(4-iodophenyl)propane" "benzene,1-iodo-4-(1-methylethyl)-" "1-iodo-4-(propan-2-yl)benzene" );
gibbsFormation
{
    dHf_298   67560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183360.0
    phase     gas;
}
