/*--------------------------------*- Choupo -*-----------------------*\
  Component: rhodinyl acetate  (C12H22O2, CAS 141-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rhodinylAcetate;
formula     C12H22O2;
CAS         141-11-7;
InChIKey    WNXJCQNXNOOMDJ-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          704.54;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       0.6538;      // -   [origin=predictive method=lee-kesler]
Tb          528.50;      // K   [origin=predictive method=joback]
HvapTb      48735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.025 1.07486 -0.0005628 9.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-7-enyl ethanoate" "rhodinol acetate" "rhodinyl ethanoate" "alpha-citronellyl acetate" "7-octen-1-ol, 3,7-dimethyl-, acetate" "3,7-dimethyl-7-octen-1-yl acetate" "3,7-dimethyloct-7-en-1-yl acetate" "3,7-dimethyl-7-octen-1-yl ethanoate" "7-octen-1-ol, 3,7-dimethyl-, 1-acetate" "(s)-3,7-dimethyloct-7-enyl acetate" "3,7-dimethyloct-7-enyl acetate" "[(3s)-3,7-dimethyloct-7-enyl] acetate" );
gibbsFormation
{
    dHf_298   -497930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     656.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183360.0
    phase     gas;
}
