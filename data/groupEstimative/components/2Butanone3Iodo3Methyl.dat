/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butanone, 3-iodo-3-methyl-  (C5H9IO, CAS 113613-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butanone3Iodo3Methyl;
formula     C5H9IO;
CAS         113613-35-7;
InChIKey    AMAJPSBXXMYTFM-UHFFFAOYSA-N;
MW          212.026;      // g/mol [origin=calculated method=formula-sum]
Tc          687.65;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.3270;      // -   [origin=predictive method=lee-kesler]
Tb          457.78;      // K   [origin=predictive method=joback]
HvapTb      41547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.08 0.61566 -0.0004827 1.5106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH3CO; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group I; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanyl-3-methyl-butan-2-one" "3-iodo-3-methylbutan-2-one" );
gibbsFormation
{
    dHf_298   -190990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76740.0
    phase     gas;
}
