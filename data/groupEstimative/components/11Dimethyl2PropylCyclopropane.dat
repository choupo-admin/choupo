/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethyl-2-propyl-cyclopropane  (C8H16, CAS 41845-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethyl2PropylCyclopropane;
formula     C8H16;
CAS         41845-48-1;
InChIKey    NWQWWOHNBLAJQT-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          569.93;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.2989;      // -   [origin=predictive method=lee-kesler]
Tb          384.95;      // K   [origin=predictive method=joback]
HvapTb      31855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.678 1.18016 -0.0011088 4.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethyl-2-propylcyclopropane" );
standardThermochemistry
{
    dHf_298   -140750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64030.0
}
