/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-fluoro-4-iodobenzene  (C6H3BrFI, CAS 136434-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Fluoro4Iodobenzene;
formula     C6H3BrFI;
CAS         136434-77-0;
InChIKey    OCODJNASCDFXSR-UHFFFAOYSA-N;
MW          300.892;      // g/mol [origin=calculated method=formula-sum]
Tc          794.75;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.4192;      // -   [origin=predictive method=lee-kesler]
Tb          532.09;      // K   [origin=predictive method=joback]
HvapTb      47541.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.1 0.4649 -0.00036892 1.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group I; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-fluoranyl-4-iodanyl-benzene" "4-bromo-3-fluoroiodobenzene" "3-fluoro-4-bromo iodobenzene" "3-fluoro-4-bromo-iodobenzene" "benzene, 1-bromo-2-fluoro-4-iodo-" "n688" );
standardThermochemistry
{
    dHf_298   -46490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-29580.0
}
