/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-oxatricyclo(3.1.0.02,6)hexan-4-one  (C5H4O2, CAS 19192-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Oxatricyclo310026Hexan4One;
formula     C5H4O2;
CAS         19192-82-6;
InChIKey    KAYMRZOTMLPTHA-UHFFFAOYSA-N;
MW          96.085;      // g/mol [origin=calculated method=formula-sum]
Tc          548.44;      // K   [origin=predictive method=joback]
Pc          46.849;      // bar [origin=predictive method=joback]
omega       0.4248;      // -   [origin=predictive method=lee-kesler]
Tb          366.42;      // K   [origin=predictive method=joback]
HvapTb      32701.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.43 0.8982 -0.0009908 4.104e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxatricyclo[3.1.0.02,6]hexan-4-one" "kaymrzotmlptha-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -234950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -10.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84110.0
}
