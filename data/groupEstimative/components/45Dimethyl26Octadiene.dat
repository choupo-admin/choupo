/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5-dimethyl-2,6-octadiene  (C10H18, CAS 18476-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45Dimethyl26Octadiene;
formula     C10H18;
CAS         18476-57-8;
InChIKey    JASAKDWEYSDIHI-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          622.59;      // K   [origin=predictive method=joback]
Pc          23.611;      // bar [origin=predictive method=joback]
omega       0.3677;      // -   [origin=predictive method=lee-kesler]
Tb          435.84;      // K   [origin=predictive method=joback]
HvapTb      36994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.93 1.00568 -0.0006942 2.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,5-dimethylocta-2,6-diene" );
standardThermochemistry
{
    dHf_298   -25850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188880.0
}
