/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentane, 2-methoxy-2-methyl-  (C7H16O, CAS 38772-53-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentane2Methoxy2Methyl;
formula     C7H16O;
CAS         38772-53-1;
InChIKey    WYLQOLGJMFRRLX-UHFFFAOYSA-N;
MW          116.204;      // g/mol [origin=calculated method=formula-sum]
Tc          554.24;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.3321;      // -   [origin=predictive method=lee-kesler]
Tb          378.95;      // K   [origin=predictive method=joback]
HvapTb      32290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.448 0.73148 -0.0004178 8.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-2-methyl-pentane" "2-methoxy-2-methylpentane" "1,1-dimethylbutyl methyl ether" );
standardThermochemistry
{
    dHf_298   -328780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94100.0
}
