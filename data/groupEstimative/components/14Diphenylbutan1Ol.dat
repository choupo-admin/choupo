/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diphenylbutan-1-ol  (C16H18O, CAS 30078-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diphenylbutan1Ol;
formula     C16H18O;
CAS         30078-89-8;
InChIKey    CAGIBUJGQRHYEW-UHFFFAOYSA-N;
MW          226.319;      // g/mol [origin=calculated method=formula-sum]
Tc          927.53;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       1.0110;      // -   [origin=predictive method=lee-kesler]
Tb          710.78;      // K   [origin=predictive method=joback]
HvapTb      72053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.857 1.4059 -0.0009426 2.395e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diphenyl-1-butanol" "benzenebutanol, .alpha.-phenyl-" "benzenebutanol, alpha-phenyl-" );
standardThermochemistry
{
    dHf_298   -58020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169400.0
}
