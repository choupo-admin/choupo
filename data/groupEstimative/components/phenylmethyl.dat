/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylmethyl  (C7H7, CAS 2154-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        phenylmethyl;
formula     C7H7;
CAS         2154-54-3;
InChIKey    SLRMQYXOBQWXCR-UHFFFAOYSA-N;
role        radical;
MW          91.133;      // g/mol [origin=calculated method=formula-sum]
Tc          591.83;      // K   [origin=predictive method=joback]
Pc          42.002;      // bar [origin=predictive method=joback]
omega       0.2419;      // -   [origin=predictive method=lee-kesler]
Tb          381.04;      // K   [origin=predictive method=joback]
HvapTb      32803.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.28 0.5599 -0.0003692 9.13e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methylbenzene" "benzyl radical" "methyl,phenyl-" "methyl, phenyl-" "phenyl(2h2)methyl" );
gibbsFormation
{
    dHf_298   115540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168200.0
    phase     gas;
}
