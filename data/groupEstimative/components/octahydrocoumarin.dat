/*--------------------------------*- Choupo -*-----------------------*\
  Component: octahydrocoumarin  (C9H14O2, CAS 4430-31-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octahydrocoumarin;
formula     C9H14O2;
CAS         4430-31-3;
InChIKey    MSFLYJIWLHSQLG-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          699.63;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.4578;      // -   [origin=predictive method=lee-kesler]
Tb          485.76;      // K   [origin=predictive method=joback]
HvapTb      43205.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.61 1.0866 -0.0007188 1.776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,4a,5,6,7,8,8a-octahydrochromen-2-one" "bicyclononalactone" "2h-1-benzopyran-2-one, octahydro-" "cyclohexyllactone" "cyclohexyl lactone" "coumarin, octahydro-" "octahydro-1-benzopyran-2-one" "octahydro-2h-1-benzopyran-2-one" "octahydrochromen-2-one" "agn-pc-00po9n" );
gibbsFormation
{
    dHf_298   -413090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188170.0
    phase     gas;
}
