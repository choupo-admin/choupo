/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-propanediol diacrylate  (C9H12O4, CAS 24493-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13PropanediolDiacrylate;
formula     C9H12O4;
CAS         24493-53-6;
InChIKey    GFLJTEHFZZNCTR-UHFFFAOYSA-N;
MW          184.191;      // g/mol [origin=calculated method=formula-sum]
Tc          698.52;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.7050;      // -   [origin=predictive method=lee-kesler]
Tb          515.32;      // K   [origin=predictive method=joback]
HvapTb      49102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.543 0.7092 -0.0003224 1.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-prop-2-enoyloxypropyl prop-2-enoate" "2-propenoic acid, 1,1'-(1,3-propanediyl) ester" "1,3-propanediyl diacrylate" "agn-pc-0ctmny" "2-propenoic acid, 1,3-propanediyl ester" "3-(2-deuterioprop-2-enoyloxy)propyl 2-deuterioprop-2-enoate" );
gibbsFormation
{
    dHf_298   -612790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-420160.0
    phase     gas;
}
