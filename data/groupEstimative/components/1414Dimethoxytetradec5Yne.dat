/*--------------------------------*- Choupo -*-----------------------*\
  Component: 14,14-dimethoxytetradec-5-yne  (C16H30O2, CAS 71393-97-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1414Dimethoxytetradec5Yne;
formula     C16H30O2;
CAS         71393-97-0;
InChIKey    AZYAQNJSVUMBBD-UHFFFAOYSA-N;
MW          254.414;      // g/mol [origin=calculated method=formula-sum]
Tc          795.82;      // K   [origin=predictive method=joback]
Pc          14.568;      // bar [origin=predictive method=joback]
omega       0.7788;      // -   [origin=predictive method=lee-kesler]
Tb          619.08;      // K   [origin=predictive method=joback]
HvapTb      57794.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.22 1.25356 -0.00053566 4.808e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 1; } { group CH3O; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group tC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-tetradecyne, 14,14-dimethoxy-" "9-tetradecynal dimethyl acetal" );
gibbsFormation
{
    dHf_298   -370990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     764.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74200.0
    phase     gas;
}
