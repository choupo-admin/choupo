/*--------------------------------*- Choupo -*-----------------------*\
  Component: dichlorodiphenylmethane  (C13H10Cl2, CAS 2051-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dichlorodiphenylmethane;
formula     C13H10Cl2;
CAS         2051-90-3;
InChIKey    OPTDDWCXQQYKGU-UHFFFAOYSA-N;
MW          237.123;      // g/mol [origin=calculated method=formula-sum]
Tc          890.74;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.4437;      // -   [origin=predictive method=lee-kesler]
Tb          622.03;      // K   [origin=predictive method=joback]
HvapTb      56558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.43 1.2204 -0.0009584 2.844e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[bis(chloranyl)-phenyl-methyl]benzene" "diphenyldichloromethane" "dpm (halocarbon)" "alpha,alpha-dichlorodiphenylmethane" "methane, dichlorodiphenyl-" "dichlorodiphenyl methane" "benzene, 1,1'-(dichloromethylene)bis-" "[dichloro(phenyl)methyl]benzene" "bisphenyldichloromethane" "diphenyl-dichloromethane" "bis-chlorodiphenylmethane" "(dichloro)diphenylmethane" );
standardThermochemistry
{
    dHf_298   121180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=262380.0
}
