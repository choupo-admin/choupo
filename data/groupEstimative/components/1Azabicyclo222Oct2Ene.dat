/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-azabicyclo[2.2.2]oct-2-ene  (C7H11N, CAS 13929-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azabicyclo222Oct2Ene;
formula     C7H11N;
CAS         13929-94-7;
InChIKey    JRRHUIUXVVVOQH-UHFFFAOYSA-N;
MW          109.172;      // g/mol [origin=calculated method=formula-sum]
Tc          597.36;      // K   [origin=predictive method=joback]
Pc          42.275;      // bar [origin=predictive method=joback]
omega       0.3317;      // -   [origin=predictive method=lee-kesler]
Tb          393.78;      // K   [origin=predictive method=joback]
HvapTb      33818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.93 1.0554 -0.00090628 3.106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo(2.2.2)oct-2-ene" );
gibbsFormation
{
    dHf_298   97280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265910.0
    phase     gas;
}
