/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl iodide  (C7H7I, CAS 620-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylIodide;
formula     C7H7I;
CAS         620-05-3;
InChIKey    XJTQJERLRPWUGL-UHFFFAOYSA-N;
MW          218.033;      // g/mol [origin=calculated method=formula-sum]
Tc          731.51;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.2916;      // -   [origin=predictive method=lee-kesler]
Tb          479.58;      // K   [origin=predictive method=joback]
HvapTb      42825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.689 0.6289 -0.0004696 1.375e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "iodanylmethylbenzene" "(iodomethyl)benzene" "benzene, (iodomethyl)-" "iodomethylbenzene" "alpha-iodotoluene" "toluene, .alpha.-iodo-" "benzyl-iodide" );
gibbsFormation
{
    dHf_298   125590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178590.0
    phase     gas;
}
