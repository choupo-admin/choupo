/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentyl hexanoate  (C11H22O2, CAS 540-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentylHexanoate;
formula     C11H22O2;
CAS         540-07-8;
InChIKey    WRFZKAGPPQGDDQ-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          677.72;      // K   [origin=predictive method=joback]
Pc          19.424;      // bar [origin=predictive method=joback]
omega       0.6907;      // -   [origin=predictive method=lee-kesler]
Tb          509.50;      // K   [origin=predictive method=joback]
HvapTb      47487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.298 0.99404 -0.00048 6.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "amyl hexanoate" "hexanoic acid, pentyl ester" "n-amyl caproate" "amyl caproate" "pentyl caproate" "amyl capronate" "amyl hexoate" "amyl hexanoate (natural)" "hexanoic acid pentyl ester" "valeryl hexanoate" "hexanoic acid amyl ester" "we(5:0/6:0)" );
gibbsFormation
{
    dHf_298   -587650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268630.0
    phase     gas;
}
