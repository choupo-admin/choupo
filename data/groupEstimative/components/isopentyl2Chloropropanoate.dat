/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopentyl 2-chloropropanoate  (C8H15ClO2, CAS 62108-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopentyl2Chloropropanoate;
formula     C8H15ClO2;
CAS         62108-69-4;
InChIKey    KNERPDYJMKKKNT-UHFFFAOYSA-N;
MW          178.656;      // g/mol [origin=calculated method=formula-sum]
Tc          662.99;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.5424;      // -   [origin=predictive method=lee-kesler]
Tb          477.41;      // K   [origin=predictive method=joback]
HvapTb      44418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.552 0.72766 -0.0003436 3.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl 2-chloranylpropanoate" "3-methylbutyl 2-chloropropanoate" "3-methylbutyl 2-chloropropionate" "propanoic acid, 3-methylbutyl ester" "propanoic acid, 2-chloro-, 3-methylbutyl ester" );
gibbsFormation
{
    dHf_298   -552030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310700.0
    phase     gas;
}
