/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-cyclobut(f)indene, 2,4,5,6-tetrahydro-  (C11H12, CAS 60582-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hCyclobutFIndene2456Tetrahydro;
formula     C11H12;
CAS         60582-10-7;
InChIKey    MJAGWIHRUOVQJZ-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          743.39;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.4510;      // -   [origin=predictive method=lee-kesler]
Tb          511.45;      // K   [origin=predictive method=joback]
HvapTb      44614.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.36 1.1558 -0.00100228 3.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   124190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     343.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274280.0
    phase     gas;
}
