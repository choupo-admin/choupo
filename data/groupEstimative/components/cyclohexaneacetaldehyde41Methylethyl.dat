/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexaneacetaldehyde, 4-(1-methylethyl)-  (C11H20O, CAS 93981-63-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexaneacetaldehyde41Methylethyl;
formula     C11H20O;
CAS         93981-63-6;
InChIKey    DTUMUCFHNCPJHZ-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          717.90;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.5051;      // -   [origin=predictive method=lee-kesler]
Tb          514.38;      // K   [origin=predictive method=joback]
HvapTb      46532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.059 1.12484 -0.0005964 9.85e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-propan-2-ylcyclohexyl)ethanal" "4-(isopropyl)cyclohexaneacetaldehyde" "2-(4-propan-2-ylcyclohexyl)acetaldehyde" );
standardThermochemistry
{
    dHf_298   -327250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43480.0
}
