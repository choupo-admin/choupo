/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-diethylphenyl isocyanate  (C11H13NO, CAS 20458-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiethylphenylIsocyanate;
formula     C11H13NO;
CAS         20458-99-5;
InChIKey    AUSRFKVPUCQCCN-UHFFFAOYSA-N;
MW          175.231;      // g/mol [origin=calculated method=formula-sum]
Tc          767.28;      // K   [origin=predictive method=joback]
Pc          27.730;      // bar [origin=predictive method=joback]
omega       0.6171;      // -   [origin=predictive method=lee-kesler]
Tb          554.59;      // K   [origin=predictive method=joback]
HvapTb      53212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCd; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diethyl-2-isocyanato-benzene" "1,3-diethyl-2-isocyanatobenzene" "2,6-diethylbenzenisocyanate" "2,6-diethylphenylisocyanate" "benzene,1,3-diethyl-2-isocyanato-" "isocyanicacid, 2,6-diethylphenyl ester (7ci,8ci); 1,3-diethyl-2-isocyanatobenzene;2,6-diethylphenyl isocyanate" );
