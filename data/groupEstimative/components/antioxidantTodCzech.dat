/*--------------------------------*- Choupo -*-----------------------*\
  Component: antioxidant tod [czech]  (C31H48O2, CAS 19546-20-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        antioxidantTodCzech;
formula     C31H48O2;
CAS         19546-20-4;
InChIKey    WBGDNDKJQZGXRE-UHFFFAOYSA-N;
MW          452.723;      // g/mol [origin=calculated method=formula-sum]
Tc          1376.18;      // K   [origin=predictive method=joback]
Pc          9.723;      // bar [origin=predictive method=joback]
omega       0.9395;      // -   [origin=predictive method=lee-kesler]
Tb          1123.75;      // K   [origin=predictive method=joback]
HvapTb      112616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.762 3.35876 -0.00261904 8.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 6; } { group C; count 3; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 8; } { group C; count 3; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,2-diethylbutyl)-5-[2-[3-(2,2-diethylbutyl)-4-oxidanyl-phenyl]propan-2-yl]phenol" "2-(2,2-diethylbutyl)-4-{2-[4-(2,2-diethylbutyl)-3-hydroxyphenyl]propan-2-yl}phenol" "propane, 2,2-bis(3'-t-octyl-4'-hydroxyphenyl)-" "antioxidant tod" "2,2-bis-3'-terc.oktyl-4'-hydroxyfenylpropan" "2-(2,2-diethylbutyl)-5-[2-[3-(2,2-diethylbutyl)-4-hydroxyphenyl]propan-2-yl]phenol" );
standardThermochemistry
{
    dHf_298   -613920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1074.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114980.0
}
