/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl prop-2-enoate; methyl 2-methylprop-2-enoate; prop-2-enyl 2-methylprop-2-enoate; styrene  (C27H38O6, CAS 51252-07-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylProp2EnoateMethyl2Methylprop2EnoateProp2Enyl2Methylprop;
formula     C27H38O6;
CAS         51252-07-4;
InChIKey    DOJLMPGHBACAEM-UHFFFAOYSA-N;
MW          458.595;      // g/mol [origin=calculated method=formula-sum]
Tc          1233.27;      // K   [origin=predictive method=joback]
Pc          8.126;      // bar [origin=predictive method=joback]
omega       0.7661;      // -   [origin=predictive method=lee-kesler]
Tb          1006.06;      // K   [origin=predictive method=joback]
HvapTb      97885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (128.784 1.60678 -6.71e-05 -3.967e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH2=CH; count 3; } { group CH2=C; count 2; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH2; count 5; } { group dCH; count 3; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;ethenylbenzene;methyl 2-methylprop-2-enoate;prop-2-enyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, methyl ester, polymer with butyl 2-propenoate, ethenylbenzene and 2-propenyl 2-methyl-2-propenoate" );
gibbsFormation
{
    dHf_298   -1043210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1546.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-534420.0
    phase     gas;
}
