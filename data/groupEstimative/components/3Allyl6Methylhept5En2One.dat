/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-allyl-6-methylhept-5-en-2-one  (C11H18O, CAS 2633-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Allyl6Methylhept5En2One;
formula     C11H18O;
CAS         2633-95-6;
InChIKey    KRYSMAVDGZCJFJ-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          694.95;      // K   [origin=predictive method=joback]
Pc          22.590;      // bar [origin=predictive method=joback]
omega       0.5522;      // -   [origin=predictive method=lee-kesler]
Tb          505.43;      // K   [origin=predictive method=joback]
HvapTb      45806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.298 1.02666 -0.0006681 1.7676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-3-prop-2-enyl-hept-5-en-2-one" "5-hepten-2-one, 6-methyl-3-(2-propenyl)-" "5-hepten-2-one, 6-methyl-3-(2-propen-1-yl)-" "6-methyl-3-prop-2-enylhept-5-en-2-one" "6-methyl-3-(prop-2-en-1-yl)hept-5-en-2-one" );
gibbsFormation
{
    dHf_298   -155370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69890.0
    phase     gas;
}
