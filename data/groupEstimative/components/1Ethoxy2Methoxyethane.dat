/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-Ethoxy-2-methoxyethane  (C5H12O2, CAS 5137-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxy2Methoxyethane;
formula     C5H12O2;
CAS         5137-45-1;
InChIKey    CAQYAZNFWDDMIT-UHFFFAOYSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          524.38;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.4043;      // -   [origin=predictive method=lee-kesler]
Tb          358.84;      // K   [origin=predictive method=joback]
HvapTb      31544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.343 0.35244 -2.62e-05 -6.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-Methoxyethoxy)ethane" "2-ethoxy-1-methoxyethane" "ethane, 1-ethoxy-2-methoxy-" "ethyl 2-methoxyethyl ether" "ethylene glycol ethyl methyl ether" "2,5-dioxaheptane" "1-ethoxy-2-methoxy-ethane" "AS-87303" "DB-051953" "NS00045456" );
gibbsFormation
{
    dHf_298   -410970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-218780.0
    phase     gas;
}
