/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-chloroethyl)-1,1-dimethylurea  (C5H11ClN2O, CAS 71162-62-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32Chloroethyl11Dimethylurea;
formula     C5H11ClN2O;
CAS         71162-62-4;
InChIKey    VMJXYAOXDCSUBQ-UHFFFAOYSA-N;
MW          150.606;      // g/mol [origin=calculated method=formula-sum]
Tc          655.91;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.6644;      // -   [origin=predictive method=lee-kesler]
Tb          467.91;      // K   [origin=predictive method=joback]
HvapTb      46334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.692 0.65774 -0.0004111 9.616e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH; count 1; } { group CH2Cl; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group Cl; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-chloroethyl)-1,1-dimethyl-urea" "urea, 3-(2-chloroethyl)-1,1-dimethyl-" );
gibbsFormation
{
    dHf_298   -153850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50540.0
    phase     gas;
}
