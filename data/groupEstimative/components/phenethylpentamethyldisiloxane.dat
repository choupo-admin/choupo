/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethylpentamethyldisiloxane  (C13H24OSi2, CAS 3439-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H24OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        phenethylpentamethyldisiloxane;
formula     C13H24OSi2;
CAS         3439-15-4;
InChIKey    STJDVFLIFYPTDX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          252.504;      // g/mol [origin=calculated method=formula-sum]
Tc          756.59;      // K   [origin=predictive method=joback]
Pc          17.477;      // bar [origin=predictive method=joback]
omega       0.4084;      // -   [origin=predictive method=lee-kesler]
Tb          548.94;      // K   [origin=predictive method=joback]
HvapTb      49806.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.302 0.6844 0.000226 -3.202e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl-(2-phenylethyl)-trimethylsilyloxy-silane" "disiloxane, pentamethyl(2-phenylethyl)-" "disiloxane, 1,1,1,3,3-pentamethyl-3-(2-phenylethyl)-" "dimethyl-phenethyl-trimethylsilyloxysilane" );
gibbsFormation
{
    dHf_298   -430580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     820.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143530.0
    phase     gas;
}
