/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxy, trifluoro-  (CF3O, CAS 21811-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        methoxyTrifluoro;
formula     CF3O;
CAS         21811-29-0;
InChIKey    KALJDHMOUFYADP-UHFFFAOYSA-N;
role        radical;
MW          85.004;      // g/mol [origin=calculated method=formula-sum]
Tc          324.98;      // K   [origin=predictive method=joback]
Pc          57.654;      // bar [origin=predictive method=joback]
omega       0.2830;      // -   [origin=predictive method=lee-kesler]
Tb          205.86;      // K   [origin=predictive method=joback]
HvapTb      19835.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.81 0.3827 -0.0004463 1.802e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group C; count 1; } { group F; count 3; } { group dO_oth; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(fluoranyl)-$l^{1}-oxidanyl-methane" "cf3o" "(trifluoromethyl)oxidanyl" );
gibbsFormation
{
    dHf_298   -852850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     310.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-822500.0
    phase     gas;
}
