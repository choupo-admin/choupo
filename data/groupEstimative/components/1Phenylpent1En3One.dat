/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylpent-1-en-3-one  (C11H12O, CAS 3152-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenylpent1En3One;
formula     C11H12O;
CAS         3152-68-9;
InChIKey    LVGUHATVVHIJET-UHFFFAOYSA-N;
MW          160.216;      // g/mol [origin=calculated method=formula-sum]
Tc          757.43;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.5285;      // -   [origin=predictive method=lee-kesler]
Tb          535.99;      // K   [origin=predictive method=joback]
HvapTb      49060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.839 0.96192 -0.0006709 1.8356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl styryl ketone" "styryl ethyl ketone" "ethyl 2-phenylvinyl ketone" "1-penten-3-one,1-phenyl-" "1-penten-3-one, 1-phenyl- (8ci)(9ci)" );
standardThermochemistry
{
    dHf_298   -29200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105450.0
}
