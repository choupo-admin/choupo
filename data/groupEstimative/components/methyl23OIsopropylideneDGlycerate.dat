/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,3-o-isopropylidene-d-glycerate  (C7H12O4, CAS 52373-72-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl23OIsopropylideneDGlycerate;
formula     C7H12O4;
CAS         52373-72-5;
InChIKey    DOWWCCDWPKGNGX-RXMQYKEDSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          692.56;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.5051;      // -   [origin=predictive method=lee-kesler]
Tb          482.73;      // K   [origin=predictive method=joback]
HvapTb      46400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.96 1.00516 -0.0008392 3.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (4r)-2,2-dimethyl-1,3-dioxolane-4-carboxylate" "methyl (r)-(+)-2,2-dimethyl-1,3-dioxolane-4-carboxylate" "(r)-2,2-dimethyl-[1,3]dioxolane-4-carboxylic acid methyl ester" "(r)-(+)-2,2-dimethyl-1,3-dioxolane-4-carboxylic acid methyl ester" "2,2-dimethyl-(4r)-1,3-dioxolane-4-carboxylic acid methyl ester" "(r)-methyl 2,2-dimethyl-1,3-dioxolane-4-carboxylate" "methyl(r)-(+)-2,2-dimethyl-1,3-dioxolane-4-carboxylate" "dowwccdwpkgngx-rxmqykedsa-" "n775" "methyl alpha,beta-isopropylidene-d-glycerate" "(+)-methyl 2,3-o-isopropylidene-d-glycerate" "alpha,beta-isopropylidene-d-glyceric acid methyl ester" );
gibbsFormation
{
    dHf_298   -713710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-451200.0
    phase     gas;
}
