/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-methoxyphenyl)acetamide  (C9H11NO2, CAS 6343-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24MethoxyphenylAcetamide;
formula     C9H11NO2;
CAS         6343-93-7;
InChIKey    OLKQIWCQICCYQS-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          812.39;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.7349;      // -   [origin=predictive method=lee-kesler]
Tb          586.00;      // K   [origin=predictive method=joback]
HvapTb      58363.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.451 0.69112 -0.00034366 4.366e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methoxyphenyl)ethanamide" "p-methoxyphenylacetamide" "4-methoxyphenylacetamide" "benzeneacetamide, 4-methoxy-" "4-methoxyphenoxyphenylacetamide" "benzeneacetamide,4-methoxy-" "zhz" );
gibbsFormation
{
    dHf_298   -215040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39790.0
    phase     gas;
}
