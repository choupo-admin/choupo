/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-azabicyclo[4.2.1]nona-2,4-diene  (C8H11N, CAS 7129-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Azabicyclo421Nona24Diene;
formula     C8H11N;
CAS         7129-31-9;
InChIKey    REILICYQYHWFDU-UHFFFAOYSA-N;
MW          121.183;      // g/mol [origin=calculated method=formula-sum]
Tc          687.58;      // K   [origin=predictive method=joback]
Pc          41.409;      // bar [origin=predictive method=joback]
omega       0.3472;      // -   [origin=predictive method=lee-kesler]
Tb          455.80;      // K   [origin=predictive method=joback]
HvapTb      41086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.75 0.9114 -0.00062656 1.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 2; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-azabicyclo(4.2.1)nona-2,4-diene" "9-azabicyclo[4.2.1]nona-2,4-diene(6ci,8ci,9ci)" );
gibbsFormation
{
    dHf_298   72040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     265.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249310.0
    phase     gas;
}
