/*--------------------------------*- Choupo -*-----------------------*\
  Component: amlure  (C12H14O4, CAS 24902-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amlure;
formula     C12H14O4;
CAS         24902-02-1;
InChIKey    GIWVWMBTCWHKMO-UHFFFAOYSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          851.32;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.7577;      // -   [origin=predictive method=lee-kesler]
Tb          628.95;      // K   [origin=predictive method=joback]
HvapTb      61756.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.938 1.08592 -0.00064456 1.271e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl 2,3-dihydro-1,4-benzodioxine-3-carboxylate" "propyl 1,4-benzodioxan-2-carboxylate" "1,4-benzodioxan-2-carboxylic acid, propyl ester" "1,4-benzodioxin-2-carboxylic acid, 2,3-dihydro-, propyl ester" "1,4-benzodioxin-2-carboxylicacid, 2,3-dihydro-, propyl ester" "1,4-benzodioxin-2-carboxylic acid, 2,3-dihydro-, propyl ester (9ci)" "1,4-benzodioxan-2-carboxylicacid, propyl ester (8ci); amlure; propyl 1,4-benzodioxan-2-carboxylate" );
gibbsFormation
{
    dHf_298   -580590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-281020.0
    phase     gas;
}
