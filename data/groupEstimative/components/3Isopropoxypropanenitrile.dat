/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-isopropoxypropanenitrile  (C6H11NO, CAS 110-47-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Isopropoxypropanenitrile;
formula     C6H11NO;
CAS         110-47-4;
InChIKey    BMSYXLRQGIFLFO-UHFFFAOYSA-N;
MW          113.16;      // g/mol [origin=calculated method=formula-sum]
Tc          653.40;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.5114;      // -   [origin=predictive method=lee-kesler]
Tb          460.94;      // K   [origin=predictive method=joback]
HvapTb      41450.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.252 0.45134 -0.0001638 -1.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-propan-2-yloxypropanenitrile" "3-isopropoxypropionitrile" "beta-isopropoxypropionitrile" "propanenitrile, 3-(1-methylethoxy)-" "propionitrile, 3-isopropoxy-" "3-isopropoxypropiononitrile" "3-(methylethoxy)propanenitrile" "propionitrile, 3-isopropoxy-;" );
gibbsFormation
{
    dHf_298   -139790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25380.0
    phase     gas;
}
