/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-1,5-dimethyl-1,3-cyclohexadiene  (C9H14O, CAS 98677-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy15Dimethyl13Cyclohexadiene;
formula     C9H14O;
CAS         98677-98-6;
InChIKey    SNEXTYOVZVMOCT-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          660.61;      // K   [origin=predictive method=joback]
Pc          29.155;      // bar [origin=predictive method=joback]
omega       0.3882;      // -   [origin=predictive method=lee-kesler]
Tb          455.77;      // K   [origin=predictive method=joback]
HvapTb      40375.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.24 0.68676 -0.00027628 9.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=C; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxy-1,5-dimethyl-cyclohexa-1,3-diene" "3-methoxy-1,5-dimethylcyclohexa-1,3-diene" );
standardThermochemistry
{
    dHf_298   -214370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14990.0
}
