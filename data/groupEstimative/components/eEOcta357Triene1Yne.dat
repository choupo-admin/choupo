/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e),(e)-octa-3,5,7-triene-1-yne  (C8H6, CAS 53477-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eEOcta357Triene1Yne;
formula     C8H6;
CAS         53477-04-6;
InChIKey    ZFZDQOLMOIFFRX-KQQUZDAGSA-N;
MW          102.136;      // g/mol [origin=calculated method=formula-sum]
Tc          580.78;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       0.2000;      // -   [origin=predictive method=lee-kesler]
Tb          371.20;      // K   [origin=predictive method=joback]
HvapTb      33034.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.19 0.616 -0.00057086 2.1558e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 4; } { group tCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,5e)-octa-3,5-dien-1,7-diyne" "(e),(e)-hc.equiv.cch=chch=chc.equiv.ch" );
standardThermochemistry
{
    dHf_298   609790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=623060.0
}
