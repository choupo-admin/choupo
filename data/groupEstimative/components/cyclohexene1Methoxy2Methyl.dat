/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 1-methoxy-2-methyl-  (C8H14O, CAS 1728-38-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene1Methoxy2Methyl;
formula     C8H14O;
CAS         1728-38-7;
InChIKey    YSAZFHDEUZHTIM-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          644.02;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.3683;      // -   [origin=predictive method=lee-kesler]
Tb          438.40;      // K   [origin=predictive method=joback]
HvapTb      38166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.05 0.67424 -0.00029 2.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH3O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methoxy-2-methyl-cyclohexene" "agn-pc-00cf3q" );
gibbsFormation
{
    dHf_298   -231170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-45660.0
    phase     gas;
}
