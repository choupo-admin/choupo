/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-(3,5-di-sec-butylcyclopent-1-enyl)-2,3,5-trihydroxyvaleric acid  (C18H32O5, CAS 491-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        535DiSecButylcyclopent1Enyl235TrihydroxyvalericAcid;
formula     C18H32O5;
CAS         491-14-5;
InChIKey    RKOUCPMGBBKLNK-UHFFFAOYSA-N;
MW          328.449;      // g/mol [origin=calculated method=formula-sum]
Tc          1288.58;      // K   [origin=predictive method=joback]
Pc          17.758;      // bar [origin=predictive method=joback]
omega       1.4029;      // -   [origin=predictive method=lee-kesler]
Tb          1046.04;      // K   [origin=predictive method=joback]
HvapTb      121825.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.877 1.88588 -0.00112744 2.485e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 7; } { group CH=C; count 1; } { group OH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 5; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[3,5-di(butan-2-yl)cyclopenten-1-yl]-2,3,5-tris(oxidanyl)pentanoic acid" "indoleacetic acids" "5-(3,5-dibutan-2-yl-1-cyclopentenyl)-2,3,5-trihydroxy-pentanoic acid" "5-[3,5-di(butan-2-yl)cyclopenten-1-yl]-2,3,5-trihydroxypentanoic acid" );
gibbsFormation
{
    dHf_298   -1161760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     878.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-616720.0
    phase     gas;
}
