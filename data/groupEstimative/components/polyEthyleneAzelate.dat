/*--------------------------------*- Choupo -*-----------------------*\
  Component: poly(ethylene azelate)  (C11H22O6, CAS 26760-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polyEthyleneAzelate;
formula     C11H22O6;
CAS         26760-99-6;
InChIKey    HPXYFPBBKMWIFM-UHFFFAOYSA-N;
MW          250.291;      // g/mol [origin=calculated method=formula-sum]
Tc          1136.26;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       1.8017;      // -   [origin=predictive method=lee-kesler]
Tb          928.06;      // K   [origin=predictive method=joback]
HvapTb      108060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.489 1.0122 -0.0003658 -2.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group COOH; count 2; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;nonanedioic acid" );
gibbsFormation
{
    dHf_298   -1386990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     900.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1024480.0
    phase     gas;
}
