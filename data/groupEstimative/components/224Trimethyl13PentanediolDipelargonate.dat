/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4-trimethyl-1,3-pentanediol dipelargonate  (C26H50O4, CAS 15721-83-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224Trimethyl13PentanediolDipelargonate;
formula     C26H50O4;
CAS         15721-83-2;
InChIKey    CYIXYIDXFMPPSQ-UHFFFAOYSA-N;
MW          426.682;      // g/mol [origin=calculated method=formula-sum]
Tc          1110.81;      // K   [origin=predictive method=joback]
Pc          7.429;      // bar [origin=predictive method=joback]
omega       0.6922;      // -   [origin=predictive method=lee-kesler]
Tb          906.81;      // K   [origin=predictive method=joback]
HvapTb      86212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.235 2.50192 -0.0013796 2.549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 13; } { group CH; count 2; } { group C; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 15; } { group CH; count 2; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,2,4-trimethyl-3-nonanoyloxy-pentyl) nonanoate" "2,2,4-trimethyl-1,3-pentanediol dinonanoate" "nonanoic acid, 1,1'-(2,2-dimethyl-1-(1-methylethyl)-1,3-propanediyl) ester" "nonanoic acid, 1,1'-[2,2-dimethyl-1-(1-methylethyl)-1,3-propanediyl] ester" "(2,2,4-trimethyl-3-nonanoyloxypentyl) nonanoate" "nonanoic acid, 2,2-dimethyl-1-(1-methylethyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -1233840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1213.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-454740.0
    phase     gas;
}
