/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(bromanyl)-2-(bromomethyl)-2-methyl-propane  (C5H9Br3, CAS 60111-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisBromanyl2Bromomethyl2MethylPropane;
formula     C5H9Br3;
CAS         60111-68-4;
InChIKey    DFEASKVNLCLOLT-UHFFFAOYSA-N;
MW          308.839;      // g/mol [origin=calculated method=formula-sum]
Tc          745.05;      // K   [origin=predictive method=joback]
Pc          46.151;      // bar [origin=predictive method=joback]
omega       0.5276;      // -   [origin=predictive method=lee-kesler]
Tb          509.25;      // K   [origin=predictive method=joback]
HvapTb      44733.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.557 0.71922 -0.0006342 2.225e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -76290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37020.0
    phase     gas;
}
