/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(azepan-1-yl)nonan-1-one  (C15H29NO, CAS 23410-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Azepan1YlNonan1One;
formula     C15H29NO;
CAS         23410-40-4;
InChIKey    JXSJWHXALVHMGE-UHFFFAOYSA-N;
MW          239.403;      // g/mol [origin=calculated method=formula-sum]
Tc          824.78;      // K   [origin=predictive method=joback]
Pc          17.970;      // bar [origin=predictive method=joback]
omega       0.8092;      // -   [origin=predictive method=lee-kesler]
Tb          633.33;      // K   [origin=predictive method=joback]
HvapTb      58511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.623 1.67332 -0.0010225 2.3346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH2_ring; count 6; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-azepanyl)-1-nonanone" "1-nonanone,1-(hexahydro-1h-azepin-1-yl)-" );
standardThermochemistry
{
    dHf_298   -323320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     794.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89440.0
}
