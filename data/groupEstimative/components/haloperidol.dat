/*--------------------------------*- Choupo -*-----------------------*\
  Component: haloperidol  (C21H23ClFNO2, CAS 52-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        haloperidol;
formula     C21H23ClFNO2;
CAS         52-86-8;
InChIKey    LNEPOXFFQSENCJ-UHFFFAOYSA-N;
MW          375.868;      // g/mol [origin=calculated method=formula-sum]
Tc          1185.08;      // K   [origin=predictive method=joback]
Pc          18.805;      // bar [origin=predictive method=joback]
omega       1.3410;      // -   [origin=predictive method=lee-kesler]
Tb          954.11;      // K   [origin=predictive method=joback]
HvapTb      96358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-144.947 2.2941 -0.00186802 6.3016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 8; } { group AC; count 2; } { group OH; count 1; } { group CH2CO; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group Cl; count 1; } { group OH; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4-(4-chlorophenyl)-4-oxidanyl-piperidin-1-yl]-1-(4-fluorophenyl)butan-1-one" "haldol" "eukystol" "serenace" "aloperidin" "aloperidol" "brotopon" "linton" "einalon s" "aloperidolo" "galoperidol" "halopoidol" );
gibbsFormation
{
    dHf_298   -360060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     926.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=860.0
    phase     gas;
}
