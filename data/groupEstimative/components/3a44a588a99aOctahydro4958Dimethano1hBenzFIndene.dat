/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3a,4,4a,5,8,8a,9,9a-octahydro-4,9:5,8-dimethano-1h-benz(f)indene  (C15H18, CAS 7158-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3a44a588a99aOctahydro4958Dimethano1hBenzFIndene;
formula     C15H18;
CAS         7158-25-0;
InChIKey    XCGKRTHKVBCXLN-UHFFFAOYSA-N;
MW          198.309;      // g/mol [origin=calculated method=formula-sum]
Tc          786.49;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.4714;      // -   [origin=predictive method=lee-kesler]
Tb          560.81;      // K   [origin=predictive method=joback]
HvapTb      48206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-228.58 1.9918 -0.00170156 5.876e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 8; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 8; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclopentadiene" "4,9:5,8-dimethano-1h-benz[f]indene, 3a,4,4a,5,8,8a,9,9a-octahydro-" "4,9:5,8-dimethano-1h-benz(f)indene, 3a,4,4a,5,8,8a,9,9a-octahydro-" "agn-pc-00qsnc" );
standardThermochemistry
{
    dHf_298   65610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     87.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=415960.0
}
