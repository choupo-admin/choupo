/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-ethylenebis(3-methylpiperidine)  (C14H28N2, CAS 67990-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Ethylenebis3Methylpiperidine;
formula     C14H28N2;
CAS         67990-20-9;
InChIKey    YAFHICXFCISWPA-UHFFFAOYSA-N;
MW          224.392;      // g/mol [origin=calculated method=formula-sum]
Tc          778.19;      // K   [origin=predictive method=joback]
Pc          20.549;      // bar [origin=predictive method=joback]
omega       0.6066;      // -   [origin=predictive method=lee-kesler]
Tb          575.36;      // K   [origin=predictive method=joback]
HvapTb      51358.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.188 1.84504 -0.0012178 3.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1-[2-(3-methylpiperidin-1-yl)ethyl]piperidine" "1,1'-ethylenebis[3-methylpiperidine]" "piperidine, 1,1'-(1,2-ethanediyl)bis(3-methyl-" "piperidine, 1,1'-(1,2-ethanediyl)bis[3-methyl-" "3-methyl-1-[2-(3-methyl-1-piperidyl)ethyl]piperidine" );
gibbsFormation
{
    dHf_298   -76270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=361660.0
    phase     gas;
}
