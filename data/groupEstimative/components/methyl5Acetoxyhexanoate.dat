/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl-5-acetoxyhexanoate  (C9H16O4, CAS 35234-22-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl5Acetoxyhexanoate;
formula     C9H16O4;
CAS         35234-22-1;
InChIKey    XZGQJRXRXRYNRI-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          701.52;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.7182;      // -   [origin=predictive method=lee-kesler]
Tb          521.52;      // K   [origin=predictive method=joback]
HvapTb      50054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.843 0.75516 -0.0002798 -1.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH3COO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 5-acetyloxyhexanoate" "methyl hexanoate, 5-acetoxy" "methyl 5-acetoxyhexanoate" "(+/-)-methyl 5-acetoxyhexanoate" "delta-acetoxycaproic acid methyl ester" "(+/-)-methyl 5-acetoxyhexanoate [fhfi]" "hexanoic acid,5-(acetyloxy)-, methyl ester" "hexanoic acid, 5-(acetyloxy)-, methyl ester" "methyl5-acetoxyhexanoate; d-acetoxycaproic acid methyl ester" );
gibbsFormation
{
    dHf_298   -868930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-598280.0
    phase     gas;
}
