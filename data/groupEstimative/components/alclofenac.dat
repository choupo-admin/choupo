/*--------------------------------*- Choupo -*-----------------------*\
  Component: alclofenac  (C11H11ClO3, CAS 22131-79-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alclofenac;
formula     C11H11ClO3;
CAS         22131-79-9;
InChIKey    ARHWPKZXBHOEEE-UHFFFAOYSA-N;
MW          226.656;      // g/mol [origin=calculated method=formula-sum]
Tc          912.65;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.9505;      // -   [origin=predictive method=lee-kesler]
Tb          689.96;      // K   [origin=predictive method=joback]
HvapTb      66969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.582 0.8253 -0.00047662 9.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-chloranyl-4-prop-2-enoxy-phenyl)ethanoic acid" "prinalgin" "mervan" "alclofenaco" "alclofenacum" "allopydin" "medifenac" "neosten" "neoston" "reufenac" "zumaril" "alclophenac" );
gibbsFormation
{
    dHf_298   -429580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238110.0
    phase     gas;
}
