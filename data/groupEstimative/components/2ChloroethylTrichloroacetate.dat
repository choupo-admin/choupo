/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloroethyl trichloroacetate  (C4H4Cl4O2, CAS 4974-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroethylTrichloroacetate;
formula     C4H4Cl4O2;
CAS         4974-21-4;
InChIKey    LZAFIYKPGDSKLN-UHFFFAOYSA-N;
MW          225.874;      // g/mol [origin=calculated method=formula-sum]
Tc          712.63;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.4884;      // -   [origin=predictive method=lee-kesler]
Tb          495.83;      // K   [origin=predictive method=joback]
HvapTb      48149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.752 0.482 -0.0003526 8.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2Cl; count 1; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group Cl; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloroethyl 2,2,2-tris(chloranyl)ethanoate" "2-chloroethyl 2,2,2-trichloroacetate" "acetic acid,2,2,2-trichloro-, 2-chloroethyl ester" );
standardThermochemistry
{
    dHf_298   -514880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-372450.0
}
