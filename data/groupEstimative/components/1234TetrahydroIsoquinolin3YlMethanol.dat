/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,2,3,4-tetrahydro-isoquinolin-3-yl)-methanol  (C10H13NO, CAS 63006-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234TetrahydroIsoquinolin3YlMethanol;
formula     C10H13NO;
CAS         63006-93-9;
InChIKey    ZSKDXMLMMQFHGW-UHFFFAOYSA-N;
MW          163.22;      // g/mol [origin=calculated method=formula-sum]
Tc          830.38;      // K   [origin=predictive method=joback]
Pc          39.555;      // bar [origin=predictive method=joback]
omega       0.9367;      // -   [origin=predictive method=lee-kesler]
Tb          611.80;      // K   [origin=predictive method=joback]
HvapTb      64314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.959 0.9773 -0.00062796 1.547e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrahydroisoquinolin-3-ylmethanol" "1,2,3,4-tetrahydroisoquinoline-3-methanol" "(1,2,3,4-tetrahydroisoquinolin-3-yl)methanol" "sdccgmls-0066261.p001" "rac 1,2,3,4-tetrahydroisoquinoline-3-methanol" "3-hydroxymethyl-1,2,3,4-tetrahydroisoquinoline" "3-hydroxymethyl-1,2,3,4-tetrahydro-isoquinoline" "3-(hydroxymethyl)isoquinoline;isoquinolin-3-ylmethanol;" "(3s)-3-(hydroxymethyl)-1,2,3,4-tetrahydroisoquinoline 97%" );
standardThermochemistry
{
    dHf_298   -72450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135640.0
}
