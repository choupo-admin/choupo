/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentane, 2,2,3,4,4-pentamethyl-  (C10H22, CAS 16747-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentane22344Pentamethyl;
formula     C10H22;
CAS         16747-45-8;
InChIKey    OWFKEHICSVOVAC-UHFFFAOYSA-N;
MW          142.286;      // g/mol [origin=calculated method=formula-sum]
Tc          609.55;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       0.2824;      // -   [origin=predictive method=lee-kesler]
Tb          421.50;      // K   [origin=predictive method=joback]
HvapTb      34874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.83 1.21144 -0.000867 2.511e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH; count 1; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 1; } { group C; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,4,4-pentamethylpentane" );
standardThermochemistry
{
    dHf_298   -272510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36560.0
}
