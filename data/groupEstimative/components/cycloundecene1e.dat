/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloundecene, (1e)-  (C11H20, CAS 13151-60-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloundecene1e;
formula     C11H20;
CAS         13151-60-5;
InChIKey    GMUVJAZTJOCSND-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          734.44;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.2858;      // -   [origin=predictive method=lee-kesler]
Tb          496.01;      // K   [origin=predictive method=joback]
HvapTb      41970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.48 1.0934 -0.00046628 1.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloundecene" "cycloundecene,(e)- (8ci); (e)-cycloundecene; trans-cycloundecene" );
gibbsFormation
{
    dHf_298   -168730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43360.0
    phase     gas;
}
