/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxyhex-4-enoic acid lactone  (C6H8O2, CAS 3393-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxyhex4EnoicAcidLactone;
formula     C6H8O2;
CAS         3393-34-8;
InChIKey    CBRZDGMGLYOALR-GORDUTHDSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          609.72;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.4222;      // -   [origin=predictive method=lee-kesler]
Tb          413.15;      // K   [origin=predictive method=joback]
HvapTb      37366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.24 0.61892 -0.0004521 1.315e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5e)-5-ethylideneoxolan-2-one" "2(3h)-furanone, 5-ethylidenedihydro-" "5-ethylidenedihydro-2(3h)-furanone" );
standardThermochemistry
{
    dHf_298   -315280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196810.0
}
