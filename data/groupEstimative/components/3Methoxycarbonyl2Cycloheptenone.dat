/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(methoxycarbonyl)-2-cycloheptenone  (C9H12O3, CAS 42205-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxycarbonyl2Cycloheptenone;
formula     C9H12O3;
CAS         42205-57-2;
InChIKey    GDTPFKPPIYKGSI-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          796.54;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.5692;      // -   [origin=predictive method=lee-kesler]
Tb          564.19;      // K   [origin=predictive method=joback]
HvapTb      49146.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.96 0.65922 -0.00013744 -8.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=C; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-oxidanylidenecycloheptene-1-carboxylate" "methyl 3-oxocycloheptene-1-carboxylate" "methyl 3-oxocyclohept-1-ene-1-carboxylate" "3-oxo-cycloheptene-1-carboxylic acid methyl ester" );
standardThermochemistry
{
    dHf_298   -569260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367670.0
}
