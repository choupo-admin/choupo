/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[4.2.0]octa-1,3,5,7-tetraene  (C8H6, CAS 4026-23-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo420Octa1357Tetraene;
formula     C8H6;
CAS         4026-23-7;
InChIKey    WHEATZOONURNGF-UHFFFAOYSA-N;
MW          102.136;      // g/mol [origin=calculated method=formula-sum]
Tc          644.08;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.3137;      // -   [origin=predictive method=lee-kesler]
Tb          420.60;      // K   [origin=predictive method=joback]
HvapTb      36682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.27 0.7564 -0.00068484 2.462e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(4.2.0)octa-1,3,5,7-tetraene" "benzocyclobutadiene" );
standardThermochemistry
{
    dHf_298   173690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     249.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229780.0
}
