/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-heptyne  (C9H16, CAS 23097-98-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3Heptyne;
formula     C9H16;
CAS         23097-98-5;
InChIKey    YVYHUBIXJLIYRU-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          610.02;      // K   [origin=predictive method=joback]
Pc          27.614;      // bar [origin=predictive method=joback]
omega       0.2680;      // -   [origin=predictive method=lee-kesler]
Tb          411.29;      // K   [origin=predictive method=joback]
HvapTb      36484.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.208 0.83488 -0.00054546 1.4678e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethylhept-3-yne" "3-heptyne,5,5-dimethyl-" );
gibbsFormation
{
    dHf_298   34460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230540.0
    phase     gas;
}
