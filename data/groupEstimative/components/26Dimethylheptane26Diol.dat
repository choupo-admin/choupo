/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethylheptane-2,6-diol  (C9H20O2, CAS 6257-51-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethylheptane26Diol;
formula     C9H20O2;
CAS         6257-51-8;
InChIKey    PREYRMMHKDIKLF-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          754.14;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       1.1965;      // -   [origin=predictive method=lee-kesler]
Tb          583.42;      // K   [origin=predictive method=joback]
HvapTb      66394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.657 1.17848 -0.0008702 2.593e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethyl-2,6-heptanediol" "preyrmmhkdiklf-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -551050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-243060.0
    phase     gas;
}
