/*--------------------------------*- Choupo -*-----------------------*\
  Component: cumyl allyl ether  (C12H16O, CAS 69856-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cumylAllylEther;
formula     C12H16O;
CAS         69856-00-4;
InChIKey    AZHRVNVMEODXMJ-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          731.56;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.4394;      // -   [origin=predictive method=lee-kesler]
Tb          516.71;      // K   [origin=predictive method=joback]
HvapTb      45026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.889 1.10754 -0.0007439 1.916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enoxypropan-2-ylbenzene" "benzene, (1-methyl-1-(2-propen-1-yloxy)ethyl)-" "benzene, [1-methyl-1-(2-propen-1-yloxy)ethyl]-" "2-(allyloxy)-2-phenylpropane" "(1-(allyloxy)-1-methylethyl)benzene" "benzene, (1-methyl-1-(2-propenyloxy)ethyl)-" );
standardThermochemistry
{
    dHf_298   -70020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148250.0
}
