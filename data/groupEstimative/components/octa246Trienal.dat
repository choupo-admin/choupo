/*--------------------------------*- Choupo -*-----------------------*\
  Component: octa-2,4,6-trienal  (C8H10O, CAS 17609-31-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octa246Trienal;
formula     C8H10O;
CAS         17609-31-3;
InChIKey    ZUZGMJKUENNLQL-UHFFFAOYSA-N;
MW          122.167;      // g/mol [origin=calculated method=formula-sum]
Tc          641.18;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.4474;      // -   [origin=predictive method=lee-kesler]
Tb          443.78;      // K   [origin=predictive method=joback]
HvapTb      39996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.53 0.79832 -0.0006558 2.241e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 6; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-octatrienal, (e,e,e)-" );
gibbsFormation
{
    dHf_298   57630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157620.0
    phase     gas;
}
