/*--------------------------------*- Choupo -*-----------------------*\
  Component: haloprogin  (C9H4Cl3IO, CAS 777-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        haloprogin;
formula     C9H4Cl3IO;
CAS         777-11-7;
InChIKey    CTETYYAZBPJBHE-UHFFFAOYSA-N;
MW          361.38;      // g/mol [origin=calculated method=formula-sum]
Tc          967.03;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.5469;      // -   [origin=predictive method=lee-kesler]
Tb          683.99;      // K   [origin=predictive method=joback]
HvapTb      66980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (97.121 0.4478 -0.00023534 3.778e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group CH2O; count 1; } { group ACCl; count 3; } { group I; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tC; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group I; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tris(chloranyl)-5-(3-iodanylprop-2-ynoxy)benzene" "mycanden" "halotex" "mycilan" "polik" "haloproginum" "haloprogina" "haloprogine" "aloprogen" "haloprogine [inn-french]" "haloproginum [inn-latin]" "m-1028 (meiji)" );
gibbsFormation
{
    dHf_298   142760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=228550.0
    phase     gas;
}
