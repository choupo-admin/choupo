/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,10-undecadiene  (C11H20, CAS 13688-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        110Undecadiene;
formula     C11H20;
CAS         13688-67-0;
InChIKey    VOSLXTGMYNYCPW-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          612.69;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       0.4988;      // -   [origin=predictive method=lee-kesler]
Tb          444.64;      // K   [origin=predictive method=joback]
HvapTb      38740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.093 1.0088 -0.0006204 1.545e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undeca-1,10-diene" "undecadiene, 1,10-" );
standardThermochemistry
{
    dHf_298   -19510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217420.0
}
