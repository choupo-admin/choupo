/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-naphthalenedimethanethiol  (C12H12S2, CAS 60948-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Naphthalenedimethanethiol;
formula     C12H12S2;
CAS         60948-99-4;
InChIKey    JKNPWHHGFOPCTJ-UHFFFAOYSA-N;
MW          220.348;      // g/mol [origin=calculated method=formula-sum]
Tc          927.79;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       0.5873;      // -   [origin=predictive method=lee-kesler]
Tb          655.50;      // K   [origin=predictive method=joback]
HvapTb      61020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.988 0.9968 -0.00070764 1.996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[8-(sulfanylmethyl)naphthalen-1-yl]methanethiol" "naphthalene,1,8-mercaptomethyl" "naphthalene, 1,8-mercaptomethyl-" "naphthalene-1,8-diyldimethanethiol" );
gibbsFormation
{
    dHf_298   190610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308740.0
    phase     gas;
}
