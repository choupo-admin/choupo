/*--------------------------------*- Choupo -*-----------------------*\
  Component: plastflow  (C38H76N2O2, CAS 110-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        plastflow;
formula     C38H76N2O2;
CAS         110-30-5;
InChIKey    RKISUIUJZGSLEV-UHFFFAOYSA-N;
MW          593.038;      // g/mol [origin=calculated method=formula-sum]
Tc          1792.99;      // K   [origin=predictive method=joback]
Pc          4.500;      // bar [origin=predictive method=joback]
omega       -0.3178;      // -   [origin=predictive method=lee-kesler]
Tb          1277.12;      // K   [origin=predictive method=joback]
HvapTb      126546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.356 3.71024 -0.0021032 4.4392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 32; } { group CONHCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 34; } { group CdO; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(octadecanoylamino)ethyl]octadecanamide" "n,n'-ethylenebis(stearamide)" "abril wax 10ds" "advawax" "acrowax c" "acrawax ct" "lubrol ea" "ethylenedistearamide" "ethylenebisstearoamide" "ethylenebis(stearamide)" "ethylenebis(stearylamide)" "n,n'-ethylenedistearamide" );
standardThermochemistry
{
    dHf_298   -945870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1770.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190020.0
}
