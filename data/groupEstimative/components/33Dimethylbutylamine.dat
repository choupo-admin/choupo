/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethylbutylamine  (C6H15N, CAS 15673-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethylbutylamine;
formula     C6H15N;
CAS         15673-00-4;
InChIKey    GPWHFPWZAPOYNO-UHFFFAOYSA-N;
MW          101.193;      // g/mol [origin=calculated method=formula-sum]
Tc          598.32;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       0.3745;      // -   [origin=predictive method=lee-kesler]
Tb          406.18;      // K   [origin=predictive method=joback]
HvapTb      38295.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.548 0.76156 -0.0005178 1.431e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbutan-1-amine" "1-butanamine, 3,3-dimethyl-" "3,3-dimethyl butylamine" "1-butanamine,3,3-dimethyl-" "3,3-dimethyl-butan-1-amine" );
standardThermochemistry
{
    dHf_298   -142130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68930.0
}
