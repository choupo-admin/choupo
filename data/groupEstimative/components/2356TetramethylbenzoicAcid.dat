/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetramethylbenzoic acid  (C11H14O2, CAS 2604-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356TetramethylbenzoicAcid;
formula     C11H14O2;
CAS         2604-45-7;
InChIKey    STIDRZRESMTQBD-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          863.20;      // K   [origin=predictive method=joback]
Pc          27.297;      // bar [origin=predictive method=joback]
omega       0.8229;      // -   [origin=predictive method=lee-kesler]
Tb          643.39;      // K   [origin=predictive method=joback]
HvapTb      62168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.78 0.78278 -0.00041024 7.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group ACCH3; count 4; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 2,3,5,6-tetramethyl-" "2,5,6-tetramethylbenzoic acid" "benzoic acid,3,5,6-tetramethyl-" "2,3,5,6-tetramethyl-benzoic acid" "benzoic acid,2,3,5,6-tetrachloro-" );
standardThermochemistry
{
    dHf_298   -429990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228280.0
}
