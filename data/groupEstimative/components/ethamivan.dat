/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethamivan  (C12H17NO3, CAS 304-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethamivan;
formula     C12H17NO3;
CAS         304-84-7;
InChIKey    BQJODPIMMWWMFC-UHFFFAOYSA-N;
MW          223.272;      // g/mol [origin=calculated method=formula-sum]
Tc          888.86;      // K   [origin=predictive method=joback]
Pc          28.874;      // bar [origin=predictive method=joback]
omega       1.0156;      // -   [origin=predictive method=lee-kesler]
Tb          675.17;      // K   [origin=predictive method=joback]
HvapTb      69457.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.378 1.19276 -0.00083242 2.3886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyl-3-methoxy-4-oxidanyl-benzamide" "vanillic acid diethylamide" "etamivan" "simaron" "n,n-diethylvanillamide" "analepticon" "cardiovamil" "cardiovanil" "corivanil" "diethamivan" "etamivanum" "ventilone" );
standardThermochemistry
{
    dHf_298   -420530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124820.0
}
