/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-heptadecanedione  (C17H32O2, CAS 64042-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Heptadecanedione;
formula     C17H32O2;
CAS         64042-18-8;
InChIKey    VZRNDOSIHXJXCH-UHFFFAOYSA-N;
MW          268.441;      // g/mol [origin=calculated method=formula-sum]
Tc          871.22;      // K   [origin=predictive method=joback]
Pc          13.477;      // bar [origin=predictive method=joback]
omega       0.9808;      // -   [origin=predictive method=lee-kesler]
Tb          696.30;      // K   [origin=predictive method=joback]
HvapTb      66928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.153 1.56284 -0.0008636 1.7302e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptadecane-2,4-dione" );
standardThermochemistry
{
    dHf_298   -619370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     871.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-165580.0
}
