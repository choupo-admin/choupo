/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,10,13-tetraoxa-7,16-diazacyclooctadecane-7,16-diaceticacid  (C16H30N2O8, CAS 72912-01-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        141013Tetraoxa716Diazacyclooctadecane716Diaceticacid;
formula     C16H30N2O8;
CAS         72912-01-7;
InChIKey    NCKZZTXKSYMGTD-UHFFFAOYSA-N;
MW          378.422;      // g/mol [origin=calculated method=formula-sum]
Tc          1307.20;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       1.5272;      // -   [origin=predictive method=lee-kesler]
Tb          1056.30;      // K   [origin=predictive method=joback]
HvapTb      110122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.308 1.9138 -0.0008338 1.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group FCH2O; count 4; } { group CH2N; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 12; } { group O_ring; count 4; } { group COOH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[16-(2-hydroxy-2-oxoethyl)-1,4,10,13-tetraoxa-7,16-diazacyclooctadec-7-yl]ethanoic acid" "1,10-diaza-4,7,13,16-tetraoxacyclooctadecane-n,n'-diaceticacid; dacda" "2,2'-(1,4,10,13-tetraoxa-7,16-diazacyclooctadecane-7,16-diyl)diacetic acid" "2-[10-(carboxymethyl)-4,7,13,16-tetraoxa-1,10-diazacyclooctadecyl]acetic acid" "2-[16-(carboxymethyl)-1,4,10,13-tetraoxa-7,16-diazacyclooctadec-7-yl]acetic acid" );
standardThermochemistry
{
    dHf_298   -1453990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     923.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-815740.0
}
