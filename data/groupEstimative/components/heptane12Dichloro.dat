/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptane, 1,2-dichloro-  (C7H14Cl2, CAS 10575-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptane12Dichloro;
formula     C7H14Cl2;
CAS         10575-87-8;
InChIKey    WBCSJABQCRFUCP-UHFFFAOYSA-N;
MW          169.089;      // g/mol [origin=calculated method=formula-sum]
Tc          617.11;      // K   [origin=predictive method=joback]
Pc          26.137;      // bar [origin=predictive method=joback]
omega       0.4371;      // -   [origin=predictive method=lee-kesler]
Tb          434.18;      // K   [origin=predictive method=joback]
HvapTb      39558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.625 0.68832 -0.000401 8.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)heptane" );
standardThermochemistry
{
    dHf_298   -224570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18240.0
}
