/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2(or 4)-sec-docosyl-  (C28H50O, CAS 233587-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol2Or4SecDocosyl;
formula     C28H50O;
CAS         233587-35-4;
InChIKey    GQNCKPHQJKXIBF-UHFFFAOYSA-N;
MW          402.707;      // g/mol [origin=calculated method=formula-sum]
Tc          1159.58;      // K   [origin=predictive method=joback]
Pc          8.560;      // bar [origin=predictive method=joback]
omega       0.8262;      // -   [origin=predictive method=lee-kesler]
Tb          947.10;      // K   [origin=predictive method=joback]
HvapTb      92824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.071 2.74544 -0.00179016 4.801e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 19; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 19; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-docosan-2-ylphenol" );
gibbsFormation
{
    dHf_298   -567310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1157.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140230.0
    phase     gas;
}
