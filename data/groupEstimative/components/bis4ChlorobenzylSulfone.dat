/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis[4-chlorobenzyl]sulfone  (C14H12Cl2O2S, CAS 84355-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H12Cl2O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bis4ChlorobenzylSulfone;
formula     C14H12Cl2O2S;
CAS         84355-05-5;
InChIKey    JEVYVLLSVHNREX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          315.208;      // g/mol [origin=calculated method=formula-sum]
Tc          857.86;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.8045;      // -   [origin=predictive method=lee-kesler]
Tb          637.10;      // K   [origin=predictive method=joback]
HvapTb      73222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.628 1.1098 -0.00068152 1.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCl; count 2; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-[(4-chlorophenyl)methylsulfonylmethyl]benzene" "benzene, 1,1'-[sulfonylbis(methylene)]bis[4-chloro-" "1-chloro-4-[(4-chlorophenyl)methylsulfonylmethyl]benzene" );
standardThermochemistry
{
    dHf_298   -408870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252960.0
}
