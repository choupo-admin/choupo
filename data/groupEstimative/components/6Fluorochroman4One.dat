/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-fluorochroman-4-one  (C9H7FO2, CAS 66892-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Fluorochroman4One;
formula     C9H7FO2;
CAS         66892-34-0;
InChIKey    SWBBIJZMIGAZHW-UHFFFAOYSA-N;
MW          166.151;      // g/mol [origin=calculated method=formula-sum]
Tc          791.46;      // K   [origin=predictive method=joback]
Pc          38.483;      // bar [origin=predictive method=joback]
omega       0.5582;      // -   [origin=predictive method=lee-kesler]
Tb          551.88;      // K   [origin=predictive method=joback]
HvapTb      47562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.06 0.6692 -0.00035062 5.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH2CO; count 1; } { group FCH2O; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-fluoranyl-2,3-dihydrochromen-4-one" "6-fluoro-4-chromanone" "6-fluorochromano-4-one" "6-fluorochromanone" "6-fluoro-4-oxochroman" "6-fluoro-2,3-dihydro-4h-1-benzopyran-4-one" "6-fluoro-2,3-dihydro-4h-chromen-4-one" "2,3-dihydro-6-fluoro-4h-chromen-4-one" "6-fluoro-2,3-dihydro-1-benzopyran-4-one" "2,3-dihydro-6-fluoro-4h-1-benzopyran-4-one" "6-fluoro-3,4-dihydro-2h-1-benzopyran-4-one" "6-fluoro-chroman-4-one" );
standardThermochemistry
{
    dHf_298   -394330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     261.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-229110.0
}
