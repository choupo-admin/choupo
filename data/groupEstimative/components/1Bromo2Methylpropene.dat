/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-methylpropene  (C4H7Br, CAS 3017-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Methylpropene;
formula     C4H7Br;
CAS         3017-69-4;
InChIKey    DEFNUDNHTUZJAL-UHFFFAOYSA-N;
MW          135.004;      // g/mol [origin=calculated method=formula-sum]
Tc          561.56;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       0.2677;      // -   [origin=predictive method=lee-kesler]
Tb          361.32;      // K   [origin=predictive method=joback]
HvapTb      30971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.43 0.44194 -0.0003513 1.197e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-methyl-prop-1-ene" "isocrotyl bromide" "1-bromo-2-methyl-1-propene" "1-bromo-2-methylprop-1-ene" ".beta.,.beta.-dimethylvinylbromide" "2-methyl-1-propenyl bromide" "beta,beta-dimethylvinylbromide" "propene, 1-bromo-2-methyl-" "1-propene, 1-bromo-2-methyl-" "propene, 1-bromo-2-methyl- (8ci)" "1-propene, 1-bromo-2-methyl- (9ci)" );
gibbsFormation
{
    dHf_298   7870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68790.0
    phase     gas;
}
