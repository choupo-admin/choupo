/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-ethylcyclohexylamine  (C8H17N, CAS 5459-93-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nEthylcyclohexylamine;
formula     C8H17N;
CAS         5459-93-8;
InChIKey    AGVKXDPPPSLISR-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          656.75;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.4184;      // -   [origin=predictive method=lee-kesler]
Tb          452.36;      // K   [origin=predictive method=joback]
HvapTb      40267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.199 0.96212 -0.000541 1.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethylcyclohexanamine" "cyclohexanamine, n-ethyl-" "n-cyclohexylethylamine" "vulkacit hx" "cyclohexylamine, n-ethyl-" "accelerator hx" "cyclohexyl(ethyl)amine" "(ethylamino)cyclohexane" "n-ethyl(cyclohexyl)amine" "cyclohexane, (ethylamino)-" "n-ethyl cyclohexylamine" "cyclohexyl-ethyl-amine" );
gibbsFormation
{
    dHf_298   -100660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130320.0
    phase     gas;
}
