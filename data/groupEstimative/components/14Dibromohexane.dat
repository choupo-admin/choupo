/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromohexane  (C6H12Br2, CAS 25118-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromohexane;
formula     C6H12Br2;
CAS         25118-28-9;
InChIKey    PZPWGUJTIZXBKR-UHFFFAOYSA-N;
MW          243.97;      // g/mol [origin=calculated method=formula-sum]
Tc          675.01;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.5175;      // -   [origin=predictive method=lee-kesler]
Tb          468.76;      // K   [origin=predictive method=joback]
HvapTb      41432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.134 0.65612 -0.0004486 1.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)hexane" );
standardThermochemistry
{
    dHf_298   -119790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25840.0
}
