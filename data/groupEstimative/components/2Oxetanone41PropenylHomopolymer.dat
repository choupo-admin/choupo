/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxetanone, 4-(1-propenyl)-, homopolymer  (C6H8O2, CAS 63450-12-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Oxetanone41PropenylHomopolymer;
formula     C6H8O2;
CAS         63450-12-4;
InChIKey    JYGDLXCKZZOZAZ-NSCUHMNNSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          592.35;      // K   [origin=predictive method=joback]
Pc          37.546;      // bar [origin=predictive method=joback]
omega       0.4096;      // -   [origin=predictive method=lee-kesler]
Tb          401.73;      // K   [origin=predictive method=joback]
HvapTb      36056.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.46 0.69952 -0.0005584 1.797e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(e)-prop-1-enyl]oxetan-2-one" "2-oxetanone, 4-(1-propen-1-yl)-, homopolymer" );
gibbsFormation
{
    dHf_298   -288270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157660.0
    phase     gas;
}
