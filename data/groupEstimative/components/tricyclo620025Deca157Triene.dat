/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[6.2.0.02,5]deca-1,5,7-triene  (C10H10, CAS 58436-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo620025Deca157Triene;
formula     C10H10;
CAS         58436-35-4;
InChIKey    AMEHDLQPXQOMQW-UHFFFAOYSA-N;
MW          130.19;      // g/mol [origin=calculated method=formula-sum]
Tc          711.45;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.4343;      // -   [origin=predictive method=lee-kesler]
Tb          484.30;      // K   [origin=predictive method=joback]
HvapTb      42216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.33 1.0704 -0.00099428 3.734e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(6.2.0.02,5)deca-1,5,7-triene" );
gibbsFormation
{
    dHf_298   150990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     284.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=277960.0
    phase     gas;
}
