/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butoxyethyl acetate  (C8H16O3, CAS 112-07-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButoxyethylAcetate;
formula     C8H16O3;
CAS         112-07-2;
InChIKey    NQBXSWAWVZHKBZ-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          634.77;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.6272;      // -   [origin=predictive method=lee-kesler]
Tb          463.28;      // K   [origin=predictive method=joback]
HvapTb      43219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.525 0.64584 -0.0002058 -2.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH3COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butoxyethyl ethanoate" "ethylene glycol monobutyl ether acetate" "butyl glycol acetate" "butyl cellosolve acetate" "butoxyethyl acetate" "butylglycol acetate" "ethanol, 2-butoxy-, acetate" "egbea" "ektasolve eb acetate" "butylcellosolve acetate" "n-butoxyethanol acetate" "2-butoxyethanol acetate" );
gibbsFormation
{
    dHf_298   -657950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-398890.0
    phase     gas;
}
