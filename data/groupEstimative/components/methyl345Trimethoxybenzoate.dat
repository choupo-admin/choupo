/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,4,5-trimethoxybenzoate  (C11H14O5, CAS 1916-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl345Trimethoxybenzoate;
formula     C11H14O5;
CAS         1916-07-0;
InChIKey    KACHFMOHOPLTNX-UHFFFAOYSA-N;
MW          226.228;      // g/mol [origin=calculated method=formula-sum]
Tc          822.00;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.8253;      // -   [origin=predictive method=lee-kesler]
Tb          618.38;      // K   [origin=predictive method=joback]
HvapTb      58979.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (103.79 0.54708 2.292e-05 -1.51e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl tri-o-methylgallate" "benzoic acid, 3,4,5-trimethoxy-, methyl ester" "trimethylgallic acid methyl ester" "3,4,5-trimethoxybenzoic acid methyl ester" "3,4,5-trimethoxybenzoic acid, methyl ester" "methyl 3,4,5-trimethoxy benzoate" "methyl 3,5-trimethoxybenzoate" "methyl3,4,5-trimethoxybenzoate" "3,5-trimethoxybenzoic acid methyl ester" "3,5-trimethoxybenzoic acid, methyl ester" "methyl-3,4,5-trimethoxy benzoate" "benzoic acid,4,5-trimethoxy-, methyl ester" );
standardThermochemistry
{
    dHf_298   -782190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-500110.0
}
