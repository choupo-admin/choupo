/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonylamine  (C9H21N, CAS 112-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonylamine;
formula     C9H21N;
CAS         112-20-9;
InChIKey    FJDUDHYHRVPMJZ-UHFFFAOYSA-N;
MW          143.274;      // g/mol [origin=calculated method=formula-sum]
Tc          653.95;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       0.6237;      // -   [origin=predictive method=lee-kesler]
Tb          478.05;      // K   [origin=predictive method=joback]
HvapTb      46269.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.198 0.92072 -0.0005092 1.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonan-1-amine" "1-nonanamine" "1-aminononane" "n-nonylamine" "1-nonylamine" "nonyl-amine" "2016-39-9 (hydrochloride)" "72060-14-1 (sulfate[2:1])" "nonylamine(6ci,7ci,8ci);1-aminononane;1-nonylamine;monononylamine;n-nonylamine;" );
standardThermochemistry
{
    dHf_298   -195300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=91350.0
}
