/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl heptanoate  (C8H16O2, CAS 106-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylHeptanoate;
formula     C8H16O2;
CAS         106-73-0;
InChIKey    XNCNNDVCAUWAIT-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          612.60;      // K   [origin=predictive method=joback]
Pc          25.482;      // bar [origin=predictive method=joback]
omega       0.5491;      // -   [origin=predictive method=lee-kesler]
Tb          440.86;      // K   [origin=predictive method=joback]
HvapTb      40809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.025 0.70904 -0.0003168 2.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptanoic acid, methyl ester" "heptanoic acid methyl ester" "methyl heptoate" "methyl heptylate" "methyl n-heptylate" "methyl oenanthylate" "methyl heptylate (natural)" "enanthic acid methyl ester" "agn-pc-00gt7d" "u098" "6aa46ce6-9176-493d-9a85-b7b2dda47cce" );
gibbsFormation
{
    dHf_298   -525730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293890.0
    phase     gas;
}
