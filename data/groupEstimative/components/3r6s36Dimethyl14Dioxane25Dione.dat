/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3r,6s)-3,6-dimethyl-1,4-dioxane-2,5-dione  (C6H8O4, CAS 13076-19-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3r6s36Dimethyl14Dioxane25Dione;
formula     C6H8O4;
CAS         13076-19-2;
InChIKey    JJTUDXZGHPGLLC-ZXZARUISSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          639.48;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.5702;      // -   [origin=predictive method=lee-kesler]
Tb          451.12;      // K   [origin=predictive method=joback]
HvapTb      43196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.07 0.59824 -0.0003246 4.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dioxane-2,5-dione, 3,6-dimethyl-, (3r,6s)-rel-" );
gibbsFormation
{
    dHf_298   -743110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-555960.0
    phase     gas;
}
