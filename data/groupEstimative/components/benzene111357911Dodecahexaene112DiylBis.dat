/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1'-(1,3,5,7,9,11-dodecahexaene-1,12-diyl)bis-  (C24H22, CAS 3029-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene111357911Dodecahexaene112DiylBis;
formula     C24H22;
CAS         3029-42-3;
InChIKey    UXYRZRFBRUPVBU-MDLXKTDOSA-N;
MW          310.44;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.53;      // K   [origin=predictive method=joback]
Pc          15.403;      // bar [origin=predictive method=joback]
omega       0.7273;      // -   [origin=predictive method=lee-kesler]
Tb          827.04;      // K   [origin=predictive method=joback]
HvapTb      73318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-171.83 2.246 -0.001847 6.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 6; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 12; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1e,3e,5e,7e,9e,11e)-12-phenyldodeca-1,3,5,7,9,11-hexaenyl]benzene" );
gibbsFormation
{
    dHf_298   637690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     838.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=857340.0
    phase     gas;
}
