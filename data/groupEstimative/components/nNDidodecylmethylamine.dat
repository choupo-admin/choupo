/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-didodecylmethylamine  (C25H53N, CAS 2915-90-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDidodecylmethylamine;
formula     C25H53N;
CAS         2915-90-4;
InChIKey    UWHRNIXHZAWBMF-UHFFFAOYSA-N;
MW          367.706;      // g/mol [origin=calculated method=formula-sum]
Tc          959.95;      // K   [origin=predictive method=joback]
Pc          7.631;      // bar [origin=predictive method=joback]
omega       0.7216;      // -   [origin=predictive method=lee-kesler]
Tb          784.04;      // K   [origin=predictive method=joback]
HvapTb      73287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.528 2.50276 -0.0014488 3.237e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 22; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 22; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-dodecyl-n-methyl-dodecan-1-amine" "n-methyldidodecylamine" "n-dodecyl-n-methyl-1-dodecanamine" "1-dodecanamine, n-dodecyl-n-methyl-" "didodecylmethylamine" "didodecyl methyl amine" "n-dodecyl-n-methyldodecan-1-amine" );
gibbsFormation
{
    dHf_298   -491800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1145.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270400.0
    phase     gas;
}
