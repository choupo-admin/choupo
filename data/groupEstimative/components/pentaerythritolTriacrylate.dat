/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentaerythritol triacrylate  (C14H18O7, CAS 3524-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentaerythritolTriacrylate;
formula     C14H18O7;
CAS         3524-68-3;
InChIKey    HVVWZTWDBSEWIH-UHFFFAOYSA-N;
MW          298.291;      // g/mol [origin=calculated method=formula-sum]
Tc          961.10;      // K   [origin=predictive method=joback]
Pc          18.740;      // bar [origin=predictive method=joback]
omega       1.3346;      // -   [origin=predictive method=lee-kesler]
Tb          773.57;      // K   [origin=predictive method=joback]
HvapTb      82352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.234 1.2692 -0.0007249 1.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 3; } { group OH; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group C; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group OH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(hydroxymethyl)-3-prop-2-enoyloxy-2-(prop-2-enoyloxymethyl)propyl] prop-2-enoate" "peta" "kayarad pet 30" "light acrylate pe 3a" "p 300 (acrylate)" "nk ester a-tmm 3" "nk ester tmm 50t" "nk ester a-tmm 3l" "pentaerythrityl triacrylate" "acrylic acid, triester with pentaerythritol" "tetramethylolmethane triacrylate" "sr 444c" );
standardThermochemistry
{
    dHf_298   -1068820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     853.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-734570.0
}
