/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-5-hepten-1-ol  (C9H18O, CAS 4234-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl5Hepten1Ol;
formula     C9H18O;
CAS         4234-93-9;
InChIKey    WFZFXUZFKAOTRR-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          673.10;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.8103;      // -   [origin=predictive method=lee-kesler]
Tb          501.30;      // K   [origin=predictive method=joback]
HvapTb      51957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.557 0.91866 -0.0005855 1.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylhept-5-en-1-ol" "5-hepten-1-ol, 2,6-dimethyl-" "(2s)-2,6-dimethylhept-5-en-1-ol" "agn-pc-00h0rz" "5-hepten-1-ol,6-dimethyl-" );
gibbsFormation
{
    dHf_298   -279170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-42690.0
    phase     gas;
}
