/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1,2-tetrachloropropane  (C3H4Cl4, CAS 812-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1112Tetrachloropropane;
formula     C3H4Cl4;
CAS         812-03-3;
InChIKey    FEKGWIHDBVDVSM-UHFFFAOYSA-N;
MW          181.865;      // g/mol [origin=calculated method=formula-sum]
Tc          633.32;      // K   [origin=predictive method=joback]
Pc          37.777;      // bar [origin=predictive method=joback]
omega       0.2640;      // -   [origin=predictive method=lee-kesler]
Tb          414.29;      // K   [origin=predictive method=joback]
HvapTb      38128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.57 0.44772 -0.000396 1.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHCl; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 1; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2-tetrakis(chloranyl)propane" "propane, 1,1,1,2-tetrachloro-" "propane,1,1,1,2-tetrachloro-" );
standardThermochemistry
{
    dHf_298   -182240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     358.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72940.0
}
