/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-4-hydroxyphenylglycine  (C8H9NO3, CAS 22818-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        d4Hydroxyphenylglycine;
formula     C8H9NO3;
CAS         22818-40-2;
InChIKey    LJCWONGJFPCTTL-SSDOTTSWSA-N;
MW          167.164;      // g/mol [origin=calculated method=formula-sum]
Tc          956.25;      // K   [origin=predictive method=joback]
Pc          54.707;      // bar [origin=predictive method=joback]
omega       1.1494;      // -   [origin=predictive method=lee-kesler]
Tb          707.54;      // K   [origin=predictive method=joback]
HvapTb      76109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.8 0.9581 -0.00081816 2.811e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanyl-2-(4-hydroxyphenyl)ethanoic acid" "4-hydroxy-d-phenylglycine" "d(-)-4-hydroxyphenylglycine" "d-n-(4-hydroxyphenyl)glycine" "(r)-alpha-amino-4-hydroxybenzeneacetic acid" "(2r)-2-amino-2-(4-hydroxyphenyl)acetic acid" "(d)-(-)-alfa-4-hydroxyphenyl glycine" "(r)-2-amino-2-(4-hydroxyphenyl)acetic acid" "d-(-)-2-(4-hydroxyphenyl)glycine" "(r)-(-)-amino(4-hydroxyphenyl)acetic acid" "(2r)-amino(4-hydroxyphenyl)acetic acid" "p-hydroxy-d-phenylglycine" );
standardThermochemistry
{
    dHf_298   -470990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-305630.0
}
