/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propylnaphthalene  (C13H14, CAS 2027-19-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propylnaphthalene;
formula     C13H14;
CAS         2027-19-2;
InChIKey    LQBNOHAXLHRIQW-UHFFFAOYSA-N;
MW          170.255;      // g/mol [origin=calculated method=formula-sum]
Tc          773.88;      // K   [origin=predictive method=joback]
Pc          27.556;      // bar [origin=predictive method=joback]
omega       0.4915;      // -   [origin=predictive method=lee-kesler]
Tb          547.68;      // K   [origin=predictive method=joback]
HvapTb      49110.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.978 1.09672 -0.00078428 2.252e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene, 2-propyl-" "2-n-propylnaphthalene" "2-propylnaphthalene;b-propylnaphthalene;b-n-propylnaphthalene;" );
standardThermochemistry
{
    dHf_298   104480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=268010.0
}
