/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-decyn-1-ol  (C10H18O, CAS 68274-97-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Decyn1Ol;
formula     C10H18O;
CAS         68274-97-5;
InChIKey    RNTNGQCWAKHVKO-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          705.88;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.8676;      // -   [origin=predictive method=lee-kesler]
Tb          529.58;      // K   [origin=predictive method=joback]
HvapTb      56685.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.647 0.83802 -0.00045846 9.658e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-5-yn-1-ol" "5-decyne-1-ol;" );
standardThermochemistry
{
    dHf_298   -129660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99300.0
}
