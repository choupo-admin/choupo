/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-(alpha-(alpha,alpha,alpha-trifluoro-m-tolyl)benzyloxy)ethyl)morpholine fumarate  (C24H26F3NO6, CAS 3216-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42AlphaAlphaAlphaAlphaTrifluoroMTolylBenzyloxyEthylMorpholin;
formula     C24H26F3NO6;
CAS         3216-14-6;
InChIKey    HERAOOOZGHYHSO-WLHGVMLRSA-N;
MW          481.467;      // g/mol [origin=calculated method=formula-sum]
Tc          1444.12;      // K   [origin=predictive method=joback]
Pc          14.176;      // bar [origin=predictive method=joback]
omega       1.2857;      // -   [origin=predictive method=lee-kesler]
Tb          1179.54;      // K   [origin=predictive method=joback]
HvapTb      114206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.778 2.3649 -0.00148606 3.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } { group COOH; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group F; count 3; } { group O; count 1; } { group O_ring; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-but-2-enedioic acid;4-[2-[phenyl-[3-(trifluoromethyl)phenyl]methoxy]ethyl]morpholine" "morpholine, 4-(2-(alpha-(alpha,alpha,alpha-trifluoro-m-tolyl)benzyloxy)ethyl)-, fumarate" "(e)-but-2-enedioic acid; 4-[2-[phenyl-[3-(trifluoromethyl)phenyl]methoxy]ethyl]morpholine" );
gibbsFormation
{
    dHf_298   -1490270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1093.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-966080.0
    phase     gas;
}
