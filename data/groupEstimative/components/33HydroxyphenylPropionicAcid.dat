/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(3-hydroxyphenyl)propionic acid  (C9H10O3, CAS 621-54-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33HydroxyphenylPropionicAcid;
formula     C9H10O3;
CAS         621-54-5;
InChIKey    QVWAEZJXDYOKEH-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          891.69;      // K   [origin=predictive method=joback]
Pc          43.684;      // bar [origin=predictive method=joback]
omega       1.0074;      // -   [origin=predictive method=lee-kesler]
Tb          658.33;      // K   [origin=predictive method=joback]
HvapTb      68082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.518 0.9853 -0.00082596 2.825e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-hydroxyphenyl)propanoic acid" "3-(m-hydroxyphenyl)propionic acid" "dihydro-3-coumaric acid" "benzenepropanoic acid, 3-hydroxy-" "m-hydroxy-hydrocinnamic acid" "beta-(m-hydroxyphenyl)propionic acid" "m-hydroxyphenylpropionic acid" "3-hydroxyphenylpropionic acid" "beta-(3-hydroxyphenyl)propionic acid" "hydrocinnamic acid, m-hydroxy-" ".beta.-(m-hydroxyphenyl)propionic acid" "3-hydroxybenzenepropanoic acid" );
standardThermochemistry
{
    dHf_298   -520140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361220.0
}
