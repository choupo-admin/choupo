/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethyl-7-hydroxy-3-(p-methoxyphenyl)coumarin  (C18H16O4, CAS 5219-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethyl7Hydroxy3PMethoxyphenylCoumarin;
formula     C18H16O4;
CAS         5219-17-0;
InChIKey    OFVOGSOIXOYRRC-UHFFFAOYSA-N;
MW          296.322;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.15;      // K   [origin=predictive method=joback]
Pc          24.195;      // bar [origin=predictive method=joback]
omega       1.1757;      // -   [origin=predictive method=lee-kesler]
Tb          852.28;      // K   [origin=predictive method=joback]
HvapTb      86035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.379 1.48564 -0.00110968 3.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 7; } { group AC; count 4; } { group ACOH; count 1; } { group CH3O; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 7; } { group OH_phenol; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyl-3-(4-methoxyphenyl)-7-oxidanyl-chromen-2-one" "coumarin, 4-ethyl-7-hydroxy-3-(p-methoxyphenyl)-" "4-ethyl-7-oh-3-(p-methoxyphenyl)-dihydro-1-benzopyran-2-one" "4-ethyl-7-hydroxy-3-(4-methoxyphenyl)-chromen-2-one" "4-ethyl-7-hydroxy-3-(4-methoxyphenyl)chromen-2-one" "4-ethyl-7-hydroxy-3-(4-methoxyphenyl)-2h-chromen-2-one" "2h-1-benzopyran-2-one, 4-ethyl-7-hydroxy-3-(4-methoxyphenyl)-" "2h-1-benzopyran-2-one,4-ethyl-7-hydroxy-3-(4-methoxyphenyl)-" "2h-1-benzopyran-2-one, 4-ethyl-7-hydroxy-3-(4-methoxyphenyl)- (9ci)" );
gibbsFormation
{
    dHf_298   -457400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-172490.0
    phase     gas;
}
