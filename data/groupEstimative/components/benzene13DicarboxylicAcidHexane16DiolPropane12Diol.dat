/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene-1,3-dicarboxylic acid;hexane-1,6-diol;propane-1,2-diol  (C17H28O8, CAS 50258-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene13DicarboxylicAcidHexane16DiolPropane12Diol;
formula     C17H28O8;
CAS         50258-68-9;
InChIKey    VANSXUKDJAJJCQ-UHFFFAOYSA-N;
MW          360.403;      // g/mol [origin=calculated method=formula-sum]
Tc          1647.65;      // K   [origin=predictive method=joback]
Pc          21.513;      // bar [origin=predictive method=joback]
omega       1.0552;      // -   [origin=predictive method=lee-kesler]
Tb          1282.32;      // K   [origin=predictive method=joback]
HvapTb      157618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.147 1.31152 -0.00030556 -1.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 4; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-benzenedicarboxylic acid, polymer with 1,6-hexanediol and 1,2-propanediol" "benzene-1,3-dicarboxylic acid; hexane-1,6-diol; propane-1,2-diol" );
standardThermochemistry
{
    dHf_298   -1707130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1221.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1252020.0
}
