/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dichloro-p-phenylenediamine  (C6H6Cl2N2, CAS 609-20-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DichloroPPhenylenediamine;
formula     C6H6Cl2N2;
CAS         609-20-1;
InChIKey    HQCHAOKWWKLXQH-UHFFFAOYSA-N;
MW          177.028;      // g/mol [origin=calculated method=formula-sum]
Tc          852.84;      // K   [origin=predictive method=joback]
Pc          46.403;      // bar [origin=predictive method=joback]
omega       0.6752;      // -   [origin=predictive method=lee-kesler]
Tb          598.42;      // K   [origin=predictive method=joback]
HvapTb      63264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.19 0.4538 -0.00026028 5.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACNH2; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(chloranyl)benzene-1,4-diamine" "fast brown rr salt" "2,6-dichlorobenzene-1,4-diamine" "2,6-dichloro-1,4-phenylenediamine" "daito brown salt rr" "1,4-benzenediamine, 2,6-dichloro-" "2,6-dichloro-1,4-benzenediamine" "1,4-diamino-2,6-dichlorobenzene" "2,5-diamino-1,3-dichlorobenzene" "p-phenylenediamine, 2,6-dichloro-" "2,6-dichloro-para-phenylenediamine" "3,5-dichloro-1,4-phenylenediamine" );
standardThermochemistry
{
    dHf_298   71050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192200.0
}
