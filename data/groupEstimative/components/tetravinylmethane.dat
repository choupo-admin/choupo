/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetravinylmethane  (C9H12, CAS 20685-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetravinylmethane;
formula     C9H12;
CAS         20685-34-1;
InChIKey    QOYZWSPUVHSVFK-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          577.88;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       0.2649;      // -   [origin=predictive method=lee-kesler]
Tb          389.01;      // K   [origin=predictive method=joback]
HvapTb      31652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.73 0.9046 -0.0007292 2.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH2=CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH2; count 4; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis(ethenyl)penta-1,4-diene" );
gibbsFormation
{
    dHf_298   263880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=379100.0
    phase     gas;
}
