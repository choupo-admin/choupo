/*--------------------------------*- Choupo -*-----------------------*\
  Component: (c8) branched trialkylamine  (C25H53N, CAS 68439-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        c8BranchedTrialkylamine;
formula     C25H53N;
CAS         68439-83-8;
InChIKey    CXZRAXNXPJFXPX-UHFFFAOYSA-N;
MW          367.706;      // g/mol [origin=calculated method=formula-sum]
Tc          959.31;      // K   [origin=predictive method=joback]
Pc          7.768;      // bar [origin=predictive method=joback]
omega       0.7216;      // -   [origin=predictive method=lee-kesler]
Tb          782.28;      // K   [origin=predictive method=joback]
HvapTb      71735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.256 2.52644 -0.0014616 3.217e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 13; } { group CH; count 4; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 14; } { group CH; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyl-n-(3-ethyl-2-methyl-pentyl)-5-methyl-n-octyl-hexan-1-amine" "1-octanamine, n,n-dioctyl-, branched" "4-ethyl-n-(3-ethyl-2-methylpentyl)-5-methyl-n-octylhexan-1-amine" );
gibbsFormation
{
    dHf_298   -512920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1107.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=260640.0
    phase     gas;
}
