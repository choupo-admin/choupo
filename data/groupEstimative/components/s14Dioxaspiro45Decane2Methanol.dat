/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-(+)-1,4-dioxaspiro[4.5]decane-2-methanol  (C9H16O3, CAS 95335-91-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s14Dioxaspiro45Decane2Methanol;
formula     C9H16O3;
CAS         95335-91-4;
InChIKey    XUGYZVQSZWPABZ-QMMMGPOBSA-N;
MW          172.224;      // g/mol [origin=calculated method=formula-sum]
Tc          797.08;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.8635;      // -   [origin=predictive method=lee-kesler]
Tb          582.40;      // K   [origin=predictive method=joback]
HvapTb      60690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.319 1.4421 -0.0012558 4.653e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s)-1,4-dioxaspiro[4.5]decan-3-yl]methanol" "(2s)-1,4-dioxaspiro[4.5]decane-2-methanol" "d-" "a," "a-cyclohexylideneglycerol" "d-alpha,beta-cyclohexylideneglycerol" "()-1,4-dioxaspiro[4.5]decane-2-methanol" "(+)-1,4-dioxaspiro[4.5]decane-2-methanol" );
standardThermochemistry
{
    dHf_298   -509120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216550.0
}
