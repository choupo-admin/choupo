/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexenyl-2-propanone  (C9H14O, CAS 768-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexenyl2Propanone;
formula     C9H14O;
CAS         768-50-3;
InChIKey    RDOUKLWMBUMPIX-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          701.79;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.4662;      // -   [origin=predictive method=lee-kesler]
Tb          487.75;      // K   [origin=predictive method=joback]
HvapTb      44066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.399 0.86392 -0.00050374 1.0396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(cyclohexen-1-yl)propan-2-one" "2-propanone, 1-(1-cyclohexen-1-yl)-" "1-cyclohexenylacetone" "1-(cyclohexenyl)acetone" "cyclohexenyl-2-propanone" "1-(1-cyclohexenyl)propan-2-one" "1-(1-cyclohexenyl)-propan-2-one" );
gibbsFormation
{
    dHf_298   -220700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51530.0
    phase     gas;
}
