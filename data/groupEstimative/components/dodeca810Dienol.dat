/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodeca-8,10-dienol  (C12H22O, CAS 33956-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodeca810Dienol;
formula     C12H22O;
CAS         33956-49-9;
InChIKey    CSWBSLXBXRFNST-UHFFFAOYSA-N;
MW          182.307;      // g/mol [origin=calculated method=formula-sum]
Tc          743.86;      // K   [origin=predictive method=joback]
Pc          21.158;      // bar [origin=predictive method=joback]
omega       0.9716;      // -   [origin=predictive method=lee-kesler]
Tb          574.66;      // K   [origin=predictive method=joback]
HvapTb      58901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.093 1.21782 -0.000827 2.362e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodeca-8,10-dien-1-ol" "(8e,10e)-dodeca-8,10-dien-1-ol" "(8e,10z)-dodeca-8,10-dien-1-ol" "e,e-8,10-dodecadien-1-ol" "8,10-dodecadien-1-ol,(8e,10e)-" "8,10-dodecadien-1-ol, (8z,10e)-" "8,10-dodecadien-1-ol, (8z,10z)-" "8,10-dodecadien-1-ol,(e,e)- (8ci); (8e,10e)-8,10-dodecadien-1-ol; (8e,10e)-dodecadien-1-ol;(e,e)-8,10-dodecadien-1-ol; (e,e)-8,10-dodecadien-l-ol;(e,e)-8,10-dodecadienol; 8-trans,10-trans-dodecadien-1-ol; cp-mk; codlelure;codlemone; feroflon sr 2; feroflor sr 2; trans-8,trans-10-dodecadien-1-ol;trans-trans-8,10-dodecadien-1-ol" );
standardThermochemistry
{
    dHf_298   -208800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     661.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73780.0
}
