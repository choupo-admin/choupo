/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-n-(2-methoxyisopropyl)-6-methylaniline  (C13H21NO, CAS 51219-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylN2Methoxyisopropyl6Methylaniline;
formula     C13H21NO;
CAS         51219-00-2;
InChIKey    YXWIRQHVEQIJOV-UHFFFAOYSA-N;
MW          207.317;      // g/mol [origin=calculated method=formula-sum]
Tc          807.57;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       0.7323;      // -   [origin=predictive method=lee-kesler]
Tb          605.83;      // K   [origin=predictive method=joback]
HvapTb      56590.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.372 1.05988 -0.00052132 7.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-n-(1-methoxypropan-2-yl)-6-methyl-aniline" "benzenamine, 2-ethyl-n-(2-methoxy-1-methylethyl)-6-methyl-" "benzenamine, 2-ethyl-n-[(1s)-2-methoxy-1-methylethyl]-6-methyl-" "2-ethyl-n-(1-methoxypropan-2-yl)-6-methylaniline" "2-ethyl-6-methyl-n-(1'-methyl-2-methoxyethyl)aniline" "n-(2-methoxy-1-methylethyl)-2-ethyl-6-methylbenzenamine" );
gibbsFormation
{
    dHf_298   -182090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133680.0
    phase     gas;
}
