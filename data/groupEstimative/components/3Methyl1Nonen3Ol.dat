/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-1-nonen-3-ol  (C10H20O, CAS 22616-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl1Nonen3Ol;
formula     C10H20O;
CAS         22616-15-5;
InChIKey    CXFWZMIYAODOSX-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          683.66;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       0.8262;      // -   [origin=predictive method=lee-kesler]
Tb          514.03;      // K   [origin=predictive method=joback]
HvapTb      52567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.375 1.09364 -0.0007453 2.069e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylnon-1-en-3-ol" "1-nonen-3-ol, 3-methyl-" );
gibbsFormation
{
    dHf_298   -285280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12820.0
    phase     gas;
}
