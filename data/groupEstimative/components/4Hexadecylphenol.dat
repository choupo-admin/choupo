/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hexadecylphenol  (C22H38O, CAS 2589-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hexadecylphenol;
formula     C22H38O;
CAS         2589-78-8;
InChIKey    MHCHQNXRVNQPHJ-UHFFFAOYSA-N;
MW          318.545;      // g/mol [origin=calculated method=formula-sum]
Tc          1004.16;      // K   [origin=predictive method=joback]
Pc          12.311;      // bar [origin=predictive method=joback]
omega       1.0113;      // -   [origin=predictive method=lee-kesler]
Tb          810.26;      // K   [origin=predictive method=joback]
HvapTb      79856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.935 2.16952 -0.00146056 4.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 4-hexadecyl-" "p-hexadecylphenol" "4-n-hexadecylphenol" "phenol, p-hexadecyl-" "phenol,p-hexadecyl- (7ci,8ci); 4-hexadecylphenol; p-hexadecyl phenol" );
gibbsFormation
{
    dHf_298   -438190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     933.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92150.0
    phase     gas;
}
