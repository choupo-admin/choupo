/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethyl-2-pentyne  (C7H12, CAS 999-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethyl2Pentyne;
formula     C7H12;
CAS         999-78-0;
InChIKey    FOALCTWKQSWRST-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          567.37;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.1784;      // -   [origin=predictive method=lee-kesler]
Tb          365.53;      // K   [origin=predictive method=joback]
HvapTb      32032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.39 0.64488 -0.00043666 1.2298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-dimethylpent-2-yne" "2-pentyne, 4,4-dimethyl-" "4,4-dimethyl-pent-2-yne" "tert-butylmethylacetylene" );
standardThermochemistry
{
    dHf_298   75740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=213700.0
}
