/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[2.4]heptane  (C7H12, CAS 185-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro24Heptane;
formula     C7H12;
CAS         185-49-9;
InChIKey    HEMCGZPSGYRIOL-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          595.83;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.2377;      // -   [origin=predictive method=lee-kesler]
Tb          382.42;      // K   [origin=predictive method=joback]
HvapTb      30332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.01 1.2794 -0.001339 5.67e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -12790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119680.0
}
