/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tridecanamine, n,n-diethyl-  (C17H37N, CAS 66577-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TridecanamineNNDiethyl;
formula     C17H37N;
CAS         66577-48-8;
InChIKey    GFKYEYVYVGMLQL-UHFFFAOYSA-N;
MW          255.49;      // g/mol [origin=calculated method=formula-sum]
Tc          759.20;      // K   [origin=predictive method=joback]
Pc          12.294;      // bar [origin=predictive method=joback]
omega       0.8128;      // -   [origin=predictive method=lee-kesler]
Tb          601.00;      // K   [origin=predictive method=joback]
HvapTb      55479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.256 1.74276 -0.0010136 2.285e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 13; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethyltridecan-1-amine" );
gibbsFormation
{
    dHf_298   -326680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     834.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203040.0
    phase     gas;
}
