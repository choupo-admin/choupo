/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxyisopropyl chloroacetate  (C6H11ClO3, CAS 64046-46-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1MethoxyisopropylChloroacetate;
formula     C6H11ClO3;
CAS         64046-46-4;
InChIKey    PFYYFYKWCJMOMO-UHFFFAOYSA-N;
MW          166.601;      // g/mol [origin=calculated method=formula-sum]
Tc          643.71;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.4853;      // -   [origin=predictive method=lee-kesler]
Tb          451.72;      // K   [origin=predictive method=joback]
HvapTb      41856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.761 0.58846 -0.0002892 2.92e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH3O; count 1; } { group CH2Cl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxypropan-2-yl 2-chloranylethanoate" "2-methoxypropan-2-yl 2-chloroacetate" );
standardThermochemistry
{
    dHf_298   -641160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-424820.0
}
