/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 3-thiadipate  (C7H12O4S, CAS 7400-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl3Thiadipate;
formula     C7H12O4S;
CAS         7400-45-5;
InChIKey    XNDKLLFGXIEGKL-UHFFFAOYSA-N;
MW          192.229;      // g/mol [origin=calculated method=formula-sum]
Tc          743.50;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.7293;      // -   [origin=predictive method=lee-kesler]
Tb          544.98;      // K   [origin=predictive method=joback]
HvapTb      52807.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.943 0.55363 -0.0001276 -6.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2COO; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group COO; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(2-methoxy-2-oxidanylidene-ethyl)sulfanylpropanoate" "dimethyl 3-thiaadipate" "methyl 3-[(2-methoxy-2-oxoethyl)sulfanyl]propanoate" "methyl 3-(methoxycarbonylmethylthio)propionate" "propanoic acid, 3-[(2-methoxy-2-oxoethyl)thio]-, methyl ester" "methyl 3-((2-methoxy-2-oxoethyl)thio)propanoate" "methyl 3-((2-methoxy-2-oxoethyl)thio)propionate" "methyl 3-[(2-methoxy-2-oxoethyl)thio]propanoate" "methyl 3-[(2-methoxy-2-oxoethyl)thio]propionate" "propanoic acid, 3-((2-methoxy-2-oxoethyl)thio)-, methyl ester" "methyl 3-[(methoxycarbonyl)methylthio]propanoate" "methyl 3-(2-methoxy-2-oxoethyl)sulfanylpropanoate" );
standardThermochemistry
{
    dHf_298   -780500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-579560.0
}
