/*--------------------------------*- Choupo -*-----------------------*\
  Component: arachidic acid, trimethylsilyl ester  (C23H48O2Si, CAS 55530-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C23H48O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        arachidicAcidTrimethylsilylEster;
formula     C23H48O2Si;
CAS         55530-70-6;
InChIKey    AYSGFBVOWSXJCN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          384.72;      // g/mol [origin=calculated method=formula-sum]
Tc          963.31;      // K   [origin=predictive method=joback]
Pc          7.975;      // bar [origin=predictive method=joback]
omega       0.7444;      // -   [origin=predictive method=lee-kesler]
Tb          785.46;      // K   [origin=predictive method=joback]
HvapTb      74493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.208 1.92788 -0.000718 -1.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 17; } { group CH2COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 18; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl icosanoate" "eicosanoic acid, trimethylsilyl ester" "icosanoic acid trimethylsilyl ester" );
standardThermochemistry
{
    dHf_298   -946950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1229.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-272350.0
}
