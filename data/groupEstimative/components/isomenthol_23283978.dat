/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-isomenthol  (C10H20O, CAS 23283-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isomenthol;
formula     C10H20O;
CAS         23283-97-8;
InChIKey    NOOLISFMXDJSKH-BBBLOLIVSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          719.94;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.7217;      // -   [origin=predictive method=lee-kesler]
Tb          530.35;      // K   [origin=predictive method=joback]
HvapTb      53956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.32 1.06286 -0.000524 7.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2r,5r)-5-methyl-2-propan-2-yl-cyclohexan-1-ol" "d-isomenthol" "menthol, trans-1,3,cis-1,4-, (+)-" "()-isomenthol" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, (1s,2r,5r)-" "noolisfmxdjskh-bbblolivsa-" "(1s,2r,5r)-5-methyl-2-propan-2-ylcyclohexan-1-ol" "(1s-(1alpha,2beta,5beta))-5-methyl-(1-isopropyl)cyclohexan-2-ol" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, [1s-(1?,2ss,5ss)]-" "cyclohexanol, 5-methyl-2-(1-methylethyl)-, (1s-(1alpha,2beta,5beta))-" );
standardThermochemistry
{
    dHf_298   -393600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96910.0
}
