/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenedicarboxylic acid, polymer with 1,4-benzenedicarboxylic acid and 1,3-propanediol  (C19H20O10, CAS 105726-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BenzenedicarboxylicAcidPolymerWith14BenzenedicarboxylicAci;
formula     C19H20O10;
CAS         105726-60-1;
InChIKey    ACGGXLCHUZKCTB-UHFFFAOYSA-N;
MW          408.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1855.14;      // K   [origin=predictive method=joback]
Pc          23.888;      // bar [origin=predictive method=joback]
omega       1.3058;      // -   [origin=predictive method=lee-kesler]
Tb          1466.84;      // K   [origin=predictive method=joback]
HvapTb      166366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.023 1.3908 -0.00045972 -8.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,3-dicarboxylic acid;propane-1,3-diol;terephthalic acid" );
gibbsFormation
{
    dHf_298   -1914150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1200.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1544140.0
    phase     gas;
}
