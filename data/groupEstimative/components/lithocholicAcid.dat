/*--------------------------------*- Choupo -*-----------------------*\
  Component: lithocholic acid  (C24H40O3, CAS 434-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lithocholicAcid;
formula     C24H40O3;
CAS         434-13-9;
InChIKey    SMEROWZSTRWXGI-HVATVPOCSA-N;
MW          376.581;      // g/mol [origin=calculated method=formula-sum]
Tc          1249.70;      // K   [origin=predictive method=joback]
Pc          13.418;      // bar [origin=predictive method=joback]
omega       1.1766;      // -   [origin=predictive method=lee-kesler]
Tb          1016.08;      // K   [origin=predictive method=joback]
HvapTb      99447.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-313.518 3.40796 -0.0028804 1.0426e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 6; } { group C_ring; count 2; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r)-4-[(3r,5r,8r,9s,10s,13r,14s,17r)-10,13-dimethyl-3-oxidanyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-17-yl]pentanoic acid" "lithocholate" "3alpha-hydroxy-5beta-cholanic acid" "lithocolic acid" "3-hydroxycholan-24-oic acid" "3alpha-hydroxy-5beta-cholan-24-oic acid" "3-alpha-hydroxycholanic acid" "3alpha-hydroxycholanic acid" "3-alpha-hydroxy-5-beta-cholanic acid" "5beta-cholanic acid-3alpha-ol" "(3alpha,5beta)-3-hydroxycholan-24-oic acid" "3alpha-hydroxy-5beta-cholanoic acid" );
standardThermochemistry
{
    dHf_298   -836950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     893.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-191290.0
}
