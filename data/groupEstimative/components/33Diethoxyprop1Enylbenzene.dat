/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-diethoxyprop-1-enylbenzene  (C13H18O2, CAS 25226-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Diethoxyprop1Enylbenzene;
formula     C13H18O2;
CAS         25226-98-6;
InChIKey    VYKDEWVAUWARRX-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          778.24;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.6194;      // -   [origin=predictive method=lee-kesler]
Tb          572.28;      // K   [origin=predictive method=joback]
HvapTb      51198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.698 1.05944 -0.0005796 1.063e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, (3,3-diethoxy-1-propenyl)-" "benzene, (3,3-diethoxy-1-propen-1-yl)-" "benzene, [(1e)-3,3-diethoxy-1-propenyl]-" "benzene, [(1e)-3,3-diethoxy-1-propen-1-yl]-" "1,1-diethoxy-3-phenylprop-2-ene" "benzene,[(1e)-3,3-diethoxy-1-propen-1-yl]-" "benzene,(3,3-diethoxy-1-propenyl)-, (e)-; benzene, [(1e)-3,3-diethoxy-1-propenyl]-(9ci); cinnamaldehyde, diethyl acetal, (e)- (8ci); benzene,(3,3-diethoxypropenyl)-, (e)- (8ci); (e)-cinnamaldehyde diethyl acetal;(e)-cinnamic aldehyde diethyl acetal; trans-cinnamaldehyde diethyl acetal" );
standardThermochemistry
{
    dHf_298   -227620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38770.0
}
