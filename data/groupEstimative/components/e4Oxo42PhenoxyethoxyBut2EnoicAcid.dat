/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-4-oxo-4-(2-phenoxyethoxy)but-2-enoic acid  (C12H12O5, CAS 46841-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e4Oxo42PhenoxyethoxyBut2EnoicAcid;
formula     C12H12O5;
CAS         46841-90-1;
InChIKey    RUGDBESIUZOJPC-UHFFFAOYSA-N;
MW          236.223;      // g/mol [origin=calculated method=formula-sum]
Tc          951.30;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       1.0942;      // -   [origin=predictive method=lee-kesler]
Tb          731.15;      // K   [origin=predictive method=joback]
HvapTb      71521.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.598 1.0177 -0.000611 1.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylidene-4-(2-phenoxyethoxy)but-2-enoic acid" "2-butenedioic acid (2z)-, 1-(2-phenoxyethyl) ester" "2-butenedioic acid (2z)-, mono(2-phenoxyethyl) ester" );
standardThermochemistry
{
    dHf_298   -737030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516490.0
}
