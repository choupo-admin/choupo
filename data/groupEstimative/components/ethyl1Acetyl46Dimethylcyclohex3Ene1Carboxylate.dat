/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 1-acetyl-4,6-dimethylcyclohex-3-ene-1-carboxylate  (C13H20O3, CAS 67674-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl1Acetyl46Dimethylcyclohex3Ene1Carboxylate;
formula     C13H20O3;
CAS         67674-38-8;
InChIKey    IBMDADQQJZKLJI-UHFFFAOYSA-N;
MW          224.3;      // g/mol [origin=calculated method=formula-sum]
Tc          840.03;      // K   [origin=predictive method=joback]
Pc          21.433;      // bar [origin=predictive method=joback]
omega       0.7118;      // -   [origin=predictive method=lee-kesler]
Tb          628.39;      // K   [origin=predictive method=joback]
HvapTb      58608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.739 1.42808 -0.00104854 3.3606e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-ethanoyl-4,6-dimethyl-cyclohex-3-ene-1-carboxylate" "3-cyclohexene-1-carboxylic acid, 1-acetyl-4,6-dimethyl-, ethyl ester" "2,4-dimethyl-5-acetyl-5-carbethoxy-1-cyclohexene" );
standardThermochemistry
{
    dHf_298   -645980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-349130.0
}
