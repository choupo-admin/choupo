/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-2-tritylpropane  (C23H24, CAS 24523-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl2Tritylpropane;
formula     C23H24;
CAS         24523-60-2;
InChIKey    MBCVQGKENSKVCY-UHFFFAOYSA-N;
MW          300.445;      // g/mol [origin=calculated method=formula-sum]
Tc          1066.68;      // K   [origin=predictive method=joback]
Pc          17.061;      // bar [origin=predictive method=joback]
omega       0.6612;      // -   [origin=predictive method=lee-kesler]
Tb          807.19;      // K   [origin=predictive method=joback]
HvapTb      72598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.59 2.02436 -0.00142896 3.855e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 14; } { group AC; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-2-(diphenylmethyl)benzene" "agn-pc-01xmye" "1-benzhydryl-2-tert-butylbenzene" );
standardThermochemistry
{
    dHf_298   166040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=470780.0
}
