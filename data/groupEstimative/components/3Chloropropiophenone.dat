/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3'-chloropropiophenone  (C9H9ClO, CAS 34841-35-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloropropiophenone;
formula     C9H9ClO;
CAS         34841-35-5;
InChIKey    PQWGFUFROKIJBO-UHFFFAOYSA-N;
MW          168.62;      // g/mol [origin=calculated method=formula-sum]
Tc          753.38;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       0.5245;      // -   [origin=predictive method=lee-kesler]
Tb          528.48;      // K   [origin=predictive method=joback]
HvapTb      49697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.649 0.69922 -0.00043166 9.646e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-chlorophenyl)propan-1-one" "m-chloropropiophenone" "1-(3-chloro-phenyl)-propan-1-one" "m-chlorophenylacetone" "3'-chloro propiophenone" "3-chlorophenyl ethyl ketone" "pqwgfufrokijbo-uhfffaoysa-" "1-(3-chlorophenyl)-1-propanone" "1-propanone,1-(3-chlorophenyl)-" "1-propanone, 1-(3-chlorophenyl)-" "propiophenone,3'-chloro- (6ci,7ci);1-(3-chlorophenyl)-1-propanone;3-chlorophenyl ethylketone;m-chloropropiophenone;" );
standardThermochemistry
{
    dHf_298   -132350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-13170.0
}
