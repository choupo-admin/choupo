/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethyl(pentyloxy)silane  (C11H26OSi, CAS 14629-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H26OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        triethylPentyloxySilane;
formula     C11H26OSi;
CAS         14629-52-8;
InChIKey    CAZPSHHIYOJOIP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          202.413;      // g/mol [origin=calculated method=formula-sum]
Tc          641.96;      // K   [origin=predictive method=joback]
Pc          17.203;      // bar [origin=predictive method=joback]
omega       0.5153;      // -   [origin=predictive method=lee-kesler]
Tb          475.10;      // K   [origin=predictive method=joback]
HvapTb      42784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.207 0.77948 -4.88e-05 -1.523e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triethyl(pentoxy)silane" "pentyloxytriethylsilane" "silane, triethyl(pentyloxy)-" );
standardThermochemistry
{
    dHf_298   -514210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     722.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-168020.0
}
