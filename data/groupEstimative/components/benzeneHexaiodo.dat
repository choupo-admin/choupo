/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, hexaiodo-  (C6I6, CAS 608-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneHexaiodo;
formula     C6I6;
CAS         608-74-2;
InChIKey    QNMKKFHJKJJOMZ-UHFFFAOYSA-N;
MW          833.466;      // g/mol [origin=calculated method=formula-sum]
Tc          1372.62;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.4746;      // -   [origin=predictive method=lee-kesler]
Tb          947.30;      // K   [origin=predictive method=joback]
HvapTb      90774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (105.17 0.4314 -0.000487 2.006e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 6; } { group I; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC_ring; count 6; } { group I; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,6-hexakis(iodanyl)benzene" "hexaiodobenzene" "benzene, 1,2,3,4,5,6-hexaiodo-" "periodobenzene" "p-iodoanil" "1,2,3,4,5,6-hexaiodobenzene" "benzene,1,2,3,4,5,6-hexaiodo-" );
gibbsFormation
{
    dHf_298   473230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=412620.0
    phase     gas;
}
