/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-tert-butylbenzylamine  (C11H17N, CAS 3378-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nTertButylbenzylamine;
formula     C11H17N;
CAS         3378-72-1;
InChIKey    DLSOILHAKCBARI-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          741.34;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.4912;      // -   [origin=predictive method=lee-kesler]
Tb          524.90;      // K   [origin=predictive method=joback]
HvapTb      47496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.699 1.17196 -0.0008262 2.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-n-(phenylmethyl)propan-2-amine" "tert-butylbenzylamine" "n-(tert-butyl)benzylamine" "n-t-butylbenzylamine" "n-benzyl-tert-butylamine" "n-benzyl-2-methylpropan-2-amine" "benzenemethanamine, n-(1,1-dimethylethyl)-" "benzyl-tert-butyl-amine" "(tert-butyl)benzylamine" "n-benzyl tert-butylamine" "agn-pc-03dsyj" "n-(1,1-dimethylethyl)benzylamine" );
gibbsFormation
{
    dHf_298   10880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=246380.0
    phase     gas;
}
