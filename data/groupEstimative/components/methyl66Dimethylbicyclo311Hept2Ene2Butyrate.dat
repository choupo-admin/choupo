/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 6,6-dimethylbicyclo(3.1.1)hept-2-ene-2-butyrate  (C14H22O2, CAS 38049-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl66Dimethylbicyclo311Hept2Ene2Butyrate;
formula     C14H22O2;
CAS         38049-29-5;
InChIKey    MBUKQPVDYQVJCI-UHFFFAOYSA-N;
MW          222.328;      // g/mol [origin=calculated method=formula-sum]
Tc          797.37;      // K   [origin=predictive method=joback]
Pc          19.948;      // bar [origin=predictive method=joback]
omega       0.6598;      // -   [origin=predictive method=lee-kesler]
Tb          595.60;      // K   [origin=predictive method=joback]
HvapTb      53657.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.007 1.72116 -0.00143464 5.161e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-(6,6-dimethyl-4-bicyclo[3.1.1]hept-3-enyl)butanoate" "bicyclo(3.1.1)hept-2-ene-2-butanoic acid, 6,6-dimethyl-, methyl ester" "bicyclo[3.1.1]hept-2-ene-2-butanoic acid, 6,6-dimethyl-, methyl ester" "4-(7,7-dimethyl-2-bicyclo[3.1.1]hept-2-enyl)-butyric acid methyl ester" );
standardThermochemistry
{
    dHf_298   -468920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126840.0
}
