/*--------------------------------*- Choupo -*-----------------------*\
  Component: s-(-)-diphenylprolinol  (C17H19NO, CAS 112068-01-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sDiphenylprolinol;
formula     C17H19NO;
CAS         112068-01-6;
InChIKey    OGCGXUGBDJGFFY-INIZCTEOSA-N;
MW          253.345;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.07;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       1.0272;      // -   [origin=predictive method=lee-kesler]
Tb          794.70;      // K   [origin=predictive method=joback]
HvapTb      80386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.12 1.7391 -0.0012324 3.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diphenyl-[(2s)-pyrrolidin-2-yl]methanol" "(s)-(-)-alpha,alpha-diphenyl-2-pyrrolidinemethanol" "alpha,alpha-diphenyl-l-prolinol" "(s)-(-)-2-(diphenylhydroxymethyl)pyrrolidine" "(s)-(-)-diphenylpyrrolidinemethanol" "(s)-diphenyl(pyrrolidin-2-yl)methanol" "r-(+)-alfa,alfa-diphenyl-2-pyrrolidine methanol" "(s)-(-)-alpha,alpha-diphenyl-2-pyrrolidine methanol" "diphenyl-l-pyrrolidin-2-yl-methanol" "((2s)pyrrolidin-2-yl)diphenylmethan-1-ol" "a,a-diphenyl-l-prolinol" "(s)-diphenylpyrrolidinemethanol" );
standardThermochemistry
{
    dHf_298   16160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=307360.0
}
