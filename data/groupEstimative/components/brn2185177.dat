/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2185177  (C30H24O4, CAS 60223-52-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2185177;
formula     C30H24O4;
CAS         60223-52-1;
InChIKey    AXASTMHSWNALDT-UHFFFAOYSA-N;
MW          448.518;      // g/mol [origin=calculated method=formula-sum]
Tc          1398.35;      // K   [origin=predictive method=joback]
Pc          13.418;      // bar [origin=predictive method=joback]
omega       1.1783;      // -   [origin=predictive method=lee-kesler]
Tb          1137.10;      // K   [origin=predictive method=joback]
HvapTb      107786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.89 2.02768 -0.00134268 3.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 14; } { group CH3O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 12; } { group dC_ring; count 14; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo(g,p)chrysene, 3,6,11,14-tetramethoxy-" );
standardThermochemistry
{
    dHf_298   -91290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=350340.0
}
