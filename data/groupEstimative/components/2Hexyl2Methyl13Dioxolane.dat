/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hexyl-2-methyl-1,3-dioxolane  (C10H20O2, CAS 937-94-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hexyl2Methyl13Dioxolane;
formula     C10H20O2;
CAS         937-94-0;
InChIKey    HTSKVUFGMXXBAG-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          694.36;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.5321;      // -   [origin=predictive method=lee-kesler]
Tb          497.82;      // K   [origin=predictive method=joback]
HvapTb      45980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.035 1.37144 -0.0011524 4.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-hexyl-2-methyl-" "methyl hexyl ketone ethylene ketal" );
gibbsFormation
{
    dHf_298   -438010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107860.0
    phase     gas;
}
