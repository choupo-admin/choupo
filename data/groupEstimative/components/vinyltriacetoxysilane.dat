/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyltriacetoxysilane  (C8H12O6Si, CAS 4130-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H12O6Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        vinyltriacetoxysilane;
formula     C8H12O6Si;
CAS         4130-08-9;
InChIKey    NOZAQBYNLKNDRT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          232.263;      // g/mol [origin=calculated method=formula-sum]
Tc          747.50;      // K   [origin=predictive method=joback]
Pc          23.819;      // bar [origin=predictive method=joback]
omega       0.7222;      // -   [origin=predictive method=lee-kesler]
Tb          555.38;      // K   [origin=predictive method=joback]
HvapTb      55247.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (109.67 0.37326 0.0002643 -2.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH3COO; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[diacetyloxy(ethenyl)silyl] ethanoate" "triacetoxy(vinyl)silane" "vinylsilanetriyl triacetate" "vinylsilanetriol triacetate" "vinyl triacetoxy silane" "silanetriol, ethenyl-, triacetate" "silanetriol, 1-ethenyl-, 1,1,1-triacetate" "(triacetoxysilyl)ethylene" "ethenylsilanetriyl triacetate" "silanetriol, vinyl-, triacetate" "nozaqbynlkndrt-uhfffaoysa-" "[diacetyloxy(ethenyl)silyl] acetate" );
standardThermochemistry
{
    dHf_298   -1146480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-931550.0
}
