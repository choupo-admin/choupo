/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-hexadecen-1-amine, (9z)-  (C16H33N, CAS 40853-88-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Hexadecen1Amine9z;
formula     C16H33N;
CAS         40853-88-1;
InChIKey    UATFHWVUSDADRL-UHFFFAOYSA-N;
MW          239.447;      // g/mol [origin=calculated method=formula-sum]
Tc          816.21;      // K   [origin=predictive method=joback]
Pc          14.294;      // bar [origin=predictive method=joback]
omega       0.8708;      // -   [origin=predictive method=lee-kesler]
Tb          642.37;      // K   [origin=predictive method=joback]
HvapTb      61809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.347 1.60572 -0.0009738 2.376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH=CH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group dCH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadec-9-en-1-amine" "(z)-hexadec-9-en-1-amine" );
gibbsFormation
{
    dHf_298   -222560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     824.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230510.0
    phase     gas;
}
