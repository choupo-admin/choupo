/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,4,6,6-pentamethylhept-1-ene  (C12H24, CAS 14031-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24466Pentamethylhept1Ene;
formula     C12H24;
CAS         14031-86-8;
InChIKey    NSSBKMKRTGHAAN-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          652.03;      // K   [origin=predictive method=joback]
Pc          19.153;      // bar [origin=predictive method=joback]
omega       0.3557;      // -   [origin=predictive method=lee-kesler]
Tb          464.26;      // K   [origin=predictive method=joback]
HvapTb      39124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.648 1.37542 -0.0009978 2.946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-heptene, 2,4,4,6,6-pentamethyl-" "2,4,4,6,6-pentamethylheptene-1" );
standardThermochemistry
{
    dHf_298   -192870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135130.0
}
