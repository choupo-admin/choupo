/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl ethylmalonate  (C9H16O4, CAS 133-13-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylEthylmalonate;
formula     C9H16O4;
CAS         133-13-1;
InChIKey    VQAZCUCWHIIFGE-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          701.52;      // K   [origin=predictive method=joback]
Pc          23.474;      // bar [origin=predictive method=joback]
omega       0.7182;      // -   [origin=predictive method=lee-kesler]
Tb          521.52;      // K   [origin=predictive method=joback]
HvapTb      50054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.843 0.75516 -0.0002798 -1.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-ethylpropanedioate" "propanedioic acid, ethyl-, diethyl ester" "diethyl 2-ethylmalonate" "malonic acid, ethyl-, diethyl ester" "propanedioic acid, 2-ethyl-, 1,3-diethyl ester" "diethyl 2-ethylpropane-1,3-dioate" "diethyl ethylpropanedioate" "agn-pc-0cj65c" "ethylmalonic acid diethyl ester" "2-ethylpropanedioic acid diethyl ester" "malonic acid, ethyl-, diethyl ester (8ci)" "1,1-propanedicarboxylic acid,diethyl ester  (malonic acid,ethyl,diethyl ester)" );
gibbsFormation
{
    dHf_298   -868930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-598280.0
    phase     gas;
}
