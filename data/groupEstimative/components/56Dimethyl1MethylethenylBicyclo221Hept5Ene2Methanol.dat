/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6-dimethyl-(1-methylethenyl)bicyclo(2.2.1)hept-5-ene-2-methanol  (C13H20O, CAS 110458-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56Dimethyl1MethylethenylBicyclo221Hept5Ene2Methanol;
formula     C13H20O;
CAS         110458-85-0;
InChIKey    MLDAJXVVSUEALX-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          804.74;      // K   [origin=predictive method=joback]
Pc          24.411;      // bar [origin=predictive method=joback]
omega       0.8691;      // -   [origin=predictive method=lee-kesler]
Tb          608.22;      // K   [origin=predictive method=joback]
HvapTb      60775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.599 1.63536 -0.0014634 5.654e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3-dimethyl-4-prop-1-en-2-yl-5-bicyclo[2.2.1]hept-2-enyl)methanol" "bicyclo(2.2.1)hept-5-ene-2-methanol, 5,6-dimethyl-1-(1-methylethenyl)-" "bicyclo[2.2.1]hept-5-ene-2-methanol, 5,6-dimethyl-1-(1-methylethenyl)-" );
standardThermochemistry
{
    dHf_298   -179060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107950.0
}
