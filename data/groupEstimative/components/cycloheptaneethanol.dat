/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptaneethanol  (C9H18O, CAS 4480-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptaneethanol;
formula     C9H18O;
CAS         4480-98-2;
InChIKey    WLPDUJITFJCPFH-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          716.61;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.7386;      // -   [origin=predictive method=lee-kesler]
Tb          521.52;      // K   [origin=predictive method=joback]
HvapTb      52908.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.728 1.0053 -0.0005308 8.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cycloheptylethanol" );
gibbsFormation
{
    dHf_298   -333160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99570.0
    phase     gas;
}
