/*--------------------------------*- Choupo -*-----------------------*\
  Component: disilanol  (H6OSi2, CAS 87963-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula H6OSi2 (delta H+5Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        disilanol;
formula     H6OSi2;
CAS         87963-93-7;
InChIKey    GKOZKEKDBJADSV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          78.217;      // g/mol [origin=calculated method=formula-sum]
Tc          447.80;      // K   [origin=predictive method=joback]
Pc          58.629;      // bar [origin=predictive method=joback]
omega       0.3854;      // -   [origin=predictive method=lee-kesler]
Tb          291.08;      // K   [origin=predictive method=joback]
HvapTb      32126.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.23 0.1409 -0.000214 1.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group OH; count 1; } { group SiH3; count 1; } { group SiH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxidanyl(silanyl)silane" );
gibbsFormation
{
    dHf_298   -139750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135320.0
    phase     gas;
}
