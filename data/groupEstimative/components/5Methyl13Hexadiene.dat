/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-1,3-hexadiene  (C7H12, CAS 2783-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl13Hexadiene;
formula     C7H12;
CAS         2783-10-0;
InChIKey    HQLSCIPCIFAMOK-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          540.50;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.2679;      // -   [origin=predictive method=lee-kesler]
Tb          360.16;      // K   [origin=predictive method=joback]
HvapTb      30076.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.33 0.67474 -0.0004669 1.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylhexa-1,3-diene" "1,3-hexadiene,5-methyl-" "1,3-hexadiene,5-methyl-, (3e)-" "1,3-hexadiene,5-methyl-, (e)-; (e)-1-isopropyl-1,3-butadiene; (e)-5-methyl-1,3-hexadiene;trans-2-methyl-3,5-hexadiene" );
gibbsFormation
{
    dHf_298   49560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173680.0
    phase     gas;
}
