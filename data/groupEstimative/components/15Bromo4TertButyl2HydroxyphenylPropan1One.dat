/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(5-bromo-4-tert-butyl-2-hydroxyphenyl)propan-1-one  (C13H17BrO2, CAS 35154-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Bromo4TertButyl2HydroxyphenylPropan1One;
formula     C13H17BrO2;
CAS         35154-28-0;
InChIKey    CXPSWPHSFBXYIK-UHFFFAOYSA-N;
MW          285.181;      // g/mol [origin=calculated method=formula-sum]
Tc          970.27;      // K   [origin=predictive method=joback]
Pc          28.750;      // bar [origin=predictive method=joback]
omega       0.9418;      // -   [origin=predictive method=lee-kesler]
Tb          731.10;      // K   [origin=predictive method=joback]
HvapTb      73031.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.079 1.33158 -0.00106138 3.4926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5-bromanyl-4-tert-butyl-2-oxidanyl-phenyl)propan-1-one" "propiophenone, 5-bromo-4-tert-butyl-2-hydroxy-" "propiophenone, 5-bromo-4-tert-butyl-2-hydroxy-," );
gibbsFormation
{
    dHf_298   -370370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114650.0
    phase     gas;
}
