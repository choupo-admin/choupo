/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,3,4-tetramethylpentane  (C9H20, CAS 1186-53-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2234Tetramethylpentane;
formula     C9H20;
CAS         1186-53-4;
InChIKey    VZFMYOCAEQDWDY-UHFFFAOYSA-N;
MW          128.259;      // g/mol [origin=calculated method=formula-sum]
Tc          583.14;      // K   [origin=predictive method=joback]
Pc          23.865;      // bar [origin=predictive method=joback]
omega       0.2963;      // -   [origin=predictive method=lee-kesler]
Tb          401.41;      // K   [origin=predictive method=joback]
HvapTb      33556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.13 0.99652 -0.000644 1.668e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 2; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane, 2,2,3,4-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -248400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=22860.0
}
