/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tribromo-3-hydroxybenzoic acid  (C7H3Br3O3, CAS 14348-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Tribromo3HydroxybenzoicAcid;
formula     C7H3Br3O3;
CAS         14348-40-4;
InChIKey    YDBHVMTTYXWHLI-UHFFFAOYSA-N;
MW          374.81;      // g/mol [origin=calculated method=formula-sum]
Tc          1102.33;      // K   [origin=predictive method=joback]
Pc          74.445;      // bar [origin=predictive method=joback]
omega       1.4485;      // -   [origin=predictive method=lee-kesler]
Tb          825.99;      // K   [origin=predictive method=joback]
HvapTb      84921.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.77 0.7314 -0.00073024 2.863e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 4; } { group ACOH; count 1; } { group COOH; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Br; count 3; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(bromanyl)-3-oxidanyl-benzoic acid" "3-hydroxy-2,4,6-tribromobenzoic acid" "benzoic acid, 2,4,6-tribromo-3-hydroxy-" "2,4,6-thba" "p330" "2,4,6-tribromo-3-hydroxybenzoicacid;tbhba;" );
gibbsFormation
{
    dHf_298   -434280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363990.0
    phase     gas;
}
