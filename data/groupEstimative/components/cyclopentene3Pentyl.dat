/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene,3-pentyl-  (C10H18, CAS 37689-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentene3Pentyl;
formula     C10H18;
CAS         37689-14-8;
InChIKey    GLIXSFLUBRAPLZ-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          634.14;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.3973;      // -   [origin=predictive method=lee-kesler]
Tb          442.84;      // K   [origin=predictive method=joback]
HvapTb      38403.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.906 1.02952 -0.00063488 1.515e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pentylcyclopentene" "3-pentyl-1-cyclopentene" "cyclopentene, 3-pentyl-" );
gibbsFormation
{
    dHf_298   -131470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99830.0
    phase     gas;
}
