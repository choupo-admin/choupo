/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-amino-3,5-dibromobenzoate  (C8H7Br2NO2, CAS 606-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2Amino35Dibromobenzoate;
formula     C8H7Br2NO2;
CAS         606-00-8;
InChIKey    NGXVMFCGYYHEGC-UHFFFAOYSA-N;
MW          308.957;      // g/mol [origin=calculated method=formula-sum]
Tc          942.44;      // K   [origin=predictive method=joback]
Pc          44.444;      // bar [origin=predictive method=joback]
omega       0.9181;      // -   [origin=predictive method=lee-kesler]
Tb          687.33;      // K   [origin=predictive method=joback]
HvapTb      68582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.89 0.58992 -0.00033308 5.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACNH2; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-azanyl-3,5-bis(bromanyl)benzoate" "methyl 3,5-dibromoanthranilate" "3,5-dibromoanthranilic acid methyl ester" "anthranilic acid, 3,5-dibromo-, methyl ester" "2-amino-3,5-dibromobenzoic acid methyl ester" "benzoic acid, 2-amino-3,5-dibromo-, methyl ester" "benzoic acid,5-dibromo-, methyl ester" "3,5-dibromanthranilic acid, methyl ester" "anthranilic acid,5-dibromo-, methyl ester" "2-amino-3,5-dibromo benzoic acid methyl ester" "2-amino-3,5-dibromo-benzoic acid methyl  ester" );
standardThermochemistry
{
    dHf_298   -237160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-115280.0
}
