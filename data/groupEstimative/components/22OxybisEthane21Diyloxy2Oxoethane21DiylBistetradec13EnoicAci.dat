/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-{oxybis[ethane-2,1-diyloxy(2-oxoethane-2,1-diyl)]}bistetradec-13-enoic acid  (C36H62O9, CAS 68128-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22OxybisEthane21Diyloxy2Oxoethane21DiylBistetradec13EnoicAci;
formula     C36H62O9;
CAS         68128-23-4;
InChIKey    BXBUYAUHGSITOZ-UHFFFAOYSA-N;
MW          638.883;      // g/mol [origin=calculated method=formula-sum]
Tc          2106.52;      // K   [origin=predictive method=joback]
Pc          5.158;      // bar [origin=predictive method=joback]
omega       -0.3318;      // -   [origin=predictive method=lee-kesler]
Tb          1445.64;      // K   [origin=predictive method=joback]
HvapTb      145166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.336 3.3244 -0.0018318 3.38e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 23; } { group CH; count 2; } { group CH2=CH; count 2; } { group CH2COO; count 2; } { group CH2O; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 26; } { group CH; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group O; count 1; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(3-carboxypentadec-14-enoyloxy)ethoxy]ethoxy]-2-oxidanylidene-ethyl]tetradec-13-enoic acid" "butanedioic acid, dodecenyl-, oxydi-2,1-ethanediyl ester" "butanedioic acid, 2-(dodecen-1-yl)-, 1,1'-(oxydi-2,1-ethanediyl) ester" "diethylene glycol bis(dodecenylsuccinate)" "2-dodecenylsuccinic acid, ester with 2,2'-oxydiethanol (2:1)" "2-[2-[2-[2-(3-carboxypentadec-14-enoyloxy)ethoxy]ethoxy]-2-oxoethyl]tetradec-13-enoic acid" );
standardThermochemistry
{
    dHf_298   -2013390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1750.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-990520.0
}
