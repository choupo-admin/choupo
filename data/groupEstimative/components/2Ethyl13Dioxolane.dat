/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-1,3-dioxolane  (C5H10O2, CAS 2568-96-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl13Dioxolane;
formula     C5H10O2;
CAS         2568-96-9;
InChIKey    WEBRDDDJKLAXTO-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          581.77;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       0.3293;      // -   [origin=predictive method=lee-kesler]
Tb          383.18;      // K   [origin=predictive method=joback]
HvapTb      36001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.499 0.60452 -0.0003478 7.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-ethyl-" "propanal, cyclic 1,2-ethanediyl acetal" "2-ethyl dioxolane" "2-ethyl-1,3-dioxacyclopentane;2-ethyl-1,3-dioxolane; 2-ethyldioxolane; propanal, cyclic 1,2-ethanediyl acetal" );
gibbsFormation
{
    dHf_298   -350050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     197.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144470.0
    phase     gas;
}
