/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlormadinone  (C21H27ClO3, CAS 1961-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlormadinone;
formula     C21H27ClO3;
CAS         1961-77-9;
InChIKey    VUHJZBBCZGVNDZ-TTYLFXKOSA-N;
MW          362.894;      // g/mol [origin=calculated method=formula-sum]
Tc          1226.36;      // K   [origin=predictive method=joback]
Pc          18.499;      // bar [origin=predictive method=joback]
omega       1.2258;      // -   [origin=predictive method=lee-kesler]
Tb          979.35;      // K   [origin=predictive method=joback]
HvapTb      92746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-274.74 2.99066 -0.00288298 1.17936e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group C; count 3; } { group CH=C; count 2; } { group OH; count 1; } { group CH3CO; count 1; } { group CH2CO; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } { group CdO; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17r)-6-chloranyl-17-ethanoyl-10,13-dimethyl-17-oxidanyl-2,8,9,11,12,14,15,16-octahydro-1h-cyclopenta[a]phenanthren-3-one" "chlormadinon" "6-chloro-17-hydroxypregna-4,6-diene-3,20-dione" "clormadinone [dcit]" "chlormadinone [inn:ban]" "chlormadinonum [inn-latin]" "pregna-4,6-diene-3,20-dione, 6-chloro-17-hydroxy-" "chlormadinonum" "clormadinona" "clormadinone" "chlormadinone (inn)" "m167" );
standardThermochemistry
{
    dHf_298   -536960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     781.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83050.0
}
