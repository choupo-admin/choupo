/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl prop-2-enoate; ethyl prop-2-enoate; styrene  (C20H28O4, CAS 51243-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylProp2EnoateEthylProp2EnoateStyrene;
formula     C20H28O4;
CAS         51243-47-1;
InChIKey    CKDRPPBTNRFVHP-UHFFFAOYSA-N;
MW          332.44;      // g/mol [origin=calculated method=formula-sum]
Tc          1000.32;      // K   [origin=predictive method=joback]
Pc          12.337;      // bar [origin=predictive method=joback]
omega       0.8309;      // -   [origin=predictive method=lee-kesler]
Tb          793.16;      // K   [origin=predictive method=joback]
HvapTb      75782.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.284 1.24294 -0.0001453 -2.441e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2=CH; count 3; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;ethenylbenzene;ethyl prop-2-enoate" "styrene, ethyl acrylate, n-butyl acrylate polymer" );
gibbsFormation
{
    dHf_298   -701110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1132.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-336810.0
    phase     gas;
}
