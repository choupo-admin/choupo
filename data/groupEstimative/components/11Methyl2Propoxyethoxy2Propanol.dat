/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-Methyl-2-propoxyethoxy)-2-propanol  (C9H20O3, CAS 29911-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Methyl2Propoxyethoxy2Propanol;
formula     C9H20O3;
CAS         29911-27-1;
InChIKey    WEZPLQKRXDBPEP-UHFFFAOYSA-N;
MW          176.256;      // g/mol [origin=calculated method=formula-sum]
Tc          706.59;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       1.0040;      // -   [origin=predictive method=lee-kesler]
Tb          541.66;      // K   [origin=predictive method=joback]
HvapTb      56351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.634 0.77826 -0.0002806 -4.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-propoxypropan-2-yloxy)propan-2-ol" "2-Propanol, 1-(1-methyl-2-propoxyethoxy)-" "arcosolv dpnp" "celtol dpnp" "dipropylene glycol mono-n-propyl ether" "dipropylene glycol, monopropyl ether" "dipropylene glycol, propyl ether" "dowanol dpnp" "butyl dipropasol solvent" "1-(1-Methyl-2-propoxyethoxy)2-propanol" "1-(1-Methyl-2-propoxyethoxy)propan-2-ol" "1-[(1-PROPOXYPROPAN-2-YL)OXY]PROPAN-2-OL" );
gibbsFormation
{
    dHf_298   -656320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-326800.0
    phase     gas;
}
