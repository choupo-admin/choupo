/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-inden-1-one, 7a-ethyloctahydro-  (C11H18O, CAS 74895-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hInden1One7aEthyloctahydro;
formula     C11H18O;
CAS         74895-97-9;
InChIKey    YKVXLDMZVJNKHD-UHFFFAOYSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          781.72;      // K   [origin=predictive method=joback]
Pc          28.936;      // bar [origin=predictive method=joback]
omega       0.4412;      // -   [origin=predictive method=lee-kesler]
Tb          545.63;      // K   [origin=predictive method=joback]
HvapTb      43518.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.519 1.44542 -0.0011644 4.136e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7a-ethyl-3,3a,4,5,6,7-hexahydro-2h-inden-1-one" );
standardThermochemistry
{
    dHf_298   -265710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1140.0
}
