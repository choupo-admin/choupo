/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2,2-diethyl-3-oxobutanoate  (C10H18O3, CAS 1619-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl22Diethyl3Oxobutanoate;
formula     C10H18O3;
CAS         1619-57-4;
InChIKey    WEIQRLLXVVSKIL-UHFFFAOYSA-N;
MW          186.251;      // g/mol [origin=calculated method=formula-sum]
Tc          725.73;      // K   [origin=predictive method=joback]
Pc          22.871;      // bar [origin=predictive method=joback]
omega       0.6740;      // -   [origin=predictive method=lee-kesler]
Tb          537.26;      // K   [origin=predictive method=joback]
HvapTb      50711.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.093 0.99688 -0.0005787 1.1356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2-diethyl-3-oxidanylidene-butanoate" "ethyl 2,2-diethylacetoacetate" "butanoic acid, 2,2-diethyl-3-oxo-, ethyl ester" "diethyl acetoacetate" "acetoacetic acid, 2,2-diethyl-, ethyl ester" "butanoic acid,2,2-diethyl-3-oxo-, ethyl ester" "acetoaceticacid, 2,2-diethyl-, ethyl ester (6ci,7ci,8ci); ethyl a,a-diethylacetoacetate" );
gibbsFormation
{
    dHf_298   -688340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-403130.0
    phase     gas;
}
