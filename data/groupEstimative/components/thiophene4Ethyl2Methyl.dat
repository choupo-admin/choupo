/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiophene, 4-ethyl-2-methyl-  (C7H10S, CAS 13678-54-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiophene4Ethyl2Methyl;
formula     C7H10S;
CAS         13678-54-1;
InChIKey    KIWVMUQUYOKTKU-UHFFFAOYSA-N;
MW          126.217;      // g/mol [origin=calculated method=formula-sum]
Tc          654.51;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.3267;      // -   [origin=predictive method=lee-kesler]
Tb          435.82;      // K   [origin=predictive method=joback]
HvapTb      39462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.919 0.61045 -0.00039898 1.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyl-2-methyl-thiophene" "4-ethyl-2-methylthiophene" "2-methyl-4-ethyl thiophene" );
gibbsFormation
{
    dHf_298   30890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132840.0
    phase     gas;
}
