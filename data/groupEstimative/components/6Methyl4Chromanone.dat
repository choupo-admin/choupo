/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyl-4-chromanone  (C10H10O2, CAS 39513-75-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyl4Chromanone;
formula     C10H10O2;
CAS         39513-75-2;
InChIKey    RJHXEPLSJAVTFW-UHFFFAOYSA-N;
MW          162.188;      // g/mol [origin=calculated method=formula-sum]
Tc          822.88;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.5475;      // -   [origin=predictive method=lee-kesler]
Tb          575.49;      // K   [origin=predictive method=joback]
HvapTb      50605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.06 0.75242 -0.00038862 5.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH2CO; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-2,3-dihydrochromen-4-one" "6-methylchroman-4-one" "6-methyl-2,3-dihydro-4h-chromen-4-one" "6-methyl-2,3-dihydro-1-benzopyran-4-one" "4h-1-benzopyran-4-one, 2,3-dihydro-6-methyl-" );
gibbsFormation
{
    dHf_298   -218860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     268.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-25880.0
    phase     gas;
}
