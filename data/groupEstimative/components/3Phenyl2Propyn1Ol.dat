/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-2-propyn-1-ol  (C9H8O, CAS 1504-58-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl2Propyn1Ol;
formula     C9H8O;
CAS         1504-58-1;
InChIKey    NITUNGCLDSFVDL-UHFFFAOYSA-N;
MW          132.162;      // g/mol [origin=calculated method=formula-sum]
Tc          753.60;      // K   [origin=predictive method=joback]
Pc          44.504;      // bar [origin=predictive method=joback]
omega       0.7098;      // -   [origin=predictive method=lee-kesler]
Tb          533.38;      // K   [origin=predictive method=joback]
HvapTb      56735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.349 0.6641 -0.00043526 1.1018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylprop-2-yn-1-ol" "2-propyn-1-ol, 3-phenyl-" "3-phenyl-prop-2-yn-1-ol" "1-hydroxymethyl-2-phenylacetylene" "3-phenylpropargyl alcohol" "1-phenyl-1-propyn-3-ol" "phenylpropargyl alcohol" "u512" );
standardThermochemistry
{
    dHf_298   127510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203290.0
}
