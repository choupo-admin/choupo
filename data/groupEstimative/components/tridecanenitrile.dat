/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecanenitrile  (C13H25N, CAS 629-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecanenitrile;
formula     C13H25N;
CAS         629-60-7;
InChIKey    WKJHMKQSIBMURP-UHFFFAOYSA-N;
MW          195.35;      // g/mol [origin=calculated method=formula-sum]
Tc          775.73;      // K   [origin=predictive method=joback]
Pc          16.116;      // bar [origin=predictive method=joback]
omega       0.7860;      // -   [origin=predictive method=lee-kesler]
Tb          599.12;      // K   [origin=predictive method=joback]
HvapTb      55010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.071 1.17362 -0.0006524 1.372e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl cyanide" "1-cyanododecane" "nitriles, c10-16" "tridecannitril" "lauryl cyanide" "n-tridecanonitrile" "n-dodecyl cyanide" "(c10-c16) alkylnitrile" );
gibbsFormation
{
    dHf_298   -146770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     668.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191760.0
    phase     gas;
}
