/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanal, heptafluoro-  (C4HF7O, CAS 375-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanalHeptafluoro;
formula     C4HF7O;
CAS         375-02-0;
InChIKey    IQJZGNJYXIIMGP-UHFFFAOYSA-N;
MW          198.037;      // g/mol [origin=calculated method=formula-sum]
Tc          466.57;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.4649;      // -   [origin=predictive method=lee-kesler]
Tb          324.98;      // K   [origin=predictive method=joback]
HvapTb      21611.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.13 0.8183 -0.000817 2.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group CF3; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 7; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,4,4,4-heptakis(fluoranyl)butanal" "heptafluorobutyraldehyde" "butyraldehyde, heptafluoro-" "heptafluorobutyraldehyde, tech." "2,2,3,3,4,4,4-heptafluorobutanal" "butanal,2,2,3,3,4,4,4-heptafluoro-" );
gibbsFormation
{
    dHf_298   -1610490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1471870.0
    phase     gas;
}
