/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylaminoethylpyridine  (C8H12N2, CAS 55496-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylaminoethylpyridine;
formula     C8H12N2;
CAS         55496-55-4;
InChIKey    QZBUGNURVLWJPK-UHFFFAOYSA-N;
MW          136.198;      // g/mol [origin=calculated method=formula-sum]
Tc          735.82;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.5440;      // -   [origin=predictive method=lee-kesler]
Tb          513.19;      // K   [origin=predictive method=joback]
HvapTb      48324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.438 0.79488 -0.00050046 1.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3NH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-2-pyridin-4-yl-ethanamine" "n-methyl-2-(pyridin-4-yl)ethanamine" "4-[2-(methylamino)ethyl]pyridine" "methyl[2-(pyridin-4-yl)ethyl]amine" "n-methyl-n-(2-pyridin-4-ylethyl)amine" "4-(2-methylamino)ethyl)pyridine" "methyl(2-(4-pyridyl)ethyl)amine" "pyridine, 4-(2-methylaminoethyl)-" "4-(2-(methylamino)ethyl)pyridine" "4-pyridineethanamine,n-methyl-" "n-methyl-2-pyridin-4-ylethanamine" "n-methyl-2-(4-pyridinyl)ethanamine" );
standardThermochemistry
{
    dHf_298   114340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=295330.0
}
