/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(octylamino)propanenitrile  (C11H22N2, CAS 29504-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3OctylaminoPropanenitrile;
formula     C11H22N2;
CAS         29504-89-0;
InChIKey    AFXXFNVAHYRPIZ-UHFFFAOYSA-N;
MW          182.311;      // g/mol [origin=calculated method=formula-sum]
Tc          785.07;      // K   [origin=predictive method=joback]
Pc          19.136;      // bar [origin=predictive method=joback]
omega       0.8603;      // -   [origin=predictive method=lee-kesler]
Tb          603.53;      // K   [origin=predictive method=joback]
HvapTb      56994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.679 1.05982 -0.0005922 1.239e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2NH; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group NH; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(octylamino)propionitrile" "propanenitrile, 3-(octylamino)-" "3-(octylamino)propiononitrile" "propanenitrile,3-(octylamino)-" );
standardThermochemistry
{
    dHf_298   -52020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=264310.0
}
