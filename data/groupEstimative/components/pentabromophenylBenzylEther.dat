/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentabromophenyl benzyl ether  (C13H7Br5O, CAS 38521-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentabromophenylBenzylEther;
formula     C13H7Br5O;
CAS         38521-49-2;
InChIKey    SMSGVBSSPGZMES-UHFFFAOYSA-N;
MW          578.718;      // g/mol [origin=calculated method=formula-sum]
Tc          1222.40;      // K   [origin=predictive method=joback]
Pc          41.570;      // bar [origin=predictive method=joback]
omega       1.2416;      // -   [origin=predictive method=lee-kesler]
Tb          928.52;      // K   [origin=predictive method=joback]
HvapTb      86979.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.211 0.9113 -0.0006566 1.857e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 7; } { group CH2O; count 1; } { group Br; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group Br; count 5; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(bromanyl)-6-phenylmethoxy-benzene" "1,2,3,4,5-pentabromo-6-phenylmethoxybenzene" "benzene, 1,2,3,4,5-pentabromo-6-(phenylmethoxy)-" "pentabromo-alpha-phenylanisole" "benzene, pentabromo(phenylmethoxy)-" "1-(benzyloxy)-2,3,4,5,6-pentabromobenzene" "benzene,1,2,3,4,5-pentabromo-6-(phenylmethoxy)-" "benzene,pentabromo(phenylmethoxy)- (9ci); pentabromophenyl benzyl ether" );
standardThermochemistry
{
    dHf_298   103490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201850.0
}
