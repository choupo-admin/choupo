/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl methacrylate  (C12H22O2, CAS 2157-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylMethacrylate;
formula     C12H22O2;
CAS         2157-01-9;
InChIKey    NZIDBRBFGPQCRY-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          701.65;      // K   [origin=predictive method=joback]
Pc          18.611;      // bar [origin=predictive method=joback]
omega       0.6856;      // -   [origin=predictive method=lee-kesler]
Tb          528.94;      // K   [origin=predictive method=joback]
HvapTb      49123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.707 1.06894 -0.0005596 9.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl 2-methylprop-2-enoate" "n-octyl methacrylate" "2-propenoic acid, 2-methyl-, octyl ester" "octyl 2-methyl-2-propenoate" "octyl 2-methylacrylate" );
gibbsFormation
{
    dHf_298   -492650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-180920.0
    phase     gas;
}
