/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-acetylindan  (C11H12O, CAS 4228-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Acetylindan;
formula     C11H12O;
CAS         4228-10-8;
InChIKey    HCMWPTFPUCPKQM-UHFFFAOYSA-N;
MW          160.216;      // g/mol [origin=calculated method=formula-sum]
Tc          783.59;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.5563;      // -   [origin=predictive method=lee-kesler]
Tb          553.20;      // K   [origin=predictive method=joback]
HvapTb      50648.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.24 1.00032 -0.00072862 2.1386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,3-dihydro-1h-inden-5-yl)ethanone" "5-acetylindane" "1-(2,3-dihydro-1h-inden-5-yl)ethan-1-one" "ethanone,3-dihydro-1h-inden-5-yl)-" "indan-5-ylethan-1-one" "ketone,5-indanyl methyl (6ci,7ci,8ci);1-(indan-5-yl)ethanone;5-acetylindan;" );
gibbsFormation
{
    dHf_298   -76220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74430.0
    phase     gas;
}
