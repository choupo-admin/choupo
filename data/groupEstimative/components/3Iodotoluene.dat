/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodotoluene  (C7H7I, CAS 625-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Iodotoluene;
formula     C7H7I;
CAS         625-95-6;
InChIKey    VLCPISYURGTGLP-UHFFFAOYSA-N;
MW          218.033;      // g/mol [origin=calculated method=formula-sum]
Tc          737.93;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.2913;      // -   [origin=predictive method=lee-kesler]
Tb          484.56;      // K   [origin=predictive method=joback]
HvapTb      43487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.39 0.56942 -0.00040256 1.126e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-3-methyl-benzene" "m-iodotoluene" "1-iodo-3-methylbenzene" "benzene, 1-iodo-3-methyl-" "m-tolyl iodide" "m-methyliodobenzene" "toluene, m-iodo-" "3-methylphenyl iodide" "toluene, m-iodo- (7ci,8ci)" "1-iodo-3-methyl-benzene" );
standardThermochemistry
{
    dHf_298   114120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168960.0
}
