/*--------------------------------*- Choupo -*-----------------------*\
  Component: erbon  (C11H9Cl5O3, CAS 136-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        erbon;
formula     C11H9Cl5O3;
CAS         136-25-4;
InChIKey    KMHZPJNVPCAUMN-UHFFFAOYSA-N;
MW          366.44;      // g/mol [origin=calculated method=formula-sum]
Tc          993.31;      // K   [origin=predictive method=joback]
Pc          21.315;      // bar [origin=predictive method=joback]
omega       0.8601;      // -   [origin=predictive method=lee-kesler]
Tb          757.46;      // K   [origin=predictive method=joback]
HvapTb      74788.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.772 0.83322 -0.00047288 7.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group CH2O; count 1; } { group CCl2; count 1; } { group ACCl; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 5; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4,5-tris(chloranyl)phenoxy]ethyl 2,2-bis(chloranyl)propanoate" "pentanate" "novege" "baron" "novon" "erbn" "erbon [ansi]" "propanoic acid, 2,2-dichloro-, 2-(2,4,5-trichlorophenoxy)ethyl ester" "2-(2,4,5-trichlorophenoxy)ethyl 2,2-dichloropropanoate" "2-(2,4,5-trichlorophenoxy)ethyl 2,2-dichloropropionate" "2,4,5-trichlorophenoxyethyl-alpha,alpha-dichloropropionate" "ethanol, 2-(2,4,5-trichlorophenoxy)-, 2,2-dichloropropionate" );
standardThermochemistry
{
    dHf_298   -605200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-346920.0
}
