/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hydroxy-2,2-dimethyl-3-phenylpropionic acid  (C11H14O3, CAS 23985-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hydroxy22Dimethyl3PhenylpropionicAcid;
formula     C11H14O3;
CAS         23985-59-3;
InChIKey    KTEPFMROLJOJHE-UHFFFAOYSA-N;
MW          194.23;      // g/mol [origin=calculated method=formula-sum]
Tc          928.01;      // K   [origin=predictive method=joback]
Pc          33.220;      // bar [origin=predictive method=joback]
omega       1.2018;      // -   [origin=predictive method=lee-kesler]
Tb          711.98;      // K   [origin=predictive method=joback]
HvapTb      74515.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.28 1.18644 -0.0008838 2.544e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-3-oxidanyl-3-phenyl-propanoic acid" "benzenepropanoic acid, b-hydroxy-a,a-dimethyl-" "hydracrylicacid, 2,2-dimethyl-3-phenyl- (8ci); hydrocinnamic acid, b-hydroxy-a,a-dimethyl- (4ci)" );
standardThermochemistry
{
    dHf_298   -550370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-326180.0
}
