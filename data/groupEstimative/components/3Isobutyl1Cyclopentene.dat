/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-isobutyl-1-cyclopentene  (C9H16, CAS 37689-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Isobutyl1Cyclopentene;
formula     C9H16;
CAS         37689-12-6;
InChIKey    VEJUMQITLZVKQQ-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          617.30;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.3188;      // -   [origin=predictive method=lee-kesler]
Tb          419.52;      // K   [origin=predictive method=joback]
HvapTb      35789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.679 0.94044 -0.00058368 1.391e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylpropyl)cyclopentene" "cyclopentene, 3-(2-methylpropyl)-" );
standardThermochemistry
{
    dHf_298   -116110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88970.0
}
