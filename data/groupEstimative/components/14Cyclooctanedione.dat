/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-cyclooctanedione  (C8H12O2, CAS 55794-45-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Cyclooctanedione;
formula     C8H12O2;
CAS         55794-45-1;
InChIKey    LZTHLBQVLFQNKK-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          806.71;      // K   [origin=predictive method=joback]
Pc          37.730;      // bar [origin=predictive method=joback]
omega       0.4448;      // -   [origin=predictive method=lee-kesler]
Tb          551.04;      // K   [origin=predictive method=joback]
HvapTb      42978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.31 0.5566 3.3e-05 -1.64e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclooctane-1,4-dione" "cyclooctane-1,4-quinone" );
gibbsFormation
{
    dHf_298   -421510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-220740.0
    phase     gas;
}
