/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-difluoroanisole  (C7H6F2O, CAS 93343-10-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Difluoroanisole;
formula     C7H6F2O;
CAS         93343-10-3;
InChIKey    OTGQPYSISUUHAF-UHFFFAOYSA-N;
MW          144.12;      // g/mol [origin=calculated method=formula-sum]
Tc          608.54;      // K   [origin=predictive method=joback]
Pc          34.765;      // bar [origin=predictive method=joback]
omega       0.4315;      // -   [origin=predictive method=lee-kesler]
Tb          417.36;      // K   [origin=predictive method=joback]
HvapTb      35552.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.9 0.43132 -0.00017592 4.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3O; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(fluoranyl)-5-methoxy-benzene" "1,3-difluoro-5-methoxybenzene" "3,5-difluoro-1-methoxybenzene" "3,5-difluoro anisole" "benzene, 1,3-difluoro-5-methoxy-" "3,5-difluorophenyl methyl ether" "otgqpysisuuhaf-uhfffaoysa-" "wt216" "93343-10-3 3,5-difluoroanisole" "toluene,a,a,a,3,4-pentafluoro-(8ci);1,2-difluoro-4-(trifluoromethyl)benzene;a,a,a,3,4-pentafluorotoluene;" );
gibbsFormation
{
    dHf_298   -498660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-393410.0
    phase     gas;
}
