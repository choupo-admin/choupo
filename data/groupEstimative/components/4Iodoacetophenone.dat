/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-iodoacetophenone  (C8H7IO, CAS 13329-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Iodoacetophenone;
formula     C8H7IO;
CAS         13329-40-3;
InChIKey    JZJWCDQGIPQBAO-UHFFFAOYSA-N;
MW          246.043;      // g/mol [origin=calculated method=formula-sum]
Tc          818.69;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.4623;      // -   [origin=predictive method=lee-kesler]
Tb          561.31;      // K   [origin=predictive method=joback]
HvapTb      52459.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.94 0.63642 -0.00043826 1.1546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-iodophenyl)ethanone" "4-iodoacetophenone" "p-iodoacetophenone" "1-(4-iodophenyl)ethan-1-one" "ethanone, 1-(4-iodophenyl)-" "1-acetyl-4-iodobenzene" "agn-pc-00boyy" "1-(4-iodophenyl)-ethanone" "1-(4-iodo-phenyl)-ethanone" "1-(4-iodophenyl)-1-oxoethane" "wt169" "13329-40-3 4'-iodoacetophenone" );
gibbsFormation
{
    dHf_298   -19100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48460.0
    phase     gas;
}
