/*--------------------------------*- Choupo -*-----------------------*\
  Component: octamethyltrisilane  (C8H24Si3, CAS 3704-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H24Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        octamethyltrisilane;
formula     C8H24Si3;
CAS         3704-44-7;
InChIKey    DDIMPUQNMJIVKL-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          204.535;      // g/mol [origin=calculated method=formula-sum]
Tc          568.78;      // K   [origin=predictive method=joback]
Pc          18.170;      // bar [origin=predictive method=joback]
omega       0.1410;      // -   [origin=predictive method=lee-kesler]
Tb          386.84;      // K   [origin=predictive method=joback]
HvapTb      34284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (118.07 0.14536 0.000833 -5.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl-bis(trimethylsilyl)silane" "trisilane, octamethyl-" );
standardThermochemistry
{
    dHf_298   -543310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297800.0
}
