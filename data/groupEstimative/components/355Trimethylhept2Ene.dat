/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5,5-trimethylhept-2-ene  (C10H20, CAS 39083-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        355Trimethylhept2Ene;
formula     C10H20;
CAS         39083-40-4;
InChIKey    DCHMHNYBYHOYQC-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          613.84;      // K   [origin=predictive method=joback]
Pc          22.633;      // bar [origin=predictive method=joback]
omega       0.3439;      // -   [origin=predictive method=lee-kesler]
Tb          429.21;      // K   [origin=predictive method=joback]
HvapTb      36596.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.548 1.0996 -0.0007781 2.289e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group C; count 1; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -151050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107830.0
}
