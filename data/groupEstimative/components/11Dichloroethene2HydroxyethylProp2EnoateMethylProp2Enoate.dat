/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloroethene; 2-hydroxyethyl prop-2-enoate; methyl prop-2-enoate  (C11H16Cl2O5, CAS 63744-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloroethene2HydroxyethylProp2EnoateMethylProp2Enoate;
formula     C11H16Cl2O5;
CAS         63744-63-8;
InChIKey    HJVFHUPJXKAULW-UHFFFAOYSA-N;
MW          299.144;      // g/mol [origin=calculated method=formula-sum]
Tc          922.48;      // K   [origin=predictive method=joback]
Pc          19.052;      // bar [origin=predictive method=joback]
omega       1.1053;      // -   [origin=predictive method=lee-kesler]
Tb          727.48;      // K   [origin=predictive method=joback]
HvapTb      79001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (147.752 0.51432 0.000302 -3.471e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group OH; count 1; } { group Cl_C=C_; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group Cl; count 2; } { group OH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)ethene;2-hydroxyethyl prop-2-enoate;methyl prop-2-enoate" "2-propenoic acid, 2-hydroxyethyl ester, polymer with 1,1-dichloroethene and methyl 2-propenoate" "2-hydroxyethyl-2-propenoate, 1,1-dichloroethane, methyl 2-propenate polymer" );
gibbsFormation
{
    dHf_298   -945380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1002.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-694230.0
    phase     gas;
}
