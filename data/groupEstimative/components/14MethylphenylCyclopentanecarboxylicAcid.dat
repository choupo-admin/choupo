/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methylphenyl)cyclopentanecarboxylic acid  (C13H16O2, CAS 80789-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14MethylphenylCyclopentanecarboxylicAcid;
formula     C13H16O2;
CAS         80789-75-9;
InChIKey    YKDWTRWSHHGVII-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          936.73;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.7771;      // -   [origin=predictive method=lee-kesler]
Tb          689.73;      // K   [origin=predictive method=joback]
HvapTb      63740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.41 1.57482 -0.00138016 5.096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methylphenyl)cyclopentane-1-carboxylic acid" "1-p-tolyl-cyclopentanecarboxylic acid" "cyclopentanecarboxylicacid, 1-(4-methylphenyl)-" "cyclopentanecarboxylic acid, 1-(4-methylphenyl)-" "1-(4-methylphenyl)-1-cyclohepentanecarboxylic acid" );
standardThermochemistry
{
    dHf_298   -361140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-151490.0
}
