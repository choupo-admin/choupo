/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-methyl-3-cyclohexen-1-yl)-3-butenyl 2-methylbutyrate  (C16H26O2, CAS 72928-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Methyl3Cyclohexen1Yl3Butenyl2Methylbutyrate;
formula     C16H26O2;
CAS         72928-25-7;
InChIKey    BJWDLKYOQKQDLM-UHFFFAOYSA-N;
MW          250.382;      // g/mol [origin=calculated method=formula-sum]
Tc          843.32;      // K   [origin=predictive method=joback]
Pc          16.418;      // bar [origin=predictive method=joback]
omega       0.7027;      // -   [origin=predictive method=lee-kesler]
Tb          643.71;      // K   [origin=predictive method=joback]
HvapTb      59022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.137 1.46146 -0.00078164 1.297e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group CH2=C; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-methylcyclohex-3-en-1-yl)but-3-enyl 2-methylbutanoate" "3-(4-methyl-3-cyclohexen-1-yl)but-3-enyl 2-methylbutyrate" "butanoic acid, 2-methyl-, 3-(4-methyl-3-cyclohexen-1-yl)-3-buten-1-yl ester" "3-(4-methyl-3-cyclohexen-1-yl)-3-butenyl 2-methylbutanoate" "butanoic acid, 2-methyl-, 3-(4-methyl-3-cyclohexen-1-yl)-3-butenyl ester" "butanoic acid,2-methyl-, 3-(4-methyl-3-cyclohexen-1-yl)-3-buten-1-yl ester" "butanoicacid, 2-methyl-, 3-(4-methyl-3-cyclohexen-1-yl)-3-butenyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -479860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     738.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104900.0
}
