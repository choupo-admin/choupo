/*--------------------------------*- Choupo -*-----------------------*\
  Component: octanenitrile  (C8H15N, CAS 124-12-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octanenitrile;
formula     C8H15N;
CAS         124-12-9;
InChIKey    YSIMAPNUZAVQER-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          669.93;      // K   [origin=predictive method=joback]
Pc          24.727;      // bar [origin=predictive method=joback]
omega       0.5664;      // -   [origin=predictive method=lee-kesler]
Tb          484.72;      // K   [origin=predictive method=joback]
HvapTb      43880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.616 0.69862 -0.0003804 7.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "caprylonitrile" "arneel 8" "caprylnitrile" "octanonitrile" "1-cyanoheptane" "heptyl cyanide" "n-heptyl cyanide" "q532" );
standardThermochemistry
{
    dHf_298   -43570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149660.0
}
