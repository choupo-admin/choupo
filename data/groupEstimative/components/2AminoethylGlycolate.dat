/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-aminoethyl glycolate  (C4H9NO3, CAS 67674-52-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AminoethylGlycolate;
formula     C4H9NO3;
CAS         67674-52-6;
InChIKey    FPWNJWWLQAXJAA-UHFFFAOYSA-N;
MW          119.12;      // g/mol [origin=calculated method=formula-sum]
Tc          695.79;      // K   [origin=predictive method=joback]
Pc          47.694;      // bar [origin=predictive method=joback]
omega       1.0610;      // -   [origin=predictive method=lee-kesler]
Tb          514.05;      // K   [origin=predictive method=joback]
HvapTb      59225.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.443 0.4249 -0.000173 1e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group OH; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylethyl 2-oxidanylethanoate" "acetic acid, hydroxy-, 2-aminoethyl ester" "acetic acid, 2-hydroxy-, 2-aminoethyl ester" "2-aminoethyl hydroxyacetate" "2-aminoethyl 2-hydroxyacetate" );
standardThermochemistry
{
    dHf_298   -561610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397940.0
}
