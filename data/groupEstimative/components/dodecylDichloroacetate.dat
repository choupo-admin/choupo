/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl dichloroacetate  (C14H26Cl2O2, CAS 83005-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecylDichloroacetate;
formula     C14H26Cl2O2;
CAS         83005-01-0;
InChIKey    XOWWGPRKFWEEDR-UHFFFAOYSA-N;
MW          297.26;      // g/mol [origin=calculated method=formula-sum]
Tc          830.04;      // K   [origin=predictive method=joback]
Pc          14.535;      // bar [origin=predictive method=joback]
omega       0.8730;      // -   [origin=predictive method=lee-kesler]
Tb          652.56;      // K   [origin=predictive method=joback]
HvapTb      62547.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.671 1.29852 -0.0006872 1.158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CHCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl 2,2-bis(chloranyl)ethanoate" "dichloroacetic acid, dodecyl ester" "dodecyl 2,2-dichloroacetate" "acetic acid, dichloro-, dodecyl ester" );
standardThermochemistry
{
    dHf_298   -686330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     809.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-269670.0
}
