/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoamyl 2-octynoate  (C13H22O2, CAS 68555-60-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoamyl2Octynoate;
formula     C13H22O2;
CAS         68555-60-2;
InChIKey    OTJSOSMJTUKXJR-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          751.67;      // K   [origin=predictive method=joback]
Pc          19.019;      // bar [origin=predictive method=joback]
omega       0.6620;      // -   [origin=predictive method=lee-kesler]
Tb          563.82;      // K   [origin=predictive method=joback]
HvapTb      53703.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.356 1.04016 -0.00049986 6.488e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group C_C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group tC; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl oct-2-ynoate" "isoamyl heptine carbonate" "2-octynoic acid, 3-methylbutyl ester" "2-octynoic acid isoamyl ester" "2-octynoic acid 3-methylbutyl ester" "isopentyl 2-octynoate" "2-octynoic acid isopentyl ester" );
standardThermochemistry
{
    dHf_298   -361910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51430.0
}
