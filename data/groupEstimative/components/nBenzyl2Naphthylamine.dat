/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-2-naphthylamine  (C17H15N, CAS 13672-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzyl2Naphthylamine;
formula     C17H15N;
CAS         13672-18-9;
InChIKey    KBOITYDYBXNTMF-UHFFFAOYSA-N;
MW          233.314;      // g/mol [origin=calculated method=formula-sum]
Tc          968.62;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       0.7433;      // -   [origin=predictive method=lee-kesler]
Tb          716.05;      // K   [origin=predictive method=joback]
HvapTb      66726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.729 1.474 -0.00108168 3.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 4; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 4; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(phenylmethyl)naphthalen-2-amine" "n-benzylnaphthalen-2-amine" );
gibbsFormation
{
    dHf_298   311920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=503490.0
    phase     gas;
}
