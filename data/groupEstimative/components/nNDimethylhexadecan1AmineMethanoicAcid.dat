/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylhexadecan-1-amine;methanoic acid  (C19H41NO2, CAS 128023-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C19H41NO2 (delta H+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nNDimethylhexadecan1AmineMethanoicAcid;
formula     C19H41NO2;
CAS         128023-59-6;
InChIKey    YHLGXPMEHMBUHD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          315.542;      // g/mol [origin=calculated method=formula-sum]
Tc          975.22;      // K   [origin=predictive method=joback]
Pc          10.885;      // bar [origin=predictive method=joback]
omega       0.9921;      // -   [origin=predictive method=lee-kesler]
Tb          792.97;      // K   [origin=predictive method=joback]
HvapTb      77242.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.065 1.88046 -0.0009876 1.717e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH3N; count 1; } { group HCOOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 15; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "formic acid, compd. with n,n-dimethyl-1-hexadecanamine (1:1)" "formic acid compd. with n,n-dimethyl-1-hexadecanamine (1:1)" );
standardThermochemistry
{
    dHf_298   -774040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1084.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-176410.0
}
