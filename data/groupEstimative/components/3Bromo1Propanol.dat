/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-1-propanol  (C3H7BrO, CAS 627-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo1Propanol;
formula     C3H7BrO;
CAS         627-18-9;
InChIKey    RQFUZUMFPRMVDX-UHFFFAOYSA-N;
MW          138.992;      // g/mol [origin=calculated method=formula-sum]
Tc          607.41;      // K   [origin=predictive method=joback]
Pc          55.278;      // bar [origin=predictive method=joback]
omega       0.7575;      // -   [origin=predictive method=lee-kesler]
Tb          426.58;      // K   [origin=predictive method=joback]
HvapTb      45386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.643 0.361 -0.0002412 6.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylpropan-1-ol" "3-bromopropan-1-ol" "trimethylene bromohydrin" "1-propanol, 3-bromo-" "3-hydroxypropyl bromide" "3-bromopropanol" "agn-pc-0cqr2t" );
standardThermochemistry
{
    dHf_298   -231150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     374.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-148120.0
}
