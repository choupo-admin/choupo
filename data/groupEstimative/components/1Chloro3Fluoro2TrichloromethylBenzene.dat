/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-fluoro-2-(trichloromethyl)benzene  (C7H3Cl4F, CAS 84473-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro3Fluoro2TrichloromethylBenzene;
formula     C7H3Cl4F;
CAS         84473-83-6;
InChIKey    PNAGDDZKFJHOOK-UHFFFAOYSA-N;
MW          247.899;      // g/mol [origin=calculated method=formula-sum]
Tc          785.01;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.4336;      // -   [origin=predictive method=lee-kesler]
Tb          542.16;      // K   [origin=predictive method=joback]
HvapTb      50203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.4 0.6357 -0.00052392 1.613e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CCl3; count 1; } { group ACCl; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-fluoranyl-2-(trichloromethyl)benzene" "2-chloro-6-fluorobenzotrichloride" "3-chloro-1-fluoro-2-(trichloromethyl)benzene" "benzene, 1-chloro-3-fluoro-2-(trichloromethyl)-" );
gibbsFormation
{
    dHf_298   -242040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-138480.0
    phase     gas;
}
