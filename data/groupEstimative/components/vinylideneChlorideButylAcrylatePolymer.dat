/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinylidene chloride, butyl acrylate polymer  (C9H14Cl2O2, CAS 9011-09-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylideneChlorideButylAcrylatePolymer;
formula     C9H14Cl2O2;
CAS         9011-09-0;
InChIKey    AILYVBNAYCPJBT-UHFFFAOYSA-N;
MW          225.109;      // g/mol [origin=calculated method=formula-sum]
Tc          730.92;      // K   [origin=predictive method=joback]
Pc          21.633;      // bar [origin=predictive method=joback]
omega       0.5489;      // -   [origin=predictive method=lee-kesler]
Tb          533.24;      // K   [origin=predictive method=joback]
HvapTb      50839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (81.043 0.57132 -4.53e-05 -1.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group Cl_C=C_; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)ethene;butyl prop-2-enoate" "2-propenoic acid, butyl ester, polymer with 1,1-dichloroethene" "butyl acrylate vinylidene chloride polymer" "butyl prop-2-enoate; 1,1-dichloroethene" "butyl prop-2-enoate- 1,1-dichloroethene(1:1)" "butyl prop-2-enoate - 1,1-dichloroethene (1:1)" );
standardThermochemistry
{
    dHf_298   -448400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     719.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246960.0
}
