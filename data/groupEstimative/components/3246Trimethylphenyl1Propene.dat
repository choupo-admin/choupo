/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2,4,6-trimethylphenyl)-1-propene  (C12H16, CAS 4810-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3246Trimethylphenyl1Propene;
formula     C12H16;
CAS         4810-05-3;
InChIKey    HEIXPNNBTVAWDD-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          719.59;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       0.4613;      // -   [origin=predictive method=lee-kesler]
Tb          512.46;      // K   [origin=predictive method=joback]
HvapTb      45898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.019 0.86646 -0.00048198 9.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 2; } { group ACCH3; count 3; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-trimethyl-2-prop-2-enyl-benzene" "benzene, 1,3,5-trimethyl-2-(2-propenyl)-" );
standardThermochemistry
{
    dHf_298   36540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221520.0
}
