/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl ethyl ether  (C6H14O, CAS 637-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylEthylEther;
formula     C6H14O;
CAS         637-92-3;
InChIKey    NUMQCACRALPSHD-UHFFFAOYSA-N;
MW          102.177;      // g/mol [origin=calculated method=formula-sum]
Tc          531.78;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       0.2852;      // -   [origin=predictive method=lee-kesler]
Tb          356.07;      // K   [origin=predictive method=joback]
HvapTb      30064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.539 0.63648 -0.0003634 7.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxy-2-methyl-propane" "ethyl tert-butyl ether" "etbe" "2-ethoxy-2-methylpropane" "propane, 2-ethoxy-2-methyl-" "ether, tert-butyl ethyl" "ethyl tert-butyl oxide" "2-methyl-2-ethoxypropane" "ethyl t-butyl ether" "methyl-2-ethoxypropane" "2-methyl-2-ethoxypropane (etbe)" "1,1-dimethylethyl ethyl ether" );
standardThermochemistry
{
    dHf_298   -308140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     362.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-102520.0
}
