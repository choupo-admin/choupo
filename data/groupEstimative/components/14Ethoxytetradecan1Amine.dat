/*--------------------------------*- Choupo -*-----------------------*\
  Component: 14-ethoxytetradecan-1-amine  (C16H35NO, CAS 71808-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Ethoxytetradecan1Amine;
formula     C16H35NO;
CAS         71808-33-8;
InChIKey    RYIOFBAZDNVTMM-UHFFFAOYSA-N;
MW          257.462;      // g/mol [origin=calculated method=formula-sum]
Tc          829.80;      // K   [origin=predictive method=joback]
Pc          13.576;      // bar [origin=predictive method=joback]
omega       0.9458;      // -   [origin=predictive method=lee-kesler]
Tb          660.63;      // K   [origin=predictive method=joback]
HvapTb      64261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.335 1.52252 -0.000779 1.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "amines, c14-18 and c16-18-unsatd. alkyl, ethoxylated propoxylated" );
standardThermochemistry
{
    dHf_298   -472000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     842.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45290.0
}
