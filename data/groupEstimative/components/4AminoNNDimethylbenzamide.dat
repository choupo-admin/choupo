/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-amino-n,n-dimethylbenzamide  (C9H12N2O, CAS 6331-71-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4AminoNNDimethylbenzamide;
formula     C9H12N2O;
CAS         6331-71-1;
InChIKey    QEPGWLBMAAEBCP-UHFFFAOYSA-N;
MW          164.208;      // g/mol [origin=calculated method=formula-sum]
Tc          801.81;      // K   [origin=predictive method=joback]
Pc          36.820;      // bar [origin=predictive method=joback]
omega       0.7168;      // -   [origin=predictive method=lee-kesler]
Tb          576.02;      // K   [origin=predictive method=joback]
HvapTb      57996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.74 0.87824 -0.00056726 1.3586e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-n,n-dimethyl-benzamide" "4-(dimethylcarbamyl)aniline" "n,n-dimethyl 4-aminobenzamide" "4-amino-n,n-dimethyl-benzamide" "benzamide, 4-amino-n,n-dimethyl-" "(4-aminophenyl)-n,n-dimethylcarboxamide" "4-(dimethylcarbamoyl)aniline" "benzamide,4-amino-n,n-dimethyl-" );
standardThermochemistry
{
    dHf_298   -15290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175990.0
}
