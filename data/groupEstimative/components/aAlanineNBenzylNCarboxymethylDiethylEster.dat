/*--------------------------------*- Choupo -*-----------------------*\
  Component: |a-alanine, n-benzyl-n-carboxymethyl, diethyl ester  (C16H23NO4, CAS 795-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aAlanineNBenzylNCarboxymethylDiethylEster;
formula     C16H23NO4;
CAS         795-18-6;
InChIKey    JWYHGTSTWMQTHS-UHFFFAOYSA-N;
MW          293.363;      // g/mol [origin=calculated method=formula-sum]
Tc          916.38;      // K   [origin=predictive method=joback]
Pc          17.146;      // bar [origin=predictive method=joback]
omega       1.0059;      // -   [origin=predictive method=lee-kesler]
Tb          721.24;      // K   [origin=predictive method=joback]
HvapTb      70343.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.434 1.45924 -0.0008012 1.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-[(2-ethoxy-2-oxidanylidene-ethyl)-(phenylmethyl)amino]propanoate" "beta-alanine, n-benzyl-n-carboxymethyl, diethyl ester" "ethyl 3-[benzyl-(2-ethoxy-2-oxoethyl)amino]propanoate" "ethyl 3-[(2-ethoxy-2-oxoethyl)-(phenylmethyl)amino]propanoate" "ethyl n-(2-ethoxy-2-oxoethyl)-n-(phenylmethyl)-beta-alaninate" "3-(benzyl-ethoxycarbonylmethyl-amino)-propionic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -704070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313710.0
    phase     gas;
}
