/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isocyanatoethyl methacrylate  (C7H9NO3, CAS 30674-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IsocyanatoethylMethacrylate;
formula     C7H9NO3;
CAS         30674-80-7;
InChIKey    RBQRWNWVPQDTJJ-UHFFFAOYSA-N;
MW          155.153;      // g/mol [origin=calculated method=formula-sum]
Tc          671.84;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.6324;      // -   [origin=predictive method=lee-kesler]
Tb          481.21;      // K   [origin=predictive method=joback]
HvapTb      47525.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCd; count 1; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-isocyanatoethyl 2-methylprop-2-enoate" "isocyanoethyl methacrylate" "2-(methacryloyloxy)ethyl isocyanate" "methacryloyloxyethyl isocyanate" "beta-isocyanatoethyl methacrylate" "2-propenoic acid, 2-methyl-, 2-isocyanatoethyl ester" "methacrylic acid, 2-isocyanatoethyl ester" "metharcylic acid, 2-isocyanatoethyl ester" "metharcyclic acid, 2-isocyanatoethyl ester" "iem" "methacrylic acid 2-isocyanatoethyl ester" "2-isocyanatoethyl methacrylate, stabilized with 0.5% bht" );
