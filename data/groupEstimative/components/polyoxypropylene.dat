/*--------------------------------*- Choupo -*-----------------------*\
  Component: polyoxypropylene  (C6H14O3, CAS 25322-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polyoxypropylene;
formula     C6H14O3;
CAS         25322-69-4;
InChIKey    DUFKCOQISQKSAV-UHFFFAOYSA-N;
MW          134.175;      // g/mol [origin=calculated method=formula-sum]
Tc          705.85;      // K   [origin=predictive method=joback]
Pc          38.531;      // bar [origin=predictive method=joback]
omega       1.3234;      // -   [origin=predictive method=lee-kesler]
Tb          542.78;      // K   [origin=predictive method=joback]
HvapTb      63942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.152 0.59044 -0.0002588 2.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-oxidanylpropoxy)propan-1-ol" "poly(propylene oxide)" "polyoxypropylene glycol" "emkapyl" "methyloxirane homopolymer" "lineartop e" "niax ppg" "propylene oxide homopolymer" "polymer 2" "desmophen 360c" "2-(2-hydroxypropoxy)-1-propanol" "glycols, polypropylene" );
gibbsFormation
{
    dHf_298   -614410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-383880.0
    phase     gas;
}
