/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 5-(octadecylamino)isophthalate  (C28H47NO4, CAS 63217-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl5OctadecylaminoIsophthalate;
formula     C28H47NO4;
CAS         63217-37-8;
InChIKey    MSEHBOQBRYAONO-UHFFFAOYSA-N;
MW          461.687;      // g/mol [origin=calculated method=formula-sum]
Tc          1286.22;      // K   [origin=predictive method=joback]
Pc          7.794;      // bar [origin=predictive method=joback]
omega       0.6741;      // -   [origin=predictive method=lee-kesler]
Tb          1043.49;      // K   [origin=predictive method=joback]
HvapTb      102772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.737 2.43256 -0.00125592 1.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 16; } { group ACH; count 3; } { group AC; count 3; } { group CH2NH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 5-(octadecylamino)benzene-1,3-dicarboxylate" "dimethyl 5-(stearylamino)isophthalate" "1,3-benzenedicarboxylic acid, 5-(octadecylamino)-, 1,3-dimethyl ester" "dimethyl 5-(octadecylamino)-1,3-benzenedicarboxylate" "1,3-benzenedicarboxylic acid, 5-(octadecylamino)-, dimethyl ester" );
standardThermochemistry
{
    dHf_298   -988750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1271.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253320.0
}
