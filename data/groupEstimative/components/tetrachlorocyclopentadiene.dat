/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrachlorocyclopentadiene  (C5H2Cl4, CAS 695-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrachlorocyclopentadiene;
formula     C5H2Cl4;
CAS         695-77-2;
InChIKey    RLKOAZNVJZJJFB-UHFFFAOYSA-N;
MW          203.871;      // g/mol [origin=calculated method=formula-sum]
Tc          740.88;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.4098;      // -   [origin=predictive method=lee-kesler]
Tb          501.91;      // K   [origin=predictive method=joback]
HvapTb      48062.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (56.24 0.3142 -0.000219 6.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group Cl_C=C_; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dC_ring; count 4; } { group Cl; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrakis(chloranyl)cyclopenta-1,3-diene" "1,2,3,4-tetrachlorocyclopentadiene" "1,3-cyclopentadiene, 1,2,3,4-tetrachloro-" "1,2,3,4-tetrachloro-1,3-cyclopentadiene" "2,3,4,5-tetrachlorocyclopentadiene" "1,2,3,4-tetrachlorocyclopenta-1,3-diene" "1, 1,2,3,4-tetrachloro-" "1,3,4-tetrachlorocyclopentadiene" "2,4,5-tetrachlorocyclopentadiene" "1,3-cyclopentadiene, tetrachloro-" "1,3,4-tetrachloro-1,3-cyclopentadiene" "1,3-cyclopentadiene,1,2,3,4-tetrachloro-" );
standardThermochemistry
{
    dHf_298   -58990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9160.0
}
