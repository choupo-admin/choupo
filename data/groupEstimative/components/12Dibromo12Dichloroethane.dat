/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromo-1,2-dichloroethane  (C2H2Br2Cl2, CAS 683-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromo12Dichloroethane;
formula     C2H2Br2Cl2;
CAS         683-68-1;
InChIKey    RJMDFMUPJANPGX-UHFFFAOYSA-N;
MW          256.746;      // g/mol [origin=calculated method=formula-sum]
Tc          689.43;      // K   [origin=predictive method=joback]
Pc          56.532;      // bar [origin=predictive method=joback]
omega       0.4056;      // -   [origin=predictive method=lee-kesler]
Tb          451.66;      // K   [origin=predictive method=joback]
HvapTb      40910.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.87 0.2956 -0.000275 9.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group Cl; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-1,2-bis(chloranyl)ethane" "1,2-dibrom-1,2-dichlorethan" "ethane, 1,2-dibromo-1,2-dichloro-" "1,2-dbdce" "1,2-dibromoethylene dichloride" "1,2-dichloroethylene dibromide" "1,2-dichloro-1,2-dibromoethane" "ethane,2-dibromo-1,2-dichloro-" "ethane,1,2-dibromo-1,2-dichloro-" "ethane, 1,2-dibromo-1,2-dichloro- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   -73990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     383.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34140.0
    phase     gas;
}
