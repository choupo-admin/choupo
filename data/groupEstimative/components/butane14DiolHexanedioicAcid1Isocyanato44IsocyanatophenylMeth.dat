name        butane14DiolHexanedioicAcid1Isocyanato44IsocyanatophenylMeth;
formula     C31H40N2O10;
CAS         41366-45-4;
InChIKey    DPWSNLCFPCKPAS-UHFFFAOYSA-N;
MW          600.665;      // g/mol [origin=calculated method=formula-sum]
Tc          2287.93;      // K   [origin=predictive method=joback]
Pc          10.419;      // bar [origin=predictive method=joback]
omega       0.1563;      // -   [origin=predictive method=lee-kesler]
Tb          1663.29;      // K   [origin=predictive method=joback]
HvapTb      186081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 12; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 2; } { group CH2COO; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 9; } { group dCd; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group COOH; count 2; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
