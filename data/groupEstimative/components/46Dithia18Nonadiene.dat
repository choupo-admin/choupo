/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dithia-1,8-nonadiene  (C7H12S2, CAS 18068-26-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dithia18Nonadiene;
formula     C7H12S2;
CAS         18068-26-3;
InChIKey    QTUCHGYIDKFWSU-UHFFFAOYSA-N;
MW          160.293;      // g/mol [origin=calculated method=formula-sum]
Tc          709.31;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.4374;      // -   [origin=predictive method=lee-kesler]
Tb          490.68;      // K   [origin=predictive method=joback]
HvapTb      43470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.743 0.61758 -0.0003224 5.17e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 2; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(prop-2-enylsulfanylmethylsulfanyl)prop-1-ene" "1-propene, 3,3'-[methylenebis(thio)]bis-" );
standardThermochemistry
{
    dHf_298   146790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=249980.0
}
