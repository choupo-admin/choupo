/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexene-1-octanoic acid, 5(or 6)-((dodecyloxy)carbonyl)-4-hexyl-, dodecyl ester  (C45H84O4, CAS 72245-40-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexene1OctanoicAcid5Or6DodecyloxyCarbonyl4HexylDodecyl;
formula     C45H84O4;
CAS         72245-40-0;
InChIKey    RJBNDRAQWRZKCU-QPHPTHAZSA-N;
MW          689.163;      // g/mol [origin=calculated method=formula-sum]
Tc          1975.08;      // K   [origin=predictive method=joback]
Pc          3.490;      // bar [origin=predictive method=joback]
omega       -0.4891;      // -   [origin=predictive method=lee-kesler]
Tb          1355.01;      // K   [origin=predictive method=joback]
HvapTb      130681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.146 4.18236 -0.00219248 3.675e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 34; } { group CH; count 3; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 34; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecyl (1r,2r,5s)-5-(8-dodecoxy-8-oxidanylidene-octyl)-2-hexyl-cyclohex-3-ene-1-carboxylate" "dodecyl (1r,2r,5s)-5-(8-dodecoxy-8-oxooctyl)-2-hexylcyclohex-3-ene-1-carboxylate" );
gibbsFormation
{
    dHf_298   -1535270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1858.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253730.0
    phase     gas;
}
