/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2,4,6-trichlorophenoxy)propanoic acid  (C9H7Cl3O3, CAS 53548-21-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3246TrichlorophenoxyPropanoicAcid;
formula     C9H7Cl3O3;
CAS         53548-21-3;
InChIKey    CJFMEZGDFLYDEP-UHFFFAOYSA-N;
MW          269.502;      // g/mol [origin=calculated method=formula-sum]
Tc          960.32;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       1.0069;      // -   [origin=predictive method=lee-kesler]
Tb          727.36;      // K   [origin=predictive method=joback]
HvapTb      72619.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (72.472 0.6094 -0.00031868 4.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group CH2O; count 1; } { group COOH; count 1; } { group ACCl; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2,4,6-tris(chloranyl)phenoxy]propanoic acid" "3-(2,4,6-trichlorophenoxy)propionic acid" "propionic acid, 2-(2,4,6-trichlorophenoxy)-" );
standardThermochemistry
{
    dHf_298   -556680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-376280.0
}
