/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1,3-dioxane  (C5H10O2, CAS 1120-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl13Dioxane;
formula     C5H10O2;
CAS         1120-97-4;
InChIKey    INCCMBMMWVKEGJ-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          594.72;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.2981;      // -   [origin=predictive method=lee-kesler]
Tb          387.45;      // K   [origin=predictive method=joback]
HvapTb      36173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.62 0.59492 -0.0003014 4.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 4-methyl-" "4-methyldioxane" "m-dioxane, 4-methyl-" "4-methyl-m-dioxane" "4-methyl-[1,3]dioxane" "m-dioxane, 4-methyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -356210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     217.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156570.0
}
