/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2,2'-(isopropylidenebis((2,6-dibromo-p-phenylene)oxy)), di(ethylene glycol, terephthalic acid) polymer  (C29H32Br4O10, CAS 53714-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol22Isopropylidenebis26DibromoPPhenyleneOxyDiEthyleneGl;
formula     C29H32Br4O10;
CAS         53714-34-4;
InChIKey    VCWBGFXOXBHQDJ-UHFFFAOYSA-N;
MW          860.181;      // g/mol [origin=calculated method=formula-sum]
Tc          3023.39;      // K   [origin=predictive method=joback]
Pc          16.220;      // bar [origin=predictive method=joback]
omega       -0.0598;      // -   [origin=predictive method=lee-kesler]
Tb          1946.81;      // K   [origin=predictive method=joback]
HvapTb      222506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (146.196 2.08304 -0.00085072 -4.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 10; } { group COOH; count 2; } { group _CH2OH_2; count 1; } { group Br; count 4; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 10; } { group Br; count 4; } { group OH; count 4; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[2-[3,5-bis(bromanyl)-4-(2-hydroxyethyloxy)phenyl]propan-2-yl]-2,6-bis(bromanyl)phenoxy]ethanol;ethane-1,2-diol;terephthalic acid" "1,4-benzenedicarboxylic acid, polymer with 1,2-ethanediol and 2,2'-((1-methylethylidene)bis((2,6-dibromo-4,1-phenylene)oxy))bis(ethanol)" "2-[2,6-dibromo-4-[2-[3,5-dibromo-4-(2-hydroxyethoxy)phenyl]propan-2-yl]phenoxy]ethanol; ethane-1,2-diol; terephthalic acid" );
standardThermochemistry
{
    dHf_298   -1713160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1636.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1131380.0
}
