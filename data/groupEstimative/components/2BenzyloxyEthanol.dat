/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(benzyloxy)ethanol  (C9H12O2, CAS 622-08-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BenzyloxyEthanol;
formula     C9H12O2;
CAS         622-08-2;
InChIKey    CUZKCNWZBXLAJX-UHFFFAOYSA-N;
MW          152.193;      // g/mol [origin=calculated method=formula-sum]
Tc          740.29;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.8996;      // -   [origin=predictive method=lee-kesler]
Tb          546.80;      // K   [origin=predictive method=joback]
HvapTb      56993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.407 0.7507 -0.0004164 7.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH2; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylmethoxyethanol" "2-benzyloxyethanol" "ethanol, 2-(phenylmethoxy)-" "ethylene glycol monobenzyl ether" "ethanol, 2-(benzyloxy)-" "2-benzyloxy-1-ethanol" "benzyl cellosolve" "glycol benzyl ether" "glycol monobenzyl ether" "2-(benzyloxy) ethanol" "2-(phenylmethoxy)ethan-1-ol" "benzylcelosolv" );
gibbsFormation
{
    dHf_298   -277010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104510.0
    phase     gas;
}
