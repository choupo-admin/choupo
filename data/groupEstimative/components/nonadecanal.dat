/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonadecanal  (C19H38O, CAS 17352-32-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonadecanal;
formula     C19H38O;
CAS         17352-32-8;
InChIKey    SXIYYZWCMUFWBW-UHFFFAOYSA-N;
MW          282.512;      // g/mol [origin=calculated method=formula-sum]
Tc          848.55;      // K   [origin=predictive method=joback]
Pc          11.352;      // bar [origin=predictive method=joback]
omega       0.9154;      // -   [origin=predictive method=lee-kesler]
Tb          682.98;      // K   [origin=predictive method=joback]
HvapTb      64608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.983 1.78332 -0.0010028 2.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -521070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     914.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9580.0
    phase     gas;
}
