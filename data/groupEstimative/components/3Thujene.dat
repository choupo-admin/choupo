/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-thujene  (C10H16, CAS 2867-05-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Thujene;
formula     C10H16;
CAS         2867-05-2;
InChIKey    KQAZVFVOEIRWHN-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          652.11;      // K   [origin=predictive method=joback]
Pc          29.409;      // bar [origin=predictive method=joback]
omega       0.3503;      // -   [origin=predictive method=lee-kesler]
Tb          445.82;      // K   [origin=predictive method=joback]
HvapTb      37095.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.28 1.43796 -0.00141664 5.832e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-1-propan-2-yl-bicyclo[3.1.0]hex-3-ene" "thujiene" "bicyclo[3.1.0]hex-2-ene, 2-methyl-5-(1-methylethyl)-" "4-methyl-1-propan-2-ylbicyclo[3.1.0]hex-3-ene" "alpha-thujene" "5-isopropyl-2-methylbicyclo(3.1.0)hex-2-ene" "5-isopropyl-2-methylbicyclo[3.1.0]hex-2-ene" "bicyclo(3.1.0)hex-2-ene, 2-methyl-5-(1-methylethyl)-" "origanene" "alpha-thuiene" "alpha-thujen" "2-methyl-5-propan-2-ylbicyclo[3.1.0]hex-2-ene" );
gibbsFormation
{
    dHf_298   -47860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     381.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167220.0
    phase     gas;
}
