/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 4,4'-(1,2-ethanediyl)bis-, diacetate  (C18H18O4, CAS 63450-00-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol4412EthanediylBisDiacetate;
formula     C18H18O4;
CAS         63450-00-0;
InChIKey    BLEZMBQFCXEANG-UHFFFAOYSA-N;
MW          298.338;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.23;      // K   [origin=predictive method=joback]
Pc          18.838;      // bar [origin=predictive method=joback]
omega       0.9565;      // -   [origin=predictive method=lee-kesler]
Tb          791.20;      // K   [origin=predictive method=joback]
HvapTb      76352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.868 1.32744 -0.00069452 9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[2-(4-acetyloxyphenyl)ethyl]phenyl] ethanoate" "ethane-1,2-diyldi-4,1-phenylene diacetate" "[4-[2-(4-acetyloxyphenyl)ethyl]phenyl] acetate" "phenol, 4,4'-(1,2-ethanediyl)bis-, 1,1'-diacetate" );
gibbsFormation
{
    dHf_298   -599290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     734.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-314500.0
    phase     gas;
}
