/*--------------------------------*- Choupo -*-----------------------*\
  Component: thymoxamine  (C16H25NO3, CAS 54-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thymoxamine;
formula     C16H25NO3;
CAS         54-32-0;
InChIKey    VRYMTAVOXVTQEF-UHFFFAOYSA-N;
MW          279.38;      // g/mol [origin=calculated method=formula-sum]
Tc          895.81;      // K   [origin=predictive method=joback]
Pc          16.338;      // bar [origin=predictive method=joback]
omega       0.8994;      // -   [origin=predictive method=lee-kesler]
Tb          699.94;      // K   [origin=predictive method=joback]
HvapTb      66944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.872 1.27832 -0.00058688 5.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH3COO; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[2-(dimethylamino)ethoxy]-2-methyl-5-propan-2-yl-phenyl] ethanoate" "moxisylyte" "acetoxythymoxamine" "timoxamina" "arlytene" "moxisylyt" "sympal" "moxilite" "opilon" "moxisylytum [inn-latin]" "phenol, 4-(2-(dimethylamino)ethoxy)-2-methyl-5-(1-methylethyl)-, acetate (ester)" "carvacrol, 5-(2-(dimethylamino)ethoxy)-, acetate (ester)" );
gibbsFormation
{
    dHf_298   -558700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     723.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-139670.0
    phase     gas;
}
