/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-(dimethylamino)undecan-4-ol  (C13H29NO, CAS 68413-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10DimethylaminoUndecan4Ol;
formula     C13H29NO;
CAS         68413-35-4;
InChIKey    JSLWGNAJHHYCQT-UHFFFAOYSA-N;
MW          215.381;      // g/mol [origin=calculated method=formula-sum]
Tc          762.50;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       1.0514;      // -   [origin=predictive method=lee-kesler]
Tb          600.78;      // K   [origin=predictive method=joback]
HvapTb      62478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.693 1.40858 -0.0008328 1.897e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 2; } { group OH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "alcohols, c10-secondary, beta-(dimethylamino)" );
gibbsFormation
{
    dHf_298   -406910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     710.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27660.0
    phase     gas;
}
