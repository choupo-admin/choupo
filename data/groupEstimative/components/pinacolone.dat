/*--------------------------------*- Choupo -*-----------------------*\
  Component: pinacolone  (C6H12O, CAS 75-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pinacolone;
formula     C6H12O;
CAS         75-97-8;
InChIKey    PJGSXYOJTGTZAV-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          577.23;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.3294;      // -   [origin=predictive method=lee-kesler]
Tb          387.52;      // K   [origin=predictive method=joback]
HvapTb      34400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.68 0.67168 -0.0004557 1.2306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylbutan-2-one" "3,3-dimethyl-2-butanone" "tert-butyl methyl ketone" "pinacolin" "2-butanone, 3,3-dimethyl-" "t-butyl methyl ketone" "pinacoline" "methyl tert-butyl ketone" "2,2-dimethylbutanone" "3,3-dimethylbutanone" "pinakolin" "1,1,1-trimethylacetone" );
gibbsFormation
{
    dHf_298   -288500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126440.0
    phase     gas;
}
