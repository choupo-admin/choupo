/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexen-1-one, 3-ethoxy-5,5-dimethyl-  (C10H16O2, CAS 6267-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexen1One3Ethoxy55Dimethyl;
formula     C10H16O2;
CAS         6267-39-6;
InChIKey    HALCXXAVLJHSTJ-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          766.02;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.5038;      // -   [origin=predictive method=lee-kesler]
Tb          542.57;      // K   [origin=predictive method=joback]
HvapTb      44743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.789 1.02086 -0.00069904 2.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxy-5,5-dimethyl-cyclohex-2-en-1-one" "3-ethoxy-5,5-dimethyl-cyclohex-2-enone" "3-ethoxy-5,5-dimethylcyclohex-2-en-1-one" "3-ethoxy-5,5-dimethyl-2-cyclohexen-1-one" );
standardThermochemistry
{
    dHf_298   -403780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154980.0
}
