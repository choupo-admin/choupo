/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(carbomethoxymethyl)aziridine  (C5H9NO2, CAS 14745-52-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1CarbomethoxymethylAziridine;
formula     C5H9NO2;
CAS         14745-52-9;
InChIKey    VWCXRUKYXADUBM-UHFFFAOYSA-N;
MW          115.132;      // g/mol [origin=calculated method=formula-sum]
Tc          572.85;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.4863;      // -   [origin=predictive method=lee-kesler]
Tb          391.80;      // K   [origin=predictive method=joback]
HvapTb      36224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.999 0.73492 -0.0005882 1.86e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(aziridin-1-yl)ethanoate" "methyl 1-aziridineacetate" "1-(methoxycarbonyl)aziridine" "n-(carbomethoxymethyl)aziridine" "2-(1-aziridinyl)acetic acid methyl ester" "acetic acid, 2-(1-aziridinyl)-, methyl ester" "1-aziridineacetic acid, methyl ester" "methyl aziridin-1-ylacetate" "methyl 2-(aziridin-1-yl)acetate" );
standardThermochemistry
{
    dHf_298   -296980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127810.0
}
