/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-propylbenzene  (C9H11Br, CAS 588-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Propylbenzene;
formula     C9H11Br;
CAS         588-93-2;
InChIKey    NUPWGLKBGVNSJX-UHFFFAOYSA-N;
MW          199.091;      // g/mol [origin=calculated method=formula-sum]
Tc          729.33;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.4614;      // -   [origin=predictive method=lee-kesler]
Tb          503.34;      // K   [origin=predictive method=joback]
HvapTb      45001.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.708 0.75862 -0.00050136 1.306e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-propyl-benzene" "4-propyl bromobenzene" "4-bromo-n-propylbenzene" "1-(4'-bromophenyl)propane" "4-bromo propylbenzene" "1-bromo-4-n-propyl-benzene" "i328" "1-propyl-4-bromobenzene;4-bromopropylbenzene;4-propyl-1-bromobenzene;4-propylbromobenzene;4-n-propylbromobenzene;benzene,1-bromo-4-propyl-;" );
gibbsFormation
{
    dHf_298   22300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142000.0
    phase     gas;
}
