/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trifluorotoluene  (C7H5F3, CAS 93343-11-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trifluorotoluene;
formula     C7H5F3;
CAS         93343-11-4;
InChIKey    HZCVONJWZPKKBI-UHFFFAOYSA-N;
MW          146.111;      // g/mol [origin=calculated method=formula-sum]
Tc          581.80;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.4134;      // -   [origin=predictive method=lee-kesler]
Tb          399.19;      // K   [origin=predictive method=joback]
HvapTb      32987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.79 0.44682 -0.00023628 3.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(fluoranyl)-2-methyl-benzene" "1,3,5-trifluoro-2-methylbenzene" "2,4-6-trifluorotoluene" "benzene, 1,3,5-trifluoro-2-methyl-" "2-methyl-1,3,5-trifluorobenzene" "1,3,5-trifluoro-2-methylbenzene;2,4,6-trifluorotoluene;" );
gibbsFormation
{
    dHf_298   -574020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-492850.0
    phase     gas;
}
