/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-cyclopentanecarboxylic acid ethyl ester, cis  (C8H14O3, CAS 61586-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HydroxyCyclopentanecarboxylicAcidEthylEsterCis;
formula     C8H14O3;
CAS         61586-79-6;
InChIKey    IIFIGGNBUOZGAB-RQJHMYQMSA-N;
MW          158.197;      // g/mol [origin=calculated method=formula-sum]
Tc          732.35;      // K   [origin=predictive method=joback]
Pc          32.954;      // bar [origin=predictive method=joback]
omega       0.8968;      // -   [origin=predictive method=lee-kesler]
Tb          543.65;      // K   [origin=predictive method=joback]
HvapTb      57436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.229 0.84822 -0.0004192 4.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (1r,2s)-2-oxidanylcyclopentane-1-carboxylate" "(1r,2s)-ethyl 2-hydroxycyclopentanecarboxylate" "ethyl (1r,2s)-cis-2-hydroxycyclopentanecarboxylate" "ethyl (2s,1r)-2-hydroxycyclopentanecarboxylate" "ethyl ((1r,2s)-cis-2-hydroxycyclopentanecarboxylate" "ethyl (1r,2s)-2-hydroxycyclopentane-1-carboxylate" "ethyl cis-2-hydroxy-1-cyclopentanecarboxylate" "cyclopentanecarboxylicacid, 2-hydroxy-, ethyl ester, (1r,2s)-rel-" "cyclopentanecarboxylicacid, 2-hydroxy-, ethyl ester, cis- (8ci); ethyl cis-2-hydroxycyclopentanecarboxylate;ethyl cis-2-hydroxycyclopentanecarboxylate; racemic ethylcis-2-hydroxycyclopentanecarboxylate; cis-2-carbethoxycyclopentanol" );
standardThermochemistry
{
    dHf_298   -637820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-401870.0
}
