/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chlorothioanisole  (C7H7ClS, CAS 4867-37-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chlorothioanisole;
formula     C7H7ClS;
CAS         4867-37-2;
InChIKey    PTGSDZVASWKUHK-UHFFFAOYSA-N;
MW          158.643;      // g/mol [origin=calculated method=formula-sum]
Tc          743.96;      // K   [origin=predictive method=joback]
Pc          39.357;      // bar [origin=predictive method=joback]
omega       0.3664;      // -   [origin=predictive method=lee-kesler]
Tb          497.63;      // K   [origin=predictive method=joback]
HvapTb      45316.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.41 0.53161 -0.00030136 5.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-methylsulfanyl-benzene" "3-chlorophenyl methyl sulfide" "3-chloro thioanisole" "m-chlorothioanisole" "1-chloro-3-(methylsulfanyl)benzene" "3-(methylthio)chlorobenzene" "3-cpms" "1-chloro-3-methylthiobenzene" "1-chloro-3-(methylthio)benzene" "1-chloro-3-methylsulfanylbenzene" "benzene, 1-chloro-3-(methylthio)-" "1-chloro-3-methylsulfanyl-benzene" );
gibbsFormation
{
    dHf_298   63380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132030.0
    phase     gas;
}
