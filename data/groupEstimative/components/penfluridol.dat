/*--------------------------------*- Choupo -*-----------------------*\
  Component: penfluridol  (C28H27ClF5NO, CAS 26864-56-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        penfluridol;
formula     C28H27ClF5NO;
CAS         26864-56-2;
InChIKey    MDLAAYDRRZXJIF-UHFFFAOYSA-N;
MW          523.97;      // g/mol [origin=calculated method=formula-sum]
Tc          1335.22;      // K   [origin=predictive method=joback]
Pc          11.948;      // bar [origin=predictive method=joback]
omega       1.1285;      // -   [origin=predictive method=lee-kesler]
Tb          1090.45;      // K   [origin=predictive method=joback]
HvapTb      103842.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.767 2.9681 -0.00240524 7.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group C; count 1; } { group ACH; count 11; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group ACF; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group F; count 5; } { group Cl; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4,4-bis(4-fluorophenyl)butyl]-4-[4-chloranyl-3-(trifluoromethyl)phenyl]piperidin-4-ol" "semap" "1-(4,4-bis(4-fluorophenyl)butyl)-4-(4-chloro-3-(trifluoromethyl)phenyl)piperidin-4-ol" "penfluridolum [inn-latin]" "mcn-jr-16,341" "4-piperidinol, 1-(4,4-bis(4-fluorophenyl)butyl)-4-(4-chloro-3-(trifluoromethyl)phenyl)-" "1-[4,4-bis(4-fluorophenyl)butyl]-4-[4-chloro-3-(trifluoromethyl)phenyl]-4-piperidinol" "4-piperidinol, 1-[4,4-bis(4-fluorophenyl)butyl]-4-[4-chloro-3-(trifluoromethyl)phenyl]-" "1-(4,4-bis(p-fluorophenyl)butyl)-4-(4-chloro-alpha,alpha,alpha-trifluoro-m-tolyl)-4-piperidinol" "4-piperidinol, 1-(4,4-bis(p-fluorophenyl)butyl)-4-(4-chloro-alpha,alpha,alpha-trifluoro-m-tolyl)-" "4-piperidinol, 4-(4-chloro-alpha,alpha,alpha-trifluoro-m-tolyl)-1-(4,4-bis(p-fluorophenyl)butyl)-" "hydroxamates" );
standardThermochemistry
{
    dHf_298   -976840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1132.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-496970.0
}
