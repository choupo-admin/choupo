/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethyl-2-hexanol  (C8H18O, CAS 66576-27-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethyl2Hexanol;
formula     C8H18O;
CAS         66576-27-0;
InChIKey    VGGMROOHXNLMTP-UHFFFAOYSA-N;
MW          130.231;      // g/mol [origin=calculated method=formula-sum]
Tc          643.16;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.7563;      // -   [origin=predictive method=lee-kesler]
Tb          473.50;      // K   [origin=predictive method=joback]
HvapTb      48917.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.139 0.81558 -0.0004514 9.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethylhexan-2-ol" "2-hexanol, 3,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -376520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-127660.0
}
