/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl phenylmalonate  (C13H16O4, CAS 83-13-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylPhenylmalonate;
formula     C13H16O4;
CAS         83-13-6;
InChIKey    FGYDHYCFHBSNPE-UHFFFAOYSA-N;
MW          236.267;      // g/mol [origin=calculated method=formula-sum]
Tc          847.31;      // K   [origin=predictive method=joback]
Pc          22.313;      // bar [origin=predictive method=joback]
omega       0.8062;      // -   [origin=predictive method=lee-kesler]
Tb          639.72;      // K   [origin=predictive method=joback]
HvapTb      61234.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.302 1.05624 -0.0005286 5.43e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-phenylpropanedioate" "diethyl 2-phenylmalonate" "propanedioic acid, phenyl-, diethyl ester" "phenylmalonic acid diethyl ester" "malonic acid, phenyl-, diethyl ester" "propanedioic acid, 2-phenyl-, 1,3-diethyl ester" "diethyl 2-phenylpropane-1,3-dioate" "1,3-diethyl 2-phenylpropanedioate" "2-phenyl-propanedioic acid diethyl ester" "bim-0047923.p001" "malonic acid, phenyl-, diethyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -714960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-452190.0
    phase     gas;
}
