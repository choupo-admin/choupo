/*--------------------------------*- Choupo -*-----------------------*\
  Component: hotrienol  (C10H16O, CAS 20053-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hotrienol;
formula     C10H16O;
CAS         20053-88-7;
InChIKey    ZJIQIJIQBTVTDY-VOTSOKGWSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          697.96;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.7371;      // -   [origin=predictive method=lee-kesler]
Tb          514.75;      // K   [origin=predictive method=joback]
HvapTb      51935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.239 1.09354 -0.0008543 2.735e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 3; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5e)-3,7-dimethylocta-1,5,7-trien-3-ol" "1,5,7-octatrien-3-ol, 3,7-dimethyl-" "(e)-3,7-dimethylocta-1,5,7-trien-3-ol" "3,7-dimethylocta-1,5,7-trien-3-ol" "3,7-dimethyl-1,5,7-octatrien-3-ol (hotrienol)" );
gibbsFormation
{
    dHf_298   -52420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146690.0
    phase     gas;
}
