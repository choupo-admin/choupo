/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromopropyl acrylate  (C6H8Br2O2, CAS 19660-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DibromopropylAcrylate;
formula     C6H8Br2O2;
CAS         19660-16-3;
InChIKey    MUKJDVAYJDKPAG-UHFFFAOYSA-N;
MW          271.936;      // g/mol [origin=calculated method=formula-sum]
Tc          739.32;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.6545;      // -   [origin=predictive method=lee-kesler]
Tb          523.66;      // K   [origin=predictive method=joback]
HvapTb      48169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.552 0.5813 -0.0003769 8.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)propyl prop-2-enoate" "2,3-dibromopropyl propenoate" "2-propenoic acid, 2,3-dibromopropyl ester" "acrylic acid, 2,3-dibromopropyl ester" "2,3-dibromopropyl prop-2-enoate" "acrylic acid 2,3-dibromopropyl ester" );
gibbsFormation
{
    dHf_298   -311640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196690.0
    phase     gas;
}
