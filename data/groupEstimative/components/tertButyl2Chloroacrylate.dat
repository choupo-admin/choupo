/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl 2-chloroacrylate  (C7H11ClO2, CAS 72088-85-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButyl2Chloroacrylate;
formula     C7H11ClO2;
CAS         72088-85-8;
InChIKey    ISIMQTCWOTYBLH-UHFFFAOYSA-N;
MW          162.613;      // g/mol [origin=calculated method=formula-sum]
Tc          647.56;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.4072;      // -   [origin=predictive method=lee-kesler]
Tb          448.74;      // K   [origin=predictive method=joback]
HvapTb      41082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.67 0.72656 -0.0004798 1.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group Cl_C=C_; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl 2-chloranylprop-2-enoate" "tert-butyl 2-chloroprop-2-enoate" "2-propenoic acid, 2-chloro-, 1,1-dimethylethyl ester" "tert-butyl alpha-chloroacrylate" );
gibbsFormation
{
    dHf_298   -413940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232110.0
    phase     gas;
}
