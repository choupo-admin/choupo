/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentene, 3-chloro-2-methyl-  (C6H11Cl, CAS 4104-01-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pentene3Chloro2Methyl;
formula     C6H11Cl;
CAS         4104-01-2;
InChIKey    YWMUJGKROQVGHA-UHFFFAOYSA-N;
MW          118.604;      // g/mol [origin=calculated method=formula-sum]
Tc          554.37;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.2836;      // -   [origin=predictive method=lee-kesler]
Tb          370.43;      // K   [origin=predictive method=joback]
HvapTb      32357.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.961 0.56644 -0.0003514 8.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=C; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-2-methyl-pent-1-ene" "agn-pc-00k7sa" );
standardThermochemistry
{
    dHf_298   -72550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64560.0
}
