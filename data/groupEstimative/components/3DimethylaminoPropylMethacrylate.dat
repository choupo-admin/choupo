/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dimethylamino)propyl methacrylate  (C9H17NO2, CAS 20602-77-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DimethylaminoPropylMethacrylate;
formula     C9H17NO2;
CAS         20602-77-1;
InChIKey    WWJCRUKUIQRCGP-UHFFFAOYSA-N;
MW          171.24;      // g/mol [origin=calculated method=formula-sum]
Tc          648.05;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.6067;      // -   [origin=predictive method=lee-kesler]
Tb          472.74;      // K   [origin=predictive method=joback]
HvapTb      44488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.743 0.90786 -0.000509 9.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH2=C; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(dimethylamino)propyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 3-(dimethylamino)propyl ester" "2-propenoic acid, 2-methyl-, 3-(dimethylamino)propyl ester, homopolymer" "3-dimethylaminopropyl 2-methylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -363200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-95400.0
    phase     gas;
}
