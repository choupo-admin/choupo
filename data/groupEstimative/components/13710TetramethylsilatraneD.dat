/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,7,10-tetramethylsilatrane, d  (C10H21NO3Si, CAS 71229-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H21NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13710TetramethylsilatraneD;
formula     C10H21NO3Si;
CAS         71229-51-1;
InChIKey    CZVPEYKMGJNICG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          231.367;      // g/mol [origin=calculated method=formula-sum]
Tc          757.90;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       0.5202;      // -   [origin=predictive method=lee-kesler]
Tb          544.71;      // K   [origin=predictive method=joback]
HvapTb      53754.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.02 1.10908 -0.0004221 -1.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH-O; count 3; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,7,10-tetramethyl-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "1,3,7,10-tetramethylsilatrane, e" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1,3,7,10-tetramethyl-" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 1,3,7,10-tetramethyl-" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 1,3,7,1-tetramethyl-" );
gibbsFormation
{
    dHf_298   -583040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     371.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-141530.0
    phase     gas;
}
