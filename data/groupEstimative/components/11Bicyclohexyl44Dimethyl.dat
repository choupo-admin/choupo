/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-bicyclohexyl, 4,4'-dimethyl-  (C14H26, CAS 54823-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Bicyclohexyl44Dimethyl;
formula     C14H26;
CAS         54823-98-2;
InChIKey    CGJFYDPGFFFGHA-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          773.26;      // K   [origin=predictive method=joback]
Pc          20.327;      // bar [origin=predictive method=joback]
omega       0.3752;      // -   [origin=predictive method=lee-kesler]
Tb          549.68;      // K   [origin=predictive method=joback]
HvapTb      46998.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.17 1.52504 -0.000789 1.182e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-(4-methylcyclohexyl)cyclohexane" "4,4'-dimethyl-1,1'-bi(cyclohexyl)" );
gibbsFormation
{
    dHf_298   -264330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100480.0
    phase     gas;
}
