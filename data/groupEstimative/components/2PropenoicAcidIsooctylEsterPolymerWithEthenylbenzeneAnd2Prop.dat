/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, isooctyl ester, polymer with ethenylbenzene and 2-propenamide  (C22H33NO3, CAS 109075-75-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcidIsooctylEsterPolymerWithEthenylbenzeneAnd2Prop;
formula     C22H33NO3;
CAS         109075-75-4;
InChIKey    WMIJEWJJDNHONO-UHFFFAOYSA-N;
MW          359.51;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.22;      // K   [origin=predictive method=joback]
Pc          11.760;      // bar [origin=predictive method=joback]
omega       0.9568;      // -   [origin=predictive method=lee-kesler]
Tb          906.66;      // K   [origin=predictive method=joback]
HvapTb      89826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.225 1.52754 -0.0003766 -1.6174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2=CH; count 3; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH2; count 3; } { group dCH; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;6-methylheptyl prop-2-enoate;prop-2-enamide" );
gibbsFormation
{
    dHf_298   -509180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1228.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-74510.0
    phase     gas;
}
