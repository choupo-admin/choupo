/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butyl-1,5-dimethyl-2-oxabicyclo(2.2.2)octane  (C13H24O, CAS 72230-90-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Butyl15Dimethyl2Oxabicyclo222Octane;
formula     C13H24O;
CAS         72230-90-1;
InChIKey    SENDFKGNJBUEOA-WUHRBBMRSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          740.51;      // K   [origin=predictive method=joback]
Pc          20.927;      // bar [origin=predictive method=joback]
omega       0.4954;      // -   [origin=predictive method=lee-kesler]
Tb          536.91;      // K   [origin=predictive method=joback]
HvapTb      47443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.447 1.75736 -0.0014389 5.152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2r,4r,6s)-2-butyl-4,6-dimethyl-3-oxabicyclo[2.2.2]octane" "2-oxabicyclo(2.2.2)octane, 3-butyl-1,5-dimethyl-" );
gibbsFormation
{
    dHf_298   -335810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48850.0
    phase     gas;
}
