/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-phenyl-1-butenyl)benzene  (C16H16, CAS 1726-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl1ButenylBenzene;
formula     C16H16;
CAS         1726-14-3;
InChIKey    FKDKAGHZAOFATR-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          867.77;      // K   [origin=predictive method=joback]
Pc          24.147;      // bar [origin=predictive method=joback]
omega       0.5099;      // -   [origin=predictive method=lee-kesler]
Tb          623.08;      // K   [origin=predictive method=joback]
HvapTb      55800.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.339 1.38592 -0.0009951 2.794e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylbut-1-enylbenzene" "benzene, 1,1'-(1-butenylidene)bis-" "butene, diphenyl-" "but-1-ene-1,1-diyldibenzene" );
gibbsFormation
{
    dHf_298   206920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     555.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=380330.0
    phase     gas;
}
