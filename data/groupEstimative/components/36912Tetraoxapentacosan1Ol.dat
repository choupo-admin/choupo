/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6,9,12-tetraoxapentacosan-1-ol  (C21H44O5, CAS 930-08-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36912Tetraoxapentacosan1Ol;
formula     C21H44O5;
CAS         930-08-5;
InChIKey    XGJLRCKXPUPYKH-UHFFFAOYSA-N;
MW          376.578;      // g/mol [origin=calculated method=formula-sum]
Tc          1058.61;      // K   [origin=predictive method=joback]
Pc          9.705;      // bar [origin=predictive method=joback]
omega       0.9052;      // -   [origin=predictive method=lee-kesler]
Tb          861.94;      // K   [origin=predictive method=joback]
HvapTb      88659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (91.09 1.78002 -0.000705 2.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2O; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group OH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-(2-tridecoxyethoxy)ethoxy]ethoxy]ethanol" "tridecyl alcohol tri(oxyethylene) ethanol" );
standardThermochemistry
{
    dHf_298   -1157880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1069.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-430880.0
}
