/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-ethyl-1-methyl-1,3-cyclopentadiene  (C8H12, CAS 25148-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Ethyl1Methyl13Cyclopentadiene;
formula     C8H12;
CAS         25148-01-0;
InChIKey    AOUGDAYMVXBDDZ-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          611.32;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.3259;      // -   [origin=predictive method=lee-kesler]
Tb          410.87;      // K   [origin=predictive method=joback]
HvapTb      35876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.649 0.69104 -0.00043468 1.103e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethyl-1-methyl-cyclopenta-1,3-diene" "agn-pc-01u7kd" );
standardThermochemistry
{
    dHf_298   -35010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=101400.0
}
