/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylamine  (C2H7N, CAS 124-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylamine;
formula     C2H7N;
CAS         124-40-3;
InChIKey    ROSDSFDQCJNGOL-UHFFFAOYSA-N;
MW          45.085;      // g/mol [origin=calculated method=formula-sum]
Tc          464.41;      // K   [origin=predictive method=joback]
Pc          51.240;      // bar [origin=predictive method=joback]
omega       0.2632;      // -   [origin=predictive method=lee-kesler]
Tb          295.53;      // K   [origin=predictive method=joback]
HvapTb      26482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.14 0.27004 -0.0001336 2.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methylmethanamine" "methanamine, n-methyl-" "n,n-dimethylamine" "dimethylamine solution" "dimethyl-amine" "dimethylamine (anhydrous)" "dimethylamine anhydrous" "dimethylamin" "dimethylamine aqueous solution" "dimethyl amine" "(ch3)2nh" "dimethylamine, in aqueous solution" );
standardThermochemistry
{
    dHf_298   -31140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     274.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55350.0
}
