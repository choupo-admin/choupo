/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4,4-tetramethyltetrahydrofuran  (C8H16O, CAS 3358-28-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2244Tetramethyltetrahydrofuran;
formula     C8H16O;
CAS         3358-28-9;
InChIKey    FIDGQQIVMWAIAD-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          631.33;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.2800;      // -   [origin=predictive method=lee-kesler]
Tb          420.68;      // K   [origin=predictive method=joback]
HvapTb      35558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.59 1.44988 -0.0015347 6.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 2; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4-tetramethyloxolane" "furan, tetrahydro-2,2,4,4-tetramethyl-" "2,2,4,4-tetramethyltetrahydrofuran;" "furan,tetrahydro-2,2,4,4-tetramethyl-" );
gibbsFormation
{
    dHf_298   -269830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     462.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51780.0
    phase     gas;
}
