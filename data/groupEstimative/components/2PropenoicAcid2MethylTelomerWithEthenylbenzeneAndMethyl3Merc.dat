/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, telomer with ethenylbenzene and methyl 3-mercaptopropanoate  (C16H22O4S, CAS 150632-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2MethylTelomerWithEthenylbenzeneAndMethyl3Merc;
formula     C16H22O4S;
CAS         150632-04-5;
InChIKey    JWNKGDVVDGGXMZ-UHFFFAOYSA-N;
MW          310.408;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.86;      // K   [origin=predictive method=joback]
Pc          18.077;      // bar [origin=predictive method=joback]
omega       0.9932;      // -   [origin=predictive method=lee-kesler]
Tb          854.99;      // K   [origin=predictive method=joback]
HvapTb      84122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (75.302 1.01574 -9.67e-05 -2.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group COOH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenylbenzene;2-methylprop-2-enoic acid;methyl 3-sulfanylpropanoate" );
gibbsFormation
{
    dHf_298   -748280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1041.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-471030.0
    phase     gas;
}
