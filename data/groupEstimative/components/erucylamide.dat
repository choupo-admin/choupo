/*--------------------------------*- Choupo -*-----------------------*\
  Component: erucylamide  (C22H43NO, CAS 112-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        erucylamide;
formula     C22H43NO;
CAS         112-84-5;
InChIKey    UAUDZVJPLUQNMU-KTKRTIGZSA-N;
MW          337.592;      // g/mol [origin=calculated method=formula-sum]
Tc          1022.48;      // K   [origin=predictive method=joback]
Pc          10.027;      // bar [origin=predictive method=joback]
omega       0.9481;      // -   [origin=predictive method=lee-kesler]
Tb          833.52;      // K   [origin=predictive method=joback]
HvapTb      81911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.442 2.14772 -0.0012815 2.9996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH=CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-docos-13-enamide" "erucamide" "13-docosenamide, (z)-" "cis-13-docosenoamide" "erucyl amide" "erucic acid amide" "13-docosenamide, (13z)-" "13-docosenamide" "cis-13-docosenamide" "(z)-13-docosenamide" "(13z)docos-13-enamide" );
gibbsFormation
{
    dHf_298   -458980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1084.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152110.0
    phase     gas;
}
