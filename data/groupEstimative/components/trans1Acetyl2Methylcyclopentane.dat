/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1-acetyl-2-methylcyclopentane  (C8H14O, CAS 1601-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans1Acetyl2Methylcyclopentane;
formula     C8H14O;
CAS         1601-00-9;
InChIKey    SIXBTZFYFSHXJI-UHFFFAOYSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          651.94;      // K   [origin=predictive method=joback]
Pc          31.704;      // bar [origin=predictive method=joback]
omega       0.3946;      // -   [origin=predictive method=lee-kesler]
Tb          447.12;      // K   [origin=predictive method=joback]
HvapTb      40096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.57 0.84104 -0.0004647 8.626e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-methylcyclopentyl)ethanone" "ethanone, 1-(2-methylcyclopentyl)-" "1-acetyl-2-methylcyclopentane" "ethanone, 1-(2-methylcyclopentyl)-, trans-" );
standardThermochemistry
{
    dHf_298   -280890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83600.0
}
