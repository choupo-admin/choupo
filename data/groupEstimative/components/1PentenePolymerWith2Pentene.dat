/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentene, polymer with 2-pentene  (C10H20, CAS 68992-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PentenePolymerWith2Pentene;
formula     C10H20;
CAS         68992-12-1;
InChIKey    BOWDPJFAGBREQM-WGCWOXMQSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          610.33;      // K   [origin=predictive method=joback]
Pc          21.197;      // bar [origin=predictive method=joback]
omega       0.3578;      // -   [origin=predictive method=lee-kesler]
Tb          430.64;      // K   [origin=predictive method=joback]
HvapTb      37436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.443 0.74766 -0.0002121 -4.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-ene;(e)-pent-2-ene" "1-pentene, 2-pentene polymer" );
standardThermochemistry
{
    dHf_298   -118700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     642.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96620.0
}
