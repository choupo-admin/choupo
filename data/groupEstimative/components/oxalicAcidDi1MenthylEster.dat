/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxalic acid, di(1-menthyl) ester  (C22H38O4, CAS 68889-96-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxalicAcidDi1MenthylEster;
formula     C22H38O4;
CAS         68889-96-3;
InChIKey    ZQJMKLXHLODZMT-UHFFFAOYSA-N;
MW          366.542;      // g/mol [origin=calculated method=formula-sum]
Tc          1050.79;      // K   [origin=predictive method=joback]
Pc          10.921;      // bar [origin=predictive method=joback]
omega       0.8016;      // -   [origin=predictive method=lee-kesler]
Tb          838.94;      // K   [origin=predictive method=joback]
HvapTb      78226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.11 2.13432 -0.0009306 4.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 8; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(5-methyl-2-propan-2-yl-cyclohexyl) ethanedioate" "ethanedioic acid, 1,2-bis((1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl) ester, rel-" "ethanedioic acid, 1,2-bis[(1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl] ester, rel-" "ethanedioic acid, bis((1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl) ester, rel-" "ethanedioic acid, bis[(1r,2s,5r)-5-methyl-2-(1-methylethyl)cyclohexyl] ester, rel-" "bis(5-methyl-2-propan-2-ylcyclohexyl) oxalate" "bis[(1r,2s,5r)-5-methyl-2-propan-2-ylcyclohexyl] oxalate" );
standardThermochemistry
{
    dHf_298   -1115250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     866.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-473200.0
}
