/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-methylenecyclopropyl)methanol  (C5H8O, CAS 29279-66-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylenecyclopropylMethanol;
formula     C5H8O;
CAS         29279-66-1;
InChIKey    CQFQAARMEJVWAL-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          588.65;      // K   [origin=predictive method=joback]
Pc          47.107;      // bar [origin=predictive method=joback]
omega       0.6678;      // -   [origin=predictive method=lee-kesler]
Tb          412.08;      // K   [origin=predictive method=joback]
HvapTb      43475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.319 0.5462 -0.0004064 1.283e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methylidenecyclopropyl)methanol" "2-methylenecyclopropanemethanol" "cyclopropanemethanol, 2-methylene-, (s)-" "(2-methyl enecyclopropyl)methanol" "cyclopropanemethanol, 2-methylene-" );
gibbsFormation
{
    dHf_298   -141720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     285.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31770.0
    phase     gas;
}
