/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenal, 2-ethyl-  (C6H10O, CAS 63883-69-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butenal2Ethyl;
formula     C6H10O;
CAS         63883-69-2;
InChIKey    IQGZCSXWIRBTRW-ZZXKWVIFSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          574.81;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.3922;      // -   [origin=predictive method=lee-kesler]
Tb          389.58;      // K   [origin=predictive method=joback]
HvapTb      35708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.039 0.56824 -0.0003817 1.073e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-2-ethylbut-2-enal" "2-ethyl-2-butenal" "2-ethyl-trans-2-butenal" "trans-2-ethylcrotonal" "2-ethyl crotonic aldehyde" "2-ethylcrotonaldehyde" "(2e)-2-ethyl-2-butenal" "ch3ch=c(c2h5)cho" "crotonaldehyde, 2-ethyl-" "iqgzcsxwirbtrw-zzxkwvifsa-" );
gibbsFormation
{
    dHf_298   -145320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28210.0
    phase     gas;
}
