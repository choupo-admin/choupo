/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-humulene  (C15H24, CAS 116-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaHumulene;
formula     C15H24;
CAS         116-04-1;
InChIKey    HAVYZKHVTLAPDZ-RCHZWEEESA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          821.93;      // K   [origin=predictive method=joback]
Pc          20.530;      // bar [origin=predictive method=joback]
omega       0.3982;      // -   [origin=predictive method=lee-kesler]
Tb          586.40;      // K   [origin=predictive method=joback]
HvapTb      50527.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.8 1.50586 -0.00098892 2.798e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1z,5e)-1,4,4-trimethyl-8-methylidene-cycloundeca-1,5-diene" "1,5-cycloundecadiene, 1,4,4-trimethyl-8-methylene-, (1e,5e)-" "(1z,5e)-1,4,4-trimethyl-8-methylidenecycloundeca-1,5-diene" "1,5-cycloundecadiene, 1,4,4-trimethyl-8-methylene-, (e,e)-" );
standardThermochemistry
{
    dHf_298   -125840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     771.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137250.0
}
