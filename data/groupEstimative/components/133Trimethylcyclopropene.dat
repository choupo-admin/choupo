/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-trimethylcyclopropene  (C6H10, CAS 3664-56-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Trimethylcyclopropene;
formula     C6H10;
CAS         3664-56-0;
InChIKey    MRLAULBRWNYTDV-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          538.85;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.2302;      // -   [origin=predictive method=lee-kesler]
Tb          348.00;      // K   [origin=predictive method=joback]
HvapTb      28666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.72 0.90116 -0.00097564 4.368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropene-1,3,3-trimethyl" "cyclopropene, 1,3,3-trimethyl-" );
gibbsFormation
{
    dHf_298   -32820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     325.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75230.0
    phase     gas;
}
