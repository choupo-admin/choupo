/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetraethylisophthalamide  (C16H24N2O2, CAS 13698-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNNTetraethylisophthalamide;
formula     C16H24N2O2;
CAS         13698-87-8;
InChIKey    GZWCNZZTWDDVSL-UHFFFAOYSA-N;
MW          276.38;      // g/mol [origin=calculated method=formula-sum]
Tc          930.29;      // K   [origin=predictive method=joback]
Pc          18.643;      // bar [origin=predictive method=joback]
omega       1.0362;      // -   [origin=predictive method=lee-kesler]
Tb          729.96;      // K   [origin=predictive method=joback]
HvapTb      71726.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.926 1.57728 -0.00099856 2.3652e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n3,n3-tetraethylbenzene-1,3-dicarboxamide" "[3-(n,n-diethylcarbamoyl)phenyl]-n,n-diethylcarboxamide" "n,n,n',n'-tetraethylbenzene-1,3-dicarboxamide" "1,3-benzenedicarboxamide,n1,n1,n3,n3-tetraethyl-" "brd-k51473477-001-01-4" "1-n,1-n,3-n,3-n-tetraethylbenzene-1,3-dicarboxamide" "1,3-benzenedicarboxamide,n,n,n',n'-tetraethyl- (9ci);m-bis(diethylcarbamoyl)benzene;isophthalamide, n,n,n',n'-tetraethyl- (6ci,8ci);n,n,n',n'-tetraethylbenzene-1,3-dicarboxamide;n,n,n',n'-tetraethylisophthalamide;" );
standardThermochemistry
{
    dHf_298   -238610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=150340.0
}
