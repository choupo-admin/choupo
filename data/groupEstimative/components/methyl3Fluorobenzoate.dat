/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-fluorobenzoate  (C8H7FO2, CAS 455-68-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl3Fluorobenzoate;
formula     C8H7FO2;
CAS         455-68-5;
InChIKey    YXZNVLYXBIIIOB-UHFFFAOYSA-N;
MW          154.14;      // g/mol [origin=calculated method=formula-sum]
Tc          678.01;      // K   [origin=predictive method=joback]
Pc          34.199;      // bar [origin=predictive method=joback]
omega       0.4968;      // -   [origin=predictive method=lee-kesler]
Tb          471.79;      // K   [origin=predictive method=joback]
HvapTb      42930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.51 0.58242 -0.00029736 3.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-fluoranylbenzoate" "3-fluorobenzoic acid, methyl ester" "benzoic acid, 3-fluoro-, methyl ester" "methyl3-fluorobenzoate" "3-fluorobenzoic acid methyl ester" "i514" "benzoicacid, m-fluoro-, methyl ester (7ci,8ci);3-fluorobenzoic acid methyl ester;methyl 3-fluorobenzoate;methyl m-fluorobenzoate;" );
gibbsFormation
{
    dHf_298   -496780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-385920.0
    phase     gas;
}
