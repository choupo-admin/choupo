/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycluron  (C11H22N2O, CAS 2163-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycluron;
formula     C11H22N2O;
CAS         2163-69-1;
InChIKey    DQZCVNGCTZLGAQ-UHFFFAOYSA-N;
MW          198.31;      // g/mol [origin=calculated method=formula-sum]
Tc          811.75;      // K   [origin=predictive method=joback]
Pc          26.434;      // bar [origin=predictive method=joback]
omega       0.6936;      // -   [origin=predictive method=lee-kesler]
Tb          595.85;      // K   [origin=predictive method=joback]
HvapTb      56078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.5 1.32384 -0.0007053 1.0836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CHNH; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclooctyl-1,1-dimethyl-urea" "3-cyclooctyl-1,1-dimethylurea" "cyclouron" "urea, n'-cyclooctyl-n,n-dimethyl-" "cycluron [bsi:iso]" "urea, 3-cyclooctyl-1,1-dimethyl-" "n-cyclooctyl-n',n'-dimethylurea" "hs 61" "3-cyclooctyl-1,1-dimethylharnstoff [german]" "omu" "3-cyclooctyl-1,1-dimethylharnstoff" "(dimethylamino)-n-cyclooctylcarboxamide" );
standardThermochemistry
{
    dHf_298   -219950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     677.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113240.0
}
