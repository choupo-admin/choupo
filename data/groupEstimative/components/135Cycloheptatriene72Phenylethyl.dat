/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-cycloheptatriene,7-(2-phenylethyl)-  (C15H16, CAS 71275-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Cycloheptatriene72Phenylethyl;
formula     C15H16;
CAS         71275-32-6;
InChIKey    CHBFHNUTCRRSGB-UHFFFAOYSA-N;
MW          196.293;      // g/mol [origin=calculated method=formula-sum]
Tc          833.00;      // K   [origin=predictive method=joback]
Pc          25.277;      // bar [origin=predictive method=joback]
omega       0.4636;      // -   [origin=predictive method=lee-kesler]
Tb          590.78;      // K   [origin=predictive method=joback]
HvapTb      52737.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.038 1.2944 -0.00081984 1.851e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(2-phenylethyl)cyclohepta-1,3,5-triene" "7-phenethylcyclohepta-1,3,5-triene" "1,3,5-cycloheptatriene, 7-(2-phenylethyl)-" );
gibbsFormation
{
    dHf_298   105100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290060.0
    phase     gas;
}
