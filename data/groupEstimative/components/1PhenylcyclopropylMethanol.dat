/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-phenylcyclopropyl)methanol  (C10H12O, CAS 31729-66-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PhenylcyclopropylMethanol;
formula     C10H12O;
CAS         31729-66-5;
InChIKey    APALRPYIDIBHQN-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          769.02;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.7793;      // -   [origin=predictive method=lee-kesler]
Tb          554.24;      // K   [origin=predictive method=joback]
HvapTb      55571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.049 1.3517 -0.0013346 5.404e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl cyclopropane-1-methanol" "cyclopropanemethanol,1-phenyl-" "apalrpyidibhqn-uhfffaoysa-" "(1-phenylcyclopropyl)methanol;1-phenyl-1-(hydroxymethyl)cyclopropane;1-phenyl-1-cyclopropanemethanol;1-phenylcyclopropanemethanol;" );
gibbsFormation
{
    dHf_298   -77390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64170.0
    phase     gas;
}
