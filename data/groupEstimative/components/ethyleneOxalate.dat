/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene oxalate  (C4H4O4, CAS 3524-70-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneOxalate;
formula     C4H4O4;
CAS         3524-70-7;
InChIKey    ZNLAHAOCFKBYRH-UHFFFAOYSA-N;
MW          116.072;      // g/mol [origin=calculated method=formula-sum]
Tc          607.50;      // K   [origin=predictive method=joback]
Pc          47.301;      // bar [origin=predictive method=joback]
omega       0.5307;      // -   [origin=predictive method=lee-kesler]
Tb          414.70;      // K   [origin=predictive method=joback]
HvapTb      39362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.99 0.4612 -0.0003266 7.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dioxane-2,3-dione" "diketodioxane" );
gibbsFormation
{
    dHf_298   -661150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-557380.0
    phase     gas;
}
