/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-4,7-dihydro-1,3-dioxepine  (C11H12O2, CAS 2568-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyl47Dihydro13Dioxepine;
formula     C11H12O2;
CAS         2568-24-3;
InChIKey    DRRPAFPCDLXMFG-UHFFFAOYSA-N;
MW          176.215;      // g/mol [origin=calculated method=formula-sum]
Tc          806.54;      // K   [origin=predictive method=joback]
Pc          34.807;      // bar [origin=predictive method=joback]
omega       0.4466;      // -   [origin=predictive method=lee-kesler]
Tb          554.84;      // K   [origin=predictive method=joback]
HvapTb      52269.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.32 1.0204 -0.00059988 1.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-dihydro-2-phenyl-1,3-dioxepin" "2-phenyl-2h,4h,7h-1,3-dioxepin" "1,3-dioxepin,4,7-dihydro-2-phenyl-" "2-phenyl-4,7-dihydro-2h-1,3-dioxepine" );
standardThermochemistry
{
    dHf_298   -191900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     327.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=24220.0
}
