/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl benzene-1,3-dicarboxylate;2,2,4-trimethylpentane-1,3-diol  (C18H28O6, CAS 65072-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylBenzene13Dicarboxylate224Trimethylpentane13Diol;
formula     C18H28O6;
CAS         65072-12-0;
InChIKey    ARFFQIAZXGCLDR-UHFFFAOYSA-N;
MW          340.416;      // g/mol [origin=calculated method=formula-sum]
Tc          1153.88;      // K   [origin=predictive method=joback]
Pc          16.142;      // bar [origin=predictive method=joback]
omega       1.3846;      // -   [origin=predictive method=lee-kesler]
Tb          941.19;      // K   [origin=predictive method=joback]
HvapTb      104994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.301 1.46532 -0.00055456 -3.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-benzenedicarboxylic acid, dimethyl ester, polymer with 2,2,4-trimethyl-1,3-pentanediol" "1,3-benzenedicarboxylic acid, 1,3-dimethyl ester, polymer with 2,2,4-trimethyl-1,3-pentanediol" "dimethyl benzene-1,3-dicarboxylate; 2,2,4-trimethylpentane-1,3-diol" );
gibbsFormation
{
    dHf_298   -1259740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     998.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-797720.0
    phase     gas;
}
