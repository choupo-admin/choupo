/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxy-2,4,5-trifluorobenzoic acid  (C8H5F3O3, CAS 112811-65-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxy245TrifluorobenzoicAcid;
formula     C8H5F3O3;
CAS         112811-65-1;
InChIKey    YVJHZWWMKFQKDC-UHFFFAOYSA-N;
MW          206.119;      // g/mol [origin=calculated method=formula-sum]
Tc          793.87;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.9523;      // -   [origin=predictive method=lee-kesler]
Tb          594.98;      // K   [origin=predictive method=joback]
HvapTb      55449.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.28 0.46992 -0.00018524 -1e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,5-tris(fluoranyl)-3-methoxy-benzoic acid" "2,4,5-trifluoro-3-methoxybenzoic acid" "2,4,5-trifluoro-m-anisic acid" "2,4,5-trifluoro-3-methoxy-benzoic acid" "3-methoxy-2,4,5-trifluorobenzoicacid" "2,4,5-trifluoro-3-methoxy benzoic acid" );
gibbsFormation
{
    dHf_298   -1088620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-942970.0
    phase     gas;
}
