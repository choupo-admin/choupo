/*--------------------------------*- Choupo -*-----------------------*\
  Component: salicylic acid, carbitol, triethanolamine, diethanolamine reaction product  (C23H46N2O11, CAS 68512-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        salicylicAcidCarbitolTriethanolamineDiethanolamineReactionPr;
formula     C23H46N2O11;
CAS         68512-08-3;
InChIKey    AOBMSYHSZLSYCY-UHFFFAOYSA-N;
MW          526.624;      // g/mol [origin=calculated method=formula-sum]
Tc          2921.10;      // K   [origin=predictive method=joback]
Pc          14.884;      // bar [origin=predictive method=joback]
omega       -0.3030;      // -   [origin=predictive method=lee-kesler]
Tb          1643.38;      // K   [origin=predictive method=joback]
HvapTb      213501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (137.055 1.97442 -0.00046476 -2.054e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 5; } { group ACOH; count 1; } { group CH2O; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 6; } { group OH_phenol; count 1; } { group O; count 2; } { group COOH; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-hydroxyethyl)amino]ethanol;2-(2-ethoxyethoxy)ethanol;2-(2-hydroxyethylamino)ethanol;2-oxidanylbenzoic acid" "2-(bis(2-hydroxyethyl)amino)ethanol; 2-(2-ethoxyethoxy)ethanol; 2-hydroxybenzoic acid; 2-(2-hydroxyethylamino)ethanol" "2-[bis(2-hydroxyethyl)amino]ethanol; 2-(2-ethoxyethoxy)ethanol; 2-hydroxybenzoic acid; 2-(2-hydroxyethylamino)ethanol" "benzoic acid, 2-hydroxy-, reaction products with diethanolamine, 2-(2-ethoxyethoxy)ethanol and triethanolamine" );
gibbsFormation
{
    dHf_298   -2200780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1732.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1388370.0
    phase     gas;
}
