/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(1-naphthyl)ethylenediamine  (C12H14N2, CAS 551-09-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n1NaphthylEthylenediamine;
formula     C12H14N2;
CAS         551-09-7;
InChIKey    NULAJYZBOLVQPQ-UHFFFAOYSA-N;
MW          186.258;      // g/mol [origin=calculated method=formula-sum]
Tc          884.13;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.7955;      // -   [origin=predictive method=lee-kesler]
Tb          647.50;      // K   [origin=predictive method=joback]
HvapTb      63961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.788 1.1398 -0.00082188 2.348e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH2NH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-naphthalen-1-ylethane-1,2-diamine" "1,2-ethanediamine, n-1-naphthalenyl-" "1,2-ethanediamine, n1-1-naphthalenyl-" "n-(naphthalen-1-yl)ethane-1,2-diamine" "1,2-ethanediamine, n1-1-naphthalenyl-, hydrochloride (1:2)" "(2-aminoethyl)naphthylamine" "1465-25-4 (di-hydrochloride)" "n-(1-naphthyl)ethane-1,2-diamine" "n-naphthalen-1-ylethane-1,2-diamine" "naphthalene, 1-[2-aminoethyl;amino]-" "n1-(naphthalen-1-yl)ethane-1,2-diamine" "n-(naphthalen-1-yl) ethylenediamine" );
standardThermochemistry
{
    dHf_298   212380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=415430.0
}
