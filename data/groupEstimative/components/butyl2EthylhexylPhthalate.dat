/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl 2-ethylhexyl phthalate  (C20H30O4, CAS 85-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butyl2EthylhexylPhthalate;
formula     C20H30O4;
CAS         85-69-8;
InChIKey    AVOLBYOSCILFLL-UHFFFAOYSA-N;
MW          334.456;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.59;      // K   [origin=predictive method=joback]
Pc          12.719;      // bar [origin=predictive method=joback]
omega       0.9925;      // -   [origin=predictive method=lee-kesler]
Tb          804.86;      // K   [origin=predictive method=joback]
HvapTb      77478.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.238 1.66176 -0.00084236 1.127e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-butyl o2-(2-ethylhexyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, butyl 2-ethylhexyl ester" "phthalic acid, butyl 2-ethylhexyl ester" "1,2-benzenedicarboxylic acid, 1-butyl 2-(2-ethylhexyl) ester" "2-ethylhexyl butyl phthalate" "1-o-butyl 2-o-(2-ethylhexyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylicacid, 1-butyl 2-(2-ethylhexyl) ester" "1,2-benzenedicarboxylicacid, butyl 2-ethylhexyl ester (9ci); phthalic acid, butyl 2-ethylhexyl ester(6ci,7ci,8ci); butyl 2-ethylhexyl phthalate" );
gibbsFormation
{
    dHf_298   -870910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     915.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-402880.0
    phase     gas;
}
