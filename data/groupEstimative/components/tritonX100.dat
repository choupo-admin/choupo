/*--------------------------------*- Choupo -*-----------------------*\
  Component: triton x-100  (C16H26O2, CAS 9002-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tritonX100;
formula     C16H26O2;
CAS         9002-93-1;
InChIKey    JYCQQPHGFMYQCF-UHFFFAOYSA-N;
MW          250.382;      // g/mol [origin=calculated method=formula-sum]
Tc          903.47;      // K   [origin=predictive method=joback]
Pc          18.499;      // bar [origin=predictive method=joback]
omega       0.9818;      // -   [origin=predictive method=lee-kesler]
Tb          705.48;      // K   [origin=predictive method=joback]
HvapTb      70645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.417 1.6079 -0.00107376 2.786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2,4,4-trimethylpentan-2-yl)phenoxy]ethanol" "octoxynol 9" "octoxynol" "triton x" "preceptin" "triton x-45" "triton x 45" "octoxynol-3" "octoxynol-9" "hydrol sw" "alfenol 3" "alfenol 9" );
gibbsFormation
{
    dHf_298   -450460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-49520.0
    phase     gas;
}
