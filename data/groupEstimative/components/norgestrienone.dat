/*--------------------------------*- Choupo -*-----------------------*\
  Component: norgestrienone  (C20H22O2, CAS 848-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norgestrienone;
formula     C20H22O2;
CAS         848-21-5;
InChIKey    GVDMJXQHPUYPHP-FYQPLNBISA-N;
MW          294.394;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.60;      // K   [origin=predictive method=joback]
Pc          23.451;      // bar [origin=predictive method=joback]
omega       1.0912;      // -   [origin=predictive method=lee-kesler]
Tb          868.53;      // K   [origin=predictive method=joback]
HvapTb      81970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-220.11 2.46852 -0.00232125 9.2359e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 2; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group CH_C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,13s,14s,17r)-17-ethynyl-13-methyl-17-oxidanyl-1,2,6,7,8,14,15,16-octahydrocyclopenta[a]phenanthren-3-one" "ogyline" "planor" "ethynyl trienolone" "17alpha-ethynyltrienolone" "norgestrienonum [inn-latin]" "17-alpha-ethynyl-17-beta-hydroxyestra-4,9,11-trien-3-one" "17-hydroxy-19-nor-17-alpha-pregna-4,9,11-trien-20-yn-3-one" "17-hydroxy-19-nor-17alpha-pregna-4,9,11-trien-20-yn-3-one" "19-nor-17-alpha-pregna-4,9,11-trien-20-yn-3-one, 17-hydroxy-" "norgestrienona" "norgestrienonum" );
gibbsFormation
{
    dHf_298   -24350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=313690.0
    phase     gas;
}
