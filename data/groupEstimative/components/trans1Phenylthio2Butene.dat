/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-1-(phenylthio)-2-butene  (C10H12S, CAS 36195-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans1Phenylthio2Butene;
formula     C10H12S;
CAS         36195-56-9;
InChIKey    BNNLEMHAUPCSCL-NSCUHMNNSA-N;
MW          164.266;      // g/mol [origin=calculated method=formula-sum]
Tc          765.56;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.4202;      // -   [origin=predictive method=lee-kesler]
Tb          528.02;      // K   [origin=predictive method=joback]
HvapTb      46905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.689 0.88931 -0.000595 1.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-but-2-enyl]sulfanylbenzene" "[(e)-but-2-enyl]sulfanyl-benzene" );
standardThermochemistry
{
    dHf_298   145890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=259070.0
}
