/*--------------------------------*- Choupo -*-----------------------*\
  Component: [17-(5-ethyl-6-methylhept-3-en-2-yl)-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] acetate  (C31H50O2, CAS 4651-48-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        175Ethyl6Methylhept3En2Yl1013Dimethyl234789111214151617Dodec;
formula     C31H50O2;
CAS         4651-48-3;
InChIKey    IZEUIYYDWBKERE-UHFFFAOYSA-N;
MW          454.739;      // g/mol [origin=calculated method=formula-sum]
Tc          1242.56;      // K   [origin=predictive method=joback]
Pc          8.372;      // bar [origin=predictive method=joback]
omega       0.7445;      // -   [origin=predictive method=lee-kesler]
Tb          1008.86;      // K   [origin=predictive method=joback]
HvapTb      89038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-305.769 3.87624 -0.00312944 1.0849e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 9; } { group CH; count 8; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 1; } { group CH; count 3; } { group dCH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[17-(5-ethyl-6-methyl-hept-3-en-2-yl)-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] ethanoate" "[(3s,10r,13r,17r)-17-[(z,5s)-5-ethyl-6-methylhept-3-en-2-yl]-10,13-dimethyl-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] acetate" );
standardThermochemistry
{
    dHf_298   -622900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1086.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141390.0
}
