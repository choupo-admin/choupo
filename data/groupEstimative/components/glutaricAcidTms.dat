/*--------------------------------*- Choupo -*-----------------------*\
  Component: glutaric acid (tms)  (C11H24O4Si2, CAS 55494-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H24O4Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        glutaricAcidTms;
formula     C11H24O4Si2;
CAS         55494-07-0;
InChIKey    UWZGPXOJVOOLSG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          276.479;      // g/mol [origin=calculated method=formula-sum]
Tc          753.88;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       0.6206;      // -   [origin=predictive method=lee-kesler]
Tb          570.52;      // K   [origin=predictive method=joback]
HvapTb      55482.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (125.343 0.52692 0.0004442 -4.289e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH2COO; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(trimethylsilyl) pentanedioate" "pentanedioic acid, bis(trimethylsilyl) ester" );
gibbsFormation
{
    dHf_298   -1128170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     940.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-788520.0
    phase     gas;
}
