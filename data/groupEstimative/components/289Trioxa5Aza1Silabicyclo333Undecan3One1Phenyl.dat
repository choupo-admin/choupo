/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecan-3-one, 1-phenyl-  (C12H15NO4Si, CAS 53883-47-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H15NO4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        289Trioxa5Aza1Silabicyclo333Undecan3One1Phenyl;
formula     C12H15NO4Si;
CAS         53883-47-9;
InChIKey    NAVDJBGJEHGBBM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          265.34;      // g/mol [origin=calculated method=formula-sum]
Tc          894.28;      // K   [origin=predictive method=joback]
Pc          30.090;      // bar [origin=predictive method=joback]
omega       0.7348;      // -   [origin=predictive method=lee-kesler]
Tb          653.89;      // K   [origin=predictive method=joback]
HvapTb      63962.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.23 1.267 -0.0007404 1.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group CH2O; count 2; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-phenyl-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecan-3-one" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecan-3-one, 1-phenyl-" );
standardThermochemistry
{
    dHf_298   -499730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-189200.0
}
