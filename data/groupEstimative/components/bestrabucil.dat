/*--------------------------------*- Choupo -*-----------------------*\
  Component: bestrabucil  (C41H47Cl2NO6, CAS 75219-46-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bestrabucil;
formula     C41H47Cl2NO6;
CAS         75219-46-4;
InChIKey    IFJUINDAXYAPTO-YEMMQMLISA-N;
MW          720.728;      // g/mol [origin=calculated method=formula-sum]
Tc          1915.60;      // K   [origin=predictive method=joback]
Pc          6.754;      // bar [origin=predictive method=joback]
omega       0.3456;      // -   [origin=predictive method=lee-kesler]
Tb          1514.28;      // K   [origin=predictive method=joback]
HvapTb      147022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-200.962 4.12912 -0.00295828 8.423e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 3; } { group C; count 1; } { group ACH; count 12; } { group AC; count 3; } { group ACCH2; count 2; } { group ACCH; count 1; } { group CH2COO; count 2; } { group CH2N; count 1; } { group CH2Cl; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group Cl; count 2; } { group COO; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(17s)-17-[2-[4-[4-[bis(2-chloroethyl)amino]phenyl]butanoyloxy]ethanoyloxy]-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-3-yl] benzoate" "atrimustine" "atrimustinum [inn-latin]" "estradiol 3-benzoate 17-glycolate, 4-(p-(bis(2-chloroethyl)amino)phenyl)butyrate" "estra-1,3,5(10)-triene-3,17-diol, (17-beta)-, 3-benzoate, 17-((4-(4-(bis(2-chloroethyl)amino)phenyl)-1-oxobutoxy)acetate)" "atrimustina" "atrimustinum" "atrimustine [inn]" "estra-1,3,5(10)-triene-3,17-diol (17beta)-, 3-benzoate 17-((4-(4-(bis(2-chloroethyl)amino)phenyl)-1-oxobutoxy)acetate)" "[(17s)-17-[2-[4-[4-[bis(2-chloroethyl)amino]phenyl]butanoyloxy]acetyl]oxy-13-methyl-6,7,8,9,11,12,14,15,16,17-decahydrocyclopenta[a]phenanthren-3-yl] benzoate" );
standardThermochemistry
{
    dHf_298   -949540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1405.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-104370.0
}
