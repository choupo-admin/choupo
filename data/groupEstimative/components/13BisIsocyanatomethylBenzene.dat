/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(isocyanatomethyl)benzene  (C10H8N2O2, CAS 3634-83-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13BisIsocyanatomethylBenzene;
formula     C10H8N2O2;
CAS         3634-83-1;
InChIKey    RTTZISZSHSCFRH-UHFFFAOYSA-N;
MW          188.186;      // g/mol [origin=calculated method=formula-sum]
Tc          815.44;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.7650;      // -   [origin=predictive method=lee-kesler]
Tb          593.40;      // K   [origin=predictive method=joback]
HvapTb      59856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 2; } { group dCd; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-xylylene diisocyanate" "m-xylene diisocyanate" "takenate" "benzene, 1,3-bis(isocyanatomethyl)-" "m-xdi" "m-xylidene diisocyanate" "m-phenylenedimethylene isocyanate" "isocyanic acid, m-phenylenedimethylene ester" "1,3-bis[isocyanatomethyl]benzene" "m-xylylendiisokyanat" "m-xylylene diisocyanate (xdi)" "1,3-bis-(isokyanatomethyl)benzen" );
