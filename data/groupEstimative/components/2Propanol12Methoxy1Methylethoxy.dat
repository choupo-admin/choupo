/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1-(2-methoxy-1-methylethoxy)-  (C7H16O3, CAS 20324-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol12Methoxy1Methylethoxy;
formula     C7H16O3;
CAS         20324-32-7;
InChIKey    WGYZMNBUZFHYRX-UHFFFAOYSA-N;
MW          148.202;      // g/mol [origin=calculated method=formula-sum]
Tc          662.78;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.9138;      // -   [origin=predictive method=lee-kesler]
Tb          495.90;      // K   [origin=predictive method=joback]
HvapTb      51899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.452 0.58826 -0.0001718 -2.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH3O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-methoxypropan-2-yloxy)propan-2-ol" "1-(2-methoxy-1-methylethoxy)propan-2-ol" "ppg-3 methyl ether" "polypropylene glycol monomethyl ether" "polypropylene monomethyl ether" "propylene oxide-methanol adduct" "polypropylene glycol methyl ether" "polyoxypropylene (3) methyl ether" "poly(oxypropylene) monomethyl ether" "polypropylene glycol monomethylether" "1-(2-methoxy-1-methylethoxy)-2-propanol" "polypropylene glycol methyl monoether" );
standardThermochemistry
{
    dHf_298   -615040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343640.0
}
