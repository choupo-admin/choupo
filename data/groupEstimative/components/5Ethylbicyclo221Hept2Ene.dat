/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-ethylbicyclo[2.2.1]hept-2-ene  (C9H14, CAS 15403-89-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Ethylbicyclo221Hept2Ene;
formula     C9H14;
CAS         15403-89-1;
InChIKey    QHJIJNGGGLNBNJ-UHFFFAOYSA-N;
MW          122.211;      // g/mol [origin=calculated method=formula-sum]
Tc          618.85;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.3174;      // -   [origin=predictive method=lee-kesler]
Tb          417.76;      // K   [origin=predictive method=joback]
HvapTb      35609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.179 1.06852 -0.00079168 2.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 3; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-ethyl-2-norbornene" "5-ethyl bicyclo[2.2.1]-2-heptene" "5-ethyl bicyclo(2.2.1)-2-heptene" "5-ethylnorbornene" "bicyclo(2.2.1)hept-2-ene, 5-ethyl-" );
standardThermochemistry
{
    dHf_298   -52210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     266.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=156550.0
}
