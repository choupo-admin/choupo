/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl propionate  (C6H12O2, CAS 637-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylPropionate;
formula     C6H12O2;
CAS         637-78-5;
InChIKey    IJMWOMHMDSDKGK-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          572.39;      // K   [origin=predictive method=joback]
Pc          31.526;      // bar [origin=predictive method=joback]
omega       0.4173;      // -   [origin=predictive method=lee-kesler]
Tb          394.66;      // K   [origin=predictive method=joback]
HvapTb      35969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.161 0.52496 -0.0002112 2.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl propanoate" "propanoic acid, 1-methylethyl ester" "propionic acid isopropyl ester" "propionic acid, isopropyl ester" "methylethyl propanoate" "isopropyl propanoate" "1-methylethyl propanoate" "propionicacid, isopropyl ester (6ci,7ci,8ci);1-methylethyl propanoate;2-propylpropionate;isopropyl propionate;iso-propyl propionate;" );
standardThermochemistry
{
    dHf_298   -489730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313170.0
}
