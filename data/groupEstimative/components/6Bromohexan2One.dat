/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromohexan-2-one  (C6H11BrO, CAS 10226-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Bromohexan2One;
formula     C6H11BrO;
CAS         10226-29-6;
InChIKey    CZGOECYPTLSLNI-UHFFFAOYSA-N;
MW          179.057;      // g/mol [origin=calculated method=formula-sum]
Tc          652.56;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.5545;      // -   [origin=predictive method=lee-kesler]
Tb          456.91;      // K   [origin=predictive method=joback]
HvapTb      42131.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.984 0.58402 -0.0003553 8.526e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanylhexan-2-one" "6-bromo-2-hexanone" "1-bromo-5-hexanone" "2-hexanone, 6-bromo-" "5-oxohexyl bromide" "6-bromo-hexan-2-one" "1-bromo-5-hexanone;5-oxohexyl bromide;6-bromo-2-hexanone;" );
standardThermochemistry
{
    dHf_298   -253420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114960.0
}
