/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexene, 1,1-dimethoxy-, (3z)-  (C8H16O2, CAS 55444-65-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexene11Dimethoxy3z;
formula     C8H16O2;
CAS         55444-65-0;
InChIKey    AIFDKYGVVMSLMZ-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          607.21;      // K   [origin=predictive method=joback]
Pc          26.031;      // bar [origin=predictive method=joback]
omega       0.4840;      // -   [origin=predictive method=lee-kesler]
Tb          431.20;      // K   [origin=predictive method=joback]
HvapTb      37792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.752 0.66336 -0.0002764 2.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethoxyhex-3-ene" );
standardThermochemistry
{
    dHf_298   -360950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-115740.0
}
