/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-isopropylideneglyceraldehyde  (C6H10O3, CAS 15186-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rIsopropylideneglyceraldehyde;
formula     C6H10O3;
CAS         15186-48-8;
InChIKey    YSGPYVWACGYQDJ-YFKPBYRVSA-N;
MW          130.143;      // g/mol [origin=calculated method=formula-sum]
Tc          662.57;      // K   [origin=predictive method=joback]
Pc          41.839;      // bar [origin=predictive method=joback]
omega       0.4610;      // -   [origin=predictive method=lee-kesler]
Tb          450.29;      // K   [origin=predictive method=joback]
HvapTb      43487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.06 0.93944 -0.0008724 3.5e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CHO; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r)-2,2-dimethyl-1,3-dioxolane-4-carbaldehyde" "(r)-(+)-2,2-dimethyl-1,3-dioxolane-4-carboxaldehyde" "(4r)-2,2-dimethyl-1,3-dioxolan-4-carbaldehyd" "1,3-dioxolane-4-carboxaldehyde, 2,2-dimethyl-, (r)-" "d-glyceraldehyde acetonide" "(r)-(+)-glyceraldehyde acetonide" "(4r)-2,2-dimethyl-1,3-dioxolane-4-carboxaldehyde" "(r)-(+)-2,2-dimethyl-1,3-dioxolane-4-carbaldehyde" "(r)-(+)-2,2-dimethyl-1,3-dioxolan-4-carboxaldehyde" "(r)-2,2-dimethyl-1,3-dioxolane-4-carboxaldehyde 50% in dichloromethane reversibly polymerizes on standing" );
standardThermochemistry
{
    dHf_298   -461370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     282.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248770.0
}
