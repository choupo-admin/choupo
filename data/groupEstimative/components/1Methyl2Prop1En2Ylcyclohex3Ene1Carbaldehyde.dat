/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-2-prop-1-en-2-ylcyclohex-3-ene-1-carbaldehyde  (C11H16O, CAS 68140-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl2Prop1En2Ylcyclohex3Ene1Carbaldehyde;
formula     C11H16O;
CAS         68140-59-0;
InChIKey    YBBDTMDDFBAHSO-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          728.85;      // K   [origin=predictive method=joback]
Pc          27.701;      // bar [origin=predictive method=joback]
omega       0.4425;      // -   [origin=predictive method=lee-kesler]
Tb          510.78;      // K   [origin=predictive method=joback]
HvapTb      45471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.27 1.33474 -0.00113828 4.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-2-prop-1-en-2-yl-cyclohex-3-ene-1-carbaldehyde" "1-methyl-2-(1-methylvinyl)cyclohex-3-ene-1-carbaldehyde" "1-methyl-2-(prop-1-en-2-yl)cyclohex-3-ene-1-carbaldehyde" "3-cyclohexene-1-carboxaldehyde, 1-methyl-2-(1-methylethenyl)-" );
gibbsFormation
{
    dHf_298   -133310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62720.0
    phase     gas;
}
