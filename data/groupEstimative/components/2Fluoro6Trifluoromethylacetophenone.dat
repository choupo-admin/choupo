/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-6-trifluoromethylacetophenone;  (C9H6F4O, CAS 174013-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro6Trifluoromethylacetophenone;
formula     C9H6F4O;
CAS         174013-29-7;
InChIKey    IYMYYQMPOBPRPU-UHFFFAOYSA-N;
MW          206.138;      // g/mol [origin=calculated method=formula-sum]
Tc          680.78;      // K   [origin=predictive method=joback]
Pc          28.323;      // bar [origin=predictive method=joback]
omega       0.6000;      // -   [origin=predictive method=lee-kesler]
Tb          489.88;      // K   [origin=predictive method=joback]
HvapTb      41410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.35 0.80592 -0.00058162 1.5686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3CO; count 1; } { group ACF; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 4; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-fluoranyl-6-(trifluoromethyl)phenyl]ethanone" "2'-fluoro-6'-(trifluoromethyl)acetophenone" "1-(2-fluoro-6-(trifluoromethyl)phenyl)ethanone" "1-[2-fluoro-6-(trifluoromethyl)phenyl]ethanone" "2'-fluoro-6'-(trifluoromethyl)-acetophenone" "1-acetyl-2-fluoro-6-(trifluoromethyl)benzene" "2-fluoro-6-(trifluoromethyl)acetophenone" "1-(2-fluoro-6-trifluoromethyl-phenyl)-ethanone" "ethanone,1-[2-fluoro-6-(trifluoromethyl)phenyl]-" "1-[2-fluoro-6-(trifluoromethyl)phenyl]ethan-1-one" );
gibbsFormation
{
    dHf_298   -921270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-787270.0
    phase     gas;
}
