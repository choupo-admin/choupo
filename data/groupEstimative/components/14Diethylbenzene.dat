/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diethylbenzene  (C10H14, CAS 105-05-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diethylbenzene;
formula     C10H14;
CAS         105-05-5;
InChIKey    DSNHSQKRULAAEI-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          666.07;      // K   [origin=predictive method=joback]
Pc          28.843;      // bar [origin=predictive method=joback]
omega       0.3891;      // -   [origin=predictive method=lee-kesler]
Tb          460.06;      // K   [origin=predictive method=joback]
HvapTb      40792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.808 0.81544 -0.00048436 1.084e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-diethylbenzene" "benzene, 1,4-diethyl-" "benzene, p-diethyl-" "p-ethylethylbenzene" "agn-pc-0cqers" "ambap105-05-5" "i794" "benzene,p-diethyl- (8ci);p-xylene, a,a'-dimethyl- (7ci);p-diethylbenzene;p-ethylethylbenzene;" );
gibbsFormation
{
    dHf_298   -24670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136100.0
    phase     gas;
}
