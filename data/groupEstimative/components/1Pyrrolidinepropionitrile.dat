/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pyrrolidinepropionitrile  (C7H12N2, CAS 26165-45-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pyrrolidinepropionitrile;
formula     C7H12N2;
CAS         26165-45-7;
InChIKey    PDVYZQGNSCSKPG-UHFFFAOYSA-N;
MW          124.187;      // g/mol [origin=calculated method=formula-sum]
Tc          697.52;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.5375;      // -   [origin=predictive method=lee-kesler]
Tb          489.96;      // K   [origin=predictive method=joback]
HvapTb      44091.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.468 0.8953 -0.0006678 2.008e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pyrrolidin-1-ylpropanenitrile" "1-pyrrolidinepropanenitrile" "3-(1-pyrrolidino)propionitrile" "beta-pyrrolidinopropionitrile" "n-(2-cyanoethyl)pyrrolidine" "pyrrolidine-1-propiononitrile" "n-(beta-cyanoethyl)pyrrolidine" "3-(1-pyrrolidine)propionitrile" "3-(1-pyrrolidinyl)propionitrile" "3-(pyrrolidin-1-yl)propanenitrile" "beta-n-pyrrolidinopropionitrile" "3-pyrrolidinylpropanenitrile" );
standardThermochemistry
{
    dHf_298   131580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=308380.0
}
