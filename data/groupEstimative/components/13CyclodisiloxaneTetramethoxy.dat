/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-cyclodisiloxane, tetramethoxy-  (C4H12O6Si2, CAS 129575-55-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H12O6Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13CyclodisiloxaneTetramethoxy;
formula     C4H12O6Si2;
CAS         129575-55-9;
InChIKey    AMFXSEZYSPPJOW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          212.304;      // g/mol [origin=calculated method=formula-sum]
Tc          633.68;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.5013;      // -   [origin=predictive method=lee-kesler]
Tb          444.64;      // K   [origin=predictive method=joback]
HvapTb      43796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (166.47 -0.10032 0.0007856 -4.772e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3O; count 4; } { group SiO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group O; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4-tetramethoxy-1,3,2,4-dioxadisiletane" );
standardThermochemistry
{
    dHf_298   -1042710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-738400.0
}
