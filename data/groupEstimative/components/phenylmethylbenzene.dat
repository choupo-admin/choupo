/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylmethylbenzene  (C13H11, CAS 4471-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        phenylmethylbenzene;
formula     C13H11;
CAS         4471-17-4;
InChIKey    UIBVOXFCGWJCTC-UHFFFAOYSA-N;
role        radical;
MW          167.231;      // g/mol [origin=calculated method=formula-sum]
Tc          803.11;      // K   [origin=predictive method=joback]
Pc          31.633;      // bar [origin=predictive method=joback]
omega       0.4079;      // -   [origin=predictive method=lee-kesler]
Tb          552.48;      // K   [origin=predictive method=joback]
HvapTb      49063.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.83 1.091 -0.0007877 2.182e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group dCH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   220020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=323510.0
}
