/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-ethanediol, 1-cyclohexyl-  (C8H16O2, CAS 59411-58-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Ethanediol1Cyclohexyl;
formula     C8H16O2;
CAS         59411-58-4;
InChIKey    ZXXFBCPKEVLRTI-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          770.46;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       1.2268;      // -   [origin=predictive method=lee-kesler]
Tb          586.11;      // K   [origin=predictive method=joback]
HvapTb      66801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.089 0.9598 -0.0005564 1.127e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexylethane-1,2-diol" "agn-pc-00g71r" );
gibbsFormation
{
    dHf_298   -463870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235150.0
    phase     gas;
}
