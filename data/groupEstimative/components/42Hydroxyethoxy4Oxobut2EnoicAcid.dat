/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-hydroxyethoxy)-4-oxobut-2-enoic acid  (C6H8O5, CAS 26560-94-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42Hydroxyethoxy4Oxobut2EnoicAcid;
formula     C6H8O5;
CAS         26560-94-1;
InChIKey    MAIIXYUYRNFKPL-UHFFFAOYSA-N;
MW          160.125;      // g/mol [origin=calculated method=formula-sum]
Tc          827.79;      // K   [origin=predictive method=joback]
Pc          41.303;      // bar [origin=predictive method=joback]
omega       1.3761;      // -   [origin=predictive method=lee-kesler]
Tb          636.95;      // K   [origin=predictive method=joback]
HvapTb      70158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.552 0.6238 -0.0003948 8.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 2; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2-hydroxyethyloxy)-4-oxidanylidene-but-2-enoic acid" "2-butenedioic acid (2e)-, 1-(2-hydroxyethyl) ester" "2-butenedioic acid (2z)-, 1-(2-hydroxyethyl) ester" "2-butenedioic acid (2e)-, mono(2-hydroxyethyl) ester" "2-butenedioic acid(2z)-, 1-(2-hydroxyethyl) ester" "2-butenedioicacid (2z)-, mono(2-hydroxyethyl) ester (9ci); 2-butenedioic acid (z)-,mono(2-hydroxyethyl) ester; maleic acid, 2-hydroxyethyl ester (6ci,7ci); maleicacid, mono(2-hydroxyethyl) ester (8ci); ethylene glycol, maleate (6ci);ethylene glycol, mono(hydrogen maleate) (8ci); 2-hydroxyethyl hydrogen maleate;ethylene glycol monomaleate; ethylene glycol, mono(hydrogen butenedioate);hydrogen 2-hydroxyethyl maleate; mono(2-hydroxyethyl) maleate" );
gibbsFormation
{
    dHf_298   -869730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-711240.0
    phase     gas;
}
