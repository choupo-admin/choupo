/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-isopropoxyethoxy)propane  (C8H18O2, CAS 4285-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21IsopropoxyethoxyPropane;
formula     C8H18O2;
CAS         4285-59-0;
InChIKey    TWWSMHPNERSWRN-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          601.55;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.4545;      // -   [origin=predictive method=lee-kesler]
Tb          426.16;      // K   [origin=predictive method=joback]
HvapTb      37058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.57 0.6552 -0.000199 -2.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 1; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(1-propan-2-yloxyethoxy)propane" "propane, 2,2'-[ethylidenebis(oxy)]bis-" "2,4,6-trimethyl-3,5-dioxaheptane" "2,4,6-trimethyl-3,5-dioxaheptane;" );
gibbsFormation
{
    dHf_298   -488730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-200840.0
    phase     gas;
}
