/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(2-chloroethoxy)ethane  (C6H12Cl2O2, CAS 112-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis2ChloroethoxyEthane;
formula     C6H12Cl2O2;
CAS         112-26-5;
InChIKey    AGYUOJIYYGGHKV-UHFFFAOYSA-N;
MW          187.06;      // g/mol [origin=calculated method=formula-sum]
Tc          636.00;      // K   [origin=predictive method=joback]
Pc          27.643;      // bar [origin=predictive method=joback]
omega       0.5740;      // -   [origin=predictive method=lee-kesler]
Tb          456.58;      // K   [origin=predictive method=joback]
HvapTb      42540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.216 0.461 -0.0001214 -3.14e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2O; count 2; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group Cl; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(2-chloroethyloxy)ethane" "triethylene glycol dichloride" "triglycol dichloride" "ethane, 1,2-bis(2-chloroethoxy)-" "1,2-bis(chloroethoxy)ethane" "dichlorotriethylene dioxide" "bis(2-chloroethoxy)ethane" "di(2-chloroethyl) cellosolve" "tri(ethylene glycol) dichloride" "1,8-dichloro-3,6-dioxaoctane" "2-(2-chloroethoxy)ethyl 2'-chloroethyl ether" "1,2-bis-(2-chloroethoxy)ethane" );
gibbsFormation
{
    dHf_298   -463090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-234220.0
    phase     gas;
}
