/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrabenzyl orthosilicate  (C28H28O4Si, CAS 4424-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C28H28O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetrabenzylOrthosilicate;
formula     C28H28O4Si;
CAS         4424-00-4;
InChIKey    BINKQJJWJHNOSQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          456.613;      // g/mol [origin=calculated method=formula-sum]
Tc          1293.08;      // K   [origin=predictive method=joback]
Pc          13.033;      // bar [origin=predictive method=joback]
omega       1.0015;      // -   [origin=predictive method=lee-kesler]
Tb          1038.04;      // K   [origin=predictive method=joback]
HvapTb      96960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.366 1.8892 -0.0007654 -1.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 20; } { group AC; count 4; } { group CH2O; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 20; } { group dC_ring; count 4; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(phenylmethyl) silicate" "silicic acid (h4sio4), tetrakis(methylphenyl) ester" "silicic acid (h4sio4), tetrakis(phenylmethyl) ester" "tetrabenzyl silicate" "tetrabenzyloxysilane" "silicon ester of benzyl alcohol" "tetrakis(methylphenyl) orthosilicate" "silicic acid, tetrakis(phenylmethyl) ester" );
gibbsFormation
{
    dHf_298   -315630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     992.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109760.0
    phase     gas;
}
