/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyl-n-(2-phenylethyl)acetamide  (C16H17NO, CAS 5460-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylN2PhenylethylAcetamide;
formula     C16H17NO;
CAS         5460-60-6;
InChIKey    SERBNUYNEAQHNJ-UHFFFAOYSA-N;
MW          239.318;      // g/mol [origin=calculated method=formula-sum]
Tc          957.15;      // K   [origin=predictive method=joback]
Pc          24.605;      // bar [origin=predictive method=joback]
omega       0.8701;      // -   [origin=predictive method=lee-kesler]
Tb          723.08;      // K   [origin=predictive method=joback]
HvapTb      68944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.317 1.4142 -0.0009389 2.3166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group ACCH2; count 2; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-n-(2-phenylethyl)ethanamide" "n-phenethyl-2-phenylacetamide" "n-(2-phenylethyl)phenylacetamide" "n-(phenethyl)phenylacetamide" "n-phenethyl-2-phenyl-acetamide" "benzeneacetamide, n-(2-phenylethyl)-" );
gibbsFormation
{
    dHf_298   40380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=269130.0
    phase     gas;
}
