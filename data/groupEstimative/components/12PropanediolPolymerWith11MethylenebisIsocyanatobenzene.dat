/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-propanediol, polymer with 1,1'-methylenebis(isocyanatobenzene)  (C18H22N2O4, CAS 9077-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12PropanediolPolymerWith11MethylenebisIsocyanatobenzene;
formula     C18H22N2O4;
CAS         9077-17-2;
InChIKey    RUEUBUWQEKTOKN-UHFFFAOYSA-N;
MW          330.384;      // g/mol [origin=calculated method=formula-sum]
Tc          1194.16;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       1.6118;      // -   [origin=predictive method=lee-kesler]
Tb          966.32;      // K   [origin=predictive method=joback]
HvapTb      107714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group C; count 2; } { group CH=CH; count 4; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCd; count 2; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 8; } { group OH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-isocyanato-5-[(1-isocyanatocyclohexa-2,4-dien-1-yl)methyl]cyclohexa-1,3-diene;propane-1,2-diol" );
