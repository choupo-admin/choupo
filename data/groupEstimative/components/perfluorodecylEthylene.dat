/*--------------------------------*- Choupo -*-----------------------*\
  Component: (perfluorodecyl)ethylene  (C12H3F21, CAS 30389-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perfluorodecylEthylene;
formula     C12H3F21;
CAS         30389-25-4;
InChIKey    UCHSAVGOZUCXHC-UHFFFAOYSA-N;
MW          546.114;      // g/mol [origin=calculated method=formula-sum]
Tc          534.51;      // K   [origin=predictive method=joback]
Pc          10.521;      // bar [origin=predictive method=joback]
omega       0.6956;      // -   [origin=predictive method=lee-kesler]
Tb          423.21;      // K   [origin=predictive method=joback]
HvapTb      11519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.83 2.6296 -0.0027143 9.856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 10; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 21; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,12-henicosakis(fluoranyl)dodec-1-ene" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,12-henicosafluorododec-1-ene" "(n-perfluorodecyl)ethylene" "1h,1h,2h-perfluorododec-1-ene" "(heneicosafluorodecyl)ethylene" "1-dodecene, 3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,12-heneicosafluoro-" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,12-heneicosafluoro-1-dodecene" "3,3,4,4,5,5,6,6,7,7,8,8,9,9,10,10,11,11,12,12,12-henicosafluorododecene" );
gibbsFormation
{
    dHf_298   -4371390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     895.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3924610.0
    phase     gas;
}
