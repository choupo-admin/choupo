/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-phenyl-1,10-phenanthroline  (C18H12N2, CAS 6153-89-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Phenyl110Phenanthroline;
formula     C18H12N2;
CAS         6153-89-5;
InChIKey    QQEQHUHZBMUJET-UHFFFAOYSA-N;
MW          256.308;      // g/mol [origin=calculated method=formula-sum]
Tc          1111.76;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.7989;      // -   [origin=predictive method=lee-kesler]
Tb          820.12;      // K   [origin=predictive method=joback]
HvapTb      77238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.45 1.49712 -0.00117568 3.7e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 12; } { group dC_ring; count 6; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,10-phenanthroline, 5-phenyl-" "1,10-phenanthroline,5-phenyl-" "5-phenyl-1,10-phenanthroline;5-phenylpyridino[3,2-h]quinoline;" );
standardThermochemistry
{
    dHf_298   482990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=673640.0
}
