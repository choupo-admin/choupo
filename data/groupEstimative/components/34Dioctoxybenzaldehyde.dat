/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dioctoxybenzaldehyde  (C23H38O3, CAS 131525-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C23H38O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        34Dioctoxybenzaldehyde;
formula     C23H38O3;
CAS         131525-50-3;
InChIKey    ZOKNJOSLKRWLJI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          362.554;      // g/mol [origin=calculated method=formula-sum]
Tc          968.83;      // K   [origin=predictive method=joback]
Pc          10.306;      // bar [origin=predictive method=joback]
omega       0.8873;      // -   [origin=predictive method=lee-kesler]
Tb          783.74;      // K   [origin=predictive method=joback]
HvapTb      72839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.174 1.87264 -0.00105552 2.253e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-bis(octyloxy)benzaldehyde" "3',4'-(dioctyloxy)benzaldehyde" );
gibbsFormation
{
    dHf_298   -492450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1036.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69890.0
    phase     gas;
}
