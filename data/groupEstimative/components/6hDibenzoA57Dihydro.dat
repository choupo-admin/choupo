/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6h-dibenzo[a, 5,7-dihydro-  (C15H12O, CAS 1139-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6hDibenzoA57Dihydro;
formula     C15H12O;
CAS         1139-82-8;
InChIKey    YGWVVRDRBWXLNX-UHFFFAOYSA-N;
MW          208.26;      // g/mol [origin=calculated method=formula-sum]
Tc          952.01;      // K   [origin=predictive method=joback]
Pc          29.926;      // bar [origin=predictive method=joback]
omega       0.6295;      // -   [origin=predictive method=lee-kesler]
Tb          685.35;      // K   [origin=predictive method=joback]
HvapTb      59329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.71 1.1611 -0.00075212 1.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,7-dihydrodibenzo[1,2-a:1',2'-d][7]annulen-6-one" "6h-dibenzo(a,c)cyclohepten-6-one, 5,7-dihydro-" "5,7-dihydro-6h-dibenzo[a,c]cyclohepten-6-one" "5,7-dihydro-6h-dibenzo[a,c][7]annulen-6-one" );
gibbsFormation
{
    dHf_298   52630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=226850.0
    phase     gas;
}
