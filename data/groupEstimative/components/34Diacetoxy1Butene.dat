/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-diacetoxy-1-butene  (C8H12O4, CAS 18085-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Diacetoxy1Butene;
formula     C8H12O4;
CAS         18085-02-4;
InChIKey    MWWXARALRVYLAE-UHFFFAOYSA-N;
MW          172.18;      // g/mol [origin=calculated method=formula-sum]
Tc          680.72;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.6454;      // -   [origin=predictive method=lee-kesler]
Tb          495.32;      // K   [origin=predictive method=joback]
HvapTb      47158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.761 0.64014 -0.0002483 -1.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-acetyloxybut-3-enyl ethanoate" "diacetoxybutene" "dacb" "3-butene-1,2-diol diacetate" "1-butene-3,4-diol diacetate" "1-butene-3,4-diyl diacetate" "but-3-ene-1,2-diyl diacetate" "1,2-diacetoxy-3-butene" "2-acetyloxybut-3-enyl acetate" "3-butene-1,2-diol 1,2-diacetate" "3-butene-1,2-diol,1,2-diacetate" "3-butene-1,2-diol, 1,2-diacetate" );
gibbsFormation
{
    dHf_298   -722860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-518860.0
    phase     gas;
}
