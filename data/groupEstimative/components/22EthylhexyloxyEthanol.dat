/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-ethylhexyloxy)ethanol  (C10H22O2, CAS 1559-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22EthylhexyloxyEthanol;
formula     C10H22O2;
CAS         1559-35-9;
InChIKey    OHJYHAOODFPJOD-UHFFFAOYSA-N;
MW          174.284;      // g/mol [origin=calculated method=formula-sum]
Tc          703.97;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       0.9988;      // -   [origin=predictive method=lee-kesler]
Tb          542.56;      // K   [origin=predictive method=joback]
HvapTb      56555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.907 0.93054 -0.0004428 6.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-ethylhexoxy)ethanol" "eeh solvent" "ethanol, 2-[(2-ethylhexyl)oxy]-" "ethylene glycol, mono(2-ethylhexyl) ether" "2-((2-ethylhexyl)oxy)ethanol" "ethanol, 2-((ethylhexyl)oxy)-" "ethylene glycol 2-ethylhexyl ether" "ethanol, 2-((2-ethylhexyl)oxy)-" "2-(2-ethylhexyl-oxy)ethanol" "polyethylene glycol mono(2-ethylhexyl) ether" "poly(oxy-1,2-ethanediyl), alpha-(2-ethylhexyl)-omega-hydroxy-" );
standardThermochemistry
{
    dHf_298   -539460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210940.0
}
