/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran, 2-(8-dodecynyloxy)tetrahydro-  (C17H30O2, CAS 64604-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran28DodecynyloxyTetrahydro;
formula     C17H30O2;
CAS         64604-68-8;
InChIKey    JXPUZAOSDJTBBV-UHFFFAOYSA-N;
MW          266.425;      // g/mol [origin=calculated method=formula-sum]
Tc          865.15;      // K   [origin=predictive method=joback]
Pc          15.860;      // bar [origin=predictive method=joback]
omega       0.7540;      // -   [origin=predictive method=lee-kesler]
Tb          666.48;      // K   [origin=predictive method=joback]
HvapTb      62937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.791 1.52492 -0.00076496 1.1618e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group tC; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dodec-8-ynoxyoxane" "2-(dodec-8-yn-1-yloxy)tetrahydro-2h-pyran" "2h-pyran, 2-(8-dodecyn-1-yloxy)tetrahydro-" "tetrahydropyran-2-ol ether of 8-dodecynol" );
standardThermochemistry
{
    dHf_298   -331810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     719.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128390.0
}
