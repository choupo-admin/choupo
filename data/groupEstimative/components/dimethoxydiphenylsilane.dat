/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethoxydiphenylsilane  (C14H16O2Si, CAS 6843-66-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H16O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethoxydiphenylsilane;
formula     C14H16O2Si;
CAS         6843-66-9;
InChIKey    AHUXYBVKTIBBJW-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          244.365;      // g/mol [origin=calculated method=formula-sum]
Tc          859.68;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.5218;      // -   [origin=predictive method=lee-kesler]
Tb          619.52;      // K   [origin=predictive method=joback]
HvapTb      56424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.17 0.84344 -0.0001634 -1.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH3O; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethoxy(diphenyl)silane" "diphenyldimethoxysilane" "silane, dimethoxydiphenyl-" "benzene, 1,1'-(dimethoxysilylene)bis-" "dimethoxy-di(phenyl)silane" "ahuxybvktibbjw-uhfffaoysa-" "p123" );
gibbsFormation
{
    dHf_298   -235290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     637.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22940.0
    phase     gas;
}
