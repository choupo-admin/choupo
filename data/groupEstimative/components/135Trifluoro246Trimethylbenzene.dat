/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-trifluoro-2,4,6-trimethylbenzene  (C9H9F3, CAS 363-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Trifluoro246Trimethylbenzene;
formula     C9H9F3;
CAS         363-64-4;
InChIKey    AWOTVEDDCKYHRO-UHFFFAOYSA-N;
MW          174.165;      // g/mol [origin=calculated method=formula-sum]
Tc          637.40;      // K   [origin=predictive method=joback]
Pc          26.004;      // bar [origin=predictive method=joback]
omega       0.5111;      // -   [origin=predictive method=lee-kesler]
Tb          454.91;      // K   [origin=predictive method=joback]
HvapTb      38763.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.57 0.51786 -0.000211 1.37e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH3; count 3; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dC_ring; count 6; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(fluoranyl)-2,4,6-trimethyl-benzene" "benzene, 1,3,5-trifluoro-2,4,6-trimethyl-" "benzene,1,3,5-trifluoro-2,4,6-trimethyl-" "2,4,6-trifluoro-1,3,5-trimethylbenzene" );
standardThermochemistry
{
    dHf_298   -638240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-495270.0
}
