/*--------------------------------*- Choupo -*-----------------------*\
  Component: coniferaldehyde  (C10H10O3, CAS 458-36-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coniferaldehyde;
formula     C10H10O3;
CAS         458-36-6;
InChIKey    DKZBBWMURDFHNE-NSCUHMNNSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          844.94;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.8454;      // -   [origin=predictive method=lee-kesler]
Tb          615.92;      // K   [origin=predictive method=joback]
HvapTb      62894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.01 0.90132 -0.00070652 2.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CHO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-(3-methoxy-4-oxidanyl-phenyl)prop-2-enal" "coniferyl aldehyde" "4-hydroxy-3-methoxycinnamaldehyde" "ferulaldehyde" "coniferylaldehyde" "3-(4-hydroxy-3-methoxyphenyl)prop-2-enal" "2-propenal, 3-(4-hydroxy-3-methoxyphenyl), (e)-" "2-propenal, 3-(4-hydroxy-3-methoxyphenyl)-" "trans-coniferyl aldehyde" "ferulyl aldehyde" "ferulic aldehyde" "p-coniferaldehyde" );
gibbsFormation
{
    dHf_298   -302560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142820.0
    phase     gas;
}
