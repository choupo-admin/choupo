/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-methylenebis(3-methylpiperidine)  (C13H26N2, CAS 68922-17-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Methylenebis3Methylpiperidine;
formula     C13H26N2;
CAS         68922-17-8;
InChIKey    KLFHRQOZJWCFOI-UHFFFAOYSA-N;
MW          210.365;      // g/mol [origin=calculated method=formula-sum]
Tc          758.40;      // K   [origin=predictive method=joback]
Pc          22.461;      // bar [origin=predictive method=joback]
omega       0.5593;      // -   [origin=predictive method=lee-kesler]
Tb          552.48;      // K   [origin=predictive method=joback]
HvapTb      49132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.279 1.75004 -0.0011634 2.973e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1-[(3-methylpiperidin-1-yl)methyl]piperidine" "piperidine, 1,1'-methylenebis[3-methyl-" "piperidine, 1,1'-methylenebis(3-methyl-" "3-methyl-1-[(3-methylpiperidyl)methyl]piperidine" "bis(3-methylpiperidino)methane" "piperidine,1,1'-methylenebis[3-methyl-" "1,1 inverted exclamation marka-methylenebis(3-methylpiperidine)" );
standardThermochemistry
{
    dHf_298   -55630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=353240.0
}
