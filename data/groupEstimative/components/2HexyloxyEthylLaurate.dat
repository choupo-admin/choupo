/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(hexyloxy)ethyl laurate  (C20H40O3, CAS 20207-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HexyloxyEthylLaurate;
formula     C20H40O3;
CAS         20207-36-7;
InChIKey    CYESQOILIGXMLD-UHFFFAOYSA-N;
MW          328.537;      // g/mol [origin=calculated method=formula-sum]
Tc          908.48;      // K   [origin=predictive method=joback]
Pc          10.078;      // bar [origin=predictive method=joback]
omega       0.9109;      // -   [origin=predictive method=lee-kesler]
Tb          737.84;      // K   [origin=predictive method=joback]
HvapTb      69931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.617 1.78584 -0.0008586 1.149e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 15; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexoxyethyl dodecanoate" "dodecanoic acid, 2-(hexyloxy)ethyl ester" "lauric acid, 2-(hexyloxy)ethyl ester" "dodecanoic acid 2-(hexyloxy)ethyl ester" );
gibbsFormation
{
    dHf_298   -905630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     997.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297850.0
    phase     gas;
}
