/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonanoylaziridine  (C11H21NO, CAS 63021-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonanoylaziridine;
formula     C11H21NO;
CAS         63021-51-2;
InChIKey    NBIRNIFJIBJTTI-UHFFFAOYSA-N;
MW          183.295;      // g/mol [origin=calculated method=formula-sum]
Tc          700.97;      // K   [origin=predictive method=joback]
Pc          23.225;      // bar [origin=predictive method=joback]
omega       0.7634;      // -   [origin=predictive method=lee-kesler]
Tb          524.73;      // K   [origin=predictive method=joback]
HvapTb      48919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.503 1.33172 -0.0009905 3.0546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH2_ring; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(aziridin-1-yl)nonan-1-one" "nonanoylethyleneimine" "aziridine, 1-nonanoyl-" "aziridine, 1-(1-oxononyl)-" );
standardThermochemistry
{
    dHf_298   -216120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     559.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104160.0
}
