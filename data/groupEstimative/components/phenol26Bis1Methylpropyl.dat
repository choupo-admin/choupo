/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, 2,6-bis(1-methylpropyl)-  (C14H22O, CAS 5510-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenol26Bis1Methylpropyl;
formula     C14H22O;
CAS         5510-99-6;
InChIKey    FHTGJZOULSYEOB-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          845.02;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.7453;      // -   [origin=predictive method=lee-kesler]
Tb          631.32;      // K   [origin=predictive method=joback]
HvapTb      61934.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.728 1.36188 -0.00096472 2.881e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 3; } { group ACCH; count 2; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-di(butan-2-yl)phenol" "phenol, 2,6-di-sec-butyl-" "2,6-di-sec-butylphenol" "di-sec-butylphenol, mixed isomers" "2,6-di-sec-butyl phenol" "2,6-di-sec-butylfenol" "2,6-bis(methylpropyl)phenol" "phenol,2,6-bis(1-methylpropyl)-" "di-sec-butylphenol,mixture of isomers" "p193" "di-sec-butylphenol, mixture of isomers, predom. 2,6-isomer" "phenol,2,6-di-sec-butyl- (6ci,7ci,8ci); 2,6-di-sec-butylphenol" );
standardThermochemistry
{
    dHf_298   -295100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     596.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10280.0
}
