/*--------------------------------*- Choupo -*-----------------------*\
  Component: buta-1,3-diene;ethenylbenzene;2-hydroxyethyl prop-2-enoate;3-prop-2-enoyloxypropanoic acid  (C23H30O7, CAS 64755-12-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        buta13DieneEthenylbenzene2HydroxyethylProp2Enoate3Prop2Enoyl;
formula     C23H30O7;
CAS         64755-12-0;
InChIKey    UJYQBCJXOHRJPN-UHFFFAOYSA-N;
MW          418.486;      // g/mol [origin=calculated method=formula-sum]
Tc          1340.25;      // K   [origin=predictive method=joback]
Pc          11.429;      // bar [origin=predictive method=joback]
omega       1.0846;      // -   [origin=predictive method=lee-kesler]
Tb          1094.25;      // K   [origin=predictive method=joback]
HvapTb      115257.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (116.284 1.3665 -4.25e-05 -3.53e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2=CH; count 5; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 5; } { group dCH; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-carboxyethyl ester, polymer with 1,3-butadiene, ethenylbenzene and 2-hydroxyethyl 2-propenoate" "2-propenoic acid, 2-carboxyethyl ester, polymer with 1,3-butadiene,ethenylbenzene and 2-hydroxyethyl 2-propenoate" );
gibbsFormation
{
    dHf_298   -1126290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1452.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-721360.0
    phase     gas;
}
