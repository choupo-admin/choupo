/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl isopropylmethylmalonate  (C11H20O4, CAS 58447-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylIsopropylmethylmalonate;
formula     C11H20O4;
CAS         58447-69-1;
InChIKey    NQSVPQIOJRYMGQ-UHFFFAOYSA-N;
MW          216.277;      // g/mol [origin=calculated method=formula-sum]
Tc          750.23;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       0.7080;      // -   [origin=predictive method=lee-kesler]
Tb          564.05;      // K   [origin=predictive method=joback]
HvapTb      53210.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.552 1.071 -0.0005604 7.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-methyl-2-propan-2-yl-propanedioate" "diethyl methyl-isopropylmalonate" "diethyl methylisopropylmalonate" "diethyl methyl-iso-propylmalonate" "diethyl 2-methyl-2-propan-2-ylpropanedioate" "diethyl 2-methyl-2-(methylethyl)propane-1,3-dioate" "2-methyl-2-propan-2-ylpropanedioic acid diethyl ester" "propanedioic acid,2-methyl-2-(1-methylethyl)-, 1,3-diethyl ester" "diethyl isopropyl(methyl)malonate;diethyl methyl(1-methylethyl)propanedioate;diethyl methylisopropylmalonate;" );
gibbsFormation
{
    dHf_298   -918960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     638.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-578600.0
    phase     gas;
}
