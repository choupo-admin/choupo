/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl phthalyl ethyl glycolate  (C14H16O6, CAS 84-72-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylPhthalylEthylGlycolate;
formula     C14H16O6;
CAS         84-72-0;
InChIKey    PZBLUWVMZMXIKZ-UHFFFAOYSA-N;
MW          280.276;      // g/mol [origin=calculated method=formula-sum]
Tc          931.10;      // K   [origin=predictive method=joback]
Pc          20.091;      // bar [origin=predictive method=joback]
omega       1.0292;      // -   [origin=predictive method=lee-kesler]
Tb          726.24;      // K   [origin=predictive method=joback]
HvapTb      71917.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.783 1.03104 -0.00041816 -1.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH2COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-(2-ethoxy-2-oxidanylidene-ethyl) o1-ethyl benzene-1,2-dicarboxylate" "ethoxycarbonylmethyl ethyl phthalate" "santicizer e-15" "phthalic acid, ethyl ester, ester with ethyl glycolate" "carbethoxymethyl ethyl phthalate" "1,2-benzenedicarboxylic acid, 2-ethoxy-2-oxoethyl ethyl ester" "diethyl o-carboxybenzoyloxyacetate" "ethylphthalyl ethylglycolate(epeg)" "ethyl carbethoxymethyl phthalate" "1,2-benzenedicarboxylic acid, 2-ethoxy-2-oxoethyl-, ethyl ester" "ethyl 2-[2-(ethoxycarbonyl)phenylcarbonyloxy]acetate" "ethylphthalyl ethylglycolate" );
gibbsFormation
{
    dHf_298   -1059070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     742.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-761330.0
    phase     gas;
}
