/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-(2,2,3-trimethylcyclopent-3-en-1-yl)hex-4-en-3-ol  (C14H24O, CAS 67801-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6223Trimethylcyclopent3En1YlHex4En3Ol;
formula     C14H24O;
CAS         67801-12-1;
InChIKey    RHQDMXYIGACKOH-UHFFFAOYSA-N;
MW          208.345;      // g/mol [origin=calculated method=formula-sum]
Tc          822.40;      // K   [origin=predictive method=joback]
Pc          20.718;      // bar [origin=predictive method=joback]
omega       0.8925;      // -   [origin=predictive method=lee-kesler]
Tb          630.81;      // K   [origin=predictive method=joback]
HvapTb      62758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.868 1.67538 -0.00138004 5.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -270890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     669.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51640.0
    phase     gas;
}
