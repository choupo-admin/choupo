/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzeneacetic acid, (1s,5r)-2-methyl-5-(1-methylethenyl)-2-cyclohexen-1-yl ester  (C18H24O2, CAS 74431-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneaceticAcid1s5r2Methyl51Methylethenyl2Cyclohexen1YlEst;
formula     C18H24O2;
CAS         74431-25-7;
InChIKey    YEABMHFAQMWROG-HYVNUMGLSA-N;
MW          272.388;      // g/mol [origin=calculated method=formula-sum]
Tc          927.53;      // K   [origin=predictive method=joback]
Pc          17.019;      // bar [origin=predictive method=joback]
omega       0.6726;      // -   [origin=predictive method=lee-kesler]
Tb          703.11;      // K   [origin=predictive method=joback]
HvapTb      64566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.379 1.62914 -0.0008874 1.438e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 3; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1r,2r,5s)-2-methyl-5-prop-1-en-2-yl-cyclohexyl] 2-phenylethanoate" "[(1r,2r,5s)-2-methyl-5-prop-1-en-2-ylcyclohexyl] 2-phenylacetate" );
standardThermochemistry
{
    dHf_298   -366320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8960.0
}
