/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentylphenyl 3-chloro-4-hydroxybenzoate  (C18H19ClO3, CAS 50687-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentylphenyl3Chloro4Hydroxybenzoate;
formula     C18H19ClO3;
CAS         50687-70-2;
InChIKey    MBWAFEFPEJYWGU-UHFFFAOYSA-N;
MW          318.797;      // g/mol [origin=calculated method=formula-sum]
Tc          1085.59;      // K   [origin=predictive method=joback]
Pc          20.718;      // bar [origin=predictive method=joback]
omega       1.1033;      // -   [origin=predictive method=lee-kesler]
Tb          851.03;      // K   [origin=predictive method=joback]
HvapTb      86344.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.306 1.54362 -0.00106588 2.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group Cl; count 1; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-pentylphenyl) 3-chloranyl-4-oxidanyl-benzoate" "benzoic acid, 3-chloro-4-hydroxy-, 4-pentylphenyl ester" "(4-pentylphenyl) 3-chloro-4-hydroxybenzoate" "3-chloro-4-hydroxybenzoic acid 4-pentylphenyl ester" );
standardThermochemistry
{
    dHf_298   -475060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170680.0
}
