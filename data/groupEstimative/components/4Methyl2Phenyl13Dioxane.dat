/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-phenyl-1,3-dioxane  (C11H14O2, CAS 774-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Phenyl13Dioxane;
formula     C11H14O2;
CAS         774-44-7;
InChIKey    NJDSRMVYAFOBIZ-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          786.75;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       0.4519;      // -   [origin=predictive method=lee-kesler]
Tb          546.74;      // K   [origin=predictive method=joback]
HvapTb      51496.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.04 1.05952 -0.0006036 1.092e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-4-methyl-1,3-dioxane" "1,3-dioxane, 4-methyl-2-phenyl-" "m-dioxane, 4-methyl-2-phenyl-" "4-methyl-2-phenyl-m-dioxane" "1, 4-methyl-2-phenyl-" "agn-pc-00gj0r" "1,3-dioxane,4-methyl-2-phenyl-" );
standardThermochemistry
{
    dHf_298   -263860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1350.0
}
