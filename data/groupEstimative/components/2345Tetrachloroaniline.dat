/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5-tetrachloroaniline  (C6H3Cl4N, CAS 634-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2345Tetrachloroaniline;
formula     C6H3Cl4N;
CAS         634-83-3;
InChIKey    GBKZRUCVLTWAML-UHFFFAOYSA-N;
MW          230.897;      // g/mol [origin=calculated method=formula-sum]
Tc          860.93;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.6075;      // -   [origin=predictive method=lee-kesler]
Tb          605.73;      // K   [origin=predictive method=joback]
HvapTb      62055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (78.78 0.346 -0.00019064 3.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACNH2; count 1; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5-tetrakis(chloranyl)aniline" "benzenamine, 2,3,4,5-tetrachloro-" "aniline, 2,3,4,5-tetrachloro-" "2,3,4,5-tetrachlorophenylamine" "2,3,4,5-tetrachloroaniline solution" "2,3,4,5-tetrachlorobenzenamine" "gbkzrucvltwaml-uhfffaoysa-" "benzenamine,2,3,5,6-tetrachloro-" );
standardThermochemistry
{
    dHf_298   -5690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92260.0
}
