/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-acetyl-6-methyl-2,3-dihydropyran  (C8H12O2, CAS 28450-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Acetyl6Methyl23Dihydropyran;
formula     C8H12O2;
CAS         28450-02-4;
InChIKey    QIYRGBNUCNZLNY-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          702.91;      // K   [origin=predictive method=joback]
Pc          34.359;      // bar [origin=predictive method=joback]
omega       0.4781;      // -   [origin=predictive method=lee-kesler]
Tb          487.15;      // K   [origin=predictive method=joback]
HvapTb      46041.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.23 0.73944 -0.00038004 5.516e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=C; count 1; } { group CH3CO; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(6-methyl-3,4-dihydro-2h-pyran-2-yl)ethanone" "ethanone, 1-(3,4-dihydro-6-methyl-2h-pyran-2-yl)-" );
standardThermochemistry
{
    dHf_298   -352400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153780.0
}
