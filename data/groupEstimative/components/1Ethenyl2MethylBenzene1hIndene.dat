/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethenyl-2-methyl-benzene;1h-indene  (C18H18, CAS 68110-36-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethenyl2MethylBenzene1hIndene;
formula     C18H18;
CAS         68110-36-1;
InChIKey    DVPDLOVYZYJJCL-UHFFFAOYSA-N;
MW          234.342;      // g/mol [origin=calculated method=formula-sum]
Tc          936.46;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       0.5457;      // -   [origin=predictive method=lee-kesler]
Tb          683.41;      // K   [origin=predictive method=joback]
HvapTb      61676.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.26 1.33222 -0.0007547 1.361e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "vinyltoluene, indene resin" "1h-indene, polymer with ethenylmethylbenzene" "1-ethenyl-2-methylbenzene; 1h-indene" );
standardThermochemistry
{
    dHf_298   200000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=387740.0
}
