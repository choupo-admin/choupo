/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,4-dinonyl-  (C24H42, CAS 40775-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene14Dinonyl;
formula     C24H42;
CAS         40775-34-6;
InChIKey    SHDYOAGCPLZUNG-UHFFFAOYSA-N;
MW          330.6;      // g/mol [origin=calculated method=formula-sum]
Tc          965.08;      // K   [origin=predictive method=joback]
Pc          9.729;      // bar [origin=predictive method=joback]
omega       0.8333;      // -   [origin=predictive method=lee-kesler]
Tb          780.38;      // K   [origin=predictive method=joback]
HvapTb      71956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.534 2.14544 -0.00124596 2.75e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group ACH; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-di(nonyl)benzene" "agn-pc-00l5ky" );
gibbsFormation
{
    dHf_298   -313630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     978.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=253980.0
    phase     gas;
}
