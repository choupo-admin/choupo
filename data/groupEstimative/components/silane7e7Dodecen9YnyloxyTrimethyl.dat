/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, [(7e)-7-dodecen-9-ynyloxy]trimethyl-  (C15H28OSi, CAS 58763-69-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C15H28OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silane7e7Dodecen9YnyloxyTrimethyl;
formula     C15H28OSi;
CAS         58763-69-2;
InChIKey    BSFTXFASOLZMHG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          252.473;      // g/mol [origin=calculated method=formula-sum]
Tc          767.21;      // K   [origin=predictive method=joback]
Pc          14.988;      // bar [origin=predictive method=joback]
omega       0.5728;      // -   [origin=predictive method=lee-kesler]
Tb          579.78;      // K   [origin=predictive method=joback]
HvapTb      53798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.947 1.02968 -0.00025806 -7.832e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH=CH; count 1; } { group CH2O; count 1; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group dCH; count 2; } { group tC; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-7-en-9-ynoxy(trimethyl)silane" "silane, [(7e)-7-dodecen-9-yn-1-yloxy]trimethyl-" );
standardThermochemistry
{
    dHf_298   -207250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     843.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148680.0
}
