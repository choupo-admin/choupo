/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenamide, n-[2-(2-hydroxyethoxy)ethyl]-, (9z)-  (C22H43NO3, CAS 20429-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenamideN22HydroxyethoxyEthyl9z;
formula     C22H43NO3;
CAS         20429-33-8;
InChIKey    ULHGTPIJYDGNHZ-UHFFFAOYSA-N;
MW          369.59;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.76;      // K   [origin=predictive method=joback]
Pc          10.227;      // bar [origin=predictive method=joback]
omega       0.9444;      // -   [origin=predictive method=lee-kesler]
Tb          925.76;      // K   [origin=predictive method=joback]
HvapTb      96795.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.648 2.13282 -0.0012061 2.5446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH=CH; count 1; } { group CONHCH2; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH; count 2; } { group OH; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(2-hydroxyethyloxy)ethyl]octadec-9-enamide" );
standardThermochemistry
{
    dHf_298   -723750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1135.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66770.0
}
