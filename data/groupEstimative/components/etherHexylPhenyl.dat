/*--------------------------------*- Choupo -*-----------------------*\
  Component: ether, hexyl phenyl  (C12H18O, CAS 1132-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        etherHexylPhenyl;
formula     C12H18O;
CAS         1132-66-7;
InChIKey    KNRQFACTBMDELK-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          721.02;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.5625;      // -   [origin=predictive method=lee-kesler]
Tb          523.26;      // K   [origin=predictive method=joback]
HvapTb      46992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.425 1.00172 -0.0005492 1.023e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexoxybenzene" "benzene, (hexyloxy)-" "hexylphenyl ether" );
standardThermochemistry
{
    dHf_298   -186700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57570.0
}
