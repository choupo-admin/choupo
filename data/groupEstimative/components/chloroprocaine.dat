/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroprocaine  (C13H19ClN2O2, CAS 133-16-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloroprocaine;
formula     C13H19ClN2O2;
CAS         133-16-4;
InChIKey    VDANGULDQQJODZ-UHFFFAOYSA-N;
MW          270.757;      // g/mol [origin=calculated method=formula-sum]
Tc          925.12;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       0.9864;      // -   [origin=predictive method=lee-kesler]
Tb          714.30;      // K   [origin=predictive method=joback]
HvapTb      72608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.864 1.17874 -0.00066232 1.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 3; } { group AC; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 4-azanyl-2-chloranyl-benzoate" "chloroprocain" "2-chloroprocaine" "halestyn" "piocaine" "chlor-procaine" "nesacaine" "chloroprocainum" "chlorprocaine" "chlorprocainum" "cloroprocaina" "nesacaine-ce" );
standardThermochemistry
{
    dHf_298   -329760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6660.0
}
