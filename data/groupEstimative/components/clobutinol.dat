/*--------------------------------*- Choupo -*-----------------------*\
  Component: clobutinol  (C14H22ClNO, CAS 14860-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        clobutinol;
formula     C14H22ClNO;
CAS         14860-49-2;
InChIKey    KVHHQGIIZCJATJ-UHFFFAOYSA-N;
MW          255.786;      // g/mol [origin=calculated method=formula-sum]
Tc          889.26;      // K   [origin=predictive method=joback]
Pc          21.315;      // bar [origin=predictive method=joback]
omega       1.0181;      // -   [origin=predictive method=lee-kesler]
Tb          689.96;      // K   [origin=predictive method=joback]
HvapTb      71119.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.108 1.49188 -0.00104036 2.836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)-4-(dimethylamino)-2,3-dimethyl-butan-2-ol" "clobutinolum [inn-latin]" "clobutinol (inn)" "clobutinol [inn]" "clobutinol hcl" "4-chloro-alpha(2-(dimethylamino)-1-methylethyl)alpha-methylbenzeneethanol" "1-(4-chlorophenyl)-2,3-dimethyl-4-dimethylamino-2-butanol" "1-(4-chlorophenyl)-4-(dimethylamino)-2,3-dimethylbutan-2-ol" "benzeneethanol, 4-chloro-alpha-(2-(dimethylamino)-1-methyl)-alpha-methyl-" "p-chloro-alpha-(2-(dimethylamino)-1-methylethyl)-alpha-methylphenethyl alcohol" "p-chloro-alpha-(2-(dimethylamino)-1-methylethyl)-alpha-methyl-phenethyl alcohol" "phenethyl alcohol, p-chloro-alpha-(2-(dimethylamino)-1-methylethyl)-alpha-methyl-" );
gibbsFormation
{
    dHf_298   -221700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132210.0
    phase     gas;
}
