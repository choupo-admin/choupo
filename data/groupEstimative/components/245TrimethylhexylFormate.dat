/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,5-trimethylhexyl formate  (C10H20O2, CAS 54140-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H20O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        245TrimethylhexylFormate;
formula     C10H20O2;
CAS         54140-17-9;
InChIKey    MXGQOAGPWCOKJN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          574.94;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       0.3447;      // -   [origin=predictive method=lee-kesler]
Tb          403.50;      // K   [origin=predictive method=joback]
HvapTb      34317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.748 0.97968 -0.0006828 2.03e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,5-trimethylhexyl methanoate" "1-hexanol, trimethyl-, formate" "1-hexanol, trimethyl-, 1-formate" "trimethylhexyl formate" );
standardThermochemistry
{
    dHf_298   -189120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69960.0
}
