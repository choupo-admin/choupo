/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethyl-3-octen  (C10H20, CAS 53966-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethyl3Octen;
formula     C10H20;
CAS         53966-51-1;
InChIKey    NOBLDEYGTBPLMF-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          605.91;      // K   [origin=predictive method=joback]
Pc          22.229;      // bar [origin=predictive method=joback]
omega       0.4374;      // -   [origin=predictive method=lee-kesler]
Tb          432.44;      // K   [origin=predictive method=joback]
HvapTb      37892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.075 0.97376 -0.0006063 1.57e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethyloct-3-ene" "agn-pc-02v0f3" );
standardThermochemistry
{
    dHf_298   -142300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104990.0
}
