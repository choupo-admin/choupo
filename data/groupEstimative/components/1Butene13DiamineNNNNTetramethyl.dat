/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butene-1,3-diamine, n,n,n',n'-tetramethyl-  (C8H18N2, CAS 17336-84-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butene13DiamineNNNNTetramethyl;
formula     C8H18N2;
CAS         17336-84-4;
InChIKey    DOJGJJJBWVDGTJ-UHFFFAOYSA-N;
MW          142.246;      // g/mol [origin=calculated method=formula-sum]
Tc          584.22;      // K   [origin=predictive method=joback]
Pc          26.846;      // bar [origin=predictive method=joback]
omega       0.4514;      // -   [origin=predictive method=lee-kesler]
Tb          411.24;      // K   [origin=predictive method=joback]
HvapTb      37058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.63 1.0376 -0.0007236 2.057e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group dCH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n3,n3-tetramethylbut-1-ene-1,3-diamine" "1-butene-1,3-diamine, n1,n1,n3,n3-tetramethyl-" "n,n,n',n'-tetramethyl-1-butene-1,3-diamine" "1-n,1-n,3-n,3-n-tetramethylbut-1-ene-1,3-diamine" );
gibbsFormation
{
    dHf_298   38550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=315820.0
    phase     gas;
}
