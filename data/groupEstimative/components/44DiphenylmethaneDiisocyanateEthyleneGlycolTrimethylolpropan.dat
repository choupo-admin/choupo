/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diphenylmethane diisocyanate, ethylene glycol, trimethylolpropane polymer  (C23H30N2O7, CAS 72231-00-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44DiphenylmethaneDiisocyanateEthyleneGlycolTrimethylolpropan;
formula     C23H30N2O7;
CAS         72231-00-6;
InChIKey    RKZRYHWGCABWKL-UHFFFAOYSA-N;
MW          446.5;      // g/mol [origin=calculated method=formula-sum]
Tc          1831.86;      // K   [origin=predictive method=joback]
Pc          18.216;      // bar [origin=predictive method=joback]
omega       0.6835;      // -   [origin=predictive method=lee-kesler]
Tb          1382.97;      // K   [origin=predictive method=joback]
HvapTb      174419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group OH; count 3; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group C; count 1; } { group dCd; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 5; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;2-ethyl-2-(hydroxymethyl)propane-1,3-diol;1-isocyanato-4-[(4-isocyanatophenyl)methyl]benzene" "1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-, polymer with 1,2-ethanediol and 1,1'-methylenebis(4-isocyanatobenzene)" );
