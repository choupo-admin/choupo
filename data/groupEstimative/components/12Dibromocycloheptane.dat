/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromocycloheptane  (C7H12Br2, CAS 29974-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromocycloheptane;
formula     C7H12Br2;
CAS         29974-68-3;
InChIKey    PQKOJNVKGNOTKZ-UHFFFAOYSA-N;
MW          255.981;      // g/mol [origin=calculated method=formula-sum]
Tc          761.59;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.3999;      // -   [origin=predictive method=lee-kesler]
Tb          511.23;      // K   [origin=predictive method=joback]
HvapTb      44338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.88 0.8312 -0.000479 9.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)cycloheptane" "trans-1,2-dibromocycloheptane" "cycloheptane, 1,2-dibromo-" "cycloheptane, trans-1,2-dibromo-," );
standardThermochemistry
{
    dHf_298   -107330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41340.0
}
