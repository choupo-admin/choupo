/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1h-phenalene, 2,3-dihydro, 1,3-methano-  (C14H12, CAS 30736-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1hPhenalene23Dihydro13Methano;
formula     C14H12;
CAS         30736-77-7;
InChIKey    VDRBUVNLLKKVPW-UHFFFAOYSA-N;
MW          180.25;      // g/mol [origin=calculated method=formula-sum]
Tc          821.30;      // K   [origin=predictive method=joback]
Pc          30.659;      // bar [origin=predictive method=joback]
omega       0.5327;      // -   [origin=predictive method=lee-kesler]
Tb          580.48;      // K   [origin=predictive method=joback]
HvapTb      51480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.83 1.4532 -0.00130484 4.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 6; } { group AC; count 2; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-1,3-methanophenalene" );
gibbsFormation
{
    dHf_298   230290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     253.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=412500.0
    phase     gas;
}
