/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-hydroxyphenyl)propanoic acid  (C9H10O3, CAS 938-96-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24HydroxyphenylPropanoicAcid;
formula     C9H10O3;
CAS         938-96-5;
InChIKey    ZHMMPVANGNPCBW-UHFFFAOYSA-N;
MW          166.176;      // g/mol [origin=calculated method=formula-sum]
Tc          896.12;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       0.9668;      // -   [origin=predictive method=lee-kesler]
Tb          657.89;      // K   [origin=predictive method=joback]
HvapTb      67694.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.2 0.99122 -0.00082916 2.82e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-hydroxyphenyl)propionic acid" "4-hydroxyhydratropic acid" "4-hydroxyhydratropate" "zhmmpvangnpcbw-uhfffaoysa-" "(4-hydroxyphenyl)(methyl)acetic acid" );
gibbsFormation
{
    dHf_298   -525420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363660.0
    phase     gas;
}
