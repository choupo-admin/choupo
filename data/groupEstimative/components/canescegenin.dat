/*--------------------------------*- Choupo -*-----------------------*\
  Component: canescegenin  (C23H32O7, CAS 6785-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        canescegenin;
formula     C23H32O7;
CAS         6785-70-2;
InChIKey    KKEVCQDNOHUAOZ-QBAFWMPPSA-N;
MW          420.502;      // g/mol [origin=calculated method=formula-sum]
Tc          1542.21;      // K   [origin=predictive method=joback]
Pc          21.938;      // bar [origin=predictive method=joback]
omega       1.4843;      // -   [origin=predictive method=lee-kesler]
Tb          1242.91;      // K   [origin=predictive method=joback]
HvapTb      143174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-390.99 3.89712 -0.00394544 1.648e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 5; } { group C; count 4; } { group CH=C; count 1; } { group OH; count 4; } { group CHO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 5; } { group C_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 4; } { group OdCH_al; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,5s,8r,10r,13s,14s)-10-methyl-3,5,11,14-tetrakis(oxidanyl)-17-(5-oxidanylidene-2h-furan-3-yl)-2,3,4,6,7,8,9,11,12,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene-13-carbaldehyde" "canescegenine" "nigrescigenin" "sarmentosigenin a" "sarmentosigenin a (6ci)" "5-beta-card-20(22)-enolide, 3-beta,5,11-alpha,14-tetrahydroxy-19-oxo-" "5-beta-card-20(22)-enolide, 3-beta,5,11-alpha,14-tetrahydroxy-19-oxo- (8ci)" "card-20(22)-enolide, 3,5,11,14-tetrahydroxy-19-oxo-, (3-beta,5-beta,11-alpha)-" "card-20(22)-enolide, 3,5,11,14-tetrahydroxy-19-oxo-, (3-beta,5-beta,11-alpha)- (9ci)" "(3s,5s,8r,10r,13s,14s)-3,5,11,14-tetrahydroxy-10-methyl-17-(5-oxo-2h-furan-3-yl)-2,3,4,6,7,8,9,11,12,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene-13-carbaldehyde" );
standardThermochemistry
{
    dHf_298   -1170720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1038.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-603610.0
}
