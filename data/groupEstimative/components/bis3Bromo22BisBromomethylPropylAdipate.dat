/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis[3-bromo-2,2-bis(bromomethyl)propyl] adipate  (C16H24Br6O4, CAS 54473-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis3Bromo22BisBromomethylPropylAdipate;
formula     C16H24Br6O4;
CAS         54473-70-0;
InChIKey    OGVCMSQSAJXIJQ-UHFFFAOYSA-N;
MW          759.788;      // g/mol [origin=calculated method=formula-sum]
Tc          1320.29;      // K   [origin=predictive method=joback]
Pc          19.036;      // bar [origin=predictive method=joback]
omega       1.4750;      // -   [origin=predictive method=lee-kesler]
Tb          1072.62;      // K   [origin=predictive method=joback]
HvapTb      102042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.362 1.895 -0.0014294 4.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group C; count 2; } { group CH2COO; count 2; } { group Br; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 12; } { group C; count 2; } { group Br; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[3-bromanyl-2,2-bis(bromomethyl)propyl] hexanedioate" "bis[3-bromo-2,2-bis(bromomethyl)propyl] hexanedioate" "hexanedioic acid, bis(3-bromo-2,2-bis(bromomethyl)propyl) ester" "hexanedioic acid, bis[3-bromo-2,2-bis(bromomethyl)propyl] ester" "hexanedioic acid, 1,6-bis(3-bromo-2,2-bis(bromomethyl)propyl) ester" "hexanedioic acid, 1,6-bis[3-bromo-2,2-bis(bromomethyl)propyl] ester" "hexanedioic acid, bis(2,2,2-tris(bromomethyl)ethyl) ester" "hexanedioic acid bis[3-bromo-2,2-bis(bromomethyl)propyl] ester" );
gibbsFormation
{
    dHf_298   -867650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1110.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-445300.0
    phase     gas;
}
