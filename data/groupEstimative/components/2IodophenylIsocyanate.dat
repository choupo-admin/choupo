/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-iodophenyl isocyanate  (C7H4INO, CAS 128255-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2IodophenylIsocyanate;
formula     C7H4INO;
CAS         128255-31-2;
InChIKey    VVNMGFXOVZRKQF-UHFFFAOYSA-N;
MW          245.015;      // g/mol [origin=calculated method=formula-sum]
Tc          812.43;      // K   [origin=predictive method=joback]
Pc          43.169;      // bar [origin=predictive method=joback]
omega       0.4652;      // -   [origin=predictive method=lee-kesler]
Tb          551.23;      // K   [origin=predictive method=joback]
HvapTb      53019.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-2-isocyanato-benzene" "1-iodo-2-isocyanatobenzene" "benzene,1-iodo-2-isocyanato-" "1-iodo-2-isocyanatobenzene;2-iodophenylisocyanate; o-iodophenyl isocyanate" );
