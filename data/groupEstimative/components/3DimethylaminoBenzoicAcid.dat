/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(dimethylamino)benzoic acid  (C9H11NO2, CAS 99-64-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3DimethylaminoBenzoicAcid;
formula     C9H11NO2;
CAS         99-64-9;
InChIKey    NEGFNJRAUMCZMY-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          816.75;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.7954;      // -   [origin=predictive method=lee-kesler]
Tb          595.13;      // K   [origin=predictive method=joback]
HvapTb      57773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.99 0.89514 -0.00061516 1.619e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-dimethylaminobenzoic acid" "benzoic acid, 3-(dimethylamino)-" "m-(dimethylamino)benzoic acid" "m-(dimethylamino)-benzoic acid" "n,n-dimethyl-m-aminobenzoic acid" "m-dimethylaminobenzoic acid" "benzoic acid, m-(dimethylamino)-" "3-dimethylamino benzoic acid" "3-dimethylamino-benzoic acid" "benzoic acid, m-(dimethylamino)- (8ci)" "o783" );
gibbsFormation
{
    dHf_298   -286770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105450.0
    phase     gas;
}
