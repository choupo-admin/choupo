/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octyl-1,2,3,4-tetrahydronaphthalene  (C18H28, CAS 29138-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octyl1234Tetrahydronaphthalene;
formula     C18H28;
CAS         29138-91-8;
InChIKey    LZSIUCCRELNUIP-UHFFFAOYSA-N;
MW          244.422;      // g/mol [origin=calculated method=formula-sum]
Tc          857.57;      // K   [origin=predictive method=joback]
Pc          16.325;      // bar [origin=predictive method=joback]
omega       0.6935;      // -   [origin=predictive method=lee-kesler]
Tb          654.11;      // K   [origin=predictive method=joback]
HvapTb      58685.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.443 1.71672 -0.00109336 2.73e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrahydro-1-octylnaphthalene" "naphthalene, 1,2,3,4-tetrahydro-1-octyl-" );
standardThermochemistry
{
    dHf_298   -123150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=252110.0
}
