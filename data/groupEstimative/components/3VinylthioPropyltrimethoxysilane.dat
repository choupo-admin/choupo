/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(vinylthio)propyltrimethoxysilane  (C8H18O3SSi, CAS 63823-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H18O3SSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3VinylthioPropyltrimethoxysilane;
formula     C8H18O3SSi;
CAS         63823-06-3;
InChIKey    XIOWFGAZSNMDKS-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          222.374;      // g/mol [origin=calculated method=formula-sum]
Tc          709.25;      // K   [origin=predictive method=joback]
Pc          22.719;      // bar [origin=predictive method=joback]
omega       0.5662;      // -   [origin=predictive method=lee-kesler]
Tb          516.76;      // K   [origin=predictive method=joback]
HvapTb      47073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (129.543 0.34245 0.0003537 -3.078e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CH3O; count 3; } { group Si; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 3; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethenylsulfanylpropyl(trimethoxy)silane" "3-(trimethoxysilyl)propylvinyl thioether" "silane,[3-(ethenylthio)propyl]trimethoxy-" );
gibbsFormation
{
    dHf_298   -549430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-282320.0
    phase     gas;
}
