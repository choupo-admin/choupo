/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-oxotridecanoic acid  (C13H24O3, CAS 2345-12-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12OxotridecanoicAcid;
formula     C13H24O3;
CAS         2345-12-2;
InChIKey    NRVDTUOVKXZNCW-UHFFFAOYSA-N;
MW          228.332;      // g/mol [origin=calculated method=formula-sum]
Tc          881.03;      // K   [origin=predictive method=joback]
Pc          18.676;      // bar [origin=predictive method=joback]
omega       1.1158;      // -   [origin=predictive method=lee-kesler]
Tb          696.42;      // K   [origin=predictive method=joback]
HvapTb      68442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.03 1.26162 -0.0007373 1.6246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "12-oxidanylidenetridecanoic acid" "12-ketotridecanoic acid" "tridecanoic acid, 12-oxo-" "12-keto tridecanoic acid" "12-oxo-tridecanoic acid" "tridecanoic acid,12-oxo-" );
gibbsFormation
{
    dHf_298   -774500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     742.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-414250.0
    phase     gas;
}
