/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-l-alanine  (C4H9NO2, CAS 3913-67-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethylLAlanine;
formula     C4H9NO2;
CAS         3913-67-5;
InChIKey    GDFAOVXKHJXLEI-VKHMYHEASA-N;
MW          103.121;      // g/mol [origin=calculated method=formula-sum]
Tc          686.59;      // K   [origin=predictive method=joback]
Pc          44.922;      // bar [origin=predictive method=joback]
omega       0.7193;      // -   [origin=predictive method=lee-kesler]
Tb          486.36;      // K   [origin=predictive method=joback]
HvapTb      47710.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.96 0.51674 -0.0003182 7.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH3NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-(methylamino)propanoic acid" "n-methylalanine" "l-alanine, n-methyl-" "n-methyl alanine" "methylalanine, dl-" "n-me-l-ala" "h-n-me-ala-oh" "dl-alanine, n-methyl-" "n-" "a-methyl-l-alanine" "(s)-2-(methylamino)propanoic acid" );
standardThermochemistry
{
    dHf_298   -427970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-274160.0
}
