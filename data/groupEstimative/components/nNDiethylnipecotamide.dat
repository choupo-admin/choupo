/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-diethylnipecotamide  (C10H20N2O, CAS 3367-95-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiethylnipecotamide;
formula     C10H20N2O;
CAS         3367-95-1;
InChIKey    ZXQKYQVJDRTTLZ-UHFFFAOYSA-N;
MW          184.283;      // g/mol [origin=calculated method=formula-sum]
Tc          772.08;      // K   [origin=predictive method=joback]
Pc          28.084;      // bar [origin=predictive method=joback]
omega       0.6782;      // -   [origin=predictive method=lee-kesler]
Tb          562.81;      // K   [origin=predictive method=joback]
HvapTb      53830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.218 1.15844 -0.0006345 1.1286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2NH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylpiperidine-3-carboxamide" "3-piperidinecarboxamide, n,n-diethyl-" "nipecotamide, n,n-diethyl-" "3-(n,n-diethylcarbamoyl)piperidine" "n,n-diethyl-3-piperidylcarboxamide" "n,n-diethylnipecotamide,tech." "n,n-diethyl nipecotamide" "n,n-diethylnipecotamide (tech.)" "3-piperidinecarboxamide,n,n-diethyl-" "nipecotamide,n,n-diethyl- (6ci,7ci,8ci); 3-(diethylcarbamoyl)piperidine;3-(diethylcarboxamido)piperidine; 3-[(diethylamino)carbonyl]piperidine;diethylnipecotamide; n,n-diethyl-3-piperidinecarboxamide;n,n-diethylnipecotamide; piperidine-3-carboxylic acid diethylamide" );
gibbsFormation
{
    dHf_298   -202650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127340.0
    phase     gas;
}
