/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyl octanoate  (C9H17ClO2, CAS 61413-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chloromethylOctanoate;
formula     C9H17ClO2;
CAS         61413-70-5;
InChIKey    JRCUJOMLYAQHDP-UHFFFAOYSA-N;
MW          192.683;      // g/mol [origin=calculated method=formula-sum]
Tc          677.44;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.6573;      // -   [origin=predictive method=lee-kesler]
Tb          501.17;      // K   [origin=predictive method=joback]
HvapTb      47420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.007 0.81082 -0.0003916 4.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2COO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octanoic acid, chloromethyl ester" );
gibbsFormation
{
    dHf_298   -562110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     591.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297400.0
    phase     gas;
}
