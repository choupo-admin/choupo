/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-chloropropyl)triethoxysilane  (C9H21ClO3Si, CAS 5089-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H21ClO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3ChloropropylTriethoxysilane;
formula     C9H21ClO3Si;
CAS         5089-70-3;
InChIKey    KSCAZPYHLGGNPZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          240.799;      // g/mol [origin=calculated method=formula-sum]
Tc          685.71;      // K   [origin=predictive method=joback]
Pc          19.069;      // bar [origin=predictive method=joback]
omega       0.6261;      // -   [origin=predictive method=lee-kesler]
Tb          511.61;      // K   [origin=predictive method=joback]
HvapTb      47537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.916 0.46986 0.0002616 -2.767e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH2O; count 3; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropyl(triethoxy)silane" "3-chloropropyltriethoxysilane" "silane, (3-chloropropyl)triethoxy-" "(3-chloropropyl)(triethoxy)silane" "(chloropropyl)triethoxysilane" "triethoxy(gamma-chloropropyl)silane" "3-(chloropropyl)triethoxysilane" "3-chloropropyl(triethoxy)silane" "gamma-chloropropyltriethoxysilane" "gama-chloropropyl triethoxy silane" "3-(triethoxysilyl)propyl chloride" "triethoxy-(3-chloro-propyl)-silane" );
gibbsFormation
{
    dHf_298   -753110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-406790.0
    phase     gas;
}
