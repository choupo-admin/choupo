/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyloctadecylamine  (C21H45N, CAS 13329-71-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropyloctadecylamine;
formula     C21H45N;
CAS         13329-71-0;
InChIKey    WHFZOMWNDCWQRF-UHFFFAOYSA-N;
MW          311.598;      // g/mol [origin=calculated method=formula-sum]
Tc          899.36;      // K   [origin=predictive method=joback]
Pc          9.687;      // bar [origin=predictive method=joback]
omega       0.8668;      // -   [origin=predictive method=lee-kesler]
Tb          729.81;      // K   [origin=predictive method=joback]
HvapTb      68388.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.093 2.08096 -0.0011704 2.487e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 16; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-propan-2-yloctadecan-1-amine" "1-octadecanamine, n-(1-methylethyl)-" "n-isopropyloctadecylamine" "octadecylamine, n-isopropyl-" "n-(1-methylethyl)-1-octadecanamine" "octadecyl(propan-2-yl)amine" "n-(propan-2-yl)octadecan-1-amine" );
standardThermochemistry
{
    dHf_298   -428580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1005.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212890.0
}
