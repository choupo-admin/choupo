/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,10-dodecadienal, 3,7,11-trimethyl-, (6e)-  (C15H26O, CAS 51513-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        610Dodecadienal3711Trimethyl6e;
formula     C15H26O;
CAS         51513-58-7;
InChIKey    ITBYWGRSPHMAEE-NTEUORMPSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          783.37;      // K   [origin=predictive method=joback]
Pc          16.498;      // bar [origin=predictive method=joback]
omega       0.7209;      // -   [origin=predictive method=lee-kesler]
Tb          599.10;      // K   [origin=predictive method=joback]
HvapTb      55392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.775 1.44908 -0.0009606 2.631e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 2; } { group dC; count 2; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6e)-3,7,11-trimethyldodeca-6,10-dienal" "3,7,11-trimethyl-6e,10-dodecadienal" );
standardThermochemistry
{
    dHf_298   -228930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     727.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116800.0
}
