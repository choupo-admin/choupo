/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-(2-tert-butoxyethoxy)ethoxy]butane  (C12H26O3, CAS 52788-78-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122TertButoxyethoxyEthoxyButane;
formula     C12H26O3;
CAS         52788-78-0;
InChIKey    WQQZDUVVRLTLIJ-UHFFFAOYSA-N;
MW          218.337;      // g/mol [origin=calculated method=formula-sum]
Tc          707.42;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       0.7111;      // -   [origin=predictive method=lee-kesler]
Tb          538.19;      // K   [origin=predictive method=joback]
HvapTb      48240.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.007 1.08008 -0.0004678 3.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group C; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-[2-[(2-methylpropan-2-yl)oxy]ethoxy]ethoxy]butane" "1-[2-[2-(tert-butoxy)ethoxy]ethoxy]butane" "1-(2-(2-(tert-butoxy)ethoxy)ethoxy)butane" "butane, 1-(2-(2-(1,1-dimethylethoxy)ethoxy)ethoxy)-" "butane, 1-[2-[2-(1,1-dimethylethoxy)ethoxy]ethoxy]-" );
gibbsFormation
{
    dHf_298   -696420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-262000.0
    phase     gas;
}
