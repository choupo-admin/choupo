/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanoic acid, ((1-oxododecyl)imino)di-2,1-ethanediyl ester  (C40H77NO5, CAS 2512-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanoicAcid1OxododecylIminoDi21EthanediylEster;
formula     C40H77NO5;
CAS         2512-14-3;
InChIKey    OHGIKYNYMQWJRT-UHFFFAOYSA-N;
MW          652.058;      // g/mol [origin=calculated method=formula-sum]
Tc          1875.50;      // K   [origin=predictive method=joback]
Pc          4.021;      // bar [origin=predictive method=joback]
omega       -0.4200;      // -   [origin=predictive method=lee-kesler]
Tb          1297.55;      // K   [origin=predictive method=joback]
HvapTb      128237.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.014 3.79016 -0.0020569 3.7896e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 30; } { group CH2COO; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 34; } { group CdO; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[dodecanoyl(2-dodecanoyloxyethyl)amino]ethyl dodecanoate" "dodecanoic acid, [(1-oxododecyl)imino]di-2,1-ethanediyl ester" "dodecanoic acid, 1,1'-(((1-oxododecyl)imino)di-2,1-ethanediyl) ester" "dodecanoic acid, 1,1'-[[(1-oxododecyl)imino]di-2,1-ethanediyl] ester" );
gibbsFormation
{
    dHf_298   -1548540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1859.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-352960.0
    phase     gas;
}
