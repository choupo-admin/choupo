/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-adamantanol  (C10H16O, CAS 768-95-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Adamantanol;
formula     C10H16O;
CAS         768-95-6;
InChIKey    VLLNJDMHDJRNFK-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          748.61;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.7454;      // -   [origin=predictive method=lee-kesler]
Tb          540.64;      // K   [origin=predictive method=joback]
HvapTb      52984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-200.81 1.6963 -0.001642 6.554e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "adamantan-1-ol" "1-hydroxyadamantane" "1-adamantol" "tricyclo[3.3.1.1(3,7)]decan-1-ol" "adamantanol" "tricyclo(3.3.1.13,7)decan-1-ol" "tricyclo[3.3.1.1~3,7~]decan-1-ol" "tricyclo[3.3.1.13,7]decan-1-ol" "ambap31878-59-8" "sdccgmls-0066229.p001" "k334" "tricyclo(3.3.1.1(sup 3,7))decan-1-ol" );
standardThermochemistry
{
    dHf_298   -194820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53450.0
}
