/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)butyl benzoate;nonanedioic acid  (C22H34O8, CAS 65970-43-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylButylBenzoateNonanedioicAcid;
formula     C22H34O8;
CAS         65970-43-6;
InChIKey    FWTHSSJZWMAWPG-UHFFFAOYSA-N;
MW          426.506;      // g/mol [origin=calculated method=formula-sum]
Tc          1591.74;      // K   [origin=predictive method=joback]
Pc          13.707;      // bar [origin=predictive method=joback]
omega       0.9065;      // -   [origin=predictive method=lee-kesler]
Tb          1261.41;      // K   [origin=predictive method=joback]
HvapTb      140933.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.521 2.04932 -0.0010726 1.493e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 2; } { group COOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } { group COOH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanedioic acid, polymer with 2-ethyl-2-(hydroxymethyl)-1,3-propanediol, benzoate" "2,2-bis(hydroxymethyl)butyl benzoate; nonanedioic acid" );
gibbsFormation
{
    dHf_298   -1703530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1234.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1126980.0
    phase     gas;
}
