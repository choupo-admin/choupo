/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-1,1-difluoroethane  (C2H3BrF2, CAS 357188-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo11Difluoroethane;
formula     C2H3BrF2;
CAS         357188-74-0;
InChIKey    MGCGGCMKJWCMKL-UHFFFAOYSA-N;
MW          144.946;      // g/mol [origin=calculated method=formula-sum]
Tc          483.08;      // K   [origin=predictive method=joback]
Pc          50.157;      // bar [origin=predictive method=joback]
omega       0.2503;      // -   [origin=predictive method=lee-kesler]
Tb          306.83;      // K   [origin=predictive method=joback]
HvapTb      23551.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.03 0.38142 -0.000361 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group Br; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group F; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-1,1-bis(fluoranyl)ethane" "bromodifluoroethane" "ethane, bromodifluoro-" );
gibbsFormation
{
    dHf_298   -459250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     309.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-406500.0
    phase     gas;
}
