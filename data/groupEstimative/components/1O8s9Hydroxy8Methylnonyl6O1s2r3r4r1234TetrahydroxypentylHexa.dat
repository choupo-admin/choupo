/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-o-[(8s)-9-hydroxy-8-methylnonyl] 6-o-[(1s,2r,3r,4r)-1,2,3,4-tetrahydroxypentyl] hexanedioate  (C21H40O9, CAS 115984-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1O8s9Hydroxy8Methylnonyl6O1s2r3r4r1234TetrahydroxypentylHexa;
formula     C21H40O9;
CAS         115984-51-5;
InChIKey    FFZJWGDSUFBPRE-ADDNLYQESA-N;
MW          436.542;      // g/mol [origin=calculated method=formula-sum]
Tc          1758.91;      // K   [origin=predictive method=joback]
Pc          13.477;      // bar [origin=predictive method=joback]
omega       0.2017;      // -   [origin=predictive method=lee-kesler]
Tb          1255.22;      // K   [origin=predictive method=joback]
HvapTb      158609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.662 2.08874 -0.0010974 1.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 5; } { group OH; count 5; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group CH; count 5; } { group OH; count 5; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-[(8s)-8-methyl-9-oxidanyl-nonyl] o6-[(1s,2r,3r,4r)-1,2,3,4-tetrakis(oxidanyl)pentyl] hexanedioate" );
standardThermochemistry
{
    dHf_298   -1898880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1283.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1191100.0
}
