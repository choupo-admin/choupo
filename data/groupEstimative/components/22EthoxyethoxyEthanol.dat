/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-ethoxyethoxy)ethanol  (C6H14O3, CAS 111-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22EthoxyethoxyEthanol;
formula     C6H14O3;
CAS         111-90-0;
InChIKey    XXJWXESWEXIICW-UHFFFAOYSA-N;
MW          134.175;      // g/mol [origin=calculated method=formula-sum]
Tc          635.30;      // K   [origin=predictive method=joback]
Pc          33.182;      // bar [origin=predictive method=joback]
omega       0.9403;      // -   [origin=predictive method=lee-kesler]
Tb          473.90;      // K   [origin=predictive method=joback]
HvapTb      50449.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.725 0.48142 -0.000111 -3.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethylene glycol monoethyl ether" "carbitol" "dioxitol" "transcutol" "ethanol, 2-(2-ethoxyethoxy)-" "solvolsol" "ethoxy diglycol" "ethyl carbitol" "ethyl digol" "carbitol solvent" "losungsmittel apv" "dowanol de" );
gibbsFormation
{
    dHf_298   -583840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-347180.0
    phase     gas;
}
