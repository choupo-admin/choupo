/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-bromobenzyl)methylamine  (C8H10BrN, CAS 698-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromobenzylMethylamine;
formula     C8H10BrN;
CAS         698-19-1;
InChIKey    TUADRPBKJHMHDH-UHFFFAOYSA-N;
MW          200.079;      // g/mol [origin=calculated method=formula-sum]
Tc          760.68;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       0.5732;      // -   [origin=predictive method=lee-kesler]
Tb          530.63;      // K   [origin=predictive method=joback]
HvapTb      49211.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.009 0.73982 -0.00049556 1.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3NH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-bromophenyl)-n-methyl-methanamine" "2-bromo-n-methylbenzylamine" "n-methyl-2-bromobenzylamine" "n-methyl-o-bromobenzylamine" "[(2-bromophenyl)methyl]methylamine" "1-(2-bromophenyl)-n-methylmethanamine" );
standardThermochemistry
{
    dHf_298   96410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222970.0
}
