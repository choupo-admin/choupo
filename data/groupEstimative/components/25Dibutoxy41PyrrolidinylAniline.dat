/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dibutoxy-4-(1-pyrrolidinyl)aniline  (C18H30N2O2, CAS 67828-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dibutoxy41PyrrolidinylAniline;
formula     C18H30N2O2;
CAS         67828-47-1;
InChIKey    LWCNNIJUQDICTR-UHFFFAOYSA-N;
MW          306.45;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.30;      // K   [origin=predictive method=joback]
Pc          16.646;      // bar [origin=predictive method=joback]
omega       1.0704;      // -   [origin=predictive method=lee-kesler]
Tb          798.55;      // K   [origin=predictive method=joback]
HvapTb      77822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.984 1.68364 -0.00094868 1.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group ACH; count 2; } { group AC; count 3; } { group CH2O; count 2; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dibutoxy-4-pyrrolidin-1-yl-aniline" "2,5-dibutoxy-4-(pyrrolidin-1-yl)aniline" "benzenamine, 2,5-dibutoxy-4-(1-pyrrolidinyl)-" "2,5-dibutoxy-4-pyrrolidin-1-ylaniline" "n-(4-amino-2,5-dibutoxyphenyl)pyrrolidine" );
gibbsFormation
{
    dHf_298   -288870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     794.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207790.0
    phase     gas;
}
