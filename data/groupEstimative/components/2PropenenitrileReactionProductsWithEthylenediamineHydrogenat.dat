/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenenitrile, reaction products with ethylenediamine, hydrogenated  (C5H11N3, CAS 68909-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenenitrileReactionProductsWithEthylenediamineHydrogenat;
formula     C5H11N3;
CAS         68909-99-9;
InChIKey    BDLZGUGOSAZRDI-UHFFFAOYSA-N;
MW          113.164;      // g/mol [origin=calculated method=formula-sum]
Tc          784.40;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.6639;      // -   [origin=predictive method=lee-kesler]
Tb          559.22;      // K   [origin=predictive method=joback]
HvapTb      58108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (66.152 0.3112 8.79e-05 -1.358e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2NH2; count 2; } { group ACRY; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group NH2; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diamine;prop-2-enenitrile" "ethane-1,2-diamine; prop-2-enenitrile" );
standardThermochemistry
{
    dHf_298   99740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=240380.0
}
