/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1255391  (C19H30ClNO, CAS 29122-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1255391;
formula     C19H30ClNO;
CAS         29122-60-9;
InChIKey    ZVBWFFQRJPHKFY-UHFFFAOYSA-N;
MW          323.905;      // g/mol [origin=calculated method=formula-sum]
Tc          975.98;      // K   [origin=predictive method=joback]
Pc          15.164;      // bar [origin=predictive method=joback]
omega       0.8432;      // -   [origin=predictive method=lee-kesler]
Tb          762.32;      // K   [origin=predictive method=joback]
HvapTb      70116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.777 1.84846 -0.00111812 2.489e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(5-chloranyl-2-ethoxy-phenyl)-3-methyl-pentyl]piperidine" "piperidine, 1-(beta-sec-butyl-5-chloro-2-ethoxyphenethyl)-" "1-[2-(5-chloro-2-ethoxyphenyl)-3-methylpentyl]piperidine" );
gibbsFormation
{
    dHf_298   -232070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     811.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235480.0
    phase     gas;
}
