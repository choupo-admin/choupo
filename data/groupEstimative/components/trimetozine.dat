/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimetozine  (C14H19NO5, CAS 635-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimetozine;
formula     C14H19NO5;
CAS         635-41-6;
InChIKey    XWVOEFLBOSSYGM-UHFFFAOYSA-N;
MW          281.308;      // g/mol [origin=calculated method=formula-sum]
Tc          961.06;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       1.0370;      // -   [origin=predictive method=lee-kesler]
Tb          742.01;      // K   [origin=predictive method=joback]
HvapTb      72115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.22 1.13796 -0.00049768 2.916e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 2; } { group AC; count 4; } { group CH3O; count 3; } { group FCH2O; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "morpholin-4-yl-(3,4,5-trimethoxyphenyl)methanone" "sedoxazine" "trioxazin" "trioxazine" "opalene" "trifenoxazin" "trimethoxazine" "triksazin" "trimetozin" "trimetozina" "trioxyfar" "4-(3,4,5-trimethoxybenzoyl)morpholine" );
gibbsFormation
{
    dHf_298   -623060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     593.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224480.0
    phase     gas;
}
