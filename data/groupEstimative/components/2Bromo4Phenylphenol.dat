/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4-phenylphenol  (C12H9BrO, CAS 92-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo4Phenylphenol;
formula     C12H9BrO;
CAS         92-03-5;
InChIKey    DZGMMVYPLBTLRQ-UHFFFAOYSA-N;
MW          249.107;      // g/mol [origin=calculated method=formula-sum]
Tc          952.89;      // K   [origin=predictive method=joback]
Pc          44.150;      // bar [origin=predictive method=joback]
omega       0.7522;      // -   [origin=predictive method=lee-kesler]
Tb          679.28;      // K   [origin=predictive method=joback]
HvapTb      66969.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.26 1.1193 -0.00095212 3.249e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4-phenyl-phenol" "phenol, 2-bromo-4-phenyl-" "dowicide 5" "3-bromobiphenyl-4-ol" "4-biphenylol, 3-bromo-" "3-bromo[1,1'-biphenyl]-4-ol" "3-bromo-biphenyl-4-ol" "3-bromo-4-hydroxybiphenyl" "3-bromo-4-biphenylol" "[1, 3-bromo-" );
gibbsFormation
{
    dHf_298   19600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=125050.0
    phase     gas;
}
