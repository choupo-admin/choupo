/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethoxy-4'-pentylbiphenyl  (C19H24O, CAS 68413-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethoxy4Pentylbiphenyl;
formula     C19H24O;
CAS         68413-56-9;
InChIKey    KOAUFWIBJVYJHF-UHFFFAOYSA-N;
MW          268.4;      // g/mol [origin=calculated method=formula-sum]
Tc          937.19;      // K   [origin=predictive method=joback]
Pc          16.977;      // bar [origin=predictive method=joback]
omega       0.7769;      // -   [origin=predictive method=lee-kesler]
Tb          720.06;      // K   [origin=predictive method=joback]
HvapTb      66174.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.095 1.46884 -0.00082712 1.613e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethoxy-4-(4-pentylphenyl)benzene" "4-ethoxy-4'-pentyl-1,1'-biphenyl" "1,1'-biphenyl, 4-ethoxy-4'-pentyl-" "4-n-pentyl-4'-ethoxybiphenyl" );
standardThermochemistry
{
    dHf_298   -117590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     682.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=209660.0
}
