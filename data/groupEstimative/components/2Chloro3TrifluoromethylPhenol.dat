/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-3-(trifluoromethyl)phenol  (C7H4ClF3O, CAS 138377-34-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro3TrifluoromethylPhenol;
formula     C7H4ClF3O;
CAS         138377-34-1;
InChIKey    BGXZMBZFGAIBDH-UHFFFAOYSA-N;
MW          196.552;      // g/mol [origin=calculated method=formula-sum]
Tc          719.18;      // K   [origin=predictive method=joback]
Pc          40.159;      // bar [origin=predictive method=joback]
omega       0.6051;      // -   [origin=predictive method=lee-kesler]
Tb          504.05;      // K   [origin=predictive method=joback]
HvapTb      47766.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.31 0.853 -0.00081892 3.035e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-3-(trifluoromethyl)phenol" "2-chloro-3-hydroxybenzotrifluoride" );
gibbsFormation
{
    dHf_298   -752880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-637300.0
    phase     gas;
}
