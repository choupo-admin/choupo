name        246Trimethylbenzene135TriylTrimethanediylTrisTrimethylsilane;
formula     C21H42Si3;
CAS         69020-18-4;
InChIKey    DSLWDSYSGBDWRB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          378.822;      // g/mol [origin=calculated method=formula-sum]
Tc          934.27;      // K   [origin=predictive method=joback]
Pc          8.975;      // bar [origin=predictive method=joback]
omega       0.5324;      // -   [origin=predictive method=lee-kesler]
Tb          735.86;      // K   [origin=predictive method=joback]
HvapTb      68808.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (143.843 1.00404 0.0004298 -5.119e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 9; } { group ACCH3; count 3; } { group ACCH2; count 3; } { group Si; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group CH2; count 3; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[[2,4,6-trimethyl-3,5-bis(trimethylsilylmethyl)phenyl]methyl]silane" "silane,[(2,4,6-trimethyl-1,3,5-benzenetriyl)tris(methylene)]tris[trimethyl-" "silane, ((2,4,6-trimethyl-1,3,5-benzenetriyl)tris(methylene))tris(trimethyl-" );
standardThermochemistry
{
    dHf_298   -632450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1216.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124080.0
}
