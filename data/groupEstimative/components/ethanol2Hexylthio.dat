/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-(hexylthio)-  (C8H18OS, CAS 24475-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol2Hexylthio;
formula     C8H18OS;
CAS         24475-56-7;
InChIKey    ZMGLDPZVDZFNLE-UHFFFAOYSA-N;
MW          162.291;      // g/mol [origin=calculated method=formula-sum]
Tc          720.71;      // K   [origin=predictive method=joback]
Pc          28.384;      // bar [origin=predictive method=joback]
omega       0.9427;      // -   [origin=predictive method=lee-kesler]
Tb          543.60;      // K   [origin=predictive method=joback]
HvapTb      56898.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.507 0.79221 -0.0004016 6.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group OH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexylsulfanylethanol" "2-hydroxyethylhexyl sulfide" "2-hexylthioethan-1-ol" "2-(hexylthio)ethanol" "2-(hexylsulfanyl)ethan-1-ol" "t301" );
gibbsFormation
{
    dHf_298   -318810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87220.0
    phase     gas;
}
