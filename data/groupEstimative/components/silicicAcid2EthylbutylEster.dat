/*--------------------------------*- Choupo -*-----------------------*\
  Component: silicic acid, 2-ethylbutyl ester  (C6H16O4Si, CAS 1336-62-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H16O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silicicAcid2EthylbutylEster;
formula     C6H16O4Si;
CAS         1336-62-5;
InChIKey    GRVOIMCYNZWCHU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          180.275;      // g/mol [origin=calculated method=formula-sum]
Tc          799.38;      // K   [origin=predictive method=joback]
Pc          36.865;      // bar [origin=predictive method=joback]
omega       1.7411;      // -   [origin=predictive method=lee-kesler]
Tb          636.80;      // K   [origin=predictive method=joback]
HvapTb      81303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.943 0.41234 0.0001288 -1.829e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 3; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylbutoxy-tris(oxidanyl)silane" "2-ethylbutyl trihydrogen orthosilicate" "polybis(2-ethylbutyl)siloxane" "2-ethylbutoxy(trihydroxy)silane" );
gibbsFormation
{
    dHf_298   -872980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-623020.0
    phase     gas;
}
