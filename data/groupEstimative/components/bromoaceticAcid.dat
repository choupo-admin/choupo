/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromoacetic acid  (C2H3BrO2, CAS 79-08-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromoaceticAcid;
formula     C2H3BrO2;
CAS         79-08-3;
InChIKey    KDPAWGWELVVRCH-UHFFFAOYSA-N;
MW          138.948;      // g/mol [origin=calculated method=formula-sum]
Tc          673.08;      // K   [origin=predictive method=joback]
Pc          63.796;      // bar [origin=predictive method=joback]
omega       0.6195;      // -   [origin=predictive method=lee-kesler]
Tb          457.03;      // K   [origin=predictive method=joback]
HvapTb      43645.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.861 0.2828 -0.000229 7.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylethanoic acid" "2-bromoacetic acid" "monobromoacetic acid" "acetic acid, bromo-" "bromoethanoic acid" "to ntu" "bromoacetate ion" "acetic acid, 2-bromo-" ".alpha.-bromoacetic acid" "acide bromacetique" "2-bromoacetyl group" "alpha-bromoacetic acid" );
standardThermochemistry
{
    dHf_298   -408550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-363630.0
}
