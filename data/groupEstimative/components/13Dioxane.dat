/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxane  (C4H8O2, CAS 505-22-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxane;
formula     C4H8O2;
CAS         505-22-6;
InChIKey    VDFVNEFVBPFDSB-UHFFFAOYSA-N;
MW          88.106;      // g/mol [origin=calculated method=formula-sum]
Tc          578.78;      // K   [origin=predictive method=joback]
Pc          52.358;      // bar [origin=predictive method=joback]
omega       0.2786;      // -   [origin=predictive method=lee-kesler]
Tb          369.24;      // K   [origin=predictive method=joback]
HvapTb      34256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.65 0.5264 -0.0003024 5.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "m-dioxane" "1,3-dioxacyclohexane" "meta-dioxane" "1,3-propanediol formal" "m-dioxin, dihydro-" "trimethylene glycol methylene ether" "formaldehyde trimethylene acetal" "dihydro-m-dioxin" );
gibbsFormation
{
    dHf_298   -315230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     221.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157280.0
    phase     gas;
}
