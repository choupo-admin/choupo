/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentylbenzene  (C11H16, CAS 538-68-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentylbenzene;
formula     C11H16;
CAS         538-68-1;
InChIKey    PWATWSYOIIXYMA-UHFFFAOYSA-N;
MW          148.249;      // g/mol [origin=calculated method=formula-sum]
Tc          679.98;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       0.4381;      // -   [origin=predictive method=lee-kesler]
Tb          477.96;      // K   [origin=predictive method=joback]
HvapTb      42356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.016 0.96992 -0.0006058 1.452e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylpentane" "amylbenzene" "benzene, pentyl-" "phenylpentane" "n-amylbenzene" "n-pentylbenzene" "1-phenyl-n-pentane" "pentane, 1-phenyl-" "1-pentylbenzene" "pentyl-benzene" "pentane, phenyl-" "agn-pc-03eb7n" );
standardThermochemistry
{
    dHf_298   -33840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=154150.0
}
