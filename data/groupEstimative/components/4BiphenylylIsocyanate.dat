/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-biphenylyl isocyanate  (C13H9NO, CAS 92-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BiphenylylIsocyanate;
formula     C13H9NO;
CAS         92-95-5;
InChIKey    WIRPZDICFIIBRF-UHFFFAOYSA-N;
MW          195.221;      // g/mol [origin=calculated method=formula-sum]
Tc          873.40;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.6083;      // -   [origin=predictive method=lee-kesler]
Tb          622.05;      // K   [origin=predictive method=joback]
HvapTb      59278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-phenyl-benzene" "p-xenylcarbimide" "4-isocyanatobiphenyl" "p-diphenyl isocyanate" "4-biphenyl isocyanate" "p-xenylcarbimide [mi]" "p-phenylphenyl isocyanate" "4-phenylphenyl isocyanate" "1-isocyanato-4-phenylbenzene" "1,1'-biphenyl, 4-isocyanato-" "4-isocyanatobiphenyl;p-xenyl isocyanate;4-isocyanato-1,1'-biphenyl;biphenyl-4-yl isocyanate;p-xenylcarbimide" );
// formation datum unavailable (element entropy missing): dHf_298=144530.0 dGf_298=None
