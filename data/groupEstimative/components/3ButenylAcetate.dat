/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-butenyl acetate  (C6H10O2, CAS 1576-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ButenylAcetate;
formula     C6H10O2;
CAS         1576-84-7;
InChIKey    IEKXSSZASGLISC-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          569.09;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.4256;      // -   [origin=predictive method=lee-kesler]
Tb          391.78;      // K   [origin=predictive method=joback]
HvapTb      35687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.852 0.49902 -0.0002309 2.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-3-enyl ethanoate" "2-vinylethyl acetate" "3-buten-1-ol acetate" "3-buten-1-ol, acetate" "3-buten-1-ol, 1-acetate" "but-3-enyl acetate" "acetic acid 3-buten-1-yl ester" "4-acetoxy-1-butene" "but-3-en-1-yl acetate" "acetic acid 3-butenyl ester" );
standardThermochemistry
{
    dHf_298   -359020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222890.0
}
