/*--------------------------------*- Choupo -*-----------------------*\
  Component: (dibutoxymethyl)benzene  (C15H24O2, CAS 5395-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibutoxymethylBenzene;
formula     C15H24O2;
CAS         5395-08-4;
InChIKey    WSVMGQQPLZDDQN-UHFFFAOYSA-N;
MW          236.355;      // g/mol [origin=calculated method=formula-sum]
Tc          806.36;      // K   [origin=predictive method=joback]
Pc          18.062;      // bar [origin=predictive method=joback]
omega       0.7423;      // -   [origin=predictive method=lee-kesler]
Tb          613.88;      // K   [origin=predictive method=joback]
HvapTb      55692.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.666 1.22944 -0.0006046 8.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibutoxymethylbenzene" "benzaldehyde, dibutyl acetal" );
standardThermochemistry
{
    dHf_298   -386120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24610.0
}
