/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2723919  (C12H17NO2, CAS 66827-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2723919;
formula     C12H17NO2;
CAS         66827-45-0;
InChIKey    RWNILOMIPVLRIS-UHFFFAOYSA-N;
MW          207.273;      // g/mol [origin=calculated method=formula-sum]
Tc          776.10;      // K   [origin=predictive method=joback]
Pc          24.314;      // bar [origin=predictive method=joback]
omega       0.6655;      // -   [origin=predictive method=lee-kesler]
Tb          571.06;      // K   [origin=predictive method=joback]
HvapTb      53644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.889 1.13996 -0.0006814 1.369e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH3COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(dimethylamino)-1-phenyl-ethyl] ethanoate" "phenethylamine, beta-acetoxy-n,n-dimethyl-" "beta-acetyloxy-beta-phenylethyl dimethylamine" "n,n-dimethyl beta-acetoxy beta-phenylethylamine" "(2-dimethylamino-1-phenyl-ethyl) acetate" "acetic acid, alpha-(dimethylaminomethyl)benzyl ester" "[2-(dimethylamino)-1-phenylethyl] acetate" );
gibbsFormation
{
    dHf_298   -309510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39460.0
    phase     gas;
}
