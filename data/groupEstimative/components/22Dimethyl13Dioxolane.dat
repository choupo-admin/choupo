/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-1,3-dioxolane  (C5H10O2, CAS 2916-31-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl13Dioxolane;
formula     C5H10O2;
CAS         2916-31-6;
InChIKey    SIJBDWPVNAYVGY-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          591.43;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.2886;      // -   [origin=predictive method=lee-kesler]
Tb          383.42;      // K   [origin=predictive method=joback]
HvapTb      34850.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.49 0.89644 -0.0008804 3.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "acetone ethylene ketal" "acetone ethylene acetal" "2,2-dimethyl-1,3-dioxolan" "1,3-dioxolane, 2,2-dimethyl-" "1,3-dioxolane,2,2-dimethyl-" "sijbdwpvnayvgy-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -334810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     267.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149960.0
}
