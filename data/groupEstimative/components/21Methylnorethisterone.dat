/*--------------------------------*- Choupo -*-----------------------*\
  Component: 21-methylnorethisterone  (C21H28O2, CAS 7359-79-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21Methylnorethisterone;
formula     C21H28O2;
CAS         7359-79-7;
InChIKey    IIIIYXODNAQVOO-XUDSTZEESA-N;
MW          312.453;      // g/mol [origin=calculated method=formula-sum]
Tc          1142.36;      // K   [origin=predictive method=joback]
Pc          19.631;      // bar [origin=predictive method=joback]
omega       1.0313;      // -   [origin=predictive method=lee-kesler]
Tb          892.67;      // K   [origin=predictive method=joback]
HvapTb      83964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-249.52 2.68564 -0.0023363 8.8108e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tC; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17s)-13-methyl-17-oxidanyl-17-prop-1-ynyl-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-one" "17-alpha-methylethynyl-19-nortestosterone" "17-beta-hydroxy-17-(1-propynyl)estr-4-en-3-one" "estr-4-en-3-one, 17-beta-hydroxy-17-(1-propynyl)-" "estr-4-en-3-one, 17-beta-hydroxy-17-alpha-(1-propynyl)-" );
gibbsFormation
{
    dHf_298   -197890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=245760.0
    phase     gas;
}
