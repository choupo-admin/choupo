/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-malic acid  (C4H6O5, CAS 97-67-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lMalicAcid;
formula     C4H6O5;
CAS         97-67-6;
InChIKey    BJEPYKJPYRNKOW-REOHCLBHSA-N;
MW          134.087;      // g/mol [origin=calculated method=formula-sum]
Tc          874.46;      // K   [origin=predictive method=joback]
Pc          57.046;      // bar [origin=predictive method=joback]
omega       1.6081;      // -   [origin=predictive method=lee-kesler]
Tb          673.88;      // K   [origin=predictive method=joback]
HvapTb      75117.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.061 0.5253 -0.0003726 1.017e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-oxidanylbutanedioic acid" "l-(-)-malic acid" "(-)-malic acid" "(2s)-2-hydroxybutanedioic acid" "(s)-2-hydroxysuccinic acid" "apple acid" "l-apple acid" "s-(-)-malic acid" "l-hydroxybutanedioic acid" "(-)-hydroxysuccinic acid" "s-2-hydroxybutanedioic acid" "(s)-malic acid" );
standardThermochemistry
{
    dHf_298   -983940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-844280.0
}
