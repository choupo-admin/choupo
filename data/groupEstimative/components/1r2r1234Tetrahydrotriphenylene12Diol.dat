/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-1,2,3,4-tetrahydrotriphenylene-1,2-diol  (C18H16O2, CAS 74444-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2r1234Tetrahydrotriphenylene12Diol;
formula     C18H16O2;
CAS         74444-58-9;
InChIKey    HGWVETHQBKANGX-AEFFLSMTSA-N;
MW          264.324;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.43;      // K   [origin=predictive method=joback]
Pc          28.781;      // bar [origin=predictive method=joback]
omega       1.5629;      // -   [origin=predictive method=lee-kesler]
Tb          881.72;      // K   [origin=predictive method=joback]
HvapTb      96338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.21 1.6318 -0.00123812 3.768e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 8; } { group AC; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 6; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrahydro-1,2-triphenylenediol trans-" "1,2-triphenylenediol, 1,2,3,4-tetrahydro-, trans-" );
standardThermochemistry
{
    dHf_298   -88750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164800.0
}
