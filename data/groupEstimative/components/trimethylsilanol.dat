/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylsilanol  (C3H10OSi, CAS 1066-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H10OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trimethylsilanol;
formula     C3H10OSi;
CAS         1066-40-6;
InChIKey    AAPLIUHOKVUFCC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          90.197;      // g/mol [origin=calculated method=formula-sum]
Tc          529.92;      // K   [origin=predictive method=joback]
Pc          42.496;      // bar [origin=predictive method=joback]
omega       0.4896;      // -   [origin=predictive method=lee-kesler]
Tb          361.82;      // K   [origin=predictive method=joback]
HvapTb      39245.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.27 0.11666 0.000245 -1.829e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group OH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(oxidanyl)silane" "hydroxytrimethylsilane" "silanol, trimethyl-" "silanol, 1,1,1-trimethyl-" "trimethylhydroxysilane" "2004-14-0 (lithium salt)" "10519-96-7 (potassium salt)" "18027-10-6 (na salt)" "18027-10-6 (hydrochloride salt)" "5599-26-8 (sb(3 )salt)" "1795-31-9 (phosphite (3:1))" );
gibbsFormation
{
    dHf_298   -369100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-267200.0
    phase     gas;
}
