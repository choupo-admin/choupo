/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxytamoxifen  (C26H29NO2, CAS 68047-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxytamoxifen;
formula     C26H29NO2;
CAS         68047-06-3;
InChIKey    TXUZVZSFRXZGTL-QPLCGJKRSA-N;
MW          387.523;      // g/mol [origin=calculated method=formula-sum]
Tc          1246.51;      // K   [origin=predictive method=joback]
Pc          15.451;      // bar [origin=predictive method=joback]
omega       1.1212;      // -   [origin=predictive method=lee-kesler]
Tb          998.90;      // K   [origin=predictive method=joback]
HvapTb      98545.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.837 2.41276 -0.00176352 5.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 13; } { group AC; count 4; } { group ACOH; count 1; } { group CH2O; count 1; } { group CH3N; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dC; count 2; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(z)-1-[4-[2-(dimethylamino)ethoxy]phenyl]-2-phenyl-but-1-enyl]phenol" "hydroxytamoxifen" "(z)-4-hydroxytamoxifen" "afimoxifene" "tamogel" "trans-4-hydroxytamoxifen" "4-monohydroxytamoxifen" "4-oh-tam" "tamoxifen, 4-hydroxy-, (z)-" "ici 79,280" "phenol, 4-(1-(4-(2-(dimethylamino)ethoxy)phenyl)-2-phenyl-1-butenyl)-," "4-hydroxy-(z)-tamoxifen" );
gibbsFormation
{
    dHf_298   -26210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     882.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=409920.0
    phase     gas;
}
