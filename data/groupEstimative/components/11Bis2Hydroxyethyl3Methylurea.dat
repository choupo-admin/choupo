/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-bis(2-hydroxyethyl)-3-methylurea  (C6H14N2O3, CAS 37437-17-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Bis2Hydroxyethyl3Methylurea;
formula     C6H14N2O3;
CAS         37437-17-5;
InChIKey    VEEUFWDGCHUMFT-UHFFFAOYSA-N;
MW          162.189;      // g/mol [origin=calculated method=formula-sum]
Tc          806.08;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       1.7490;      // -   [origin=predictive method=lee-kesler]
Tb          637.72;      // K   [origin=predictive method=joback]
HvapTb      77533.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.474 0.81392 -0.0005059 1.1866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 2; } { group CH3NH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 2; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(2-hydroxyethyl)-3-methyl-urea" "urea, 1,1-bis(2-hydroxyethyl)-3-methyl-" );
standardThermochemistry
{
    dHf_298   -463210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-202750.0
}
