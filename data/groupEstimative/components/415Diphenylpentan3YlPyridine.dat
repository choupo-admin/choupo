/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(1,5-diphenylpentan-3-yl)pyridine  (C22H23N, CAS 2057-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        415Diphenylpentan3YlPyridine;
formula     C22H23N;
CAS         2057-47-8;
InChIKey    RWNXMNLTEMDVIG-UHFFFAOYSA-N;
MW          301.433;      // g/mol [origin=calculated method=formula-sum]
Tc          1091.02;      // K   [origin=predictive method=joback]
Pc          18.452;      // bar [origin=predictive method=joback]
omega       0.8113;      // -   [origin=predictive method=lee-kesler]
Tb          836.26;      // K   [origin=predictive method=joback]
HvapTb      77216.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.446 1.89676 -0.00127906 3.284e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 14; } { group dC_ring; count 3; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[3-phenyl-1-(2-phenylethyl)propyl]pyridine" "4-(3-phenyl-1-(2-phenylethyl)propyl)pyridine" "pyridine, 4-(3-phenyl-1-(2-phenylethyl)propyl)-" "pyridine, 4-[3-phenyl-1-(2-phenylethyl)propyl]-" "4-(1-phenethyl-3-phenylpropyl)pyridine" "4-(1-phenethyl-3-phenyl-propyl)pyridine" "4-(1-phenethyl-3-phenyl-propyl)-pyridine" "pyridine,4-[3-phenyl-1-(2-phenylethyl)propyl]-" "pyridine,4-(1-phenethyl-3-phenylpropyl)- (7ci,8ci)" );
standardThermochemistry
{
    dHf_298   239690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=546200.0
}
