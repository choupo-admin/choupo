/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(3-chloropropyl)-1,1,3,3-tetramethyldisiloxane  (C10H24Cl2OSi2, CAS 18132-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H24Cl2OSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13Bis3Chloropropyl1133Tetramethyldisiloxane;
formula     C10H24Cl2OSi2;
CAS         18132-72-4;
InChIKey    OILWIZSTLQQEBD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          287.371;      // g/mol [origin=calculated method=formula-sum]
Tc          712.97;      // K   [origin=predictive method=joback]
Pc          15.885;      // bar [origin=predictive method=joback]
omega       0.4810;      // -   [origin=predictive method=lee-kesler]
Tb          528.48;      // K   [origin=predictive method=joback]
HvapTb      49622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (126.716 0.49188 0.0003796 -3.634e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH2Cl; count 2; } { group Si; count 1; } { group SiO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropyl-[3-chloranylpropyl(dimethyl)silyl]oxy-dimethyl-silane" "1,1,3,3-tetramethyl-1,3-(di-3-chlorpropyl)-disiloxane" "disiloxane, 1,3-bis(3-chloropropyl)-1,1,3,3-tetramethyl-" "1,3-bis(3-chloropropyl)-1,1,3,3-tetramethyldisiloxane;" "disiloxane,1,3-bis(3-chloropropyl)-1,1,3,3-tetramethyl-" "3-chloropropyl-[3-chloropropyl(dimethyl)silyl]oxy-dimethylsilane" );
standardThermochemistry
{
    dHf_298   -636670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     876.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-305060.0
}
