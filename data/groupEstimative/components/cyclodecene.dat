/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclodecene  (C10H18, CAS 935-31-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclodecene;
formula     C10H18;
CAS         935-31-9;
InChIKey    UCIYGNATMHQYCT-UPHRSURJSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          702.17;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.2695;      // -   [origin=predictive method=lee-kesler]
Tb          468.86;      // K   [origin=predictive method=joback]
HvapTb      39572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.45 1.008 -0.00045828 3.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cis-cyclodecene" "cyclodecene, (z)-" "1-cyclodecene" "trans-cyclodecene" "(z)-cyclodecene" "(9z)-cyclodecene" );
gibbsFormation
{
    dHf_298   -141930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     599.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47040.0
    phase     gas;
}
