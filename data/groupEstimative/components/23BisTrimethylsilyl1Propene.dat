/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-bis(trimethylsilyl)-1-propene  (C9H22Si2, CAS 17891-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H22Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        23BisTrimethylsilyl1Propene;
formula     C9H22Si2;
CAS         17891-65-5;
InChIKey    UNGXKSVOMSCMCE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          186.445;      // g/mol [origin=calculated method=formula-sum]
Tc          586.72;      // K   [origin=predictive method=joback]
Pc          19.321;      // bar [origin=predictive method=joback]
omega       0.2203;      // -   [origin=predictive method=lee-kesler]
Tb          404.88;      // K   [origin=predictive method=joback]
HvapTb      35626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.661 0.42642 0.0003386 -3.193e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH2=C; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(2-trimethylsilylprop-2-enyl)silane" "1-propene, 1,3-bis-trimethylsilyl" "silane,1,1'-(1-methylene-1,2-ethanediyl)bis[1,1,1-trimethyl-" "2,5-disilahexane,2,2,5,5-tetramethyl-3-methylene- (8ci); silane,(1-methylene-1,2-ethanediyl)bis[trimethyl- (9ci);trimethyl[2-(trimethylsilyl)-2-propenyl]silane" );
standardThermochemistry
{
    dHf_298   -336690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     750.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105330.0
}
