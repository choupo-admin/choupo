/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethchlorvynol  (C7H9ClO, CAS 113-18-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethchlorvynol;
formula     C7H9ClO;
CAS         113-18-8;
InChIKey    ZEHYJZXQEQOSON-AATRIKPKSA-N;
MW          144.598;      // g/mol [origin=calculated method=formula-sum]
Tc          677.20;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.6556;      // -   [origin=predictive method=lee-kesler]
Tb          480.42;      // K   [origin=predictive method=joback]
HvapTb      50760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.169 0.76152 -0.00065933 2.2859e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH_C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group dCH; count 2; } { group tCH; count 1; } { group tC; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-chloranyl-3-ethyl-pent-1-en-4-yn-3-ol" "ethchlorovynol" "placidyl" "alvinol" "ethchlorvinol" "etchlorvinolo" "ethchlorvinyl" "ethclorvynol" "ethochlorvynol" "ethychlorvynol" "normonson" "normosan" );
gibbsFormation
{
    dHf_298   44590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     437.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=165440.0
    phase     gas;
}
