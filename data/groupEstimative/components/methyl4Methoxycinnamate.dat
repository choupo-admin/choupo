/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-methoxycinnamate  (C11H12O3, CAS 832-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Methoxycinnamate;
formula     C11H12O3;
CAS         832-01-9;
InChIKey    VEZIKIAGFYZTCI-UHFFFAOYSA-N;
MW          192.214;      // g/mol [origin=calculated method=formula-sum]
Tc          782.57;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.6305;      // -   [origin=predictive method=lee-kesler]
Tb          567.74;      // K   [origin=predictive method=joback]
HvapTb      52793.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.01 0.81244 -0.00041696 5.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-(4-methoxyphenyl)prop-2-enoate" "methyl (2e)-3-(4-methoxyphenyl)prop-2-enoate" "methyl p-methoxycinnamate" "4-methoxycinnamate methyl ester" "cinnamate, methyl p-methoxy-" "p-methoxymethylcinnamate" "4-methoxycinnamic acid methyl ester" "methyl (2z)-3-(4-methoxyphenyl)prop-2-enoate" "cinnamic acid, p-methoxy-, methyl ester (8ci)" "2-propenoic acid,3-(4-methoxyphenyl)-, methyl ester" "2-propenoic acid, 3-(4-methoxyphenyl)-, methyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -377590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-190630.0
}
