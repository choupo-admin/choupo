/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diacetylbiphenyl  (C16H14O2, CAS 787-69-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diacetylbiphenyl;
formula     C16H14O2;
CAS         787-69-9;
InChIKey    YSTSBXDVNKYPTR-UHFFFAOYSA-N;
MW          238.286;      // g/mol [origin=calculated method=formula-sum]
Tc          980.33;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.8394;      // -   [origin=predictive method=lee-kesler]
Tb          736.74;      // K   [origin=predictive method=joback]
HvapTb      70578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.15 1.19104 -0.00073752 1.6232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 4; } { group CH3CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[4-(4-ethanoylphenyl)phenyl]ethanone" "4,4'-diacetyl biphenyl" "1-(4'-acetyl[1,1'-biphenyl]-4-yl)ethanone" "1-[4-(4-acetylphenyl)phenyl]ethanone" "1-acetyl-4-(4-acetylphenyl)benzene" "4',4''-biacetophenone" "1,1'-biphenyl-4,4'-diyldiethanone" "1-[4-(4-acetyl-phenyl)-phenyl]-ethanone" "bim-0004844.p001" "[1,1'-biphenyl-4,4'-diyl]diethan-1-one" "4,4'-diacetylbiphenyl 98%;1-[4-(4-acetylphenyl)cyclohexyl]ethanone;1-[4-(4-acetylphenyl)phenyl]ethanone;" );
gibbsFormation
{
    dHf_298   -148610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=31560.0
    phase     gas;
}
