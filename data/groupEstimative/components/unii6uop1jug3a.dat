/*--------------------------------*- Choupo -*-----------------------*\
  Component: unii-6uop1jug3a  (C18H25NO5, CAS 74217-57-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        unii6uop1jug3a;
formula     C18H25NO5;
CAS         74217-57-5;
InChIKey    VDHBZYVHRJQOLV-JHKFPADBSA-N;
MW          335.4;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.89;      // K   [origin=predictive method=joback]
Pc          18.871;      // bar [origin=predictive method=joback]
omega       1.3113;      // -   [origin=predictive method=lee-kesler]
Tb          873.65;      // K   [origin=predictive method=joback]
HvapTb      90073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.16 2.21086 -0.00170188 5.427e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group OH; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -852830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-384790.0
}
