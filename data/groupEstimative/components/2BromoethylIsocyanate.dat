/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoethyl isocyanate  (C3H4BrNO, CAS 42865-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromoethylIsocyanate;
formula     C3H4BrNO;
CAS         42865-19-0;
InChIKey    JLHTVZLEHOQZBM-UHFFFAOYSA-N;
MW          149.975;      // g/mol [origin=calculated method=formula-sum]
Tc          602.67;      // K   [origin=predictive method=joback]
Pc          53.828;      // bar [origin=predictive method=joback]
omega       0.4570;      // -   [origin=predictive method=lee-kesler]
Tb          401.07;      // K   [origin=predictive method=joback]
HvapTb      38239.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH2; count 2; } { group dCd; count 1; } { group Br; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-isocyanato-ethane" "1-bromo-2-isocyanatoethane" "ethane,1-bromo-2-isocyanato-" "2-bromo-isocyanatoethane" "2-bromoethylisocyanate; b-bromoethylisocyanate" );
// formation datum unavailable (element entropy missing): dHf_298=-84330.0 dGf_298=None
