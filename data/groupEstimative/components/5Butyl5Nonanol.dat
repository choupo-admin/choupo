/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-butyl-5-nonanol  (C13H28O, CAS 597-93-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Butyl5Nonanol;
formula     C13H28O;
CAS         597-93-3;
InChIKey    RWKMYNWNESNJQQ-UHFFFAOYSA-N;
MW          200.366;      // g/mol [origin=calculated method=formula-sum]
Tc          750.33;      // K   [origin=predictive method=joback]
Pc          18.031;      // bar [origin=predictive method=joback]
omega       0.9650;      // -   [origin=predictive method=lee-kesler]
Tb          585.99;      // K   [origin=predictive method=joback]
HvapTb      59915.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.111 1.39866 -0.0008856 2.252e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-butylnonan-5-ol" "tributylcarbinol" "5-nonanol, 5-butyl-" "tributylmethanol" "5-butyl-nonan-5-ol" );
standardThermochemistry
{
    dHf_298   -472630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     674.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75400.0
}
