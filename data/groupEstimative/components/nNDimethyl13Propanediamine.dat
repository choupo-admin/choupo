/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,N-Dimethyl-1,3-propanediamine  (C5H14N2, CAS 109-55-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl13Propanediamine;
formula     C5H14N2;
CAS         109-55-7;
InChIKey    IUNMPGNGSSIWFP-UHFFFAOYSA-N;
MW          102.181;      // g/mol [origin=calculated method=formula-sum]
Tc          578.40;      // K   [origin=predictive method=joback]
Pc          37.045;      // bar [origin=predictive method=joback]
omega       0.4854;      // -   [origin=predictive method=lee-kesler]
Tb          398.97;      // K   [origin=predictive method=joback]
HvapTb      39408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.857 0.66464 -0.0004042 9.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2NH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "N',N'-dimethylpropane-1,3-diamine" "(3-aminopropyl)dimethylamine" "(3-Dimethylaminopropan-1-yl)amine" "1,3-propanediamine, n,n-dimethyl-" "1,3-propanediamine, n1,n1-dimethyl-" "1-(Dimethylamino)-3-aminopropane" "1-Amino-3-(dimethylamino)propane" "3-(dimethylamino)-1-aminopropane" "3-(Dimethylamino)-1-propanamine" "3-(Dimethylamino)-1-propylamine" "3-(dimethylamino)propanamine" "3-(Dimethylamino)propylamine" );
standardThermochemistry
{
    dHf_298   -45210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168450.0
}
