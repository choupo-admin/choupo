/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentenal  (C5H8O, CAS 2100-17-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentenal;
formula     C5H8O;
CAS         2100-17-6;
InChIKey    QUMSUJWRUHPEEJ-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          535.99;      // K   [origin=predictive method=joback]
Pc          39.956;      // bar [origin=predictive method=joback]
omega       0.3818;      // -   [origin=predictive method=lee-kesler]
Tb          359.34;      // K   [origin=predictive method=joback]
HvapTb      32774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.752 0.4333 -0.0002641 6.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-4-enal" "pent-4-en-1-al" "qumsujwruhpeej-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -106680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20460.0
}
