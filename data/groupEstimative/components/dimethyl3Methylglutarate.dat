/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl 3-methylglutarate  (C8H14O4, CAS 19013-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethyl3Methylglutarate;
formula     C8H14O4;
CAS         19013-37-7;
InChIKey    YIJLMTNDXYVGPQ-UHFFFAOYSA-N;
MW          174.196;      // g/mol [origin=calculated method=formula-sum]
Tc          680.44;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.6699;      // -   [origin=predictive method=lee-kesler]
Tb          498.64;      // K   [origin=predictive method=joback]
HvapTb      47828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.752 0.66016 -0.0002254 -3.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 3-methylpentanedioate" "dimethyl3-methylglutarate" "3-methyl-pentanedioic acid dimethyl ester" "glutaric acid, 3-methyl-, dimethyl ester" "pentanedioic acid, 3-methyl-, dimethyl ester" "pentanedioic acid,3-methyl-, 1,5-dimethyl ester" );
gibbsFormation
{
    dHf_298   -848290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-606700.0
    phase     gas;
}
