/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyladamantane  (C11H18, CAS 700-56-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyladamantane;
formula     C11H18;
CAS         700-56-1;
InChIKey    VMODAALDMAYACB-UHFFFAOYSA-N;
MW          150.265;      // g/mol [origin=calculated method=formula-sum]
Tc          676.90;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.3509;      // -   [origin=predictive method=lee-kesler]
Tb          466.43;      // K   [origin=predictive method=joback]
HvapTb      39373.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.08 1.43892 -0.001078 3.313e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3.3.1.13,7]decane, 2-methyl-" "ambap700-56-1" "tricyclo[3.3.1.1<3,7>]decane, 2-methyl-" "tricyclo[3.3.1.1~3,7~]decane, 2-methyl-" );
standardThermochemistry
{
    dHf_298   -98810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     248.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196470.0
}
