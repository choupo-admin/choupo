/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylbiphenyl  (C13H12, CAS 643-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylbiphenyl;
formula     C13H12;
CAS         643-93-6;
InChIKey    NPDIDUXTRAITDE-UHFFFAOYSA-N;
MW          168.239;      // g/mol [origin=calculated method=formula-sum]
Tc          801.28;      // K   [origin=predictive method=joback]
Pc          30.223;      // bar [origin=predictive method=joback]
omega       0.4250;      // -   [origin=predictive method=lee-kesler]
Tb          555.38;      // K   [origin=predictive method=joback]
HvapTb      49746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.44 1.02152 -0.00067876 1.696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-3-phenyl-benzene" "3-phenyltoluene" "1,1'-biphenyl, 3-methyl-" "1-methyl-3-phenylbenzene" "3-methyl-biphenyl" "biphenyl, 3-methyl-" "3-methyl-1,1'biphenyl" "3-methyl-1-phenylbenzene" "agn-pc-0cuj80" "643-93-6 3-phenyltoluene" "3-methyl-1,1'-biphenyl" "h221" );
gibbsFormation
{
    dHf_298   149940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=273770.0
    phase     gas;
}
