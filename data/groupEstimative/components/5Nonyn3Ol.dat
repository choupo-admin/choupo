/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-nonyn-3-ol  (C9H16O, CAS 53723-19-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Nonyn3Ol;
formula     C9H16O;
CAS         53723-19-6;
InChIKey    UWQZATMGBARJPE-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          687.82;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.7825;      // -   [origin=predictive method=lee-kesler]
Tb          506.26;      // K   [origin=predictive method=joback]
HvapTb      54071.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.874 0.74894 -0.00040726 8.418e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "non-5-yn-3-ol" );
gibbsFormation
{
    dHf_298   -114300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     519.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=88440.0
    phase     gas;
}
