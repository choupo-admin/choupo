/*--------------------------------*- Choupo -*-----------------------*\
  Component: malonamide  (C3H6N2O2, CAS 108-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        malonamide;
formula     C3H6N2O2;
CAS         108-13-4;
InChIKey    WRIRWRKPLXCTFD-UHFFFAOYSA-N;
MW          102.093;      // g/mol [origin=calculated method=formula-sum]
Tc          742.34;      // K   [origin=predictive method=joback]
Pc          62.393;      // bar [origin=predictive method=joback]
omega       0.8069;      // -   [origin=predictive method=lee-kesler]
Tb          521.04;      // K   [origin=predictive method=joback]
HvapTb      57046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.861 0.3566 -0.0001888 2.842e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanediamide" "malonodiamide" "malondiamide" "malonyldiamide" "carboxamidoacetamide" "malonic acid diamide" "malonic diamide" "methane-1,1-dicarboxamide" "propane-1,3-diamide" "m630" "b7adf368-69fc-4139-a4af-9f37a8b615b4" );
standardThermochemistry
{
    dHf_298   -262830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-150560.0
}
