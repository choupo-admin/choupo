/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzosuberol  (C15H14O, CAS 1210-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzosuberol;
formula     C15H14O;
CAS         1210-34-0;
InChIKey    POAVRNPUPPJLKZ-UHFFFAOYSA-N;
MW          210.276;      // g/mol [origin=calculated method=formula-sum]
Tc          936.81;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.9710;      // -   [origin=predictive method=lee-kesler]
Tb          705.04;      // K   [origin=predictive method=joback]
HvapTb      71452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.91 1.3369 -0.00097112 2.776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 2; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,11-dihydro-5h-dibenzo[1,2-a:1',2'-e][7]annulen-11-ol" "5h-dibenzo[a,d]cyclohepten-5-ol, 10,11-dihydro-" "10,11-dihydro-5h-dibenzo(a,d)cyclohepten-5-ol" "10,11-dihydro-5h-dibenzo[a,d]cyclohepten-5-ol" "10,d]cyclohepten-5-ol" "5-hydroxy-10,11-dihydro-5h-dibenzo[a,d]cycloheptene" );
standardThermochemistry
{
    dHf_298   17760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204910.0
}
