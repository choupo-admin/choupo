/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3,3-diethoxyacrylate  (C9H16O4, CAS 32002-24-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl33Diethoxyacrylate;
formula     C9H16O4;
CAS         32002-24-7;
InChIKey    POJGRKZMYVJCST-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          692.76;      // K   [origin=predictive method=joback]
Pc          23.703;      // bar [origin=predictive method=joback]
omega       0.6905;      // -   [origin=predictive method=lee-kesler]
Tb          512.62;      // K   [origin=predictive method=joback]
HvapTb      47893.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.243 0.69756 -0.0002353 -2.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=C; count 1; } { group CH2O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 1; } { group dC; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3,3-diethoxyprop-2-enoate" "3,3-diethoxyacrylic acid ethyl ester" "2-propenoic acid, 3,3-diethoxy-, ethyl ester" "ethyl-3,3-diethoxy acrylate" "am907" "u746" "2-propenoic acid,3,3-diethoxy-, ethyl ester" "acrylicacid, 3-oxo-, ethyl ester, diethyl acetal (7ci,8ci); 3,3-diethoxyacrylic acidethyl ester; carbethoxyketene diethyl acetal; ethyl 3,3-diethoxyacrylate; ethylb,b-diethoxyacrylate" );
gibbsFormation
{
    dHf_298   -703380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-423800.0
    phase     gas;
}
