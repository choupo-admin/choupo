/*--------------------------------*- Choupo -*-----------------------*\
  Component: pseudomorphine  (C34H36N2O6, CAS 125-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pseudomorphine;
formula     C34H36N2O6;
CAS         125-24-6;
InChIKey    FOJYFDFNGPRXDR-UHFFFAOYSA-N;
MW          568.67;      // g/mol [origin=calculated method=formula-sum]
Tc          1916.16;      // K   [origin=predictive method=joback]
Pc          17.894;      // bar [origin=predictive method=joback]
omega       1.1220;      // -   [origin=predictive method=lee-kesler]
Tb          1519.98;      // K   [origin=predictive method=joback]
HvapTb      168918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-468.27 4.98324 -0.00504024 2.0404e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 6; } { group C; count 2; } { group CH=CH; count 2; } { group ACH; count 2; } { group AC; count 6; } { group ACCH2; count 2; } { group OH; count 2; } { group ACOH; count 2; } { group CH-O; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 8; } { group C_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 10; } { group OH; count 2; } { group OH_phenol; count 2; } { group O_ring; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-10-[3-methyl-7,9-bis(oxidanyl)-2,4,4a,7,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-10-yl]-2,4,4a,7,7a,13-hexahydro-1h-4,12-methanobenzofuro[3,2-e]isoquinoline-7,9-diol" "[2,2'-bimorphinan]-3,3',6,6'-tetrol, 7,7',8,8'-tetradehydro-4,5:4',5'-diepoxy-17,17'-dimethyl-, (5.alpha.,6.alpha.)-(5'.alpha.,6'.alpha.)-" "dehydromorphine" "oxydimorphine" "morphine impurity" "2,2'-dehydrodimorphine" "pseudo morphine (morphine impurity)" "(5" "a,6" "a)-(5'" "a,6'" "a-7,7',8,8'-tetradehydro-4,5:4',5'-diepoxy-17,17'-dimethyl-[2,2'-bimorphinan]-3,3',6,6'-tetrol" );
standardThermochemistry
{
    dHf_298   -428790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=412600.0
}
