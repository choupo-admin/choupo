/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrocatecholphthlein  (C20H14O6, CAS 596-28-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrocatecholphthlein;
formula     C20H14O6;
CAS         596-28-1;
InChIKey    QPFLFTVMWJJXKU-UHFFFAOYSA-N;
MW          350.326;      // g/mol [origin=calculated method=formula-sum]
Tc          1405.53;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       1.9840;      // -   [origin=predictive method=lee-kesler]
Tb          1121.36;      // K   [origin=predictive method=joback]
HvapTb      125485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-202.97 2.6332 -0.0028672 1.2108e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 10; } { group AC; count 4; } { group ACOH; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group OH_phenol; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis[3,4-bis(oxidanyl)phenyl]-2-benzofuran-1-one" "pyrocatecholphthalein" "phthalide, 3,3-bis(3,4-dihydroxyphenyl)-" "1(3h)-isobenzofuranone, 3,3-bis(3,4-dihydroxyphenyl)-" "phthalide,3-bis(3,4-dihydroxyphenyl)-" "3,3-bis(3,4-dihydroxyphenyl)-2-benzofuran-1-one" "1(3h)-isobenzofuranone,3-bis(3,4-dihydroxyphenyl)-" "3,3-bis(3,4-dihydroxyphenyl)isobenzofuran-1(3h)-one" );
standardThermochemistry
{
    dHf_298   -684170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     706.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-404270.0
}
