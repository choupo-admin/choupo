/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethyl-1-hexene  (C8H16, CAS 7423-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethyl1Hexene;
formula     C8H16;
CAS         7423-69-0;
InChIKey    FEZKAPRRVNNJTK-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          553.20;      // K   [origin=predictive method=joback]
Pc          26.902;      // bar [origin=predictive method=joback]
omega       0.3178;      // -   [origin=predictive method=lee-kesler]
Tb          378.44;      // K   [origin=predictive method=joback]
HvapTb      31956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.739 0.75566 -0.0004407 1.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethylhex-1-ene" "1-hexene, 3,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -93580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99440.0
}
