/*--------------------------------*- Choupo -*-----------------------*\
  Component: dianol 22  (C19H24O4, CAS 901-44-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dianol22;
formula     C19H24O4;
CAS         901-44-0;
InChIKey    UUAGPGQUHZVJBQ-UHFFFAOYSA-N;
MW          316.397;      // g/mol [origin=calculated method=formula-sum]
Tc          1137.08;      // K   [origin=predictive method=joback]
Pc          19.912;      // bar [origin=predictive method=joback]
omega       1.5121;      // -   [origin=predictive method=lee-kesler]
Tb          923.61;      // K   [origin=predictive method=joback]
HvapTb      100646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.486 1.59944 -0.00094872 1.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[2-[4-(2-hydroxyethyloxy)phenyl]propan-2-yl]phenoxy]ethanol" "bisphenol a bis(2-hydroxyethyl)ether" "2,2-bis[4-(2-hydroxyethoxy)phenyl]propane" "4,4'-bis(hydroxyethoxy)diphenyldimethylmethane" "1,1'-isopropylidenebis(p-phenyleneoxy-2-ethanol)" "2,2'-[isopropylidenebis(p-phenyleneoxy)]diethanol" "ethanol, 2,2'-[(1-methylethylidene)bis(4,1-phenyleneoxy)]bis-" "2,2-bis(p-(2-hydroxyethoxy)phenyl)propane" "2,2-bis[p-(2-hydroxyethoxy)phenyl]propane" "2,2-bis(4-(2-hydroxyethoxy)phenyl)propane" "2,2'-(isopropylidenebis(p-phenyleneoxy))diethanol" "ethanol, 2,2'-((1-methylethylidene)bis(4,1-phenyleneoxy))bis-" );
gibbsFormation
{
    dHf_298   -563020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166140.0
    phase     gas;
}
