/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlornaphazine  (C14H15Cl2N, CAS 494-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlornaphazine;
formula     C14H15Cl2N;
CAS         494-03-1;
InChIKey    XCDXSSFOJZZGQC-UHFFFAOYSA-N;
MW          268.181;      // g/mol [origin=calculated method=formula-sum]
Tc          883.50;      // K   [origin=predictive method=joback]
Pc          23.181;      // bar [origin=predictive method=joback]
omega       0.7227;      // -   [origin=predictive method=lee-kesler]
Tb          657.86;      // K   [origin=predictive method=joback]
HvapTb      62149.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.796 1.3292 -0.00099208 2.925e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH2N; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group Cl; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-chloroethyl)naphthalen-2-amine" "chlornaftina" "chlornaphazin" "chlornaphthin" "chloronaftina" "chloronaphthina" "chloronaphthine" "cloronaftina" "nafticlorina" "aleukon" "erysan" "n,n-bis(2-chloroethyl)-2-naphthylamine" );
gibbsFormation
{
    dHf_298   119890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=363350.0
    phase     gas;
}
