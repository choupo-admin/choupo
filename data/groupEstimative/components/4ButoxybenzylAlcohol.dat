/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-butoxybenzyl alcohol  (C11H16O2, CAS 6214-45-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ButoxybenzylAlcohol;
formula     C11H16O2;
CAS         6214-45-5;
InChIKey    MGKNBDBZIKPUFM-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          787.31;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.9936;      // -   [origin=predictive method=lee-kesler]
Tb          597.54;      // K   [origin=predictive method=joback]
HvapTb      62107.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.074 0.88122 -0.00045816 7.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-butoxyphenyl)methanol" "p-butoxybenzyl alcohol" "4-n-butoxybenzyl alcohol" "(4-butoxy-phenyl)-methanol" "benzenemethanol,4-butoxy-" "benzenemethanol, 4-butoxy-" "(4-butoxyphenyl)methan-1-ol" "4-n-butyloxybenzyl alcohol" "q180" );
standardThermochemistry
{
    dHf_298   -329760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97300.0
}
