/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyltrimethylsilane  (C6H14Si, CAS 762-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H14Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        allyltrimethylsilane;
formula     C6H14Si;
CAS         762-72-1;
InChIKey    HYWCXWRMUZYRPH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          114.263;      // g/mol [origin=calculated method=formula-sum]
Tc          508.19;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.1956;      // -   [origin=predictive method=lee-kesler]
Tb          334.96;      // K   [origin=predictive method=joback]
HvapTb      28574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.261 0.34766 8.93e-05 -1.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH2=CH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(prop-2-enyl)silane" "silane, trimethyl-2-propenyl-" "silane, allyltrimethyl-" "allytrimethylsilane" "silane, trimethyl-2-propen-1-yl-" "allyl(trimethyl)silane" "3-(trimethylsilyl)propene" "allyl trimethylsilane" "trimethyl-prop-2-enylsilane" "silane,allyltrimethyl- (6ci,8ci);silane, trimethyl-2-propenyl- (9ci);3-(trimethylsilyl)-1-propene;3-(trimethylsilyl)propene;trimethyl(2-propenyl)silane;trimethylallylsilane;trimethyl(prop-2-en-1-yl)silane;2-propenyltrimethylsilane;silane, allyltrimethyl-;silane, trimethyl-2-propen-1-yl-;trimethyl(prop-2-en-1-yl)silan;" );
gibbsFormation
{
    dHf_298   -153360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17280.0
    phase     gas;
}
