/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-iodovanillin  (C8H7IO3, CAS 5438-36-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H7IO3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        5Iodovanillin;
formula     C8H7IO3;
CAS         5438-36-8;
InChIKey    FBBCSYADXYILEH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          278.041;      // g/mol [origin=calculated method=formula-sum]
Tc          850.09;      // K   [origin=predictive method=joback]
Pc          42.663;      // bar [origin=predictive method=joback]
omega       0.5939;      // -   [origin=predictive method=lee-kesler]
Tb          591.88;      // K   [origin=predictive method=joback]
HvapTb      59426.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.92 0.70442 -0.00068828 2.746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CHO; count 1; } { group CH3O; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group I; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanyl-5-methoxy-4-oxidanyl-benzaldehyde" "4-hydroxy-3-iodo-5-methoxybenzaldehyde" "5 iodovanillin" "benzaldehyde, 4-hydroxy-3-iodo-5-methoxy-" "5-iodo vanillin" "fbbcsyadxyileh-uhfffaoysa-" "3-methoxy-4-hydroxy-5-iodobenzaldehyde" "4-hydroxy-5-iodo-3-methoxybenzaldehyde" "upcmld0enat5212559:001" "4-hydroxy-3-iodo-5-methoxy-benzaldehyde" "benzaldehyde,4-hydroxy-3-iodo-5-methoxy-" );
standardThermochemistry
{
    dHf_298   -151070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-47910.0
}
