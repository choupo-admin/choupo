/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptaminol  (C8H19NO, CAS 372-66-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptaminol;
formula     C8H19NO;
CAS         372-66-7;
InChIKey    LREQLEBVOXIEOM-UHFFFAOYSA-N;
MW          145.246;      // g/mol [origin=calculated method=formula-sum]
Tc          726.69;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       0.9170;      // -   [origin=predictive method=lee-kesler]
Tb          543.68;      // K   [origin=predictive method=joback]
HvapTb      59038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.757 0.99146 -0.0006602 1.762e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-azanyl-2-methyl-heptan-2-ol" "6-amino-2-methyl-2-heptanol" "6-amino-2-methylheptan-2-ol" "heptaminol [inn:ban]" "heptaminolum [inn-latin]" "2-methyl-2-hydroxy-6-aminoheptane" "6-amino-2-methylheptan-2-ol hydrochloride" "heptaminolum" "heptaminol (inn)" "543-15-7 (hydrochloride)" "brd-a32988684-003-01-2" );
standardThermochemistry
{
    dHf_298   -340920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-53490.0
}
