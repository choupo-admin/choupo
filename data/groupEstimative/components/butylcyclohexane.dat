/*--------------------------------*- Choupo -*-----------------------*\
  Component: butylcyclohexane  (C10H20, CAS 1678-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylcyclohexane;
formula     C10H20;
CAS         1678-93-9;
InChIKey    GGBJHURWWWLEQH-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          644.85;      // K   [origin=predictive method=joback]
Pc          25.689;      // bar [origin=predictive method=joback]
omega       0.3674;      // -   [origin=predictive method=lee-kesler]
Tb          447.95;      // K   [origin=predictive method=joback]
HvapTb      38283.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.807 1.07592 -0.0006012 1.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butylcyclohexane" "cyclohexane, butyl-" "1-cyclohexylbutane" "butyl-cyclohexane" "butane, 1-cyclohexyl-" );
standardThermochemistry
{
    dHf_298   -195410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=57770.0
}
