/*--------------------------------*- Choupo -*-----------------------*\
  Component: damascenine  (C10H13NO3, CAS 483-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        damascenine;
formula     C10H13NO3;
CAS         483-64-7;
InChIKey    ZRWJIZYZTLTXJI-UHFFFAOYSA-N;
MW          195.218;      // g/mol [origin=calculated method=formula-sum]
Tc          805.90;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       0.7840;      // -   [origin=predictive method=lee-kesler]
Tb          595.85;      // K   [origin=predictive method=joback]
HvapTb      57707.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.19 0.71416 -0.00026032 -1.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH3O; count 1; } { group CH3NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3-methoxy-2-(methylamino)benzoate" "nigelline" "5296-80-0 (hydrochloride)" "3-methoxy-2-(methylamino)benzoic acid methyl ester" "benzoic acid, 3-methoxy-2-(methylamino)-, methyl ester" );
gibbsFormation
{
    dHf_298   -432170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199510.0
    phase     gas;
}
