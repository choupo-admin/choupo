/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3',5'-diacetoxyacetophenone  (C12H12O5, CAS 35086-59-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Diacetoxyacetophenone;
formula     C12H12O5;
CAS         35086-59-0;
InChIKey    QODJHYBESCIPOG-UHFFFAOYSA-N;
MW          236.223;      // g/mol [origin=calculated method=formula-sum]
Tc          896.29;      // K   [origin=predictive method=joback]
Pc          25.100;      // bar [origin=predictive method=joback]
omega       0.9326;      // -   [origin=predictive method=lee-kesler]
Tb          681.11;      // K   [origin=predictive method=joback]
HvapTb      67466.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.85 0.80836 -0.00031822 -1.594e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CH3CO; count 1; } { group CH3COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3-acetyloxy-5-ethanoyl-phenyl) ethanoate" "5-acetyl-1,3-phenylene diacetate" "3-acetyl-5-acetyloxyphenyl acetate" "3,5-diacetoxyacetophenone" "(3-acetyl-5-acetyloxyphenyl) acetate" "3-acetyl-5-(acetyloxy)phenyl acetate" "acetic acid (3-acetyl-5-acetyloxyphenyl) ester" "3,5-diacetoxy acetophenone;acetophenone,3',5'-dihydroxy-, diacetate (6ci);5-acetyl-1,3-phenylene diacetate;" );
gibbsFormation
{
    dHf_298   -824560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     633.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-606350.0
    phase     gas;
}
