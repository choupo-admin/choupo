/*--------------------------------*- Choupo -*-----------------------*\
  Component: superphane  (C24H24, CAS 60144-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        superphane;
formula     C24H24;
CAS         60144-50-5;
InChIKey    BVTYOCKAKQQPEE-UHFFFAOYSA-N;
MW          312.456;      // g/mol [origin=calculated method=formula-sum]
Tc          1148.34;      // K   [origin=predictive method=joback]
Pc          19.407;      // bar [origin=predictive method=joback]
omega       1.0095;      // -   [origin=predictive method=lee-kesler]
Tb          896.12;      // K   [origin=predictive method=joback]
HvapTb      80784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-209.29 2.4468 -0.002191 8.036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH2; count 12; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2.2.2.2.2.2](1,2,3,4,5,6)cyclophane" "(2.2.2.2.2.2)(1,2,3,4,5,6)cyclophane" "heptacyclo[16.6.0.02,9.05,22.06,13.010,17.014,21]tetracosa-1,5,9,13,17,21-hexaene (non-preferred name)" );
standardThermochemistry
{
    dHf_298   303850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=658320.0
}
