/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromoadamantane  (C10H15Br, CAS 7314-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromoadamantane;
formula     C10H15Br;
CAS         7314-85-4;
InChIKey    RCXJARRRXOPXBC-UHFFFAOYSA-N;
MW          215.134;      // g/mol [origin=calculated method=formula-sum]
Tc          740.32;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       0.4201;      // -   [origin=predictive method=lee-kesler]
Tb          509.71;      // K   [origin=predictive method=joback]
HvapTb      43582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-141.98 1.3821 -0.001095 3.535e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 5; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 5; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyladamantane" "adamantane, 2-bromo-" "2-adamantyl bromide" "2-bromotricyclo[3.3.1.13.7]decane" "tricyclo[3.3.1.1(3,7)]decane, 2-bromo-" "2-bromo-adamantane" "(1r,3s)-2-bromoadamantane" "k245" "tricyclo[3.3.1.13,7]decane,2-bromo-" "adamantane,2-bromo- (7ci,8ci);2-adamantyl bromide;" );
gibbsFormation
{
    dHf_298   -51840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     260.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=202370.0
    phase     gas;
}
