/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6,9,12-tetradecatetraen-5-one, 9,13-dimethyl-  (C16H24O, CAS 72927-82-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16912Tetradecatetraen5One913Dimethyl;
formula     C16H24O;
CAS         72927-82-3;
InChIKey    CDQMGJIMWCZPBY-UHFFFAOYSA-N;
MW          232.367;      // g/mol [origin=calculated method=formula-sum]
Tc          821.43;      // K   [origin=predictive method=joback]
Pc          16.220;      // bar [origin=predictive method=joback]
omega       0.7133;      // -   [origin=predictive method=lee-kesler]
Tb          628.47;      // K   [origin=predictive method=joback]
HvapTb      57320.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.216 1.53566 -0.0011068 3.3336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 5; } { group dC; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,13-dimethyltetradeca-1,6,9,12-tetraen-5-one" );
gibbsFormation
{
    dHf_298   -28640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     773.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266320.0
    phase     gas;
}
