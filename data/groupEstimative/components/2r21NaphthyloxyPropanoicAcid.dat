/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2r)-2-(1-naphthyloxy)propanoic acid  (C13H12O3, CAS 6366-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2r21NaphthyloxyPropanoicAcid;
formula     C13H12O3;
CAS         6366-23-0;
InChIKey    KTAVXDDWEGVLRN-SECBINFHSA-N;
MW          216.236;      // g/mol [origin=calculated method=formula-sum]
Tc          951.82;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.9433;      // -   [origin=predictive method=lee-kesler]
Tb          715.17;      // K   [origin=predictive method=joback]
HvapTb      68296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.56 1.09022 -0.00074908 1.979e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 7; } { group AC; count 3; } { group CH-O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-naphthalen-1-yloxypropanoic acid" "(-)-2-(1-naphthyloxy)propionic acid" "propanoic acid, 2-(1-naphthalenyloxy)-, (r)-" );
gibbsFormation
{
    dHf_298   -383290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183340.0
    phase     gas;
}
