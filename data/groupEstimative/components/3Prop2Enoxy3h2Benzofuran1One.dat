/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-prop-2-enoxy-3h-2-benzofuran-1-one  (C11H10O3, CAS 61133-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Prop2Enoxy3h2Benzofuran1One;
formula     C11H10O3;
CAS         61133-37-7;
InChIKey    VUHVYYOSDKVVEP-UHFFFAOYSA-N;
MW          190.198;      // g/mol [origin=calculated method=formula-sum]
Tc          768.95;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.6751;      // -   [origin=predictive method=lee-kesler]
Tb          558.46;      // K   [origin=predictive method=joback]
HvapTb      51734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.799 0.9425 -0.00066906 1.849e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1(3h)-isobenzofuranone, 3-(2-propenyloxy)-" );
standardThermochemistry
{
    dHf_298   -284260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98060.0
}
