/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxeladin  (C20H33NO3, CAS 468-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxeladin;
formula     C20H33NO3;
CAS         468-61-1;
InChIKey    IQADUMSPOQKAAO-UHFFFAOYSA-N;
MW          335.488;      // g/mol [origin=calculated method=formula-sum]
Tc          967.62;      // K   [origin=predictive method=joback]
Pc          12.737;      // bar [origin=predictive method=joback]
omega       0.9406;      // -   [origin=predictive method=lee-kesler]
Tb          773.73;      // K   [origin=predictive method=joback]
HvapTb      72954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.452 1.95668 -0.0011742 2.497e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(diethylamino)ethoxy]ethyl 2-ethyl-2-phenyl-butanoate" "oxeladinum" "oxeladina" "oxeladine" "oxeladine [inn-french]" "oxeladinum [inn-latin]" "2-(2-diethylaminoethoxy)ethyl 2-ethyl-2-phenylbutyrate" "2-[2-(diethylamino)ethoxy]ethyl 2-ethyl-2-phenylbutanoate" "2-(2-diethylaminoethoxy)ethyl alpha,alpha-diethylphenylacetate" "2-ethyl-2-phenylbutyric acid 2-(2-diethylaminoethoxy)ethyl ester" "ethanol, 2-(2-(diethylamino)ethoxy)-, 2-ethyl-2-phenylbutyrate" "alpha,alpha-diethylbenzeneacetic acid 2-(2-(diethylamino)ethoxy)ethyl ester" );
gibbsFormation
{
    dHf_298   -610320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     868.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-71820.0
    phase     gas;
}
