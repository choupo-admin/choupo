/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5,7,9-pentaoxecane  (C5H10O5, CAS 16528-92-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13579Pentaoxecane;
formula     C5H10O5;
CAS         16528-92-0;
InChIKey    QSBDXVOJNUPDPI-UHFFFAOYSA-N;
MW          150.13;      // g/mol [origin=calculated method=formula-sum]
Tc          731.71;      // K   [origin=predictive method=joback]
Pc          50.658;      // bar [origin=predictive method=joback]
omega       0.4642;      // -   [origin=predictive method=lee-kesler]
Tb          490.05;      // K   [origin=predictive method=joback]
HvapTb      50700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.08 0.574 -0.0001295 -7.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group FCH2O; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group O_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5,7,9-pentoxecane(8ci,9ci)" "1,3,5,7,9-pentoxacane;formaldehyde, cyclic pentamer; pentaoxane; pentoxane" );
gibbsFormation
{
    dHf_298   -756510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     185.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-455620.0
    phase     gas;
}
