/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(dodecyloxy)benzoic acid  (C19H30O3, CAS 2312-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4DodecyloxyBenzoicAcid;
formula     C19H30O3;
CAS         2312-15-4;
InChIKey    ALQLYJHDBAKLBB-UHFFFAOYSA-N;
MW          306.446;      // g/mol [origin=calculated method=formula-sum]
Tc          1034.43;      // K   [origin=predictive method=joback]
Pc          14.197;      // bar [origin=predictive method=joback]
omega       1.1210;      // -   [origin=predictive method=lee-kesler]
Tb          833.91;      // K   [origin=predictive method=joback]
HvapTb      80400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.889 1.65802 -0.00093556 1.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-dodecoxybenzoic acid" "4-dodecyloxybenzoic acid" "p-dodecyloxybenzoic acid" "benzoic acid, 4-(dodecyloxy)-" "4-n-dodecyloxybenzoic acid" "benzoic acid, p-(dodecyloxy)-" "p-(dodecyloxy)benzoic acid" "benzoic acid,4-(dodecyloxy)-" );
gibbsFormation
{
    dHf_298   -692920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     847.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237030.0
    phase     gas;
}
