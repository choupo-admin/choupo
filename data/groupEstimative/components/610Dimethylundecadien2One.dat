/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,10-dimethylundecadien-2-one  (C13H22O, CAS 68228-05-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        610Dimethylundecadien2One;
formula     C13H22O;
CAS         68228-05-7;
InChIKey    HBZBROBMQHJIBO-KOOBJXAQSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          748.09;      // K   [origin=predictive method=joback]
Pc          19.136;      // bar [origin=predictive method=joback]
omega       0.6345;      // -   [origin=predictive method=lee-kesler]
Tb          558.67;      // K   [origin=predictive method=joback]
HvapTb      50886.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.307 1.25668 -0.0008378 2.3056e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 3; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e,5e)-6,10-dimethylundeca-3,5-dien-2-one" );
gibbsFormation
{
    dHf_298   -204860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79110.0
    phase     gas;
}
