/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane-1-butanenitrile  (C10H18N2O3Si, CAS 79747-04-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H18N2O3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        289Trioxa5Aza1Silabicyclo333Undecane1Butanenitrile;
formula     C10H18N2O3Si;
CAS         79747-04-9;
InChIKey    CGPZMTAMGCNLFK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          242.35;      // g/mol [origin=calculated method=formula-sum]
Tc          888.22;      // K   [origin=predictive method=joback]
Pc          26.272;      // bar [origin=predictive method=joback]
omega       0.7869;      // -   [origin=predictive method=lee-kesler]
Tb          660.80;      // K   [origin=predictive method=joback]
HvapTb      65159.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.837 1.1233 -0.0005573 6.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2O; count 3; } { group CH2N; count 1; } { group CH2CN; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 6; } { group O_ring; count 3; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecan-5-yl)butanenitrile" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane-1-butane nitrile" );
standardThermochemistry
{
    dHf_298   -357140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14780.0
}
