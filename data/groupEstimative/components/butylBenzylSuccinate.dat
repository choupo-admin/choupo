/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl benzyl succinate  (C15H20O4, CAS 1223-37-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylBenzylSuccinate;
formula     C15H20O4;
CAS         1223-37-6;
InChIKey    SISDVYCKRJTJHA-UHFFFAOYSA-N;
MW          264.321;      // g/mol [origin=calculated method=formula-sum]
Tc          884.61;      // K   [origin=predictive method=joback]
Pc          18.627;      // bar [origin=predictive method=joback]
omega       0.9196;      // -   [origin=predictive method=lee-kesler]
Tb          685.92;      // K   [origin=predictive method=joback]
HvapTb      66074.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.166 1.24032 -0.0006342 7.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-butyl o4-(phenylmethyl) butanedioate" "1-benzyl 4-butyl succinate" "butanedioic acid, butyl phenylmethyl ester" "4-o-benzyl 1-o-butyl butanedioate" );
standardThermochemistry
{
    dHf_298   -750960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     736.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-432910.0
}
