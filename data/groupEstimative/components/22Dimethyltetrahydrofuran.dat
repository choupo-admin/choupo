/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyltetrahydrofuran  (C6H12O, CAS 1003-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyltetrahydrofuran;
formula     C6H12O;
CAS         1003-17-4;
InChIKey    ZPDIRKNRUWXYLJ-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          585.00;      // K   [origin=predictive method=joback]
Pc          40.159;      // bar [origin=predictive method=joback]
omega       0.2526;      // -   [origin=predictive method=lee-kesler]
Tb          379.35;      // K   [origin=predictive method=joback]
HvapTb      32566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.72 0.99444 -0.0009487 3.89e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyloxolane" "tetrahydrodimethylfuran" "tetrahydrodimethyl furane" "furan, tetrahydrodimethyl-" "tetrahydrofuran, 2,2-dimethyl-" );
standardThermochemistry
{
    dHf_298   -223450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     357.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-55420.0
}
