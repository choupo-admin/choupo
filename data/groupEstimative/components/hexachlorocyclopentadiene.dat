/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexachlorocyclopentadiene  (C5Cl6, CAS 77-47-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexachlorocyclopentadiene;
formula     C5Cl6;
CAS         77-47-4;
InChIKey    VUNCWTMEJYMOOR-UHFFFAOYSA-N;
MW          272.755;      // g/mol [origin=calculated method=formula-sum]
Tc          831.20;      // K   [origin=predictive method=joback]
Pc          35.305;      // bar [origin=predictive method=joback]
omega       0.4570;      // -   [origin=predictive method=lee-kesler]
Tb          572.34;      // K   [origin=predictive method=joback]
HvapTb      55372.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.97 0.5932 -0.000737 3.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 1; } { group Cl_C=C_; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 1; } { group dC_ring; count 4; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5,5-hexakis(chloranyl)cyclopenta-1,3-diene" "graphlox" "perchlorocyclopentadiene" "hccpd" "1,3-cyclopentadiene, 1,2,3,4,5,5-hexachloro-" "1,2,3,4,5,5-hexachlorocyclopenta-1,3-diene" "c 56" "cyclopentadiene, hexachloro-" "perchloro-1,3-cyclopentadiene" "hexachloro-1,3-cyclopentadiene" "hexachlorcyklopentadien" "hexachlorocyclopentadiene(hccpd)" );
standardThermochemistry
{
    dHf_298   -95570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27900.0
}
