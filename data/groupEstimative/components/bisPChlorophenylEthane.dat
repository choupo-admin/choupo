/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(p-chlorophenyl)ethane  (C14H12Cl2, CAS 5216-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisPChlorophenylEthane;
formula     C14H12Cl2;
CAS         5216-35-3;
InChIKey    HTHGRQSFMYIQHB-UHFFFAOYSA-N;
MW          251.15;      // g/mol [origin=calculated method=formula-sum]
Tc          906.14;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       0.5930;      // -   [origin=predictive method=lee-kesler]
Tb          658.10;      // K   [origin=predictive method=joback]
HvapTb      61404.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.268 1.0706 -0.00070692 1.746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group ACCH2; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-[2-(4-chlorophenyl)ethyl]benzene" "ethane, 1,2-bis(p-chlorophenyl)-" "1-chloro-4-[2-(4-chlorophenyl)ethyl]benzene" "ethane,2-bis(p-chlorophenyl)-" "1-chloro-4-(4-chlorophenethyl)benzene" "benzene,1'-(1,2-ethanediyl)bis[4-chloro-" "benzene, 1,1'-(1,2-ethanediyl)bis(4-chloro-" "benzene, 1,1'-(1,2-ethanediyl)bis(4-chloro-)" "brd-k08731527-001-01-9" "benzene, 1,1'-(1,2-ethanediyl)bis(4-chloro- (9ci)" );
standardThermochemistry
{
    dHf_298   86350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     543.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248700.0
}
