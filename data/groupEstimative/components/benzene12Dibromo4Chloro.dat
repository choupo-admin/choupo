/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,2-dibromo-4-chloro-  (C6H3Br2Cl, CAS 60956-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene12Dibromo4Chloro;
formula     C6H3Br2Cl;
CAS         60956-24-3;
InChIKey    MTMKNVKLWIJHFL-UHFFFAOYSA-N;
MW          270.348;      // g/mol [origin=calculated method=formula-sum]
Tc          806.04;      // K   [origin=predictive method=joback]
Pc          51.609;      // bar [origin=predictive method=joback]
omega       0.5011;      // -   [origin=predictive method=lee-kesler]
Tb          543.27;      // K   [origin=predictive method=joback]
HvapTb      49805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.4 0.4591 -0.00036292 1.131e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCl; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-4-chloranyl-benzene" "3,4-dibromochlorobenzene" "1,2-dibromo-4-chlorobenzene" "1-chloro-3,4-dibromobenzene" );
standardThermochemistry
{
    dHf_298   83340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109500.0
}
