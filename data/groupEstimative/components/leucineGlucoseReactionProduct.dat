/*--------------------------------*- Choupo -*-----------------------*\
  Component: leucine, glucose reaction product  (C12H25NO8, CAS 68784-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        leucineGlucoseReactionProduct;
formula     C12H25NO8;
CAS         68784-18-9;
InChIKey    OXHDUMPNAUHUSI-FPBYJLLGSA-N;
MW          311.331;      // g/mol [origin=calculated method=formula-sum]
Tc          1540.54;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       1.3781;      // -   [origin=predictive method=lee-kesler]
Tb          1200.52;      // K   [origin=predictive method=joback]
HvapTb      158192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.652 1.23024 -0.0004944 -2.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 5; } { group OH; count 5; } { group CHO; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 6; } { group OH; count 5; } { group OdCH_al; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanyl-4-methyl-pentanoic acid;(2r,3s,4r,5r)-2,3,4,5,6-pentakis(oxidanyl)hexanal" "l-leucine, reaction products with d-glucose" "(2s)-2-amino-4-methylpentanoic acid; (2r,3s,4r,5r)-2,3,4,5,6-pentahydroxyhexanal" );
gibbsFormation
{
    dHf_298   -1597520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1051.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1130320.0
    phase     gas;
}
