/*--------------------------------*- Choupo -*-----------------------*\
  Component: bencainamide  (C13H20N2O, CAS 3690-53-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bencainamide;
formula     C13H20N2O;
CAS         3690-53-7;
InChIKey    ZDQCKWWIYRSDKD-UHFFFAOYSA-N;
MW          220.316;      // g/mol [origin=calculated method=formula-sum]
Tc          842.72;      // K   [origin=predictive method=joback]
Pc          23.542;      // bar [origin=predictive method=joback]
omega       0.8901;      // -   [origin=predictive method=lee-kesler]
Tb          640.20;      // K   [origin=predictive method=joback]
HvapTb      62033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.376 1.33204 -0.0008571 2.0786e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[2-(diethylamino)ethyl]benzamide" "n-(2-(diethylamino)ethyl)benzamide" "gc 30" "benzamide, n-(2-(diethylamino)ethyl)-" "n-(2-diethylaminoethyl)benzamide" );
gibbsFormation
{
    dHf_298   -66700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242240.0
    phase     gas;
}
