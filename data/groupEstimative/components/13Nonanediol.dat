/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-nonanediol  (C9H20O2, CAS 23433-07-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Nonanediol;
formula     C9H20O2;
CAS         23433-07-0;
InChIKey    CGNJFUJNEYIYRZ-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          748.60;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       1.3742;      // -   [origin=predictive method=lee-kesler]
Tb          589.44;      // K   [origin=predictive method=joback]
HvapTb      68598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.607 0.93272 -0.0005298 1.15e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonane-1,3-diol" "1,3-nonanediol, (3r)-" "(?a'a a'a currency)-1,3-nonanediol" );
gibbsFormation
{
    dHf_298   -538830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251180.0
    phase     gas;
}
