/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexyl-2-methylpyridine  (C12H19N, CAS 710-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexyl2Methylpyridine;
formula     C12H19N;
CAS         710-40-7;
InChIKey    CVQOAKGVDNOWHA-UHFFFAOYSA-N;
MW          177.291;      // g/mol [origin=calculated method=formula-sum]
Tc          768.63;      // K   [origin=predictive method=joback]
Pc          23.726;      // bar [origin=predictive method=joback]
omega       0.5828;      // -   [origin=predictive method=lee-kesler]
Tb          559.52;      // K   [origin=predictive method=joback]
HvapTb      51454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.565 1.0392 -0.00060242 1.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-hexyl-2-methyl-pyridine" "pyridine, 5-hexyl-2-methyl-" "pyridine,5-hexyl-2-methyl-" "2-picoline,5-hexyl- (7ci,8ci); 5-hexyl-2-methylpyridine" );
standardThermochemistry
{
    dHf_298   -33160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229990.0
}
