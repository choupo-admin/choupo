/*--------------------------------*- Choupo -*-----------------------*\
  Component: .alpha.,4-dimethyl-3-cyclohexene-1-acetaldehyde  (C10H16O, CAS 29548-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alpha4Dimethyl3Cyclohexene1Acetaldehyde;
formula     C10H16O;
CAS         29548-14-9;
InChIKey    UMEJBWOWZDRULR-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          710.28;      // K   [origin=predictive method=joback]
Pc          28.597;      // bar [origin=predictive method=joback]
omega       0.4830;      // -   [origin=predictive method=lee-kesler]
Tb          500.31;      // K   [origin=predictive method=joback]
HvapTb      45569.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.01 0.94084 -0.00051764 9.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-methylcyclohex-3-en-1-yl)propanal" "3-cyclohexene-1-acetaldehyde, .alpha.,4-dimethyl-" "1-p-menthen-9-al" "p-menth-1-ene-9-al" "p-menth-1-en-9-al" "1-p-menthen-9-al;p-menth-1-en-9-al" "3-cyclohexene-1-acetaldehyde,a,4-dimethyl-" "alpha,4-dimethyl-3-cyclohexene-1-acetaldehyde" "alpha,4-dimethylcyclohex-3-ene-1-acetaldehyde" "3-cyclohexene-1-acetaldehyde, alpha,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -239960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23860.0
    phase     gas;
}
