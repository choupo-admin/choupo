/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydroxypethidine  (C15H21NO3, CAS 468-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydroxypethidine;
formula     C15H21NO3;
CAS         468-56-4;
InChIKey    WTJBNMUWRKPFRS-UHFFFAOYSA-N;
MW          263.337;      // g/mol [origin=calculated method=formula-sum]
Tc          970.29;      // K   [origin=predictive method=joback]
Pc          26.298;      // bar [origin=predictive method=joback]
omega       0.9488;      // -   [origin=predictive method=lee-kesler]
Tb          736.28;      // K   [origin=predictive method=joback]
HvapTb      72830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.329 1.99724 -0.00175776 6.437e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-(3-hydroxyphenyl)-1-methyl-piperidine-4-carboxylate" "oxipethidine" "hydropetidine" "oxipethidinum" "oxydolantin" "oxypetidin" "bemidon" "bemidone" "demidone" "hoechst no. 10,446" "idrossipetidina [dcit]" "hoechst 10,446" );
gibbsFormation
{
    dHf_298   -467740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135320.0
    phase     gas;
}
