/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-undecen-4-ol  (C11H22O, CAS 22381-86-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Undecen4Ol;
formula     C11H22O;
CAS         22381-86-8;
InChIKey    CTPCMVYYXSEEPM-UHFFFAOYSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          714.00;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       0.9297;      // -   [origin=predictive method=lee-kesler]
Tb          547.18;      // K   [origin=predictive method=joback]
HvapTb      56329.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.684 1.10874 -0.000692 1.764e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undec-2-en-4-ol" "2-undecen-4-ol, (2e)-" );
standardThermochemistry
{
    dHf_298   -310660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17300.0
}
