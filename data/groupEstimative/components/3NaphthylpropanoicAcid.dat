/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-naphthylpropanoic acid  (C13H12O2, CAS 3243-42-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3NaphthylpropanoicAcid;
formula     C13H12O2;
CAS         3243-42-3;
InChIKey    PRLKVVMRQFFIOQ-UHFFFAOYSA-N;
MW          200.237;      // g/mol [origin=calculated method=formula-sum]
Tc          928.68;      // K   [origin=predictive method=joback]
Pc          30.323;      // bar [origin=predictive method=joback]
omega       0.8941;      // -   [origin=predictive method=lee-kesler]
Tb          693.19;      // K   [origin=predictive method=joback]
HvapTb      66274.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.378 1.1475 -0.00085688 2.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-naphthalen-1-ylpropanoic acid" "1-naphthalenepropanoic acid" "3-(1-naphthyl)propionic acid" "3-(1-naphthyl)-propionic acid" "3-(naphthalen-1-yl)propanoic acid" "1-naphthalenepropionic acid" "3-(1-naphthyl)propanoic acid" "alpha-naphthylpropionate" "1-naphthalenepropanoicacid" "3-(naphth-1-yl)propanoic acid" "3-naphthalen-1-ylpropionic acid" "beta-(1-naphthyl)propionic acid" );
gibbsFormation
{
    dHf_298   -245790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75900.0
    phase     gas;
}
