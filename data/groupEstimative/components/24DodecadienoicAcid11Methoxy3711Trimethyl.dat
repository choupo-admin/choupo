/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dodecadienoic acid, 11-methoxy-3,7,11-trimethyl-  (C16H28O3, CAS 207597-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DodecadienoicAcid11Methoxy3711Trimethyl;
formula     C16H28O3;
CAS         207597-75-9;
InChIKey    MNYBEULOKRVZKY-UHFFFAOYSA-N;
MW          268.397;      // g/mol [origin=calculated method=formula-sum]
Tc          935.64;      // K   [origin=predictive method=joback]
Pc          15.427;      // bar [origin=predictive method=joback]
omega       0.9512;      // -   [origin=predictive method=lee-kesler]
Tb          738.14;      // K   [origin=predictive method=joback]
HvapTb      69096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.766 1.6831 -0.0011531 3.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group dCH; count 3; } { group dC; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11-methoxy-3,7,11-trimethyl-dodeca-2,4-dienoic acid" "2,4-dodecadienoic acid, 11-methoxy-3,7,11-trimethyl-, (2z,4e)-" "(2e,4e)-11-methoxy-3,7,11-trimethyl-dodeca-2,4-dienoic acid" "11-methoxy-3,7s,11-trimethyl-2e,4e-dodecadienoic acid" "2,4-dodecadienoic acid, 11-methoxy-3,7,11-trimethyl-, (2e,4e)-" );
gibbsFormation
{
    dHf_298   -645440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     777.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-212780.0
    phase     gas;
}
