/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxyethyl)-6-hydroxyhexanamide  (C10H21NO4, CAS 68052-21-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2Hydroxyethyl6Hydroxyhexanamide;
formula     C10H21NO4;
CAS         68052-21-1;
InChIKey    ISYSXHXTFFZRKN-UHFFFAOYSA-N;
MW          219.281;      // g/mol [origin=calculated method=formula-sum]
Tc          945.66;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       1.9269;      // -   [origin=predictive method=lee-kesler]
Tb          771.25;      // K   [origin=predictive method=joback]
HvapTb      96680.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.339 1.1517 -0.0007053 1.6556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group OH; count 3; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group OH; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-hydroxyethyl)-6-oxidanyl-hexanamide" "6-hydroxy-n,n-bis(2-hydroxyethyl)hexanamide" "hexanamide, 6-hydroxy-n,n-bis(2-hydroxyethyl)-" );
gibbsFormation
{
    dHf_298   -751470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     740.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-395280.0
    phase     gas;
}
