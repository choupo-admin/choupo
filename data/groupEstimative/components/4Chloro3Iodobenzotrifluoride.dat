/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-3-iodobenzotrifluoride  (C7H3ClF3I, CAS 672-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro3Iodobenzotrifluoride;
formula     C7H3ClF3I;
CAS         672-57-1;
InChIKey    SSLWFPKNYZEOTH-UHFFFAOYSA-N;
MW          306.445;      // g/mol [origin=calculated method=formula-sum]
Tc          757.12;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.4207;      // -   [origin=predictive method=lee-kesler]
Tb          521.55;      // K   [origin=predictive method=joback]
HvapTb      44787.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.6 0.6779 -0.00057692 1.854e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCl; count 1; } { group I; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-iodanyl-4-(trifluoromethyl)benzene" "1-chloro-2-iodo-4-(trifluoromethyl)benzene" "3-iodo-4-chlorobenzotrifluoride" "4-chloro-3-iodobenzo trifluoride" "benzene, 1-chloro-2-iodo-4-(trifluoromethyl)-" "4-chloro-3-iodotrifluorotoluene" "1-chloro-2-iodo-4-trifluoromethylbenzene" "i335" "2-chloro-5-(trifluoromethyl)iodobenzene" "4-chloro-3-iodo-alpha,alpha,alpha-trifluorotoluene" );
standardThermochemistry
{
    dHf_298   -510170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-434190.0
}
