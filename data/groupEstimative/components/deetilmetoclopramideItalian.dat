/*--------------------------------*- Choupo -*-----------------------*\
  Component: deetilmetoclopramide [italian]  (C12H18ClN3O2, CAS 27260-19-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deetilmetoclopramideItalian;
formula     C12H18ClN3O2;
CAS         27260-19-1;
InChIKey    RTQMQUZXBADBGJ-UHFFFAOYSA-N;
MW          271.745;      // g/mol [origin=calculated method=formula-sum]
Tc          1020.77;      // K   [origin=predictive method=joback]
Pc          25.201;      // bar [origin=predictive method=joback]
omega       1.2761;      // -   [origin=predictive method=lee-kesler]
Tb          802.37;      // K   [origin=predictive method=joback]
HvapTb      83622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.793 1.01634 -0.00049038 5.956e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 1; } { group CH2NH; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanyl-5-chloranyl-n-[2-(ethylamino)ethyl]-2-methoxy-benzamide" "4-amino-5-chloro-n-(2-(ethylamino)ethyl)-o-anisamide" "4-amino-5-chloro-n-(2-ethylaminoethyl)-2-methoxybenzamide" "benzamide, 4-amino-5-chloro-n-(2-(ethylamino)ethyl)-2-methoxy-" "o-anisamide, 4-amino-5-chloro-n-(2-(ethylamino)ethyl)-" "4-amino-5-chloro-n-[2-(ethylamino)ethyl]-o-anisamide" "deetilmetoclopramide" "monodeethylated-mcp" "mdmcp" "deetilato metoclopramide" "n-desethyl metoclopramide" "n-(ethylaminoethyl)-2-methoxy-4-amino-5-chlorobenzamide" );
standardThermochemistry
{
    dHf_298   -208700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     702.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133060.0
}
