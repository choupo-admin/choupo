/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propene, 3-propoxy-  (C6H12O, CAS 1471-03-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propene3Propoxy;
formula     C6H12O;
CAS         1471-03-0;
InChIKey    LWJHSQQHGRQCKO-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          523.97;      // K   [origin=predictive method=joback]
Pc          31.955;      // bar [origin=predictive method=joback]
omega       0.3553;      // -   [origin=predictive method=lee-kesler]
Tb          355.98;      // K   [origin=predictive method=joback]
HvapTb      30690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.943 0.49062 -0.0002145 2.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-prop-2-enoxypropane" "propyl allyl ether" "allyl propyl ether" "ether, allyl propyl" "allyl n-propyl ether" "1-allyloxy-propane" "ether, allyl propyl (8ci)" );
standardThermochemistry
{
    dHf_298   -173960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17520.0
}
