/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dihydro-1,11-dimethylchrysene  (C20H18, CAS 52171-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dihydro111Dimethylchrysene;
formula     C20H18;
CAS         52171-93-4;
InChIKey    PEWVKAUVYOKXKY-UHFFFAOYSA-N;
MW          258.364;      // g/mol [origin=calculated method=formula-sum]
Tc          1012.55;      // K   [origin=predictive method=joback]
Pc          21.276;      // bar [origin=predictive method=joback]
omega       0.7481;      // -   [origin=predictive method=lee-kesler]
Tb          761.58;      // K   [origin=predictive method=joback]
HvapTb      69666.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.11 1.63184 -0.00125012 3.918e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 7; } { group AC; count 5; } { group ACCH3; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,11-dimethyl-3,4-dihydrochrysene" "chrysene, 3,4-dihydro-1,11-dimethyl-" );
gibbsFormation
{
    dHf_298   249950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=481400.0
    phase     gas;
}
