/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-cyclopropanedicarboxylic acid  (C5H6O4, CAS 598-10-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11CyclopropanedicarboxylicAcid;
formula     C5H6O4;
CAS         598-10-7;
InChIKey    FDKLLWKMYAMLIF-UHFFFAOYSA-N;
MW          130.099;      // g/mol [origin=calculated method=formula-sum]
Tc          842.11;      // K   [origin=predictive method=joback]
Pc          55.278;      // bar [origin=predictive method=joback]
omega       1.0020;      // -   [origin=predictive method=lee-kesler]
Tb          612.00;      // K   [origin=predictive method=joback]
HvapTb      59814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.69 1.0232 -0.0011462 5.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropane-1,1-dicarboxylic acid" "cyclopropane-1,1-dicarboxylicacid" "1,1-cyclopropanedicarboxylate" "cyclopropane, 3" "1,1-dicarboxycyclopropane" "agn-pc-0d5ugv" "cyclopropanedicarboxylic acid" "cycloprpopane-1,1-dicarboxylic acid;1,1-cyclopropane dicarboxylic acid;cyclopropane-1,1-dicarboxylate;cyclopropane-1,1-dicarboxylic acid;" );
gibbsFormation
{
    dHf_298   -759030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-641340.0
    phase     gas;
}
