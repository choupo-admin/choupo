/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl acrylate  (C7H12O2, CAS 141-32-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylAcrylate;
formula     C7H12O2;
CAS         141-32-2;
InChIKey    CQEYYJKEWSMYFG-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          591.01;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.4752;      // -   [origin=predictive method=lee-kesler]
Tb          414.66;      // K   [origin=predictive method=joback]
HvapTb      37913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.943 0.59402 -0.0002853 3.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate" "n-butyl acrylate" "acrylic acid butyl ester" "2-propenoic acid, butyl ester" "n-butyl propenoate" "butyl 2-propenoate" "acrylic acid, butyl ester" "acrylic acid n-butyl ester" "2-propenoic acid butyl ester" "poly(butyl acrylate) solution" "butyl acrylate homopolymer" "poly(butyl acrylate)" );
standardThermochemistry
{
    dHf_298   -379660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-214470.0
}
