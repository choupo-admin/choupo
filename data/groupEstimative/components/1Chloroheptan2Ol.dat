/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloroheptan-2-ol  (C7H15ClO, CAS 53660-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloroheptan2Ol;
formula     C7H15ClO;
CAS         53660-21-2;
InChIKey    PLOHTJPTRQIWDY-UHFFFAOYSA-N;
MW          150.646;      // g/mol [origin=calculated method=formula-sum]
Tc          658.64;      // K   [origin=predictive method=joback]
Pc          29.959;      // bar [origin=predictive method=joback]
omega       0.8437;      // -   [origin=predictive method=lee-kesler]
Tb          488.93;      // K   [origin=predictive method=joback]
HvapTb      51852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.025 0.71552 -0.000411 9.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group Cl; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylheptan-2-ol" "2-heptanol, 1-chloro-" "2-heptanol, 1-chloro-, (r)-" "agn-pc-00bjcv" );
standardThermochemistry
{
    dHf_298   -361060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143130.0
}
