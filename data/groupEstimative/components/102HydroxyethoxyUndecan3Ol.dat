/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-(2-hydroxyethoxy)undecan-3-ol  (C13H28O3, CAS 68413-39-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        102HydroxyethoxyUndecan3Ol;
formula     C13H28O3;
CAS         68413-39-8;
InChIKey    ZVYGUPOBWRJQGG-UHFFFAOYSA-N;
MW          232.364;      // g/mol [origin=calculated method=formula-sum]
Tc          868.53;      // K   [origin=predictive method=joback]
Pc          19.186;      // bar [origin=predictive method=joback]
omega       1.4286;      // -   [origin=predictive method=lee-kesler]
Tb          702.94;      // K   [origin=predictive method=joback]
HvapTb      79524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.789 1.25544 -0.0006396 1.073e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 2; } { group OH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 2; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-(2-hydroxyethyloxy)undecan-3-ol" "alcohols, c10-secondary, beta-(2-hydroxyethoxy)" );
standardThermochemistry
{
    dHf_298   -758890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-324940.0
}
