/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3-(2-dodecoxyethoxy)propanoate  (C18H36O4, CAS 7448-04-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl32DodecoxyethoxyPropanoate;
formula     C18H36O4;
CAS         7448-04-6;
InChIKey    MCJWMLZQJHEVEA-UHFFFAOYSA-N;
MW          316.482;      // g/mol [origin=calculated method=formula-sum]
Tc          883.33;      // K   [origin=predictive method=joback]
Pc          11.299;      // bar [origin=predictive method=joback]
omega       0.9652;      // -   [origin=predictive method=lee-kesler]
Tb          714.50;      // K   [origin=predictive method=joback]
HvapTb      67889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.935 1.53264 -0.0006388 3.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH2COO; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propionic acid, 3-dodecyloxy-2-ethoxy-, methyl ester" "methyl 3-[2-(dodecyloxy)ethoxy]propanoate" "propionic acid, 3-[2-(dodecyloxy)ethoxy]- methyl ester" );
standardThermochemistry
{
    dHf_298   -996570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     930.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-419690.0
}
