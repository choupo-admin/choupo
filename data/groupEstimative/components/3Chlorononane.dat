/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chlorononane  (C9H19Cl, CAS 28123-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chlorononane;
formula     C9H19Cl;
CAS         28123-68-4;
InChIKey    ASQUFLQVFQDUFF-UHFFFAOYSA-N;
MW          162.701;      // g/mol [origin=calculated method=formula-sum]
Tc          616.13;      // K   [origin=predictive method=joback]
Pc          22.440;      // bar [origin=predictive method=joback]
omega       0.4760;      // -   [origin=predictive method=lee-kesler]
Tb          442.51;      // K   [origin=predictive method=joback]
HvapTb      39625.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.916 0.87154 -0.0004894 1.044e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylnonane" "nonane, 3-chloro-" );
standardThermochemistry
{
    dHf_298   -250110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10530.0
}
