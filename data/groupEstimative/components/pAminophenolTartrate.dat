/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-aminophenol tartrate  (C10H13NO7, CAS 69782-45-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pAminophenolTartrate;
formula     C10H13NO7;
CAS         69782-45-2;
InChIKey    QWEVPEOCAQELJP-LREBCSMRSA-N;
MW          259.214;      // g/mol [origin=calculated method=formula-sum]
Tc          1329.12;      // K   [origin=predictive method=joback]
Pc          54.788;      // bar [origin=predictive method=joback]
omega       2.4881;      // -   [origin=predictive method=lee-kesler]
Tb          1084.13;      // K   [origin=predictive method=joback]
HvapTb      130989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.7 1.0666 -0.00064876 1.348e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 4; } { group OH; count 2; } { group ACOH; count 1; } { group ACNH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group OH_phenol; count 1; } { group COOH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-azanylphenol;(2r,3r)-2,3-bis(oxidanyl)butanedioic acid" "phenol, p-amino-, tartrate" "4-aminophenol; (2r,3r)-2,3-dihydroxybutanedioic acid" );
gibbsFormation
{
    dHf_298   -1283900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     813.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1013540.0
    phase     gas;
}
