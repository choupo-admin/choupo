/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[4.2.0]octa-1,5-diene  (C8H10, CAS 42206-10-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo420Octa15Diene;
formula     C8H10;
CAS         42206-10-0;
InChIKey    LKVVIADCTAYVMJ-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          640.98;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.3160;      // -   [origin=predictive method=lee-kesler]
Tb          422.28;      // K   [origin=predictive method=joback]
HvapTb      36098.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.83 0.8684 -0.00071028 2.378e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(4.2.0)octa-1,5-diene" );
standardThermochemistry
{
    dHf_298   58130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=169860.0
}
