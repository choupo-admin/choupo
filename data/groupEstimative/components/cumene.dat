/*--------------------------------*- Choupo -*-----------------------*\
  Component: cumene  (C9H12, CAS 98-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cumene;
formula     C9H12;
CAS         98-82-8;
InChIKey    RWGFKTVRMDUZSP-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          644.01;      // K   [origin=predictive method=joback]
Pc          32.916;      // bar [origin=predictive method=joback]
omega       0.3105;      // -   [origin=predictive method=lee-kesler]
Tb          431.76;      // K   [origin=predictive method=joback]
HvapTb      37516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.88 0.78584 -0.0005002 1.209e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-Methylethyl)benzene" "2-phenylpropane" "Benzene, (1-methylethyl)-" "cumol" "isopropylbenzene" "i-propylbenzene" "isopropylbenzol" "cumeen" "isopropilbenzene" "isopropylbenzeen" "2-fenilpropano" "2-fenyl-propaan" );
gibbsFormation
{
    dHf_298   2160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134870.0
    phase     gas;
}
