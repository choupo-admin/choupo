/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16-azatricyclo(9.2.2.14,8)hexadeca-2,4,6,8(16),9,11,13,14-octaene  (C15H11N, CAS 51647-34-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Azatricyclo922148Hexadeca2468169111314Octaene;
formula     C15H11N;
CAS         51647-34-8;
InChIKey    NQUFFEOQBCAXSM-WGEIWTTOSA-N;
MW          205.26;      // g/mol [origin=calculated method=formula-sum]
Tc          948.86;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.5805;      // -   [origin=predictive method=lee-kesler]
Tb          673.82;      // K   [origin=predictive method=joback]
HvapTb      62048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-85.64 1.24156 -0.00093354 2.763e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 11; } { group dC_ring; count 4; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "16-azatricyclo[9.2.2.14,8]hexadeca-2,4,6,8(16),9,11,13,14-octaene" );
gibbsFormation
{
    dHf_298   332520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=474310.0
    phase     gas;
}
