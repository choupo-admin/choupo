/*--------------------------------*- Choupo -*-----------------------*\
  Component: wieland-miescher ketone  (C11H14O2, CAS 20007-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        wielandMiescherKetone;
formula     C11H14O2;
CAS         20007-72-1;
InChIKey    DNHDRUMZDHWHKG-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          889.14;      // K   [origin=predictive method=joback]
Pc          32.840;      // bar [origin=predictive method=joback]
omega       0.5467;      // -   [origin=predictive method=lee-kesler]
Tb          626.53;      // K   [origin=predictive method=joback]
HvapTb      49200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.07 1.17852 -0.00084964 2.782e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8a-methyl-3,4,7,8-tetrahydro-2h-naphthalene-1,6-dione" "miescher-wieland ketone" "8a-methyl-3,4,8,8a-tetrahydro-1,6(2h,7h)-naphthalenedione" "9-(s)-methyl-.delta.-5(10)-octalin-1,6-dione" "wieland-michler ketone" "wieland cmiescher ketone" "9(s)-methyl-delta-5(10)-octalin-1,6-dione" "(+/-)-9-methyl-5(10)-octaline-1,6-dione" "8a-methyl-2,3,4,7,8,8a-hexahydronaphthalene-1,6-dione" "3,4,8,8a-tetrahydro-8a-methyl-(2h,7h)naphthalene-1,6-dione" "8a-methyl-1,2,3,4,6,7,8,8a-octahydronaphthalene-1,6-dione" "8a-methyl-3,4,8,8a-tetrahydronaphthalene-1,6(2h,7h)-dione" );
gibbsFormation
{
    dHf_298   -342920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-107790.0
    phase     gas;
}
