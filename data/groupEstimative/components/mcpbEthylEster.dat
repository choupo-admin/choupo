/*--------------------------------*- Choupo -*-----------------------*\
  Component: mcpb ethyl ester  (C13H17ClO3, CAS 10443-70-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mcpbEthylEster;
formula     C13H17ClO3;
CAS         10443-70-6;
InChIKey    XNKARWLGLZGMGX-UHFFFAOYSA-N;
MW          256.726;      // g/mol [origin=calculated method=formula-sum]
Tc          856.21;      // K   [origin=predictive method=joback]
Pc          20.401;      // bar [origin=predictive method=joback]
omega       0.8176;      // -   [origin=predictive method=lee-kesler]
Tb          651.75;      // K   [origin=predictive method=joback]
HvapTb      62334.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.564 0.92974 -0.00039532 1.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2COO; count 1; } { group CH2O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-(4-chloranyl-2-methyl-phenoxy)butanoate" "mcpb ethyl" "mcpb-ethyl" "mcpbe" "mcpb-ethyl [iso]" "butanoic acid, 4-(4-chloro-2-methylphenoxy)-, ethyl ester" "ethyl 4-(2-methyl-4-chlorophenoxy)butylate" "ethyl 4-(4-chloro-2-methylphenoxy)butanoate" "butyric acid, 4-((4-chloro-o-tolyl)oxy)-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -563300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275570.0
}
