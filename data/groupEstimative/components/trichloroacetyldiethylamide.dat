/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichloroacetyldiethylamide  (C6H10Cl3NO, CAS 2430-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichloroacetyldiethylamide;
formula     C6H10Cl3NO;
CAS         2430-00-4;
InChIKey    OIWFZENWZGPLQZ-UHFFFAOYSA-N;
MW          218.502;      // g/mol [origin=calculated method=formula-sum]
Tc          719.23;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.5666;      // -   [origin=predictive method=lee-kesler]
Tb          512.25;      // K   [origin=predictive method=joback]
HvapTb      49598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.302 0.81594 -0.0006295 1.8746e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CCl3; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group Cl; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-tris(chloranyl)-n,n-diethyl-ethanamide" "2,2,2-trichloro-n,n-diethylacetamide" "acetamide, 2,2,2-trichloro-n,n-diethyl-" "2,2,2-trichloro-n,n-diethyl-acetamide" );
gibbsFormation
{
    dHf_298   -268190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     493.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51450.0
    phase     gas;
}
