/*--------------------------------*- Choupo -*-----------------------*\
  Component: defekton (tn)  (C32H42N4O5, CAS 100482-23-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        defektonTn;
formula     C32H42N4O5;
CAS         100482-23-3;
InChIKey    LQMNVYGQJJRMRR-BTJKTKAUSA-N;
MW          562.711;      // g/mol [origin=calculated method=formula-sum]
Tc          1860.63;      // K   [origin=predictive method=joback]
Pc          12.521;      // bar [origin=predictive method=joback]
omega       1.0004;      // -   [origin=predictive method=lee-kesler]
Tb          1497.99;      // K   [origin=predictive method=joback]
HvapTb      150520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-275.757 3.8568 -0.00298682 9.3376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH2N; count 3; } { group COOH; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH; count 2; } { group CH2_ring; count 11; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group CdO; count 1; } { group COOH; count 2; } { group NH2; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-but-2-enedioic acid;1-[3-(5,6-dihydrobenzo[b][1]benzazepin-11-yl)propyl]-4-piperidin-1-yl-piperidine-4-carboxamide" "carpipramine maleate" "carpipramine maleate (jan)" );
standardThermochemistry
{
    dHf_298   -568990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1454.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137510.0
}
