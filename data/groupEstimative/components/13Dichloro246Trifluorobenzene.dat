/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dichloro-2,4,6-trifluorobenzene  (C6HCl2F3, CAS 2368-53-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dichloro246Trifluorobenzene;
formula     C6HCl2F3;
CAS         2368-53-8;
InChIKey    UOGVNYNJSZHQCN-UHFFFAOYSA-N;
MW          200.968;      // g/mol [origin=calculated method=formula-sum]
Tc          656.00;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.4823;      // -   [origin=predictive method=lee-kesler]
Tb          456.15;      // K   [origin=predictive method=joback]
HvapTb      40193.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (64.78 0.3059 -0.00015564 2.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group ACCl; count 2; } { group ACF; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 1; } { group dC_ring; count 5; } { group F; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(chloranyl)-1,3,5-tris(fluoranyl)benzene" "2,4-dichloro-1,3,5-trifluorobenzene" "benzene,2,4-dichloro-1,3,5-trifluoro-" "1,3,5-trifluoro-2,4-dichlorobenzene;1,3-dichloro-2,4,6-trifluorobenzene; 2,4-dichloro-1,3,5-trifluorobenzene" );
gibbsFormation
{
    dHf_298   -596330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-534760.0
    phase     gas;
}
