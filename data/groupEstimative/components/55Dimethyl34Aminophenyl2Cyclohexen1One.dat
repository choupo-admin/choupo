/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-[4-aminophenyl]-2-cyclohexen-1-one  (C14H17NO, CAS 72036-57-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl34Aminophenyl2Cyclohexen1One;
formula     C14H17NO;
CAS         72036-57-8;
InChIKey    KMDFZRUKDNJUKH-UHFFFAOYSA-N;
MW          215.296;      // g/mol [origin=calculated method=formula-sum]
Tc          979.74;      // K   [origin=predictive method=joback]
Pc          28.203;      // bar [origin=predictive method=joback]
omega       0.6962;      // -   [origin=predictive method=lee-kesler]
Tb          715.86;      // K   [origin=predictive method=joback]
HvapTb      64816.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.04 1.38754 -0.0010352 3.409e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group CdO_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-aminophenyl)-5,5-dimethyl-cyclohex-2-en-1-one" "5,5-dimethyl-3-(4-aminophenyl)-2-cyclohexen-1-one" "5,5-dimethyl-3-(4-aminophenyl)cyclohex-2-enone" "3-(4-aminophenyl)-5,5-dimethyl-2-cyclohexenone" "2-cyclohexen-1-one,3-(4-aminophenyl)-5,5-dimethyl-" "3-(4-aminophenyl)-5,5-dimethylcyclohex-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -95270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152930.0
}
