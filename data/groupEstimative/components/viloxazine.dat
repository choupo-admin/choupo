/*--------------------------------*- Choupo -*-----------------------*\
  Component: viloxazine  (C13H19NO3, CAS 46817-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        viloxazine;
formula     C13H19NO3;
CAS         46817-91-8;
InChIKey    YWPHCCPCQOJSGZ-UHFFFAOYSA-N;
MW          237.299;      // g/mol [origin=calculated method=formula-sum]
Tc          899.15;      // K   [origin=predictive method=joback]
Pc          25.951;      // bar [origin=predictive method=joback]
omega       0.7762;      // -   [origin=predictive method=lee-kesler]
Tb          668.59;      // K   [origin=predictive method=joback]
HvapTb      63987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.898 1.07972 -0.00043206 2.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 2; } { group FCH2O; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2-ethoxyphenoxy)methyl]morpholine" "emovit" "viloxazin" "2-((2-ethoxyphenoxy)methyl)morpholine" "viloxazinum [inn-latin]" "morpholine, 2-((2-ethoxyphenoxy)methyl)-" "morpholine, 2-[(2-ethoxyphenoxy)methyl]-" "2-(2-ethoxyphenoxymethyl)tetrahydro-1,4-oxazine" "viloxazina" "viloxazinum" "viloxazine (inn)" "ici-58,834" );
standardThermochemistry
{
    dHf_298   -390900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22600.0
}
