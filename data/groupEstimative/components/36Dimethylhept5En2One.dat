/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dimethylhept-5-en-2-one  (C9H16O, CAS 760-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dimethylhept5En2One;
formula     C9H16O;
CAS         760-97-4;
InChIKey    GFFWTYGLHZTFHM-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          652.93;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.4789;      // -   [origin=predictive method=lee-kesler]
Tb          462.99;      // K   [origin=predictive method=joback]
HvapTb      42024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.489 0.85668 -0.0005364 1.3556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-hepten-2-one, 3,6-dimethyl-" "5-hepten-2-one,3,6-dimethyl-" "2,5-dimethyl-2-hepten-6-one;3,6-dimethyl-5-hepten-2-one" );
gibbsFormation
{
    dHf_298   -239520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34790.0
    phase     gas;
}
