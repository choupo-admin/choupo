/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-4-(prop-2-yn-1-yloxy)benzene  (C13H16O, CAS 48144-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl4Prop2Yn1YloxyBenzene;
formula     C13H16O;
CAS         48144-15-6;
InChIKey    LCKMFILTJDWOQW-UHFFFAOYSA-N;
MW          188.27;      // g/mol [origin=calculated method=formula-sum]
Tc          761.21;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.4405;      // -   [origin=predictive method=lee-kesler]
Tb          538.01;      // K   [origin=predictive method=joback]
HvapTb      48442.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.729 1.06916 -0.00070429 1.7959e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-prop-2-ynoxy-benzene" "benzene, 1-(1,1-dimethylethyl)-4-(2-propynyloxy)-" "4-tert-butylphenyl propargyl ether" "1-tert-butyl-4-prop-2-ynoxybenzene" "1-prop-2-ynoxy-4-tert-butyl-benzene" );
gibbsFormation
{
    dHf_298   64340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282270.0
    phase     gas;
}
