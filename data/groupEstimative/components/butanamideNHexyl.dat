/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanamide, n-hexyl-  (C10H21NO, CAS 10264-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanamideNHexyl;
formula     C10H21NO;
CAS         10264-17-2;
InChIKey    YRVDTEDFGDNSLD-UHFFFAOYSA-N;
MW          171.284;      // g/mol [origin=calculated method=formula-sum]
Tc          708.00;      // K   [origin=predictive method=joback]
Pc          22.633;      // bar [origin=predictive method=joback]
omega       0.7837;      // -   [origin=predictive method=lee-kesler]
Tb          532.44;      // K   [origin=predictive method=joback]
HvapTb      51036.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.053 1.00204 -0.0005501 1.0926e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-hexylbutanamide" "butyramide, n-hexyl-" "n-hexylbutyramide" );
standardThermochemistry
{
    dHf_298   -308840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6210.0
}
