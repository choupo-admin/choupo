/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetoacetic acid  (C4H6O3, CAS 541-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetoaceticAcid;
formula     C4H6O3;
CAS         541-50-4;
InChIKey    WDJHALXBUFZDSR-UHFFFAOYSA-N;
MW          102.089;      // g/mol [origin=calculated method=formula-sum]
Tc          694.45;      // K   [origin=predictive method=joback]
Pc          47.562;      // bar [origin=predictive method=joback]
omega       0.7268;      // -   [origin=predictive method=lee-kesler]
Tb          490.50;      // K   [origin=predictive method=joback]
HvapTb      48408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.211 0.40662 -0.0002477 5.536e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-oxidanylidenebutanoic acid" "3-ketobutyrate" "3-oxobutyric acid" "3-oxobutanoic acid" "oxobutyrate" "beta-ketobutyric acid" "3-ketobutyric acid" "diacetic acid" "3-oxo-butanoic acid" "butanoic acid, 3-oxo-" "3-oxo-butyric acid" "3-oxobutanate" );
gibbsFormation
{
    dHf_298   -588740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     391.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-490030.0
    phase     gas;
}
