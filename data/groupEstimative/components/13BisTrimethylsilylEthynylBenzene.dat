/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis[(trimethylsilyl)ethynyl]benzene  (C16H22Si2, CAS 38170-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H22Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        13BisTrimethylsilylEthynylBenzene;
formula     C16H22Si2;
CAS         38170-80-8;
InChIKey    ASZOZZMGMNVKDV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          270.522;      // g/mol [origin=calculated method=formula-sum]
Tc          871.98;      // K   [origin=predictive method=joback]
Pc          17.985;      // bar [origin=predictive method=joback]
omega       0.3056;      // -   [origin=predictive method=lee-kesler]
Tb          618.14;      // K   [origin=predictive method=joback]
HvapTb      59040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (85.49 0.67352 0.00020312 -2.9664e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 4; } { group AC; count 2; } { group C_C; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group tC; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[2-[3-(2-trimethylsilylethynyl)phenyl]ethynyl]silane" "1,3-bis((trimethylsilyl)ethynyl)benzene" "benzene,1,3-bis[2-(trimethylsilyl)ethynyl]-" "4-[3-(3,3-dimethyl-3-silabut-1-ynyl)phenyl]-2,2-dimethyl-2-silabut-3-yne" "(1,3-phenylenediethyne-2,1-diyl)bis(trimethylsilane);1,3-bis((trimethylsilyl)ethynyl)benzene;" );
gibbsFormation
{
    dHf_298   172850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     863.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=382700.0
    phase     gas;
}
