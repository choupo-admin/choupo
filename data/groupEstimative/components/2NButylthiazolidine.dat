/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-n-butylthiazolidine  (C7H15NS, CAS 30188-50-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NButylthiazolidine;
formula     C7H15NS;
CAS         30188-50-2;
InChIKey    BOOIWYNDUXYILL-UHFFFAOYSA-N;
MW          145.264;      // g/mol [origin=calculated method=formula-sum]
Tc          689.34;      // K   [origin=predictive method=joback]
Pc          34.971;      // bar [origin=predictive method=joback]
omega       0.4204;      // -   [origin=predictive method=lee-kesler]
Tb          471.42;      // K   [origin=predictive method=joback]
HvapTb      44003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.217 0.80153 -0.0004425 8.75e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butyl-1,3-thiazolidine" "thiazolidine, 2-butyl-" "2-butylthiazolidine" );
gibbsFormation
{
    dHf_298   -44260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172180.0
    phase     gas;
}
