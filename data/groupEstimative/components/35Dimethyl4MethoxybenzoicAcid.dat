/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dimethyl-4-methoxybenzoic acid  (C10H12O3, CAS 21553-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dimethyl4MethoxybenzoicAcid;
formula     C10H12O3;
CAS         21553-46-8;
InChIKey    WXVQURJGDUNJCS-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          858.00;      // K   [origin=predictive method=joback]
Pc          30.190;      // bar [origin=predictive method=joback]
omega       0.8606;      // -   [origin=predictive method=lee-kesler]
Tb          637.95;      // K   [origin=predictive method=joback]
HvapTb      61690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.89 0.68406 -0.00031188 3.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-3,5-dimethyl-benzoic acid" "3,5-dimethyl-p-anisic acid" "4-methoxy-3,5-dimethylbenzoic acid" "4-methoxy-3,5-dimethylbenzoicacid" "3,5-dimethyl anisic acid" );
gibbsFormation
{
    dHf_298   -530100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-332070.0
    phase     gas;
}
