/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methoxy-4-(1-propan-2-ylcyclopropyl)benzene  (C13H18O, CAS 63340-03-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methoxy41Propan2YlcyclopropylBenzene;
formula     C13H18O;
CAS         63340-03-4;
InChIKey    IPZVRJFKWVHDQG-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          781.57;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       0.4987;      // -   [origin=predictive method=lee-kesler]
Tb          557.66;      // K   [origin=predictive method=joback]
HvapTb      48254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.95 1.48596 -0.00129256 4.861e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1-methoxy-4-(1-(1-methylethyl)cyclopropyl)-" );
standardThermochemistry
{
    dHf_298   -136050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109180.0
}
