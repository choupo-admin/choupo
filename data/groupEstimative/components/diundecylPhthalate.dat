/*--------------------------------*- Choupo -*-----------------------*\
  Component: diundecyl phthalate  (C30H50O4, CAS 3648-20-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diundecylPhthalate;
formula     C30H50O4;
CAS         3648-20-2;
InChIKey    QQVHEQUEHCEAKS-UHFFFAOYSA-N;
MW          474.726;      // g/mol [origin=calculated method=formula-sum]
Tc          1276.36;      // K   [origin=predictive method=joback]
Pc          7.028;      // bar [origin=predictive method=joback]
omega       0.5715;      // -   [origin=predictive method=lee-kesler]
Tb          1034.10;      // K   [origin=predictive method=joback]
HvapTb      100126.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.83 2.60584 -0.00138316 2.322e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 20; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 20; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diundecyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, diundecyl ester" "di-711-phthalate" "di-n-undecyl phthalate" "1,2-benzenedicarboxylic acid, 1,2-diundecyl ester" "undecyl 2-(undecyloxycarbonyl)benzoate" "phthalic acid diundecyl ester" "ls-95" "phthalic acid, diundecyl ester, branched and linear" );
gibbsFormation
{
    dHf_298   -1072030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1314.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-316240.0
    phase     gas;
}
