/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-5-hexene  (C12H16, CAS 1588-44-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl5Hexene;
formula     C12H16;
CAS         1588-44-9;
InChIKey    UWAVXORKDISRCD-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          701.11;      // K   [origin=predictive method=joback]
Pc          25.075;      // bar [origin=predictive method=joback]
omega       0.4629;      // -   [origin=predictive method=lee-kesler]
Tb          497.52;      // K   [origin=predictive method=joback]
HvapTb      43912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.916 1.0449 -0.0006831 1.745e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-5-enylbenzene" "hex-5-enyl-benzene" "benzene, 5-hexenyl-" "6-phenyl-1-hexene" );
gibbsFormation
{
    dHf_298   70950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=250410.0
    phase     gas;
}
