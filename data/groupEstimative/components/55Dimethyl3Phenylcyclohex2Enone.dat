/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-phenylcyclohex-2-enone  (C14H16O, CAS 36047-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3Phenylcyclohex2Enone;
formula     C14H16O;
CAS         36047-17-3;
InChIKey    GYKMJRAFILCDKJ-UHFFFAOYSA-N;
MW          200.281;      // g/mol [origin=calculated method=formula-sum]
Tc          896.69;      // K   [origin=predictive method=joback]
Pc          26.986;      // bar [origin=predictive method=joback]
omega       0.5143;      // -   [origin=predictive method=lee-kesler]
Tb          638.35;      // K   [origin=predictive method=joback]
HvapTb      53513.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.83 1.38514 -0.00105884 3.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-phenyl-cyclohex-2-en-1-one" "5,5-dimethyl-3-phenylcyclohex-2-en-1-one" );
standardThermochemistry
{
    dHf_298   -117590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96110.0
}
