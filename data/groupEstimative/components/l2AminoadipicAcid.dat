/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-2-aminoadipic acid  (C6H11NO4, CAS 1118-90-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        l2AminoadipicAcid;
formula     C6H11NO4;
CAS         1118-90-7;
InChIKey    OYIFNHCXNCRBQI-BYPYZUCNSA-N;
MW          161.157;      // g/mol [origin=calculated method=formula-sum]
Tc          914.63;      // K   [origin=predictive method=joback]
Pc          41.570;      // bar [origin=predictive method=joback]
omega       1.3207;      // -   [origin=predictive method=lee-kesler]
Tb          699.99;      // K   [origin=predictive method=joback]
HvapTb      73531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.443 0.7432 -0.0004944 1.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CHNH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group COOH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-2-azanylhexanedioic acid" "(s)-2-aminohexanedioic acid" "l-homoglutamic acid" "(2s)-2-aminohexanedioic acid" "l-alpha-aminoadipate" "l-a-aminoadipic acid" "l-alpha-aminoadipic acid" "l-2-amino adipic acid" "l-2-aminoadipate" "l-2-aminohexanedioate" "aminoadipate" "l-2-aminoadipicacid" );
gibbsFormation
{
    dHf_298   -839200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-624170.0
    phase     gas;
}
