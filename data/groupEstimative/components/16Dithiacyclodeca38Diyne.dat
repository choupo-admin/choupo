/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-dithiacyclodeca-3,8-diyne  (C8H8S2, CAS 53690-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Dithiacyclodeca38Diyne;
formula     C8H8S2;
CAS         53690-50-9;
InChIKey    OOODPCKCQPBXKZ-UHFFFAOYSA-N;
MW          168.272;      // g/mol [origin=calculated method=formula-sum]
Tc          824.52;      // K   [origin=predictive method=joback]
Pc          48.225;      // bar [origin=predictive method=joback]
omega       0.2183;      // -   [origin=predictive method=lee-kesler]
Tb          520.52;      // K   [origin=predictive method=joback]
HvapTb      50068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.83 0.64162 -0.00040092 9.736e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C_C; count 2; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group CH2_ring; count 4; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,8-diyne" "1, 3,4,8,9-tetradehydro-2,5,7,10-tetrahydro-" "1,6-dithiecin, 3,4,8,9-tetradehydro-2,5,7,10-tetrahydro-" "3,4,8,9-tetradehydro-2,5,7,10-tetrahydro-1,6-dithiecine" );
gibbsFormation
{
    dHf_298   501330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=533960.0
    phase     gas;
}
