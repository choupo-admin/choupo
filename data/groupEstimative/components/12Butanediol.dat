/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-butanediol  (C4H10O2, CAS 584-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Butanediol;
formula     C4H10O2;
CAS         584-03-2;
InChIKey    BMRWNKZVCUKKSR-UHFFFAOYSA-N;
MW          90.122;      // g/mol [origin=calculated method=formula-sum]
Tc          636.74;      // K   [origin=predictive method=joback]
Pc          50.299;      // bar [origin=predictive method=joback]
omega       1.1787;      // -   [origin=predictive method=lee-kesler]
Tb          475.04;      // K   [origin=predictive method=joback]
HvapTb      57468.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.152 0.45772 -0.0002578 5.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane-1,2-diol" "1,2-butylene glycol" "1,2-dihydroxybutane" "alpha-butyleneglycol" "alpha-butylene glycol" "butanediol, 1,2-" "1,2-(dihydroxy)butane" ".+/-.-1,2-butanediol" "1,2-butanediol, (.+/-.)-" "1,2-butandiol" "a-butylene glycol" ".alpha.-butylene glycol" );
gibbsFormation
{
    dHf_298   -435630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293280.0
    phase     gas;
}
