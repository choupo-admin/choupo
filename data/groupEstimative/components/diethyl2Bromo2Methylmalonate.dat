/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2-bromo-2-methylmalonate  (C8H13BrO4, CAS 29263-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl2Bromo2Methylmalonate;
formula     C8H13BrO4;
CAS         29263-94-3;
InChIKey    CSLQAXTUGPUBCW-UHFFFAOYSA-N;
MW          253.092;      // g/mol [origin=calculated method=formula-sum]
Tc          764.75;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.7333;      // -   [origin=predictive method=lee-kesler]
Tb          562.01;      // K   [origin=predictive method=joback]
HvapTb      53355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.152 0.81826 -0.0004654 7.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group Br; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group Br; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-bromanyl-2-methyl-propanedioate" "diethyl bromomethylmalonate" "diethyl bromo(methyl)malonate" "diethyl 2-bromo-2-methylpropanedioate" "cslqaxtugpubcw-uhfffaoysa-" "m277" "1,3-diethyl 2-bromo-2-methylpropanedioate" "2-bromo-2-methylpropandioic acid diethyl ester" "2-bromo-2-methylpropanedioic acid diethyl ester" "propanedioic acid, bromomethyl-, diethyl ester" );
standardThermochemistry
{
    dHf_298   -825430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-587100.0
}
