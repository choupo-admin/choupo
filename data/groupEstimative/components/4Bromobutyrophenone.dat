/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-bromobutyrophenone  (C10H11BrO, CAS 4981-64-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromobutyrophenone;
formula     C10H11BrO;
CAS         4981-64-0;
InChIKey    HOIDKJFWEVIJAT-UHFFFAOYSA-N;
MW          227.101;      // g/mol [origin=calculated method=formula-sum]
Tc          810.47;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.6466;      // -   [origin=predictive method=lee-kesler]
Tb          580.09;      // K   [origin=predictive method=joback]
HvapTb      53973.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.258 0.82562 -0.00053706 1.3346e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-bromophenyl)butan-1-one" "p-bromobutyrophenone" "1-butanone, 1-(4-bromophenyl)-" "butyrophenone, 4'-bromo-" "butyrophenone, 4'-bromo- (8ci)" "t602" "4'-bromomethylbiphenyl-2-carboxylic acid tert-butyl ester" );
gibbsFormation
{
    dHf_298   -110920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=21500.0
    phase     gas;
}
