/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propyne, 1,3-dibromo-  (C3H2Br2, CAS 627-16-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propyne13Dibromo;
formula     C3H2Br2;
CAS         627-16-7;
InChIKey    DWKIXODUXSEILO-UHFFFAOYSA-N;
MW          197.857;      // g/mol [origin=calculated method=formula-sum]
Tc          650.80;      // K   [origin=predictive method=joback]
Pc          68.528;      // bar [origin=predictive method=joback]
omega       0.3112;      // -   [origin=predictive method=lee-kesler]
Tb          409.56;      // K   [origin=predictive method=joback]
HvapTb      37294.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.101 0.2154 -0.00019006 7.168e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group Br; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group tC; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(bromanyl)prop-1-yne" );
standardThermochemistry
{
    dHf_298   219710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205820.0
}
