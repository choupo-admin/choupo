/*--------------------------------*- Choupo -*-----------------------*\
  Component: ocimene quintoxide  (C10H18O, CAS 56058-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ocimeneQuintoxide;
formula     C10H18O;
CAS         56058-69-6;
InChIKey    LPEYLSKLVYWOEQ-VMPITWQZSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          680.95;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.3552;      // -   [origin=predictive method=lee-kesler]
Tb          470.24;      // K   [origin=predictive method=joback]
HvapTb      41199.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.29 1.36788 -0.001197 4.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[(e)-but-2-en-2-yl]-2,2-dimethyl-oxolane" "5-(but-2-en-2-yl)-2,2-dimethyltetrahydrofuran" "2,2-dimethyl-5-(1-methylpropen-1-yl)tetrahydrofuran" "furan, tetrahydro-2,2-dimethyl-5-(1-methyl-1-propenyl)-" "2,2-dimethyl-5-[(1e)-1-methyl-1-propenyl]tetrahydrofuran" "(+/-)-2,2-dimethyl-5-(1-methyl-1-propenyl)tetrahydrofuran" "(e)-tetrahydro-2,2-dimethyl-5-(1-methyl-1-propenyl)furan" "5-[(e)-but-2-en-2-yl]-2,2-dimethyloxolane" "(e)-5-(but-2-en-2-yl)-2,2-dimethyltetrahydrofuran" "furan, tetrahydro-2,2-dimethyl-5-(1-methyl-1-propenyl)-, (e)-" "( inverted exclamation marka)-2,2-dimethyl-5-(1-methyl-1-propenyl)tetrahydrofuran" );
standardThermochemistry
{
    dHf_298   -218920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42220.0
}
