/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(isocyanatomethyl)cyclohexane  (C10H14N2O2, CAS 10347-54-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BisIsocyanatomethylCyclohexane;
formula     C10H14N2O2;
CAS         10347-54-3;
InChIKey    ROHUXHMNZLHBSF-UHFFFAOYSA-N;
MW          194.234;      // g/mol [origin=calculated method=formula-sum]
Tc          790.45;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.6991;      // -   [origin=predictive method=lee-kesler]
Tb          576.62;      // K   [origin=predictive method=joback]
HvapTb      57038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 2; } { group dCd; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohexane, 1,4-bis(isocyanatomethyl)-" "1,4-bis(aminomethyl)cyclohexane diisocyanate" "1,4-cyclohexane bis(methylisocyanate)" "1,4-bis(methylisocyanate)cyclohexane [diisocyanates]" "1,4-bis(methylisocyanate)cyclohexane" );
