/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzylcyclopentanone  (C12H14O, CAS 2867-63-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Benzylcyclopentanone;
formula     C12H14O;
CAS         2867-63-2;
InChIKey    TVKMRMXVNWHKTF-UHFFFAOYSA-N;
MW          174.243;      // g/mol [origin=calculated method=formula-sum]
Tc          830.92;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.4929;      // -   [origin=predictive method=lee-kesler]
Tb          583.94;      // K   [origin=predictive method=joback]
HvapTb      49086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.979 1.0283 -0.0005436 8.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethyl)cyclopentan-1-one" "2-benzyl-cyclopentanone" "2-benzylcyclopentan-1-one" "cyclopentanone, 2-(phenylmethyl)-, (r)-" "2-benzyl-cyclopentan-1-one" "cyclopentanone, 2-(phenylmethyl)-" "cyclopentanone, 2-benzyl- (6ci,7ci,8ci);2-benzylcyclopentanone;2-benzylcyclopentanone;2-benzyl-cyclopentanone;" );
standardThermochemistry
{
    dHf_298   -131700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76530.0
}
