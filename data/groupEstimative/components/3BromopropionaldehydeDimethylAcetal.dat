/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromopropionaldehyde dimethyl acetal  (C5H11BrO2, CAS 36255-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BromopropionaldehydeDimethylAcetal;
formula     C5H11BrO2;
CAS         36255-44-4;
InChIKey    ODZZAIFAQLODKN-UHFFFAOYSA-N;
MW          183.045;      // g/mol [origin=calculated method=formula-sum]
Tc          613.48;      // K   [origin=predictive method=joback]
Pc          36.509;      // bar [origin=predictive method=joback]
omega       0.4961;      // -   [origin=predictive method=lee-kesler]
Tb          424.56;      // K   [origin=predictive method=joback]
HvapTb      37591.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.852 0.39654 -0.0001008 -2.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3O; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-1,1-dimethoxy-propane" "3-bromo-1,1-dimethoxypropane" "1-bromo-3,3-dimethoxypropane" "propane, 3-bromo-1,1-dimethoxy-" "1-bromo-3,3-dimethoxypropane;3,3-dimethoxypropyl bromide; 3-bromo-1,1-dimethoxypropane; 3-bromopropanaldimethyl acetal; 3-bromopropionaldehyde dimethylacetal" );
gibbsFormation
{
    dHf_298   -389920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206900.0
    phase     gas;
}
