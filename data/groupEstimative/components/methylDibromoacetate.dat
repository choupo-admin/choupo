/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl dibromoacetate  (C3H4Br2O2, CAS 6482-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylDibromoacetate;
formula     C3H4Br2O2;
CAS         6482-26-4;
InChIKey    DZFMIUJZSYIMPH-UHFFFAOYSA-N;
MW          231.871;      // g/mol [origin=calculated method=formula-sum]
Tc          679.57;      // K   [origin=predictive method=joback]
Pc          54.465;      // bar [origin=predictive method=joback]
omega       0.5246;      // -   [origin=predictive method=lee-kesler]
Tb          458.34;      // K   [origin=predictive method=joback]
HvapTb      42161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (40.27 0.31632 -0.0001908 3.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2-bis(bromanyl)ethanoate" "acetic acid, dibromo-, methyl ester" "methyl 2,2-dibromoacetate" );
standardThermochemistry
{
    dHf_298   -375150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-309790.0
}
