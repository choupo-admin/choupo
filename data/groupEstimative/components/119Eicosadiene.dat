/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,19-eicosadiene  (C20H38, CAS 14811-95-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        119Eicosadiene;
formula     C20H38;
CAS         14811-95-1;
InChIKey    AWJFCAXSGQLCKK-UHFFFAOYSA-N;
MW          278.524;      // g/mol [origin=calculated method=formula-sum]
Tc          813.75;      // K   [origin=predictive method=joback]
Pc          10.722;      // bar [origin=predictive method=joback]
omega       0.7998;      // -   [origin=predictive method=lee-kesler]
Tb          650.56;      // K   [origin=predictive method=joback]
HvapTb      58774.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.274 1.8638 -0.00111 2.616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 16; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosa-1,19-diene" "1,19-icosadiene" "1,19-icosadiene;1 19-eicosadiene;1 19-eicosadiene 97%" );
standardThermochemistry
{
    dHf_298   -205270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     925.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=293200.0
}
