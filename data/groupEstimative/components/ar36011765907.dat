name        ar36011765907;
formula     C11H19NO;
CAS         56570-54-8;
InChIKey    ATHWBNYVLNKQJY-UHFFFAOYSA-N;
MW          181.279;      // g/mol [origin=calculated method=formula-sum]
Tc          814.70;      // K   [origin=predictive method=joback]
Pc          26.164;      // bar [origin=predictive method=joback]
omega       0.6344;      // -   [origin=predictive method=lee-kesler]
Tb          593.20;      // K   [origin=predictive method=joback]
HvapTb      50995.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.408 1.25526 -0.00091304 3.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-(propylamino)cyclohex-2-en-1-one" "5,5-dimethyl-3-(n-propylamino)cyclohex-2-en-1-one" "5,5-dimethyl-3-(n-propylamino)cyclohex-2-enone" );
standardThermochemistry
{
    dHf_298   -238730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47830.0
}
