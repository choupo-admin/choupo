/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-ethanonaphtho(1,8-ef)-1,4-diazepine, 2,3-dihydro-  (C14H14N2, CAS 59950-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Ethanonaphtho18Ef14Diazepine23Dihydro;
formula     C14H14N2;
CAS         59950-41-3;
InChIKey    HXUNLWTXIJHGQZ-UHFFFAOYSA-N;
MW          210.28;      // g/mol [origin=calculated method=formula-sum]
Tc          847.37;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.7258;      // -   [origin=predictive method=lee-kesler]
Tb          614.70;      // K   [origin=predictive method=joback]
HvapTb      56184.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.09 1.754 -0.00164084 6.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 6; } { group AC; count 4; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   406030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=649480.0
}
