/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(octadecyloxy)propylamine  (C21H45NO, CAS 7617-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3OctadecyloxyPropylamine;
formula     C21H45NO;
CAS         7617-75-6;
InChIKey    GWOUPOJUVSKJCH-UHFFFAOYSA-N;
MW          327.597;      // g/mol [origin=calculated method=formula-sum]
Tc          951.69;      // K   [origin=predictive method=joback]
Pc          9.802;      // bar [origin=predictive method=joback]
omega       0.9164;      // -   [origin=predictive method=lee-kesler]
Tb          775.03;      // K   [origin=predictive method=joback]
HvapTb      75391.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.79 1.99752 -0.001051 1.949e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-octadecoxypropan-1-amine" "1-propanamine, 3-(octadecyloxy)-" );
gibbsFormation
{
    dHf_298   -575200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1036.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87390.0
    phase     gas;
}
