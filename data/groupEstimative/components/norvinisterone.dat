/*--------------------------------*- Choupo -*-----------------------*\
  Component: norvinisterone  (C20H28O2, CAS 6795-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norvinisterone;
formula     C20H28O2;
CAS         6795-60-4;
InChIKey    VOJYZDFYEHKHAP-XGXHKTLJSA-N;
MW          300.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1094.16;      // K   [origin=predictive method=joback]
Pc          19.254;      // bar [origin=predictive method=joback]
omega       1.0468;      // -   [origin=predictive method=lee-kesler]
Tb          857.47;      // K   [origin=predictive method=joback]
HvapTb      78916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-269.16 2.72042 -0.00239694 9.076e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 4; } { group C; count 2; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8r,9s,10r,13s,14s,17r)-17-ethenyl-13-methyl-17-oxidanyl-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-3-one" "neoprogestin" "nor-progestelea" "norvinisteronum [inn-latin]" "17-vinyl-19-nortestosterone" "19-nor-17-alpha-vinyltestosterone" "17-hydroxy-17-alpha-vinyl-4-estren-3-one" "17-hydroxy-19-nor-17-alpha-pregna-4,20-dien-3-one" "19-nor-17-alpha-pregna-4,20-dien-3-one, 17-hydroxy-" "norvinisterona" "norvinisteronum" "norvinisterone [inn]" );
standardThermochemistry
{
    dHf_298   -324120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122380.0
}
