/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-hexadiene, 1,6-dibromo-  (C6H8Br2, CAS 62116-23-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Hexadiene16Dibromo;
formula     C6H8Br2;
CAS         62116-23-8;
InChIKey    UPCQGURPQYFOKT-UHFFFAOYSA-N;
MW          239.938;      // g/mol [origin=calculated method=formula-sum]
Tc          699.68;      // K   [origin=predictive method=joback]
Pc          41.516;      // bar [origin=predictive method=joback]
omega       0.4783;      // -   [origin=predictive method=lee-kesler]
Tb          477.52;      // K   [origin=predictive method=joback]
HvapTb      41736.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.548 0.6902 -0.000613 2.232e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH; count 4; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-bis(bromanyl)hexa-2,4-diene" "2,4-hexadiene, 1,6-dibromo-, (e,e)-" );
gibbsFormation
{
    dHf_298   119930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     478.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188720.0
    phase     gas;
}
