/*--------------------------------*- Choupo -*-----------------------*\
  Component: retrorsine  (C18H25NO6, CAS 480-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        retrorsine;
formula     C18H25NO6;
CAS         480-54-6;
InChIKey    BCJMNZRQJAVDLD-CQRYIUNCSA-N;
MW          351.399;      // g/mol [origin=calculated method=formula-sum]
Tc          1181.91;      // K   [origin=predictive method=joback]
Pc          20.163;      // bar [origin=predictive method=joback]
omega       1.5855;      // -   [origin=predictive method=lee-kesler]
Tb          964.06;      // K   [origin=predictive method=joback]
HvapTb      106413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.729 2.29244 -0.00182694 6.04e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 3; } { group C; count 1; } { group CH=C; count 2; } { group OH; count 2; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 2; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "beta-longilobine" "retrorsin" "12,18-dihydroxysenecionan-11,16-dione" "usaramine" "cis-retronecic acid ester of retronecine" "12,18-dihydroxy-senecionan-11,16-dione" "senecionan-11,16-dione, 12,18-dihydroxy-" "(15z)-12,18-dihydroxysenecionan-11,16-dione" "trans-15-ethylidene-12beta-hydroxy-12alpha-hydroxymethyl-13beta-methylsenec-1-enine" "3-ethylidene-3,4,5,6,9,11,13,14,14a,14b-decahydro-6-hydroxy-6-hydroxymethyl-5-methyl(1,6)dioxacyclododeca(2,3,4-gh)pyrrolizidine-2,7-dione" "a-longilobine" "prestwick_562" );
gibbsFormation
{
    dHf_298   -969180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     822.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-484380.0
    phase     gas;
}
