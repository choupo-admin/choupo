/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tetradecanol  (C14H30O, CAS 112-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tetradecanol;
formula     C14H30O;
CAS         112-72-1;
InChIKey    HLZKNKRTKFSKGZ-UHFFFAOYSA-N;
MW          214.393;      // g/mol [origin=calculated method=formula-sum]
Tc          770.20;      // K   [origin=predictive method=joback]
Pc          16.391;      // bar [origin=predictive method=joback]
omega       1.0746;      // -   [origin=predictive method=lee-kesler]
Tb          612.10;      // K   [origin=predictive method=joback]
HvapTb      63437.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.547 1.36782 -0.0007682 1.652e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecan-1-ol" "myristyl alcohol" "tetradecanol" "tetradecyl alcohol" "n-tetradecanol" "myristic alcohol" "lanette k" "loxanol v" "lanette wax ks" "n-tetradecan-1-ol" "n-tetradecyl alcohol" "alfol 14" );
standardThermochemistry
{
    dHf_298   -484520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69820.0
}
