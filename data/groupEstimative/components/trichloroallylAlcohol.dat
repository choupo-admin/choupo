/*--------------------------------*- Choupo -*-----------------------*\
  Component: trichloroallyl alcohol  (C3H3Cl3O, CAS 3266-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trichloroallylAlcohol;
formula     C3H3Cl3O;
CAS         3266-39-5;
InChIKey    ZJBQSUGZKRQVLI-UHFFFAOYSA-N;
MW          161.406;      // g/mol [origin=calculated method=formula-sum]
Tc          676.22;      // K   [origin=predictive method=joback]
Pc          46.721;      // bar [origin=predictive method=joback]
omega       0.7058;      // -   [origin=predictive method=lee-kesler]
Tb          476.63;      // K   [origin=predictive method=joback]
HvapTb      52224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.561 0.363 -0.0003194 1.123e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group Cl_C=C_; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dC; count 2; } { group Cl; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,3-tris(chloranyl)prop-2-en-1-ol" "2,3,3-trichloro-2-propen-1-ol" "2,3,3-trichloroallyl alcohol" "2-propen-1-ol, 2,3,3-trichloro-" "2,3,3-trichloroprop-2-en-1-ol" );
gibbsFormation
{
    dHf_298   -207060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135110.0
    phase     gas;
}
