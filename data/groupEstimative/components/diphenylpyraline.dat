/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenylpyraline  (C19H23NO, CAS 147-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenylpyraline;
formula     C19H23NO;
CAS         147-20-6;
InChIKey    OWQUZNMMYNAXSL-UHFFFAOYSA-N;
MW          281.399;      // g/mol [origin=calculated method=formula-sum]
Tc          981.18;      // K   [origin=predictive method=joback]
Pc          20.456;      // bar [origin=predictive method=joback]
omega       0.7188;      // -   [origin=predictive method=lee-kesler]
Tb          737.38;      // K   [origin=predictive method=joback]
HvapTb      66762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.55 1.84932 -0.0012044 2.875e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH-O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(diphenylmethyl)oxy-1-methyl-piperidine" "allergen" "belfene" "hispril" "lyssipoll" "mepiben" "neargal" "histyn" "lergobine" "dayfen" "histryl" "diphenylpyrilene" );
gibbsFormation
{
    dHf_298   28080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=373810.0
    phase     gas;
}
