/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorambucil  (C14H19Cl2NO2, CAS 305-03-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorambucil;
formula     C14H19Cl2NO2;
CAS         305-03-3;
InChIKey    JCKYGMPEJWAADB-UHFFFAOYSA-N;
MW          304.211;      // g/mol [origin=calculated method=formula-sum]
Tc          996.32;      // K   [origin=predictive method=joback]
Pc          20.055;      // bar [origin=predictive method=joback]
omega       1.1253;      // -   [origin=predictive method=lee-kesler]
Tb          784.39;      // K   [origin=predictive method=joback]
HvapTb      77673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.753 1.3837 -0.00092796 2.394e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } { group COOH; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[4-[bis(2-chloroethyl)amino]phenyl]butanoic acid" "leukeran" "ambochlorin" "chloraminophen" "chlorbutin" "chloraminophene" "chloroambucil" "amboclorin" "chlorbutine" "chlorobutin" "chlorobutine" "linfolizin" );
gibbsFormation
{
    dHf_298   -421450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     724.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-87210.0
    phase     gas;
}
