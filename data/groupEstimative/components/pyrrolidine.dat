/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrrolidine  (C4H9N, CAS 123-75-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrrolidine;
formula     C4H9N;
CAS         123-75-1;
InChIKey    RWRDLPDLKQPQOW-UHFFFAOYSA-N;
MW          71.123;      // g/mol [origin=calculated method=formula-sum]
Tc          568.72;      // K   [origin=predictive method=joback]
Pc          53.749;      // bar [origin=predictive method=joback]
omega       0.2559;      // -   [origin=predictive method=lee-kesler]
Tb          359.62;      // K   [origin=predictive method=joback]
HvapTb      31822.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.25 0.5286 -0.000316 7.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "azacyclopentane" "tetrahydropyrrole" "tetrahydro pyrrole" "azolidine" "tetramethylenimine" "butylenimine" "perhydropyrrole" "prolamine" "1-azacyclopentane" "pyrrole, tetrahydro-" "pyrrolidine ring" "tetramethyleneimine" );
standardThermochemistry
{
    dHf_298   -7260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     297.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114770.0
}
