/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl trichloroacetate  (C5H7Cl3O2, CAS 3974-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropylTrichloroacetate;
formula     C5H7Cl3O2;
CAS         3974-99-0;
InChIKey    JYXIYFNAIFVCAN-UHFFFAOYSA-N;
MW          205.459;      // g/mol [origin=calculated method=formula-sum]
Tc          693.67;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.4450;      // -   [origin=predictive method=lee-kesler]
Tb          480.84;      // K   [origin=predictive method=joback]
HvapTb      45602.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.27 0.57614 -0.0003898 8.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CCl3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group C; count 1; } { group Cl; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 2,2,2-tris(chloranyl)ethanoate" "trichloroaetic acid isopropyl ester" "acetic acid, trichloro-, 1-methylethyl ester" "1-methylethyl trichloroacetate" "acetic acid, 2,2,2-trichloro-, 1-methylethyl ester" "acetic acid, trichloro-, isopropyl ester (6ci,7ci,8ci)" "propan-2-yl 2,2,2-trichloroacetate" "acetic acid,2,2,2-trichloro-, 1-methylethyl ester" );
gibbsFormation
{
    dHf_298   -525060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-354540.0
    phase     gas;
}
