/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentylcyclopentane  (C10H20, CAS 3741-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentylcyclopentane;
formula     C10H20;
CAS         3741-00-2;
InChIKey    HPQURZRDYMUHJI-UHFFFAOYSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          633.11;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.3987;      // -   [origin=predictive method=lee-kesler]
Tb          443.68;      // K   [origin=predictive method=joback]
HvapTb      38111.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.686 1.08552 -0.0006476 1.473e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentane, pentyl-" "pentane, 1-cyclopentyl-" "amylcyclopentane" "n-pentylcyclopentane" "cyclopentane, n-pentyl-" "hpqurzrdymuhji-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -189250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=69870.0
    phase     gas;
}
