/*--------------------------------*- Choupo -*-----------------------*\
  Component: 12-hydroxy-1,2-dihydrosenecionan-11,16-dione  (C18H27NO5, CAS 480-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Hydroxy12Dihydrosenecionan1116Dione;
formula     C18H27NO5;
CAS         480-78-4;
InChIKey    BTHCJHQOYFUIMG-BQSAVQNUSA-N;
MW          337.416;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.36;      // K   [origin=predictive method=joback]
Pc          17.758;      // bar [origin=predictive method=joback]
omega       1.2770;      // -   [origin=predictive method=lee-kesler]
Tb          863.07;      // K   [origin=predictive method=joback]
HvapTb      88471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-161.16 2.34746 -0.0018209 5.867e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 4; } { group C; count 1; } { group CH=C; count 1; } { group OH; count 1; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group C_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "platifillin" "(1r,4z,6s,7r,11s,17r)-4-ethylidene-7-hydroxy-6,7-dimethyl-2,9-dioxa-14-azatricyclo[9.5.1.0^{14,17}]heptadecane-3,8-dione" "(6s,11s,1r,7r,17r)-4-ethylidene-7-hydroxy-6,7-dimethyl-2,9-dioxa-14-azatricycl o[9.5.1.0<14,17>]heptadecane-3,8-dione" );
gibbsFormation
{
    dHf_298   -883600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     772.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-375600.0
    phase     gas;
}
