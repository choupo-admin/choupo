/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-oxocycloheptanecarboxylate  (C10H16O3, CAS 774-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Oxocycloheptanecarboxylate;
formula     C10H16O3;
CAS         774-05-0;
InChIKey    MKRBAWHVHOVBOQ-UHFFFAOYSA-N;
MW          184.235;      // g/mol [origin=calculated method=formula-sum]
Tc          802.91;      // K   [origin=predictive method=joback]
Pc          27.469;      // bar [origin=predictive method=joback]
omega       0.5903;      // -   [origin=predictive method=lee-kesler]
Tb          578.26;      // K   [origin=predictive method=joback]
HvapTb      50109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.089 0.84322 -0.0002162 -8.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-oxidanylidenecycloheptane-1-carboxylate" "ethyl 2-oxo-cycloheptanecarboxylate" "ethyl 2-oxocycloheptane-1-carboxylate" "2-oxo-cycloheptane-1-carboxylic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -656550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-387290.0
    phase     gas;
}
