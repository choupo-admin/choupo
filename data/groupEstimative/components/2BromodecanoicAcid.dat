/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromodecanoic acid  (C10H19BrO2, CAS 2623-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromodecanoicAcid;
formula     C10H19BrO2;
CAS         2623-95-2;
InChIKey    KNLOTZNPRIFUAR-UHFFFAOYSA-N;
MW          251.164;      // g/mol [origin=calculated method=formula-sum]
Tc          835.96;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.9839;      // -   [origin=predictive method=lee-kesler]
Tb          639.63;      // K   [origin=predictive method=joback]
HvapTb      61065.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.907 1.04872 -0.0006674 1.694e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyldecanoic acid" "decanoic acid, 2-bromo-" "2-bromocapric acid" "alpha-bromocapric acid" "2-bromo-decanoic acid" "alpha-bromodecanoic acid" ".alpha.-bromocapric acid" "alpha-bromocapric acid technical grade" );
standardThermochemistry
{
    dHf_298   -578950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-298710.0
}
