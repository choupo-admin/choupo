/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butyne  (C4H6, CAS 503-17-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butyne;
formula     C4H6;
CAS         503-17-3;
InChIKey    XNMQEEKYCVKGBD-UHFFFAOYSA-N;
MW          54.092;      // g/mol [origin=calculated method=formula-sum]
Tc          488.77;      // K   [origin=predictive method=joback]
Pc          48.092;      // bar [origin=predictive method=joback]
omega       0.1340;      // -   [origin=predictive method=lee-kesler]
Tb          300.12;      // K   [origin=predictive method=joback]
HvapTb      26650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.81 0.23404 -0.00010166 1.538e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "but-2-yne" "dimethylacetylene" "crotonylene" "1,2-dimethylvinylene" "1-methyl-1-propynyl" "agn-pc-03ddnz" "2-butine(3ci); dimethylacetylene" );
standardThermochemistry
{
    dHf_298   146410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     283.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185600.0
}
