/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-n-propylaniline  (C10H15N, CAS 54837-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylNPropylaniline;
formula     C10H15N;
CAS         54837-90-0;
InChIKey    YPEZCZIRPXYWSI-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          717.83;      // K   [origin=predictive method=joback]
Pc          29.250;      // bar [origin=predictive method=joback]
omega       0.5429;      // -   [origin=predictive method=lee-kesler]
Tb          510.23;      // K   [origin=predictive method=joback]
HvapTb      47228.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.018 0.89164 -0.00053296 1.189e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-n-propyl-aniline" "n-propyl-p-toluidine" "benzenamine, 4-methyl-n-propyl-" );
gibbsFormation
{
    dHf_298   28800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225490.0
    phase     gas;
}
