/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-5-methyl-1,4-phenylenediamine  (C7H9ClN2, CAS 5307-03-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro5Methyl14Phenylenediamine;
formula     C7H9ClN2;
CAS         5307-03-9;
InChIKey    CPCPKQUNFFHAIZ-UHFFFAOYSA-N;
MW          156.613;      // g/mol [origin=calculated method=formula-sum]
Tc          829.23;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.6612;      // -   [origin=predictive method=lee-kesler]
Tb          583.87;      // K   [origin=predictive method=joback]
HvapTb      61105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.39 0.54202 -0.00029428 5.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACNH2; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-5-methyl-benzene-1,4-diamine" "2-chloro-5-methylbenzene-1,4-diamine" "2,5-diamino-4-chlorotoluene" "4-chloro-2,5-diamino toluene" "5-chloro-2-methyl-1,4-phenylenediamine" "2-chloro-5-methyl-p-phenylenediamine" "4-chloro-2,5-diaminotoluene" "5-chloro-2-methylbenzene-1,4-diamine" "toluene-2,5-diamine,4-chloro- (7ci,8ci);2,5-diamino-4-chlorotoluene;2-methyl-5-chloro-1,4-diaminobenzene;5-chloro-2-methyl-1,4-phenylenediamine;" );
standardThermochemistry
{
    dHf_298   66150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212550.0
}
