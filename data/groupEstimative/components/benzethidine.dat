/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzethidine  (C23H29NO3, CAS 3691-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzethidine;
formula     C23H29NO3;
CAS         3691-78-9;
InChIKey    UVTBZAWTRVBTMK-UHFFFAOYSA-N;
MW          367.489;      // g/mol [origin=calculated method=formula-sum]
Tc          1120.38;      // K   [origin=predictive method=joback]
Pc          15.343;      // bar [origin=predictive method=joback]
omega       0.9922;      // -   [origin=predictive method=lee-kesler]
Tb          887.80;      // K   [origin=predictive method=joback]
HvapTb      82310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-156.086 2.46052 -0.0018568 5.765e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-phenyl-1-(2-phenylmethoxyethyl)piperidine-4-carboxylate" "benzethidin" "benzethidinum [inn-latin]" "benzethidine [inn:ban:dcf]" "ethyl 1-(2-benzyloxyethyl)-4-phenylpiperidine-4-carboxylate" "ethyl 1-[2-(benzyloxy)ethyl]-4-phenylpiperidine-4-carboxylate" "1-(2-benzyloxyethyl)-4-phenylpiperidine-4-carboxylic acid ethyl ester" "isonipecotic acid, 1-(2-(benzyloxy)ethyl)-4-phenyl-, ethyl ester" "4-piperidinecarboxylic acid, 4-phenyl-1-(2-(phenylmethoxy)ethyl)-, ethyl ester" "4-piperidinecarboxylic acid, 4-phenyl-1-[2-(phenylmethoxy)ethyl]-, ethyl ester" "benzethidinum" "benzetidina" );
standardThermochemistry
{
    dHf_298   -351240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     936.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94070.0
}
