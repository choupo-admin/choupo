/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5-pentabromo-6-chlorocyclohexane  (C6H6Br5Cl, CAS 87-84-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12345Pentabromo6Chlorocyclohexane;
formula     C6H6Br5Cl;
CAS         87-84-3;
InChIKey    UZOSVZSBPTTWIG-UHFFFAOYSA-N;
MW          513.084;      // g/mol [origin=calculated method=formula-sum]
Tc          992.82;      // K   [origin=predictive method=joback]
Pc          47.826;      // bar [origin=predictive method=joback]
omega       0.7299;      // -   [origin=predictive method=lee-kesler]
Tb          701.31;      // K   [origin=predictive method=joback]
HvapTb      64394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.37 0.7612 -0.000484 1.083e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 5; } { group CHCl; count 1; } { group Br; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 6; } { group Cl; count 1; } { group Br; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(bromanyl)-6-chloranyl-cyclohexane" "chloropentabromocyclohexane" "pentabromochlorocyclohexane" "cyclohexane, 1,2,3,4,5-pentabromo-6-chloro-" "cyclohexane, 1-chloro-2,3,4,5,6-pentabromo-" "1-chloro-2,3,4,5,6-pentabromo cyclohexane" );
gibbsFormation
{
    dHf_298   -98640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45210.0
    phase     gas;
}
