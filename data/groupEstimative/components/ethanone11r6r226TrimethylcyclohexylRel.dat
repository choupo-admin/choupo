/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanone, 1-((1r,6r)-2,2,6-trimethylcyclohexyl)-, rel-  (C11H20O, CAS 52612-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanone11r6r226TrimethylcyclohexylRel;
formula     C11H20O;
CAS         52612-42-7;
InChIKey    LGEFCQRTSXYJAD-SCZZXKLOSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          728.01;      // K   [origin=predictive method=joback]
Pc          24.338;      // bar [origin=predictive method=joback]
omega       0.4390;      // -   [origin=predictive method=lee-kesler]
Tb          515.60;      // K   [origin=predictive method=joback]
HvapTb      45486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.47 1.38188 -0.0010587 3.6186e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(1r,6r)-2,2,6-trimethylcyclohexyl]ethanone" "(1r-cis)-1-(2,2,6-trimethylcyclohexyl)ethanone" "cis-1-(2,2,6-trimethylcyclohexyl)ethanone" );
standardThermochemistry
{
    dHf_298   -354070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83640.0
}
