/*--------------------------------*- Choupo -*-----------------------*\
  Component: isodecyl tridecyl phthalate  (C31H52O4, CAS 61886-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isodecylTridecylPhthalate;
formula     C31H52O4;
CAS         61886-60-0;
InChIKey    TYLLMRSWXAGLFH-UHFFFAOYSA-N;
MW          488.753;      // g/mol [origin=calculated method=formula-sum]
Tc          1307.31;      // K   [origin=predictive method=joback]
Pc          6.712;      // bar [origin=predictive method=joback]
omega       0.5100;      // -   [origin=predictive method=lee-kesler]
Tb          1056.54;      // K   [origin=predictive method=joback]
HvapTb      101964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.239 2.70676 -0.00144076 2.436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 19; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 19; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-(8-methylnonyl) o1-tridecyl benzene-1,2-dicarboxylate" "8-methylnonyl tridecyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, 1-isodecyl 2-tridecyl ester" "1,2-benzenedicarboxylic acid, mixed isodecyl and tridecyl diesters" "tridecyl isodecyl phthalate" "phthalic acid mixed isodecyl and tridecyl diesters" "mixed isodecyl, tridecyl phthalates" "1,2-benzenedicarboxylic acid, isodecyl tridecyl ester" "1,2-benzenedicarboxylicacid, 1-isodecyl 2-tridecyl ester" "2-o-(8-methylnonyl) 1-o-tridecyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylicacid, isodecyl tridecyl ester (9ci); isodecyl tridecyl phthalate" );
standardThermochemistry
{
    dHf_298   -1097950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1343.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-310260.0
}
