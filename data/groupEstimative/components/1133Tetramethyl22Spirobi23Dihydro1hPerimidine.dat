/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1',3,3'-tetramethyl-2,2'-spirobi(2,3-dihydro-1h-perimidine)  (C25H24N4, CAS 99643-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1133Tetramethyl22Spirobi23Dihydro1hPerimidine;
formula     C25H24N4;
CAS         99643-41-1;
InChIKey    YYMDPYAYXLWGSX-UHFFFAOYSA-N;
MW          380.495;      // g/mol [origin=calculated method=formula-sum]
Tc          1166.74;      // K   [origin=predictive method=joback]
Pc          18.563;      // bar [origin=predictive method=joback]
omega       1.2017;      // -   [origin=predictive method=lee-kesler]
Tb          929.64;      // K   [origin=predictive method=joback]
HvapTb      88020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-266.91 3.13948 -0.00311468 1.2238e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 12; } { group AC; count 8; } { group CH3N; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C_ring; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 8; } { group N; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1',3,3'-tetramethyl-2,2'-spirobi[perimidine]" "1,1',3,3'-tetramethyl-2,2'-spirobi[2,3-dihydro-1h-perimidine]" "1,1',3,3'-tetramethyl-1h,1'h,3h,3'h-2,2'-spirobi[perimidine]" );
gibbsFormation
{
    dHf_298   732090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=1186560.0
    phase     gas;
}
