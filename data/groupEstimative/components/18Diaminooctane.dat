/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-diaminooctane  (C8H20N2, CAS 373-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Diaminooctane;
formula     C8H20N2;
CAS         373-44-4;
InChIKey    PWGJDPKCLMLPJW-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          716.12;      // K   [origin=predictive method=joback]
Pc          28.536;      // bar [origin=predictive method=joback]
omega       0.7618;      // -   [origin=predictive method=lee-kesler]
Tb          527.70;      // K   [origin=predictive method=joback]
HvapTb      54684.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.598 0.8876 -0.0004982 1.06e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane-1,8-diamine" "octamethylenediamine" "1,8-octanediamine" "1,8-octylenediamine" "1,8-octamethylenediamine" "octane 1,8-diamine" "1,8-diaminooctane 1 m solution" "diaminooctane" "alpha,omega-diaminooctane" "octane, 1,8-diamino-" "1,8-diaminooctane solution" "1,8-diaminooctane  solution" );
standardThermochemistry
{
    dHf_298   -140870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149380.0
}
