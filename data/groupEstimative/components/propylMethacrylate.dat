/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl methacrylate  (C7H12O2, CAS 2210-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylMethacrylate;
formula     C7H12O2;
CAS         2210-28-8;
InChIKey    NHARPDSAXCBDDR-UHFFFAOYSA-N;
MW          128.171;      // g/mol [origin=calculated method=formula-sum]
Tc          594.32;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.4475;      // -   [origin=predictive method=lee-kesler]
Tb          414.54;      // K   [origin=predictive method=joback]
HvapTb      37993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.252 0.59394 -0.0002876 3.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl 2-methylprop-2-enoate" "methacrylic acid, propyl ester" "n-propyl methacrylate" "2-propenoic acid, 2-methyl-, propyl ester" "propyl 2-methyl-2-propenoate" "propyl 2-methylacrylate" "2-propenoic acid,2-methyl-, propyl ester" );
standardThermochemistry
{
    dHf_298   -389450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223020.0
}
