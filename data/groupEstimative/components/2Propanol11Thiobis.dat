/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1,1'-thiobis-  (C6H14O2S, CAS 6704-15-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol11Thiobis;
formula     C6H14O2S;
CAS         6704-15-0;
InChIKey    WGLYLHNRGWWZMW-UHFFFAOYSA-N;
MW          150.236;      // g/mol [origin=calculated method=formula-sum]
Tc          768.30;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       1.3203;      // -   [origin=predictive method=lee-kesler]
Tb          589.14;      // K   [origin=predictive method=joback]
HvapTb      68349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.252 0.64803 -0.0003296 5.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } { group OH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-oxidanylpropylsulfanyl)propan-2-ol" "1,1'-thiobis(2-propanol)" "sulfide, bis(2-hydroxypropyl)" "beta-hydroxypropyl sulfide" "2-propanol,1'-thiodi-" "2-propanol,1'-thiobis-" "1,1'-thiodipropan-2-ol" "agn-pc-00faf9" ".beta.-hydroxypropyl sulfide" "2-propanol, 1,1'-thiodi-" "bis(beta-hydroxypropyl) sulfide" "bis(.beta.-hydroxypropyl) sulfide" );
standardThermochemistry
{
    dHf_298   -440320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-245760.0
}
