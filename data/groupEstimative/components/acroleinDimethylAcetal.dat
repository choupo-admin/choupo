/*--------------------------------*- Choupo -*-----------------------*\
  Component: acrolein dimethyl acetal  (C5H10O2, CAS 6044-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acroleinDimethylAcetal;
formula     C5H10O2;
CAS         6044-68-4;
InChIKey    OBWGMYALGNDUNM-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          528.13;      // K   [origin=predictive method=joback]
Pc          35.347;      // bar [origin=predictive method=joback]
omega       0.3486;      // -   [origin=predictive method=lee-kesler]
Tb          355.08;      // K   [origin=predictive method=joback]
HvapTb      30486.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.67 0.33834 -5.23e-05 -4.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH2=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethoxyprop-1-ene" "3,3-dimethoxy-1-propene" "1-propene, 3,3-dimethoxy-" "3,3-dimethoxypropene-1" "3,3-dimethoxypropene" "acrolein,dimethyl acetal" "1-propene,3-dimethoxy-" "acrolein,dimethyl acetal (6ci,7ci,8ci);1,1-dimethoxyprop-2-ene;2-propenal, dimethylacetal;3,3-dimethoxy-1-propene;3,3-dimethoxypropene;" );
gibbsFormation
{
    dHf_298   -290820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133380.0
    phase     gas;
}
