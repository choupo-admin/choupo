/*--------------------------------*- Choupo -*-----------------------*\
  Component: prenylthiol  (C5H10S, CAS 5287-45-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        prenylthiol;
formula     C5H10S;
CAS         5287-45-6;
InChIKey    GYDPOKGOQFTYGW-UHFFFAOYSA-N;
MW          102.195;      // g/mol [origin=calculated method=formula-sum]
Tc          585.47;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.2648;      // -   [origin=predictive method=lee-kesler]
Tb          380.90;      // K   [origin=predictive method=joback]
HvapTb      33499.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.639 0.52604 -0.0003567 1.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbut-2-ene-1-thiol" "3-methyl-2-butene-1-thiol" "prenyl mercaptan" "3-methyl-2-buten-1-thiol" "1-mercapto-3-methyl-2-butene" "3-methyl-1-mercapto-2-butene" "2-butene-1-thiol, 3-methyl-" "3-methyl-2-buten-1-thiol, preparation kit" );
standardThermochemistry
{
    dHf_298   -620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92280.0
}
