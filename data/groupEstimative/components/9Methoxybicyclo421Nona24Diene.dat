/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-methoxybicyclo[4.2.1]nona-2,4-diene  (C10H14O, CAS 64725-62-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Methoxybicyclo421Nona24Diene;
formula     C10H14O;
CAS         64725-62-8;
InChIKey    HUONNNWVSARUEW-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          686.62;      // K   [origin=predictive method=joback]
Pc          30.156;      // bar [origin=predictive method=joback]
omega       0.3731;      // -   [origin=predictive method=lee-kesler]
Tb          470.76;      // K   [origin=predictive method=joback]
HvapTb      40881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.05 1.02512 -0.00062956 1.421e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 2; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo(4.2.1)nona-2,4-diene, 9-methoxy-, syn-" );
standardThermochemistry
{
    dHf_298   -159610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65730.0
}
