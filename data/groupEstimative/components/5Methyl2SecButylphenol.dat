/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-2-sec-butylphenol  (C11H16O, CAS 29472-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl2SecButylphenol;
formula     C11H16O;
CAS         29472-95-5;
InChIKey    ZBAXSFRZNDZTMT-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          783.65;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.6326;      // -   [origin=predictive method=lee-kesler]
Tb          563.12;      // K   [origin=predictive method=joback]
HvapTb      55644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.319 1.07096 -0.00079832 2.529e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 3; } { group ACCH3; count 1; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butan-2-yl-5-methyl-phenol" "agn-pc-03c1ir" "2-butan-2-yl-5-methylphenol" );
standardThermochemistry
{
    dHf_298   -227900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12540.0
}
