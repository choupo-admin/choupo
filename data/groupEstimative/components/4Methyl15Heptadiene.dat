/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-1,5-heptadiene  (C8H14, CAS 998-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl15Heptadiene;
formula     C8H14;
CAS         998-94-7;
InChIKey    ITKKJSFRRSLPHX-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          562.76;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.3144;      // -   [origin=predictive method=lee-kesler]
Tb          383.04;      // K   [origin=predictive method=joback]
HvapTb      32302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.239 0.76974 -0.0005213 1.483e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylhepta-1,5-diene" );
gibbsFormation
{
    dHf_298   28920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=182100.0
    phase     gas;
}
