/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-Methyl-1-butanethiol  (C5H12S, CAS 541-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl1Butanethiol;
formula     C5H12S;
CAS         541-31-1;
InChIKey    GIJGXNFNUUFEGH-UHFFFAOYSA-N;
MW          104.211;      // g/mol [origin=calculated method=formula-sum]
Tc          571.03;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.2933;      // -   [origin=predictive method=lee-kesler]
Tb          376.42;      // K   [origin=predictive method=joback]
HvapTb      33073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.552 0.51204 -0.0002738 5.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutane-1-thiol" "1-butanethiol, 3-methyl-" "2-methyl-4-butanethiol" "3-methylbutan-1-thiol" "3-methylbutanethiol" "3-methylbutyl mercaptan" "isoamyl mercaptan" "isoamyl sulfhydrate" "isopentanethiol" "isopentyl mercaptan" "isopentylthiol" "iso-amyl mercaptan" );
gibbsFormation
{
    dHf_298   -113330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18170.0
    phase     gas;
}
