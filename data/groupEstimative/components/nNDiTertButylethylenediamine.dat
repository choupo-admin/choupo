/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-di-tert-butylethylenediamine  (C10H24N2, CAS 4062-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiTertButylethylenediamine;
formula     C10H24N2;
CAS         4062-60-6;
InChIKey    KGHYGBGIWLNFAV-UHFFFAOYSA-N;
MW          172.316;      // g/mol [origin=calculated method=formula-sum]
Tc          711.52;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.6052;      // -   [origin=predictive method=lee-kesler]
Tb          522.28;      // K   [origin=predictive method=joback]
HvapTb      48134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.568 1.35792 -0.000961 2.726e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-ditert-butylethane-1,2-diamine" "1,2-bis(tert-butylamino)ethane" "n,n'-di-t-butylethylenediamine" "n,n'-di-tert-butyl-ethylenediamine" "1,2-ethanediamine, n,n'-bis(1,1-dimethylethyl)-" "n,n'-bis(tert-butyl)ethylenediamine" "n1,n2-di-tert-butylethane-1,2-diamine" "n,n'-bis(1,1-dimethylethyl)-1,2-ethanediamine" "1,2-ethanediamine, n1,n2-bis(1,1-dimethylethyl)-" "(tert-butyl){2-[(tert-butyl)amino]ethyl}amine" "n,n'-di-tert-butylethane-1,2-diamine" "n,n'-di-t-butyl ethylene diamine" );
gibbsFormation
{
    dHf_298   -160290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=217780.0
    phase     gas;
}
