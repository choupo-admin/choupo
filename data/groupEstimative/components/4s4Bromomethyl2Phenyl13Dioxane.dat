/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4s)-4-bromomethyl-2-phenyl-1,3-dioxane  (C11H13BrO2, CAS 201743-52-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4s4Bromomethyl2Phenyl13Dioxane;
formula     C11H13BrO2;
CAS         201743-52-4;
InChIKey    LZPOSTLTDVMAGB-VUWPPUDQSA-N;
MW          257.127;      // g/mol [origin=calculated method=formula-sum]
Tc          866.60;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.5805;      // -   [origin=predictive method=lee-kesler]
Tb          612.90;      // K   [origin=predictive method=joback]
HvapTb      57931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.849 1.0977 -0.000675 1.433e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s)-4-(bromomethyl)-2-phenyl-1,3-dioxane" "1,3-dioxane,4-(bromomethyl)-2-phenyl-, (4s)-" "1,3-dioxane, 4-(bromomethyl)-2-phenyl-, (4s);(4s)-4-bromomethyl-2-phenyl-1,3-dioxane;(4s)-4-bromomethyl-2-phenyl-1,3-dioxane 95%" );
standardThermochemistry
{
    dHf_298   -237530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     353.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12970.0
}
