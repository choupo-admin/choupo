/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropylidene cyclopropane  (C6H8, CAS 27567-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropylideneCyclopropane;
formula     C6H8;
CAS         27567-82-4;
InChIKey    VIVNOHOCUKALPP-UHFFFAOYSA-N;
MW          80.13;      // g/mol [origin=calculated method=formula-sum]
Tc          571.38;      // K   [origin=predictive method=joback]
Pc          46.785;      // bar [origin=predictive method=joback]
omega       0.2854;      // -   [origin=predictive method=lee-kesler]
Tb          368.82;      // K   [origin=predictive method=joback]
HvapTb      31010.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.55 0.7536 -0.000707 2.696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropylidenecyclopropane" "cyclopropane cyclopropylidene-" "cyclopropane,cyclopropylidene-" "bicyclopropylidene(8ci); 1,1'-bicyclopropylidene; cyclopropylidenecyclopropane" );
gibbsFormation
{
    dHf_298   53950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     244.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=147260.0
    phase     gas;
}
