/*--------------------------------*- Choupo -*-----------------------*\
  Component: diacetoxydimethylsilane  (C6H12O4Si, CAS 2182-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H12O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diacetoxydimethylsilane;
formula     C6H12O4Si;
CAS         2182-66-3;
InChIKey    RQVFGTYFBUVGOP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          176.243;      // g/mol [origin=calculated method=formula-sum]
Tc          642.29;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.4940;      // -   [origin=predictive method=lee-kesler]
Tb          454.72;      // K   [origin=predictive method=joback]
HvapTb      44058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (89.07 0.25808 0.0003014 -2.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH3COO; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[acetyloxy(dimethyl)silyl] ethanoate" "dimethyldiacetoxysilane" "silanediol, dimethyl-, diacetate" "dimethylsilanediyl diacetate" "silanediol, 1,1-dimethyl-, 1,1-diacetate" "(acetyloxy-dimethylsilyl) acetate" "rqvfgtyfbuvgop-uhfffaoysa-" "[acetyloxy(dimethyl)silyl] acetate" "silanediol,1,1-dimethyl-, 1,1-diacetate" );
standardThermochemistry
{
    dHf_298   -913350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-725860.0
}
