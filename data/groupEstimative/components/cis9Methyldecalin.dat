/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-9-methyldecalin  (C11H20, CAS 2547-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis9Methyldecalin;
formula     C11H20;
CAS         2547-26-4;
InChIKey    RAFDCSMAXTUJKJ-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          710.59;      // K   [origin=predictive method=joback]
Pc          28.627;      // bar [origin=predictive method=joback]
omega       0.3069;      // -   [origin=predictive method=lee-kesler]
Tb          482.08;      // K   [origin=predictive method=joback]
HvapTb      39443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-178.07 1.60412 -0.001362 4.967e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 1; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8a-methyl-2,3,4,4a,5,6,7,8-octahydro-1h-naphthalene" "trans-9-methyldecalin" "cis-4a-methyl-decahydronaphthalene" "trans-4a-methyl-decahydronaphthalene" "4a-methyldecalin" "4a-methyldecahydronaphthalene" "cis-4a-methyldecahydronaphthalene" "naphthalene, decahydro-4a-methyl-" "trans-4a-methyldecahydronaphthalene" "naphthalene, decahydro-4a-methyl-, cis-" "naphthalene, decahydro-4a-methyl-, trans-" );
standardThermochemistry
{
    dHf_298   -134170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     553.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109350.0
}
