/*--------------------------------*- Choupo -*-----------------------*\
  Component: eicosanoic acid  (C20H40O2, CAS 506-30-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eicosanoicAcid;
formula     C20H40O2;
CAS         506-30-9;
InChIKey    VKOBVWXKNCXXDE-UHFFFAOYSA-N;
MW          312.538;      // g/mol [origin=calculated method=formula-sum]
Tc          985.65;      // K   [origin=predictive method=joback]
Pc          10.757;      // bar [origin=predictive method=joback]
omega       0.9998;      // -   [origin=predictive method=lee-kesler]
Tb          802.71;      // K   [origin=predictive method=joback]
HvapTb      77278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.692 1.95462 -0.0011368 2.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "icosanoic acid" "arachic acid" "arachidic acid" "c 20" "c20 fatty acid" "peanut acid" "n-eicosanic acid" "n-eicosanoic acid" "arachidinic acid" "arachidate" "eicosanoate" "arachinsaeure" );
gibbsFormation
{
    dHf_298   -806400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     988.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-226390.0
    phase     gas;
}
