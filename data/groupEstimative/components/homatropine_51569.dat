/*--------------------------------*- Choupo -*-----------------------*\
  Component: homatropine  (C16H21NO3, CAS 51-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        homatropine;
formula     C16H21NO3;
CAS         51-56-9;
InChIKey    ZTVIKZXZYLEVOL-UHFFFAOYSA-N;
MW          275.348;      // g/mol [origin=calculated method=formula-sum]
Tc          979.33;      // K   [origin=predictive method=joback]
Pc          23.383;      // bar [origin=predictive method=joback]
omega       1.1926;      // -   [origin=predictive method=lee-kesler]
Tb          767.84;      // K   [origin=predictive method=joback]
HvapTb      78916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.9 1.81962 -0.001268 3.348e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8-methyl-8-azabicyclo[3.2.1]octan-3-yl) 2-oxidanyl-2-phenyl-ethanoate" "homotropine" "dl-homatropine hydrobromide" "8-methyl-8-azabicyclo[3.2.1]oct-3-yl hydroxy(phenyl)acetate" "homatropine hcl" "homatropin" "homoatropine" "mandelytropeine" "mandelyltropeine" "methylhomatropinum" "homatropine [ban]" "omatropina [dcit]" );
gibbsFormation
{
    dHf_298   -425200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     578.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-40910.0
    phase     gas;
}
