/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-3,5-dihydroxy-n,n-bis(2-hydroxyethyl)benzamide  (C11H14BrNO5, CAS 60679-72-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromo35DihydroxyNNBis2HydroxyethylBenzamide;
formula     C11H14BrNO5;
CAS         60679-72-3;
InChIKey    WFBOGRVLTDVBOL-UHFFFAOYSA-N;
MW          320.139;      // g/mol [origin=calculated method=formula-sum]
Tc          1183.42;      // K   [origin=predictive method=joback]
Pc          55.196;      // bar [origin=predictive method=joback]
omega       2.4053;      // -   [origin=predictive method=lee-kesler]
Tb          961.01;      // K   [origin=predictive method=joback]
HvapTb      117628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.116 1.4217 -0.00127758 4.6856e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group AC; count 2; } { group OH; count 2; } { group ACOH; count 2; } { group Br; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH; count 2; } { group OH_phenol; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-n,n-bis(2-hydroxyethyl)-3,5-bis(oxidanyl)benzamide" "benzamide, 4-bromo-3,5-dihydroxy-n,n-bis(2-hydroxyethyl)-" );
standardThermochemistry
{
    dHf_298   -723110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-442180.0
}
