/*--------------------------------*- Choupo -*-----------------------*\
  Component: aldrin  (C12H8Cl6, CAS 309-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aldrin;
formula     C12H8Cl6;
CAS         309-00-2;
InChIKey    QBYJBZPUGVGKQQ-SJJAEHHWSA-N;
MW          364.896;      // g/mol [origin=calculated method=formula-sum]
Tc          994.14;      // K   [origin=predictive method=joback]
Pc          25.151;      // bar [origin=predictive method=joback]
omega       0.5867;      // -   [origin=predictive method=lee-kesler]
Tb          720.69;      // K   [origin=predictive method=joback]
HvapTb      65796.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-219.64 2.3534 -0.00290428 1.3508e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group CH=CH; count 1; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group Cl; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hhdn" "aldocit" "aldrine" "aldrite" "aldrosol" "kortofin" "seedrin" "soilgrin" "tatuzinho" "aldron" "algran" "tipula" );
standardThermochemistry
{
    dHf_298   -16930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222640.0
}
