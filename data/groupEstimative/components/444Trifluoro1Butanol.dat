/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4,4-trifluoro-1-butanol  (C4H7F3O, CAS 461-18-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        444Trifluoro1Butanol;
formula     C4H7F3O;
CAS         461-18-7;
InChIKey    VKRFUGHXKNNIJO-UHFFFAOYSA-N;
MW          128.093;      // g/mol [origin=calculated method=formula-sum]
Tc          525.09;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.7413;      // -   [origin=predictive method=lee-kesler]
Tb          377.88;      // K   [origin=predictive method=joback]
HvapTb      37430.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.657 0.579 -0.0004452 1.349e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group C; count 1; } { group F; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4,4-tris(fluoranyl)butan-1-ol" "4,4,4-trifluorobutan-1-ol" "4,4,4-trifluorobutanol" "4,4,4-trifluoro-butan-1-ol" "4,4,4-trifluorobutanol-1" "1,1,1-trifluoro-butan-2-one" "1-butanol, 4,4,4-trifluoro-" "4,4,4-trifluoro-1-butanol;4,4,4-trifluorobutanol;trifluorobutanol;4,4,4-trifluorobutanol-1;" );
standardThermochemistry
{
    dHf_298   -875200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-735610.0
}
