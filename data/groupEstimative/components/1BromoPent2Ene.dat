/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-pent-2-ene  (C5H9Br, CAS 20599-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1BromoPent2Ene;
formula     C5H9Br;
CAS         20599-27-3;
InChIKey    FTBPZRNURKMEFD-UHFFFAOYSA-N;
MW          149.031;      // g/mol [origin=calculated method=formula-sum]
Tc          579.20;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.3407;      // -   [origin=predictive method=lee-kesler]
Tb          384.32;      // K   [origin=predictive method=joback]
HvapTb      33117.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.648 0.53702 -0.0004034 1.298e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylpent-2-ene" "(z)-1-bromo-2-pentene" "1-bromopent-2-ene" "1-bromo-2-pentene" "2-pentene, 1-bromo-, (z)-" "2-pentene, 1-bromo-, (2e)-" );
gibbsFormation
{
    dHf_298   -2980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85760.0
    phase     gas;
}
