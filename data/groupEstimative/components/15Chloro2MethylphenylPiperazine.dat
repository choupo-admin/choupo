/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(5-chloro-2-methylphenyl)piperazine  (C11H15ClN2, CAS 76835-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Chloro2MethylphenylPiperazine;
formula     C11H15ClN2;
CAS         76835-20-6;
InChIKey    FVDJRHNUZNLRJC-UHFFFAOYSA-N;
MW          210.705;      // g/mol [origin=calculated method=formula-sum]
Tc          849.04;      // K   [origin=predictive method=joback]
Pc          31.776;      // bar [origin=predictive method=joback]
omega       0.6086;      // -   [origin=predictive method=lee-kesler]
Tb          606.29;      // K   [origin=predictive method=joback]
HvapTb      57432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.72 1.12642 -0.00072692 1.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(5-chloranyl-2-methyl-phenyl)piperazine" "(5-chloro-2-methylphenyl)piperazine" "n-(5-chloro-2-methylphenyl)piperazine" "piperazine,1-(5-chloro-2-methylphenyl)-" "1-(5-chloro-2-methylphenyl)piperazine;1-(5-chloro-o-tolyl)piperazine; 4-(2-methyl-5-chlorophenyl)piperazine; n-(5-chloro-2-methylphenyl)piperazine" );
standardThermochemistry
{
    dHf_298   113640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=365710.0
}
