/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopropanol  (C3H6O, CAS 16545-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropanol;
formula     C3H6O;
CAS         16545-68-9;
InChIKey    YOXHCYXIAVIFCZ-UHFFFAOYSA-N;
MW          58.08;      // g/mol [origin=calculated method=formula-sum]
Tc          543.72;      // K   [origin=predictive method=joback]
Pc          60.655;      // bar [origin=predictive method=joback]
omega       0.5713;      // -   [origin=predictive method=lee-kesler]
Tb          367.16;      // K   [origin=predictive method=joback]
HvapTb      38864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.79 0.4737 -0.00039 1.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hydroxycyclopropane" "cyclopropyl alcohol" "cyclopropyl alcohol;hydroxycyclopropane;" );
gibbsFormation
{
    dHf_298   -184680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     233.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-101690.0
    phase     gas;
}
