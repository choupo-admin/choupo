/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-bis(diethylamino)-2-butyne  (C12H24N2, CAS 105-18-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14BisDiethylamino2Butyne;
formula     C12H24N2;
CAS         105-18-0;
InChIKey    ZSHOGSSMVWJOGA-UHFFFAOYSA-N;
MW          196.338;      // g/mol [origin=calculated method=formula-sum]
Tc          685.40;      // K   [origin=predictive method=joback]
Pc          20.401;      // bar [origin=predictive method=joback]
omega       0.6195;      // -   [origin=predictive method=lee-kesler]
Tb          508.04;      // K   [origin=predictive method=joback]
HvapTb      48544.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.844 1.24188 -0.00076206 1.8538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH2N; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group tC; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetraethylbut-2-yne-1,4-diamine" "2-butyne-1,4-diamine, n,n,n',n'-tetraethyl-" "n,n,n',n'-tetraethyl-2-butyne-1,4-diamine" "1,4-bis (diethylamino)-2-butyne" "n,n,n',n'-tetraethyl-2-butynylenediamine" "n,n,n',n'-tetraethylbut-2-ynylenediamine" "[4-(diethylamino)but-2-yn-1-yl]diethylamine" "2-butynylenediamine, n,n,n'n'-tetraethyl-" "2-butyne-1,4-diamine, n1,n1,n4,n4-tetraethyl-" "zshogssmvwjoga-uhfffaoysa-" "2-butyne-1, n,n,n',n'-tetraethyl-" "2-butynylenediamine,n,n'n'-tetraethyl-" );
standardThermochemistry
{
    dHf_298   116350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=474520.0
}
