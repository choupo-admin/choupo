/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl isodehydroacetate  (C10H12O4, CAS 3385-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylIsodehydroacetate;
formula     C10H12O4;
CAS         3385-34-0;
InChIKey    FBPWNVQUVXSXKS-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          773.57;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.7633;      // -   [origin=predictive method=lee-kesler]
Tb          573.78;      // K   [origin=predictive method=joback]
HvapTb      55632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.771 0.72156 -0.00033364 2.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH=C; count 1; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 3; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,4-dimethyl-6-oxidanylidene-pyran-3-carboxylate" "ethylisodehydroacetate" "ethyl 4,6-dimethyl-2-oxo-2h-pyran-5-carboxylate" "ethyl isodehydracetate" "5-carbethoxy-4,6-dimethyl-2-pyrone" "2h-pyran-5-carboxylic acid, 4,6-dimethyl-2-oxo-, ethyl ester" "ethyl 4,6-dimethyl-2-oxopyran-5-carboxylate" "ethyl 4,6-dimethyl-5-coumalate" "ethyl 2,4-dimethyl-6-oxopyran-3-carboxylate" "2,4-dimethyl-6-oxo-3-pyrancarboxylic acid ethyl ester" "2,4-dimethyl-6-oxo-6h-pyran-3-carboxylic acid ethyl ester" "2h-pyran-5-carboxylic acid,6-dimethyl-2-oxo-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -716160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-500030.0
}
