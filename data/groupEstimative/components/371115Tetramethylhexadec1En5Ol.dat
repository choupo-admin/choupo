/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,7,11,15-tetramethylhexadec-1-en-5-ol  (C20H40O, CAS 60046-87-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        371115Tetramethylhexadec1En5Ol;
formula     C20H40O;
CAS         60046-87-9;
InChIKey    WEINNTOCTSLDML-UHFFFAOYSA-N;
MW          296.539;      // g/mol [origin=calculated method=formula-sum]
Tc          917.98;      // K   [origin=predictive method=joback]
Pc          11.383;      // bar [origin=predictive method=joback]
omega       0.9919;      // -   [origin=predictive method=lee-kesler]
Tb          743.86;      // K   [origin=predictive method=joback]
HvapTb      74183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.402 1.9474 -0.0011335 2.515e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 5; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 8; } { group CH; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-hexadecen-3-ol,3,7,11,15-tetramethyl-" "(all-rac)-isophytol;1-phyten-3-ol; 3,7,11,15-tetramethyl-1-hexadecen-3-ol" );
gibbsFormation
{
    dHf_298   -509330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     933.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=56340.0
    phase     gas;
}
