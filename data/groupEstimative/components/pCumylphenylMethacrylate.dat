/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-cumylphenyl methacrylate  (C19H20O2, CAS 68443-35-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pCumylphenylMethacrylate;
formula     C19H20O2;
CAS         68443-35-6;
InChIKey    PDLZOMRBHUBXSF-UHFFFAOYSA-N;
MW          280.367;      // g/mol [origin=calculated method=formula-sum]
Tc          983.84;      // K   [origin=predictive method=joback]
Pc          18.515;      // bar [origin=predictive method=joback]
omega       0.7081;      // -   [origin=predictive method=lee-kesler]
Tb          744.21;      // K   [origin=predictive method=joback]
HvapTb      68623.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.64 1.64246 -0.00110756 2.75e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group ACH; count 9; } { group AC; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(2-phenylpropan-2-yl)phenyl] 2-methylprop-2-enoate" "4-cumylphenyl methacrylate" "2-propenoic acid, 2-methyl-, 4-(1-methyl-1-phenylethyl)phenyl ester" "4-(1-methyl-1-phenylethyl)phenyl methacrylate" );
standardThermochemistry
{
    dHf_298   -184290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=96050.0
}
