/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-aminophenyl)(phenyl)methanol  (C13H13NO, CAS 13209-38-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2AminophenylPhenylMethanol;
formula     C13H13NO;
CAS         13209-38-6;
InChIKey    NAWYZLGDGZTAPN-UHFFFAOYSA-N;
MW          199.253;      // g/mol [origin=calculated method=formula-sum]
Tc          954.69;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       1.0831;      // -   [origin=predictive method=lee-kesler]
Tb          719.65;      // K   [origin=predictive method=joback]
HvapTb      76678.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.34 1.1233 -0.00075576 1.899e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-aminophenyl)-phenyl-methanol" "2-aminobenzhydrol" "(2-aminophenyl)-phenylmethanol" "benzenemethanol, 2-amino-.alpha.-phenyl-" "(2-aminophenyl)phenylmethan-1-ol" "o-aminodiphenylcarbinol" "a-o-aminophenylbenzyl alcohol" "2-[hydroxy(phenyl)methyl]aniline" "benzenemethanol,2-amino-a-phenyl-" );
gibbsFormation
{
    dHf_298   26220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200960.0
    phase     gas;
}
