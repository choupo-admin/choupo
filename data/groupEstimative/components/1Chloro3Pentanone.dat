/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3-pentanone  (C5H9ClO, CAS 32830-97-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro3Pentanone;
formula     C5H9ClO;
CAS         32830-97-0;
InChIKey    APNSUHRNUVUCIP-UHFFFAOYSA-N;
MW          120.576;      // g/mol [origin=calculated method=formula-sum]
Tc          591.77;      // K   [origin=predictive method=joback]
Pc          35.771;      // bar [origin=predictive method=joback]
omega       0.4364;      // -   [origin=predictive method=lee-kesler]
Tb          405.30;      // K   [origin=predictive method=joback]
HvapTb      37855.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.593 0.45762 -0.0002499 4.826e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2CO; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylpentan-3-one" "3-pentanone, 1-chloro-" "1-chloropentan-3-one" "1-chloroethyl ethyl ketone" "beta-chloroethyl ethyl ketone" ".beta.-chloroethyl ethyl ketone" );
gibbsFormation
{
    dHf_298   -274850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149630.0
    phase     gas;
}
