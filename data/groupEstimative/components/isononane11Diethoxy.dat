/*--------------------------------*- Choupo -*-----------------------*\
  Component: isononane, 1,1-diethoxy-  (C13H28O2, CAS 67923-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isononane11Diethoxy;
formula     C13H28O2;
CAS         67923-83-5;
InChIKey    UAARUIRTLPTVEA-UHFFFAOYSA-N;
MW          216.365;      // g/mol [origin=calculated method=formula-sum]
Tc          707.10;      // K   [origin=predictive method=joback]
Pc          16.207;      // bar [origin=predictive method=joback]
omega       0.7128;      // -   [origin=predictive method=lee-kesler]
Tb          541.00;      // K   [origin=predictive method=joback]
HvapTb      48576.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.707 1.12428 -0.0004678 3.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diethoxy-7-methyl-octane" "1,1-diethoxy-7-methyloctane" "isononal diethyl acetal" "1,1-diethoxyisononane" "isononanal diethylacetal" );
gibbsFormation
{
    dHf_298   -586650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-156300.0
    phase     gas;
}
