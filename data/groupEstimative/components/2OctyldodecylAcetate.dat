/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-octyldodecyl acetate  (C22H44O2, CAS 74051-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OctyldodecylAcetate;
formula     C22H44O2;
CAS         74051-84-6;
InChIKey    WHCASFSSRGWZGS-UHFFFAOYSA-N;
MW          340.592;      // g/mol [origin=calculated method=formula-sum]
Tc          934.75;      // K   [origin=predictive method=joback]
Pc          9.089;      // bar [origin=predictive method=joback]
omega       0.8418;      // -   [origin=predictive method=lee-kesler]
Tb          760.74;      // K   [origin=predictive method=joback]
HvapTb      71585.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.617 2.04496 -0.0010816 1.93e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octyldodecyl ethanoate" "1-dodecanol, 2-octyl-, acetate" "1-dodecanol, 2-octyl-, 1-acetate" "2-octyl-1-dodecanol acetate" "1-dodecanol, 2-octyl-,1-acetate" "1-dodecanol,2-octyl-, acetate (9ci); 2-octyldodecyl acetate" );
gibbsFormation
{
    dHf_298   -819970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1054.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-178450.0
    phase     gas;
}
