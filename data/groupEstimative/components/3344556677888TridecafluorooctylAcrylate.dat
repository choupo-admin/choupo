/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluorooctyl acrylate  (C11H7F13O2, CAS 17527-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3344556677888TridecafluorooctylAcrylate;
formula     C11H7F13O2;
CAS         17527-29-6;
InChIKey    VPKQPPJQTZJZDB-UHFFFAOYSA-N;
MW          418.149;      // g/mol [origin=calculated method=formula-sum]
Tc          610.76;      // K   [origin=predictive method=joback]
Pc          13.738;      // bar [origin=predictive method=joback]
omega       0.7775;      // -   [origin=predictive method=lee-kesler]
Tb          477.31;      // K   [origin=predictive method=joback]
HvapTb      28420.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.348 1.8822 -0.0017469 5.842e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CF3; count 1; } { group CF2; count 5; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 6; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 13; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,6,6,7,7,8,8,8-tridecakis(fluoranyl)octyl prop-2-enoate" "2-propenoic acid, 3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluorooctyl ester" "1h,1h,2h,2h-perfluorooctyl acrylate" "1,1,2,2-tetrahydroperfluorooctyl acrylate" "3,3,4,4,5,5,6,6,7,7,8,8,8-tridecafluorooctyl prop-2-enoate" "2-(perfluorohexyl)ethyl acrylate" "2-(perfluorohex-1-yl)ethyl acrylate" );
gibbsFormation
{
    dHf_298   -3064150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     810.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2696280.0
    phase     gas;
}
