/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-(prop-2-en-1-yl)pent-4-enoic acid  (C9H14O2, CAS 93681-82-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Prop2En1YlPent4EnoicAcid;
formula     C9H14O2;
CAS         93681-82-4;
InChIKey    LLWNYXLAJUISMK-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          740.99;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.7195;      // -   [origin=predictive method=lee-kesler]
Tb          543.83;      // K   [origin=predictive method=joback]
HvapTb      51144.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.048 0.87542 -0.0005897 1.6e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-prop-2-enyl-pent-4-enoic acid" "2-allyl-4-methyl-4-pentenoic acid" "4-methyl-2-prop-2-enylpent-4-enoic acid" );
gibbsFormation
{
    dHf_298   -343570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154320.0
    phase     gas;
}
