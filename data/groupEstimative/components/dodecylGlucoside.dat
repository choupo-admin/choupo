/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecyl glucoside  (C18H36O6, CAS 59122-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecylGlucoside;
formula     C18H36O6;
CAS         59122-55-3;
InChIKey    PYIDGJJWBIBVIA-UYTYNIKBSA-N;
MW          348.48;      // g/mol [origin=calculated method=formula-sum]
Tc          1293.61;      // K   [origin=predictive method=joback]
Pc          15.610;      // bar [origin=predictive method=joback]
omega       1.0612;      // -   [origin=predictive method=lee-kesler]
Tb          1030.40;      // K   [origin=predictive method=joback]
HvapTb      128491.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.662 1.79972 -0.0008115 7.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH; count 4; } { group OH; count 4; } { group CH2O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group CH_ring; count 5; } { group OH; count 4; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r,4s,5s,6r)-2-dodecoxy-6-(hydroxymethyl)oxane-3,4,5-triol" "dodecyl beta-d-glucopyranoside" "dodecyl " "a-d-glucopyranoside" "n-dodecyl glucoside" "lauryl glucoside" "dodecyl d-glucoside" "dodecyl b-d-glucopyranoside" "dodecyl-beta-d-glucopyranoside" "n-dodecyl beta-d-glucopyranoside" );
standardThermochemistry
{
    dHf_298   -1315030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     820.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-644110.0
}
