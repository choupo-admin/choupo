/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 1129  (C21H14O, CAS 3343-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris1129;
formula     C21H14O;
CAS         3343-08-6;
InChIKey    WZVWVFJAIXIJNQ-UHFFFAOYSA-N;
MW          282.342;      // g/mol [origin=calculated method=formula-sum]
Tc          1128.76;      // K   [origin=predictive method=joback]
Pc          23.338;      // bar [origin=predictive method=joback]
omega       0.9463;      // -   [origin=predictive method=lee-kesler]
Tb          863.56;      // K   [origin=predictive method=joback]
HvapTb      77143.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.57 1.63002 -0.00130276 4.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 8; } { group ACCH3; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 9; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1h-benzo[j]aceanthrylen-2-one" "3-methylcholanthrene-2-one" "2-cholanthrenone, 3-methyl-" "benz(j)aceanthrylen-2(1h)-one, 3-methyl-" "benz[j]aceanthrylen-2(1h)-one, 3-methyl-" "benz[j]aceanthrylen-2(1h)-one,3-methyl-" "3-methylcyclopenta[ij]tetraphen-2(1h)-one" "2-cholanthrenone,3-methyl- (7ci,8ci); 2-oxo-3-methylcholanthrene; 3-methyl-2-oxocholanthrene;3-methylcholanthren-2-one; 3-methylcholanthrene-2-one" );
standardThermochemistry
{
    dHf_298   237220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     363.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=468120.0
}
