/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethoxybuta-1,3-diene  (C6H10O, CAS 19774-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethoxybuta13Diene;
formula     C6H10O;
CAS         19774-35-7;
InChIKey    LDVKFLIDEBQMNX-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          537.24;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.3211;      // -   [origin=predictive method=lee-kesler]
Tb          360.14;      // K   [origin=predictive method=joback]
HvapTb      30648.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.761 0.51062 -0.0002983 7.02e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 3; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-butadiene, 1-ethoxy-" "1,3-butadiene, 1-ethoxy-, (e)-" "1,3-butadiene,1-ethoxy-, (z)- (9ci)" "ether,1,3-butadienyl ethyl, (z)- (8ci); cis-1-ethoxy-1,3-butadiene" );
standardThermochemistry
{
    dHf_298   -56740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62700.0
}
