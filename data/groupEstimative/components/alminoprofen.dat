/*--------------------------------*- Choupo -*-----------------------*\
  Component: alminoprofen  (C13H17NO2, CAS 39718-89-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alminoprofen;
formula     C13H17NO2;
CAS         39718-89-3;
InChIKey    FPHLBGOJWPEVME-UHFFFAOYSA-N;
MW          219.284;      // g/mol [origin=calculated method=formula-sum]
Tc          940.93;      // K   [origin=predictive method=joback]
Pc          25.176;      // bar [origin=predictive method=joback]
omega       1.0032;      // -   [origin=predictive method=lee-kesler]
Tb          720.50;      // K   [origin=predictive method=joback]
HvapTb      70092.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.509 1.21324 -0.00079716 2.013e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-methylprop-2-enylamino)phenyl]propanoic acid" "minalfene" "alminoprofene" "alminoprofeno" "alminoprofenum" "(+)-alminoprofen" "(-)-alminoprofen" "alminoprofene [inn-french]" "alminoprofenum [inn-latin]" "p-((2-methylallyl)amino)hydratropic acid" "2-{4-[(2-methylprop-2-en-1-yl)amino]phenyl}propanoic acid" "2-(4-((2-methylallyl)amino)phenyl)propansaeure" );
gibbsFormation
{
    dHf_298   -273030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16310.0
    phase     gas;
}
