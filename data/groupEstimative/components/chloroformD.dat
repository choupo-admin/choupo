/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloroform-d  (CDCl3, CAS 865-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula CDCl3 (delta D+1H-1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloroformD;
formula     CDCl3;
CAS         865-49-6;
InChIKey    HEDRZPFGACZZDS-MICDWDOJSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          120.375;      // g/mol [origin=calculated method=formula-sum]
Tc          532.43;      // K   [origin=predictive method=joback]
Pc          49.804;      // bar [origin=predictive method=joback]
omega       0.2105;      // -   [origin=predictive method=lee-kesler]
Tb          334.33;      // K   [origin=predictive method=joback]
HvapTb      30587.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.97 0.1251 -9.5e-05 2.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris(chloranyl)-deuterio-methane" "deuterochloroform" "methane-d, trichloro-" "chloroform, deutero-" "chloroform- d" "trichloromethane-d" "(2h)chloroform" "deuterated chloroform" "trichloro(deuterio)methane" "de38a" "chloroform, deuterated, 99%" ""chloroform-d ""100%"" >99.96 atom % d"" );
standardThermochemistry
{
    dHf_298   -116470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     285.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80690.0
}
