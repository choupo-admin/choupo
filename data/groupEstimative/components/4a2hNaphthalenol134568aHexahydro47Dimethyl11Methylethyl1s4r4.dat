/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4a(2h)-naphthalenol,1,3,4,5,6,8a-hexahydro-4,7-dimethyl-1-(1-methylethyl)-, (1s,4r,4ar,8ar)-  (C8H6O, CAS 21284-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4a2hNaphthalenol134568aHexahydro47Dimethyl11Methylethyl1s4r4;
formula     C8H6O;
CAS         21284-22-0;
InChIKey    XDMOPVQNPWVPSX-UHFFFAOYSA-N;
MW          118.135;      // g/mol [origin=calculated method=formula-sum]
Tc          673.30;      // K   [origin=predictive method=joback]
Pc          50.948;      // bar [origin=predictive method=joback]
omega       0.8680;      // -   [origin=predictive method=lee-kesler]
Tb          483.32;      // K   [origin=predictive method=joback]
HvapTb      48598.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-222.13 1.7099 -0.002198 1.0238e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 5; } { group C; count 1; } { group OH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 5; } { group C_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10bh-cadin-4-en-1-ol (8ci);4a(2h)-naphthalenol, 1,3,4,5,6,8a-hexahydro-4,7-dimethyl-1-(1-methylethyl)-,[1s-(1a,4b,4ab,8aa)]-; (-)-cubenol; cubenol" );
gibbsFormation
{
    dHf_298   76180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -94.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265610.0
    phase     gas;
}
