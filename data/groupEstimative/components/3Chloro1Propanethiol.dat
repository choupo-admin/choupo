/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-1-propanethiol  (C3H7ClS, CAS 17481-19-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro1Propanethiol;
formula     C3H7ClS;
CAS         17481-19-5;
InChIKey    TZCFWOHAWRIQGF-UHFFFAOYSA-N;
MW          110.599;      // g/mol [origin=calculated method=formula-sum]
Tc          569.69;      // K   [origin=predictive method=joback]
Pc          45.716;      // bar [origin=predictive method=joback]
omega       0.2859;      // -   [origin=predictive method=lee-kesler]
Tb          368.53;      // K   [origin=predictive method=joback]
HvapTb      33394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.943 0.3229 -0.0001822 3.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2Cl; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group Cl; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropane-1-thiol" "3-chloropropane-1-thiol" "3-chloropropanethiol" "1-propanethiol,3-chloro- (8ci,9ci)" "3-chloropropan-1-thiol; 3-chloropropanethiol; 3-chloropropyl mercaptan" );
standardThermochemistry
{
    dHf_298   -82510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-8160.0
}
