/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-di-tert-amylhydroquinone  (C16H26O2, CAS 79-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DiTertAmylhydroquinone;
formula     C16H26O2;
CAS         79-74-3;
InChIKey    CZNRFEXEPBITDS-UHFFFAOYSA-N;
MW          250.382;      // g/mol [origin=calculated method=formula-sum]
Tc          981.71;      // K   [origin=predictive method=joback]
Pc          22.633;      // bar [origin=predictive method=joback]
omega       0.9394;      // -   [origin=predictive method=lee-kesler]
Tb          752.12;      // K   [origin=predictive method=joback]
HvapTb      77584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.048 1.94632 -0.00166708 5.898e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(2-methylbutan-2-yl)benzene-1,4-diol" "santouar a" "santovar a" "2,5-di-tert-pentylhydroquinone" "2,5-di-tert-pentylbenzene-1,4-diol" "dahq" "diamylhydroquinone" "antage dah" "hydroquinone, 2,5-di-tert-pentyl-" "usaf b-21" "2,5-di(tert-amyl)hydroquinone" "1,4-benzenediol, 2,5-bis(1,1-dimethylpropyl)-" );
standardThermochemistry
{
    dHf_298   -520630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116940.0
}
