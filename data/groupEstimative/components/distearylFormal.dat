/*--------------------------------*- Choupo -*-----------------------*\
  Component: distearyl formal  (C37H76O2, CAS 41344-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        distearylFormal;
formula     C37H76O2;
CAS         41344-25-6;
InChIKey    WXZWIPLBXXXGGI-UHFFFAOYSA-N;
MW          553.013;      // g/mol [origin=calculated method=formula-sum]
Tc          1437.76;      // K   [origin=predictive method=joback]
Pc          4.333;      // bar [origin=predictive method=joback]
omega       -0.1641;      // -   [origin=predictive method=lee-kesler]
Tb          1091.00;      // K   [origin=predictive method=joback]
HvapTb      102776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.255 3.39244 -0.001767 3.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 33; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 35; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(octadecoxymethoxy)octadecane" "octadecane, 1,1'-(methylenebis(oxy))bis-" "octadecane, 1,1'-[methylenebis(oxy)]bis-" "1,1'-(methylenebis(oxy))bisoctadecane" );
gibbsFormation
{
    dHf_298   -1071450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1619.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50660.0
    phase     gas;
}
