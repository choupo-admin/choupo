/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinylcyclohexene  (C8H12, CAS 100-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylcyclohexene;
formula     C8H12;
CAS         100-40-3;
InChIKey    BBDKZWKEPDTENS-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          605.79;      // K   [origin=predictive method=joback]
Pc          34.480;      // bar [origin=predictive method=joback]
omega       0.2493;      // -   [origin=predictive method=lee-kesler]
Tb          398.03;      // K   [origin=predictive method=joback]
HvapTb      33453.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.2 0.8099 -0.00050258 1.152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-ethenylcyclohexene" "1-vinyl-3-cyclohexene" "4-ethenyl-1-cyclohexene" "4-vch" "4-vinyl-1-cyclohexene" "4-vinylcyclohexene" "5-vinyl-2-cyclohexene" "cyclohexene, 4-ethenyl-" "cyclohexene, 4-vinyl-" "4-vinylcyclohex-1-ene" "cyclohexenylethylene" "butadiene dimer" );
gibbsFormation
{
    dHf_298   29080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158730.0
    phase     gas;
}
