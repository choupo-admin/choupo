/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl .alpha.-acetylcinnamate  (C13H14O3, CAS 620-80-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylAlphaAcetylcinnamate;
formula     C13H14O3;
CAS         620-80-4;
InChIKey    AYZGINZXVVKWKV-UHFFFAOYSA-N;
MW          218.252;      // g/mol [origin=calculated method=formula-sum]
Tc          859.75;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.7560;      // -   [origin=predictive method=lee-kesler]
Tb          639.85;      // K   [origin=predictive method=joback]
HvapTb      60999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.939 1.09704 -0.0006874 1.5206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylidene-2-(phenylmethylidene)butanoate" "butanoic acid, 3-oxo-2-(phenylmethylene)-, ethyl ester, (e)-" "butanoic acid, 3-oxo-2-(phenylmethylene)-, ethyl ester, (z)-" );
standardThermochemistry
{
    dHf_298   -397550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-196630.0
}
