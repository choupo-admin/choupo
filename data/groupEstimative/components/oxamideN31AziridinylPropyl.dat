/*--------------------------------*- Choupo -*-----------------------*\
  Component: oxamide, n-[3-(1-aziridinyl)propyl]-  (C7H13N3O2, CAS 24480-30-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oxamideN31AziridinylPropyl;
formula     C7H13N3O2;
CAS         24480-30-6;
InChIKey    NZNJMRUHUSZTRM-UHFFFAOYSA-N;
MW          171.2;      // g/mol [origin=calculated method=formula-sum]
Tc          813.39;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       1.1087;      // -   [origin=predictive method=lee-kesler]
Tb          609.78;      // K   [origin=predictive method=joback]
HvapTb      63838.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.227 1.0618 -0.0008462 2.7032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2N; count 1; } { group CONH2; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 2; } { group CdO; count 2; } { group NH2; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[3-(aziridin-1-yl)propyl]ethanediamide" );
gibbsFormation
{
    dHf_298   -158880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97400.0
    phase     gas;
}
