/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzenepropanol  (C9H12O, CAS 122-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzenepropanol;
formula     C9H12O;
CAS         122-97-4;
InChIKey    VAJVDSVGBWFCLW-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          719.36;      // K   [origin=predictive method=joback]
Pc          36.334;      // bar [origin=predictive method=joback]
omega       0.8107;      // -   [origin=predictive method=lee-kesler]
Tb          524.38;      // K   [origin=predictive method=joback]
HvapTb      54583.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.907 0.8139 -0.0005274 1.312e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylpropan-1-ol" "3-phenyl-1-propanol" "hydrocinnamyl alcohol" "3-phenylpropyl alcohol" "1-propanol, 3-phenyl-" "3-phenylpropanol" "3-benzenepropanol" "3-phenylpropanol-1" "hydrocinnamic alcohol" "3-phenyl-n-propanol" "(3-hydroxypropyl)benzene" "benzylethyl alcohol" );
standardThermochemistry
{
    dHf_298   -144790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=490.0
}
