/*--------------------------------*- Choupo -*-----------------------*\
  Component: (z)-5-(1-methoxyethylidenebicyclo(2.2.1)hept-2-ene  (C10H14O, CAS 103582-48-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z51Methoxyethylidenebicyclo221Hept2Ene;
formula     C10H14O;
CAS         103582-48-5;
InChIKey    WSAAWMQXWNFTNH-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          683.54;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.4203;      // -   [origin=predictive method=lee-kesler]
Tb          474.25;      // K   [origin=predictive method=joback]
HvapTb      41421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.12 1.04924 -0.00076128 2.286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH3O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-(1-methoxyethylidene)bicyclo[2.2.1]hept-2-ene" "(z)-5-(1-methoxyethylidenebicyclo[2.2.1]hept-2-ene" "agn-pc-03d0ni" "(5z)-5-(1-methoxyethylidene)bicyclo[2.2.1]hept-2-ene" "1-(bicyclo[2.2.1]hept-5-en-2-ylidene)ethyl methyl ether" );
standardThermochemistry
{
    dHf_298   -118490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     326.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=104590.0
}
