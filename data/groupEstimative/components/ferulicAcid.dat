/*--------------------------------*- Choupo -*-----------------------*\
  Component: ferulic acid  (C10H10O4, CAS 537-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ferulicAcid;
formula     C10H10O4;
CAS         537-98-4;
InChIKey    KSEBMYQBYZTDHS-HWKANZROSA-N;
MW          194.186;      // g/mol [origin=calculated method=formula-sum]
Tc          948.24;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       1.1103;      // -   [origin=predictive method=lee-kesler]
Tb          712.77;      // K   [origin=predictive method=joback]
HvapTb      73338.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.81 0.97762 -0.00078612 2.621e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-(3-methoxy-4-oxidanyl-phenyl)prop-2-enoic acid" "4-hydroxy-3-methoxycinnamic acid" "trans-ferulic acid" "trans-4-hydroxy-3-methoxycinnamic acid" "ferulate" "(e)-ferulic acid" "coniferic acid" "2-propenoic acid, 3-(4-hydroxy-3-methoxyphenyl)-" "3-(4-hydroxy-3-methoxyphenyl)acrylic acid" "cinnamic acid, 4-hydroxy-3-methoxy-" "fumalic acid" "3-(4-hydroxy-3-methoxyphenyl)-2-propenoic acid" );
standardThermochemistry
{
    dHf_298   -567250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     517.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-387210.0
}
