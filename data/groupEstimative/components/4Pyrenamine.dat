/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pyrenamine  (C16H11N, CAS 17075-03-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pyrenamine;
formula     C16H11N;
CAS         17075-03-5;
InChIKey    AYBSKADMMKVOIV-UHFFFAOYSA-N;
MW          217.271;      // g/mol [origin=calculated method=formula-sum]
Tc          990.61;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.8179;      // -   [origin=predictive method=lee-kesler]
Tb          729.07;      // K   [origin=predictive method=joback]
HvapTb      70397.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.04 1.3924 -0.00123576 4.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 6; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 7; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyren-4-amine" "4-aminopyrene" "pyren-4-ylamine" "4-aminopyrene;" "pyrene-4-ylamine" );
gibbsFormation
{
    dHf_298   390090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=548000.0
    phase     gas;
}
