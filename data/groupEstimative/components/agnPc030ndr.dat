/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-030ndr  (C25H43NO5, CAS 67815-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc030ndr;
formula     C25H43NO5;
CAS         67815-89-8;
InChIKey    BAMILFSYGWVQLH-UHFFFAOYSA-N;
MW          437.621;      // g/mol [origin=calculated method=formula-sum]
Tc          1345.01;      // K   [origin=predictive method=joback]
Pc          8.986;      // bar [origin=predictive method=joback]
omega       0.7620;      // -   [origin=predictive method=lee-kesler]
Tb          1087.25;      // K   [origin=predictive method=joback]
HvapTb      108525.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.725 2.46894 -0.0015149 3.5296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 14; } { group CH; count 1; } { group CH=CH; count 2; } { group COOH; count 1; } { group COO; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 15; } { group CH; count 1; } { group dCH; count 4; } { group CdO; count 1; } { group COOH; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-(octadec-9-enoylamino)propan-2-yloxy]-4-oxidanylidene-but-2-enoic acid" "2-butenedioic acid (2z)-, 1-[1-methyl-2-[[(9z)-1-oxo-9-octadecen-1-yl]amino]ethyl] ester" "(z)-4-[1-[[(e)-octadec-9-enoyl]amino]propan-2-yloxy]-4-oxobut-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1056830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1278.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-376190.0
    phase     gas;
}
