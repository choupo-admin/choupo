/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylbutyl acetate  (C7H14O2, CAS 624-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylbutylAcetate;
formula     C7H14O2;
CAS         624-41-9;
InChIKey    XHIUFYZDQBSEMF-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          594.25;      // K   [origin=predictive method=joback]
Pc          28.384;      // bar [origin=predictive method=joback]
omega       0.4666;      // -   [origin=predictive method=lee-kesler]
Tb          417.54;      // K   [origin=predictive method=joback]
HvapTb      38195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.252 0.61996 -0.0002656 1.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbutyl ethanoate" "2-methyl-1-butyl acetate" "1-butanol, 2-methyl-, acetate" "acetic acid 2-methylbutyl ester" "2-methylbutyl acetate (natural)" "1-butanol, 2-methyl-, 1-acetate" "2-methylbutanol acetate" "[(2s)-2-methylbutyl] acetate" "xhiufyzdqbsemf-uhfffaoysa-" "(s)-2-methylbutyl acetate" "1-butanol,2-methyl-, acetate (6ci,7ci,8ci,9ci);2-methyl-1-butyl acetate;2-methylbutylacetate;" );
gibbsFormation
{
    dHf_298   -510370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     470.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304750.0
    phase     gas;
}
