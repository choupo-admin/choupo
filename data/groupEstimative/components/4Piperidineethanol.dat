/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-piperidineethanol  (C7H15NO, CAS 622-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Piperidineethanol;
formula     C7H15NO;
CAS         622-26-4;
InChIKey    LDSQQXKSEFZAPE-UHFFFAOYSA-N;
MW          129.203;      // g/mol [origin=calculated method=formula-sum]
Tc          718.75;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.8143;      // -   [origin=predictive method=lee-kesler]
Tb          520.04;      // K   [origin=predictive method=joback]
HvapTb      55042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.868 0.8115 -0.0004078 5.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-piperidin-4-ylethanol" "4-(2-hydroxyethyl)piperidine" "2-(piperidin-4-yl)ethanol" "4-piperidine ethanol" "2-(piperidin-4-yl)ethan-1-ol" "4-hydroxyethyl-piperidine" "4-ethanolpiperidine" "2-(4-piperidyl)ethan-1-ol" );
gibbsFormation
{
    dHf_298   -247910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16600.0
    phase     gas;
}
