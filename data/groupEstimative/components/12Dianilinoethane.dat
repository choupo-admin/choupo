/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dianilinoethane  (C14H16N2, CAS 150-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dianilinoethane;
formula     C14H16N2;
CAS         150-61-8;
InChIKey    NOUUUQMKVOUUNR-UHFFFAOYSA-N;
MW          212.296;      // g/mol [origin=calculated method=formula-sum]
Tc          908.91;      // K   [origin=predictive method=joback]
Pc          28.475;      // bar [origin=predictive method=joback]
omega       0.8030;      // -   [origin=predictive method=lee-kesler]
Tb          673.62;      // K   [origin=predictive method=joback]
HvapTb      64182.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.068 1.3284 -0.0008974 2.274e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-diphenylethane-1,2-diamine" "n,n'-diphenylethylenediamine" "stabilite" "n,n'-ethylenedianiline" "nodx" "sym-diphenylethylenediamine" "1,2-ethanediamine, n,n'-diphenyl-" "aniline, n,n'-ethylenedi-" "ethylenediamine, n,n'-diphenyl-" "n,n'-diphenyl-1,2-ethylenediamine" "1,2-ethanediamine, n1,n2-diphenyl-" "benzenamine, n,n'-1,2-ethanediylbis-" );
gibbsFormation
{
    dHf_298   247710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=470600.0
    phase     gas;
}
