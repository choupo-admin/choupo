/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-iodobutyrate  (C5H9IO2, CAS 14273-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Iodobutyrate;
formula     C5H9IO2;
CAS         14273-85-9;
InChIKey    NBCIIVXSBPDKOM-UHFFFAOYSA-N;
MW          228.025;      // g/mol [origin=calculated method=formula-sum]
Tc          674.92;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.4482;      // -   [origin=predictive method=lee-kesler]
Tb          465.36;      // K   [origin=predictive method=joback]
HvapTb      43504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.443 0.46302 -0.000235 3.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2COO; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-iodanylbutanoate" "methyl 4-iodobutanoate" "butyric acid, 4-iodo-, methyl ester" "butanoic acid, 4-iodo-,methyl ester" "butanoic acid, 4-iodo-, methyl ester" "butyricacid, 4-iodo-, methyl ester (8ci); 4-iodobutanoic acid methyl ester;4-iodobutyric acid methyl ester; methyl 4-iodobutanoate; methyl 4-iodobutyrate;methyl g-iodobutyrate" );
standardThermochemistry
{
    dHf_298   -386940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-261030.0
}
