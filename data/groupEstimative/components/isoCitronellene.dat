/*--------------------------------*- Choupo -*-----------------------*\
  Component: iso-citronellene  (C10H18, CAS 6874-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoCitronellene;
formula     C10H18;
CAS         6874-43-7;
InChIKey    FYZHLRMYDRUDES-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          609.70;      // K   [origin=predictive method=joback]
Pc          23.315;      // bar [origin=predictive method=joback]
omega       0.3832;      // -   [origin=predictive method=lee-kesler]
Tb          428.68;      // K   [origin=predictive method=joback]
HvapTb      36834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.748 0.95966 -0.0006324 1.739e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,7-dimethylocta-1,6-diene" "2,4-dimethyl 2,7-octadiene" "1, 5,7-dimethyl-" "r(+)5,7-dimethyl-1,6-octadiene" "1,6-octadiene,5,7-dimethyl-, (r)-" "1,6-octadiene, 5,7-dimethyl-, (r)-" "1,6-octadiene,5,7-dimethyl-, (5r)-" );
gibbsFormation
{
    dHf_298   -22150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=190390.0
    phase     gas;
}
