/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-hydroxyphenyl)-1,1,3-trimethylindan-5-ol  (C18H20O2, CAS 10527-11-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Hydroxyphenyl113Trimethylindan5Ol;
formula     C18H20O2;
CAS         10527-11-4;
InChIKey    TUJHKTMBIVIOOV-UHFFFAOYSA-N;
MW          268.356;      // g/mol [origin=calculated method=formula-sum]
Tc          1101.40;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       1.0140;      // -   [origin=predictive method=lee-kesler]
Tb          833.57;      // K   [origin=predictive method=joback]
HvapTb      84206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-229.11 2.51396 -0.00269348 1.1624e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 2; } { group ACH; count 7; } { group AC; count 3; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-hydroxyphenyl)-1,1,3-trimethyl-2h-inden-5-ol" "1h-inden-5-ol, 2,3-dihydro-3-(4-hydroxyphenyl)-1,1,3-trimethyl-" "3-(p-hydroxyphenyl)-1,1,3-trimethyl-5-indanol" "3-(4-hydroxyphenyl)-1,1,3-trimethyl-2,3-dihydro-1h-inden-5-ol" "agn-pc-01zg78" );
gibbsFormation
{
    dHf_298   -224940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48690.0
    phase     gas;
}
