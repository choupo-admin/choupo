/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,6-dimethylfulvene  (C8H10, CAS 2175-91-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        66Dimethylfulvene;
formula     C8H10;
CAS         2175-91-9;
InChIKey    WXACXMWYHXOSIX-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          616.96;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.2830;      // -   [origin=predictive method=lee-kesler]
Tb          407.43;      // K   [origin=predictive method=joback]
HvapTb      35419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.84 0.73244 -0.00053956 1.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-propan-2-ylidenecyclopenta-1,3-diene" "dimethylfulvene" "1,3-cyclopentadiene, 5-(1-methylethylidene)-" "5-isopropylidene-1,3-cyclopentadiene" "5-(propan-2-ylidene)cyclopenta-1,3-diene" "1,3-cyclopentadiene, 5-isopropylidene-" "5-(1-methylethylidene)-1,3-cyclopentadiene" "6,6'-dimethylfulvene" "1, 5-isopropylidene-" "isopropylidenecyclopentadiene" "1, 5-(1-methylethylidene)-" "5-isopropylidenecyclopenta-1,3-diene" );
standardThermochemistry
{
    dHf_298   54170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157570.0
}
