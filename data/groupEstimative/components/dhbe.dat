/*--------------------------------*- Choupo -*-----------------------*\
  Component: dhbe  (C8H18O3, CAS 821-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dhbe;
formula     C8H18O3;
CAS         821-33-0;
InChIKey    AFSYRVDDZGJTIL-UHFFFAOYSA-N;
MW          162.229;      // g/mol [origin=calculated method=formula-sum]
Tc          750.61;      // K   [origin=predictive method=joback]
Pc          30.762;      // bar [origin=predictive method=joback]
omega       1.3922;      // -   [origin=predictive method=lee-kesler]
Tb          588.54;      // K   [origin=predictive method=joback]
HvapTb      68394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.334 0.78044 -0.0003676 4.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 2; } { group OH; count 2; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-oxidanylbutoxy)butan-2-ol" "2-butanol, 4,4'-oxybis-" "dyskinebyl" "boutybil" "discinil" "5-oxa-2,8-nonandiol" "4,4'-oxydi-2-butanol" "4,4'-oxybisbutan-2-ol" "4-(3-hydroxybutoxy)butan-2-ol" "1,1'-dimethyl-3,3'-oxydipropanol" "2-butanol,4,4'-oxydi- (6ci,7ci,8ci); 3,3'-dihydroxydibutyl ether; 4,4'-oxydi-2-butanol;bis(3-hydroxybutyl) ether; colenormol; dhbe; dis-cinil; diskin; dyskinebyl" );
standardThermochemistry
{
    dHf_298   -655690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-367040.0
}
