/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-desmethyltamoxifen  (C25H27NO, CAS 31750-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nDesmethyltamoxifen;
formula     C25H27NO;
CAS         31750-48-8;
InChIKey    NYDCDZSEEAUOHN-OCOZRVBESA-N;
MW          357.497;      // g/mol [origin=calculated method=formula-sum]
Tc          1177.45;      // K   [origin=predictive method=joback]
Pc          15.000;      // bar [origin=predictive method=joback]
omega       0.9761;      // -   [origin=predictive method=lee-kesler]
Tb          933.13;      // K   [origin=predictive method=joback]
HvapTb      87698.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.527 2.11544 -0.00138876 3.446e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 14; } { group AC; count 4; } { group CH2O; count 1; } { group CH3NH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dC; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group O; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-[(e)-1,2-diphenylbut-1-enyl]phenoxy]-n-methyl-ethanamine" "desmethyltamoxifen" "ici 55,548" "cis-2-(p-(1,2-diphenyl-1-butenyl)phenoxy)-n-methylethylamine" "ethylamine, 2-(p-(1,2-diphenyl-1-butenyl)phenoxy)-n-methyl-, (z)-" "2-[4-(1,2-diphenylbut-1-en-1-yl)phenoxy]-n-methylethanamine" "2-[4-[(e)-1,2-diphenylbut-1-enyl]phenoxy]-n-methylethanamine" "ethanamine, 2-(4-(1,2-diphenyl-1-butenyl)phenoxy)-n-methyl-, (z)-" "ethanamine, 2-(4-(1,2-diphenyl-1-butenyl)phenoxy)-n-methyl-, (z)- (9ci)" );
gibbsFormation
{
    dHf_298   157680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     841.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=534730.0
    phase     gas;
}
