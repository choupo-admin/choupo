/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2e,4e)-octa-2,4-dien-1-ol  (C8H14O, CAS 18409-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2e4eOcta24Dien1Ol;
formula     C8H14O;
CAS         18409-20-6;
InChIKey    LMBAOEUOOJDUBP-YTXTXJHMSA-N;
MW          126.199;      // g/mol [origin=calculated method=formula-sum]
Tc          657.32;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.7913;      // -   [origin=predictive method=lee-kesler]
Tb          483.14;      // K   [origin=predictive method=joback]
HvapTb      49997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.457 0.83782 -0.0006094 1.886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH=CH; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octa-2,4-dien-1-ol" "2,4-octadien-1-ol, (2e,4e)-" "trans-2,4-octadienol" "(2e,4e)-octa-2,4-dienol" "(e,e)-2,4-octadien-1-ol" );
standardThermochemistry
{
    dHf_298   -126240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40100.0
}
