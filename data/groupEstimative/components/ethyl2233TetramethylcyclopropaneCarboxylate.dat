/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2,2,3,3-tetramethylcyclopropane-carboxylate  (C10H18O2, CAS 771-10-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2233TetramethylcyclopropaneCarboxylate;
formula     C10H18O2;
CAS         771-10-8;
InChIKey    JGWIOJNKGNJJLE-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          680.89;      // K   [origin=predictive method=joback]
Pc          24.532;      // bar [origin=predictive method=joback]
omega       0.4675;      // -   [origin=predictive method=lee-kesler]
Tb          484.50;      // K   [origin=predictive method=joback]
HvapTb      42254.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.139 1.5808 -0.0016002 6.896e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group C; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH_ring; count 1; } { group C_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2,2,3,3-tetramethylcyclopropane-1-carboxylate" "ethyl 2,2,3,3-tetramethylcyclopropanecarboxylate" );
gibbsFormation
{
    dHf_298   -504410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242700.0
    phase     gas;
}
