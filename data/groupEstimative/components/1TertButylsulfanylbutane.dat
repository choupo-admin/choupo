/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butylsulfanylbutane  (C8H18S, CAS 926-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButylsulfanylbutane;
formula     C8H18S;
CAS         926-47-6;
InChIKey    XRYKNXGXIFPTKH-UHFFFAOYSA-N;
MW          146.292;      // g/mol [origin=calculated method=formula-sum]
Tc          646.04;      // K   [origin=predictive method=joback]
Pc          26.298;      // bar [origin=predictive method=joback]
omega       0.3712;      // -   [origin=predictive method=lee-kesler]
Tb          448.19;      // K   [origin=predictive method=joback]
HvapTb      38923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.257 0.88407 -0.000543 1.283e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(tert-butylsulfanyl)butane" "butane, 1-[(1,1-dimethylethyl)thio]-" );
gibbsFormation
{
    dHf_298   -175330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52440.0
    phase     gas;
}
