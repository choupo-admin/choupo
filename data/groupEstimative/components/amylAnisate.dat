/*--------------------------------*- Choupo -*-----------------------*\
  Component: amyl anisate  (C13H18O3, CAS 6938-46-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amylAnisate;
formula     C13H18O3;
CAS         6938-46-1;
InChIKey    DNJKWCMASVISFH-UHFFFAOYSA-N;
MW          222.284;      // g/mol [origin=calculated method=formula-sum]
Tc          809.11;      // K   [origin=predictive method=joback]
Pc          21.394;      // bar [origin=predictive method=joback]
omega       0.7612;      // -   [origin=predictive method=lee-kesler]
Tb          609.34;      // K   [origin=predictive method=joback]
HvapTb      57287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.374 0.98244 -0.00044196 3.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentyl 4-methoxybenzoate" "anisic acid, pentyl ester" "benzoic acid,4-methoxy-, pentyl ester" );
gibbsFormation
{
    dHf_298   -536090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-254010.0
    phase     gas;
}
