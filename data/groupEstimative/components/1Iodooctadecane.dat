/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodooctadecane  (C18H37I, CAS 629-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodooctadecane;
formula     C18H37I;
CAS         629-93-6;
InChIKey    ZNJOCVLVYVOUGB-UHFFFAOYSA-N;
MW          380.394;      // g/mol [origin=calculated method=formula-sum]
Tc          883.90;      // K   [origin=predictive method=joback]
Pc          11.352;      // bar [origin=predictive method=joback]
omega       0.8170;      // -   [origin=predictive method=lee-kesler]
Tb          704.58;      // K   [origin=predictive method=joback]
HvapTb      65035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.783 1.75282 -0.0010368 2.429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyloctadecane" "octadecyl iodide" "octadecane, 1-iodo-" "stearyl iodide" "iodooctadecane" "u365" );
standardThermochemistry
{
    dHf_298   -337980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     912.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158800.0
}
