/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihexyl adipate  (C18H34O4, CAS 110-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihexylAdipate;
formula     C18H34O4;
CAS         110-33-8;
InChIKey    HHECSPXBQJHZAF-UHFFFAOYSA-N;
MW          314.466;      // g/mol [origin=calculated method=formula-sum]
Tc          900.77;      // K   [origin=predictive method=joback]
Pc          11.601;      // bar [origin=predictive method=joback]
omega       0.9767;      // -   [origin=predictive method=lee-kesler]
Tb          727.88;      // K   [origin=predictive method=joback]
HvapTb      70476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.344 1.60424 -0.0007662 8.88e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dihexyl hexanedioate" "hexanedioic acid, dihexyl ester" "adipic acid, dihexyl ester" "di-n-hexyl adipate" "plasticizer dihexyl adipate" "hexanedioic acid, 1,6-dihexyl ester" "dihexyl hexane-1,6-dioate" "hexanedioic acid dihexyl ester" "hexanedioic acid,1,6-dihexyl ester" "adipicacid, dihexyl ester (6ci,7ci,8ci); hexanedioic acid, dihexyl ester (9ci);dihexyl adipate; dihexyl hexanedioate; plastomoll dha" );
standardThermochemistry
{
    dHf_298   -1049410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     959.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-520060.0
}
