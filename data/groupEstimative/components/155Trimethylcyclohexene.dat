/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5,5-trimethylcyclohexene  (C9H16, CAS 503-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        155Trimethylcyclohexene;
formula     C9H16;
CAS         503-46-8;
InChIKey    CHOOCIQDWNAXQQ-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          641.22;      // K   [origin=predictive method=joback]
Pc          30.490;      // bar [origin=predictive method=joback]
omega       0.2784;      // -   [origin=predictive method=lee-kesler]
Tb          429.45;      // K   [origin=predictive method=joback]
HvapTb      35860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.81 1.15736 -0.00099964 3.828e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylcyclohexene" "cyclohexene,1,5,5-trimethyl-" "cyclohexene, 1,5,5-trimethyl-" "1,5,5-trimethylcyclohexene;a-cyclogeraniolene" );
gibbsFormation
{
    dHf_298   -113220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64190.0
    phase     gas;
}
