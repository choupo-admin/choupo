/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-diphenyl-1,1'-bicyclohexyl  (C24H30, CAS 59358-71-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenyl11Bicyclohexyl;
formula     C24H30;
CAS         59358-71-3;
InChIKey    SZGBUFROANKUNE-UHFFFAOYSA-N;
MW          318.504;      // g/mol [origin=calculated method=formula-sum]
Tc          1126.16;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       0.6033;      // -   [origin=predictive method=lee-kesler]
Tb          841.66;      // K   [origin=predictive method=joback]
HvapTb      72126.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-317.93 2.954 -0.0025714 9.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group C; count 2; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group C_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-(1-phenylcyclohexyl)cyclohexyl]benzene" "1,1'-diphenyl-1,1'-bi(cyclohexyl)" );
gibbsFormation
{
    dHf_298   73490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     956.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=413940.0
    phase     gas;
}
