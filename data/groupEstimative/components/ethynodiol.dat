/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethynodiol  (C20H28O2, CAS 1231-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethynodiol;
formula     C20H28O2;
CAS         1231-93-2;
InChIKey    JYILPERKVHXLNF-QMNUTNMBSA-N;
MW          300.442;      // g/mol [origin=calculated method=formula-sum]
Tc          1093.46;      // K   [origin=predictive method=joback]
Pc          21.653;      // bar [origin=predictive method=joback]
omega       1.3142;      // -   [origin=predictive method=lee-kesler]
Tb          870.60;      // K   [origin=predictive method=joback]
HvapTb      91567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-277.59 2.82232 -0.00258897 1.00319e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 5; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 2; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,8r,9s,10r,13s,14s,17r)-17-ethynyl-13-methyl-2,3,6,7,8,9,10,11,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthrene-3,17-diol" "ethinodiol" "aethynodiolum" "etynodiolum" "etinodiol" "etinodiolo [dcit]" "etynodiol [inn:ban]" "etynodiolum [inn-latin]" "17alpha-ethynyl-estra-4-ene-3beta,17beta-diol" "(3beta,17beta)-17-ethynylestr-4-ene-3,17-diol" "19-nor-17-alpha-pregn-4-en-20-yne-3-beta,17-diol" "(3-beta,17-alpha)-19-norpregn-4-en-20-yne-3,17-diol" );
standardThermochemistry
{
    dHf_298   -192520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235670.0
}
