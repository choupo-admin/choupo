/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxycarbonylcubane-1-carboxylic acid  (C11H10O4, CAS 24539-28-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxycarbonylcubane1CarboxylicAcid;
formula     C11H10O4;
CAS         24539-28-4;
InChIKey    ARRJEFLYRAVFJA-UHFFFAOYSA-N;
MW          206.197;      // g/mol [origin=calculated method=formula-sum]
Tc          861.06;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.9944;      // -   [origin=predictive method=lee-kesler]
Tb          645.29;      // K   [origin=predictive method=joback]
HvapTb      59783.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-274.63 2.37082 -0.0028774 1.3078e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 6; } { group C; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 6; } { group C_ring; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(methoxycarbonyl)pentacyclo[4.2.0.02,5.03,8.04,7]octane-1-carboxylic acid" "bm541" "4-(methoxycarbonyl)-1-cubanecarboxylic acid" "pentacyclo[4.2.0.02,5.03,8.04,7]octane-1,4-dicarboxylicacid, 1-methyl ester" );
standardThermochemistry
{
    dHf_298   -561340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     110.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-258200.0
}
