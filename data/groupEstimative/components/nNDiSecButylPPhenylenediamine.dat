/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-di-sec-butyl-p-phenylenediamine  (C14H24N2, CAS 101-96-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDiSecButylPPhenylenediamine;
formula     C14H24N2;
CAS         101-96-2;
InChIKey    FSWDLYNGJBGFJH-UHFFFAOYSA-N;
MW          220.36;      // g/mol [origin=calculated method=formula-sum]
Tc          854.91;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       0.8268;      // -   [origin=predictive method=lee-kesler]
Tb          651.04;      // K   [origin=predictive method=joback]
HvapTb      61792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.228 1.35968 -0.00080556 1.76e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CHNH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n4-di(butan-2-yl)benzene-1,4-diamine" "antioxidant 22" "topanol m" "tenamene 2" "n,n'-di-sec-butyl-p-phenyldiamine" "kerobit bpd" "santoflex 44" "n,n'-di-sec-butylparaphenylenediamine" "du pont gasoline antioxidant no. 22" "n,n'-1,4-bis(sec-butylamino)benzene" "uop 5" "n,n'-di-sec-butyl-1,4-phenylenediamine" );
gibbsFormation
{
    dHf_298   -10850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     651.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=343680.0
    phase     gas;
}
