/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[3.1.0]hexan-2-one, 5-(1-methylethyl)-  (C9H14O, CAS 28892-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo310Hexan2One51Methylethyl;
formula     C9H14O;
CAS         28892-21-9;
InChIKey    MDDYCNAAAZKNAJ-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          710.43;      // K   [origin=predictive method=joback]
Pc          33.258;      // bar [origin=predictive method=joback]
omega       0.4078;      // -   [origin=predictive method=lee-kesler]
Tb          486.62;      // K   [origin=predictive method=joback]
HvapTb      38162.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-121.02 1.29014 -0.001198 4.79e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-ylbicyclo[3.1.0]hexan-4-one" "5-isopropylbicyclo(3.1.0)hexan-2-one" "bicyclo[3.1.0]hexan-2-one, 5-isopropyl-" "sabinaketone" "bicyclo(3.1.0)hexan-2-one, 5-(1-methylethyl)-" "5-propan-2-ylbicyclo[3.1.0]hexan-2-one" "5-(propan-2-yl)bicyclo[3.1.0]hexan-2-one" );
standardThermochemistry
{
    dHf_298   -211230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15880.0
}
