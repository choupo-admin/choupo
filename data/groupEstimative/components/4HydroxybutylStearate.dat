/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxybutyl stearate  (C22H44O3, CAS 15337-64-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4HydroxybutylStearate;
formula     C22H44O3;
CAS         15337-64-1;
InChIKey    IKDHIMYPOLRLJB-UHFFFAOYSA-N;
MW          356.591;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.05;      // K   [origin=predictive method=joback]
Pc          9.567;      // bar [origin=predictive method=joback]
omega       0.9141;      // -   [origin=predictive method=lee-kesler]
Tb          853.36;      // K   [origin=predictive method=joback]
HvapTb      88652.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.59 2.07302 -0.0011088 2.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 19; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 20; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylbutyl octadecanoate" "octadecanoic acid, monoester with butanediol" "stearic acid, monoester with butanediol" "4-hydroxybutyl octadecanoate" "stearic acid, 4-hydroxybutyl ester" "octadecanoic acid,4-hydroxybutyl ester" "octadecanoic acid, 4-hydroxybutyl ester" "stearicacid, 4-hydroxybutyl ester (7ci,8ci); 1,4-butanediol, monostearate (8ci);1,4-butanediol monostearate" );
standardThermochemistry
{
    dHf_298   -966920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1115.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312830.0
}
