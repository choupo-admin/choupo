/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,5,5-tetramethylcyclohexanone  (C10H18O, CAS 14376-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3355Tetramethylcyclohexanone;
formula     C10H18O;
CAS         14376-79-5;
InChIKey    OQJMHUOCLRCSED-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          743.89;      // K   [origin=predictive method=joback]
Pc          28.263;      // bar [origin=predictive method=joback]
omega       0.3608;      // -   [origin=predictive method=lee-kesler]
Tb          511.58;      // K   [origin=predictive method=joback]
HvapTb      39919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-129.42 1.46498 -0.001367 5.722e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 3; } { group C_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,5,5-tetramethylcyclohexan-1-one" "cyclohexanone, 3,3,5,5-tetramethyl-" "3,5,5-tetramethylcyclohexanone" "cyclohexanone,3,5,5-tetramethyl-" "3,3,5,5-tetramethyl cyclohexanone" "cyclohexanone,3,3,5,5-tetramethyl-" "3,3,5,5-tetramethyl-cyclohexan-1-one" "t932" );
gibbsFormation
{
    dHf_298   -322970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     532.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83510.0
    phase     gas;
}
