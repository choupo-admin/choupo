/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-(2-methylbutoxy)benzene  (C11H15BrO, CAS 67599-19-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo42MethylbutoxyBenzene;
formula     C11H15BrO;
CAS         67599-19-3;
InChIKey    XCCKZXAUGDVBSB-UHFFFAOYSA-N;
MW          243.144;      // g/mol [origin=calculated method=formula-sum]
Tc          791.44;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.6071;      // -   [origin=predictive method=lee-kesler]
Tb          571.08;      // K   [origin=predictive method=joback]
HvapTb      51475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.292 0.89134 -0.00050236 9.91e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-(2-methylbutoxy)benzene" "benzene, 1-bromo-4-(2-methylbutoxy)-" "4-bromophenyl 2-methylbutyl ether" "1-bromo-4-(2'-methyl-1'-butoxy)benzene" );
gibbsFormation
{
    dHf_298   -156480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51400.0
    phase     gas;
}
