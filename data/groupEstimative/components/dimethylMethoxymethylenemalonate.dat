/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl methoxymethylenemalonate  (C7H10O5, CAS 22398-14-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylMethoxymethylenemalonate;
formula     C7H10O5;
CAS         22398-14-7;
InChIKey    RHFZTBSULNJWEI-UHFFFAOYSA-N;
MW          174.152;      // g/mol [origin=calculated method=formula-sum]
Tc          693.10;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.6702;      // -   [origin=predictive method=lee-kesler]
Tb          502.66;      // K   [origin=predictive method=joback]
HvapTb      48438.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.97 0.51596 -0.0001429 -4.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group CH3O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 1; } { group dC; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-(methoxymethylidene)propanedioate" "dimethyl 2-(methoxymethylene)malonate" "dimethyl(methoxymethylene)malonate" "methoxymethylenemalonic acid dimethyl ester" );
gibbsFormation
{
    dHf_298   -847160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     531.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-646010.0
    phase     gas;
}
