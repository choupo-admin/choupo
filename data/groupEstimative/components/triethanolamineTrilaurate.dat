/*--------------------------------*- Choupo -*-----------------------*\
  Component: triethanolamine trilaurate  (C42H81NO6, CAS 3002-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triethanolamineTrilaurate;
formula     C42H81NO6;
CAS         3002-20-8;
InChIKey    AKXHFKRRKWIXRH-UHFFFAOYSA-N;
MW          696.111;      // g/mol [origin=calculated method=formula-sum]
Tc          2055.35;      // K   [origin=predictive method=joback]
Pc          3.646;      // bar [origin=predictive method=joback]
omega       -0.5191;      // -   [origin=predictive method=lee-kesler]
Tb          1347.66;      // K   [origin=predictive method=joback]
HvapTb      133350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.246 3.95336 -0.0020898 3.547e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 32; } { group CH2COO; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 36; } { group COO; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(2-dodecanoyloxyethyl)amino]ethyl dodecanoate" "nitrilotriethane-2,1-diyl tridodecanoate" "dodecanoic acid, 1,1',1''-(nitrilotri-2,1-ethanediyl) ester" "lauric triethanolamine ester" "nitrilotriethylene trilaurate" "lauric triethanolaminetriester" "dodecanoic acid, nitrilotri-2,1-ethanediyl ester" "dodecanoic acid,1,1',1''-(nitrilotri-2,1-ethanediyl) ester" "dodecanoicacid, nitrilotri-2,1-ethanediyl ester (9ci); lauric acid, triester with2,2',2''-nitrilotriethanol (7ci,8ci); ethanol, 2,2',2''-nitrilotri-, trilaurate(8ci); lauric triethanolamine triester; nitrilotriethylene trilaurate" );
gibbsFormation
{
    dHf_298   -1794520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1961.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-517570.0
    phase     gas;
}
