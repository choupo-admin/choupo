/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexene-1,4-dione  (C6H6O2, CAS 4505-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexene14Dione;
formula     C6H6O2;
CAS         4505-38-8;
InChIKey    GPMMYQITJVUZAT-UHFFFAOYSA-N;
MW          110.112;      // g/mol [origin=calculated method=formula-sum]
Tc          745.43;      // K   [origin=predictive method=joback]
Pc          47.562;      // bar [origin=predictive method=joback]
omega       0.4112;      // -   [origin=predictive method=lee-kesler]
Tb          495.90;      // K   [origin=predictive method=joback]
HvapTb      38474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.53 0.3298 6.172e-05 -1.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohex-2-ene-1,4-dione" "1,4-cyclohex-2-enedione" "2-cyclohexene-1,4-dione;1,4-cyclohex-2-enedione" );
standardThermochemistry
{
    dHf_298   -310130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     206.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-183420.0
}
