/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-decen-2-one  (C10H18O, CAS 10519-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Decen2One;
formula     C10H18O;
CAS         10519-33-2;
InChIKey    JRPDANVNRUIUAB-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          667.08;      // K   [origin=predictive method=joback]
Pc          23.496;      // bar [origin=predictive method=joback]
omega       0.5885;      // -   [origin=predictive method=lee-kesler]
Tb          486.43;      // K   [origin=predictive method=joback]
HvapTb      44558.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.025 0.94584 -0.0005853 1.4616e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group dCH; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-3-en-2-one" "heptylideneacetone; oenanthylidene acetone" );
standardThermochemistry
{
    dHf_298   -245090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-15380.0
}
