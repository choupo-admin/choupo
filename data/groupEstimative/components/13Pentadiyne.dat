/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-pentadiyne  (C5H4, CAS 4911-55-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Pentadiyne;
formula     C5H4;
CAS         4911-55-1;
InChIKey    VNMDYSSJFJFEQI-UHFFFAOYSA-N;
MW          64.087;      // g/mol [origin=calculated method=formula-sum]
Tc          517.14;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.1152;      // -   [origin=predictive method=lee-kesler]
Tb          313.12;      // K   [origin=predictive method=joback]
HvapTb      28734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.68 0.23512 -0.00015199 4.567e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH_C; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group tCH; count 1; } { group tC; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "penta-1,3-diyne" "ch3c.equiv.cc.equiv.ch" "methylbutadiyne;methyldiacetylene" "1,3-pentadiyne(7ci,8ci,9ci)" );
standardThermochemistry
{
    dHf_298   417670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     292.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=417090.0
}
