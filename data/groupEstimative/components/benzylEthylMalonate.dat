/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl ethyl malonate  (C12H14O4, CAS 42998-51-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylEthylMalonate;
formula     C12H14O4;
CAS         42998-51-6;
InChIKey    CGNOCUSLPSCMLL-UHFFFAOYSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          824.03;      // K   [origin=predictive method=joback]
Pc          24.290;      // bar [origin=predictive method=joback]
omega       0.7948;      // -   [origin=predictive method=lee-kesler]
Tb          617.28;      // K   [origin=predictive method=joback]
HvapTb      59396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.893 0.95532 -0.000471 4.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-ethyl o3-(phenylmethyl) propanedioate" "benzyl-ethyl malonate" "1-benzyl 3-ethyl malonate" "malonic acid benzyl ethyl ester" "3-o-benzyl 1-o-ethyl propanedioate" "ethyl phenylmethyl propane-1,3-dioate" "propanedioic acid o1-ethyl ester o3-(phenylmethyl) ester" );
standardThermochemistry
{
    dHf_298   -689040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-458170.0
}
