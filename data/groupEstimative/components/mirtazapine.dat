/*--------------------------------*- Choupo -*-----------------------*\
  Component: mirtazapine  (C17H19N3, CAS 85650-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mirtazapine;
formula     C17H19N3;
CAS         85650-52-8;
InChIKey    RONZAEMNMFQXRA-UHFFFAOYSA-N;
MW          265.36;      // g/mol [origin=calculated method=formula-sum]
Tc          993.02;      // K   [origin=predictive method=joback]
Pc          26.218;      // bar [origin=predictive method=joback]
omega       0.8441;      // -   [origin=predictive method=lee-kesler]
Tb          744.34;      // K   [origin=predictive method=joback]
HvapTb      69571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.4 1.96148 -0.00160598 5.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3N; count 1; } { group CH2N; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 4; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "remergil" "remeron" "zispin" "remergon" "rexer" "promyrtil" "norset" "remeron soltab" "6-azamianserin" "mirtazapinum" "mepirzepine" "mirtazapina" );
gibbsFormation
{
    dHf_298   395860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=737740.0
    phase     gas;
}
