/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanol, 3,5-dimethyl-4-(3-methyl-2-butenyl)-  (C13H24O, CAS 71820-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanol35Dimethyl43Methyl2Butenyl;
formula     C13H24O;
CAS         71820-53-6;
InChIKey    FLAKAPCOAXPBIL-UHFFFAOYSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          788.57;      // K   [origin=predictive method=joback]
Pc          20.456;      // bar [origin=predictive method=joback]
omega       0.7993;      // -   [origin=predictive method=lee-kesler]
Tb          598.80;      // K   [origin=predictive method=joback]
HvapTb      60751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.299 1.33538 -0.0007147 1.275e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 4; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-dimethyl-4-(3-methylbut-2-enyl)cyclohexan-1-ol" "3,5-dimethyl-4-(3-methyl-2-butenyl)cyclohexanol" "agn-pc-02zfg7" "cyclohexanol, 3,5-dimethyl-4-(3-methyl-2-buten-1-yl)-" );
standardThermochemistry
{
    dHf_298   -363150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5250.0
}
