/*--------------------------------*- Choupo -*-----------------------*\
  Component: dipentaerythritol  (C10H22O7, CAS 126-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dipentaerythritol;
formula     C10H22O7;
CAS         126-58-9;
InChIKey    TXBCBTDQIULDIA-UHFFFAOYSA-N;
MW          254.279;      // g/mol [origin=calculated method=formula-sum]
Tc          1252.73;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       1.7744;      // -   [origin=predictive method=lee-kesler]
Tb          997.44;      // K   [origin=predictive method=joback]
HvapTb      137746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.098 1.3462 -0.0009352 2.556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 2; } { group OH; count 6; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group C; count 2; } { group OH; count 6; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[[2,2-bis(hydroxymethyl)-3-oxidanyl-propoxy]methyl]-2-(hydroxymethyl)propane-1,3-diol" "dipentek" "bis(pentaerythritol)" "1,3-propanediol, 2,2'-[oxybis(methylene)]bis[2-(hydroxymethyl)-" "1,3-propanediol, 2,2'-(oxybis-(methylene)" "2,2,2',2'-tetrakis(hydroxymethyl)-3,3'-oxydipropan-1-ol" "2,2'-(oxybis(methylene))bis(2-(hydroxymethyl)propane-1,3-diol)" "1,3-propanediol, 2,2'-(oxybis(methylene))bis(2-(hydroxymethyl)-" "2,2'-[oxybis(methylene)]bis[2-(hydroxymethyl)propane-1,3-diol]" "dipentaerythritol (8ci)" "txbcbtdqiuldia-uhfffaoysa-" "o505" );
standardThermochemistry
{
    dHf_298   -1312830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     784.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-886920.0
}
