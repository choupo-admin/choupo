/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,3-trimethylbicyclo[2.2.1]hept-2-yl 3-methylbutanoate  (C15H26O2, CAS 613-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        133Trimethylbicyclo221Hept2Yl3Methylbutanoate;
formula     C15H26O2;
CAS         613-40-1;
InChIKey    UWEYUMKZEVARAF-UHFFFAOYSA-N;
MW          238.371;      // g/mol [origin=calculated method=formula-sum]
Tc          816.81;      // K   [origin=predictive method=joback]
Pc          18.325;      // bar [origin=predictive method=joback]
omega       0.6039;      // -   [origin=predictive method=lee-kesler]
Tb          609.47;      // K   [origin=predictive method=joback]
HvapTb      53081.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.729 2.203 -0.0020492 8.18e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 3; } { group C; count 2; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,2,4-trimethyl-3-bicyclo[2.2.1]heptanyl) 3-methylbutanoate" "fenchyval" "valyfen" );
gibbsFormation
{
    dHf_298   -546250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     675.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-154390.0
    phase     gas;
}
