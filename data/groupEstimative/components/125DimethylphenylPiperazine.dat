/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,5-dimethylphenyl)piperazine  (C12H18N2, CAS 1013-25-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        125DimethylphenylPiperazine;
formula     C12H18N2;
CAS         1013-25-8;
InChIKey    YRIFWVMRUFKWLM-UHFFFAOYSA-N;
MW          190.29;      // g/mol [origin=calculated method=formula-sum]
Tc          826.01;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.5968;      // -   [origin=predictive method=lee-kesler]
Tb          591.74;      // K   [origin=predictive method=joback]
HvapTb      55273.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.52 1.21464 -0.00076092 1.795e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,5-dimethylphenyl)piperazine" "1-(2,5-xylyl)piperazine" "1-(2,5-dimethyl-phenyl)-piperazine" "piperazine,1-(2,5-dimethylphenyl)-" "1-(2,5-dimethylphenyl)piperazine, 99%" "piperazine,1-(2,5-xylyl)- (6ci,7ci,8ci);1-(2,5-dimethylphenyl)piperazine;1-(2,5-xylyl)piperazine;n-(2,5-dimethylphenyl)piperazine;n-2,5-xylylpiperazine;" );
standardThermochemistry
{
    dHf_298   108740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=386060.0
}
