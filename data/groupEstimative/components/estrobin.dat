/*--------------------------------*- Choupo -*-----------------------*\
  Component: estrobin  (C24H23BrO2, CAS 60883-74-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        estrobin;
formula     C24H23BrO2;
CAS         60883-74-1;
InChIKey    BYILAACWNFQDGZ-UHFFFAOYSA-N;
MW          423.35;      // g/mol [origin=calculated method=formula-sum]
Tc          1209.36;      // K   [origin=predictive method=joback]
Pc          16.498;      // bar [origin=predictive method=joback]
omega       0.9967;      // -   [origin=predictive method=lee-kesler]
Tb          953.64;      // K   [origin=predictive method=joback]
HvapTb      88543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.418 1.85974 -0.00117912 2.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 13; } { group AC; count 5; } { group CH2O; count 2; } { group Br; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dC; count 2; } { group dCH_ring; count 13; } { group dC_ring; count 5; } { group Br; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-bromanyl-1-(4-ethoxyphenyl)-2-phenyl-ethenyl]-4-ethoxy-benzene" "1,1'-(2-bromo-2-phenylethene-1,1-diyl)bis(4-ethoxybenzene)" "alpha-bromo-beta,beta-bis(p-ethoxyphenyl)styrene" "styrene, alpha-bromo-beta,beta-bis(p-ethoxyphenyl)-" "benzene, 1,1'-(bromophenylethenylidene)bis(4-ethoxy-" "alpha,alpha-di(p-ethoxyphenyl)-beta-bromo-beta-phenylethylene" "1-[2-bromo-1-(4-ethoxyphenyl)-2-phenylethenyl]-4-ethoxybenzene" );
gibbsFormation
{
    dHf_298   7490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=336610.0
    phase     gas;
}
