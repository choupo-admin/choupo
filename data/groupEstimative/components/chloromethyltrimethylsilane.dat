/*--------------------------------*- Choupo -*-----------------------*\
  Component: chloromethyltrimethylsilane  (C4H11ClSi, CAS 2344-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H11ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloromethyltrimethylsilane;
formula     C4H11ClSi;
CAS         2344-80-1;
InChIKey    OOCUOKHIVGWCTJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          122.667;      // g/mol [origin=calculated method=formula-sum]
Tc          509.14;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.1798;      // -   [origin=predictive method=lee-kesler]
Tb          329.95;      // K   [origin=predictive method=joback]
HvapTb      29177.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (52.961 0.18446 0.0002006 -1.718e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl(trimethyl)silane" "(chloromethyl)trimethylsilane" "(trimethylsilyl)methyl chloride" "silane, (chloromethyl)trimethyl-" "(chloromethyl)(trimethyl)silane" "(ch3)3sich2cl" "silane cmm3" "chloromethyl trimethylsilane" "(chloromethyl)trimethylsilylane" );
standardThermochemistry
{
    dHf_298   -253250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133890.0
}
