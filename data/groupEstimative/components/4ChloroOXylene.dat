/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-o-xylene  (C8H9Cl, CAS 615-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChloroOXylene;
formula     C8H9Cl;
CAS         615-60-1;
InChIKey    HNQLMBJUMVLFCF-UHFFFAOYSA-N;
MW          140.61;      // g/mol [origin=calculated method=formula-sum]
Tc          676.40;      // K   [origin=predictive method=joback]
Pc          33.724;      // bar [origin=predictive method=joback]
omega       0.3492;      // -   [origin=predictive method=lee-kesler]
Tb          456.71;      // K   [origin=predictive method=joback]
HvapTb      41387.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.2 0.57274 -0.00032892 6.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 2; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-1,2-dimethyl-benzene" "3,4-dimethylchlorobenzene" "4-chloro-1,2-dimethylbenzene" "1-chloro-3,4-dimethylbenzene" "o-xylene, 4-chloro-" "benzene, 4-chloro-1,2-dimethyl-" "4-chloro-ortho-xylene" "4-chloro-1,2-xylene" "hnqlmbjumvlfcf-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -10600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97700.0
}
