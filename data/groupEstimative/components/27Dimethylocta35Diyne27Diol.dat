/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-dimethylocta-3,5-diyne-2,7-diol  (C10H14O2, CAS 5929-72-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Dimethylocta35Diyne27Diol;
formula     C10H14O2;
CAS         5929-72-6;
InChIKey    CKVWIEREOYIKNC-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          831.28;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       1.0678;      // -   [origin=predictive method=lee-kesler]
Tb          624.30;      // K   [origin=predictive method=joback]
HvapTb      72924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.45 0.97388 -0.00074032 2.2916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group OH; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group tC; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,7-dimethyl-octa-3,5-diyne-2,7-diol" "2,7-dimethyloctadiyne-3,5-diol-2,7" "2,7-dimethyl-3,5-octadiyne-2,7-diol" "3,7-diol, 2,7-dimethyl-" "2,7-dimethyl-3,5-octadiyn-2,7-diol" "3,5-octadiyne-2,7-diol,2,7-dimethyl-" "3,5-octadiyne-2,7-diol, 2,7-dimethyl-" );
standardThermochemistry
{
    dHf_298   -27090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=170960.0
}
