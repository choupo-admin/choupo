/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3'-bromo-4'-fluoroacetophenone  (C8H6BrFO, CAS 1007-15-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo4Fluoroacetophenone;
formula     C8H6BrFO;
CAS         1007-15-4;
InChIKey    SZDWTGAORQQQGY-UHFFFAOYSA-N;
MW          217.037;      // g/mol [origin=calculated method=formula-sum]
Tc          766.96;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.6052;      // -   [origin=predictive method=lee-kesler]
Tb          538.58;      // K   [origin=predictive method=joback]
HvapTb      49366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.95 0.58792 -0.00037762 9.036e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH3CO; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-bromanyl-4-fluoranyl-phenyl)ethanone" "3-bromo-4-fluoroacetophenone" "1-(3-bromo-4-fluorophenyl)ethanone" "1-(3-bromo-4-fluorophenyl)ethan-1-one" "1-acetyl-3-bromo-4-fluorobenzene" "3'-bromo-4'-fluoroacetophone" "szdwtgaorqqqgy-uhfffaoysa-" "3'-bromo-4'-fluoroacetophenone 97%" "ethanone,1-(3-bromo-4-fluorophenyl)-" "ethanone, 1-(3-bromo-4-fluorophenyl)-" "acetophenone,3'-bromo-4'-fluoro- (7ci,8ci);1-(3-bromo-4-fluorophenyl)ethan-1-one;1-(3-bromo-4-fluorophenyl)ethanone;1-acetyl-3-bromo-4-fluorobenzene;3-bromo-4-fluoroacetophenone;3'-bromo-4'-fluoroacetophenone;4'-fluoro-3'-bromoacetophenone;" );
gibbsFormation
{
    dHf_298   -277220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199780.0
    phase     gas;
}
