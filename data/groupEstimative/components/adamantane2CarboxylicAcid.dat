/*--------------------------------*- Choupo -*-----------------------*\
  Component: adamantane-2-carboxylic acid  (C11H16O2, CAS 15897-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        adamantane2CarboxylicAcid;
formula     C11H16O2;
CAS         15897-81-1;
InChIKey    UNGMXQVELCJRIH-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          836.77;      // K   [origin=predictive method=joback]
Pc          29.666;      // bar [origin=predictive method=joback]
omega       0.7285;      // -   [origin=predictive method=lee-kesler]
Tb          611.94;      // K   [origin=predictive method=joback]
HvapTb      56537.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-146.48 1.4897 -0.0011506 3.593e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 5; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-adamantanecarboxylic acid" "tricyclo[3.3.1.1~3,7~]decane-2-carboxylic acid" "admantane-2-carboxylic acid" "tricyclo[3.3.1.13,7]decane-2-carboxylicacid" "tricyclo[3.3.1.13,7]decane-2-carboxylic acid" );
gibbsFormation
{
    dHf_298   -449080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147440.0
    phase     gas;
}
