/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-octadienal  (C8H12O, CAS 30361-28-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Octadienal;
formula     C8H12O;
CAS         30361-28-5;
InChIKey    DVVATNQISMINCX-YTXTXJHMSA-N;
MW          124.183;      // g/mol [origin=calculated method=formula-sum]
Tc          627.62;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.4833;      // -   [origin=predictive method=lee-kesler]
Tb          439.62;      // K   [origin=predictive method=joback]
HvapTb      40038.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.348 0.77832 -0.000572 1.767e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH=CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e)-octa-2,4-dienal" "2,4-octadienal, (e,e)-" "trans,trans-octa-2,4-dienal" "octadienal" "octa-2,4-dienal" "(2e,4e)-2,4-octadienal" "2,4-octadienal, (2e,4e)-" "2.4-octadienal" "trans,trans-2,4-octadienal" "trans-2-trans-4-octadienal" "2,4-octadienal, trans,trans-" "(e,e)-2,4-octadien-1-al" );
gibbsFormation
{
    dHf_298   -59590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77400.0
    phase     gas;
}
