/*--------------------------------*- Choupo -*-----------------------*\
  Component: tris(dimethylamino)phenylsilane  (C12H23N3Si, CAS 4840-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H23N3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        trisDimethylaminoPhenylsilane;
formula     C12H23N3Si;
CAS         4840-75-9;
InChIKey    VJDVRUZAQRISHN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          237.422;      // g/mol [origin=calculated method=formula-sum]
Tc          737.51;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       0.5591;      // -   [origin=predictive method=lee-kesler]
Tb          539.56;      // K   [origin=predictive method=joback]
HvapTb      51005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.18 1.23052 -0.0005832 5.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[bis(dimethylamino)-phenyl-silyl]-n-methyl-methanamine" "n,n,n',n',n'',n''-hexamethyl-1-phenylsilanetriamine" "silanetriamine, n,n,n',n',n'',n''-hexamethyl-1-phenyl-" "n-[bis(dimethylamino)-phenylsilyl]-n-methylmethanamine" "n,n,n',n',n'',n''-hexamethyl-1-phenylsilanetriamine;" "silanetriamine,n,n,n',n',n'',n''-hexamethyl-1-phenyl-" );
gibbsFormation
{
    dHf_298   36490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     691.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=390150.0
    phase     gas;
}
