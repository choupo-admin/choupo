/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclaprop  (C13H18O2, CAS 17511-60-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclaprop;
formula     C13H18O2;
CAS         17511-60-3;
InChIKey    BLBJUGKATXCWET-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          779.84;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.5922;      // -   [origin=predictive method=lee-kesler]
Tb          569.57;      // K   [origin=predictive method=joback]
HvapTb      51524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.709 1.51812 -0.00107948 3.022e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 5; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 5; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclodecenyl propionate" "4,7-methano-1h-inden-6-ol, 3a,4,5,6,7,7a-hexahydro-, propanoate" "hexahydro-4,7-methanoinden-5(or 6)-yl propionate" "tricyclo(5.2.1.02,6)dec-3-en-8-yl propionate" "3a,4,5,6,7,7a-hexahydro-4,7-methano-1h-inden-6-yl propionate" "4,7-methanoinden-6-ol, 3a,4,5,6,7,7a-hexahydro-, propionate" "4,7-methanoinden-6-ol, 3a,4,5,6,7,7a-hexahydro-, propionate(8ci)" "3a,4,5,6,7,7a-hexahydro-4,7-methanoindene-6-carboxylic acid ethyl ester" "4,7-methano-1h-inden-6-ol, 3a,4,5,6,7,7a-hexahydro-, 6-propanoate" "4,7-methanoindene-6-carboxylic acid, 3a,4,5,6,7,7a-hexahydro-, ethyl ester" "agn-pc-00hril" "3a,4,5,6,7,7a-hexahydro-1h-4,7-methanoinden-6-yl propanoate" );
gibbsFormation
{
    dHf_298   -399590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     340.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-67100.0
    phase     gas;
}
