/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-methylpropiophenone  (C10H12O, CAS 5337-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylpropiophenone;
formula     C10H12O;
CAS         5337-93-9;
InChIKey    PATYHUUYADUHQS-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          730.11;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       0.5139;      // -   [origin=predictive method=lee-kesler]
Tb          513.93;      // K   [origin=predictive method=joback]
HvapTb      47538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.449 0.78744 -0.00046566 9.936e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methylphenyl)propan-1-one" "1-(p-tolyl)propan-1-one" "p-methylpropiophenone" "4-methylpropiophenone" "1-propanone, 1-(4-methylphenyl)-" "p-tolyl ethyl ketone" "p-methyl propiophenone" "1-p-tolylpropan-1-one" "patyhuuyaduhqs-uhfffaoysa-" "1-propanone,1-(4-methylphenyl)-" "l757" "4 inverted exclamation marka-methylpropiophenone" );
standardThermochemistry
{
    dHf_298   -137250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=7180.0
}
