/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl sulfide  (C4H10S, CAS 352-93-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylSulfide;
formula     C4H10S;
CAS         352-93-2;
InChIKey    LJSQFQKUNVCTIA-UHFFFAOYSA-N;
MW          90.184;      // g/mol [origin=calculated method=formula-sum]
Tc          551.06;      // K   [origin=predictive method=joback]
Pc          39.805;      // bar [origin=predictive method=joback]
omega       0.2756;      // -   [origin=predictive method=lee-kesler]
Tb          359.90;      // K   [origin=predictive method=joback]
HvapTb      31315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.852 0.37823 -0.0001536 8.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethylsulfanylethane" "ethyl sulfide" "ethane, 1,1'-thiobis-" "ethyl thioether" "thioethyl ether" "3-thiapentane" "ethylthioethane" "diethylthioether" "ethyl monosulfide" "1,1'-thiobisethane" "diethyl sulphide" "diethyl thioether" );
standardThermochemistry
{
    dHf_298   -84020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=15920.0
}
