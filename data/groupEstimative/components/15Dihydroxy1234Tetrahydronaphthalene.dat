/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dihydroxy-1,2,3,4-tetrahydronaphthalene  (C10H12O2, CAS 40771-26-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dihydroxy1234Tetrahydronaphthalene;
formula     C10H12O2;
CAS         40771-26-4;
InChIKey    MYIDTCFDQGAVFL-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          868.51;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       1.0774;      // -   [origin=predictive method=lee-kesler]
Tb          643.87;      // K   [origin=predictive method=joback]
HvapTb      70570.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.8 1.1453 -0.00094492 3.207e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrahydronaphthalene-1,5-diol" "1,2,3,4-tetrahydro-1,5-naphthalenediol" "1,5-naphthalenediol, 1,2,3,4-tetrahydro-" "5,6,7,8-tetrahydronaphthalene-1,5-diol" "1,5-dihydroxynaphthaline;1,5-naphthohydroquinone;c.i. 76625;durafurdeveloper e;1,5-naphthalenediol;oxidation base;" );
standardThermochemistry
{
    dHf_298   -287570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-106690.0
}
