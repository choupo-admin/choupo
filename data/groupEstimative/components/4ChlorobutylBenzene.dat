/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-chlorobutyl)benzene  (C10H13Cl, CAS 4830-93-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorobutylBenzene;
formula     C10H13Cl;
CAS         4830-93-7;
InChIKey    FLLZCZIHURYEQP-UHFFFAOYSA-N;
MW          168.664;      // g/mol [origin=calculated method=formula-sum]
Tc          703.13;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.4475;      // -   [origin=predictive method=lee-kesler]
Tb          492.51;      // K   [origin=predictive method=joback]
HvapTb      44515.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.216 0.8817 -0.0005718 1.423e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranylbutylbenzene" "4-phenylbutyl chloride" "1-chloro-4-phenylbutane" "4-chlorobutylbenzene" "1-chloro-4-phenyl-mutane" "benzene, (4-chlorobutyl)-" "(4-chlorobutyl)benzene;1-(4-chlorobutyl)benzene;1-chloro-4-phenylbutane;4-phenyl-1-chlorobutane;4-phenylbutyl chloride;d-chlorobutylbenzene;" );
gibbsFormation
{
    dHf_298   -28940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133800.0
    phase     gas;
}
