/*--------------------------------*- Choupo -*-----------------------*\
  Component: methorphan  (C18H25NO, CAS 125-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methorphan;
formula     C18H25NO;
CAS         125-70-2;
InChIKey    MKXZASYAUGDDCJ-CGTJXYLNSA-N;
MW          271.404;      // g/mol [origin=calculated method=formula-sum]
Tc          941.01;      // K   [origin=predictive method=joback]
Pc          20.586;      // bar [origin=predictive method=joback]
omega       0.7276;      // -   [origin=predictive method=lee-kesler]
Tb          707.67;      // K   [origin=predictive method=joback]
HvapTb      62475.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-209.81 2.31164 -0.00200092 7.273e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "levomethorphan" "dextromethorphan" "3-methoxy-17-methylmorphinan" "l-methorphan" "(-)-3-methoxy-n-methylmorphinan" "morphinan, 3-methoxy-17-methyl-, l-" "levomethorphane" "levometorfano" "triaminic" "levomethorphane [inn-french]" "levomethorphanum [inn-latin]" "levomethorphanum" );
standardThermochemistry
{
    dHf_298   -38470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=364270.0
}
