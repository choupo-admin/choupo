/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylthiambutene  (C14H17NS2, CAS 524-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylthiambutene;
formula     C14H17NS2;
CAS         524-84-5;
InChIKey    CANBGVXYBPOLRR-UHFFFAOYSA-N;
MW          263.417;      // g/mol [origin=calculated method=formula-sum]
Tc          933.55;      // K   [origin=predictive method=joback]
Pc          25.741;      // bar [origin=predictive method=joback]
omega       0.6109;      // -   [origin=predictive method=lee-kesler]
Tb          678.12;      // K   [origin=predictive method=joback]
HvapTb      63699.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.57 1.48578 -0.00115774 3.615e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group CH3N; count 1; } { group C4H3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group N; count 1; } { group S_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-4,4-dithiophen-2-yl-but-3-en-2-amine" "dimethibutin" "ohton" "dimetiltiambuteno" "dimethylthiambutenum" "dimetiltiambutene [dcit]" "3-buten-2-amine, n,n-dimethyl-4,4-di-2-thienyl-" "n,n,1-trimethyl-3,3-di-2-thienylallylamine" "3-dimethylamino-1,1-bis(2-thienyl)-1-butene" "dimethylthiambutenum [inn-latin]" "3-dimethylamino-1,1-di-(2'-thienyl)-1-butene" "n,n,1-trimethyl-3,3-di(2-thienyl)-2-propenylamine" );
gibbsFormation
{
    dHf_298   297730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=515830.0
    phase     gas;
}
