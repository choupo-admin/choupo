/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl acetate, polymer with butylacrylate and dimethyl maleate  (C17H26O8, CAS 67859-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylAcetatePolymerWithButylacrylateAndDimethylMaleate;
formula     C17H26O8;
CAS         67859-83-0;
InChIKey    RCNPUXIKUDBTIO-LWFKIUJUSA-N;
MW          358.387;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.25;      // K   [origin=predictive method=joback]
Pc          12.140;      // bar [origin=predictive method=joback]
omega       0.9902;      // -   [origin=predictive method=lee-kesler]
Tb          821.76;      // K   [origin=predictive method=joback]
HvapTb      82270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (150.543 0.96728 0.0001774 -3.895e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH2=CH; count 2; } { group CH=CH; count 1; } { group CH3COO; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group dCH2; count 2; } { group dCH; count 4; } { group COO; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl prop-2-enoate;dimethyl (z)-but-2-enedioate;ethenyl ethanoate" "2-butenedioic acid (2z)-, 1,4-dimethyl ester, polymer with butyl 2-propenoate and ethenyl acetate" "butyl prop-2-enoate; dimethyl (z)-but-2-enedioate; ethenyl acetate" );
standardThermochemistry
{
    dHf_298   -1518490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1222.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1102840.0
}
