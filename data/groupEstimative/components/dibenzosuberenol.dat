/*--------------------------------*- Choupo -*-----------------------*\
  Component: dibenzosuberenol  (C15H12O, CAS 10354-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dibenzosuberenol;
formula     C15H12O;
CAS         10354-00-4;
InChIKey    SRIISEYIFDTFRZ-UHFFFAOYSA-N;
MW          208.26;      // g/mol [origin=calculated method=formula-sum]
Tc          937.99;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.9736;      // -   [origin=predictive method=lee-kesler]
Tb          704.20;      // K   [origin=predictive method=joback]
HvapTb      71744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.13 1.2809 -0.0009584 2.818e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "11h-dibenzo[1,2-a:1',2'-e][7]annulen-11-ol" "5h-dibenzo[a,d][7]annulen-5-ol" "5h-dibenzo(a,d)cyclohepten-5-ol" "dibenzo(b,f)cyclohepten-1-ol" "5-hydrodibenzo[a,d][7]annulen-5-ol" );
gibbsFormation
{
    dHf_298   75540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=234870.0
    phase     gas;
}
