/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(3,4-dimethoxyphenyl)butyric acid  (C12H16O4, CAS 13575-74-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        434DimethoxyphenylButyricAcid;
formula     C12H16O4;
CAS         13575-74-1;
InChIKey    IDQKCIAJGRMMNC-UHFFFAOYSA-N;
MW          224.256;      // g/mol [origin=calculated method=formula-sum]
Tc          911.12;      // K   [origin=predictive method=joback]
Pc          24.654;      // bar [origin=predictive method=joback]
omega       1.0366;      // -   [origin=predictive method=lee-kesler]
Tb          701.15;      // K   [origin=predictive method=joback]
HvapTb      67890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.273 0.87034 -0.00037672 2.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3O; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3,4-dimethoxyphenyl)butanoic acid" "benzenebutanoic acid,3,4-dimethoxy-" "4-(3,4-dimethoxyphenyl)-butyric acid" "4-phenylbutyric acid, 4',5'-dimethoxy-" );
standardThermochemistry
{
    dHf_298   -692130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     580.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-410600.0
}
