/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4a,8a-ethenonaphthalene, 1,2,3,4,5,6,7,8-octahydro-  (C12H18, CAS 38992-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4a8aEthenonaphthalene12345678Octahydro;
formula     C12H18;
CAS         38992-78-8;
InChIKey    BIWIFDJXQMGJDI-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          758.73;      // K   [origin=predictive method=joback]
Pc          32.803;      // bar [origin=predictive method=joback]
omega       0.3322;      // -   [origin=predictive method=lee-kesler]
Tb          511.50;      // K   [origin=predictive method=joback]
HvapTb      40860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-272.25 2.122 -0.00225828 9.682e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group C; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group C_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   17510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     556.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222800.0
    phase     gas;
}
