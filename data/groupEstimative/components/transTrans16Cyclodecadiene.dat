/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans,trans-1,6-cyclodecadiene  (C10H16, CAS 15840-81-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        transTrans16Cyclodecadiene;
formula     C10H16;
CAS         15840-81-0;
InChIKey    GWCMUONZBWHLRN-LLGXEZKASA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          703.85;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.2679;      // -   [origin=predictive method=lee-kesler]
Tb          468.02;      // K   [origin=predictive method=joback]
HvapTb      39864.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.67 0.952 -0.00044556 3.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1e,6e)-cyclodeca-1,6-diene" );
standardThermochemistry
{
    dHf_298   -84150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77000.0
}
