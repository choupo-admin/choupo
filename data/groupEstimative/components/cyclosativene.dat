/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-cyclosativene  (C15H24, CAS 22469-52-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclosativene;
formula     C15H24;
CAS         22469-52-9;
InChIKey    XBWACJDEQIZTPR-YIZGKYRPSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          759.52;      // K   [origin=predictive method=joback]
Pc          20.869;      // bar [origin=predictive method=joback]
omega       0.4585;      // -   [origin=predictive method=lee-kesler]
Tb          547.25;      // K   [origin=predictive method=joback]
HvapTb      44675.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-285.32 2.56188 -0.002668 1.1352e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 6; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 5; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -85230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=306070.0
    phase     gas;
}
