/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-diethyl-2-hexene  (C10H20, CAS 59643-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Diethyl2Hexene;
formula     C10H20;
CAS         59643-70-8;
InChIKey    WTCHQGKPTSGKHU-WEVVVXLNSA-N;
MW          140.27;      // g/mol [origin=calculated method=formula-sum]
Tc          609.34;      // K   [origin=predictive method=joback]
Pc          22.398;      // bar [origin=predictive method=joback]
omega       0.4063;      // -   [origin=predictive method=lee-kesler]
Tb          432.00;      // K   [origin=predictive method=joback]
HvapTb      37504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.757 0.97968 -0.0006095 1.565e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3,4-diethylhex-2-ene" "3,4-diethyl-2-hexene(e)" "3,4-diethyl-2-hexene (e)" );
gibbsFormation
{
    dHf_298   -147580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102550.0
    phase     gas;
}
