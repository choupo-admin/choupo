/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-diphenylpropanol  (C15H16O, CAS 20017-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Diphenylpropanol;
formula     C15H16O;
CAS         20017-67-8;
InChIKey    IDCXQMVSIIJUEH-UHFFFAOYSA-N;
MW          212.292;      // g/mol [origin=calculated method=formula-sum]
Tc          908.16;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.9675;      // -   [origin=predictive method=lee-kesler]
Tb          687.90;      // K   [origin=predictive method=joback]
HvapTb      69827.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.948 1.3109 -0.0008882 2.276e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-diphenylpropan-1-ol" "3,3-diphenyl-1-propanol" "3,3-diphenyl-propan-1-ol" "benzenepropanol, .gamma.-phenyl-" "1-propanol, 3,3-diphenyl-" "benzenepropanol, .beta.-phenyl-" "1-propanol,3-diphenyl-" "idcxqmvsiijueh-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -37380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160980.0
}
