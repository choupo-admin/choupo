/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-thiopheneethanol  (C6H8OS, CAS 13781-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Thiopheneethanol;
formula     C6H8OS;
CAS         13781-67-4;
InChIKey    YYPNNBPPDFTQFX-UHFFFAOYSA-N;
MW          128.189;      // g/mol [origin=calculated method=formula-sum]
Tc          706.37;      // K   [origin=predictive method=joback]
Pc          48.360;      // bar [origin=predictive method=joback]
omega       0.7499;      // -   [origin=predictive method=lee-kesler]
Tb          500.14;      // K   [origin=predictive method=joback]
HvapTb      53253.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.018 0.60891 -0.00044202 1.3e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group OH; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-thiophen-3-ylethanol" "2-(3-thienyl)ethanol" "thiophene-3-ethanol" "2-(thiophen-3-yl)ethanol" "3-(2-hydroxyethyl)thiophene" "2-(thien-3-yl)ethan-1-ol" "2-(thiophen-3-yl)ethan-1-ol" "2-(3-thienyl)-1-ethanol" "2-(3-thienyl)-1-ethanol; 2-(3-thienyl)ethanol; 2-(thiophen-3-yl)ethanol; 3-(2-hydroxyethyl)thiophene" "2-(3-thienyl)-1-ethanol;2-(3-thienyl)ethanol;2-(thiophen-3-yl)ethanol;3-(2-hydroxyethyl)thiophene;3-thiopheneethanol;" );
standardThermochemistry
{
    dHf_298   -89230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2770.0
}
