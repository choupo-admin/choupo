/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-di-tert-butyl-4-nonylphenol  (C23H40O, CAS 4306-88-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26DiTertButyl4Nonylphenol;
formula     C23H40O;
CAS         4306-88-1;
InChIKey    VQQLTEBUMLSLFJ-UHFFFAOYSA-N;
MW          332.572;      // g/mol [origin=calculated method=formula-sum]
Tc          1043.17;      // K   [origin=predictive method=joback]
Pc          11.585;      // bar [origin=predictive method=joback]
omega       0.8948;      // -   [origin=predictive method=lee-kesler]
Tb          836.64;      // K   [origin=predictive method=joback]
HvapTb      80814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.192 2.39724 -0.00172448 5.151e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 7; } { group C; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 8; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-ditert-butyl-4-nonyl-phenol" "phenol, 2,6-bis(1,1-dimethylethyl)-4-nonyl-" "2,6-ditert-butyl-4-nonylphenol" "phenol,2,6-bis(1,1-dimethylethyl)-4-nonyl-" "phenol,2,6-di-tert-butyl-4-nonyl- (7ci,8ci);2,6-di-tert-butyl-4-nonylphenol;4-nonyl-2,6-di-tert-butylphenol;dinophen;" );
gibbsFormation
{
    dHf_298   -499270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     881.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86990.0
    phase     gas;
}
