/*--------------------------------*- Choupo -*-----------------------*\
  Component: triphenylacetic acid  (C20H16O2, CAS 595-91-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triphenylaceticAcid;
formula     C20H16O2;
CAS         595-91-5;
InChIKey    DCYGAPKNVCQNOE-UHFFFAOYSA-N;
MW          288.346;      // g/mol [origin=calculated method=formula-sum]
Tc          1151.90;      // K   [origin=predictive method=joback]
Pc          24.100;      // bar [origin=predictive method=joback]
omega       0.9491;      // -   [origin=predictive method=lee-kesler]
Tb          879.52;      // K   [origin=predictive method=joback]
HvapTb      82810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.88 1.8437 -0.0014022 4.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,2-triphenylethanoic acid" "2,2,2-triphenylacetic acid" "benzeneacetic acid, .alpha.,.alpha.-diphenyl-" "tritylformic acid" "acetic acid, triphenyl-" "2,2,2-triphenyl-acetic acid" "acetic acid, triphenyl- (8ci)" "benzeneacetic acid, a,a-diphenyl-" "benzeneacetic acid,.alpha.-diphenyl-" ".alpha.-toluic acid,.alpha.-diphenyl-" "alpha-toluic acid, alpha,alpha-diphenyl-" "benzeneacetic acid, alpha,alpha-diphenyl-" );
gibbsFormation
{
    dHf_298   -105560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     630.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113680.0
    phase     gas;
}
