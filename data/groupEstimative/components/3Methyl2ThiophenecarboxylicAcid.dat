/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-thiophenecarboxylic acid  (C6H6O2S, CAS 23806-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl2ThiophenecarboxylicAcid;
formula     C6H6O2S;
CAS         23806-24-8;
InChIKey    IFLKEBSJTZGCJG-UHFFFAOYSA-N;
MW          142.172;      // g/mol [origin=calculated method=formula-sum]
Tc          798.28;      // K   [origin=predictive method=joback]
Pc          47.171;      // bar [origin=predictive method=joback]
omega       0.6643;      // -   [origin=predictive method=lee-kesler]
Tb          558.45;      // K   [origin=predictive method=joback]
HvapTb      54400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.59 0.56623 -0.00041718 1.233e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group COOH; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group COOH; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylthiophene-2-carboxylic acid" "3-methyl-2-thenoic acid" "3-methyl-2-thiophene carboxylic acid" "2-carboxy-3-methylthiophene" "3-methyl-2-thiophenecarboxylic" "iflkebsjtzgcjg-uhfffaoysa-" "2-thiophenecarboxylicacid, 3-methyl-" "3-methyl-thiophene-2-carboxylic acid" "2-thiophenecarboxylic acid, 3-methyl-" "u307" );
standardThermochemistry
{
    dHf_298   -298740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     397.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-219490.0
}
