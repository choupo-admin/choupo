/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diiodonorbornane  (C7H10I2, CAS 40950-21-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diiodonorbornane;
formula     C7H10I2;
CAS         40950-21-8;
InChIKey    IGAAVEUUOLFPOR-UHFFFAOYSA-N;
MW          347.957;      // g/mol [origin=calculated method=formula-sum]
Tc          870.39;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       0.2596;      // -   [origin=predictive method=lee-kesler]
Tb          564.27;      // K   [origin=predictive method=joback]
HvapTb      47618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-185.68 1.6228 -0.001979 9.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 2; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 2; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(iodanyl)bicyclo[2.2.1]heptane" "1,4-diiodobicyclo[2.2.1]heptane" );
gibbsFormation
{
    dHf_298   135850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=222720.0
    phase     gas;
}
