/*--------------------------------*- Choupo -*-----------------------*\
  Component: phaseollidin  (C20H20O4, CAS 37831-70-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phaseollidin;
formula     C20H20O4;
CAS         37831-70-2;
InChIKey    OFWYIUYVHYPQNX-JXFKEZNVSA-N;
MW          324.376;      // g/mol [origin=calculated method=formula-sum]
Tc          1209.47;      // K   [origin=predictive method=joback]
Pc          26.325;      // bar [origin=predictive method=joback]
omega       1.3483;      // -   [origin=predictive method=lee-kesler]
Tb          953.89;      // K   [origin=predictive method=joback]
HvapTb      101392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.639 2.20204 -0.0019833 7.296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group ACOH; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group OH_phenol; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6ar,11ar)-10-(3-methylbut-2-enyl)-6a,11a-dihydro-6h-[1]benzofuro[3,2-c]chromene-3,9-diol" "(-)-phaseollidin" "6h-benzofuro(3,2-c)(1)benzopyran-3,9-diol, 6a,11a-dihydro-10-(3-methyl-2-butenyl)-,(6ar-cis)-" "phaseolidin" "(6ar,11ar)-10-(3-methylbut-2-en-1-yl)-6a,11a-dihydro-6h-[1]benzofuro[3,2-c]chromene-3,9-diol" "6h-benzofuro(3,2-c)(1)benzopyran-3,9-diol, 6a,11a-dihydro-10-(3-methyl-2-butenyl)-, (6ar,11ar)-" "6h-benzofuro(3,2-c)(1)benzopyran-3,9-diol, 6a,11a-dihydro-10-(3-methyl-2-butenyl)-, (6ar-cis)-" );
standardThermochemistry
{
    dHf_298   -376910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=37240.0
}
