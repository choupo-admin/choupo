/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-octyloxybenzoate  (C16H24O3, CAS 62435-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Octyloxybenzoate;
formula     C16H24O3;
CAS         62435-37-4;
InChIKey    JCVLYBQFVTYGKT-UHFFFAOYSA-N;
MW          264.365;      // g/mol [origin=calculated method=formula-sum]
Tc          870.87;      // K   [origin=predictive method=joback]
Pc          16.660;      // bar [origin=predictive method=joback]
omega       0.8793;      // -   [origin=predictive method=lee-kesler]
Tb          677.98;      // K   [origin=predictive method=joback]
HvapTb      63965.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.647 1.26744 -0.00060516 6.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 2; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-octoxybenzoate" "methyl 4-n-octyloxybenzoate" "methyl 4-(octyloxy)benzoate" "4-n-octyloxybenzoic acid methyl ester" "methyl 4-octyloxybenzoate;methyl 4-n-octyloxybenzoate;4-octyloxybenzoicacid methyl ester;methyl p-octyloxybenzoate;" );
standardThermochemistry
{
    dHf_298   -598010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     729.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228750.0
}
