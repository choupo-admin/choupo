/*--------------------------------*- Choupo -*-----------------------*\
  Component: propyl glycolate  (C5H10O3, CAS 90357-58-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propylGlycolate;
formula     C5H10O3;
CAS         90357-58-7;
InChIKey    NORCOOJYTVHQCR-UHFFFAOYSA-N;
MW          118.132;      // g/mol [origin=calculated method=formula-sum]
Tc          633.56;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.8890;      // -   [origin=predictive method=lee-kesler]
Tb          464.40;      // K   [origin=predictive method=joback]
HvapTb      50810.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.043 0.45802 -0.000184 1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group OH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propyl 2-oxidanylethanoate" "acetic acid, hydroxy-, propyl ester" "propyl 2-hydroxyacetate" );
standardThermochemistry
{
    dHf_298   -616040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-455970.0
}
