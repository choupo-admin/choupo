/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 3-bromopropionate  (C5H9BrO2, CAS 539-74-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl3Bromopropionate;
formula     C5H9BrO2;
CAS         539-74-2;
InChIKey    FQTIYMRSUOADDK-UHFFFAOYSA-N;
MW          181.029;      // g/mol [origin=calculated method=formula-sum]
Tc          631.58;      // K   [origin=predictive method=joback]
Pc          37.916;      // bar [origin=predictive method=joback]
omega       0.5272;      // -   [origin=predictive method=lee-kesler]
Tb          438.38;      // K   [origin=predictive method=joback]
HvapTb      40566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.943 0.46222 -0.000225 2.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-bromanylpropanoate" "ethyl 3-bromopropanoate" "propanoic acid, 3-bromo-, ethyl ester" "ethyl beta-bromopropionate" "propionic acid, 3-bromo-, ethyl ester" "ethyl-3-bromopropionate" "ethyl .beta.-bromopropionate" "fqtiymrsuoaddk-uhfffaoysa-" "3-bromopropionic acid ethyl ester" "3-bromo-propionic acid ethyl ester" "beta-bromo-propionic acid, ethyl ester" "propionic acid, 3-bromo-, ethyl ester (8ci)" );
standardThermochemistry
{
    dHf_298   -437480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304830.0
}
