/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,4,4,5,5,5-heptafluoropentan-2-ol  (C5H5F7O, CAS 375-14-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3344555Heptafluoropentan2Ol;
formula     C5H5F7O;
CAS         375-14-4;
InChIKey    RBPHBIMHZSTIDT-UHFFFAOYSA-N;
MW          214.08;      // g/mol [origin=calculated method=formula-sum]
Tc          529.48;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.7856;      // -   [origin=predictive method=lee-kesler]
Tb          390.94;      // K   [origin=predictive method=joback]
HvapTb      33408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.83 0.97872 -0.000912 3.125e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group OH; count 1; } { group CF3; count 1; } { group CF2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group C; count 3; } { group F; count 7; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3,4,4,5,5,5-heptakis(fluoranyl)pentan-2-ol" "3,3,4,4,5,5,5-heptafluoro-2-pentanol" "2-pentanol,3,3,4,4,5,5,5-heptafluoro-" "2-pentanol, 3,3,4,4,5,5,5-heptafluoro-" );
gibbsFormation
{
    dHf_298   -1703060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1503190.0
    phase     gas;
}
