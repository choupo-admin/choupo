/*--------------------------------*- Choupo -*-----------------------*\
  Component: butyl sorbate  (C10H16O2, CAS 7367-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butylSorbate;
formula     C10H16O2;
CAS         7367-78-4;
InChIKey    SCVZKPKDMFXESQ-VSAQMIDASA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          679.80;      // K   [origin=predictive method=joback]
Pc          23.360;      // bar [origin=predictive method=joback]
omega       0.5759;      // -   [origin=predictive method=lee-kesler]
Tb          494.94;      // K   [origin=predictive method=joback]
HvapTb      45177.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.157 0.93904 -0.0005932 1.455e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH=CH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl (2e,4e)-hexa-2,4-dienoate" "2,4-hexadienoic acid, butyl ester," "butyl hexa-2,4-dienoate" "n-butyl sorbate" "butyl 2e,4e-hexadienoate" "2, butyl ester, (e,e)-" "butyl (e,e)-hexa-2,4-dienoate" "butyl (2e,4e)hexa-2,4-dienoate" "(2e,4e)-hexa-2,4-dienoic acid butyl ester" "2,4-hexadienoic acid, butyl ester, (e,e)-" "we(4:0/6:2(2e,4e))" );
gibbsFormation
{
    dHf_298   -332570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116610.0
    phase     gas;
}
