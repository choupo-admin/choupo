/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dichlorocatechol  (C6H4Cl2O2, CAS 13673-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dichlorocatechol;
formula     C6H4Cl2O2;
CAS         13673-92-2;
InChIKey    XSXYVLIPQMXCBV-UHFFFAOYSA-N;
MW          178.996;      // g/mol [origin=calculated method=formula-sum]
Tc          862.20;      // K   [origin=predictive method=joback]
Pc          63.592;      // bar [origin=predictive method=joback]
omega       0.8096;      // -   [origin=predictive method=lee-kesler]
Tb          604.64;      // K   [origin=predictive method=joback]
HvapTb      66686.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.23 0.7582 -0.00082028 3.45e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACOH; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-bis(chloranyl)benzene-1,2-diol" "3,5-dichlorobenzene-1,2-diol" "1,2-benzenediol, 3,5-dichloro-" "3,5-dichloro-benzene-1,2-diol" "35c" "3,5-dichloropyrocatechol" "35-dichlorocatechol" "3,5-dichloro-1,2-benzenediol" "3,5-dichloro-1,2-dihydroxybenzene" );
gibbsFormation
{
    dHf_298   -328210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230680.0
    phase     gas;
}
