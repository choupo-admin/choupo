/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-(cyclohexylamino)cyclohex-2-enone  (C14H23NO, CAS 1500-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3CyclohexylaminoCyclohex2Enone;
formula     C14H23NO;
CAS         1500-76-1;
InChIKey    BBRPUCDNSTWJAG-UHFFFAOYSA-N;
MW          221.344;      // g/mol [origin=calculated method=formula-sum]
Tc          928.13;      // K   [origin=predictive method=joback]
Pc          24.076;      // bar [origin=predictive method=joback]
omega       0.6451;      // -   [origin=predictive method=lee-kesler]
Tb          681.39;      // K   [origin=predictive method=joback]
HvapTb      58102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.74 1.66234 -0.00115724 3.494e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(cyclohexylamino)-5,5-dimethyl-cyclohex-2-en-1-one" "5,5-dimethyl-3-(n-cyclohexylamino)-cyclohex-2-en-1-one" "5,5-dimethyl-3-[n-cyclohexylamino]-cyclohex-2-en-1-one" "3-(cyclohexylamino)-5,5-dimethyl-2-cyclohexen-1-one" );
standardThermochemistry
{
    dHf_298   -246330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     628.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97540.0
}
