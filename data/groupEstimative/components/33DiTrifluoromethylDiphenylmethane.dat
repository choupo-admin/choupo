/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3'-di(trifluoromethyl)diphenylmethane  (C15H10F6, CAS 86845-35-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33DiTrifluoromethylDiphenylmethane;
formula     C15H10F6;
CAS         86845-35-4;
InChIKey    GXGZHSTYPHZGGN-UHFFFAOYSA-N;
MW          304.233;      // g/mol [origin=calculated method=formula-sum]
Tc          794.99;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.6675;      // -   [origin=predictive method=lee-kesler]
Tb          595.28;      // K   [origin=predictive method=joback]
HvapTb      47366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.359 1.4744 -0.00116252 3.459e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(trifluoromethyl)-3-[[3-(trifluoromethyl)phenyl]methyl]benzene" "3,3'-bis(trifluoromethyl)diphenylmethane" "3,3'-methylenebis(.alpha.,.alpha.,.alpha.-trifluorotoluene" "1-(trifluoromethyl)-3-{[3-(trifluoromethyl)phenyl]methyl}benzene" "3,3'-methylenebis(alpha,alpha,alpha-trifluorotoluene" "1-(trifluoromethyl)-3-[[3-(trifluoromethyl)phenyl]methyl]benzene;" );
gibbsFormation
{
    dHf_298   -1096970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     627.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-882200.0
    phase     gas;
}
