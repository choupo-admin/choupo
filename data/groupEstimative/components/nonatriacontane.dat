/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonatriacontane  (C39H80, CAS 7194-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonatriacontane;
formula     C39H80;
CAS         7194-86-7;
InChIKey    SNXOSZZZNFRFNZ-UHFFFAOYSA-N;
MW          549.069;      // g/mol [origin=calculated method=formula-sum]
Tc          1442.85;      // K   [origin=predictive method=joback]
Pc          4.061;      // bar [origin=predictive method=joback]
omega       -0.2129;      // -   [origin=predictive method=lee-kesler]
Tb          1091.92;      // K   [origin=predictive method=joback]
HvapTb      102408.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.563 3.70884 -0.0020978 4.529e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 37; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 37; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-nonatriacontane" "nonatriacontane (>90%)" "nonatriacontane; n-nonatriacontane" "AS-87856" "DB-007776" "Q151226" "C39" "nc39" "n-c39" );
gibbsFormation
{
    dHf_298   -848290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1675.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=277500.0
    phase     gas;
}
