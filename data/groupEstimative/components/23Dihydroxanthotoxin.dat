/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydroxanthotoxin  (C12H10O4, CAS 3779-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23Dihydroxanthotoxin;
formula     C12H10O4;
CAS         3779-03-1;
InChIKey    BUNGCZLFHHXKBX-UHFFFAOYSA-N;
MW          218.208;      // g/mol [origin=calculated method=formula-sum]
Tc          873.36;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.8437;      // -   [origin=predictive method=lee-kesler]
Tb          646.06;      // K   [origin=predictive method=joback]
HvapTb      62121.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.96 1.01432 -0.00075742 2.26e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 1; } { group AC; count 4; } { group ACCH2; count 1; } { group CH3O; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group O; count 1; } { group O_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-methoxy-2,3-dihydrofuro[3,2-g]chromen-7-one" "9-methoxy-2,3-dihydro-7h-furo[3,2-g]chromen-7-one" "9-methoxy-2h-furo[3,2-g]chromen-7(3h)-one" "9-methoxy-2,3-dihydrofuro[3,2-g]coumarin" "7h-furo[3,2-g][1]benzopyran-7-one, 2,3-dihydro-9-methoxy-" "7h-furo(3,2-g)(1)benzopyran-7-one, 2,3-dihydro-9-methoxy-" "7h-furo[3, 2,3-dihydro-9-methoxy-" "9-methoxy-2,3-dihydrofurano[3,2-g]chromen-7-one" "9-methoxy-2,3-dihydrofuro[3,2-g][1]benzopyran-7-one" "2,3-dihydro-9-methoxy-7h-furo(3,2-g)(1)benzopyran-7-one" "7h-furo[3,2-g][1]benzopyran-7-one,2,3-dihydro-9-methoxy-" );
standardThermochemistry
{
    dHf_298   -431640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     350.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198460.0
}
