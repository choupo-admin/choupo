/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-(trans-4-butylcyclohexyl)-, trans-4-propylcyclohexyl ester  (C26H40O2, CAS 72928-31-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4Trans4ButylcyclohexylTrans4PropylcyclohexylEster;
formula     C26H40O2;
CAS         72928-31-5;
InChIKey    YGLLWFCMQIEINP-UHFFFAOYSA-N;
MW          384.604;      // g/mol [origin=calculated method=formula-sum]
Tc          1139.74;      // K   [origin=predictive method=joback]
Pc          10.757;      // bar [origin=predictive method=joback]
omega       0.8343;      // -   [origin=predictive method=lee-kesler]
Tb          914.12;      // K   [origin=predictive method=joback]
HvapTb      84055.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.275 2.47184 -0.00131136 2.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-propylcyclohexyl) 4-(4-butylcyclohexyl)benzoate" "4-(4-butyl-cyclohexyl)-benzoic acid 4-propyl-cyclohexyl ester" "trans-4-propylcyclohexyl 4-(trans-4-butylcyclohexyl)benzoate" );
standardThermochemistry
{
    dHf_298   -604230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     961.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6070.0
}
