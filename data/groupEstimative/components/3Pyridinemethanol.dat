/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pyridinemethanol  (C6H7NO, CAS 100-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pyridinemethanol;
formula     C6H7NO;
CAS         100-55-0;
InChIKey    MVQVNTPHUGQQHK-UHFFFAOYSA-N;
MW          109.128;      // g/mol [origin=calculated method=formula-sum]
Tc          722.29;      // K   [origin=predictive method=joback]
Pc          53.279;      // bar [origin=predictive method=joback]
omega       0.7687;      // -   [origin=predictive method=lee-kesler]
Tb          509.44;      // K   [origin=predictive method=joback]
HvapTb      54115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.119 0.56266 -0.00037346 9.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group OH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridin-3-ylmethanol" "nicotinyl alcohol" "3-pyridylcarbinol" "nicotinic alcohol" "3-(hydroxymethyl)pyridine" "roniacol" "3-pyridylmethanol" "3-pyridinylmethanol" "pyridine-3-carbinol" "pyridylcarbinol" "pyridine-3-methanol" "3-picolyl alcohol" );
gibbsFormation
{
    dHf_298   -50080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     346.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52280.0
    phase     gas;
}
