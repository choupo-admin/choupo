/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-n,n-bis(2-hydroxyethyl)hexadec-7-enamide  (C20H39NO3, CAS 68439-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eNNBis2HydroxyethylHexadec7Enamide;
formula     C20H39NO3;
CAS         68439-59-8;
InChIKey    DXMZOGYLLSKACG-MDZDMXLPSA-N;
MW          341.536;      // g/mol [origin=calculated method=formula-sum]
Tc          1122.02;      // K   [origin=predictive method=joback]
Pc          12.390;      // bar [origin=predictive method=joback]
omega       1.1028;      // -   [origin=predictive method=lee-kesler]
Tb          912.03;      // K   [origin=predictive method=joback]
HvapTb      102219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.224 2.08772 -0.0013027 3.2216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH=CH; count 1; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group dCH; count 2; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(c14-c18) and (c16-c18)unsaturated alkylcarboxylic acid amide diethanol" "amides, c14-18 and c16-18-unsatd, n,n-bis(hydroxyethyl)" );
gibbsFormation
{
    dHf_298   -688420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1073.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-94040.0
    phase     gas;
}
