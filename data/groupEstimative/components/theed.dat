/*--------------------------------*- Choupo -*-----------------------*\
  Component: theed  (C10H24N2O4, CAS 140-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        theed;
formula     C10H24N2O4;
CAS         140-07-8;
InChIKey    BYACHAOCSIPLCM-UHFFFAOYSA-N;
MW          236.312;      // g/mol [origin=calculated method=formula-sum]
Tc          1008.02;      // K   [origin=predictive method=joback]
Pc          30.390;      // bar [origin=predictive method=joback]
omega       1.9513;      // -   [origin=predictive method=lee-kesler]
Tb          822.00;      // K   [origin=predictive method=joback]
HvapTb      108656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.42 1.3376 -0.000867 2.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group OH; count 4; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group OH; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[bis(2-hydroxyethyl)amino]ethyl-(2-hydroxyethyl)amino]ethanol" "n,n,n',n'-tetrakis(2-hydroxyethyl)ethylenediamine" "ethylenediamine tetraethanol" "entol" "tked" "ethylenedinitrilotetraethanol" "ethanol, 2,2',2'',2'''-(1,2-ethanediyldinitrilo)tetrakis-" "(tetrahydroxyethyl)ethylenediamine" "tetra(hydroxyethyl)ethylenediamine" "tetrakis(hydroxyethyl)ethylenediamine" "2,2',2'',2'''-ethylenedinitrilotetraethanol" "tetrahydroxyethyl ethylenediamine" );
gibbsFormation
{
    dHf_298   -723590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     781.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292400.0
    phase     gas;
}
