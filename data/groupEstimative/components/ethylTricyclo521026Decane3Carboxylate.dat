/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl tricyclo[5.2.1.02,6]decane-3-carboxylate  (C13H20O2, CAS 68992-06-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylTricyclo521026Decane3Carboxylate;
formula     C13H20O2;
CAS         68992-06-3;
InChIKey    LINAHFPJENQYPB-UHFFFAOYSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          778.74;      // K   [origin=predictive method=joback]
Pc          22.419;      // bar [origin=predictive method=joback]
omega       0.5925;      // -   [origin=predictive method=lee-kesler]
Tb          570.41;      // K   [origin=predictive method=joback]
HvapTb      51232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.489 1.57412 -0.0010922 2.98e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 5; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-methano-1h-indene-1-carboxylic acid, octahydro-, ethyl ester" "4,7-methanoindan-1-carboxylic acid, hexahydro-, ethyl ester" );
gibbsFormation
{
    dHf_298   -457370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97060.0
    phase     gas;
}
