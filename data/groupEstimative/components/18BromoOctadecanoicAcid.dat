/*--------------------------------*- Choupo -*-----------------------*\
  Component: 18-bromo-octadecanoic acid  (C18H35BrO2, CAS 2536-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18BromoOctadecanoicAcid;
formula     C18H35BrO2;
CAS         2536-38-1;
InChIKey    BSDAIZFMQYOAFY-UHFFFAOYSA-N;
MW          363.38;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.59;      // K   [origin=predictive method=joback]
Pc          12.865;      // bar [origin=predictive method=joback]
omega       1.1244;      // -   [origin=predictive method=lee-kesler]
Tb          823.11;      // K   [origin=predictive method=joback]
HvapTb      79261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.683 1.8028 -0.0010994 2.651e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 17; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 17; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "18-bromanyloctadecanoic acid" "octadecanoic acid, 18-bromo-" );
standardThermochemistry
{
    dHf_298   -738790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     961.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-228910.0
}
