/*--------------------------------*- Choupo -*-----------------------*\
  Component: norethisterone acetate  (C22H28O3, CAS 51-98-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norethisteroneAcetate;
formula     C22H28O3;
CAS         51-98-9;
InChIKey    IMONTRJLAWHYGT-ZCPXKWAGSA-N;
MW          340.463;      // g/mol [origin=calculated method=formula-sum]
Tc          1118.56;      // K   [origin=predictive method=joback]
Pc          16.633;      // bar [origin=predictive method=joback]
omega       0.7955;      // -   [origin=predictive method=lee-kesler]
Tb          862.71;      // K   [origin=predictive method=joback]
HvapTb      74624.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-234.09 2.74774 -0.00235377 8.6549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH3COO; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17r)-17-ethynyl-13-methyl-3-oxidanylidene-1,2,6,7,8,9,10,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-17-yl] ethanoate" "norethindrone acetate" "19-norethindrone acetate" "enta" "orlutate" "norlutin acetate" "primolut-nor" "norethindrone 17-acetate" "19-norethisterone acetate" "norethisteron acetate" "norethysterone acetate" "gestakadin" );
standardThermochemistry
{
    dHf_298   -363980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100900.0
}
