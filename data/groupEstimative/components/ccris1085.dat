/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 1085  (C20H18O3, CAS 69260-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris1085;
formula     C20H18O3;
CAS         69260-83-9;
InChIKey    KJYHPFPBANRKJS-UYAOXDASSA-N;
MW          306.361;      // g/mol [origin=calculated method=formula-sum]
Tc          1260.32;      // K   [origin=predictive method=joback]
Pc          26.084;      // bar [origin=predictive method=joback]
omega       1.8304;      // -   [origin=predictive method=lee-kesler]
Tb          1028.78;      // K   [origin=predictive method=joback]
HvapTb      119085.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.359 1.68082 -0.00123052 3.648e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 6; } { group AC; count 5; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 8; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,4r)-12-(hydroxymethyl)-7-methyl-3,4-dihydrobenzo[a]anthracene-3,4-diol" "(e)-3,4-dihydroxy-7-methyl-3,4-dihydrobenz(a)anthracene-12-methanol" "trans-12-(hydroxymethyl)-7-methylbenz(a)anthracene-3,4-dihydrodiol" "trans-3,4-dihydroxy-3,4-dihydro-7-methyl-12-hydroxymethylbenz(a)anthracene" "benz(a)anthracene-12-methanol, 3,4-dihydro-3,4-dihydroxy-7-methyl-, (e)-" "benz(a)anthracene-3,4-diol, 3,4-dihydro-12-(hydroxymethyl)-7-methyl-, trans-" );
gibbsFormation
{
    dHf_298   -247420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55520.0
    phase     gas;
}
