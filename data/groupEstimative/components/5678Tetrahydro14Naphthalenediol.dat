/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6,7,8-tetrahydro-1,4-naphthalenediol  (C10H12O2, CAS 13623-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5678Tetrahydro14Naphthalenediol;
formula     C10H12O2;
CAS         13623-10-4;
InChIKey    GVTDRUXHMYZTFF-UHFFFAOYSA-N;
MW          164.204;      // g/mol [origin=calculated method=formula-sum]
Tc          892.34;      // K   [origin=predictive method=joback]
Pc          52.816;      // bar [origin=predictive method=joback]
omega       0.8455;      // -   [origin=predictive method=lee-kesler]
Tb          636.98;      // K   [origin=predictive method=joback]
HvapTb      67214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.95 1.2924 -0.00122628 4.722e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,6,7,8-tetrahydronaphthalene-1,4-diol" "1,4-naphthalenediol, 5,6,7,8-tetrahydro-" "5,7,8-tetrahydro-1,4-naphthalenediol" );
gibbsFormation
{
    dHf_298   -292310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116780.0
    phase     gas;
}
