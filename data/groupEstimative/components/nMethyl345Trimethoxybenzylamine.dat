/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-3,4,5-trimethoxybenzylamine  (C11H17NO3, CAS 58780-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyl345Trimethoxybenzylamine;
formula     C11H17NO3;
CAS         58780-82-8;
InChIKey    LFULMNRPABTDDQ-UHFFFAOYSA-N;
MW          211.261;      // g/mol [origin=calculated method=formula-sum]
Tc          811.13;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.8316;      // -   [origin=predictive method=lee-kesler]
Tb          610.33;      // K   [origin=predictive method=joback]
HvapTb      58008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (77.171 0.67808 -0.00012028 -8.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACCH2; count 1; } { group CH3O; count 3; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 3; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-1-(3,4,5-trimethoxyphenyl)methanamine" "methyl[(3,4,5-trimethoxyphenyl)methyl]amine" "3,4,5-trimethoxybenzyl methylamine" "benzenemethanamine,3,4,5-trimethoxy-n-methyl-" "benzylamine,3,4,5-trimethoxy-n-methyl- (6ci);n-methyl-3,4,5-trimethoxybenzylamine;n-methyl-n-[(3,4,5-trimethoxyphenyl)methyl]amine;" );
standardThermochemistry
{
    dHf_298   -411440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100350.0
}
