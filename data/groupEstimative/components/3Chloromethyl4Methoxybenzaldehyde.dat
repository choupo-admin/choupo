/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(chloromethyl)-4-methoxybenzaldehyde  (C9H9ClO2, CAS 52577-09-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H9ClO2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Chloromethyl4Methoxybenzaldehyde;
formula     C9H9ClO2;
CAS         52577-09-0;
InChIKey    LNKDOOILNUKDMI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          184.619;      // g/mol [origin=calculated method=formula-sum]
Tc          692.38;      // K   [origin=predictive method=joback]
Pc          31.175;      // bar [origin=predictive method=joback]
omega       0.4231;      // -   [origin=predictive method=lee-kesler]
Tb          478.43;      // K   [origin=predictive method=joback]
HvapTb      43650.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.291 0.61262 -0.00042532 1.225e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 3; } { group CHO; count 1; } { group CH3O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(chloromethyl)-4-methoxy-benzaldehyde" "3-chloromethyl-4-methoxy-benzaldehyde" "3-chloromethyl-4-methoxybenzaldehyde" "benzaldehyde, 3-(chloromethyl)-4-methoxy-" "3-(chloromethyl)-p-anisaldehyde" "benzaldehyde,3-(chloromethyl)-4-methoxy-" );
gibbsFormation
{
    dHf_298   -87010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45080.0
    phase     gas;
}
