/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-diaminonaphthalene  (C10H10N2, CAS 2243-62-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Diaminonaphthalene;
formula     C10H10N2;
CAS         2243-62-1;
InChIKey    KQSABULTKYLFEV-UHFFFAOYSA-N;
MW          158.204;      // g/mol [origin=calculated method=formula-sum]
Tc          886.59;      // K   [origin=predictive method=joback]
Pc          43.397;      // bar [origin=predictive method=joback]
omega       0.7141;      // -   [origin=predictive method=lee-kesler]
Tb          629.08;      // K   [origin=predictive method=joback]
HvapTb      64376.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.97 0.876 -0.00064084 1.866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 2; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 4; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalene-1,5-diamine" "1,5-naphthalenediamine" "1,5-naphthylenediamine" "1,5-napthalenediamine" "1,5-diamino naphthalene" );
standardThermochemistry
{
    dHf_298   222510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     421.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=366020.0
}
