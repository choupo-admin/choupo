/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-cyclohexenyl)ethylamine  (C8H15N, CAS 3399-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21CyclohexenylEthylamine;
formula     C8H15N;
CAS         3399-73-3;
InChIKey    IUDMXOOVKMKODN-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          702.08;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.4643;      // -   [origin=predictive method=lee-kesler]
Tb          483.53;      // K   [origin=predictive method=joback]
HvapTb      45735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.358 0.8588 -0.00051144 1.121e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH=C; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclohexen-1-yl)ethanamine" "1-cyclohexene-1-ethanamine" "cyclohexenylethylamine" "2-(cyclohex-1-en-1-yl)ethanamine" "1-cyclohexen-1-ylethylamine" "2-(1-cyclohexen-1-yl)ethylamine" "2-cyclohex-1-enylethylamine" "2-aminoethyl-1-cyclohexene" "cyclohex-1-ene-1-ethylamine" "beta-(1-cyclohexenyl)ethylamine" ".beta.-(1-cyclohexenyl)ethylamine" "2-(cyclohex-1-en-1-yl)ethan-1-amine" );
gibbsFormation
{
    dHf_298   -53690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135420.0
    phase     gas;
}
