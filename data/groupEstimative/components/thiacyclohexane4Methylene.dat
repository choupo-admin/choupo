/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiacyclohexane, 4-methylene  (C6H10S, CAS 50550-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiacyclohexane4Methylene;
formula     C6H10S;
CAS         50550-56-6;
InChIKey    BOJWREQWHOWAEL-UHFFFAOYSA-N;
MW          114.206;      // g/mol [origin=calculated method=formula-sum]
Tc          633.11;      // K   [origin=predictive method=joback]
Pc          42.002;      // bar [origin=predictive method=joback]
omega       0.2459;      // -   [origin=predictive method=lee-kesler]
Tb          408.09;      // K   [origin=predictive method=joback]
HvapTb      35659.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.0 0.61931 -0.0003653 7.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylidenethiane" );
gibbsFormation
{
    dHf_298   36990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124740.0
    phase     gas;
}
