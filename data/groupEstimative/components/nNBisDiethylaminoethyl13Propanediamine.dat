/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(diethylaminoethyl)-1,3-propanediamine  (C15H36N4, CAS 68413-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBisDiethylaminoethyl13Propanediamine;
formula     C15H36N4;
CAS         68413-93-4;
InChIKey    DNLSJBVDVPAZJP-UHFFFAOYSA-N;
MW          272.481;      // g/mol [origin=calculated method=formula-sum]
Tc          833.90;      // K   [origin=predictive method=joback]
Pc          14.392;      // bar [origin=predictive method=joback]
omega       1.0594;      // -   [origin=predictive method=lee-kesler]
Tb          668.02;      // K   [origin=predictive method=joback]
HvapTb      65942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.549 1.82908 -0.0011146 2.631e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH2NH; count 2; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 11; } { group NH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n'-bis[2-(diethylamino)ethyl]propane-1,3-diamine" "1,3-propanediamine, n,n'-bis(2-(diethylamino)ethyl)-" "1,3-propanediamine, n,n'-bis[2-(diethylamino)ethyl]-" "1,3-propanediamine, n1,n3-bis(2-(diethylamino)ethyl)-" "1,3-propanediamine, n1,n3-bis[2-(diethylamino)ethyl]-" "n,n'-bis(2-diethylaminoethyl)propane-1,3-diamine" "n,n'-bis(2-(diethylamino)ethyl)propane-1,3-diamine" );
gibbsFormation
{
    dHf_298   -110930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     853.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=475760.0
    phase     gas;
}
