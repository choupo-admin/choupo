/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-cholesten-3-one  (C27H44O, CAS 601-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Cholesten3One;
formula     C27H44O;
CAS         601-54-7;
InChIKey    GGCLNOIGPMGLDB-GYKMGIIDSA-N;
MW          384.648;      // g/mol [origin=calculated method=formula-sum]
Tc          1161.69;      // K   [origin=predictive method=joback]
Pc          10.617;      // bar [origin=predictive method=joback]
omega       0.7833;      // -   [origin=predictive method=lee-kesler]
Tb          927.89;      // K   [origin=predictive method=joback]
HvapTb      77713.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-281.187 3.3833 -0.00273084 9.627e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 6; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-1,2,4,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-3-one" "3-keto cholesterol" "cholest-5-en-3-one" "3-keto-5-cholestene" "oxidized cholesterol" "delta(sup 5)-cholestenone" "5-cholestenone" "3-ketocholesterol" "3-oxocholest-5-ene" "delta(5)-cholestenone" "cholestenone (delta 5)" " currency5-cholesten-3-one" );
standardThermochemistry
{
    dHf_298   -452360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     859.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=225420.0
}
