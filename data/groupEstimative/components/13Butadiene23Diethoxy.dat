/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butadiene, 2,3-diethoxy-  (C8H14O2, CAS 55370-32-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butadiene23Diethoxy;
formula     C8H14O2;
CAS         55370-32-6;
InChIKey    NSCSTEHHIAANDP-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          598.03;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       0.4488;      // -   [origin=predictive method=lee-kesler]
Tb          420.60;      // K   [origin=predictive method=joback]
HvapTb      37042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.252 0.59724 -0.0002398 1.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dC; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-diethoxybuta-1,3-diene" );
standardThermochemistry
{
    dHf_298   -241610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-34940.0
}
