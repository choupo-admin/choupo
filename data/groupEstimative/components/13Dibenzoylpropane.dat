/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dibenzoylpropane  (C17H16O2, CAS 6263-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dibenzoylpropane;
formula     C17H16O2;
CAS         6263-83-8;
InChIKey    YOLLTWVIOASMFW-UHFFFAOYSA-N;
MW          252.313;      // g/mol [origin=calculated method=formula-sum]
Tc          986.93;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.8884;      // -   [origin=predictive method=lee-kesler]
Tb          749.66;      // K   [origin=predictive method=joback]
HvapTb      71480.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.657 1.405 -0.000926 2.2402e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-diphenylpentane-1,5-dione" "1,5-diphenyl-1,5-pentanedione" "1,5-pentanedione, 1,5-diphenyl-" "1,5-pentadione" "1,5-diphenyl-1,5-pentadione" "1,5-diphenyl-pentane-1,5-dione" "1,5-pentanedione,1,5-diphenyl-" );
gibbsFormation
{
    dHf_298   -146310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     658.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59240.0
    phase     gas;
}
