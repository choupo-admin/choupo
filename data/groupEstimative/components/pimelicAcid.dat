/*--------------------------------*- Choupo -*-----------------------*\
  Component: pimelic acid  (C7H12O4, CAS 111-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pimelicAcid;
formula     C7H12O4;
CAS         111-16-0;
InChIKey    WLJVNTCWHIRURA-UHFFFAOYSA-N;
MW          160.169;      // g/mol [origin=calculated method=formula-sum]
Tc          851.81;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       1.1761;      // -   [origin=predictive method=lee-kesler]
Tb          650.78;      // K   [origin=predictive method=joback]
HvapTb      65504.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.725 0.7704 -0.0005022 1.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptanedioic acid" "pimelate" "pileric acid" "heptandioic acid" "1,5-pentanedicarboxylic acid" "6-carboxyhexanoate" "heptane-1,7-dioic acid" "6-carboxyhexanoic acid" "1,7-heptanedioic acid" "pml" "pimelic acids" "heptandioate" );
standardThermochemistry
{
    dHf_298   -888350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-679760.0
}
