/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-chlorobenzoyl)propionic acid  (C10H9ClO3, CAS 3984-34-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34ChlorobenzoylPropionicAcid;
formula     C10H9ClO3;
CAS         3984-34-7;
InChIKey    AHVASTJJVAYFPY-UHFFFAOYSA-N;
MW          212.629;      // g/mol [origin=calculated method=formula-sum]
Tc          927.40;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.9954;      // -   [origin=predictive method=lee-kesler]
Tb          696.87;      // K   [origin=predictive method=joback]
HvapTb      69087.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.958 0.845 -0.00055866 1.3636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-chlorophenyl)-4-oxidanylidene-butanoic acid" "4-(4-chlorophenyl)-4-oxobutanoic acid" "4-(4-chloro-phenyl)-4-oxo-butyric acid" "4-(4-chlorophenyl)-4-oxobutanoicacid" "3-(p-chlorobenzoyl)propionic acid" "benzenebutanoic acid, 4-chloro-gamma-oxo-" "benzenebutanoic acid, 4-chloro-.gamma.-oxo-" );
gibbsFormation
{
    dHf_298   -503260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     546.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-348660.0
    phase     gas;
}
