/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutanol, 1-phenyl-  (C10H12O, CAS 935-64-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutanol1Phenyl;
formula     C10H12O;
CAS         935-64-8;
InChIKey    LHXASHUXCRQHPZ-UHFFFAOYSA-N;
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          781.01;      // K   [origin=predictive method=joback]
Pc          41.356;      // bar [origin=predictive method=joback]
omega       0.7422;      // -   [origin=predictive method=lee-kesler]
Tb          558.51;      // K   [origin=predictive method=joback]
HvapTb      55743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.17 1.3421 -0.0012882 5.105e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylcyclobutan-1-ol" "1-phenylcyclobutanol" "benzene, cyclobut-1-yl-1-ol-" );
gibbsFormation
{
    dHf_298   -83550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52070.0
    phase     gas;
}
