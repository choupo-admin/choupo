/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromothiophene  (C4H3BrS, CAS 1003-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromothiophene;
formula     C4H3BrS;
CAS         1003-09-4;
InChIKey    TUCRZHGAIRVWTI-UHFFFAOYSA-N;
MW          163.032;      // g/mol [origin=calculated method=formula-sum]
Tc          676.42;      // K   [origin=predictive method=joback]
Pc          62.098;      // bar [origin=predictive method=joback]
omega       0.3043;      // -   [origin=predictive method=lee-kesler]
Tb          428.36;      // K   [origin=predictive method=joback]
HvapTb      38557.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.3 0.42311 -0.00037422 1.305e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 1; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 1; } { group Br; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylthiophene" "thiophene, 2-bromo-" "2-thienyl bromide" "2-bromo-thiophene" "2-bromo thiophene" "sfpdabhhryszzp@" );
standardThermochemistry
{
    dHf_298   130610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     324.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=131530.0
}
