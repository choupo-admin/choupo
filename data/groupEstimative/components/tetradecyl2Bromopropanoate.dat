/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecyl 2-bromopropanoate  (C17H33BrO2, CAS 86711-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecyl2Bromopropanoate;
formula     C17H33BrO2;
CAS         86711-82-2;
InChIKey    XLNAEONRIMSMIY-UHFFFAOYSA-N;
MW          349.353;      // g/mol [origin=calculated method=formula-sum]
Tc          890.96;      // K   [origin=predictive method=joback]
Pc          13.052;      // bar [origin=predictive method=joback]
omega       0.9613;      // -   [origin=predictive method=lee-kesler]
Tb          712.50;      // K   [origin=predictive method=joback]
HvapTb      66890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.353 1.60814 -0.000881 1.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl 2-bromanylpropanoate" "2- bromopropionic acid, tetradecyl ester" "propanoic acid, 2-bromo-, tetradecyl ester" );
gibbsFormation
{
    dHf_298   -690440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     910.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206230.0
    phase     gas;
}
