/*--------------------------------*- Choupo -*-----------------------*\
  Component: ddoh  (C14H12Cl2O, CAS 2642-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ddoh;
formula     C14H12Cl2O;
CAS         2642-82-2;
InChIKey    ZVIDYKRNLNAXFT-UHFFFAOYSA-N;
MW          267.149;      // g/mol [origin=calculated method=formula-sum]
Tc          981.17;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       1.0434;      // -   [origin=predictive method=lee-kesler]
Tb          749.84;      // K   [origin=predictive method=joback]
HvapTb      77695.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.659 1.1105 -0.00074052 1.839e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(4-chlorophenyl)ethanol" "2,2-bis(p-chlorophenyl)ethanol" "ddom" "p,p'-ddoh" "benzeneethanol, 4-chloro-.beta.-(4-chlorophenyl)-" "2,2-bis(4'-chlorophenyl)ethanol" "bis(p-chlorophenyl)ethanol" "2,2-bis(4-chlorophenyl)-1-hydroxyethane" "4,4'-ddoh" "2,2-bis(4-chlorophenyl)-1-ethanol" "2,2-bis(4'-chlorophenyl)ethanol (ddoh)" "4-chloro-beta-(4-chlorophenyl)benzeneethanol" );
standardThermochemistry
{
    dHf_298   -71160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109440.0
}
