/*--------------------------------*- Choupo -*-----------------------*\
  Component: 34424-57-2  (C20H32, CAS 34424-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34424572;
formula     C20H32;
CAS         34424-57-2;
InChIKey    IODSADAHQKFXES-CCJFMQDPSA-N;
MW          272.476;      // g/mol [origin=calculated method=formula-sum]
Tc          929.34;      // K   [origin=predictive method=joback]
Pc          16.714;      // bar [origin=predictive method=joback]
omega       0.4935;      // -   [origin=predictive method=lee-kesler]
Tb          687.11;      // K   [origin=predictive method=joback]
HvapTb      56366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-361.12 3.20928 -0.00317828 1.318e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 4; } { group C; count 3; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 7; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -147090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=302480.0
}
