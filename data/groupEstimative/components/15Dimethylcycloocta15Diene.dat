/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-dimethylcycloocta-1,5-diene  (C10H16, CAS 3760-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Dimethylcycloocta15Diene;
formula     C10H16;
CAS         3760-14-3;
InChIKey    RYOGZVTWMZNTGL-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          689.92;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.3280;      // -   [origin=predictive method=lee-kesler]
Tb          469.44;      // K   [origin=predictive method=joback]
HvapTb      40844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.83 0.85224 -0.00040428 4.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -94770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81940.0
    phase     gas;
}
