/*--------------------------------*- Choupo -*-----------------------*\
  Component: (-)-germacrene d  (C15H24, CAS 23986-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        germacreneD;
formula     C15H24;
CAS         23986-74-5;
InChIKey    GAIBLDCXCZKKJE-RXJOXMPGSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          804.78;      // K   [origin=predictive method=joback]
Pc          19.424;      // bar [origin=predictive method=joback]
omega       0.4383;      // -   [origin=predictive method=lee-kesler]
Tb          581.45;      // K   [origin=predictive method=joback]
HvapTb      51118.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.37 1.22946 -0.00050592 1.12e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1e,6e,8s)-1-methyl-5-methylidene-8-propan-2-yl-cyclodeca-1,6-diene" "germacrene d" "(1e,6e,8s)-1-methyl-5-methylidene-8-(propan-2-yl)cyclodeca-1,6-diene" "(-)-(s)-germacrene d" "(-)-(7s)-germacrene-d" "1-methyl-5-methylene-8-(1-methylethyl)-1,6-cyclodecadiene" "1(10),4(14),5-germacratriene" "(1e,5e)-germacra-1(10),4(15),5-triene" "(1e,6e,8s)-8-isopropyl-1-methyl-5-methylenecyclodeca-1,6-diene" "(1e,6e,8s)-1-methyl-5-methylidene-8-propan-2-ylcyclodeca-1,6-diene" "(1e,6e,8s)-1-methyl-8-(1-methylethyl)-5-methylidenecyclodeca-1,6-diene" );
gibbsFormation
{
    dHf_298   -140200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     672.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=152400.0
    phase     gas;
}
