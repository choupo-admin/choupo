/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylpyrogallol  (C7H8O3, CAS 609-25-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylpyrogallol;
formula     C7H8O3;
CAS         609-25-6;
InChIKey    NYUABOGYMWADSF-UHFFFAOYSA-N;
MW          140.138;      // g/mol [origin=calculated method=formula-sum]
Tc          881.69;      // K   [origin=predictive method=joback]
Pc          80.871;      // bar [origin=predictive method=joback]
omega       1.0326;      // -   [origin=predictive method=lee-kesler]
Tb          628.30;      // K   [origin=predictive method=joback]
HvapTb      72494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.14 1.05372 -0.00115728 4.969e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methylbenzene-1,2,3-triol" "3,4,5-trihydroxytoluene" "1,2,3-benzenetriol, 5-methyl-" "5-methyl-1,2,3-benzenetriol" "1,2,3-benzenetriol,5-methyl-" "3,4,5 trihydroxytoluene" "pyrogallol,5-methyl- (6ci,7ci,8ci);2,6-dihydroxy-5-methylphenol;5-methylbenzene-1,2,3-triol;5-methylpyrogallol;" );
gibbsFormation
{
    dHf_298   -483210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-343390.0
    phase     gas;
}
