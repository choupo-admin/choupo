/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran-2-one, 6-butyl-5,6-dihydro-  (C9H14O2, CAS 16400-70-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyran2One6Butyl56Dihydro;
formula     C9H14O2;
CAS         16400-70-7;
InChIKey    FZGRTOXOBUQQAD-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          666.37;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.5277;      // -   [origin=predictive method=lee-kesler]
Tb          473.91;      // K   [origin=predictive method=joback]
HvapTb      43412.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.467 0.88932 -0.00053228 1.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-butyl-2,3-dihydropyran-6-one" "6-butyl-5,6-dihydro-2h-pyran-2-one" "3-butyl-3,4-dihydro-2h-pyran-2-one" "agn-pc-03edpl" );
gibbsFormation
{
    dHf_298   -421950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-206860.0
    phase     gas;
}
