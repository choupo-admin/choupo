/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzyl-1,3-dioxane  (C11H14O2, CAS 5468-00-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Benzyl13Dioxane;
formula     C11H14O2;
CAS         5468-00-8;
InChIKey    OYXWNUNPFXKSEM-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          791.41;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.4809;      // -   [origin=predictive method=lee-kesler]
Tb          551.41;      // K   [origin=predictive method=joback]
HvapTb      51805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.979 1.086 -0.000659 1.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethyl)-1,3-dioxane" "2-phenylmethyl-1,3-dioxane" "1,3-dioxane, 2-(phenylmethyl)-" "phenyl acetaldehyde cyclic acetal with trimethylene glycol" );
gibbsFormation
{
    dHf_298   -243520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     344.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6360.0
    phase     gas;
}
