/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4-benzenetricarboxylic acid, tris(decyl) ester  (C39H66O6, CAS 4130-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124BenzenetricarboxylicAcidTrisDecylEster;
formula     C39H66O6;
CAS         4130-35-2;
InChIKey    SMYKBXMWXCZOLU-UHFFFAOYSA-N;
MW          630.951;      // g/mol [origin=calculated method=formula-sum]
Tc          1767.46;      // K   [origin=predictive method=joback]
Pc          4.633;      // bar [origin=predictive method=joback]
omega       -0.2170;      // -   [origin=predictive method=lee-kesler]
Tb          1303.22;      // K   [origin=predictive method=joback]
HvapTb      128229.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.357 3.34656 -0.00171112 2.573e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 27; } { group ACH; count 3; } { group AC; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 27; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tris-decyl benzene-1,2,4-tricarboxylate" "1,2,4-benzenetricarboxylic acid, 1,2,4-tridecyl ester" "1,2,4-benzenetricarboxylic acid, tridecyl ester (iso)" );
gibbsFormation
{
    dHf_298   -1586540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1710.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-560460.0
    phase     gas;
}
