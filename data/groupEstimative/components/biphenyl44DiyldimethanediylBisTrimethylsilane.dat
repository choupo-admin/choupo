/*--------------------------------*- Choupo -*-----------------------*\
  Component: (biphenyl-4,4'-diyldimethanediyl)bis(trimethylsilane)  (C20H30Si2, CAS 61342-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20H30Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        biphenyl44DiyldimethanediylBisTrimethylsilane;
formula     C20H30Si2;
CAS         61342-05-0;
InChIKey    IRHAFFVSIFKTLG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          326.63;      // g/mol [origin=calculated method=formula-sum]
Tc          951.12;      // K   [origin=predictive method=joback]
Pc          13.262;      // bar [origin=predictive method=joback]
omega       0.5413;      // -   [origin=predictive method=lee-kesler]
Tb          723.32;      // K   [origin=predictive method=joback]
HvapTb      66578.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.132 1.21472 -0.00016292 -2.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl-[[4-[4-(trimethylsilylmethyl)phenyl]phenyl]methyl]silane" "silane,[[1,1'-biphenyl]-4,4'-diylbis(methylene)]bis[trimethyl-" "silane, ((1,1'-biphenyl)-4,4'-diylbis(methylene))bis(trimethyl-" "silane, ((1,1-biphenyl)-4,4-diylbis(methylene))bis(trimethyl-" );
gibbsFormation
{
    dHf_298   -229250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     962.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113560.0
    phase     gas;
}
