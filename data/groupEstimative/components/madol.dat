/*--------------------------------*- Choupo -*-----------------------*\
  Component: madol  (C20H32O, CAS 3275-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        madol;
formula     C20H32O;
CAS         3275-64-7;
InChIKey    FRVHJVATKMIOPQ-PAPWGAKMSA-N;
MW          288.475;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.11;      // K   [origin=predictive method=joback]
Pc          18.436;      // bar [origin=predictive method=joback]
omega       0.8891;      // -   [origin=predictive method=lee-kesler]
Tb          783.56;      // K   [origin=predictive method=joback]
HvapTb      73217.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-360.95 3.23366 -0.00316228 1.2979e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 4; } { group C; count 3; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 3; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5s,8r,9s,10s,13s,14s,17s)-10,13,17-trimethyl-1,4,5,6,7,8,9,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-17-ol" "5-alpha-androst-2-en-17-beta-ol, 17-methyl-" "androst-2-en-17-ol, 17-methyl-, (5-alpha,17-beta)-" "17-alpha-methyl-(5-alpha)-delta(sup 2)-androstene-17-beta-ol" "pheraplex" "desoxymethyltesterone" "desoxymethyltestosterone" "17" "a-methylandrost-2-en-17" "a-ol" "17-methyl-5" "a-androst-2-en-17" "a-ol" );
standardThermochemistry
{
    dHf_298   -305480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     768.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153560.0
}
