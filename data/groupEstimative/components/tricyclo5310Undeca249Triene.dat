/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[5.3.1.0]undeca-2,4,9-triene  (C11H12, CAS 67313-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo5310Undeca249Triene;
formula     C11H12;
CAS         67313-66-0;
InChIKey    JZOWWMRTKMEQIK-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          730.37;      // K   [origin=predictive method=joback]
Pc          38.916;      // bar [origin=predictive method=joback]
omega       0.3130;      // -   [origin=predictive method=lee-kesler]
Tb          482.67;      // K   [origin=predictive method=joback]
HvapTb      39046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-250.66 1.9246 -0.00222484 9.946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group C; count 2; } { group CH=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group C_ring; count 2; } { group dCH_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(5.3.1.0)undeca-2,4,9-triene" );
gibbsFormation
{
    dHf_298   159870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=286400.0
    phase     gas;
}
