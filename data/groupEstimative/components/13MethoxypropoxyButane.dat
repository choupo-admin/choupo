/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-methoxypropoxy)butane  (C8H18O2, CAS 25736-79-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13MethoxypropoxyButane;
formula     C8H18O2;
CAS         25736-79-2;
InChIKey    SYQZZZDASGVPDV-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          591.77;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.5523;      // -   [origin=predictive method=lee-kesler]
Tb          427.48;      // K   [origin=predictive method=joback]
HvapTb      38222.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.616 0.63744 -0.0001894 -2.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH3O; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ucon dlb 62e" "ucon lubricant dlb-62-e" "poly(oxy(methyl-1,2-ethanediyl)), alpha-butyl-omega-methoxy-" "glycols, polypropylene, butyl methyl ether" "glycols, polypropylene, butyl methyl ether (8ci)" "poly[oxy(methyl-1,2-ethanediyl)],a-butyl-w-methoxy-" "poly[oxy(methyl-1,2-ethanediyl)], ?-butyl-?-methoxy-" "glycols,polypropylene, butyl methyl ether (8ci); polypropylene glycol butyl methyldiether; polypropylene glycol butyl methyl ether; ucon dlb 200e; ucon dlb 62e" );
gibbsFormation
{
    dHf_298   -472890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193520.0
    phase     gas;
}
