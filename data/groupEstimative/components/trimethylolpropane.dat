/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane  (C6H14O3, CAS 77-99-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropane;
formula     C6H14O3;
CAS         77-99-6;
InChIKey    ZJCCRDAZUWHFQH-UHFFFAOYSA-N;
MW          134.175;      // g/mol [origin=calculated method=formula-sum]
Tc          772.42;      // K   [origin=predictive method=joback]
Pc          44.504;      // bar [origin=predictive method=joback]
omega       1.7647;      // -   [origin=predictive method=lee-kesler]
Tb          610.19;      // K   [origin=predictive method=joback]
HvapTb      77691.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.166 0.80162 -0.0005656 1.615e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group C; count 1; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-2-(hydroxymethyl)propane-1,3-diol" "ethriol" "2-ethyl-2-(hydroxymethyl)-1,3-propanediol" "hexaglycerine" "ettriol" "etriol" "trimethylol propane" "tmp (alcohol)" "1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-" "1,1,1-tris(hydroxymethyl)propane" "ethyltrimethylolmethane" "tri(hydroxymethyl)propane" );
standardThermochemistry
{
    dHf_298   -632610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-407980.0
}
