/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)salicylamide  (C9H11NO3, CAS 24207-38-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxyethylSalicylamide;
formula     C9H11NO3;
CAS         24207-38-3;
InChIKey    NCPLWPQEVIBZKJ-UHFFFAOYSA-N;
MW          181.191;      // g/mol [origin=calculated method=formula-sum]
Tc          921.53;      // K   [origin=predictive method=joback]
Pc          48.630;      // bar [origin=predictive method=joback]
omega       1.4833;      // -   [origin=predictive method=lee-kesler]
Tb          709.04;      // K   [origin=predictive method=joback]
HvapTb      80779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.678 1.0167 -0.00081366 2.6576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-hydroxyethyl)-2-oxidanyl-benzamide" "salicylic acid ethanolamide" "2-salicylamidoethanol" "salicylic acid monoethanol amide" "salicylhydroxyethylamide" "salicylamide, n-(2-hydroxyethyl)-" "2-hydroxy-n-(2'-hydroxyethyl)benzamide" "s2-2" "salicylic acid monoethanolamide" "n-(beta-hydroxyethyl)salicylamide" "benzamide, 2-hydroxy-n-(2-hydroxyethyl)-" "2-hydroxy-n-(2-hydroxyethyl)benzenecarboxamide" );
gibbsFormation
{
    dHf_298   -381210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-193660.0
    phase     gas;
}
