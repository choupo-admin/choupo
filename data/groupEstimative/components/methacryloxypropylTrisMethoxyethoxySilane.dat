/*--------------------------------*- Choupo -*-----------------------*\
  Component: methacryloxypropyl tris(methoxyethoxy)silane  (C16H32O8Si, CAS 57069-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H32O8Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methacryloxypropylTrisMethoxyethoxySilane;
formula     C16H32O8Si;
CAS         57069-48-4;
InChIKey    DMZPTAFGSRVFIA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          380.509;      // g/mol [origin=calculated method=formula-sum]
Tc          934.11;      // K   [origin=predictive method=joback]
Pc          11.696;      // bar [origin=predictive method=joback]
omega       1.0071;      // -   [origin=predictive method=lee-kesler]
Tb          756.38;      // K   [origin=predictive method=joback]
HvapTb      72781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (204.889 0.86358 0.0003036 -4.047e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2=C; count 1; } { group CH3O; count 3; } { group CH2O; count 3; } { group COO; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 9; } { group dCH2; count 1; } { group dC; count 1; } { group O; count 6; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[tris(2-methoxyethoxy)silyl]propyl 2-methylprop-2-enoate" "3-(tris(2-methoxyethoxy)silyl)propyl methacrylate" "2-propenoic acid, 2-methyl-, 3-[tris(2-methoxyethoxy)silyl]propyl ester" "3-(tris(methoxyethoxy)silyl)propyl methacrylate" "3-[tris[methoxyethoxy]silyl]propyl methacrylate" "2-propenoic acid, 2-methyl-, 3-(tris(2-methoxyethoxy)silyl)propyl ester" "(3-methacryloxypropyl)tris(2-methoxyethoxy)silane" );
standardThermochemistry
{
    dHf_298   -1480150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1015.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-882000.0
}
