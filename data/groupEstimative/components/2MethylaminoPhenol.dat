/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(methylamino)phenol  (C7H9NO, CAS 611-24-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2MethylaminoPhenol;
formula     C7H9NO;
CAS         611-24-5;
InChIKey    JHKKTXXMAQLGJB-UHFFFAOYSA-N;
MW          123.155;      // g/mol [origin=calculated method=formula-sum]
Tc          747.61;      // K   [origin=predictive method=joback]
Pc          51.240;      // bar [origin=predictive method=joback]
omega       0.6350;      // -   [origin=predictive method=lee-kesler]
Tb          517.23;      // K   [origin=predictive method=joback]
HvapTb      52902.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.51 0.82072 -0.00069316 2.412e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylaminophenol" "n-methyl-2-hydroxyaniline" "2-methylamino-phenol" "o-(methylamino)phenol" "n-methyl-2-aminophenol" "phenol, o-(methylamino)-" "phenol, 2-(methylamino)-" );
standardThermochemistry
{
    dHf_298   -75120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55240.0
}
