/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutyl radical  (C4H7, CAS 4548-06-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        cyclobutylRadical;
formula     C4H7;
CAS         4548-06-5;
InChIKey    ZAEBLFKQMDEPDM-UHFFFAOYSA-N;
role        radical;
MW          55.1;      // g/mol [origin=calculated method=formula-sum]
Tc          494.64;      // K   [origin=predictive method=joback]
Pc          51.313;      // bar [origin=predictive method=joback]
omega       0.1769;      // -   [origin=predictive method=lee-kesler]
Tb          306.38;      // K   [origin=predictive method=joback]
HvapTb      25038.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.16 0.5236 -0.00041664 1.361e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutane" "cyclobutanyl" "cyclobutan-1-yl" "cyclobutyl" );
standardThermochemistry
{
    dHf_298   -10020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     265.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54140.0
}
