/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorostyrene  (C8H7Cl, CAS 1331-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorostyrene;
formula     C8H7Cl;
CAS         1331-28-8;
InChIKey    SBYMUDUGTIKLCR-UHFFFAOYSA-N;
MW          138.594;      // g/mol [origin=calculated method=formula-sum]
Tc          679.08;      // K   [origin=predictive method=joback]
Pc          37.180;      // bar [origin=predictive method=joback]
omega       0.3158;      // -   [origin=predictive method=lee-kesler]
Tb          450.91;      // K   [origin=predictive method=joback]
HvapTb      40021.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.58 0.7117 -0.0005468 1.659e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylethenylbenzene" "benzene, (2-chloroethenyl)-" "omega-chlorostyrene" "2-chloroethenylbenzene" );
gibbsFormation
{
    dHf_298   129560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=197180.0
    phase     gas;
}
