/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-methyl-2-piperidyl)acetone  (C9H17NO, CAS 18747-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl2PiperidylAcetone;
formula     C9H17NO;
CAS         18747-42-7;
InChIKey    TYHJMEIBGDDCPA-UHFFFAOYSA-N;
MW          155.241;      // g/mol [origin=calculated method=formula-sum]
Tc          687.01;      // K   [origin=predictive method=joback]
Pc          29.505;      // bar [origin=predictive method=joback]
omega       0.5329;      // -   [origin=predictive method=lee-kesler]
Tb          487.11;      // K   [origin=predictive method=joback]
HvapTb      44674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.109 1.08644 -0.0006871 1.6376e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group CH3CO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-methylpiperidin-2-yl)propan-2-one" "1-(1-methyl-2-piperidinyl)acetone" "n-methylpelletierine" "methyl-isopelletierin" "1-(1-methyl-2-piperidyl)acetone" "acetone, (1-methyl-2-piperidyl)-" "2-propanone, (1-methyl-2-piperidinyl)-" "2-propanone,1-(1-methyl-2-piperidinyl)-" "2-propanone, 1-(1-methyl-2-piperidinyl)-, (.+-.)-" "2-propanone, 1-(1-methyl-2-piperidinyl)-, (.+/-.)-" "1-(1-methyl-2-piperidinyl)acetone;isopelletierine, n-methyl- (7ci);1-(1-methylpiperidin-2-yl)propan-2-one;acetone, (1-methyl-2-piperidyl)-;methylisopunicine;n-methylisopelletierine;" );
gibbsFormation
{
    dHf_298   -213660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43310.0
    phase     gas;
}
