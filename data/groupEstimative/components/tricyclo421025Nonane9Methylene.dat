/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo(4.2.1.02,5)nonane, 9-methylene-  (C10H14, CAS 66929-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo421025Nonane9Methylene;
formula     C10H14;
CAS         66929-86-0;
InChIKey    KXDPGYYUQCLXBN-UHFFFAOYSA-N;
MW          134.222;      // g/mol [origin=calculated method=formula-sum]
Tc          650.38;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       0.3533;      // -   [origin=predictive method=lee-kesler]
Tb          443.11;      // K   [origin=predictive method=joback]
HvapTb      37443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-128.7 1.2625 -0.001033 3.484e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   32570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     206.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=260940.0
    phase     gas;
}
