/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-dihydroxy-3-methylbenzoic acid  (C8H8O4, CAS 4707-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Dihydroxy3MethylbenzoicAcid;
formula     C8H8O4;
CAS         4707-49-7;
InChIKey    KZCSDJKWEYGAIX-UHFFFAOYSA-N;
MW          168.148;      // g/mol [origin=calculated method=formula-sum]
Tc          967.67;      // K   [origin=predictive method=joback]
Pc          60.750;      // bar [origin=predictive method=joback]
omega       1.2744;      // -   [origin=predictive method=lee-kesler]
Tb          721.05;      // K   [origin=predictive method=joback]
HvapTb      79532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.23 0.98542 -0.00096088 3.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-2,4-bis(oxidanyl)benzoic acid" "benzoic acid, 2,4-dihydroxy-3-methyl-" "3-methyl-beta-resorcylic acid" "beta-resorcylic acid, 3-methyl-" );
gibbsFormation
{
    dHf_298   -688280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-533890.0
    phase     gas;
}
