/*--------------------------------*- Choupo -*-----------------------*\
  Component: monobutyl tetrabromophthalate  (C12H10Br4O4, CAS 42597-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monobutylTetrabromophthalate;
formula     C12H10Br4O4;
CAS         42597-49-9;
InChIKey    NMYAGQGGKVRMGI-UHFFFAOYSA-N;
MW          537.824;      // g/mol [origin=calculated method=formula-sum]
Tc          1249.45;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       1.6333;      // -   [origin=predictive method=lee-kesler]
Tb          994.11;      // K   [origin=predictive method=joback]
HvapTb      98203.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (92.343 0.91622 -0.0005886 1.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group AC; count 6; } { group COOH; count 1; } { group Br; count 4; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dC_ring; count 6; } { group Br; count 4; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5-tetrakis(bromanyl)-6-butoxycarbonyl-benzoic acid" "1,2-benzenedicarboxylic acid, 3,4,5,6-tetrabromo-, 1-butyl ester" "butyl hydrogen tetrabromophthalate" "2,3,4,5-tetrabromo-6-butoxycarbonylbenzoic acid" "1,2-benzenedicarboxylic acid, 3,4,5,6-tetrabromo-, monobutyl ester" "3,4,5,6-tetrabromo-1,2-benzenedicarboxylic acid, monobutyl ester" );
gibbsFormation
{
    dHf_298   -674060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     794.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-482580.0
    phase     gas;
}
