/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-(branched c16-28 alkyl) hexanedioate  (C38H74O4, CAS 71662-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diBranchedC1628AlkylHexanedioate;
formula     C38H74O4;
CAS         71662-49-2;
InChIKey    IHPZJUVJMRKHMR-IHUVGRGJSA-N;
MW          595.006;      // g/mol [origin=calculated method=formula-sum]
Tc          1574.87;      // K   [origin=predictive method=joback]
Pc          4.297;      // bar [origin=predictive method=joback]
omega       -0.2010;      // -   [origin=predictive method=lee-kesler]
Tb          1183.72;      // K   [origin=predictive method=joback]
HvapTb      113444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.436 3.52792 -0.001867 3.248e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 24; } { group CH; count 4; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 26; } { group CH; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o6-[(2r,5s)-2-butyl-5-propyl-nonyl] o1-[(4r,5s)-4-butyl-5-propyl-nonyl] hexanedioate" "hexanedioic acid, di-c16-28-branched alkyl esters" "6-o-[(2r,5s)-2-butyl-5-propylnonyl] 1-o-[(4r,5s)-4-butyl-5-propylnonyl] hexanedioate" );
standardThermochemistry
{
    dHf_298   -1483330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1700.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-361420.0
}
