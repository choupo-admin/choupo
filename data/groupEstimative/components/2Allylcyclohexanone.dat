/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-allylcyclohexanone  (C9H14O, CAS 94-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Allylcyclohexanone;
formula     C9H14O;
CAS         94-66-6;
InChIKey    UPGHEUSRLZSXAE-UHFFFAOYSA-N;
MW          138.21;      // g/mol [origin=calculated method=formula-sum]
Tc          711.51;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.3989;      // -   [origin=predictive method=lee-kesler]
Tb          489.57;      // K   [origin=predictive method=joback]
HvapTb      39634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.459 0.7926 -0.0003257 9.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-prop-2-enylcyclohexan-1-one" "cyclohexanone, 2-(2-propenyl)-" "cyclohexanone, 2-allyl-" "cyclohexanone, 2-(2-propen-1-yl)-" "2-allylcyclohexan-1-one" "2-allyl-cyclohexan-1-one" "2-(2-propenyl)cyclohexanone" "cyclohexanone, 2-allyl- (8ci)" "2-(prop-2-en-1-yl)cyclohexanone" );
standardThermochemistry
{
    dHf_298   -187040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14600.0
}
