/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-1,3-oxathiolane  (C4H8OS, CAS 17642-74-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl13Oxathiolane;
formula     C4H8OS;
CAS         17642-74-9;
InChIKey    QNNPPEKCYFEVCF-UHFFFAOYSA-N;
MW          104.167;      // g/mol [origin=calculated method=formula-sum]
Tc          598.77;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.2474;      // -   [origin=predictive method=lee-kesler]
Tb          381.18;      // K   [origin=predictive method=joback]
HvapTb      35077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.09 0.52693 -0.000326 7.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group FCH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-oxathiolane, 2-methyl-" );
standardThermochemistry
{
    dHf_298   -152150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     260.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26910.0
}
