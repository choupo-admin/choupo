/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-buten-2-one, 4-(4-methylphenyl)-  (C11H12O, CAS 3160-38-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Buten2One44Methylphenyl;
formula     C11H12O;
CAS         3160-38-1;
InChIKey    USXMUOFSQBSHGN-UHFFFAOYSA-N;
MW          160.216;      // g/mol [origin=calculated method=formula-sum]
Tc          763.54;      // K   [origin=predictive method=joback]
Pc          29.441;      // bar [origin=predictive method=joback]
omega       0.5278;      // -   [origin=predictive method=lee-kesler]
Tb          540.97;      // K   [origin=predictive method=joback]
HvapTb      49722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.54 0.90244 -0.00060386 1.5866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methylphenyl)but-3-en-2-one" "(e)-4-(4-methylphenyl)but-3-en-2-one" "1-(4-methylphenyl)but-1-en-3-one" );
standardThermochemistry
{
    dHf_298   -40670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95820.0
}
