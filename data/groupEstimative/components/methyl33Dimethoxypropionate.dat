/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,3-dimethoxypropionate  (C6H12O4, CAS 7424-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl33Dimethoxypropionate;
formula     C6H12O4;
CAS         7424-91-1;
InChIKey    SMCVPMKCDDNUCQ-UHFFFAOYSA-N;
MW          148.158;      // g/mol [origin=calculated method=formula-sum]
Tc          616.97;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.5727;      // -   [origin=predictive method=lee-kesler]
Tb          439.50;      // K   [origin=predictive method=joback]
HvapTb      40789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (72.161 0.39856 1.08e-05 -1.07e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2COO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 3,3-dimethoxypropanoate" "methyl3,3-dimethoxypropionate" "3,3-dimethoxypropionic acid methyl ester" "propanoic acid, 3,3-dimethoxy-, methyl ester" "smcvpmkcddnucq-uhfffaoysa-" "u067" "3,3-dimethoxy-propionic acid methyl ester" );
gibbsFormation
{
    dHf_298   -754170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-523170.0
    phase     gas;
}
