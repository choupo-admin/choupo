/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyldimedone  (C9H14O2, CAS 1125-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyldimedone;
formula     C9H14O2;
CAS         1125-11-7;
InChIKey    WJTGLPHMQKJRIX-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          798.80;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.4597;      // -   [origin=predictive method=lee-kesler]
Tb          556.28;      // K   [origin=predictive method=joback]
HvapTb      43091.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.09 0.90976 -0.000536 1.493e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5,5-trimethylcyclohexane-1,3-dione" "1,3-cyclohexanedione, 2,5,5-trimethyl-" "1, 2,5,5-trimethyl-" "2,5-trimethyl-1,3-cyclohexanedione" "2,5,5-trimethyl-cyclohexane-1,3-dione" );
gibbsFormation
{
    dHf_298   -455270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     345.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209030.0
    phase     gas;
}
