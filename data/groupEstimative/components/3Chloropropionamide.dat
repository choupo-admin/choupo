/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloropropionamide  (C3H6ClNO, CAS 5875-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloropropionamide;
formula     C3H6ClNO;
CAS         5875-24-1;
InChIKey    JQDXZJYAUSVHDH-UHFFFAOYSA-N;
MW          107.537;      // g/mol [origin=calculated method=formula-sum]
Tc          636.80;      // K   [origin=predictive method=joback]
Pc          49.384;      // bar [origin=predictive method=joback]
omega       0.5170;      // -   [origin=predictive method=lee-kesler]
Tb          432.07;      // K   [origin=predictive method=joback]
HvapTb      44044.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.902 0.3295 -0.0001845 3.546e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2Cl; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Cl; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropanamide" "3-chloropropanamide" "propanamide, 3-chloro-" "3-chloro-propionamide" "jqdxzjyausvhdh-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -199780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100020.0
    phase     gas;
}
