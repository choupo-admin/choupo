/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl formate  (C3H6O2, CAS 109-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C3H6O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethylFormate;
formula     C3H6O2;
CAS         109-94-4;
InChIKey    WBJINCZRORDGAQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          74.079;      // g/mol [origin=calculated method=formula-sum]
Tc          397.98;      // K   [origin=predictive method=joback]
Pc          44.802;      // bar [origin=predictive method=joback]
omega       0.1181;      // -   [origin=predictive method=lee-kesler]
Tb          244.66;      // K   [origin=predictive method=joback]
HvapTb      19899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.339 0.29692 -0.0002924 1.212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl methanoate" "areginal" "formic acid, ethyl ester" "ethyl formic ester" "aethylformiat" "ethylformiaat" "formic ether" "formic acid ethyl ester" "ethylformiat" "mrowczan etylu" "carboxylic acid oxaethane" "ethylformiaat [dutch]" );
gibbsFormation
{
    dHf_298   -28800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18340.0
    phase     gas;
}
