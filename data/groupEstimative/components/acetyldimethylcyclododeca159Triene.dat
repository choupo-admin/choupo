/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetyldimethylcyclododeca-1,5,9-triene  (C16H24O, CAS 71735-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetyldimethylcyclododeca159Triene;
formula     C16H24O;
CAS         71735-77-8;
InChIKey    SDHZNJNHVOMINO-JLXXAHACSA-N;
MW          232.367;      // g/mol [origin=calculated method=formula-sum]
Tc          909.32;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.5796;      // -   [origin=predictive method=lee-kesler]
Tb          672.16;      // K   [origin=predictive method=joback]
HvapTb      61617.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.69 1.27336 -0.00045826 -3.684e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group CH=C; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(1z,5z,7r,9e)-7,9-dimethylcyclododeca-1,5,9-trien-1-yl]ethanone" "ethanone, 1-(dimethyl-1,5,9(or 2,6,10)-cyclododecatrien-1-yl)-" );
standardThermochemistry
{
    dHf_298   -318390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     770.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22610.0
}
