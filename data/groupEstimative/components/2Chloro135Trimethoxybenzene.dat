/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1,3,5-trimethoxybenzene  (C9H11ClO3, CAS 67827-56-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro135Trimethoxybenzene;
formula     C9H11ClO3;
CAS         67827-56-9;
InChIKey    RLLPSYLJYVMSBI-UHFFFAOYSA-N;
MW          202.634;      // g/mol [origin=calculated method=formula-sum]
Tc          762.88;      // K   [origin=predictive method=joback]
Pc          28.173;      // bar [origin=predictive method=joback]
omega       0.6298;      // -   [origin=predictive method=lee-kesler]
Tb          551.83;      // K   [origin=predictive method=joback]
HvapTb      51505.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.09 0.41866 1.672e-05 -1.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group CH3O; count 3; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1,3,5-trimethoxy-benzene" "chlorophloroglucinol trimethyl ether" "benzene, 2-chloro-1,3,5-trimethoxy-" );
gibbsFormation
{
    dHf_298   -439370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-218510.0
    phase     gas;
}
