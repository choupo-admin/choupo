/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,1-trichloro-4-methyl-4-pentene  (C6H9Cl3, CAS 61446-86-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        111Trichloro4Methyl4Pentene;
formula     C6H9Cl3;
CAS         61446-86-4;
InChIKey    VZHCRXGQIJPHGI-UHFFFAOYSA-N;
MW          187.488;      // g/mol [origin=calculated method=formula-sum]
Tc          650.40;      // K   [origin=predictive method=joback]
Pc          29.569;      // bar [origin=predictive method=joback]
omega       0.3314;      // -   [origin=predictive method=lee-kesler]
Tb          442.50;      // K   [origin=predictive method=joback]
HvapTb      40219.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.952 0.69992 -0.0005608 1.783e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CCl3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5,5-tris(chloranyl)-2-methyl-pent-1-ene" "5,5,5-trichloro-2-methylpent-1-ene" "1-pentene, 5,5,5-trichloro-2-methyl-" "5,5,5-trichloro-2-methyl-pent-1-ene" );
standardThermochemistry
{
    dHf_298   -107500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45980.0
}
