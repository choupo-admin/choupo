/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-pentylphenol  (C11H16O, CAS 14938-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Pentylphenol;
formula     C11H16O;
CAS         14938-35-3;
InChIKey    ZNPSUQQXTRRSBM-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          773.32;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.6692;      // -   [origin=predictive method=lee-kesler]
Tb          558.58;      // K   [origin=predictive method=joback]
HvapTb      55370.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.936 1.12452 -0.00086216 2.783e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-n-pentylphenol" "phenol, 4-pentyl-" "4-amylphenol" "phenol, p-pentyl-" "p-amylphenol" "4-pentyl-phenol" "4-n-amylphenol" "p-pentylphenol" "amyl p-hydroxybenzene" "phenol,p-pentyl- (6ci,7ci,8ci);4-amylphenol;4-n-amylphenol;4-n-pentylphenol;amyl p-hydroxybenzene;p-amylphenol;p-hydroxy-n-pentylbenzene;p-pentylphenol;" );
standardThermochemistry
{
    dHf_298   -211150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-470.0
}
