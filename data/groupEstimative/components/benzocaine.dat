/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzocaine  (C9H11NO2, CAS 94-09-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzocaine;
formula     C9H11NO2;
CAS         94-09-7;
InChIKey    BLFLLBZGZJTVJG-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          791.94;      // K   [origin=predictive method=joback]
Pc          34.440;      // bar [origin=predictive method=joback]
omega       0.6733;      // -   [origin=predictive method=lee-kesler]
Tb          567.93;      // K   [origin=predictive method=joback]
HvapTb      56614.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.001 0.72752 -0.00037876 5.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-azanylbenzoate" "ethyl 4-aminobenzoate" "ethyl aminobenzoate" "ethyl p-aminobenzoate" "americaine" "anaesthesin" "4-aminobenzoic acid ethyl ester" "amben ethyl ester" "anesthesin" "dermoplast" "ethoform" "hurricaine" );
standardThermochemistry
{
    dHf_298   -287520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116240.0
}
