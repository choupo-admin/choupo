/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-piperidinepropanol, 2-methyl-  (C9H19NO, CAS 94-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Piperidinepropanol2Methyl;
formula     C9H19NO;
CAS         94-88-2;
InChIKey    JNSUUJLFWBSBME-UHFFFAOYSA-N;
MW          157.257;      // g/mol [origin=calculated method=formula-sum]
Tc          705.53;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.8782;      // -   [origin=predictive method=lee-kesler]
Tb          525.42;      // K   [origin=predictive method=joback]
HvapTb      54607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.177 1.14842 -0.0007362 1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylpiperidin-1-yl)propan-1-ol" "3-(.alpha.-methylpiperidino)propanol" "3-(2-methyl-piperidin-1-yl)-propan-1-ol" );
standardThermochemistry
{
    dHf_298   -253310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35410.0
}
