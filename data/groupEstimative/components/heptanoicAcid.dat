/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptanoic acid  (C7H14O2, CAS 111-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptanoicAcid;
formula     C7H14O2;
CAS         111-14-8;
InChIKey    MNWFXJYAOYHMED-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          692.25;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       0.7352;      // -   [origin=predictive method=lee-kesler]
Tb          505.27;      // K   [origin=predictive method=joback]
HvapTb      48340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.125 0.71962 -0.0004296 1.001e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-heptanoic acid" "enanthylic acid" "oenanthic acid" "n-heptoic acid" "n-heptylic acid" "heptylic acid" "heptoic acid" "oenanthylic acid" "1-hexanecarboxylic acid" "hexacid c-7" "heptanoic acid (natural)" "enanthylate" );
standardThermochemistry
{
    dHf_298   -538080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-335850.0
}
