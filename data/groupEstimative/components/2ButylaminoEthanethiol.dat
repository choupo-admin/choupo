/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(butylamino)ethanethiol  (C6H15NS, CAS 5842-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ButylaminoEthanethiol;
formula     C6H15NS;
CAS         5842-00-2;
InChIKey    OUMFAUYLXGTBCX-UHFFFAOYSA-N;
MW          133.253;      // g/mol [origin=calculated method=formula-sum]
Tc          642.43;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.5272;      // -   [origin=predictive method=lee-kesler]
Tb          449.91;      // K   [origin=predictive method=joback]
HvapTb      42123.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.115 0.67732 -0.0003736 7.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2NH; count 1; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group NH; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanethiol, 2-(butylamino)-" "(butylamino)ethanethiol" "2-n-butylaminoethanethiol" "butyl(2-sulfanylethyl)amine" "ethanethiol,2-(butylamino)-" );
standardThermochemistry
{
    dHf_298   -75220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118420.0
}
