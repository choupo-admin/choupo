/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-ethoxyethyl)pyridine  (C9H13NO, CAS 28672-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22EthoxyethylPyridine;
formula     C9H13NO;
CAS         28672-54-0;
InChIKey    BVFWKBCHXXZOJJ-UHFFFAOYSA-N;
MW          151.209;      // g/mol [origin=calculated method=formula-sum]
Tc          724.43;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.5126;      // -   [origin=predictive method=lee-kesler]
Tb          508.32;      // K   [origin=predictive method=joback]
HvapTb      46524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.637 0.75048 -0.00039526 6.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2O; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine,2-(2-ethoxyethyl)-" );
gibbsFormation
{
    dHf_298   -91990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109360.0
    phase     gas;
}
