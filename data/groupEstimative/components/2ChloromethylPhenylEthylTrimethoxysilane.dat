/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-((chloromethyl)phenyl)ethyl)trimethoxysilane  (C12H19ClO3Si, CAS 42861-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H19ClO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2ChloromethylPhenylEthylTrimethoxysilane;
formula     C12H19ClO3Si;
CAS         42861-95-0;
InChIKey    UFTVYYXWUBLQLZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          274.816;      // g/mol [origin=calculated method=formula-sum]
Tc          817.43;      // K   [origin=predictive method=joback]
Pc          19.544;      // bar [origin=predictive method=joback]
omega       0.6635;      // -   [origin=predictive method=lee-kesler]
Tb          611.91;      // K   [origin=predictive method=joback]
HvapTb      57153.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (102.583 0.61646 0.00013424 -2.404e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH3O; count 3; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(chloromethyl)phenyl]ethyl-trimethoxy-silane" "silane, (2-(2-(chloromethyl)phenyl)ethyl)trimethoxy-" "silane, [2-[2-(chloromethyl)phenyl]ethyl]trimethoxy-" "2-[2-(chloromethyl)phenyl]ethyl-trimethoxysilane" "(2-(2-(chloromethyl)phenyl)ethyl)trimethoxysilane" );
gibbsFormation
{
    dHf_298   -589970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     704.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-278750.0
    phase     gas;
}
