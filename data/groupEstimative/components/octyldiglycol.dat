/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyldiglycol  (C12H26O3, CAS 19327-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octyldiglycol;
formula     C12H26O3;
CAS         19327-37-8;
InChIKey    NDSYZZUVPRGESW-UHFFFAOYSA-N;
MW          218.337;      // g/mol [origin=calculated method=formula-sum]
Tc          770.27;      // K   [origin=predictive method=joback]
Pc          18.708;      // bar [origin=predictive method=joback]
omega       1.1594;      // -   [origin=predictive method=lee-kesler]
Tb          611.18;      // K   [origin=predictive method=joback]
HvapTb      63805.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.271 1.05142 -0.0004374 3.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-octoxyethoxy)ethanol" "2-(2-octyloxyethoxy)ethanol" "c8e2" "diethylene glycol monooctyl ether" );
standardThermochemistry
{
    dHf_298   -707680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-296660.0
}
