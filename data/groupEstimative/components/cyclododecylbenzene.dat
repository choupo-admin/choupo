/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclododecylbenzene  (C18H28, CAS 15971-88-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclododecylbenzene;
formula     C18H28;
CAS         15971-88-7;
InChIKey    NKFNKCQNUBQGQP-UHFFFAOYSA-N;
MW          244.422;      // g/mol [origin=calculated method=formula-sum]
Tc          944.06;      // K   [origin=predictive method=joback]
Pc          19.579;      // bar [origin=predictive method=joback]
omega       0.4520;      // -   [origin=predictive method=lee-kesler]
Tb          683.29;      // K   [origin=predictive method=joback]
HvapTb      59399.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.71 1.6994 -0.0007892 5.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylcyclododecane" );
standardThermochemistry
{
    dHf_298   -160960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     839.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164940.0
}
