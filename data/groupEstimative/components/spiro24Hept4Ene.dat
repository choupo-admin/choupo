/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro(2,4)hept-4-ene  (C7H10, CAS 52708-23-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro24Hept4Ene;
formula     C7H10;
CAS         52708-23-3;
InChIKey    IAQUBQHHIIUMIT-UHFFFAOYSA-N;
MW          94.157;      // g/mol [origin=calculated method=formula-sum]
Tc          597.33;      // K   [origin=predictive method=joback]
Pc          44.983;      // bar [origin=predictive method=joback]
omega       0.2364;      // -   [origin=predictive method=lee-kesler]
Tb          381.58;      // K   [origin=predictive method=joback]
HvapTb      30624.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.23 1.2234 -0.00132628 5.712e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[2.4]hept-6-ene" "spiro[2,4]hept-4-ene" "spiro[2.4]hept-4-ene" );
gibbsFormation
{
    dHf_298   44990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     342.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149640.0
    phase     gas;
}
