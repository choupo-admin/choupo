/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2'-diallylbisphenol a  (C21H24O2, CAS 1745-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DiallylbisphenolA;
formula     C21H24O2;
CAS         1745-89-7;
InChIKey    WOCGGVRGNIEDSZ-UHFFFAOYSA-N;
MW          308.421;      // g/mol [origin=calculated method=formula-sum]
Tc          1139.86;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       1.1148;      // -   [origin=predictive method=lee-kesler]
Tb          894.77;      // K   [origin=predictive method=joback]
HvapTb      91608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.708 2.11704 -0.00177724 6.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 2; } { group ACH; count 6; } { group AC; count 2; } { group ACCH2; count 2; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(4-oxidanyl-3-prop-2-enyl-phenyl)propan-2-yl]-2-prop-2-enyl-phenol" "allyl bisphenol a" "phenol, 4,4'-(1-methylethylidene)bis[2-(2-propenyl)-" "phenol, 4,4'-(1-methylethylidene)bis(2-(2-propenyl)-" "phenol, 4,4'-(1-methylethylidene)bis(2-(2-propen-1-yl)-" "phenol, 4,4'-(1-methylethylidene)bis[2-(2-propen-1-yl)-" "4-[1-(4-hydroxy-3-prop-2-enylphenyl)-isopropyl]-2-prop-2-enylphenol" "diallyl bisphenol a" "4,4'-isopropylidenebis(2-allylphenol)" "2,2-bis(4-hydroxy-3-allylphenyl)propane" "4,4'-(propane-2,2-diyl)bis(2-allylphenol)" "2,2 inverted exclamation marka-diallylbisphenol a" );
standardThermochemistry
{
    dHf_298   -139160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=200780.0
}
