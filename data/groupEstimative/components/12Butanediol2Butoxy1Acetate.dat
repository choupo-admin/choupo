/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-butanediol, 2-butoxy-, 1-acetate  (C10H20O4, CAS 68214-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Butanediol2Butoxy1Acetate;
formula     C10H20O4;
CAS         68214-09-5;
InChIKey    WDPBWUHDTQEFIQ-UHFFFAOYSA-N;
MW          204.266;      // g/mol [origin=calculated method=formula-sum]
Tc          769.81;      // K   [origin=predictive method=joback]
Pc          23.136;      // bar [origin=predictive method=joback]
omega       1.0866;      // -   [origin=predictive method=lee-kesler]
Tb          597.99;      // K   [origin=predictive method=joback]
HvapTb      63054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.525 0.99566 -0.0005168 7.76e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group OH; count 1; } { group CH3COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-butoxy-2-oxidanyl-butyl) ethanoate" "2-butoxy-2-hydroxybutyl acetate" "(2-butoxy-2-hydroxybutyl) acetate" "acetic acid 2-butoxy-2-hydroxybutyl ester" "acetic acid, (2-hydroxy-2-butoxybutyl) ester" );
gibbsFormation
{
    dHf_298   -860210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-516030.0
    phase     gas;
}
