/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecamethylcyclohexasiloxane  (C12H36O6Si6, CAS 540-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H36O6Si6 (delta Si+6; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dodecamethylcyclohexasiloxane;
formula     C12H36O6Si6;
CAS         540-97-6;
InChIKey    IUMSDRXLFWAGNT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          444.924;      // g/mol [origin=calculated method=formula-sum]
Tc          888.89;      // K   [origin=predictive method=joback]
Pc          11.842;      // bar [origin=predictive method=joback]
omega       0.4004;      // -   [origin=predictive method=lee-kesler]
Tb          668.48;      // K   [origin=predictive method=joback]
HvapTb      71868.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (269.27 0.03744 0.0018068 -1.186e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group SiO; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group O_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6,8,8,10,10,12,12-dodecamethyl-1,3,5,7,9,11-hexaoxa-2,4,6,8,10,12-hexasilacyclododecane" "cyclohexasiloxane, dodecamethyl-" "cyclohexasiloxane, 2,2,4,4,6,6,8,8,10,10,12,12-dodecamethyl-" "dodecamethyl-cyclohexasiloxane" "iumsdrxlfwagnt-uhfffaoysa-" "cyclohexasiloxane,2,2,4,4,6,6,8,8,10,10,12,12-dodecamethyl-" "2,2,4,4,6,6,8,8,10,10,12,12-dodecamethyl-1,3,5,7,9,11-hexaoxa-2,4,6,8,10,12-hexa" "cyclohexasiloxane,dodecamethyl- (6ci,7ci,8ci,9ci);dc 246;dc 246 fluid;dodecamethylcyclohexasiloxane;dodecamethylhexacyclosiloxane;dow corning 246;dow corning 246 fluid;" );
standardThermochemistry
{
    dHf_298   -1678070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1086.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1062960.0
}
