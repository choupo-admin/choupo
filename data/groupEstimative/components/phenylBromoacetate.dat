/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenyl bromoacetate  (C8H7BrO2, CAS 620-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylBromoacetate;
formula     C8H7BrO2;
CAS         620-72-4;
InChIKey    UEWYUCGVQMZMGY-UHFFFAOYSA-N;
MW          215.046;      // g/mol [origin=calculated method=formula-sum]
Tc          766.30;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.5682;      // -   [origin=predictive method=lee-kesler]
Tb          533.70;      // K   [origin=predictive method=joback]
HvapTb      49520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.689 0.6683 -0.0004194 8.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenyl 2-bromanylethanoate" "phenyl 2-bromoacetate" "bromoacetic acid, phenyl ester" "bromoacetic acid phenyl ester" "2-bromoacetic acid phenyl ester" "acetic acid, bromo-, phenyl ester" "h286" "aceticacid, bromo-, phenyl ester (6ci,7ci,8ci,9ci);alpha-phenyl bromoacetate;phenyl a-bromoacetate;bromoacetic acidphenyl ester;" );
gibbsFormation
{
    dHf_298   -262870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-167160.0
    phase     gas;
}
