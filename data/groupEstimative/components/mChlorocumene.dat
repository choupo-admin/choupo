/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-chlorocumene  (C9H11Cl, CAS 7073-93-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mChlorocumene;
formula     C9H11Cl;
CAS         7073-93-0;
InChIKey    MCGSDKVOKTWDRB-UHFFFAOYSA-N;
MW          154.637;      // g/mol [origin=calculated method=formula-sum]
Tc          694.40;      // K   [origin=predictive method=joback]
Pc          31.036;      // bar [origin=predictive method=joback]
omega       0.3664;      // -   [origin=predictive method=lee-kesler]
Tb          474.17;      // K   [origin=predictive method=joback]
HvapTb      42563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.69 0.73314 -0.00045356 1.05e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 4; } { group ACCH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-propan-2-yl-benzene" "1-chloro-3-isopropylbenzene" "benzene, 1-chloro-3-(1-methylethyl)-" "1-chloro-3-propan-2-ylbenzene" "benzene,1-chloro-3-(1-methylethyl)-" "cumene,m-chloro- (6ci,7ci,8ci); 1-chloro-3-isopropylbenzene;2-(m-chlorophenyl)propane; 3-chloroisopropylbenzene; m-chlorocumene;m-chloroisopropylbenzene; m-isopropylchlorobenzene" );
standardThermochemistry
{
    dHf_298   -25050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=113310.0
}
