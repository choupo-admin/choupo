/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-acenaphthenone  (C12H8O, CAS 2235-15-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acenaphthenone;
formula     C12H8O;
CAS         2235-15-6;
InChIKey    JBXIOAKUBCTDES-UHFFFAOYSA-N;
MW          168.195;      // g/mol [origin=calculated method=formula-sum]
Tc          860.52;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.5809;      // -   [origin=predictive method=lee-kesler]
Tb          604.74;      // K   [origin=predictive method=joback]
HvapTb      51843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.4 0.9609 -0.00074084 2.328e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-acenaphthylen-1-one" "acenaphthenone" "1(2h)-acenaphthylenone" "7-acenaphthenone" "2-acenaphthenone" "1,2-dihydroacenaphthylen-1-one" "acenaphthylen-1(2h)-one" "acenaphthen-1-one" "1-ketoacenaphthalene" "1(2h)-acenaphthylenone (9ci)" );
gibbsFormation
{
    dHf_298   75250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     249.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=207930.0
    phase     gas;
}
