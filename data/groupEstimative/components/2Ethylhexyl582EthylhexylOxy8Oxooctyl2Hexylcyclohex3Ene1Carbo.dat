/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl 5-{8-[(2-ethylhexyl)oxy]-8-oxooctyl}-2-hexylcyclohex-3-ene-1-carboxylate  (C37H68O4, CAS 67953-37-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethylhexyl582EthylhexylOxy8Oxooctyl2Hexylcyclohex3Ene1Carbo;
formula     C37H68O4;
CAS         67953-37-1;
InChIKey    TTYSEKJESAIMLF-UHFFFAOYSA-N;
MW          576.947;      // g/mol [origin=calculated method=formula-sum]
Tc          1504.35;      // K   [origin=predictive method=joback]
Pc          4.790;      // bar [origin=predictive method=joback]
omega       0.0067;      // -   [origin=predictive method=lee-kesler]
Tb          1171.09;      // K   [origin=predictive method=joback]
HvapTb      112097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.238 3.4342 -0.00176368 2.713e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 22; } { group CH; count 5; } { group CH=CH; count 1; } { group CH2COO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 22; } { group CH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl 5-[8-(2-ethylhexoxy)-8-oxidanylidene-octyl]-2-hexyl-cyclohex-3-ene-1-carboxylate" "2-cyclohexene-1-octanoic acid, 5-(((2-ethylhexyl)oxy)carbonyl)-4-hexyl-, 2-ethylhexyl ester" "2-ethylhexyl 5-(((2-ethylhexyl)oxy)carbonyl)-4-hexyl-2-cyclohexene-1-octanoate" "2-ethylhexyl 5-[[(2-ethylhexyl)oxy]carbonyl]-4-hexyl-2-cyclohexene-1-octanoate" "2-cyclohexene-1-octanoic acid, 5-[[(2-ethylhexyl)oxy]carbonyl]-4-hexyl-, 2-ethylhexyl ester" "5-carboxy-4-hexyl-2-cyclohexene-1-octanoic acid, bis(2-ethylhexyl) ester" "2-ethylhexyl 5-[8-(2-ethylhexoxy)-8-oxooctyl]-2-hexylcyclohex-3-ene-1-carboxylate" );
gibbsFormation
{
    dHf_298   -1380710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1528.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-325970.0
    phase     gas;
}
