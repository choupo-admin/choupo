/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dimethylcyclopropane  (C5H10, CAS 2511-95-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dimethylcyclopropane;
formula     C5H10;
CAS         2511-95-7;
InChIKey    VKJLDXGFBJBTRQ-UHFFFAOYSA-N;
MW          70.135;      // g/mol [origin=calculated method=formula-sum]
Tc          493.48;      // K   [origin=predictive method=joback]
Pc          39.014;      // bar [origin=predictive method=joback]
omega       0.2011;      // -   [origin=predictive method=lee-kesler]
Tb          316.07;      // K   [origin=predictive method=joback]
HvapTb      26328.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.96 0.60324 -0.000413 1.194e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopropane, 1,2-dimethyl-" "trans-1,2-dimethylcyclopropane" "cyclopropane, 1,2-dimethyl-, cis-" "cyclopropane, 1,2-dimethyl-, trans-" "cis-1,2-dimethylcyclopropane" "cyclopropane, 1,2-dimethyl" "cyclopropane,1,2-dimethyl-" "agn-pc-00jz03" );
standardThermochemistry
{
    dHf_298   -94070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     218.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=44260.0
}
