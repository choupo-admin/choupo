/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-pentylbenz(a)anthracene  (C23H22, CAS 63018-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8PentylbenzAAnthracene;
formula     C23H22;
CAS         63018-99-5;
InChIKey    YRGQCRCSPPKSOL-UHFFFAOYSA-N;
MW          298.429;      // g/mol [origin=calculated method=formula-sum]
Tc          1062.65;      // K   [origin=predictive method=joback]
Pc          17.289;      // bar [origin=predictive method=joback]
omega       0.8732;      // -   [origin=predictive method=lee-kesler]
Tb          824.40;      // K   [origin=predictive method=joback]
HvapTb      75974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.356 1.92032 -0.00146764 4.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group ACH; count 11; } { group AC; count 6; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH_ring; count 11; } { group dC_ring; count 7; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-pentylbenzo[a]anthracene" "5-n-amyl-1:2-benzanthracene" "benz(a)anthracene, 8-pentyl-" );
standardThermochemistry
{
    dHf_298   257280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     600.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=546250.0
}
