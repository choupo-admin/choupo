/*--------------------------------*- Choupo -*-----------------------*\
  Component: vetivert acetate  (C17H26O2, CAS 62563-80-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vetivertAcetate;
formula     C17H26O2;
CAS         62563-80-8;
InChIKey    UAVFEMBKDRODDE-UHFFFAOYSA-N;
MW          262.393;      // g/mol [origin=calculated method=formula-sum]
Tc          892.00;      // K   [origin=predictive method=joback]
Pc          16.051;      // bar [origin=predictive method=joback]
omega       0.6636;      // -   [origin=predictive method=lee-kesler]
Tb          678.66;      // K   [origin=predictive method=joback]
HvapTb      62560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.76 1.5814 -0.00084144 1.386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 4; } { group CH=C; count 1; } { group CH3COO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4,8-dimethyl-2-propan-2-ylidene-3,3a,4,5,6,8a-hexahydro-1h-azulen-6-yl) ethanoate" "vetiveryl acetate" "vetiver acetate" "vetiverol, acetate" "vetiver acetate, java" "vetiveryl acetate (vetiveria zizanioides (l.) nash)" "2-isopropylidene-4,8-dimethyl-1,2,3,3a,4,5,6,8a-octahydro-6-azulenyl acetate" "6-azulenol, 1,2,3,3a,4,5,6,8a-octahydro-4,8-dimethyl-2-(1-methylethylidene)-, 6-acetate" "6-azulenol, 1,2,3,3a,4,5,6,8a-octahydro-4,8-dimethyl-2-(1-methylethylidene)-, acetate" "(4,8-dimethyl-2-propan-2-ylidene-3,3a,4,5,6,8a-hexahydro-1h-azulen-6-yl) acetate" "1,2,3,3a,4,5,6,8a-octahydro-2-isopropylidene-4,8-dimethylazulen-6-yl acetate" "6-azulenol, 1,2,3,3a,4,5,6,8a-octahydro-2-isopropylidene-4,8-dimethyl-, acetate" );
standardThermochemistry
{
    dHf_298   -518660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103190.0
}
