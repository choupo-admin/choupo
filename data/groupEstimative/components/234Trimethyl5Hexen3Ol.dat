/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-trimethyl-5-hexen-3-ol  (C9H18O, CAS 28638-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Trimethyl5Hexen3Ol;
formula     C9H18O;
CAS         28638-29-1;
InChIKey    MXUVULIBGSLKGS-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          668.23;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.7079;      // -   [origin=predictive method=lee-kesler]
Tb          490.27;      // K   [origin=predictive method=joback]
HvapTb      49565.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.83 1.01048 -0.0006973 1.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4-trimethylhex-5-en-3-ol" "5-hexen-3-ol,2,3,4-trimethyl-" );
standardThermochemistry
{
    dHf_298   -275200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-26120.0
}
