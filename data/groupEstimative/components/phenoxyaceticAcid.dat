/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenoxyacetic acid  (C8H8O3, CAS 122-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenoxyaceticAcid;
formula     C8H8O3;
CAS         122-59-8;
InChIKey    LCPDWSOZIOUXRV-UHFFFAOYSA-N;
MW          152.149;      // g/mol [origin=calculated method=formula-sum]
Tc          802.61;      // K   [origin=predictive method=joback]
Pc          39.906;      // bar [origin=predictive method=joback]
omega       0.7633;      // -   [origin=predictive method=lee-kesler]
Tb          577.25;      // K   [origin=predictive method=joback]
HvapTb      55252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.189 0.6725 -0.0004042 8.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenoxyethanoic acid" "acetic acid, phenoxy-" "phenoxyethanoic acid" "phenoxyacetate" "2-phenoxyacetic acid" "glycolic acid phenyl ether" "glycol acid phenyl ether" "phenoxy acetic acid" "phenoxyessigsaeure" "glycolic acid, phenyl ether" "o-phenylglycolic acid" "phenylglycolic acid, o-" );
standardThermochemistry
{
    dHf_298   -454410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-320020.0
}
