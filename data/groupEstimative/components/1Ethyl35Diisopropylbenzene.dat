/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-3,5-diisopropylbenzene  (C14H22, CAS 15181-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl35Diisopropylbenzene;
formula     C14H22;
CAS         15181-13-2;
InChIKey    HWWKORYFZUHZKW-UHFFFAOYSA-N;
MW          190.33;      // g/mol [origin=calculated method=formula-sum]
Tc          760.09;      // K   [origin=predictive method=joback]
Pc          19.841;      // bar [origin=predictive method=joback]
omega       0.5168;      // -   [origin=predictive method=lee-kesler]
Tb          555.68;      // K   [origin=predictive method=joback]
HvapTb      49582.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.509 1.1478 -0.00064132 1.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-3,5-di(propan-2-yl)benzene" "benzene, 1,3-diisopropyl-5-ethyl-" "benzene, 1-ethyl-3,5-bis(1-methylethyl)-" "benzene, 1-ethyl-3,5-diisopropyl-" "benzene,1-ethyl-3,5-bis(1-methylethyl)-" "benzene,1-ethyl-3,5-diisopropyl- (6ci,8ci)" );
gibbsFormation
{
    dHf_298   -129260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     563.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155270.0
    phase     gas;
}
