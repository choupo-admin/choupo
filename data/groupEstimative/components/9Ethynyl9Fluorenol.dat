/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-ethynyl-9-fluorenol  (C15H10O, CAS 13461-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Ethynyl9Fluorenol;
formula     C15H10O;
CAS         13461-74-0;
InChIKey    MMZVVJGCZZAWBN-UHFFFAOYSA-N;
MW          206.244;      // g/mol [origin=calculated method=formula-sum]
Tc          927.88;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.9269;      // -   [origin=predictive method=lee-kesler]
Tb          686.86;      // K   [origin=predictive method=joback]
HvapTb      69815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.88 1.5541 -0.00159245 6.5379e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group C_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-ethynylfluoren-9-ol" "9-ethynyl-9h-fluoren-9-ol" "9-ethynyl-9-hydroxyfluorene" "9h-fluoren-9-ol,9-ethynyl-" "mmzvvjgczzawbn-uhfffaoysa-" "(9-hydroxy-9-fluorenyl)acetylene" "fluoren-9-ol,9-ethynyl- (6ci,7ci,8ci); 9-ethynyl-9-hydroxyfluorene;9-ethynyl-9h-fluoren-9-ol; 9-ethynylfluoren-9-ol; 9-hydroxy-9-ethynylfluorene" );
gibbsFormation
{
    dHf_298   337220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=446690.0
    phase     gas;
}
