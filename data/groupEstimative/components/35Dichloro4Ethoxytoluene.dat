/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-dichloro-4-ethoxytoluene  (C9H10Cl2O, CAS 67828-41-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35Dichloro4Ethoxytoluene;
formula     C9H10Cl2O;
CAS         67828-41-5;
InChIKey    RJPFGDAVUZZKMS-UHFFFAOYSA-N;
MW          205.078;      // g/mol [origin=calculated method=formula-sum]
Tc          764.82;      // K   [origin=predictive method=joback]
Pc          28.084;      // bar [origin=predictive method=joback]
omega       0.5323;      // -   [origin=predictive method=lee-kesler]
Tb          544.42;      // K   [origin=predictive method=joback]
HvapTb      51070.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.981 0.55184 -0.00022568 9.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2O; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(chloranyl)-2-ethoxy-5-methyl-benzene" "benzene, 1,3-dichloro-2-ethoxy-5-methyl-" "1,3-dichloro-2-ethoxy-5-methylbenzene" );
standardThermochemistry
{
    dHf_298   -190670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-20440.0
}
