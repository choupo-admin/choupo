/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-anisoyl-gaba  (C12H15NO4, CAS 72432-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nAnisoylGaba;
formula     C12H15NO4;
CAS         72432-14-5;
InChIKey    DZTVZKSCFQIBMV-UHFFFAOYSA-N;
MW          237.255;      // g/mol [origin=calculated method=formula-sum]
Tc          994.78;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       1.2790;      // -   [origin=predictive method=lee-kesler]
Tb          777.79;      // K   [origin=predictive method=joback]
HvapTb      78000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.623 1.04122 -0.00058466 1.0686e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(4-methoxyphenyl)carbonylamino]butanoic acid" "4-[(4-methoxybenzoyl)amino]butanoic acid" "4-((4-methoxybenzoyl)amino)butanoic acid" "butanoic acid, 4-((4-methoxybenzoyl)amino)-" "4-(4-methoxy-benzoylamino)-butyric acid" "4-{[(4-methoxyphenyl)carbonyl]amino}butanoic acid" );
gibbsFormation
{
    dHf_298   -607550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     642.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-335500.0
    phase     gas;
}
