/*--------------------------------*- Choupo -*-----------------------*\
  Component: tartaramide  (C4H8N2O4, CAS 6051-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tartaramide;
formula     C4H8N2O4;
CAS         6051-30-5;
InChIKey    GRMNJXQBRPJVQV-UHFFFAOYSA-N;
MW          148.118;      // g/mol [origin=calculated method=formula-sum]
Tc          926.02;      // K   [origin=predictive method=joback]
Pc          74.061;      // bar [origin=predictive method=joback]
omega       2.0584;      // -   [origin=predictive method=lee-kesler]
Tb          727.40;      // K   [origin=predictive method=joback]
HvapTb      91854.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.17 0.5314 -0.0003104 5.892e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group OH; count 2; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 2; } { group OH; count 2; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(oxidanyl)butanediamide" "tartramide" "2,3-dihydroxysuccinamide" "2,3-dihydroxybutanediamide" "dl-tartaramide" "(2r,3r)-2,3-dihydroxybutanediamide" "butanediamide, 2,3-dihydroxy-, (r,r)-(+)-" );
standardThermochemistry
{
    dHf_298   -598490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-420660.0
}
