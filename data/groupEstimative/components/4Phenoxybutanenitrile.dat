/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenoxybutanenitrile  (C10H11NO, CAS 2243-43-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenoxybutanenitrile;
formula     C10H11NO;
CAS         2243-43-8;
InChIKey    ZOLWCAUQCGRDGA-UHFFFAOYSA-N;
MW          161.204;      // g/mol [origin=calculated method=formula-sum]
Tc          800.16;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.6357;      // -   [origin=predictive method=lee-kesler]
Tb          579.58;      // K   [origin=predictive method=joback]
HvapTb      53018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.393 0.7465 -0.0004094 7.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenoxybutyronitrile" "butanenitrile,4-phenoxy-" );
gibbsFormation
{
    dHf_298   19460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173910.0
    phase     gas;
}
