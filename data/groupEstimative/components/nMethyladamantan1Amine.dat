/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyladamantan-1-amine  (C11H19N, CAS 3717-38-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyladamantan1Amine;
formula     C11H19N;
CAS         3717-38-2;
InChIKey    NZOLSRPWNVZXTK-UHFFFAOYSA-N;
MW          165.28;      // g/mol [origin=calculated method=formula-sum]
Tc          742.37;      // K   [origin=predictive method=joback]
Pc          29.730;      // bar [origin=predictive method=joback]
omega       0.4861;      // -   [origin=predictive method=lee-kesler]
Tb          521.51;      // K   [origin=predictive method=joback]
HvapTb      44967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-208.22 1.83352 -0.0017146 6.68e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(methylamino)adamantane" "n-methyladamantine" "n-methyladamantanamine" "1-n-methylaminoadamantane" "n-methyl-1-adamantanamine" "n-methyl-1-adamantylamine" "1-adamantanamine, n-methyl-" "n-methyltricyclo(3.3.1.1(sup 3,7))decan-1-amine" "n-1-adamantyl-n-methylamine" "ambap3717-38-2" "n-(1-adamantyl)-n-methylamine;" "n-methyltricyclo[3.3.1.1~3,7~]decan-1-amine" );
gibbsFormation
{
    dHf_298   -9760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288080.0
    phase     gas;
}
