/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,8-dimethyl-3-nonen-5-ol  (C11H22O, CAS 74499-57-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        48Dimethyl3Nonen5Ol;
formula     C11H22O;
CAS         74499-57-3;
InChIKey    SOVKQCIFRGQAEQ-CDCCAWJDSA-N;
MW          170.296;      // g/mol [origin=calculated method=formula-sum]
Tc          719.04;      // K   [origin=predictive method=joback]
Pc          22.483;      // bar [origin=predictive method=joback]
omega       0.8673;      // -   [origin=predictive method=lee-kesler]
Tb          546.62;      // K   [origin=predictive method=joback]
HvapTb      56021.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.057 1.11458 -0.0006975 1.777e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 2; } { group dCH; count 1; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e,5r)-4,8-dimethylnon-3-en-5-ol" );
standardThermochemistry
{
    dHf_298   -325730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28290.0
}
