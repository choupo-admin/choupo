/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,4,6-tetramethylpiperidine  (C9H19N, CAS 6292-82-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2246Tetramethylpiperidine;
formula     C9H19N;
CAS         6292-82-6;
InChIKey    NGBCPOUXXDBLMT-UHFFFAOYSA-N;
MW          141.258;      // g/mol [origin=calculated method=formula-sum]
Tc          679.18;      // K   [origin=predictive method=joback]
Pc          28.505;      // bar [origin=predictive method=joback]
omega       0.3398;      // -   [origin=predictive method=lee-kesler]
Tb          464.52;      // K   [origin=predictive method=joback]
HvapTb      41046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.09 1.20648 -0.000908 3.142e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidine,2,2,4,6-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -162400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116150.0
}
