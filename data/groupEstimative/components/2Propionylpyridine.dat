/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propionylpyridine  (C8H9NO, CAS 3238-55-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propionylpyridine;
formula     C8H9NO;
CAS         3238-55-9;
InChIKey    ZHAZHKPVEROFLH-UHFFFAOYSA-N;
MW          135.166;      // g/mol [origin=calculated method=formula-sum]
Tc          748.96;      // K   [origin=predictive method=joback]
Pc          39.506;      // bar [origin=predictive method=joback]
omega       0.5144;      // -   [origin=predictive method=lee-kesler]
Tb          516.89;      // K   [origin=predictive method=joback]
HvapTb      48634.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.869 0.69068 -0.00043316 1.0226e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2CO; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group CdO; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-pyridin-2-ylpropan-1-one" "1-(pyridin-2-yl)propan-1-one" "2-pyridyl ethyl ketone" "1-propanone, 1-(2-pyridyl)-" "1-propanone, 1-(2-pyridinyl)-" "1-(2-pyridinyl)-1-propanone" );
standardThermochemistry
{
    dHf_298   -51710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77020.0
}
