/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(allyloxymethyl)butyl methacrylate  (C16H26O4, CAS 20241-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisAllyloxymethylButylMethacrylate;
formula     C16H26O4;
CAS         20241-99-0;
InChIKey    DDZCXKJJOQTKQP-UHFFFAOYSA-N;
MW          282.38;      // g/mol [origin=calculated method=formula-sum]
Tc          836.00;      // K   [origin=predictive method=joback]
Pc          14.424;      // bar [origin=predictive method=joback]
omega       0.8416;      // -   [origin=predictive method=lee-kesler]
Tb          655.43;      // K   [origin=predictive method=joback]
HvapTb      60211.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.616 1.40834 -0.0007728 1.384e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 2; } { group CH2=C; count 1; } { group CH2O; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group O; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(prop-2-enoxymethyl)butyl 2-methylprop-2-enoate" "2,2-bis[(allyloxy)methyl]butyl methacrylate" "trimethylolpropane diallyl ether monomethacrylate" "2-propenoic acid, 2-methyl-, 2,2-bis((2-propen-1-yloxy)methyl)butyl ester" "2-propenoic acid, 2-methyl-, 2,2-bis[(2-propen-1-yloxy)methyl]butyl ester" "trimethylolpropane, diallyl ether, monomethacrylate" "2-propenoic acid, 2-methyl-, 2,2-bis((2-propenyloxy)methyl)butyl ester" "2-propenoic acid,2-methyl-, 2,2-bis[(2-propen-1-yloxy)methyl]butyl ester" "2-propenoicacid, 2-methyl-, 2,2-bis[(2-propenyloxy)methyl]butyl ester (9ci); methacrylicacid, 2,2-bis[(allyloxy)methyl]butyl ester (8ci);2,2-bis(allyloxymethyl)-1-butyl methacrylate" );
standardThermochemistry
{
    dHf_298   -597540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     796.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-178720.0
}
