/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,12-dihydrotetracene  (C18H14, CAS 959-02-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        512Dihydrotetracene;
formula     C18H14;
CAS         959-02-4;
InChIKey    WSXODQAKLVVOCS-UHFFFAOYSA-N;
MW          230.31;      // g/mol [origin=calculated method=formula-sum]
Tc          966.99;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.6556;      // -   [origin=predictive method=lee-kesler]
Tb          705.86;      // K   [origin=predictive method=joback]
HvapTb      63890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.89 1.5608 -0.0012754 4.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 4; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,12-dihydronaphthacene" "naphthacene, 5,12-dihydro-" "5,12-dihydro-tetracene" "naphthacene,12-dihydro-" "naphthacene, 5,12-dihydro- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   314170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=483820.0
    phase     gas;
}
