/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2h-pyran, tetrahydro-2-(10-undecynyloxy)-  (C16H28O2, CAS 51953-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2hPyranTetrahydro210Undecynyloxy;
formula     C16H28O2;
CAS         51953-88-9;
InChIKey    BIMMDYMGQQYTCS-UHFFFAOYSA-N;
MW          252.398;      // g/mol [origin=calculated method=formula-sum]
Tc          817.26;      // K   [origin=predictive method=joback]
Pc          16.977;      // bar [origin=predictive method=joback]
omega       0.7354;      // -   [origin=predictive method=lee-kesler]
Tb          624.72;      // K   [origin=predictive method=joback]
HvapTb      58417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.661 1.4858 -0.00079863 1.4369e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group CH; count 1; } { group CH2O; count 1; } { group FCH2O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-undec-10-ynoxyoxane" "2-(undec-10-yn-1-yloxy)tetrahydro-2h-pyran" "2h-pyran, tetrahydro-2-(10-undecyn-1-yloxy)-" "2h-pyran, 2-((10-undecynyl)oxy)tetrahydro-" );
gibbsFormation
{
    dHf_298   -291570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     678.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140240.0
    phase     gas;
}
