/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-8-methyl-8-azabicyclo[3.2.1]octane  (C8H14BrN, CAS 27809-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo8Methyl8Azabicyclo321Octane;
formula     C8H14BrN;
CAS         27809-79-6;
InChIKey    ASXOSTZMQJKYRY-UHFFFAOYSA-N;
MW          204.111;      // g/mol [origin=calculated method=formula-sum]
Tc          691.38;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.4469;      // -   [origin=predictive method=lee-kesler]
Tb          474.32;      // K   [origin=predictive method=joback]
HvapTb      41569.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.55 1.19162 -0.000934 2.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH3N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group Br; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-8-methyl-8-azabicyclo[3.2.1]octane" "8-azabicyclo(3.2.1)octane, 3-bromo-8-methyl-, endo-" "8-azabicyclo(3.2.1)octane, 3-bromo-8-methyl-, exo-" "8-azabicyclo[3.2.1]octane,3-bromo-8-methyl-endo-" "8-azabicyclo[3.2.1]octane,3-bromo-8-methyl-exo-" "(1r,5s)-3-bromo-8-methyl-8-azabicyclo[3.2.1]octane" );
standardThermochemistry
{
    dHf_298   4510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243270.0
}
