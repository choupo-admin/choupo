/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylsilatrane  (C12H17NO3Si, CAS 2097-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H17NO3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        phenylsilatrane;
formula     C12H17NO3Si;
CAS         2097-19-0;
InChIKey    IJOIPPSHQCEBDH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          251.357;      // g/mol [origin=calculated method=formula-sum]
Tc          884.19;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.5996;      // -   [origin=predictive method=lee-kesler]
Tb          631.16;      // K   [origin=predictive method=joback]
HvapTb      61409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.56 1.2996 -0.0007283 1.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 3; } { group CH2N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-phenyl-4,6,11-trioxa-1-aza-5-silabicyclo[3.3.3]undecane" "1-phenylsilatrane" "silatrane, phenyl-" "1-fenylosilatranu [polish]" "2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane, 1-phenyl-" "phenyl-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "1-phenyl-2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, phenyl-" "2,8,9-trioxa-5-aza-1-silabicyclo(3.3.3)undecane, 1-phenyl-" "fenylsilatran" "1-phenyl-2,8,9-trioxa-5-aza-1-silabicyclo[3.3.3]undecane" "1-fenylosilatranu" );
gibbsFormation
{
    dHf_298   -326770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10850.0
    phase     gas;
}
