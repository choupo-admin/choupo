/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,2-dimethyl-3-phenylpropanoate  (C12H16O2, CAS 14248-22-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl22Dimethyl3Phenylpropanoate;
formula     C12H16O2;
CAS         14248-22-7;
InChIKey    JWHXQYRCZPZNCW-UHFFFAOYSA-N;
MW          192.258;      // g/mol [origin=calculated method=formula-sum]
Tc          772.03;      // K   [origin=predictive method=joback]
Pc          24.629;      // bar [origin=predictive method=joback]
omega       0.5350;      // -   [origin=predictive method=lee-kesler]
Tb          555.83;      // K   [origin=predictive method=joback]
HvapTb      50693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.989 1.13596 -0.0007374 1.719e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2-dimethyl-3-phenyl-propanoate" );
gibbsFormation
{
    dHf_298   -380510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144960.0
    phase     gas;
}
