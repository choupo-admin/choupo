/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyclopentylmethanediamine  (C6H14N2, CAS 63302-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyclopentylmethanediamine;
formula     C6H14N2;
CAS         63302-04-5;
InChIKey    QLNNMIUPRPKARZ-UHFFFAOYSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          689.27;      // K   [origin=predictive method=joback]
Pc          41.947;      // bar [origin=predictive method=joback]
omega       0.5298;      // -   [origin=predictive method=lee-kesler]
Tb          474.86;      // K   [origin=predictive method=joback]
HvapTb      46284.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.769 0.8436 -0.000522 1.212e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH2; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-cyclopentylmethanediamine" "methanediamine, n-cyclopentyl-" "aminomethyl cyclopentylamine" "n-cyclopentylmethylenediamine" );
gibbsFormation
{
    dHf_298   -19430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192030.0
    phase     gas;
}
