/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromomethylbiphenyl  (C13H11Br, CAS 2567-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromomethylbiphenyl;
formula     C13H11Br;
CAS         2567-29-5;
InChIKey    HZQLUIZFUXNFHK-UHFFFAOYSA-N;
MW          247.135;      // g/mol [origin=calculated method=formula-sum]
Tc          880.97;      // K   [origin=predictive method=joback]
Pc          32.653;      // bar [origin=predictive method=joback]
omega       0.5511;      // -   [origin=predictive method=lee-kesler]
Tb          621.54;      // K   [origin=predictive method=joback]
HvapTb      56181.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.249 1.0597 -0.00075016 2.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(bromomethyl)-4-phenyl-benzene" "4-biphenylmethylbromide" "4-(bromomethyl)biphenyl" "4-bromomethyl biphenyl" "4-phenylbenzyl bromide" "1-(bromomethyl)-4-phenylbenzene" "4-(bromomethyl)-biphenyl" "biphenyl, 4-(bromomethyl)-" "hzqluizfuxnfhk-uhfffaoysa-" "4-biphenylylmethyl bromide" "4-(bromomethyl)-1,1'-biphenyl" );
gibbsFormation
{
    dHf_298   176270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288090.0
    phase     gas;
}
