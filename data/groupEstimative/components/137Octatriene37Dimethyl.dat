/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,7-octatriene, 3,7-dimethyl-  (C10H16, CAS 502-99-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        137Octatriene37Dimethyl;
formula     C10H16;
CAS         502-99-8;
InChIKey    XJPBRODHZKDRCB-CSKARUKUSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          609.87;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.3648;      // -   [origin=predictive method=lee-kesler]
Tb          425.68;      // K   [origin=predictive method=joback]
HvapTb      36632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.748 0.93364 -0.0006544 1.936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3e)-3,7-dimethylocta-1,3,7-triene" "alpha-ocimene" "alpha-trans-ocimene" "trans-alpha-ocimene" "(e)-alpha-ocimene" "1,3,7-octatriene, 3,7-dimethyl-, (3e)-" "alpha-ocimene, (e)-" "ocimene trans-alpha-form" "alpha-ocimene, (3e)-" "ocimene trans-alpha-form [mi]" "3,7-dimethylocta-1,3,7-triene" "3,7-dimethyl-1,3e,7-octatriene" );
gibbsFormation
{
    dHf_298   98770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=272120.0
    phase     gas;
}
