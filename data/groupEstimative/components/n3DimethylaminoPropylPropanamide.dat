/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-[3-(dimethylamino)propyl]propanamide  (C8H18N2O, CAS 53201-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n3DimethylaminoPropylPropanamide;
formula     C8H18N2O;
CAS         53201-66-4;
InChIKey    LPRTUAMEQDRMAZ-UHFFFAOYSA-N;
MW          158.245;      // g/mol [origin=calculated method=formula-sum]
Tc          676.04;      // K   [origin=predictive method=joback]
Pc          27.354;      // bar [origin=predictive method=joback]
omega       0.7527;      // -   [origin=predictive method=lee-kesler]
Tb          499.12;      // K   [origin=predictive method=joback]
HvapTb      48627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.926 0.93596 -0.0005539 1.2286e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH3N; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CdO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(3-(dimethylamino)propyl)propanamide" "propanamide, n-(3-(dimethylamino)propyl)-" "propanamide, n-[3-(dimethylamino)propyl]-" "n-(3-(dimethylamino)propyl)propionamide" "amides, c19-23, n-(3-(dimethylamino)propyl)" );
gibbsFormation
{
    dHf_298   -200030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87730.0
    phase     gas;
}
