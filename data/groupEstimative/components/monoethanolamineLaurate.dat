/*--------------------------------*- Choupo -*-----------------------*\
  Component: monoethanolamine laurate  (C14H31NO3, CAS 16830-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        monoethanolamineLaurate;
formula     C14H31NO3;
CAS         16830-40-3;
InChIKey    XVJSTCOYGMBYPE-UHFFFAOYSA-N;
MW          261.406;      // g/mol [origin=calculated method=formula-sum]
Tc          1023.19;      // K   [origin=predictive method=joback]
Pc          17.189;      // bar [origin=predictive method=joback]
omega       1.3899;      // -   [origin=predictive method=lee-kesler]
Tb          831.54;      // K   [origin=predictive method=joback]
HvapTb      91536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.362 1.27432 -0.0004694 -1.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylethanol;dodecanoic acid" "ethanolamine; lauric acid" "lauric acid, compound with 2-aminoethanol (1:1)" "dodecanoic acid, compd. with 2-aminoethanol (1:1)" "ethanolamine monolaurate" "lauric acid, ethanolamine salt" "2-aminoethanol; dodecanoic acid" "dodecanoic acid - 2-aminoethanol (1:1)" "dodecanoic acid compd. with 2-aminoethanol (1:1)" );
gibbsFormation
{
    dHf_298   -912620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     964.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-452040.0
    phase     gas;
}
