/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraethylene glycol  (C8H18O5, CAS 112-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetraethyleneGlycol;
formula     C8H18O5;
CAS         112-60-7;
InChIKey    UWHCKJMYHZGTIT-UHFFFAOYSA-N;
MW          194.227;      // g/mol [origin=calculated method=formula-sum]
Tc          793.62;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       1.5999;      // -   [origin=predictive method=lee-kesler]
Tb          634.26;      // K   [origin=predictive method=joback]
HvapTb      73990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (82.698 0.6422 -0.0001392 -6.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2O; count 1; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group OH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-(2-hydroxyethyloxy)ethoxy]ethoxy]ethanol" "tetraglycol" "carbitol, diethyl" "hi-dry" "ethanol, 2,2'-[oxybis(2,1-ethanediyloxy)]bis-" "3,6,9-trioxaundecane-1,11-diol" "2,2'-[oxybis(ethane-2,1-diyloxy)]diethanol" "bis[2-(2-hydroxyethoxy)ethyl] ether" "2,2'-((oxybis(ethane-2,1-diyl))bis(oxy))diethanol" "2,2'-(oxybis(ethyleneoxy)) diethanol" "tetra(ethylene glycol)" "ethanol, 2,2'-(oxybis(ethyleneoxy))di-" );
standardThermochemistry
{
    dHf_298   -909570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-572160.0
}
