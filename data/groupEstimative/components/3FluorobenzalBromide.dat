/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-fluorobenzal bromide  (C7H5Br2F, CAS 455-34-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3FluorobenzalBromide;
formula     C7H5Br2F;
CAS         455-34-5;
InChIKey    ZIAHZFPHXNQNQN-UHFFFAOYSA-N;
MW          267.923;      // g/mol [origin=calculated method=formula-sum]
Tc          766.10;      // K   [origin=predictive method=joback]
Pc          46.089;      // bar [origin=predictive method=joback]
omega       0.5167;      // -   [origin=predictive method=lee-kesler]
Tb          522.57;      // K   [origin=predictive method=joback]
HvapTb      45779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.29 0.6245 -0.00048356 1.46e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH; count 1; } { group Br; count 2; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[bis(bromanyl)methyl]-3-fluoranyl-benzene" "1-(dibromomethyl)-3-fluorobenzene" "fluorobenzene, meta-(dibromomethyl)-" "benzene,1-(dibromomethyl)-3-fluoro-" "o150" "toluene, a,a-dibromo-m-fluoro- (7ci,8ci);1-(dibromomethyl)-3-fluorobenzene; 3-fluorobenzal bromide" );
gibbsFormation
{
    dHf_298   -111480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57770.0
    phase     gas;
}
