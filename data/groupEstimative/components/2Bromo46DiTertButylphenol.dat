/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4,6-di-tert-butylphenol  (C14H21BrO, CAS 20834-61-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo46DiTertButylphenol;
formula     C14H21BrO;
CAS         20834-61-1;
InChIKey    DIWZVAHZEOFSLS-UHFFFAOYSA-N;
MW          285.225;      // g/mol [origin=calculated method=formula-sum]
Tc          939.26;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       0.7363;      // -   [origin=predictive method=lee-kesler]
Tb          696.88;      // K   [origin=predictive method=joback]
HvapTb      67215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.82 1.58042 -0.00130628 4.421e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4,6-ditert-butyl-phenol" "2,4-bis(tert-butyl)-6-bromophenol" "2-bromo-4,6-di-t-butylphenol" "2-bromo-4,6-ditert-butylphenol" "phenol,2-bromo-4,6-bis(1,1-dimethylethyl)-" "phenol,2-bromo-4,6-di-tert-butyl- (8ci); 2-bromo-4,6-di-tert-butylphenol" );
gibbsFormation
{
    dHf_298   -287180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=25530.0
    phase     gas;
}
