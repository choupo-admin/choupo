/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3a,4,7,7a-tetrahydro-4,7-methano-1h-indene, ethenylacetate copolymer  (C14H18O2, CAS 53640-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3a477aTetrahydro47Methano1hIndeneEthenylacetateCopolymer;
formula     C14H18O2;
CAS         53640-62-3;
InChIKey    QDMMYVPMSGJYOW-UHFFFAOYSA-N;
MW          218.296;      // g/mol [origin=calculated method=formula-sum]
Tc          814.11;      // K   [origin=predictive method=joback]
Pc          21.653;      // bar [origin=predictive method=joback]
omega       0.5539;      // -   [origin=predictive method=lee-kesler]
Tb          594.36;      // K   [origin=predictive method=joback]
HvapTb      53975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.95 1.35742 -0.00078466 1.467e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CH2=CH; count 1; } { group CH=CH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "acetic acid ethenyl ester, polymer with 3a,4,7,7a-tetrahydro-4,7-methano-1h-indene" );
standardThermochemistry
{
    dHf_298   -328300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37930.0
}
