/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentabromo-beta-(tetrabromophenoxy)phenetole  (C14H5Br9O2, CAS 68299-26-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentabromoBetaTetrabromophenoxyPhenetole;
formula     C14H5Br9O2;
CAS         68299-26-3;
InChIKey    GFUDECFZQUUKCZ-UHFFFAOYSA-N;
MW          924.328;      // g/mol [origin=calculated method=formula-sum]
Tc          1571.10;      // K   [origin=predictive method=joback]
Pc          47.694;      // bar [origin=predictive method=joback]
omega       2.0325;      // -   [origin=predictive method=lee-kesler]
Tb          1258.38;      // K   [origin=predictive method=joback]
HvapTb      120003.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (175.762 0.8579 -0.00061744 1.796e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 11; } { group CH2O; count 2; } { group Br; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 11; } { group Br; count 9; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,5-pentakis(bromanyl)-6-[2-[2,3,4,5-tetrakis(bromanyl)phenoxy]ethoxy]benzene" "benzene, pentabromo(2-(tetrabromophenoxy)ethoxy)-" "1-pentabromophenoxy-2-tetrabromophenoxyethane" "benzene, 1,2,3,4,5-pentabromo-6-(2-(tetrabromophenoxy)ethoxy)-" "benzene, 1,2,3,4,5-pentabromo-6-[2-(tetrabromophenoxy)ethoxy]-" "nonabromo-1,2-diphenoxyethane" "1,2,3,4,5-pentabromo-6-[2-(2,3,4,5-tetrabromophenoxy)ethoxy]benzene" );
standardThermochemistry
{
    dHf_298   10070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     914.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124030.0
}
