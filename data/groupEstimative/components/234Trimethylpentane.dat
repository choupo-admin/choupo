/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4-trimethylpentane  (C8H18, CAS 565-75-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        234Trimethylpentane;
formula     C8H18;
CAS         565-75-3;
InChIKey    RLPGDEORIPLBNF-UHFFFAOYSA-N;
MW          114.232;      // g/mol [origin=calculated method=formula-sum]
Tc          556.52;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.3107;      // -   [origin=predictive method=lee-kesler]
Tb          381.32;      // K   [origin=predictive method=joback]
HvapTb      32238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.43 0.7816 -0.000421 8.25e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentane, 2,3,4-trimethyl-" "pentane,3,4-trimethyl-" "2,3,4-trimethyl-pentane" "pentane,2,3,4-trimethyl-" );
gibbsFormation
{
    dHf_298   -224290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9160.0
    phase     gas;
}
