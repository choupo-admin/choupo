/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3141442  (C20H18, CAS 63041-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3141442;
formula     C20H18;
CAS         63041-92-9;
InChIKey    UYRWPIJGSRPYAP-UHFFFAOYSA-N;
MW          258.364;      // g/mol [origin=calculated method=formula-sum]
Tc          1026.39;      // K   [origin=predictive method=joback]
Pc          23.428;      // bar [origin=predictive method=joback]
omega       0.7807;      // -   [origin=predictive method=lee-kesler]
Tb          769.56;      // K   [origin=predictive method=joback]
HvapTb      69424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-152.95 1.8748 -0.00158484 5.45e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 6; } { group AC; count 4; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 6; } { group dC_ring; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1',2',3',4'-tetrahydro-4,10-ace-1,2-benzanthracene" "benz(e)aceanthrylene, 1,2,4,5,6,7-hexahydro-" "5,6,8,9,10,11-hexahydrocyclopenta[gh]tetraphene" );
standardThermochemistry
{
    dHf_298   291470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=532000.0
}
