/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5-bis(trifluoromethyl)phenylacetic acid  (C10H6F6O2, CAS 85068-33-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        35BisTrifluoromethylPhenylaceticAcid;
formula     C10H6F6O2;
CAS         85068-33-3;
InChIKey    PAWSKKHEEYTXSA-UHFFFAOYSA-N;
MW          272.144;      // g/mol [origin=calculated method=formula-sum]
Tc          788.43;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.9259;      // -   [origin=predictive method=lee-kesler]
Tb          599.71;      // K   [origin=predictive method=joback]
HvapTb      51124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.309 1.1291 -0.00093192 2.889e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group COOH; count 1; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 6; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3,5-bis(trifluoromethyl)phenyl]ethanoic acid" "2-(3,5-bis(trifluoromethyl)phenyl)acetic acid" "fxffr c1vq exfff" "mbt-paa" "2-[3,5-di(trifluoromethyl)phenyl]acetic acid" "2-[3,5-bis(trifluoromethyl)phenyl]acetic acid" "3,5-di(trifluoromethyl) phenylacetic acid" "[3,5-bis(trifluoromethyl)phenyl]acetic acid" "benzeneacetic acid, 3,5-bis(trifluoromethyl)-" "3,5-di(trifluoromethyl)phenylacetic acid" "3,5-bis(trifluoromethyl)phenylaceticacid" "3,5-bis-trifluoromethylphenylacetic acid" );
gibbsFormation
{
    dHf_298   -1580570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1380620.0
    phase     gas;
}
