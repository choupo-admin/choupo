/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexanone, 4-(p-tolyl)-,  (C13H18O, CAS 6957-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexanone4PTolyl;
formula     C13H18O;
CAS         6957-06-8;
InChIKey    BFKWOJUMLYZWEE-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          792.37;      // K   [origin=predictive method=joback]
Pc          23.136;      // bar [origin=predictive method=joback]
omega       0.6286;      // -   [origin=predictive method=lee-kesler]
Tb          582.13;      // K   [origin=predictive method=joback]
HvapTb      53828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.858 1.07836 -0.00063206 1.3456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methylphenyl)hexan-3-one" "4-(p-tolyl)-3-hexanone" );
gibbsFormation
{
    dHf_298   -204450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=30000.0
    phase     gas;
}
