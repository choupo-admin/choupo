/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-pyridineacetonitrile  (C7H6N2, CAS 6443-85-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Pyridineacetonitrile;
formula     C7H6N2;
CAS         6443-85-2;
InChIKey    OIPHWUPMXHQWLR-UHFFFAOYSA-N;
MW          118.139;      // g/mol [origin=calculated method=formula-sum]
Tc          787.70;      // K   [origin=predictive method=joback]
Pc          39.906;      // bar [origin=predictive method=joback]
omega       0.5052;      // -   [origin=predictive method=lee-kesler]
Tb          542.22;      // K   [origin=predictive method=joback]
HvapTb      50140.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.319 0.55846 -0.00036646 9.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C5H4N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-pyridin-3-ylethanenitrile" "3-pyridylacetonitrile" "3-cyanomethylpyridine" "2-(pyridin-3-yl)acetonitrile" "pyridin-3-ylacetonitrile" "pyridine-3-acetonitrile" "3-(cyanomethyl)pyridine" "2-pyridin-3-ylacetonitrile" "2-(3-pyridyl)ethanenitrile" "3-pyridinylacetonitrile" "oiphwupmxhqwlr-uhfffaoysa-" "(pyridin-3-yl)acetonitrile" );
gibbsFormation
{
    dHf_298   246390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330700.0
    phase     gas;
}
