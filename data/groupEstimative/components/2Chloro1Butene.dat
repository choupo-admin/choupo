/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-1-butene  (C4H7Cl, CAS 2211-70-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro1Butene;
formula     C4H7Cl;
CAS         2211-70-3;
InChIKey    HSEFPJMMKNHABB-UHFFFAOYSA-N;
MW          90.55;      // g/mol [origin=calculated method=formula-sum]
Tc          505.03;      // K   [origin=predictive method=joback]
Pc          39.456;      // bar [origin=predictive method=joback]
omega       0.2216;      // -   [origin=predictive method=lee-kesler]
Tb          325.11;      // K   [origin=predictive method=joback]
HvapTb      28293.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.461 0.37052 -0.0002394 6.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=C; count 1; } { group Cl_C=C_; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylbut-1-ene" "2-chlorobutene" "1-butene, 2-chloro-" "2-chlorobut-1-ene" "2-chloro-1-butene;" );
standardThermochemistry
{
    dHf_298   -25990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     336.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=50160.0
}
