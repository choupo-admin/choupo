/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-5-methoxytoluene  (C8H9BrO, CAS 27060-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo5Methoxytoluene;
formula     C8H9BrO;
CAS         27060-75-9;
InChIKey    BLZNSXFQRKVFRP-UHFFFAOYSA-N;
MW          201.063;      // g/mol [origin=calculated method=formula-sum]
Tc          736.49;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.4888;      // -   [origin=predictive method=lee-kesler]
Tb          507.86;      // K   [origin=predictive method=joback]
HvapTb      45847.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.0 0.54094 -0.00026892 3.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACCH3; count 1; } { group CH3O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-methoxy-2-methyl-benzene" "4-bromo-3-methylanisole" "1-bromo-4-methoxy-2-methylbenzene" "4-bromo-3-methyl-anisole" "benzene, 1-bromo-4-methoxy-2-methyl-" "1-brom-4-methoxy-2-methylbenzol" "blznsxfqrkvfrp-uhfffaoysa-" "b224" "1-bromo-2-methyl-4-methoxybenzene" "anisole,4-bromo-3-methyl- (6ci,8ci);1-bromo-2-methyl-4-methoxybenzene;1-bromo-4-methoxy-2-methylbenzene;2-bromo-5-methoxytoluene;3-methyl-4-bromoanisole;4-bromo-3-methylanisole;" );
gibbsFormation
{
    dHf_298   -100750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18950.0
    phase     gas;
}
