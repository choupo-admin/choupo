/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-chloro-4-chromanone  (C9H7ClO2, CAS 37674-72-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Chloro4Chromanone;
formula     C9H7ClO2;
CAS         37674-72-9;
InChIKey    LLTDYHFVIVSQPJ-UHFFFAOYSA-N;
MW          182.603;      // g/mol [origin=calculated method=formula-sum]
Tc          846.68;      // K   [origin=predictive method=joback]
Pc          38.868;      // bar [origin=predictive method=joback]
omega       0.5592;      // -   [origin=predictive method=lee-kesler]
Tb          590.04;      // K   [origin=predictive method=joback]
HvapTb      52764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.26 0.6642 -0.00035462 5.65e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group CH2CO; count 1; } { group FCH2O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-chloranyl-2,3-dihydrochromen-4-one" "6-chlorochroman-4-one" "6-chlorochromanone" "4h-1-benzopyran-4-one, 6-chloro-2,3-dihydro-" "6-chloro-2,3-dihydro-4h-chromen-4-one" "6-chloro chroman-4-one" "6-chloro-2,3-dihydrochromen-4-one" "6-chloro-2,3-dihydro-1-benzopyran-4-one" "6-chloro-2,3-dihydro-4h-1-benzopyran-4-one" "6-chloro-3,4-dihydro-2h-1-benzopyran-4-one" );
gibbsFormation
{
    dHf_298   -213960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     263.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46230.0
    phase     gas;
}
