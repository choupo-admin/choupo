/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4,5-tetra-tert-butylbenzene  (C22H38, CAS 796-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1245TetraTertButylbenzene;
formula     C22H38;
CAS         796-97-4;
InChIKey    KOOZRCVIAJVLEQ-UHFFFAOYSA-N;
MW          302.546;      // g/mol [origin=calculated method=formula-sum]
Tc          948.39;      // K   [origin=predictive method=joback]
Pc          11.352;      // bar [origin=predictive method=joback]
omega       0.5424;      // -   [origin=predictive method=lee-kesler]
Tb          731.66;      // K   [origin=predictive method=joback]
HvapTb      63644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.01 2.33984 -0.00169028 4.89e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 12; } { group C; count 4; } { group ACH; count 2; } { group AC; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 12; } { group C; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetratert-butylbenzene" "1,2,4,5-tetrakis-(1,1-dimethylethyl)benzene" );
gibbsFormation
{
    dHf_298   -330290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     732.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229240.0
    phase     gas;
}
