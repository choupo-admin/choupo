/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromobenzotrifluoride  (C7H4BrF3, CAS 401-78-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromobenzotrifluoride;
formula     C7H4BrF3;
CAS         401-78-5;
InChIKey    NNMBNYHMJRJUBC-UHFFFAOYSA-N;
MW          225.007;      // g/mol [origin=calculated method=formula-sum]
Tc          663.45;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.4375;      // -   [origin=predictive method=lee-kesler]
Tb          452.16;      // K   [origin=predictive method=joback]
HvapTb      36802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.09 0.7298 -0.00061356 1.955e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-3-(trifluoromethyl)benzene" "m-bromobenzotrifluoride" "1-bromo-3-(trifluoromethyl)benzene" "benzene, 1-bromo-3-(trifluoromethyl)-" "3-(trifluoromethyl)bromobenzene" "3-trifluoromethyl phenyl bromide" "3-brombenzotrifluorid" "3-bromo-alpha,alpha,alpha-trifluorotoluene" "3-bromobenzyltrifluoride" "3-bromotrifluoromethylbenzene" "m-(trifluoromethyl)bromobenzene" "m-bromo(trifluoromethyl)benzene" );
gibbsFormation
{
    dHf_298   -533500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-456430.0
    phase     gas;
}
