/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-triacontene  (C30H60, CAS 18435-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Triacontene;
formula     C30H60;
CAS         18435-53-5;
InChIKey    WMZHDICSCDKPFS-UHFFFAOYSA-N;
MW          420.81;      // g/mol [origin=calculated method=formula-sum]
Tc          1086.46;      // K   [origin=predictive method=joback]
Pc          6.079;      // bar [origin=predictive method=joback]
omega       0.4685;      // -   [origin=predictive method=lee-kesler]
Tb          882.68;      // K   [origin=predictive method=joback]
HvapTb      81704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.373 2.83382 -0.0016311 3.632e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 27; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 27; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "triacont-1-ene" "1-triacontene, contains c26-54 homologs" );
gibbsFormation
{
    dHf_298   -537100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1319.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=289560.0
    phase     gas;
}
