/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorbicyclen  (C9H6Cl8, CAS 2550-75-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorbicyclen;
formula     C9H6Cl8;
CAS         2550-75-6;
InChIKey    FUZORIOHZSVKAW-UHFFFAOYSA-N;
MW          397.747;      // g/mol [origin=calculated method=formula-sum]
Tc          984.68;      // K   [origin=predictive method=joback]
Pc          23.772;      // bar [origin=predictive method=joback]
omega       0.5991;      // -   [origin=predictive method=lee-kesler]
Tb          718.54;      // K   [origin=predictive method=joback]
HvapTb      67942.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.548 1.8266 -0.0023078 1.1004e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group CH2Cl; count 2; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH2; count 2; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,7,7-hexakis(chloranyl)-5,6-bis(chloromethyl)bicyclo[2.2.1]hept-2-ene" "cyclodan" "alodan" "nodon" "alodane" "cyclodane" "alodan (pesticide)" "alodan (van)" "chlorbicyclen [iso]" "bicyclo[2.2.1]hept-2-ene, 1,2,3,4,7,7-hexachloro-5,6-bis(chloromethyl)-" "1,2,3,4,7,7-hexachloro-5,6-bis(chloromethyl)-2-norbornene" "5,6-bis(chloromethyl)-1,2,3,4,7,7-hexachloro-2-norbornene" );
standardThermochemistry
{
    dHf_298   -196030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9960.0
}
