/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholesteryl cinnamate  (C36H52O2, CAS 1990-11-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholesterylCinnamate;
formula     C36H52O2;
CAS         1990-11-0;
InChIKey    FESYLMLHRKCTFF-MFLJIVHPSA-N;
MW          516.81;      // g/mol [origin=calculated method=formula-sum]
Tc          1409.18;      // K   [origin=predictive method=joback]
Pc          7.661;      // bar [origin=predictive method=joback]
omega       0.7201;      // -   [origin=predictive method=lee-kesler]
Tb          1150.38;      // K   [origin=predictive method=joback]
HvapTb      102832.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-342.537 4.2664 -0.00342944 1.1704e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 11; } { group CH; count 7; } { group C; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 2; } { group dCH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] (e)-3-phenylprop-2-enoate" "cholesterol trans-cinnamate" "cholest-5-en-3-beta-yl cinnamate" "trans-cinnamic acid cholesterol ester" "p588" "cholest-5-en-3-ol (3beta)-, 3-phenyl-2-propenoate" "cholest-5-en-3-ol (3beta)-, 3-(3-phenyl-2-propenoate)" "(1s,2r,5s,10s,11s,14r,15r)-2,15-dimethyl-14-[(2r)-6-methylheptan-2-yl]tetracyclo[8.7.0.0^{2,7}.0^{11,15}]heptadec-7-en-5-yl 3-phenylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -484290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1184.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=298340.0
}
