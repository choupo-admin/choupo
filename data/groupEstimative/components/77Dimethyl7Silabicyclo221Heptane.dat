/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,7-dimethyl-7-silabicyclo[2.2.1]heptane  (C8H16Si, CAS 69238-92-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        77Dimethyl7Silabicyclo221Heptane;
formula     C8H16Si;
CAS         69238-92-2;
InChIKey    FDVYFKSOGRCFTC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          140.301;      // g/mol [origin=calculated method=formula-sum]
Tc          597.97;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       0.2362;      // -   [origin=predictive method=lee-kesler]
Tb          397.52;      // K   [origin=predictive method=joback]
HvapTb      33522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.05 0.85944 -0.000437 6.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-silabicyclo(2.2.1)heptane, 7,7-dimethyl-" "7-silabicyclo[2.2.1]heptane, 7,7-dimethyl-" );
standardThermochemistry
{
    dHf_298   -174470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33220.0
}
