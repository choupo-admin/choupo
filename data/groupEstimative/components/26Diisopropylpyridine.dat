/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-diisopropylpyridine  (C11H17N, CAS 6832-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Diisopropylpyridine;
formula     C11H17N;
CAS         6832-21-9;
InChIKey    LFMMVPZBLJZNGE-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          757.96;      // K   [origin=predictive method=joback]
Pc          26.543;      // bar [origin=predictive method=joback]
omega       0.4681;      // -   [origin=predictive method=lee-kesler]
Tb          535.76;      // K   [origin=predictive method=joback]
HvapTb      48452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.02 0.95604 -0.00055442 1.211e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-di(propan-2-yl)pyridine" "2,6-diisopropyl-pyridine" "2,6-di-iso-propylpyridine" "pyridine, 2,6-bis(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -23080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216690.0
    phase     gas;
}
