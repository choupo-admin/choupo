/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-4-methylaniline  (C7H8FN, CAS 452-80-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro4Methylaniline;
formula     C7H8FN;
CAS         452-80-2;
InChIKey    ZQEXBVHABAJPHJ-UHFFFAOYSA-N;
MW          125.146;      // g/mol [origin=calculated method=formula-sum]
Tc          685.29;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.4710;      // -   [origin=predictive method=lee-kesler]
Tb          468.20;      // K   [origin=predictive method=joback]
HvapTb      44600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.8 0.54462 -0.00031392 6.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH3; count 1; } { group ACNH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-fluoranyl-4-methyl-aniline" "4-amino-3-fluorotoluene" "2-fluoro-p-toluidine" "2-fluoro-4-methyaniline" "p-toluidine, 2-fluoro-" "benzenamine, 2-fluoro-4-methyl-" "2-fluor-4-methylanilin" "2-fluoro-4-methyl-phenylamine" "2-fluoro-4-methylphenylamine" "2-fluoro-4-methyl aniline" "2-fluoro-4-methylbenzenamine" "tpc-i103" );
gibbsFormation
{
    dHf_298   -136540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27150.0
    phase     gas;
}
