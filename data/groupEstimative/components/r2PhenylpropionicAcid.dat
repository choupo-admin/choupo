/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-(-)-2-phenylpropionic acid  (C9H10O2, CAS 7782-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        r2PhenylpropionicAcid;
formula     C9H10O2;
CAS         7782-26-5;
InChIKey    YPGCWEMNNLXISK-SSDOTTSWSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          806.31;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.6910;      // -   [origin=predictive method=lee-kesler]
Tb          577.27;      // K   [origin=predictive method=joback]
HvapTb      54680.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.28 0.83662 -0.0005728 1.489e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-phenylpropanoic acid" "(r)-(-)-hydratropic acid" "(r)-2-phenylpropanoic acid" "(r)-2-phenyl-propionic acid" "(-)-hydratropic acid" "r-2-phenyl-proprionic acid" "(r)-2-phenylpropanic acid" "(r)-2-phenylpropionic acid" "(-)-hydratropasaeure" "(r)-hydratropic acid" "(r)-hta" "(r)-(-)-phenylpropionic acid" );
gibbsFormation
{
    dHf_298   -348110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-209040.0
    phase     gas;
}
