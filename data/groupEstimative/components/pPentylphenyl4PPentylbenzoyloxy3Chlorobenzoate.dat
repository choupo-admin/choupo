/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-pentylphenyl 4-(p-pentylbenzoyloxy)-3-chlorobenzoate  (C30H33ClO4, CAS 41161-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pPentylphenyl4PPentylbenzoyloxy3Chlorobenzoate;
formula     C30H33ClO4;
CAS         41161-54-0;
InChIKey    ANVGYLDROLBYEZ-UHFFFAOYSA-N;
MW          493.04;      // g/mol [origin=calculated method=formula-sum]
Tc          1395.54;      // K   [origin=predictive method=joback]
Pc          9.815;      // bar [origin=predictive method=joback]
omega       0.9508;      // -   [origin=predictive method=lee-kesler]
Tb          1139.83;      // K   [origin=predictive method=joback]
HvapTb      111049.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.192 2.27634 -0.00126484 2.175e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group ACH; count 11; } { group AC; count 4; } { group ACCH2; count 2; } { group ACCl; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group Cl; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-pentylphenyl) 3-chloranyl-4-(4-pentylphenyl)carbonyloxy-benzoate" "benzoic acid, 3-chloro-4-((4-pentylbenzoyl)oxy)-, 4-pentylphenyl ester" "benzoic acid, 3-chloro-4-[(4-pentylbenzoyl)oxy]-, 4-pentylphenyl ester" "(4-pentylphenyl) 3-chloro-4-(4-pentylbenzoyl)oxybenzoate" );
standardThermochemistry
{
    dHf_298   -649120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1116.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-132240.0
}
