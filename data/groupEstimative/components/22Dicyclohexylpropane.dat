/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dicyclohexylpropane  (C15H28, CAS 54934-90-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dicyclohexylpropane;
formula     C15H28;
CAS         54934-90-6;
InChIKey    CCXLOQVMDTWRSP-UHFFFAOYSA-N;
MW          208.389;      // g/mol [origin=calculated method=formula-sum]
Tc          812.34;      // K   [origin=predictive method=joback]
Pc          20.127;      // bar [origin=predictive method=joback]
omega       0.3811;      // -   [origin=predictive method=lee-kesler]
Tb          578.67;      // K   [origin=predictive method=joback]
HvapTb      48546.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.43 1.79884 -0.001126 2.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclohexylpropan-2-ylcyclohexane" "cyclohexane, 1,1'-(1-methylethylidene)bis-" );
gibbsFormation
{
    dHf_298   -253040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     640.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127160.0
    phase     gas;
}
