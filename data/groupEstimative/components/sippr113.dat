/*--------------------------------*- Choupo -*-----------------------*\
  Component: sippr 113  (C30H38O8, CAS 99814-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sippr113;
formula     C30H38O8;
CAS         99814-12-7;
InChIKey    KQASQXNTJIIRRU-OAHMOMQBSA-N;
MW          526.626;      // g/mol [origin=calculated method=formula-sum]
Tc          1593.43;      // K   [origin=predictive method=joback]
Pc          11.522;      // bar [origin=predictive method=joback]
omega       1.0831;      // -   [origin=predictive method=lee-kesler]
Tb          1300.02;      // K   [origin=predictive method=joback]
HvapTb      125732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-334.466 4.28484 -0.00416006 1.68118e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 4; } { group C; count 4; } { group CH2COO; count 2; } { group COOH; count 2; } { group CH_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group tCH; count 2; } { group tC; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 4; } { group COOH; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[(2r,3as,3bs,5as,6r,8as,8br,10as)-2,6-diethynyl-3a,5a-dimethyl-2-(4-oxidanyl-4-oxidanylidene-butanoyl)oxy-1,3,3b,4,5,7,8,8a,8b,9,10,10a-dodecahydroindeno[5,4-e]inden-6-yl]oxy]-4-oxidanylidene-butanoic acid" "2-alpha,17-alpha-diethynyl-a-nor-5-alpha-androstane-2-beta,17-beta-diol dihemisuccinate" "a-nor-5-alpha,17-alpha-pregn-20-yne-2-beta,17-diol, 2-ethynyl-, dihemisuccinate" "a-norpregn-20-yne-2,17-diol, 2-ethynyl-, bis(hydrogen butanedioate), (2-beta,5-alpha,17-alpha)" "a-norpregn-20-yne-2,17-diol, 2-ethynyl-, bis(hydrogen butanedioate), (2beta,5alpha,17alpha)-" "4-[[(2r,3as,3bs,5as,6r,8as,8br,10as)-2,6-diethynyl-2-(4-hydroxy-4-oxobutanoyl)oxy-3a,5a-dimethyl-1,3,3b,4,5,7,8,8a,8b,9,10,10a-dodecahydroindeno[5,4-e]inden-6-yl]oxy]-4-oxobutanoic acid" );
standardThermochemistry
{
    dHf_298   -1167670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1299.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-518900.0
}
