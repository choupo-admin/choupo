/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-sulfanylethyl trichloroacetate  (C4H5Cl3O2S, CAS 13306-59-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2SulfanylethylTrichloroacetate;
formula     C4H5Cl3O2S;
CAS         13306-59-7;
InChIKey    YBDZCJFRDQTUCI-UHFFFAOYSA-N;
MW          223.492;      // g/mol [origin=calculated method=formula-sum]
Tc          754.83;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       0.5002;      // -   [origin=predictive method=lee-kesler]
Tb          521.26;      // K   [origin=predictive method=joback]
HvapTb      50501.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.752 0.5025 -0.0003546 8.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CCl3; count 1; } { group CH2SH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 1; } { group Cl; count 3; } { group COO; count 1; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-sulfanylethyl 2,2,2-tris(chloranyl)ethanoate" "acetic acid, trichloro-, 2-mercaptoethyl ester" "acetic acid, 2,2,2-trichloro-, 2-mercaptoethyl ester" "2-sulfanylethyl 2,2,2-trichloroacetate" );
gibbsFormation
{
    dHf_298   -460660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-331130.0
    phase     gas;
}
