/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-undecanol, 10,11-dibromo-  (C11H22Br2O, CAS 24724-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Undecanol1011Dibromo;
formula     C11H22Br2O;
CAS         24724-18-3;
InChIKey    XYZSWTZGRJFHST-UHFFFAOYSA-N;
MW          330.104;      // g/mol [origin=calculated method=formula-sum]
Tc          859.55;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       1.2389;      // -   [origin=predictive method=lee-kesler]
Tb          675.34;      // K   [origin=predictive method=joback]
HvapTb      69241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.88 1.1651 -0.000751 1.972e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group OH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group CH; count 1; } { group Br; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10,11-bis(bromanyl)undecan-1-ol" "10,11-dibromoundecan-1-ol" "10,11-dibromoundecane-1-ol" );
standardThermochemistry
{
    dHf_298   -375220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     727.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-68880.0
}
