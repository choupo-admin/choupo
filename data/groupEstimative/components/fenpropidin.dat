/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenpropidin  (C19H31N, CAS 67306-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenpropidin;
formula     C19H31N;
CAS         67306-00-7;
InChIKey    MGNFYQILYYYUBS-UHFFFAOYSA-N;
MW          273.464;      // g/mol [origin=calculated method=formula-sum]
Tc          913.26;      // K   [origin=predictive method=joback]
Pc          16.155;      // bar [origin=predictive method=joback]
omega       0.6662;      // -   [origin=predictive method=lee-kesler]
Tb          694.70;      // K   [origin=predictive method=joback]
HvapTb      61751.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-137.258 2.08428 -0.00144436 3.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2_ring; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[3-(4-tert-butylphenyl)-2-methyl-propyl]piperidine" "fenpropidine" "patrol" "fenpropidin [bsi:iso]" "fenpropidine [iso-french]" "1-(3-(4-tert-butylphenyl)-2-methylpropyl)piperidine" "1-(3-(4-(1,1-dimethylethyl)phenyl)-2-methylpropyl)piperidine" "piperidine, 1-(3-(4-(1,1-dimethylethyl)phenyl)-2-methylpropyl)-" "1-[3-(4-tert-butylphenyl)-2-methylpropyl]piperidine" "piperidine, 1-[3-[4-(1,1-dimethylethyl)phenyl]-2-methylpropyl]-" );
standardThermochemistry
{
    dHf_298   -76110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=367320.0
}
