/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dibromofumaric acid  (C4H2Br2O4, CAS 608-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DibromofumaricAcid;
formula     C4H2Br2O4;
CAS         608-37-7;
InChIKey    PMNMPRXRQYSFRP-UHFFFAOYSA-N;
MW          273.864;      // g/mol [origin=calculated method=formula-sum]
Tc          968.73;      // K   [origin=predictive method=joback]
Pc          66.748;      // bar [origin=predictive method=joback]
omega       1.2802;      // -   [origin=predictive method=lee-kesler]
Tb          718.38;      // K   [origin=predictive method=joback]
HvapTb      71814.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.27 0.5816 -0.0005702 2.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 2; } { group Br; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dC; count 2; } { group Br; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(bromanyl)but-2-enedioic acid" "2-butenedioic acid, 2,3-dibromo-, (2z)-" "2,3-dibromobut-2-enedioic acid" "2-butenedioic acid,2,3-dibromo-, (2z)-" "2-butenedioicacid, 2,3-dibromo-, (z)-;" );
standardThermochemistry
{
    dHf_298   -676130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-613260.0
}
