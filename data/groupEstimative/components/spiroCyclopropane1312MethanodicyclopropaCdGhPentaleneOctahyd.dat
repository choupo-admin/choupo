/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro(cyclopropane-1,3'-(1,2)methanodicyclopropa(cd,gh)pentalene), octahydro-  (C11H12, CAS 65915-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiroCyclopropane1312MethanodicyclopropaCdGhPentaleneOctahyd;
formula     C11H12;
CAS         65915-88-0;
InChIKey    XRJMCRAIKHHJSF-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          652.48;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.4249;      // -   [origin=predictive method=lee-kesler]
Tb          448.06;      // K   [origin=predictive method=joback]
HvapTb      36276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-304.89 2.2338 -0.002587 1.1382e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 8; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 8; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   163770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -154.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=462320.0
}
