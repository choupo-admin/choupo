/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl neoabietate  (C21H32O2, CAS 3310-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylNeoabietate;
formula     C21H32O2;
CAS         3310-97-2;
InChIKey    XLNYKQDSHLEWFW-UYWIDEMCSA-N;
MW          316.485;      // g/mol [origin=calculated method=formula-sum]
Tc          1019.09;      // K   [origin=predictive method=joback]
Pc          14.770;      // bar [origin=predictive method=joback]
omega       0.7198;      // -   [origin=predictive method=lee-kesler]
Tb          786.34;      // K   [origin=predictive method=joback]
HvapTb      69556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-227.68 2.713 -0.00235344 8.798e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 2; } { group C; count 2; } { group CH=C; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dC; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (1r,4ar,4bs,10ar)-1,4a-dimethyl-7-propan-2-ylidene-3,4,4b,5,6,9,10,10a-octahydro-2h-phenanthrene-1-carboxylate" "neoabietic acid methyl ester" );
gibbsFormation
{
    dHf_298   -483760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     874.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-24130.0
    phase     gas;
}
