/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hept-2-ene, 2-trifluoromethyl-  (C8H9F3, CAS 130871-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept2Ene2Trifluoromethyl;
formula     C8H9F3;
CAS         130871-93-1;
InChIKey    ZCSSLICRCYXAKF-UHFFFAOYSA-N;
MW          162.154;      // g/mol [origin=calculated method=formula-sum]
Tc          584.23;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.3678;      // -   [origin=predictive method=lee-kesler]
Tb          399.11;      // K   [origin=predictive method=joback]
HvapTb      30607.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-94.11 1.1017 -0.00094664 3.207e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH=C; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group F; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(trifluoromethyl)bicyclo[2.2.1]hept-2-ene" "bicyclo(2.2.1)hept-2-ene, 2-trifluoromethyl-" "2-(trifluoromethyl)bicyclo[2.2.1]hept-2-ene" );
gibbsFormation
{
    dHf_298   -619780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-435380.0
    phase     gas;
}
