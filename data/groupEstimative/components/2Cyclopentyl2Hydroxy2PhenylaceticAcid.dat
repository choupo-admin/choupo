/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopentyl-2-hydroxy-2-phenylacetic acid  (C13H16O3, CAS 427-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopentyl2Hydroxy2PhenylaceticAcid;
formula     C13H16O3;
CAS         427-49-6;
InChIKey    WFLUEQCOAQCQLP-UHFFFAOYSA-N;
MW          220.268;      // g/mol [origin=calculated method=formula-sum]
Tc          1003.79;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       1.2321;      // -   [origin=predictive method=lee-kesler]
Tb          773.46;      // K   [origin=predictive method=joback]
HvapTb      79612.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-117.9 1.5022 -0.0011168 3.182e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-cyclopentyl-2-oxidanyl-2-phenyl-ethanoic acid" "cyclopentylphenylglycolic acid" "cyclopentyl(hydroxy)phenylacetic acid" "alpha-cyclopentylmandelic acid" "alpha-cyclopentyl-dl-mandelic acid" "cyclopentyl-hydroxy-phenyl-acetic acid" "cyclopentyl mandelic acid" "mandelic acid, alpha-cyclopentyl" "st039" "427-49-6 2-cyclopentyl-2-hydroxy-2-phenylacetic acid" "cyclopentylphenylglycolic acid; 2-cyclopentyl-2-hydroxy-2-phenylacetic acid" );
standardThermochemistry
{
    dHf_298   -525890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270350.0
}
