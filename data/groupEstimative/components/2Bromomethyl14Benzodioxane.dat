/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromomethyl-1,4-benzodioxane  (C9H9BrO2, CAS 2164-34-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromomethyl14Benzodioxane;
formula     C9H9BrO2;
CAS         2164-34-3;
InChIKey    QYLFKNVZIFTCIY-UHFFFAOYSA-N;
MW          229.073;      // g/mol [origin=calculated method=formula-sum]
Tc          816.07;      // K   [origin=predictive method=joback]
Pc          41.091;      // bar [origin=predictive method=joback]
omega       0.5785;      // -   [origin=predictive method=lee-kesler]
Tb          568.25;      // K   [origin=predictive method=joback]
HvapTb      54106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.429 0.8939 -0.00064736 1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(bromomethyl)-2,3-dihydro-1,4-benzodioxine" "2-(bromomethyl)-2,3-dihydro-1,4-benzodioxine" "2-bromomethyl-2,3-dihydro-benzo[1,4]dioxine" "2-(bromomethyl)-2,3-dihydrobenzo[b][1,4]dioxine" "qylfknvziftciy-uhfffaoysa-" "2-(bromomethyl)-2h,3h-benzo[e]1,4-dioxane" "2-(bromomethyl)-2h,3h-benzo[e]1,4-dioxin" "2-(bromomethyl)-2,3-dihydro-1,4-benzodioxin" "1,4-benzodioxin,2-(bromomethyl)-2,3-dihydro-" "2-(bromomethyl)-2,3-dihydro-1,4-benzodioxine;" );
standardThermochemistry
{
    dHf_298   -175060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     272.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=18410.0
}
