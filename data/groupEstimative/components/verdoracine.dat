/*--------------------------------*- Choupo -*-----------------------*\
  Component: verdoracine  (C13H18, CAS 14374-92-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        verdoracine;
formula     C13H18;
CAS         14374-92-6;
InChIKey    IRICXAFZMINCTB-UHFFFAOYSA-N;
MW          174.287;      // g/mol [origin=calculated method=formula-sum]
Tc          749.83;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.4671;      // -   [origin=predictive method=lee-kesler]
Tb          537.40;      // K   [origin=predictive method=joback]
HvapTb      47702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.1 1.06688 -0.00066752 1.661e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-propan-2-yl-2-prop-1-enyl-benzene" "p-cymene, 2-propenyl-" "2-prop-1-enyl-p-cymene" "2-(1-propenyl)-p-cymene" "4-isopropyl-1-methyl-2-propenylbenzene" "benzene, 1-methyl-4-(1-methylethyl)-2-(1-propenyl)-" "1-methyl-4-(1-methylethyl)-2-(1-propenyl)benzene" "benzene, 1-methyl-4-(1-methylethyl)-2-(1-propen-1-yl)-" "1-methyl-4-propan-2-yl-2-prop-1-enylbenzene" "1-methyl-4-propan-2-yl-2-[(z)-prop-1-enyl]benzene" "benzene,1-methyl-4-(1-methylethyl)-2-(1-propen-1-yl)-" "benzene,1-methyl-4-(1-methylethyl)-2-(1-propenyl)- (9ci); p-cymene, 2-propenyl-(7ci,8ci); 4-isopropyl-1-methyl-2-[1'-propenyl]benzene;4-isopropyl-1-methyl-2-propenylbenzene; pelargene; verdoracine" );
standardThermochemistry
{
    dHf_298   13880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=229510.0
}
