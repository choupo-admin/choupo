/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5-dimethyl-3-(pentylamino)cyclohex-2-enone  (C13H23NO, CAS 82663-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        55Dimethyl3PentylaminoCyclohex2Enone;
formula     C13H23NO;
CAS         82663-50-1;
InChIKey    FFEMJBAQTJMHCO-UHFFFAOYSA-N;
MW          209.333;      // g/mol [origin=calculated method=formula-sum]
Tc          852.85;      // K   [origin=predictive method=joback]
Pc          21.694;      // bar [origin=predictive method=joback]
omega       0.7301;      // -   [origin=predictive method=lee-kesler]
Tb          638.96;      // K   [origin=predictive method=joback]
HvapTb      55447.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.226 1.44526 -0.00102184 3.279e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5-dimethyl-3-(pentylamino)cyclohex-2-en-1-one" "5,5-dimethyl-3-(n-pentylamino)cyclohex-2-en-1-one" );
gibbsFormation
{
    dHf_298   -280010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64670.0
    phase     gas;
}
