/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenanthrene, tetradecahydro-  (C14H24, CAS 5743-97-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenanthreneTetradecahydro;
formula     C14H24;
CAS         5743-97-5;
InChIKey    GNMCGMFNBARSIY-UHFFFAOYSA-N;
MW          192.346;      // g/mol [origin=calculated method=formula-sum]
Tc          789.31;      // K   [origin=predictive method=joback]
Pc          23.114;      // bar [origin=predictive method=joback]
omega       0.3957;      // -   [origin=predictive method=lee-kesler]
Tb          556.82;      // K   [origin=predictive method=joback]
HvapTb      47048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-180.23 1.712 -0.001111 2.756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,4a,4b,5,6,7,8,8a,9,10,10a-tetradecahydrophenanthrene" "tetradecahydrophenanthrene" "perhydrophenanthrene" "cis,syn,cis-perhydrophenanthrene" "perhydrophenanthrene, (4a.alpha., 4b.alpha., 8a.alpha., 10a.beta.)-" "perhydrophenanthrene, (4a.alpha., 4b.alpha., 8a.beta., 10a.beta)-" "perhydrophenanthrene, (4a.alpha., 4b.beta., 8a.alpha., 10a.alpha)-" "perhydrophenanthrene, (4a.alpha., 4b.beta., 8a.alpha., 10a.beta.)-" "perhydrophenanthrene, (4a.alpha., 4b.beta., 8a.beta., 10a.alpha.)-" "trans,anti,trans-perhydrophenanthrene" );
gibbsFormation
{
    dHf_298   -165030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=181040.0
    phase     gas;
}
