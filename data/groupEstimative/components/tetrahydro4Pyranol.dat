/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydro-4-pyranol  (C5H10O2, CAS 2081-44-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydro4Pyranol;
formula     C5H10O2;
CAS         2081-44-9;
InChIKey    LMYJGUNNJIDROI-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          649.64;      // K   [origin=predictive method=joback]
Pc          50.299;      // bar [origin=predictive method=joback]
omega       0.6686;      // -   [origin=predictive method=lee-kesler]
Tb          452.68;      // K   [origin=predictive method=joback]
HvapTb      48342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.65 0.6319 -0.0003457 5.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group OH; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "oxan-4-ol" "tetrahydro-2h-pyran-4-ol" "4-hydroxytetrahydropyran" "tetrahydro-4h-pyran-4-ol" "4-hydroxytetrahydropyan" "tetrahydro-pyran-4-ol" "2h-pyran-4-ol, tetrahydro-" "bh769" "ht175" "4-hydroxytetrahydro-2h-pyran" "2h-3,4,5,6-tetrahydropyran-4-ol" "2081-44-9 tetrahydro-2h-pyran-4-ol" );
standardThermochemistry
{
    dHf_298   -376440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207270.0
}
