name        diethyl11Dioxidotetrahydrothien3YlMalonate;
formula     C11H18O6S;
CAS         4785-62-0;
InChIKey    ZRZIZOUPRLJLLK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          278.319;      // g/mol [origin=calculated method=formula-sum]
Tc          730.90;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.9629;      // -   [origin=predictive method=lee-kesler]
Tb          557.29;      // K   [origin=predictive method=joback]
HvapTb      66409.0;      // J/mol [origin=predictive method=joback]

