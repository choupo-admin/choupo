/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopentylphenol  (C11H14O, CAS 1518-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopentylphenol;
formula     C11H14O;
CAS         1518-84-9;
InChIKey    JHEKSKQMOBLXQS-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          822.33;      // K   [origin=predictive method=joback]
Pc          38.388;      // bar [origin=predictive method=joback]
omega       0.5615;      // -   [origin=predictive method=lee-kesler]
Tb          573.86;      // K   [origin=predictive method=joback]
HvapTb      55627.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.42 1.2562 -0.00098956 3.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group ACCH; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenol, 2-cyclopentyl-" "o-cyclopentylphenol" "2-cyclopentyl-phenol" );
gibbsFormation
{
    dHf_298   -150670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=36080.0
    phase     gas;
}
