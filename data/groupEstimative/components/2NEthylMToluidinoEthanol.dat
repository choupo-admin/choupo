/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(n-ethyl-m-toluidino)ethanol  (C11H17NO, CAS 91-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NEthylMToluidinoEthanol;
formula     C11H17NO;
CAS         91-88-3;
InChIKey    KRNUKKZDGDAWBF-UHFFFAOYSA-N;
MW          179.263;      // g/mol [origin=calculated method=formula-sum]
Tc          776.49;      // K   [origin=predictive method=joback]
Pc          28.658;      // bar [origin=predictive method=joback]
omega       0.9765;      // -   [origin=predictive method=lee-kesler]
Tb          587.56;      // K   [origin=predictive method=joback]
HvapTb      61740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.117 1.06834 -0.00068176 1.675e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[ethyl-(3-methylphenyl)amino]ethanol" "ethanol, 2-(n-ethyl-m-toluidino)-" "n-ethyl-n-(2-hydroxyethyl)-m-toluidine" "ethanol, 2-[ethyl(3-methylphenyl)amino]-" "n-ethyl-n-hydroxyethyl-meta-toluidine" "n-ethyl-n-2-hydroxyethyl-m-toluidine" "2-(ethyl(m-tolyl)amino)ethanol" "2-(n-ethyl-n-m-toluidino)ethanol" "n-hydroxyethyl-n-ethyl-m-toluidine" "2-[ethyl(3-methylphenyl)amino]ethanol" "ethanol, 2-(ethyl(3-methylphenyl)amino)-" "krnukkzdgdawbf-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -130010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118480.0
    phase     gas;
}
