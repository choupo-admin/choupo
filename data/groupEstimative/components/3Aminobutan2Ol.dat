/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminobutan-2-ol  (C4H11NO, CAS 42551-55-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Aminobutan2Ol;
formula     C4H11NO;
CAS         42551-55-3;
InChIKey    FERWBXLFSBWTDE-UHFFFAOYSA-N;
MW          89.138;      // g/mol [origin=calculated method=formula-sum]
Tc          638.60;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       0.7912;      // -   [origin=predictive method=lee-kesler]
Tb          454.95;      // K   [origin=predictive method=joback]
HvapTb      51042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.67 0.49154 -0.000274 5.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanylbutan-2-ol" "2-butanol, 3-amino-" "(2s,3r)-3-aminobutan-2-ol" "3-amino-butan-2-ol" "2-amino-3-butanol" "(2r,3s)-3-aminobutan-2-ol" );
standardThermochemistry
{
    dHf_298   -254890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     395.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-92450.0
}
