/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethoxy-2-butanone  (C6H12O3, CAS 5436-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethoxy2Butanone;
formula     C6H12O3;
CAS         5436-21-5;
InChIKey    PJCCSZUMZMCWSX-UHFFFAOYSA-N;
MW          132.159;      // g/mol [origin=calculated method=formula-sum]
Tc          616.61;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.5491;      // -   [origin=predictive method=lee-kesler]
Tb          435.15;      // K   [origin=predictive method=joback]
HvapTb      40128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.111 0.42536 -6.51e-05 -5.894e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH3CO; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group O; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-dimethoxybutan-2-one" "2-butanone, 4,4-dimethoxy-" "acetylacetaldehyde dimethyl acetal" "acetoacetaldehyde dimethyl acetal" "1,1-dimethoxy-3-butanone" "3-oxobutyraldehyde dimethyl acetal" "3-ketobutyraldehyde dimethyl acetal" "acetylacetaldehyddimethylacetal" "4,4-dimethoxybutanone" "3-ketobutyraldehyde dimethylacetal" "acetoacetaldehyde, 1-(dimethyl acetal)" "3-oxobutanal dimethyl acetal" );
standardThermochemistry
{
    dHf_298   -549470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-341720.0
}
