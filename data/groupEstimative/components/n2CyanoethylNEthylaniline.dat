/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-cyanoethyl)-n-ethylaniline  (C11H14N2, CAS 148-87-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2CyanoethylNEthylaniline;
formula     C11H14N2;
CAS         148-87-8;
InChIKey    WYRNRZQRKCXPLA-UHFFFAOYSA-N;
MW          174.247;      // g/mol [origin=calculated method=formula-sum]
Tc          808.55;      // K   [origin=predictive method=joback]
Pc          25.767;      // bar [origin=predictive method=joback]
omega       0.6683;      // -   [origin=predictive method=lee-kesler]
Tb          592.48;      // K   [origin=predictive method=joback]
HvapTb      54877.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.707 1.02862 -0.0006874 1.763e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[ethyl(phenyl)amino]propanenitrile" "propanenitrile, 3-(ethylphenylamino)-" "propionitrile, 3-(n-ethylanilino)-" "n-(cyanoethyl)-n-ethylaniline" "3-(n-ethylanilino)propionitrile" "3-(ethylphenylamino)propionitrile" "3-(n-ethylanilino)propiononitrile" "n-ethyl-n-(2-cyanoethyl)aniline" "3-(ethylphenylamino)propanenitrile" "aniline, n-ethyl-n-(2-cyanoethyl)-" "n-ethyl-n,beta-cyanoethylaniline" "n-(2-cyanoethyl)-2-phenylethylamine" );
standardThermochemistry
{
    dHf_298   198570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=398110.0
}
