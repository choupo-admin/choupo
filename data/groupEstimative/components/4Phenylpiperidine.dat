/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenylpiperidine  (C11H15N, CAS 771-99-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenylpiperidine;
formula     C11H15N;
CAS         771-99-3;
InChIKey    UTBULQCHEUWJNV-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          796.28;      // K   [origin=predictive method=joback]
Pc          34.079;      // bar [origin=predictive method=joback]
omega       0.4230;      // -   [origin=predictive method=lee-kesler]
Tb          546.06;      // K   [origin=predictive method=joback]
HvapTb      49543.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.7 1.0786 -0.0006262 1.219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenyl-piperidine" "4-phenyl piperidine" "piperidine, 4-phenyl-" "utbulqcheuwjnv-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   58290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     441.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266310.0
}
