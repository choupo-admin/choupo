/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3as,4s,6r,6as)-6-[(3r)-1,4-dioxaspiro[4.5]decan-3-yl]spiro[3a,4,6,6a-tetrahydrofuro[3,4-d][1,3]dioxole-2,1'-cyclohexane]-4-ol  (C18H28O6, CAS 61489-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3as4s6r6as63r14Dioxaspiro45Decan3YlSpiro3a466aTetrahydrofuro;
formula     C18H28O6;
CAS         61489-23-4;
InChIKey    DBZINKYMMNBMIR-OWYFMNJBSA-N;
MW          340.416;      // g/mol [origin=calculated method=formula-sum]
Tc          1144.01;      // K   [origin=predictive method=joback]
Pc          24.387;      // bar [origin=predictive method=joback]
omega       1.2283;      // -   [origin=predictive method=lee-kesler]
Tb          897.37;      // K   [origin=predictive method=joback]
HvapTb      92912.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-301.86 2.9413 -0.0026005 9.662e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 1; } { group C; count 2; } { group OH; count 1; } { group CH-O; count 4; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 11; } { group CH_ring; count 5; } { group C_ring; count 2; } { group OH; count 1; } { group O_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -922560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286190.0
    phase     gas;
}
