/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1-cyclohexenyl)cyclohexanone  (C12H18O, CAS 1502-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        21CyclohexenylCyclohexanone;
formula     C12H18O;
CAS         1502-22-3;
InChIKey    GVNVAWHJIKLAGL-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          840.76;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.4620;      // -   [origin=predictive method=lee-kesler]
Tb          589.89;      // K   [origin=predictive method=joback]
HvapTb      48674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.66 1.1307 -0.00052264 4.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclohexen-1-yl)cyclohexan-1-one" "chch" "cyclohexanone, 2-(1-cyclohexen-1-yl)-" "l6vtj b- al6utj" "2-(1-cyclohexen-1-yl)cyclohexan-1-one" "1,1'-bi(cyclohexan)-1-en-2-one" "2-cyclohexenylcyclohexanone" "2-(cyclohex-1-enyl)cyclohexanone" "2-(1-cyclohexen-1-yl)cyclohexanone" "2-(cyclohex-1-en-1-yl)cyclohexan-1-one" "2-cyclohex-1-enylcyclohexan-1-one" "gvnvawhjiklagl-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -253420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4510.0
    phase     gas;
}
