/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethyl-1-pentyn-3-ol  (C7H12O, CAS 1482-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethyl1Pentyn3Ol;
formula     C7H12O;
CAS         1482-15-1;
InChIKey    DZNLEQBXXLGELU-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          624.17;      // K   [origin=predictive method=joback]
Pc          37.963;      // bar [origin=predictive method=joback]
omega       0.5927;      // -   [origin=predictive method=lee-kesler]
Tb          438.39;      // K   [origin=predictive method=joback]
HvapTb      46029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.56 0.74066 -0.00055833 1.7169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethylpent-1-yn-3-ol" "1-pentyn-3-ol, 3,4-dimethyl-" "3,4-dimethyl-1-penten-3-ol" "1-pentyn-3-ol,4-dimethyl-" "dznleqbxxlgelu-uhfffaoysa-" "1-pentyn-3-ol,3,4-dimethyl-" "(1,2-dimethyl-1-hydroxypropyl)acetylene" );
standardThermochemistry
{
    dHf_298   -62170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     400.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94710.0
}
