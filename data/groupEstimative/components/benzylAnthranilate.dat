/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl anthranilate  (C14H13NO2, CAS 82185-41-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylAnthranilate;
formula     C14H13NO2;
CAS         82185-41-9;
InChIKey    ZHZPDMZPDWXVMJ-UHFFFAOYSA-N;
MW          227.263;      // g/mol [origin=calculated method=formula-sum]
Tc          956.24;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.8189;      // -   [origin=predictive method=lee-kesler]
Tb          709.01;      // K   [origin=predictive method=joback]
HvapTb      70020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.449 1.1236 -0.00068196 1.354e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) 2-azanylbenzoate" "benzyl 2-aminobenzoate" "benzoic acid, 2-amino-, phenylmethyl ester" "benzyl-anthranilate" "phenylmethyl 2-aminobenzoate" "2-aminobenzoic acid (phenylmethyl) ester" "benzoic acid, 2-amino-,phenylmethyl ester" );
gibbsFormation
{
    dHf_298   -154190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38270.0
    phase     gas;
}
