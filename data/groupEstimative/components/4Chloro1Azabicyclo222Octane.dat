/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-1-azabicyclo[2.2.2]octane  (C7H12ClN, CAS 5960-95-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro1Azabicyclo222Octane;
formula     C7H12ClN;
CAS         5960-95-2;
InChIKey    CHAXYLNTCZVHBJ-UHFFFAOYSA-N;
MW          145.63;      // g/mol [origin=calculated method=formula-sum]
Tc          651.04;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.3485;      // -   [origin=predictive method=lee-kesler]
Tb          432.29;      // K   [origin=predictive method=joback]
HvapTb      36760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-162.81 1.4101 -0.001472 6.134e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH2_ring; count 6; } { group C_ring; count 1; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-1-azabicyclo[2.2.2]octane" "1-azabicyclo[2.2.2]octane,4-chloro-" "4-chloro-1-azabicyclo(2.2.2)octane" );
gibbsFormation
{
    dHf_298   39000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218530.0
    phase     gas;
}
