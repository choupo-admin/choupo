/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclobutylamine  (C4H9N, CAS 2516-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclobutylamine;
formula     C4H9N;
CAS         2516-34-9;
InChIKey    KZZKOVLJUKWSKX-UHFFFAOYSA-N;
MW          71.123;      // g/mol [origin=calculated method=formula-sum]
Tc          582.00;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       0.3077;      // -   [origin=predictive method=lee-kesler]
Tb          374.66;      // K   [origin=predictive method=joback]
HvapTb      35224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.62 0.587 -0.000411 1.168e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclobutanamine" "aminocyclobutane" "cyclobutylammonium chloride" "cyclobutyl amine" "kzzkovljukwskx-uhfffaoysa-" "s087" "cyclobutylamine(6ci,7ci,8ci);1-aminocyclobutane;aminocyclobutane;" );
standardThermochemistry
{
    dHf_298   -25460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     293.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97900.0
}
