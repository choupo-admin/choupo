/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 4-(dimethoxymethyl)-  (C9H16O2, CAS 7560-65-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene4Dimethoxymethyl;
formula     C9H16O2;
CAS         7560-65-8;
InChIKey    KVQDLLJFLVONBT-UHFFFAOYSA-N;
MW          156.225;      // g/mol [origin=calculated method=formula-sum]
Tc          672.07;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.4326;      // -   [origin=predictive method=lee-kesler]
Tb          468.63;      // K   [origin=predictive method=joback]
HvapTb      40781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.8 0.80444 -0.00031528 -4e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dimethoxymethyl)cyclohexene" "4-(dimethoxymethyl)cyclohex-1-ene" "4-(dimethoxymethyl)-1-cyclohexene" "3-cyclohexene-1-carboxaldehyde, dimethyl acetal" "3-cyclohexene-1-carboxaldehyde,dimethyl acetal (7ci,8ci)" );
gibbsFormation
{
    dHf_298   -386710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-133130.0
    phase     gas;
}
