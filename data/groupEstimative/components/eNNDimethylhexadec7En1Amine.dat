/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-n,n-dimethylhexadec-7-en-1-amine  (C18H37N, CAS 68391-07-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eNNDimethylhexadec7En1Amine;
formula     C18H37N;
CAS         68391-07-1;
InChIKey    SERJWVUZSBJZME-VAWYXSNFSA-N;
MW          267.501;      // g/mol [origin=calculated method=formula-sum]
Tc          791.22;      // K   [origin=predictive method=joback]
Pc          11.923;      // bar [origin=predictive method=joback]
omega       0.8149;      // -   [origin=predictive method=lee-kesler]
Tb          628.04;      // K   [origin=predictive method=joback]
HvapTb      57663.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.347 1.85776 -0.0011518 2.878e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH=CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 13; } { group dCH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(c14-c18) and (c16-c18) unsaturated alkyldimethylamine" "(c14-c18) and (c16-c18)unsaturated alkyldimethylamine" "(c14-c18) and (c16-c18)unsaturated alkyl dimethylamine" );
standardThermochemistry
{
    dHf_298   -230100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     866.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291680.0
}
