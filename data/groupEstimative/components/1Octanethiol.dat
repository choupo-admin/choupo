/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octanethiol  (C8H18S, CAS 111-88-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octanethiol;
formula     C8H18S;
CAS         111-88-6;
InChIKey    KZCOBXFFBQJQHH-UHFFFAOYSA-N;
MW          146.292;      // g/mol [origin=calculated method=formula-sum]
Tc          631.09;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.4700;      // -   [origin=predictive method=lee-kesler]
Tb          445.50;      // K   [origin=predictive method=joback]
HvapTb      40139.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.507 0.79112 -0.0004338 8.96e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane-1-thiol" "n-octyl mercaptan" "1-mercaptooctane" "octyl mercaptan" "octylmercaptan" "octylthiol" "1-octylthiol" "n-octanethiol" "n-octanethiolate" "n-octylmercaptan" "mercaptan c8" "nanothinks(tm) 8" );
standardThermochemistry
{
    dHf_298   -169970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45870.0
}
