/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoquinuclidine  (C11H13N, CAS 4363-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoquinuclidine;
formula     C11H13N;
CAS         4363-25-1;
InChIKey    RNFRFPSSWGWDKI-UHFFFAOYSA-N;
MW          159.232;      // g/mol [origin=calculated method=formula-sum]
Tc          734.97;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.4839;      // -   [origin=predictive method=lee-kesler]
Tb          509.26;      // K   [origin=predictive method=joback]
HvapTb      45024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.71 1.3722 -0.00119356 4.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-1,4-ethanoquinoline, 3,4-dihydro-" );
gibbsFormation
{
    dHf_298   194320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     329.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=396610.0
    phase     gas;
}
