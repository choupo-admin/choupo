/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(diethylamino)benzoic acid  (C11H15NO2, CAS 5429-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4DiethylaminoBenzoicAcid;
formula     C11H15NO2;
CAS         5429-28-7;
InChIKey    LNYTUARMNSFFBE-UHFFFAOYSA-N;
MW          193.246;      // g/mol [origin=calculated method=formula-sum]
Tc          854.89;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.8952;      // -   [origin=predictive method=lee-kesler]
Tb          640.89;      // K   [origin=predictive method=joback]
HvapTb      62225.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.808 1.08514 -0.00072396 1.857e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-diethylaminobenzoic acid" "benzoic acid, 4-(diethylamino)-" "4-n,n-diethylaminobenzoic acid" "4-(diethylamino)benzoic" "p-(diethylamino)benzoic acid" "benzoic acid,4-(diethylamino)-" "4-(n-n-diethylamino)-benzoic acid" "l709" );
gibbsFormation
{
    dHf_298   -328050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88610.0
    phase     gas;
}
