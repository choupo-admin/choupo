/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-ethanobenzo[b]thiophene, 2,3,3a,4,7,7a-hexahydro-1,1-dioxide  (C10H14O2S, CAS 92688-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H14O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        47EthanobenzoBThiophene233a477aHexahydro11Dioxide;
formula     C10H14O2S;
CAS         92688-81-8;
InChIKey    BXEHFOFOUIKEKE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          198.28;      // g/mol [origin=calculated method=formula-sum]
Tc          613.31;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.5203;      // -   [origin=predictive method=lee-kesler]
Tb          426.38;      // K   [origin=predictive method=joback]
HvapTb      49566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.69 1.3536 -0.00104088 3.162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 4; } { group CH=CH; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-ethanobenzo(b)thiophene, 2,3,3a,4,7,7a-hexahydro-1,1-dioxide" "benzo[b]thiophene, 2,3,3a,4,7,7a-hexahydro-, 1,1-dioxide" "1,3,3a,4,7,7a-hexahydro-4,7-ethano-2-benzothiophene 2,2-dioxide" );
gibbsFormation
{
    dHf_298   -495270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-275940.0
    phase     gas;
}
