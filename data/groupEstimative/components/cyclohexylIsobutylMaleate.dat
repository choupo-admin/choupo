/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexyl isobutyl maleate  (C14H22O4, CAS 68109-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexylIsobutylMaleate;
formula     C14H22O4;
CAS         68109-99-9;
InChIKey    CNKATKALHSIDQP-UHFFFAOYSA-N;
MW          254.326;      // g/mol [origin=calculated method=formula-sum]
Tc          866.03;      // K   [origin=predictive method=joback]
Pc          19.119;      // bar [origin=predictive method=joback]
omega       0.7819;      // -   [origin=predictive method=lee-kesler]
Tb          659.63;      // K   [origin=predictive method=joback]
HvapTb      61571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.489 1.37224 -0.0007166 9.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o4-cyclohexyl o1-(2-methylpropyl) but-2-enedioate" "2-butenedioic acid (2z)-, cyclohexyl 2-methylpropyl ester" "2-butenedioic acid (2z)-, 1-cyclohexyl 4-(2-methylpropyl) ester" );
standardThermochemistry
{
    dHf_298   -800590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-451510.0
}
