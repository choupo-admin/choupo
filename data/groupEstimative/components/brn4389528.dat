\*---------------------------------------------------------------------------*/

name        brn4389528;
formula     C13H22OS;
CAS         77922-38-4;
InChIKey    CMSMZGJTFJRLFO-UHFFFAOYSA-N;
MW          226.378;      // g/mol [origin=calculated method=formula-sum]
Tc          865.57;      // K   [origin=predictive method=joback]
Pc          22.187;      // bar [origin=predictive method=joback]
omega       0.8833;      // -   [origin=predictive method=lee-kesler]
Tb          659.89;      // K   [origin=predictive method=joback]
HvapTb      67906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.683 1.22907 -0.00078166 1.9528e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group C_C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group tC; count 2; } { group OH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,6-trimethyl-1-propylsulfanyl-hept-6-en-4-yn-3-ol" "1-(propylthio)-2,3,6-trimethyl-6-hepten-4-yn-3-ol" "2,3,6-trimethyl-1-propylsulfanylhept-6-en-4-yn-3-ol" );
standardThermochemistry
{
    dHf_298   -48100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=237370.0
}
