/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-di-tert-butylbenzene  (C14H22, CAS 1014-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13DiTertButylbenzene;
formula     C14H22;
CAS         1014-60-4;
InChIKey    ILNDSSCEZZFNGE-UHFFFAOYSA-N;
MW          190.33;      // g/mol [origin=calculated method=formula-sum]
Tc          765.17;      // K   [origin=predictive method=joback]
Pc          20.512;      // bar [origin=predictive method=joback]
omega       0.3904;      // -   [origin=predictive method=lee-kesler]
Tb          545.12;      // K   [origin=predictive method=joback]
HvapTb      47104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.39 1.44712 -0.00104556 2.998e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group ACH; count 4; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-ditert-butylbenzene" "benzene, m-di-tert-butyl-" "benzene, 1,3-bis(1,1-dimethylethyl)-" "m-di-tert-butylbenzene" "1,3-ditert-butyl-benzene" "1,3-bis(tert-butyl)benzene" "benzene,3-bis(1,1-dimethylethyl)-" "benzene,1,3-bis(1,1-dimethylethyl)-" "m-di-tert-butylbenzene;1,3-di-tert-butylbenzene;2,4-dimethylisopropylbenzene;" );
gibbsFormation
{
    dHf_298   -124730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175460.0
    phase     gas;
}
