/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4-tetraiodobenzene  (C6H2I4, CAS 634-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1234Tetraiodobenzene;
formula     C6H2I4;
CAS         634-68-4;
InChIKey    BHASHBRUGOYKMC-UHFFFAOYSA-N;
MW          581.682;      // g/mol [origin=calculated method=formula-sum]
Tc          1119.13;      // K   [origin=predictive method=joback]
Pc          39.259;      // bar [origin=predictive method=joback]
omega       0.3797;      // -   [origin=predictive method=lee-kesler]
Tb          751.06;      // K   [origin=predictive method=joback]
HvapTb      70704.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.19 0.4724 -0.00045828 1.706e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group I; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group I; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrakis(iodanyl)benzene" );
gibbsFormation
{
    dHf_298   342430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=315640.0
    phase     gas;
}
