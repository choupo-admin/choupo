/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dibromophenol  (C6H4Br2O, CAS 608-33-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dibromophenol;
formula     C6H4Br2O;
CAS         608-33-3;
InChIKey    SSIZLKDLDKIHEV-UHFFFAOYSA-N;
MW          251.905;      // g/mol [origin=calculated method=formula-sum]
Tc          850.09;      // K   [origin=predictive method=joback]
Pc          70.498;      // bar [origin=predictive method=joback]
omega       0.6994;      // -   [origin=predictive method=lee-kesler]
Tb          581.48;      // K   [origin=predictive method=joback]
HvapTb      57772.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.71 0.6664 -0.00066592 2.621e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Br; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(bromanyl)phenol" "phenol, 2,6-dibromo-" "2,6-dibromo-phenol" "2,6-dibromo-pheno" "l109" );
gibbsFormation
{
    dHf_298   -66760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23560.0
    phase     gas;
}
