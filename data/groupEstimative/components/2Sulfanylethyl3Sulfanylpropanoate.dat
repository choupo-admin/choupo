/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-sulfanylethyl 3-sulfanylpropanoate  (C5H10O2S2, CAS 59970-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Sulfanylethyl3Sulfanylpropanoate;
formula     C5H10O2S2;
CAS         59970-59-1;
InChIKey    ROKHJQGWQDMQSQ-UHFFFAOYSA-N;
MW          166.253;      // g/mol [origin=calculated method=formula-sum]
Tc          719.07;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.5457;      // -   [origin=predictive method=lee-kesler]
Tb          497.94;      // K   [origin=predictive method=joback]
HvapTb      47605.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.534 0.4786 -0.0001984 2.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2COO; count 1; } { group CH2SH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group COO; count 1; } { group SH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-mercaptoethyl 3-mercaptopropionate" "propanoic acid, 3-mercapto-, 2-mercaptoethyl ester" );
standardThermochemistry
{
    dHf_298   -386850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-260370.0
}
