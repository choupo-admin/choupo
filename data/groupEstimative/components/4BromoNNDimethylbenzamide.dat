/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromo-n,n-dimethylbenzamide  (C9H10BrNO, CAS 18469-37-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromoNNDimethylbenzamide;
formula     C9H10BrNO;
CAS         18469-37-9;
InChIKey    BRRVYBRXLUEEJP-UHFFFAOYSA-N;
MW          228.089;      // g/mol [origin=calculated method=formula-sum]
Tc          800.77;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       0.6611;      // -   [origin=predictive method=lee-kesler]
Tb          569.65;      // K   [origin=predictive method=joback]
HvapTb      53790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.04 0.85454 -0.00059526 1.5896e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanyl-n,n-dimethyl-benzamide" "n,n-dimethyl p-bromobenzamide" "n,n-dimethyl 4-bromobenzamide" "n,n-dimethyl-4-bromobenzamide" "benzamide,4-bromo-n,n-dimethyl-" "benzamide, 4-bromo-n,n-dimethyl-" "bim-0012080.p001" "benzamide,p-bromo-n,n-dimethyl- (8ci); 4-bromo-n,n-dimethylbenzamide;n,n-dimethyl-4-bromobenzamide; n,n-dimethyl-p-bromobenzamide;p-bromo-n,n-dimethylbenzamide; p-bromobenzoyldimethylamide" );
gibbsFormation
{
    dHf_298   -22750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=123860.0
    phase     gas;
}
