/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl(2.2)paracyclophane  (C17H18, CAS 24262-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl22Paracyclophane;
formula     C17H18;
CAS         24262-07-5;
InChIKey    PCWILLLONPHNNY-UHFFFAOYSA-N;
MW          222.331;      // g/mol [origin=calculated method=formula-sum]
Tc          924.95;      // K   [origin=predictive method=joback]
Pc          23.912;      // bar [origin=predictive method=joback]
omega       0.5797;      // -   [origin=predictive method=lee-kesler]
Tb          672.54;      // K   [origin=predictive method=joback]
HvapTb      60368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.78 1.45032 -0.00099148 2.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group ACCH3; count 1; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 7; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl[2.2]paracyclophane" "5-methyltricyclo[8.2.2.24,7]hexadeca-1(12),4,6,10,13,15-hexaene" );
gibbsFormation
{
    dHf_298   131420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     558.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=344550.0
    phase     gas;
}
