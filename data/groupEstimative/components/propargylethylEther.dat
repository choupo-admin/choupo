/*--------------------------------*- Choupo -*-----------------------*\
  Component: propargylethyl ether  (C5H8O, CAS 628-33-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propargylethylEther;
formula     C5H8O;
CAS         628-33-1;
InChIKey    ADJMUEKUQLFLQP-UHFFFAOYSA-N;
MW          84.118;      // g/mol [origin=calculated method=formula-sum]
Tc          502.80;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.2626;      // -   [origin=predictive method=lee-kesler]
Tb          326.54;      // K   [origin=predictive method=joback]
HvapTb      28992.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (37.622 0.32172 -0.00013313 1.189e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2O; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group tCH; count 1; } { group tC; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxyprop-1-yne" );
gibbsFormation
{
    dHf_298   13150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     331.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=109290.0
    phase     gas;
}
