/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-tert-butylacetophenone  (C12H16O, CAS 943-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylacetophenone;
formula     C12H16O;
CAS         943-27-1;
InChIKey    UYFJYGWNYQCHOB-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          778.91;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       0.5114;      // -   [origin=predictive method=lee-kesler]
Tb          556.46;      // K   [origin=predictive method=joback]
HvapTb      50694.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.74 1.10328 -0.00074626 1.9506e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-tert-butylphenyl)ethanone" "4-tert-butylacetophenone" "acetophenone, 4'-tert-butyl-" "p-tert-butylacetophenone" "4-(tert-butyl)acetophenone" "1-[4-(tert-butyl)phenyl]ethan-1-one" "ethanone, 1-[4-(1,1-dimethylethyl)phenyl]-" "1-(4-tert-butyl-phenyl)-ethanone" "1-acetyl-4-(tert-butyl)benzene" "ethanone, 1-((1,1-dimethylethyl)phenyl)-" "ethanone, 1-[(1,1-dimethylethyl)phenyl]-" "ethanone, 1-(4-(1,1-dimethylethyl)phenyl)-" );
gibbsFormation
{
    dHf_298   -187280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26860.0
    phase     gas;
}
