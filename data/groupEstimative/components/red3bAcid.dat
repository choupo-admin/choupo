/*--------------------------------*- Choupo -*-----------------------*\
  Component: red 3b acid  (C9H9ClO2S, CAS 94-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        red3bAcid;
formula     C9H9ClO2S;
CAS         94-76-8;
InChIKey    GREQGIILILTWOH-UHFFFAOYSA-N;
MW          216.679;      // g/mol [origin=calculated method=formula-sum]
Tc          940.06;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.8712;      // -   [origin=predictive method=lee-kesler]
Tb          693.88;      // K   [origin=predictive method=joback]
HvapTb      67594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.491 0.71291 -0.00041572 8.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } { group ACCl; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chloranyl-2-methyl-phenyl)sulfanylethanoic acid" "(4-chloro-o-tolylmercapto)acetic acid" "chlorotolylthioglycolic acid" "((4-chloro-o-tolyl)thio)acetic acid" "4-chloro-o-tolylthioacetic acid" "4-chloro-2-methylphenylthioglycolic acid" "acetic acid, ((4-chloro-o-tolyl)thio)-" "((4-chloro-2-methylphenyl)thio)acetic acid" "(4-chloro-2-methylbenzenemercapto)acetic acid" "acetic acid, ((4-chloro-2-methylphenyl)thio)-" "acetic acid, 2-((4-chloro-2-methylphenyl)thio)-" "acetic acid, ((4-chloro-o-tolyl)thio)-, (6ci,7ci,8ci)" );
gibbsFormation
{
    dHf_298   -339640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204670.0
    phase     gas;
}
