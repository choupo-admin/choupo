/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl (r)-(+)-2-chloropropionate  (C4H7ClO2, CAS 77287-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylR2Chloropropionate;
formula     C4H7ClO2;
CAS         77287-29-7;
InChIKey    JLEJCNOTNLZCHQ-GSVOUGTGSA-N;
MW          122.548;      // g/mol [origin=calculated method=formula-sum]
Tc          574.09;      // K   [origin=predictive method=joback]
Pc          37.823;      // bar [origin=predictive method=joback]
omega       0.3777;      // -   [origin=predictive method=lee-kesler]
Tb          386.33;      // K   [origin=predictive method=joback]
HvapTb      35902.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.87 0.34174 -0.0001228 -1.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (2r)-2-chloranylpropanoate" "(r)-(+)-2-chloropropionic acid methyl ester" "(r)-2-chloropropanoic acid methyl ester" "(r)-(+)-methyl (r)-2-chloropropionate" "methyl (r)-2-chloropropionate" "methyl(r)-(+)-2-chloropropionate" "(r)-methyl 2-chloropropanoate" "methyl (2r)-2-chloropropanoate" "methyl (r)-()-2-chloropropionate" "(+)-methyl (r)-2-chloropropionate" "(r)-methyl 2-chloro-propionate" "(2r)-2-chloropropanoic acid methyl ester" );
gibbsFormation
{
    dHf_298   -464190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     386.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-341940.0
    phase     gas;
}
