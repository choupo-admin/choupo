/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2',3',4',5',6'-pentafluoroacetophenone  (C8H3F5O, CAS 652-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23456Pentafluoroacetophenone;
formula     C8H3F5O;
CAS         652-29-9;
InChIKey    FBGHCYZBCMDEOX-UHFFFAOYSA-N;
MW          210.101;      // g/mol [origin=calculated method=formula-sum]
Tc          660.70;      // K   [origin=predictive method=joback]
Pc          27.936;      // bar [origin=predictive method=joback]
omega       0.7152;      // -   [origin=predictive method=lee-kesler]
Tb          484.44;      // K   [origin=predictive method=joback]
HvapTb      41649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.02 0.41842 -0.0001707 3.96e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 1; } { group CH3CO; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dC_ring; count 6; } { group F; count 5; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2,3,4,5,6-pentakis(fluoranyl)phenyl]ethanone" "1-(pentafluorphenyl)ethanon" "pentafluoroacetophenone" "2,3,4,5,6-pentafluoroacetophenone" "1-acetyl-2,3,4,5,6-pentafluorobenzene" "1-pentafluorophenylethanone" "1-(perfluorophenyl)ethanone" "1-(perfluorophenyl)ethan-1-one" "1-(pentafluorophenyl)ethan-1-one" "1-(2,3,4,5,6-pentafluorophenyl)ethanone" "1-(2,3,4,5,6-pentafluoro-phenyl)-ethanone" );
gibbsFormation
{
    dHf_298   -1122400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1022230.0
    phase     gas;
}
