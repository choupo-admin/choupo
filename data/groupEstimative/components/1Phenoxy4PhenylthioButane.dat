/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenoxy-4-phenylthio-butane  (C16H18OS, CAS 59950-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenoxy4PhenylthioButane;
formula     C16H18OS;
CAS         59950-11-7;
InChIKey    IEFUOVNESVMIQY-UHFFFAOYSA-N;
MW          258.379;      // g/mol [origin=calculated method=formula-sum]
Tc          953.09;      // K   [origin=predictive method=joback]
Pc          22.849;      // bar [origin=predictive method=joback]
omega       0.7204;      // -   [origin=predictive method=lee-kesler]
Tb          710.24;      // K   [origin=predictive method=joback]
HvapTb      64989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.366 1.29719 -0.0007578 1.478e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenoxybutylsulfanylbenzene" "benzene,[(4-phenoxybutyl)thio]-" "benzene, ((4-phenoxybutyl)thio)-" "1-[(4-phenoxybutyl)sulfanyl]benzene" "6g-398s" );
standardThermochemistry
{
    dHf_298   9140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     639.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=236780.0
}
