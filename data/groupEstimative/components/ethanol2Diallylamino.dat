/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-(diallylamino)-  (C8H15NO, CAS 17719-79-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol2Diallylamino;
formula     C8H15NO;
CAS         17719-79-8;
InChIKey    NSXPSOZPCYEURW-UHFFFAOYSA-N;
MW          141.214;      // g/mol [origin=calculated method=formula-sum]
Tc          644.91;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.8840;      // -   [origin=predictive method=lee-kesler]
Tb          480.62;      // K   [origin=predictive method=joback]
HvapTb      50784.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.766 0.8817 -0.0006002 1.66e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 2; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(prop-2-enyl)amino]ethanol" "diallylethanolamine" "ethanol, 2-(di-2-propenylamino)-" "n,n-diallylaminoethanol" "n,n-diallylethanolamine" "2-(diallylamino)ethanol" "ethanol,2-(di-2-propen-1-ylamino)-" );
standardThermochemistry
{
    dHf_298   -42290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=166120.0
}
