/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentachlorobutane  (C4H5Cl5, CAS 77753-24-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentachlorobutane;
formula     C4H5Cl5;
CAS         77753-24-3;
InChIKey    AGCPZMJBXSCWQY-UHFFFAOYSA-N;
MW          230.334;      // g/mol [origin=calculated method=formula-sum]
Tc          695.43;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.4005;      // -   [origin=predictive method=lee-kesler]
Tb          476.95;      // K   [origin=predictive method=joback]
HvapTb      45259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.661 0.4355 -0.0003054 7.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group CHCl; count 2; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 3; } { group Cl; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,3,4-pentakis(chloranyl)butane" "pcb1" "1,1,2,3,4-pentachlorobutane" );
gibbsFormation
{
    dHf_298   -220430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-84170.0
    phase     gas;
}
