/*--------------------------------*- Choupo -*-----------------------*\
  Component: citronellyl butyrate  (C14H26O2, CAS 141-16-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        citronellylButyrate;
formula     C14H26O2;
CAS         141-16-2;
InChIKey    XQPZQXTWYZAXAK-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          758.65;      // K   [origin=predictive method=joback]
Pc          16.103;      // bar [origin=predictive method=joback]
omega       0.7264;      // -   [origin=predictive method=lee-kesler]
Tb          581.74;      // K   [origin=predictive method=joback]
HvapTb      53815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.016 1.30488 -0.0007325 1.47e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 1; } { group CH=C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethyloct-6-enyl butanoate" "rhodinyl butyrate" "citronellyl n-butyrate" "butanoic acid, 3,7-dimethyl-6-octenyl ester" "natural rhodinol, butylated" "citronellyl butanoate" "butyric acid, 3,7-dimethyl-6-octenyl ester" "2,6-dimethyl-2-octen-8-yl butyrate" "3,7-dimethyl-6-octen-1-yl butyrate" "citronellyl butyrate (natural)" "3,7-dimethyl-6-octenyl butyrate" "3,7-dimethyl-6-octenyl butanoate" );
gibbsFormation
{
    dHf_298   -547420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     732.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174140.0
    phase     gas;
}
