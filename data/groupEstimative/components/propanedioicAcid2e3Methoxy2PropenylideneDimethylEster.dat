/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanedioic acid, [(2e)-3-methoxy-2-propenylidene]-, dimethyl ester  (C9H12O5, CAS 133445-85-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanedioicAcid2e3Methoxy2PropenylideneDimethylEster;
formula     C9H12O5;
CAS         133445-85-9;
InChIKey    NOBNTZJTOBIOHL-UHFFFAOYSA-N;
MW          200.19;      // g/mol [origin=calculated method=formula-sum]
Tc          746.54;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.7330;      // -   [origin=predictive method=lee-kesler]
Tb          552.58;      // K   [origin=predictive method=joback]
HvapTb      52848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.97 0.72596 -0.0003355 2.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3O; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 3; } { group dC; count 1; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-(3-methoxyprop-2-enylidene)propanedioate" "2-(3-methoxyallylidene)malonic acid dimethyl ester" "propanedioic acid,2-(3-methoxy-2-propen-1-ylidene)-, 1,3-dimethyl ester" "propanedioicacid, (3-methoxy-2-propenylidene)-, dimethyl ester (9ci); dimethyl 3-methoxyallylidenemalonate" );
standardThermochemistry
{
    dHf_298   -771220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-548950.0
}
