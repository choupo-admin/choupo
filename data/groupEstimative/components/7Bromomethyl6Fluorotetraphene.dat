/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-(bromomethyl)-6-fluorotetraphene  (C19H12BrF, CAS 34346-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Bromomethyl6Fluorotetraphene;
formula     C19H12BrF;
CAS         34346-97-9;
InChIKey    DUVKQTYQIMYHMP-UHFFFAOYSA-N;
MW          339.207;      // g/mol [origin=calculated method=formula-sum]
Tc          1059.95;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.8992;      // -   [origin=predictive method=lee-kesler]
Tb          803.29;      // K   [origin=predictive method=joback]
HvapTb      73350.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.139 1.5308 -0.0012708 4.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 6; } { group ACCH2; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group F; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-(bromomethyl)-6-fluoranyl-benzo[a]anthracene" "7-bromomethyl-6-fluorobenz(a)anthracene" "6-fluoro-7-bromomethylbenz(a)anthracene" "benz(a)anthracene, 7-bromomethyl-6-fluoro-" "7-(bromomethyl)-6-fluorobenzo[a]anthracene" );
standardThermochemistry
{
    dHf_298   158590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=322450.0
}
