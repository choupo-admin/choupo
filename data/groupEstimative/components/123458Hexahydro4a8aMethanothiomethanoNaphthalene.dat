/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,4,5,8-hexahydro-4a,8a-(methanothiomethano)naphthalene  (C12H18S, CAS 17853-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123458Hexahydro4a8aMethanothiomethanoNaphthalene;
formula     C12H18S;
CAS         17853-64-4;
InChIKey    LPZHLGIDTACMCQ-UHFFFAOYSA-N;
MW          194.336;      // g/mol [origin=calculated method=formula-sum]
Tc          834.25;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.3494;      // -   [origin=predictive method=lee-kesler]
Tb          563.60;      // K   [origin=predictive method=joback]
HvapTb      46844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-255.55 2.12681 -0.00223058 9.471e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 2; } { group CH=CH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4alpha,8alpha-(methanothiomethano)naphthalene, 1,2,3,4,5,8-hexahydro-" "4.alpha.,8.alpha.-(methanothiomethano)naphthalene,1,2,3,4,5,8-hexahydro-" );
standardThermochemistry
{
    dHf_298   56610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     626.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=250560.0
}
