/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl isocyanate  (C4H5NO, CAS 1476-23-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylIsocyanate;
formula     C4H5NO;
CAS         1476-23-9;
InChIKey    HXBPYFMVGFDZFT-UHFFFAOYSA-N;
MW          83.09;      // g/mol [origin=calculated method=formula-sum]
Tc          537.73;      // K   [origin=predictive method=joback]
Pc          45.286;      // bar [origin=predictive method=joback]
omega       0.3555;      // -   [origin=predictive method=lee-kesler]
Tb          354.47;      // K   [origin=predictive method=joback]
HvapTb      33360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCd; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-isocyanatoprop-1-ene" "1-propene, 3-isocyanato-" "3-isocyanato-1-propene" "propene, 3-isocyanato-" "isocyanic acid, allyl ester" "prop-2-enisocyanate" "1-propene,3-isocyanato-" );
