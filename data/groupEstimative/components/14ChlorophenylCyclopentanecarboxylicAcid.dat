/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)cyclopentanecarboxylic acid  (C12H13ClO2, CAS 80789-69-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ChlorophenylCyclopentanecarboxylicAcid;
formula     C12H13ClO2;
CAS         80789-69-1;
InChIKey    QJNFJEMGWIQMJT-UHFFFAOYSA-N;
MW          224.684;      // g/mol [origin=calculated method=formula-sum]
Tc          959.16;      // K   [origin=predictive method=joback]
Pc          31.668;      // bar [origin=predictive method=joback]
omega       0.7916;      // -   [origin=predictive method=lee-kesler]
Tb          704.28;      // K   [origin=predictive method=joback]
HvapTb      65899.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.61 1.4866 -0.00134616 5.067e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)cyclopentane-1-carboxylic acid" "1-(4-chlorophenyl)-1-cyclopentanecarboxylic acid" "1-(4-chloro-phenyl)-cyclopentanecarboxylic  acid" "cyclopentanecarboxylic acid, 1-(4-chlorophenyl)-" );
gibbsFormation
{
    dHf_298   -356240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171840.0
    phase     gas;
}
