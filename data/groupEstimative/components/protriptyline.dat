/*--------------------------------*- Choupo -*-----------------------*\
  Component: protriptyline  (C19H21N, CAS 438-60-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        protriptyline;
formula     C19H21N;
CAS         438-60-8;
InChIKey    BWPIARFWQZKAIA-UHFFFAOYSA-N;
MW          263.384;      // g/mol [origin=calculated method=formula-sum]
Tc          987.13;      // K   [origin=predictive method=joback]
Pc          20.091;      // bar [origin=predictive method=joback]
omega       0.8334;      // -   [origin=predictive method=lee-kesler]
Tb          753.71;      // K   [origin=predictive method=joback]
HvapTb      70405.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.267 1.70312 -0.0011942 3.301e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 4; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(11h-dibenzo[1,2-a:1',2'-e][7]annulen-11-yl)-n-methyl-propan-1-amine" "vivactil" "amimetilina" "triptil" "protryptyline" "protriptilina" "protriptylinum" "novopramine" "rhotrimine" "vivactyl" "impril" "apo-imipramine" );
standardThermochemistry
{
    dHf_298   198680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     583.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=494760.0
}
