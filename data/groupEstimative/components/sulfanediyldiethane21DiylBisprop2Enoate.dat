/*--------------------------------*- Choupo -*-----------------------*\
  Component: sulfanediyldiethane-2,1-diyl bisprop-2-enoate  (C10H14O4S, CAS 19721-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sulfanediyldiethane21DiylBisprop2Enoate;
formula     C10H14O4S;
CAS         19721-37-0;
InChIKey    MGBCNPZYUKYBIJ-UHFFFAOYSA-N;
MW          230.278;      // g/mol [origin=calculated method=formula-sum]
Tc          804.90;      // K   [origin=predictive method=joback]
Pc          23.406;      // bar [origin=predictive method=joback]
omega       0.8254;      // -   [origin=predictive method=lee-kesler]
Tb          606.98;      // K   [origin=predictive method=joback]
HvapTb      58145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.234 0.79859 -0.0003366 8e-10);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 2; } { group COO; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 2; } { group dCH; count 2; } { group COO; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-prop-2-enoyloxyethylsulfanyl)ethyl prop-2-enoate" "2-propenoic acid, thiodi-2,1-ethanediyl ester" "2-propenoic acid, 1,1'-(thiodi-2,1-ethanediyl) ester" "thiodi-2,1-ethanediyl diacrylate" "2-propenoic acid, thiodi-2,1-ethanediyl ester, homopolymer" "2-propenoic acid, 1,1'-(thiodi-2,1-ethanediyl) ester, homopolymer" );
standardThermochemistry
{
    dHf_298   -591560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     700.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-378620.0
}
