/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 2,3-dibromo-, butyl ester  (C7H12Br2O2, CAS 21179-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid23DibromoButylEster;
formula     C7H12Br2O2;
CAS         21179-48-6;
InChIKey    PTODVLUSMZDXKT-UHFFFAOYSA-N;
MW          287.979;      // g/mol [origin=calculated method=formula-sum]
Tc          757.61;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.7321;      // -   [origin=predictive method=lee-kesler]
Tb          549.86;      // K   [origin=predictive method=joback]
HvapTb      51065.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (36.634 0.69632 -0.0004084 8.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group Br; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butyl 2,3-bis(bromanyl)propanoate" "butyl 2,3-dibromopropanoate" );
standardThermochemistry
{
    dHf_298   -457710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276110.0
}
