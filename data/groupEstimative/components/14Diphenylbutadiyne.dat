/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diphenylbutadiyne  (C16H10, CAS 886-66-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diphenylbutadiyne;
formula     C16H10;
CAS         886-66-8;
InChIKey    HMQFJYLWNWIYKQ-UHFFFAOYSA-N;
MW          202.256;      // g/mol [origin=calculated method=formula-sum]
Tc          930.82;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.3867;      // -   [origin=predictive method=lee-kesler]
Tb          637.04;      // K   [origin=predictive method=joback]
HvapTb      60066.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.35 1.0664 -0.00072472 1.8816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-phenylbuta-1,3-diynylbenzene" "diphenylbutadiyne" "butadiyne, diphenyl-" "diphenyldiacetylene" "diphenyl-1,3-butadiyne" "benzene, 1,1'-(1,3-butadiyne-1,4-diyl)bis-" "1,1'-buta-1,3-diyne-1,4-diyldibenzene" "1,4-diphenyl-1,3-butadiyne" "(4-phenyl-1,3-butadiynyl)benzene" "(4-phenylbuta-1,3-diynyl)benzene" "butadiyne, diphenyl- (8ci)" "1,1'-(1,3-butadiyne-1,4-diyl)bisbenzene" );
gibbsFormation
{
    dHf_298   644090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=714260.0
    phase     gas;
}
