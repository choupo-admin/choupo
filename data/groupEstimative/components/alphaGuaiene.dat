/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-guaiene  (C15H24, CAS 3691-12-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaGuaiene;
formula     C15H24;
CAS         3691-12-1;
InChIKey    ADIDQIZBYUABQK-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          791.58;      // K   [origin=predictive method=joback]
Pc          19.270;      // bar [origin=predictive method=joback]
omega       0.4581;      // -   [origin=predictive method=lee-kesler]
Tb          574.37;      // K   [origin=predictive method=joback]
HvapTb      50215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.08 1.47066 -0.00087 1.917e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 3; } { group CH2=C; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethyl-7-prop-1-en-2-yl-1,2,3,4,5,6,7,8-octahydroazulene" "1,4-dimethyl-7-(prop-1-en-2-yl)-1,2,3,4,5,6,7,8-octahydroazulene" "azulene, 1,2,3,4,5,6,7,8-octahydro-1,4-dimethyl-7-(1-methylethenyl)-, (1s,4s,7r)-" "azulene, 1,2,3,4,5,6,7,8-octahydro-1,4-dimethyl-7-(1-methylethenyl)-, [1s-(1.alpha.,4.alpha.,7.alpha.)]-" "azulene, 1,2,3,4,5,6,7,8-octahydro-1,4-dimethyl-7-(1-methylethenyl)-" );
standardThermochemistry
{
    dHf_298   -101830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=230800.0
}
