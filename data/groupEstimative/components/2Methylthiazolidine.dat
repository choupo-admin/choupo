/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylthiazolidine  (C4H9NS, CAS 24050-16-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylthiazolidine;
formula     C4H9NS;
CAS         24050-16-6;
InChIKey    DQMLFUMEBNHPPB-UHFFFAOYSA-N;
MW          103.183;      // g/mol [origin=calculated method=formula-sum]
Tc          630.02;      // K   [origin=predictive method=joback]
Pc          50.802;      // bar [origin=predictive method=joback]
omega       0.2768;      // -   [origin=predictive method=lee-kesler]
Tb          402.78;      // K   [origin=predictive method=joback]
HvapTb      37325.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.49 0.51653 -0.0002793 5.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH2NH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group NH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1,3-thiazolidine" "thiazolidine, 2-methyl-" "methyl-2 thiazolidine [french]" "methyl-2 thiazolidine" );
standardThermochemistry
{
    dHf_298   17660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     305.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=146920.0
}
