/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7,13,16,21-pentaoxa-1,10-diazabicyclo[8.8.5]tricosane  (C16H32N2O5, CAS 31364-42-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47131621Pentaoxa110Diazabicyclo885Tricosane;
formula     C16H32N2O5;
CAS         31364-42-8;
InChIKey    HDLXPNDSLDLJHF-UHFFFAOYSA-N;
MW          332.441;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.57;      // K   [origin=predictive method=joback]
Pc          22.633;      // bar [origin=predictive method=joback]
omega       0.8619;      // -   [origin=predictive method=lee-kesler]
Tb          812.18;      // K   [origin=predictive method=joback]
HvapTb      80870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.61 1.9674 -0.0008575 1.7e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group FCH2O; count 5; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 16; } { group O_ring; count 5; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7,13,16,21-pentaoxa-1,10-diazabicyclo[8.8.5.]tricosane" "4,7,13,16,21-pentaoxa-1,10-diazabicyclo(8.8.5)tricosane" );
gibbsFormation
{
    dHf_298   -804630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-169780.0
    phase     gas;
}
