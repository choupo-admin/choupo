name        docosamethyldecasiloxane;
formula     C22H66O9Si10;
CAS         556-70-7;
InChIKey    BWOVCDPFYDQAMX-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          755.611;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.41;      // K   [origin=predictive method=joback]
Pc          4.560;      // bar [origin=predictive method=joback]
omega       0.2495;      // -   [origin=predictive method=lee-kesler]
Tb          918.74;      // K   [origin=predictive method=joback]
HvapTb      89196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (620.57 -0.53656 0.003974 -2.4146e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 22; } { group Si; count 1; } { group SiO; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 22; } { group O; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[dimethyl(trimethylsilyloxy)silyl]oxy-[[[[[[dimethyl(trimethylsilyloxy)silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silyl]oxy-dimethyl-silane" "decasiloxane, docosamethyl-" "decasiloxane,docosamethyl- (7ci,8ci,9ci); docosamethyldecasiloxane" "[dimethyl(trimethylsilyloxy)silyl]oxy-[[[[[[dimethyl(trimethylsilyloxy)silyl]oxy-dimethylsilyl]oxy-dimethylsilyl]oxy-dimethylsilyl]oxy-dimethylsilyl]oxy-dimethylsilyl]oxy-dimethylsilane" "decasiloxane,1,1,1,3,3,5,5,7,7,9,9,11,11,13,13,15,15,17,17,19,19,19-docosamethyl-" );
