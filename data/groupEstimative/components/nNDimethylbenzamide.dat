/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylbenzamide  (C9H11NO, CAS 611-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylbenzamide;
formula     C9H11NO;
CAS         611-74-5;
InChIKey    IMNDHOCGZLYMRO-UHFFFAOYSA-N;
MW          149.193;      // g/mol [origin=calculated method=formula-sum]
Tc          713.79;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.5262;      // -   [origin=predictive method=lee-kesler]
Tb          498.51;      // K   [origin=predictive method=joback]
HvapTb      46693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.53 0.87584 -0.0005909 1.4976e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CON_CH3_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethylbenzamide" "benzamide, n,n-dimethyl-" "dimethylbenzmide" "nn-dimethylbenzamide" "n,n-dimethyl-benzamide" );
gibbsFormation
{
    dHf_298   -37610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=119170.0
    phase     gas;
}
