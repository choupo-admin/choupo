/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-ethenediamine, n,n,n',n'-tetramethyl-  (C6H14N2, CAS 815-62-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11EthenediamineNNNNTetramethyl;
formula     C6H14N2;
CAS         815-62-3;
InChIKey    IRZPOGNEUZKUTG-UHFFFAOYSA-N;
MW          114.192;      // g/mol [origin=calculated method=formula-sum]
Tc          526.61;      // K   [origin=predictive method=joback]
Pc          32.616;      // bar [origin=predictive method=joback]
omega       0.3699;      // -   [origin=predictive method=lee-kesler]
Tb          358.32;      // K   [origin=predictive method=joback]
HvapTb      32446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.63 0.80158 -0.000553 1.542e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=C; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH2; count 1; } { group dC; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n1',n1'-tetramethylethene-1,1-diamine" "1-dimethylaminovinyl-dimethyl-amine" "n,n,n',n'-tetramethylethene-1,1-diamine" "n,n,n',n'-tetramethylethylene-1,1-diamine" "1-n,1-n,1-n',1-n'-tetramethylethene-1,1-diamine" );
standardThermochemistry
{
    dHf_298   83530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     413.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=300490.0
}
