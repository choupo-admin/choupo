/*--------------------------------*- Choupo -*-----------------------*\
  Component: thebainone  (C18H21NO3, CAS 467-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thebainone;
formula     C18H21NO3;
CAS         467-98-1;
InChIKey    SLJDAVMWFVYEFI-HJFZTSBYSA-N;
MW          299.37;      // g/mol [origin=calculated method=formula-sum]
Tc          1106.61;      // K   [origin=predictive method=joback]
Pc          25.405;      // bar [origin=predictive method=joback]
omega       1.0992;      // -   [origin=predictive method=lee-kesler]
Tb          855.27;      // K   [origin=predictive method=joback]
HvapTb      80028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-174.52 2.24194 -0.00200056 7.516e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 2; } { group AC; count 2; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2CO; count 1; } { group CH3O; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "thebainone a" );
standardThermochemistry
{
    dHf_298   -295700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117020.0
}
