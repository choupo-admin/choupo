/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl ethyl sulfide  (C6H14S, CAS 14290-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylEthylSulfide;
formula     C6H14S;
CAS         14290-92-7;
InChIKey    GZJUDUMQICJSFJ-UHFFFAOYSA-N;
MW          118.238;      // g/mol [origin=calculated method=formula-sum]
Tc          604.43;      // K   [origin=predictive method=joback]
Pc          32.357;      // bar [origin=predictive method=joback]
omega       0.2769;      // -   [origin=predictive method=lee-kesler]
Tb          402.43;      // K   [origin=predictive method=joback]
HvapTb      34471.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.439 0.69407 -0.0004342 1.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylsulfanyl-2-methyl-propane" "sulfide, tert-butyl ethyl" "propane, 2-(ethylthio)-2-methyl-" "ethyl tert-butyl sulfide" "1-(tert-butylthio)ethane" "2,2-dimethyl-3-thiapentane" "2-ethylsulfanyl-2-methylpropane" "propane,2-(ethylthio)-2-methyl-" "2-(ethylsulfanyl)-2-methylpropane" );
gibbsFormation
{
    dHf_298   -134050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=35600.0
    phase     gas;
}
