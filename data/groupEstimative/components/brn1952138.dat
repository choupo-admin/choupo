/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 1952138  (C10H16Cl2O4, CAS 1606-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn1952138;
formula     C10H16Cl2O4;
CAS         1606-83-3;
InChIKey    FPNVDCLFXCGXLH-UHFFFAOYSA-N;
MW          271.134;      // g/mol [origin=calculated method=formula-sum]
Tc          925.68;      // K   [origin=predictive method=joback]
Pc          26.958;      // bar [origin=predictive method=joback]
omega       1.5523;      // -   [origin=predictive method=lee-kesler]
Tb          740.58;      // K   [origin=predictive method=joback]
HvapTb      86178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.356 0.771 -0.00031406 1.378e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2Cl; count 2; } { group C_C; count 1; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group CH; count 2; } { group tC; count 2; } { group Cl; count 2; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3-[4-(3-chloranyl-2-oxidanyl-propoxy)but-2-ynoxy]propan-2-ol" "1,4-bis(3-chloro-2-hydroxypropoxy)-2-butyne" "1,1'-(2-butynylenedioxy)bis(3-chloro-2-propanol)" "u 27,151" "2-propanol, 1,1'-(2-butynylenedioxy)bis(3-chloro-" "1,1'-(but-2-yne-1,4-diylbis(oxy))bis(3-chloropropan-2-ol)" "2-propanol, 1,1'-(2-butyne-1,4-diylbis(oxy))bis(3-chloro-" "1-chloro-3-[4-(3-chloro-2-hydroxypropoxy)but-2-ynoxy]propan-2-ol" );
gibbsFormation
{
    dHf_298   -588370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-276260.0
    phase     gas;
}
