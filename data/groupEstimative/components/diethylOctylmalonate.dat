/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl octylmalonate  (C15H28O4, CAS 1472-85-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylOctylmalonate;
formula     C15H28O4;
CAS         1472-85-1;
InChIKey    YZYBVYGISZANLI-UHFFFAOYSA-N;
MW          272.385;      // g/mol [origin=calculated method=formula-sum]
Tc          831.82;      // K   [origin=predictive method=joback]
Pc          14.348;      // bar [origin=predictive method=joback]
omega       0.9356;      // -   [origin=predictive method=lee-kesler]
Tb          658.80;      // K   [origin=predictive method=joback]
HvapTb      63410.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (38.389 1.32516 -0.0006062 5.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 9; } { group CH; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-octylpropanedioate" "malonic acid, octyl-, diethyl ester" "diethyl 2-octylpropane-1,3-dioate" "propanedioic acid, octyl-, diethyl ester" "propanedioic acid,2-octyl-, 1,3-diethyl ester" );
gibbsFormation
{
    dHf_298   -992770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     833.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-547760.0
    phase     gas;
}
