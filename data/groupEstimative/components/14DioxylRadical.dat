/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioxyl radical  (C4H7O2, CAS 4598-47-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        14DioxylRadical;
formula     C4H7O2;
CAS         4598-47-4;
InChIKey    XTKIUJCPLLOSMW-UHFFFAOYSA-N;
role        radical;
MW          87.098;      // g/mol [origin=calculated method=formula-sum]
Tc          579.51;      // K   [origin=predictive method=joback]
Pc          53.749;      // bar [origin=predictive method=joback]
omega       0.2782;      // -   [origin=predictive method=lee-kesler]
Tb          368.82;      // K   [origin=predictive method=joback]
HvapTb      34402.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.76 0.4984 -0.00029604 5.89e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dioxanyl" "1,4-dioxan-2-yl" );
gibbsFormation
{
    dHf_298   -286340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     202.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142300.0
    phase     gas;
}
