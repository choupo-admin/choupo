/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-iodoanisole  (C7H7IO, CAS 766-85-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Iodoanisole;
formula     C7H7IO;
CAS         766-85-8;
InChIKey    RSHBAGGASAJQCH-UHFFFAOYSA-N;
MW          234.032;      // g/mol [origin=calculated method=formula-sum]
Tc          756.90;      // K   [origin=predictive method=joback]
Pc          38.435;      // bar [origin=predictive method=joback]
omega       0.3636;      // -   [origin=predictive method=lee-kesler]
Tb          506.98;      // K   [origin=predictive method=joback]
HvapTb      45897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.11 0.50622 -0.00029156 5.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyl-3-methoxy-benzene" "m-iodoanisole" "1-iodo-3-methoxybenzene" "benzene, 1-iodo-3-methoxy-" "anisole, m-iodo-" "m-methoxyiodobenzene" "3-methoxyiodobenzene" "3-methoxyphenyl iodide" "rshbaggasajqch-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -18100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     382.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63960.0
    phase     gas;
}
