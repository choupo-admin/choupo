/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(octyloxy)ethanol  (C10H22O2, CAS 10020-43-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OctyloxyEthanol;
formula     C10H22O2;
CAS         10020-43-6;
InChIKey    ZQCIMPBZCZUDJM-UHFFFAOYSA-N;
MW          174.284;      // g/mol [origin=calculated method=formula-sum]
Tc          701.74;      // K   [origin=predictive method=joback]
Pc          22.611;      // bar [origin=predictive method=joback]
omega       1.0321;      // -   [origin=predictive method=lee-kesler]
Tb          543.00;      // K   [origin=predictive method=joback]
HvapTb      56943.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.589 0.92462 -0.0004396 6.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octoxyethanol" "ethanol, 2-(octyloxy)-" "ethylene glycol mono-n-octyl ether" "2-octyloxyethan-1-ol" "octyl alcohol, ethoxylated" "octylglycol" "alcohols, c8-20, ethoxylated" "polyethylene glycol monooctyl ether" "n-octyl-polyoxyethylene" "ethylene glycol monooctyl ether" "c8e1" "poly(oxy-1,2-ethanediyl), alpha-octyl-omega-hydroxy-" );
gibbsFormation
{
    dHf_298   -534180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-208500.0
    phase     gas;
}
