/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxane, 4-methyl-2-(2-phenylethenyl)-  (C13H16O2, CAS 5420-98-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxane4Methyl22Phenylethenyl;
formula     C13H16O2;
CAS         5420-98-4;
InChIKey    LSEPTNAIKXLPFK-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          837.67;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.5154;      // -   [origin=predictive method=lee-kesler]
Tb          596.66;      // K   [origin=predictive method=joback]
HvapTb      55906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.04 1.26952 -0.0007962 1.804e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methyl-2-(2-phenylethenyl)-1,3-dioxane" );
standardThermochemistry
{
    dHf_298   -187920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=95710.0
}
