  Component: 2,3,3a,4,7,7a-hexahydro-1-benzothiophene 1,1-dioxide  (C8H12O2S, CAS 93638-55-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H12O2S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        233a477aHexahydro1Benzothiophene11Dioxide;
formula     C8H12O2S;
CAS         93638-55-2;
InChIKey    NTHADLFTOIMHGB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          172.242;      // g/mol [origin=calculated method=formula-sum]
Tc          564.96;      // K   [origin=predictive method=joback]
Pc          42.496;      // bar [origin=predictive method=joback]
omega       0.4530;      // -   [origin=predictive method=lee-kesler]
Tb          382.82;      // K   [origin=predictive method=joback]
HvapTb      45682.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.69 1.0296 -0.00072088 1.914e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2SuCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,7,3a,7a-hexahydrobenzo[b]thiophene-1,1-dione" "benzo(c)thiophene, 1,3,3a,4,7,7a-hexahydro-2,2-dioxide" "benzo[c]thiophene, 1,3,3a,4,7,7a-hexahydro-2,2-dioxide" "sdccgmls-0064700.p001" "2,3,3a,4,7,7a-hexahydrobenzothiophene 1,1-dioxide" "2,3,3a,4,7,7a-hexahydrobenzo[b]thiophene 1,1-dioxide" "2,3,3a,4,7,7a-hexahydro-benzo[b]thiophene 1,1-dioxide" );
gibbsFormation
{
    dHf_298   -512610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-357920.0
    phase     gas;
}
