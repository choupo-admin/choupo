/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2,4-bis(diethylamino)cyclobuta-1,3-diene-1,3-dicarboxylate  (C18H30N2O4, CAS 20913-35-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl24BisDiethylaminoCyclobuta13Diene13Dicarboxylate;
formula     C18H30N2O4;
CAS         20913-35-3;
InChIKey    RHFCLUSXAFYMQB-UHFFFAOYSA-N;
MW          338.448;      // g/mol [origin=calculated method=formula-sum]
Tc          974.41;      // K   [origin=predictive method=joback]
Pc          13.320;      // bar [origin=predictive method=joback]
omega       1.0843;      // -   [origin=predictive method=lee-kesler]
Tb          786.68;      // K   [origin=predictive method=joback]
HvapTb      78188.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.416 1.66992 -0.000927 1.7e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group CH2N; count 2; } { group C=C; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group dC_ring; count 4; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-cyclobutadiene-1,3-dicarboxylic acid, 2,4-bis(diethylamino)diethyl ester" "1,3-cyclobutadiene-1,3-dicarboxylic acid,2,4-bis(diethylamino)-diethyl ester" "1,3-cyclobutadiene-1,3-dicarboxylicacid, 2,4-bis(diethylamino)-, 1,3-diethyl ester" "1,3-cyclobutadiene-1,3-dicarboxylicacid, 2,4-bis(diethylamino)-, diethyl ester (8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -757690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     864.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-220740.0
}
