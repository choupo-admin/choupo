/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-diethoxyethylamine  (C6H15NO2, CAS 645-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Diethoxyethylamine;
formula     C6H15NO2;
CAS         645-36-3;
InChIKey    HJKLEAOXCZIMPI-UHFFFAOYSA-N;
MW          133.191;      // g/mol [origin=calculated method=formula-sum]
Tc          637.12;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.5993;      // -   [origin=predictive method=lee-kesler]
Tb          453.81;      // K   [origin=predictive method=joback]
HvapTb      44023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.243 0.51524 -0.0001272 -3.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2O; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diethoxyethanamine" "aminoacetaldehyde diethyl acetal" "ethanamine, 2,2-diethoxy-" "glycinaldehyde diethyl acetal" "2-aminoacetaldehyde diethyl acetal" "acetaldehyde, amino-, diethyl acetal" "aminoacetaldehydediethylacetal" "aminoacetal" "aminoacetaldehyde acetal" "ethanamine,2-diethoxy-" "2,2-diethoxy-ethyl-amine" "2-amino-1,1-diethoxyethane" );
gibbsFormation
{
    dHf_298   -403100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146350.0
    phase     gas;
}
