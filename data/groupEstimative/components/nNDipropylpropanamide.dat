/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dipropylpropanamide  (C9H19NO, CAS 1114-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDipropylpropanamide;
formula     C9H19NO;
CAS         1114-59-6;
InChIKey    ARCMPHHHUFVAOI-UHFFFAOYSA-N;
MW          157.257;      // g/mol [origin=calculated method=formula-sum]
Tc          644.36;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       0.6367;      // -   [origin=predictive method=lee-kesler]
Tb          471.83;      // K   [origin=predictive method=joback]
HvapTb      44417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.625 0.95476 -0.0005597 1.2426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanamide, n,n-dipropyl-" );
standardThermochemistry
{
    dHf_298   -274140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     549.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6760.0
}
