/*--------------------------------*- Choupo -*-----------------------*\
  Component: amydricaine  (C16H26N2O2, CAS 963-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amydricaine;
formula     C16H26N2O2;
CAS         963-07-5;
InChIKey    VEXNFKCQMGMBBJ-UHFFFAOYSA-N;
MW          278.396;      // g/mol [origin=calculated method=formula-sum]
Tc          870.63;      // K   [origin=predictive method=joback]
Pc          17.318;      // bar [origin=predictive method=joback]
omega       0.8320;      // -   [origin=predictive method=lee-kesler]
Tb          672.23;      // K   [origin=predictive method=joback]
HvapTb      63683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.007 1.7638 -0.0011802 2.943e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1-(dimethylamino)-2-[(dimethylamino)methyl]butan-2-yl] benzoate" "benzopropyl" "alypin" "1,1-bis(dimethylaminomethyl)propyl benzoate" "dimethylaminostovaine" "benzoyl-ethyl-tetramethyldiamino-isoproanpol" "2-ethyl-1,3-bis(dimethylamino)-2-propanol benzoate" "1-(dimethylamino)-2-((dimethylamino)methyl)-2-butanol benzoate" "2-butanol, 1-(dimethylamino)-2-((dimethylamino)methyl)-, benzoate, (ester)" "amydrikain" "1,1-bis-(dimethylaminoethyl)propylester kyseliny benzoove" "[1-(dimethylamino)-2-(dimethylaminomethyl)butan-2-yl] benzoate" );
gibbsFormation
{
    dHf_298   -328010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110280.0
    phase     gas;
}
