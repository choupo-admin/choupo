/*--------------------------------*- Choupo -*-----------------------*\
  Component: [2-(naphthalen-1-yl)phenyl]acetic acid  (C18H14O2, CAS 93654-97-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Naphthalen1YlPhenylAceticAcid;
formula     C18H14O2;
CAS         93654-97-8;
InChIKey    CSPBVTFSWJQBKC-UHFFFAOYSA-N;
MW          262.308;      // g/mol [origin=calculated method=formula-sum]
Tc          1093.96;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       1.0293;      // -   [origin=predictive method=lee-kesler]
Tb          839.25;      // K   [origin=predictive method=joback]
HvapTb      80342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-79.529 1.4841 -0.00109304 3.133e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 4; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-naphthalen-1-ylphenyl)ethanoic acid" "2-(2-naphthalen-1-ylphenyl)acetic acid" );
gibbsFormation
{
    dHf_298   -123930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68980.0
    phase     gas;
}
