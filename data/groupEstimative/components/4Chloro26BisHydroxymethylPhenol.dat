/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-2,6-bis(hydroxymethyl)phenol  (C8H9ClO3, CAS 17026-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro26BisHydroxymethylPhenol;
formula     C8H9ClO3;
CAS         17026-49-2;
InChIKey    OGMITUYZIACKHB-UHFFFAOYSA-N;
MW          188.607;      // g/mol [origin=calculated method=formula-sum]
Tc          923.69;      // K   [origin=predictive method=joback]
Pc          51.832;      // bar [origin=predictive method=joback]
omega       1.7220;      // -   [origin=predictive method=lee-kesler]
Tb          721.69;      // K   [origin=predictive method=joback]
HvapTb      87759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.862 0.7953 -0.00064608 2.214e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH2; count 2; } { group OH; count 2; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group OH; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2,6-bis(hydroxymethyl)phenol" "o,o-dimethylol-p-chlorophenol" "2,6-dimethylol-4-chlorophenol" "1,3-benzenedimethanol, 5-chloro-2-hydroxy-" "1, 5-chloro-2-hydroxy-" "2,6-bis(hydroxymethyl)-4-chlorophenol" "5-chloro-m-xylene-2,alpha,alpha'-triol" "m-xylene-.alpha., 5-chloro-2-hydroxy-" "m-xylene, a,a'-diol 5-chloro-2-hydroxy-" "(5-chloro-2-hydroxy-1,3-phenylene)dimethanol" "m-xylene-alpha,alpha'-diol, 5-chloro-2-hydroxy-" );
gibbsFormation
{
    dHf_298   -492370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-330560.0
    phase     gas;
}
