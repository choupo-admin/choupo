/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-chloro-7-methyltetraphene  (C19H13Cl, CAS 6366-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10Chloro7Methyltetraphene;
formula     C19H13Cl;
CAS         6366-24-1;
InChIKey    JUWMMXBWSDLPQJ-UHFFFAOYSA-N;
MW          276.763;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.90;      // K   [origin=predictive method=joback]
Pc          23.270;      // bar [origin=predictive method=joback]
omega       0.7629;      // -   [origin=predictive method=lee-kesler]
Tb          775.29;      // K   [origin=predictive method=joback]
HvapTb      72117.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.53 1.48762 -0.0012034 3.931e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 6; } { group ACCH3; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "10-chloranyl-7-methyl-benzo[a]anthracene" "10-chloro-7-methylbenz(a)anthracene" "benz(a)anthracene, 10-chloro-7-methyl" "7-chloro-10-methyl-1,2-benzanthracene" "10-chloro-7-methylbenzo[a]anthracene" );
standardThermochemistry
{
    dHf_298   312630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     471.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=491010.0
}
