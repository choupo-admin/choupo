{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.41 1.6228 -0.00158664 6.165e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 1; } { group AC; count 2; } { group ACCH2; count 2; } { group ACOH; count 1; } { group CHO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
