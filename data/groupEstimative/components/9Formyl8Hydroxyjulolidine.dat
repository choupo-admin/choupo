name        9Formyl8Hydroxyjulolidine;
formula     C13H15NO2;
CAS         63149-33-7;
InChIKey    NRZXBDYODHLZBF-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          217.268;      // g/mol [origin=calculated method=formula-sum]
Tc          869.49;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.7760;      // -   [origin=predictive method=lee-kesler]
Tb          630.96;      // K   [origin=predictive method=joback]
HvapTb      61922.0;      // J/mol [origin=predictive method=joback]

