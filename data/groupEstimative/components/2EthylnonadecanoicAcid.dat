/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylnonadecanoic acid  (C21H42O2, CAS 69868-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylnonadecanoicAcid;
formula     C21H42O2;
CAS         69868-05-9;
InChIKey    SEVBTWRNJDEVHQ-UHFFFAOYSA-N;
MW          326.565;      // g/mol [origin=calculated method=formula-sum]
Tc          1011.96;      // K   [origin=predictive method=joback]
Pc          10.162;      // bar [origin=predictive method=joback]
omega       0.9630;      // -   [origin=predictive method=lee-kesler]
Tb          825.15;      // K   [origin=predictive method=joback]
HvapTb      79116.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.283 2.05554 -0.0011944 2.662e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylnonadecan-1-oic acid" "nonadecanoic acid, 2-ethyl-" "2-ethylnonadecanoicacid" "nonadecanoic acid,2-ethyl-" );
gibbsFormation
{
    dHf_298   -832320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1017.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-220410.0
    phase     gas;
}
