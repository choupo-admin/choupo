/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyanoacetylmorpholine  (C7H10N2O2, CAS 15029-32-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyanoacetylmorpholine;
formula     C7H10N2O2;
CAS         15029-32-0;
InChIKey    AUZPMUJGZZSMCP-UHFFFAOYSA-N;
MW          154.169;      // g/mol [origin=calculated method=formula-sum]
Tc          797.42;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.7409;      // -   [origin=predictive method=lee-kesler]
Tb          575.05;      // K   [origin=predictive method=joback]
HvapTb      55519.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.909 0.8547 -0.0005888 1.5316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group FCH2O; count 1; } { group CH2CN; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-morpholin-4-yl-3-oxidanylidene-propanenitrile" "3-morpholino-3-oxopropanenitrile" "4-(cyanoacetyl)morpholine" "3-morpholin-4-yl-3-oxopropanenitrile" "3-(morpholin-4-yl)-3-oxopropanenitrile" "3-morpholin-4-yl-3-oxo-propionitrile" "morpholinooxopropanenitrile" "(morpholinocarbonyl)acetonitrile" "4-morpholinepropanenitrile,  -oxo-" "3-(4-morpholinyl)-3-oxopropanenitrile" "4-morpholinepropanenitrile, .beta.-oxo-" );
standardThermochemistry
{
    dHf_298   -119160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=81240.0
}
