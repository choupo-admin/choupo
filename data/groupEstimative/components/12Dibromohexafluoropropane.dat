/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromohexafluoropropane  (C3Br2F6, CAS 661-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromohexafluoropropane;
formula     C3Br2F6;
CAS         661-95-0;
InChIKey    KTULQNFKNLFOHL-UHFFFAOYSA-N;
MW          309.829;      // g/mol [origin=calculated method=formula-sum]
Tc          567.95;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.4498;      // -   [origin=predictive method=lee-kesler]
Tb          386.49;      // K   [origin=predictive method=joback]
HvapTb      26352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.33 0.8134 -0.000896 3.42e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 2; } { group CF3; count 1; } { group CF2; count 1; } { group CF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 3; } { group F; count 6; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)-1,1,2,3,3,3-hexakis(fluoranyl)propane" "1,2-dibromo-1,1,2,3,3,3-hexafluoropropane" "propane, 1,2-dibromo-1,1,2,3,3,3-hexafluoro-" );
standardThermochemistry
{
    dHf_298   -1255500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1157320.0
}
