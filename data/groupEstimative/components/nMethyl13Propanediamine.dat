/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-1,3-propanediamine  (C4H12N2, CAS 6291-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyl13Propanediamine;
formula     C4H12N2;
CAS         6291-84-5;
InChIKey    QHJABUZHRJTCAR-UHFFFAOYSA-N;
MW          88.154;      // g/mol [origin=calculated method=formula-sum]
Tc          600.86;      // K   [origin=predictive method=joback]
Pc          42.607;      // bar [origin=predictive method=joback]
omega       0.5346;      // -   [origin=predictive method=lee-kesler]
Tb          413.82;      // K   [origin=predictive method=joback]
HvapTb      41575.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.533 0.52192 -0.0002858 5.79e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2NH2; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-methylpropane-1,3-diamine" "n-methyl-1,3-diaminopropane" "(3-aminopropyl)methylamine" "1,3-propanediamine, n-methyl-" "3-(methylamino)propylamine" "n-methylpropane-1,3-diamine" "n-methyltrimethylenediamine" "n-methyl-1,3-propylenediamine" "1-amino-3-(methylamino)propane" "3-amino-1-(methylamino)propane" "3-aminopropylmethylamine" "3-methylaminopropylamine" );
gibbsFormation
{
    dHf_298   -38630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     404.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138640.0
    phase     gas;
}
