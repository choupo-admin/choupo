/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-4-azabicyclo[3.2.1]oct-6-ene  (C8H13N, CAS 56125-92-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl4Azabicyclo321Oct6Ene;
formula     C8H13N;
CAS         56125-92-9;
InChIKey    YYJTYXLYVQBZAL-UHFFFAOYSA-N;
MW          123.199;      // g/mol [origin=calculated method=formula-sum]
Tc          613.20;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.3524;      // -   [origin=predictive method=lee-kesler]
Tb          411.99;      // K   [origin=predictive method=joback]
HvapTb      35735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.9 1.12392 -0.00090528 2.943e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azabicyclo(3.2.1)oct-6-ene, 2-methyl-" );
gibbsFormation
{
    dHf_298   56300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     285.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266620.0
    phase     gas;
}
