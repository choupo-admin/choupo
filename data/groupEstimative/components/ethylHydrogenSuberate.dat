/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl hydrogen suberate  (C10H18O4, CAS 14113-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylHydrogenSuberate;
formula     C10H18O4;
CAS         14113-01-0;
InChIKey    KCFVQEAPUOVXTH-UHFFFAOYSA-N;
MW          202.25;      // g/mol [origin=calculated method=formula-sum]
Tc          817.59;      // K   [origin=predictive method=joback]
Pc          23.025;      // bar [origin=predictive method=joback]
omega       1.0365;      // -   [origin=predictive method=lee-kesler]
Tb          632.13;      // K   [origin=predictive method=joback]
HvapTb      62425.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.807 0.94982 -0.0004982 7.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-ethoxy-8-oxidanylidene-octanoic acid" "8-ethoxy-8-oxooctanoic acid" "octanedioic acid, ethyl-" "ethyloctanedioic acid" "8-ethoxy-8-oxo-octanoic acid" "octanedioicacid, monoethyl ester (9ci); suberic acid, ethyl ester (6ci); suberic acid,monoethyl ester (8ci); ethyl hydrogen suberate; monoethyl suberate" );
gibbsFormation
{
    dHf_298   -917280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-620960.0
    phase     gas;
}
