/*--------------------------------*- Choupo -*-----------------------*\
  Component: glyceryl tribenzoate  (C24H20O6, CAS 614-33-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        glycerylTribenzoate;
formula     C24H20O6;
CAS         614-33-5;
InChIKey    HIZCTWCPHWUPFU-UHFFFAOYSA-N;
MW          404.418;      // g/mol [origin=calculated method=formula-sum]
Tc          1249.26;      // K   [origin=predictive method=joback]
Pc          15.923;      // bar [origin=predictive method=joback]
omega       1.1680;      // -   [origin=predictive method=lee-kesler]
Tb          1002.98;      // K   [origin=predictive method=joback]
HvapTb      97679.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.098 1.8886 -0.0010948 1.791e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 15; } { group AC; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-bis(phenylcarbonyloxy)propyl benzoate" "tribenzoin" "glycerol tribenzoate" "glycerol, tribenzoate" "1,2,3-propanetriol, tribenzoate" "1,2,3-propanetriol, 1,2,3-tribenzoate" "1,3-propanetriol, tribenzoate" "2,3-dibenzoyloxypropyl benzoate" "propane-1,2,3-triyl tribenzoate" );
standardThermochemistry
{
    dHf_298   -786220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     915.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-445120.0
}
