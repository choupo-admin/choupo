/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyloctadecylamine  (C19H41N, CAS 2439-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nMethyloctadecylamine;
formula     C19H41N;
CAS         2439-55-6;
InChIKey    SZEGKVHRCLBFKJ-UHFFFAOYSA-N;
MW          283.544;      // g/mol [origin=calculated method=formula-sum]
Tc          849.14;      // K   [origin=predictive method=joback]
Pc          10.899;      // bar [origin=predictive method=joback]
omega       0.8972;      // -   [origin=predictive method=lee-kesler]
Tb          684.49;      // K   [origin=predictive method=joback]
HvapTb      64324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.593 1.88504 -0.0010584 2.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 17; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyloctadecan-1-amine" "n-methylstearylamine" "1-octadecanamine, n-methyl-" "n-methyl-n-octadecylamine" "methylstearylamine" "methyloctadecylamine" "octadecylmethylamine" "methyl-n-octadecylamine" "n-methyl-n-stearylamine" "n-stearyl-n-methylamine" "octadecylamine, n-methyl-" "n-methyloctadecanamine" );
standardThermochemistry
{
    dHf_298   -382020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     936.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198490.0
}
