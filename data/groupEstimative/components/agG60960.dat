/*--------------------------------*- Choupo -*-----------------------*\
  Component: ag-g-60960  (C23H50N2O3, CAS 68189-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agG60960;
formula     C23H50N2O3;
CAS         68189-46-8;
InChIKey    PWVXSCFHRAKKIF-UHFFFAOYSA-N;
MW          402.664;      // g/mol [origin=calculated method=formula-sum]
Tc          1254.43;      // K   [origin=predictive method=joback]
Pc          8.795;      // bar [origin=predictive method=joback]
omega       0.7815;      // -   [origin=predictive method=lee-kesler]
Tb          1017.87;      // K   [origin=predictive method=joback]
HvapTb      103737.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.18 2.10834 -0.0008662 4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CH2O; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 20; } { group O; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanoic acid;n'-(3-tetradecoxypropyl)propane-1,3-diamine" "propanoic acid- n-[3-(tetradecyloxy)propyl]propane-1,3-diamine(1:1)" "propanoic acid compd. with n-[3-(tetradecyloxy)propyl]-1,3-propanediamine" "n-(3-myristyloxypropyl)-1,3-propanediamine propionic acid salt" "propanoic acid, compd. with n1-(3-(tetradecyloxy)propyl)-1,3-propanediamine (1:?)" "propanoic acid, compd. with n-(3-(tetradecyloxy)propyl)-1,3-propanediamine" "n-(tetradecyloxypropyl)-1,3-propanediamine propionate" "propanoic acid; n'-(3-tetradecoxypropyl)propane-1,3-diamine" "propionic acid, compound with n-(3-(tetradecyloxy)propyl)propane-1,3-diamine" );
standardThermochemistry
{
    dHf_298   -1024900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1316.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-255050.0
}
