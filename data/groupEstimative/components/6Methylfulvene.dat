/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methylfulvene  (C7H8, CAS 3839-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methylfulvene;
formula     C7H8;
CAS         3839-50-7;
InChIKey    ACGLURQVVOLIOD-UHFFFAOYSA-N;
MW          92.141;      // g/mol [origin=calculated method=formula-sum]
Tc          591.79;      // K   [origin=predictive method=joback]
Pc          40.261;      // bar [origin=predictive method=joback]
omega       0.2621;      // -   [origin=predictive method=lee-kesler]
Tb          384.67;      // K   [origin=predictive method=joback]
HvapTb      33113.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.24 0.63752 -0.00048286 1.491e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethylidenecyclopenta-1,3-diene" "1,3-cyclopentadiene, 5-ethylidene-" "agn-pc-0cn51t" );
gibbsFormation
{
    dHf_298   84600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     317.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157700.0
    phase     gas;
}
