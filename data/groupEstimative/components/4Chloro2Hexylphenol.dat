/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-2-hexylphenol  (C12H17ClO, CAS 18979-94-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro2Hexylphenol;
formula     C12H17ClO;
CAS         18979-94-7;
InChIKey    UUBASQRIVIRMIQ-UHFFFAOYSA-N;
MW          212.717;      // g/mol [origin=calculated method=formula-sum]
Tc          839.80;      // K   [origin=predictive method=joback]
Pc          26.516;      // bar [origin=predictive method=joback]
omega       0.7811;      // -   [origin=predictive method=lee-kesler]
Tb          623.87;      // K   [origin=predictive method=joback]
HvapTb      62643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.655 1.16682 -0.00086992 2.743e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2-hexyl-phenol" "2-hexyl-4-chlorophenol" "phenol, 4-chloro-2-hexyl-" );
gibbsFormation
{
    dHf_298   -259000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-13610.0
    phase     gas;
}
