/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-propionylbiphenyl  (C15H14O, CAS 37940-57-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Propionylbiphenyl;
formula     C15H14O;
CAS         37940-57-1;
InChIKey    JMBGDQSXJHLFTO-UHFFFAOYSA-N;
MW          210.276;      // g/mol [origin=calculated method=formula-sum]
Tc          897.40;      // K   [origin=predictive method=joback]
Pc          26.353;      // bar [origin=predictive method=joback]
omega       0.6540;      // -   [origin=predictive method=lee-kesler]
Tb          655.01;      // K   [origin=predictive method=joback]
HvapTb      60944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.899 1.18352 -0.00076886 1.8436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 9; } { group AC; count 3; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-phenylphenyl)propan-1-one" "4'-phenylpropiophenone" "ketone, 4-biphenyl ethyl" "4-phenylpropiophenone" "4-biphenylyl ethylketone" "propiophenone, 4'-phenyl-" "1-biphenyl-4-yl-propan-1-one" "4-n-propionybiphenyl" "1-(biphenyl-4-yl)propan-1-one" "1-propanone,1'-biphenyl]-4-yl-" "1-[1,1'-biphenyl]-4-ylpropan-1-one" "1-propanone, 1-(1,1'-biphenyl)-4-yl-" );
gibbsFormation
{
    dHf_298   -3920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161690.0
    phase     gas;
}
