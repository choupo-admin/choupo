/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl benzene-1,4-dicarboxylate;2-(2-hydroxyethyloxy)ethanol;2-methylpropane-1,3-diol  (C18H30O9, CAS 164780-85-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylBenzene14Dicarboxylate22HydroxyethyloxyEthanol2Methy;
formula     C18H30O9;
CAS         164780-85-2;
InChIKey    UAKBTQMPJPCOFN-UHFFFAOYSA-N;
MW          390.429;      // g/mol [origin=calculated method=formula-sum]
Tc          1457.56;      // K   [origin=predictive method=joback]
Pc          16.838;      // bar [origin=predictive method=joback]
omega       1.0456;      // -   [origin=predictive method=lee-kesler]
Tb          1153.04;      // K   [origin=predictive method=joback]
HvapTb      142740.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (144.356 1.13216 8.544e-05 -3.611e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group OH; count 3; } { group COO; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 4; } { group O; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-benzenedicarboxylic acid, 1,4-dimethyl ester, polymer with 2-methyl-1,3-propanediol and 2,2'-oxybis(ethanol)" "1,4-benzenedicarboxylic acid, dimethyl ester, polymer with 2-methyl-1,3-propanediol and 2,2'-oxybis(ethanol)" );
gibbsFormation
{
    dHf_298   -1794010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1267.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1281520.0
    phase     gas;
}
