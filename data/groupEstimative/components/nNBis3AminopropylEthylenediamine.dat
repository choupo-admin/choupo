/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-bis(3-aminopropyl)ethylenediamine  (C8H22N4, CAS 10563-26-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis3AminopropylEthylenediamine;
formula     C8H22N4;
CAS         10563-26-5;
InChIKey    RXFCIXRFAJRBSG-UHFFFAOYSA-N;
MW          174.292;      // g/mol [origin=calculated method=formula-sum]
Tc          819.08;      // K   [origin=predictive method=joback]
Pc          29.345;      // bar [origin=predictive method=joback]
omega       1.1153;      // -   [origin=predictive method=lee-kesler]
Tb          628.04;      // K   [origin=predictive method=joback]
HvapTb      67556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.178 1.04 -0.0005954 1.27e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH2NH2; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group NH2; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-[2-(3-azanylpropylamino)ethyl]propane-1,3-diamine" "1,5,8,12-tetraazadodecane" "1,2-bis(3-aminopropylamino)ethane" "n,n'-bis(gamma-aminopropyl)diaminoethane" "n,n'-bis(3-aminopropyl)-1,2-diaminoethane" "n,n'-di(3-aminopropyl)-1,2-ethylenediamine" "1,3-propanediamine, n,n''-1,2-ethanediylbis-" "1,3-propanediamine, n,n''-ethylenebis-" "1,3-propanediamine, n1,n1'-1,2-ethanediylbis-" "n1,n1'-(ethane-1,2-diyl)bis(propane-1,3-diamine)" "1,8,12-tetraazadodecane" "1, n,n''-ethylenebis-" );
gibbsFormation
{
    dHf_298   -33930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     652.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328160.0
    phase     gas;
}
