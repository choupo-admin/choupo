/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(octyloxy)-1,2-propanediol  (C11H24O3, CAS 96801-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Octyloxy12Propanediol;
formula     C11H24O3;
CAS         96801-44-4;
InChIKey    GUPXYSSGJWIURR-UHFFFAOYSA-N;
MW          204.31;      // g/mol [origin=calculated method=formula-sum]
Tc          818.81;      // K   [origin=predictive method=joback]
Pc          22.697;      // bar [origin=predictive method=joback]
omega       1.4650;      // -   [origin=predictive method=lee-kesler]
Tb          657.62;      // K   [origin=predictive method=joback]
HvapTb      75460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.289 1.05952 -0.0005276 8.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-octoxypropane-1,2-diol" "1,2-propanediol, 3-(octyloxy)-" "3-octyloxypropane-1,2-diol" "octyl-sepharose" "1,2-propanediol, 3-(octyloxy)-, (r)-" "octylagarose cl-4b" "1-glyceryloctyl ether" "octylsepharose cl-4b" "octyl-sepharose cl-4b" "agn-pc-00qgpm" "sepharose cl 4b, 2-hydroxy-3-(octyloxy)propyl ether" );
standardThermochemistry
{
    dHf_298   -712330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     688.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-339340.0
}
