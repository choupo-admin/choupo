/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzocycloheptatriene  (C11H10, CAS 264-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzocycloheptatriene;
formula     C11H10;
CAS         264-09-5;
InChIKey    XHVULKQHRQZNMW-UHFFFAOYSA-N;
MW          142.201;      // g/mol [origin=calculated method=formula-sum]
Tc          743.97;      // K   [origin=predictive method=joback]
Pc          35.728;      // bar [origin=predictive method=joback]
omega       0.3613;      // -   [origin=predictive method=lee-kesler]
Tb          501.21;      // K   [origin=predictive method=joback]
HvapTb      44168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.58 0.9566 -0.00069612 1.964e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9h-benzo[7]annulene" "5h-benzo[7]annulene" "5h-benzo[a]cycloheptene" "5h-benzocycloheptene" "1,2-benzotropilidene" );
gibbsFormation
{
    dHf_298   151070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=248700.0
    phase     gas;
}
