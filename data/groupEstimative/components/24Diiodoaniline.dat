/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-diiodoaniline  (C6H5I2N, CAS 533-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24Diiodoaniline;
formula     C6H5I2N;
CAS         533-70-0;
InChIKey    YJWGKXIQTRYZSH-UHFFFAOYSA-N;
MW          344.913;      // g/mol [origin=calculated method=formula-sum]
Tc          937.34;      // K   [origin=predictive method=joback]
Pc          45.654;      // bar [origin=predictive method=joback]
omega       0.4593;      // -   [origin=predictive method=lee-kesler]
Tb          632.33;      // K   [origin=predictive method=joback]
HvapTb      61937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.0 0.5158 -0.00040592 1.267e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group I; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(iodanyl)aniline" "benzenamine, 2,4-diiodo-" "aniline,4-diiodo-" "2,4-diiodophenylamine" "benzenamine,4-diiodo-" "benzenamine,2,4-diiodo-" "2,4-diiodoaniline [mi]" );
gibbsFormation
{
    dHf_298   233950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=275480.0
    phase     gas;
}
