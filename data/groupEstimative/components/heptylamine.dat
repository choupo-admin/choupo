/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptylamine  (C7H17N, CAS 111-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptylamine;
formula     C7H17N;
CAS         111-68-2;
InChIKey    WJYIASZWHGOTOU-UHFFFAOYSA-N;
MW          115.22;      // g/mol [origin=calculated method=formula-sum]
Tc          611.06;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       0.5244;      // -   [origin=predictive method=lee-kesler]
Tb          432.29;      // K   [origin=predictive method=joback]
HvapTb      41817.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.016 0.73072 -0.0004004 8.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptan-1-amine" "1-aminoheptane" "1-heptanamine" "1-heptylamine" "n-heptylamine" "heptyl-amine" "heptanamine" "BRN 1731688" "heptyl amine" "ai3-24038" "NSC2074" "heptane, 1-amino-" );
gibbsFormation
{
    dHf_298   -154020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74510.0
    phase     gas;
}
