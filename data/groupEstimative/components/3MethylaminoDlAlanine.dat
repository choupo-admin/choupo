/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(methylamino)-(dl)-alanine  (C4H10N2O2, CAS 16676-91-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylaminoDlAlanine;
formula     C4H10N2O2;
CAS         16676-91-8;
InChIKey    UJVHVMNGOZXSOZ-UHFFFAOYSA-N;
MW          118.136;      // g/mol [origin=calculated method=formula-sum]
Tc          769.09;      // K   [origin=predictive method=joback]
Pc          48.562;      // bar [origin=predictive method=joback]
omega       0.9356;      // -   [origin=predictive method=lee-kesler]
Tb          558.89;      // K   [origin=predictive method=joback]
HvapTb      58351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.451 0.57862 -0.0003616 8.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CHNH2; count 1; } { group CH3NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanyl-3-(methylamino)propanoic acid" "dl-alanine, 3-(methylamino)-" "dl-alpha-amino-beta-methylaminopropionic acid" "propionic acid, 2-amino-3-(methylamino)-, dl-" "propionic acid, alpha-amino-beta-methylamino-, dl-" "l-bmaa" "2-amino-3-(methylamino)propanoic acid" "(s)-2-amino-3-(methylamino)propanoicacid" "propionic acid, alpha-amino-beta-methylamino-" "alanine, 3-(methylamino)-" "2-amino-3(methylamino)propionic acid" "2-amino-3-methylamino-propionic acid" );
gibbsFormation
{
    dHf_298   -394180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     447.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-207710.0
    phase     gas;
}
