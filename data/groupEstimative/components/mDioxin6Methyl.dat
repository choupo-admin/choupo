/*--------------------------------*- Choupo -*-----------------------*\
  Component: m-dioxin, 6-methyl-  (C5H8O2, CAS 15973-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mDioxin6Methyl;
formula     C5H8O2;
CAS         15973-03-2;
InChIKey    XZXHLKGJBTVUGT-UHFFFAOYSA-N;
MW          100.117;      // g/mol [origin=calculated method=formula-sum]
Tc          608.02;      // K   [origin=predictive method=joback]
Pc          47.107;      // bar [origin=predictive method=joback]
omega       0.3237;      // -   [origin=predictive method=lee-kesler]
Tb          396.26;      // K   [origin=predictive method=joback]
HvapTb      37436.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.48 0.50592 -0.00027704 4.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-4h-1,3-dioxine" "4h-1,3-dioxin, 6-methyl-" );
standardThermochemistry
{
    dHf_298   -289560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     216.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-128530.0
}
