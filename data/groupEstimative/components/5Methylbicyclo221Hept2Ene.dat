/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methylbicyclo[2.2.1]hept-2-ene  (C8H12, CAS 822-96-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methylbicyclo221Hept2Ene;
formula     C8H12;
CAS         822-96-8;
InChIKey    PCBPVYHMZBWMAZ-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          597.88;      // K   [origin=predictive method=joback]
Pc          34.684;      // bar [origin=predictive method=joback]
omega       0.2706;      // -   [origin=predictive method=lee-kesler]
Tb          394.88;      // K   [origin=predictive method=joback]
HvapTb      33383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.27 0.97352 -0.00073728 2.287e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 3; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-2-norbornene" "5-methylbicyclo(2.2.1)hept-2-ene" "bicyclo[2.2.1]hept-2-ene, 5-methyl-" "bicyclo(2.2.1)hept-2-ene, 5-methyl-" );
gibbsFormation
{
    dHf_298   -31570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     227.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=148130.0
    phase     gas;
}
