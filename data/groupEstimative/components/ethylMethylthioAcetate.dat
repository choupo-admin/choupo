/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl (methylthio)acetate  (C5H10O2S, CAS 4455-13-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylMethylthioAcetate;
formula     C5H10O2S;
CAS         4455-13-4;
InChIKey    MDIAKIHKBBNYHF-UHFFFAOYSA-N;
MW          134.193;      // g/mol [origin=calculated method=formula-sum]
Tc          639.40;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.4686;      // -   [origin=predictive method=lee-kesler]
Tb          441.00;      // K   [origin=predictive method=joback]
HvapTb      40948.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.352 0.41843 -0.0001134 -3.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2COO; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group COO; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methylsulfanylethanoate" "ethyl 2-(methylthio)-acetate" "ethyl 2-(methylthio)acetate" "ethyl 2-methylsulfanylacetate" "ethyl alpha-(methylthio)acetate" "ethyl .alpha.(methylthio)acetate" "(methylthio)acetic acid ethyl ester" "acetic acid, (methylthio)-, ethyl ester" "ethyl 2-methylthioacetate" "ethyl ((methylthio)acetate" "ethyl 2-(methylsulfanyl)acetate" "mdiakihkbbnyhf-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -421940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-286030.0
}
