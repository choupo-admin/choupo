/*--------------------------------*- Choupo -*-----------------------*\
  Component: diisopentyl phthalate  (C18H26O4, CAS 605-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diisopentylPhthalate;
formula     C18H26O4;
CAS         605-50-5;
InChIKey    JANBFCARANRIKJ-UHFFFAOYSA-N;
MW          306.402;      // g/mol [origin=calculated method=formula-sum]
Tc          958.90;      // K   [origin=predictive method=joback]
Pc          14.747;      // bar [origin=predictive method=joback]
omega       0.9460;      // -   [origin=predictive method=lee-kesler]
Tb          758.66;      // K   [origin=predictive method=joback]
HvapTb      72638.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.374 1.47768 -0.00073676 8.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(3-methylbutyl) benzene-1,2-dicarboxylate" "diisoamyl phthalate" "bis(3-methylbutyl) phthalate" "isoamyl phthalate" "disoamyl phthalate" "phthalic acid, diisopentyl ester" "1,2-benzenedicarboxylic acid, bis(3-methylbutyl) ester" "3-methylbutyl 2-[(3-methylbutyl)oxycarbonyl]benzoate" "palatinol dipp" "1, bis(3-methylbutyl) ester" "phthalic acid diisopentyl ester" "1,2-benzenedicarboxylic acid 1,2-bis(3-methylbutyl) ester" );
standardThermochemistry
{
    dHf_298   -834910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     828.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-422160.0
}
