/*--------------------------------*- Choupo -*-----------------------*\
  Component: decanoic acid;hexadecane;octadecane;octanoic acid  (C52H106O4, CAS 69669-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        decanoicAcidHexadecaneOctadecaneOctanoicAcid;
formula     C52H106O4;
CAS         69669-42-7;
InChIKey    BENCKQYVFKRAOW-UHFFFAOYSA-N;
role        radical;
MW          795.416;      // g/mol [origin=calculated method=formula-sum]
Tc          3538.21;      // K   [origin=predictive method=joback]
Pc          2.549;      // bar [origin=predictive method=joback]
omega       -0.6484;      // -   [origin=predictive method=lee-kesler]
Tb          1673.78;      // K   [origin=predictive method=joback]
HvapTb      165258.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.474 4.36688 -0.0016678 -6e-10);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 4; } { group CH2; count 44; } { group dCH2; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanoic acid; hexadecane; octadecane; octanoic acid" "decanoic acid, mixed esters with cetyl alc, octanoic acid and stearyl alc." "decanoic acid, mixed esters with cetyl alc., octanoic acid and stearyl alc." );
standardThermochemistry
{
    dHf_298   -2018370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     2608.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-519680.0
}
