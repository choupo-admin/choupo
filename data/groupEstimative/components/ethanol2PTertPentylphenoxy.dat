/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanol, 2-(p-tert-pentylphenoxy)-  (C13H20O2, CAS 6382-07-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanol2PTertPentylphenoxy;
formula     C13H20O2;
CAS         6382-07-6;
InChIKey    BXXDXUTVAFRBKC-UHFFFAOYSA-N;
MW          208.301;      // g/mol [origin=calculated method=formula-sum]
Tc          835.16;      // K   [origin=predictive method=joback]
Pc          23.657;      // bar [origin=predictive method=joback]
omega       0.9712;      // -   [origin=predictive method=lee-kesler]
Tb          640.07;      // K   [origin=predictive method=joback]
HvapTb      65263.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.217 1.19706 -0.00073876 1.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[4-(2-methylbutan-2-yl)phenoxy]ethanol" "(p-tert-amylphenoxy)ethanol" "2-(p-tert-amylphenoxy)ethanol" "2-(p-tert-pentylphenoxy)ethanol" "ethanol, 2-[4-(1,1-dimethylpropyl)phenoxy]-" "ethanol, 2-(4-(1,1-dimethylpropyl)phenoxy)-" "p-t-amylphenoxyethanol" "p-tert-amyl phenoxy ethanol" "ethanol,1-dimethylpropyl)phenoxy]-" "2-(4-(1,1-dimethylpropyl)phenoxy)ethanol" "ethanol, 2-(p-tert-pentylphenoxy)- (8ci)" );
standardThermochemistry
{
    dHf_298   -379790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     573.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77620.0
}
