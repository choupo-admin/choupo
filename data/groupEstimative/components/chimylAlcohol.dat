/*--------------------------------*- Choupo -*-----------------------*\
  Component: chimyl alcohol  (C19H40O3, CAS 53584-29-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chimylAlcohol;
formula     C19H40O3;
CAS         53584-29-5;
InChIKey    OOWQBDFWEXAXPB-UHFFFAOYSA-N;
MW          316.526;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.69;      // K   [origin=predictive method=joback]
Pc          12.166;      // bar [origin=predictive method=joback]
omega       1.1287;      // -   [origin=predictive method=lee-kesler]
Tb          840.66;      // K   [origin=predictive method=joback]
HvapTb      93268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.017 1.81952 -0.0009628 1.792e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group OH; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 17; } { group CH; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-hexadecoxypropane-1,2-diol" "1-o-hexadecylglycerol" "1-hexadecylglycerol" "testriol" "3-hexadecyloxy-1,2-propanediol" "3-(hexadecyloxy)-1,2-propanediol" "rac-1-hexadecyl-glycerol" "1,2-propanediol, 3-(hexadecyloxy)-" "1-o-palmityl-rac-glycerol" "glyceryl-1-hexadecyl ether" "rac-glycerol-1-hexadecyl ether" "(1)-3-(hexadecyloxy)propane-1,2-diol" );
gibbsFormation
{
    dHf_298   -877450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     999.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-271980.0
    phase     gas;
}
