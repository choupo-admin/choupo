/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-amino-4'-fluorobiphenyl  (C12H10FN, CAS 324-93-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Amino4Fluorobiphenyl;
formula     C12H10FN;
CAS         324-93-6;
InChIKey    HTRVALPKPVGOSZ-UHFFFAOYSA-N;
MW          187.217;      // g/mol [origin=calculated method=formula-sum]
Tc          856.17;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.6136;      // -   [origin=predictive method=lee-kesler]
Tb          609.28;      // K   [origin=predictive method=joback]
HvapTb      58006.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.65 0.9407 -0.00061712 1.494e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACNH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-fluorophenyl)aniline" "4'-fluoro-4-aminobiphenyl" "4'-fluoro-4-aminodiphenyl" "4-amino-4'-fluorodiphenyl" "4'-fluoro-biphenyl-4-ylamine" "4-(p-fluorophenyl)aniline" "4'-fluoro-4-biphenylamine" "4'-fluorobiphenyl-4-amine" "4-biphenylamine, 4'-fluoro-" "4'-fluorobiphenyl-4-ylamine" "4'-fluoro-[1,1'-biphenyl]-4-amine" "4-(4-fluorophenyl)phenylamine" );
gibbsFormation
{
    dHf_298   -3210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127360.0
    phase     gas;
}
