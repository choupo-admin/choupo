/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-chloro-1-hexene  (C6H11Cl, CAS 928-89-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Chloro1Hexene;
formula     C6H11Cl;
CAS         928-89-2;
InChIKey    BLMIXWDJHNJWDT-UHFFFAOYSA-N;
MW          118.604;      // g/mol [origin=calculated method=formula-sum]
Tc          546.96;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       0.3396;      // -   [origin=predictive method=lee-kesler]
Tb          370.99;      // K   [origin=predictive method=joback]
HvapTb      32665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.334 0.5606 -0.0003459 8.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH2; count 1; } { group dCH; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-chloranylhex-1-ene" "6-chlorohex-1-ene" "1-hexene, 6-chloro-" );
standardThermochemistry
{
    dHf_298   -57480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75550.0
}
