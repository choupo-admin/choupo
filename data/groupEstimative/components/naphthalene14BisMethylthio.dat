/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, 1,4-bis(methylthio)-  (C12H12S2, CAS 10075-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthalene14BisMethylthio;
formula     C12H12S2;
CAS         10075-73-7;
InChIKey    ZYYGYYVWYHXYOF-UHFFFAOYSA-N;
MW          220.348;      // g/mol [origin=calculated method=formula-sum]
Tc          937.58;      // K   [origin=predictive method=joback]
Pc          31.210;      // bar [origin=predictive method=joback]
omega       0.5809;      // -   [origin=predictive method=lee-kesler]
Tb          667.34;      // K   [origin=predictive method=joback]
HvapTb      61180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.57 0.93102 -0.00058244 1.332e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group CH3S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(methylsulfanyl)naphthalene" );
gibbsFormation
{
    dHf_298   197390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316200.0
    phase     gas;
}
