/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-acetylpiperidine  (C7H13NO, CAS 618-42-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Acetylpiperidine;
formula     C7H13NO;
CAS         618-42-8;
InChIKey    KDISMIMTGUMORD-UHFFFAOYSA-N;
MW          127.187;      // g/mol [origin=calculated method=formula-sum]
Tc          651.43;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       0.4620;      // -   [origin=predictive method=lee-kesler]
Tb          446.02;      // K   [origin=predictive method=joback]
HvapTb      40531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.23 0.92292 -0.0006337 1.6816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-piperidin-1-ylethanone" "piperidine, 1-acetyl-" "n-acetylpiperidin" "acetic acid, piperidide" "n-acetylpiperidine" "ethanone, 1-(1-piperidinyl)-" "methyl 1-piperidyl ketone" "1-(piperidin-1-yl)ethanone" "1-(1-piperidinyl)ethanone" "1-piperidin-1-yl-ethanone" "n-acetylpiperidin [german]" "n-acetyl piperidine" );
gibbsFormation
{
    dHf_298   -152040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=34180.0
    phase     gas;
}
