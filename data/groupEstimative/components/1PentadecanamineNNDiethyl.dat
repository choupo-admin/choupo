/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pentadecanamine, n,n-diethyl-  (C19H41N, CAS 36555-73-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PentadecanamineNNDiethyl;
formula     C19H41N;
CAS         36555-73-4;
InChIKey    BICPURLNGRQXAV-UHFFFAOYSA-N;
MW          283.544;      // g/mol [origin=calculated method=formula-sum]
Tc          806.24;      // K   [origin=predictive method=joback]
Pc          10.792;      // bar [origin=predictive method=joback]
omega       0.8388;      // -   [origin=predictive method=lee-kesler]
Tb          646.76;      // K   [origin=predictive method=joback]
HvapTb      59931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.074 1.93276 -0.0011224 2.523e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 15; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-diethylpentadecan-1-amine" "agn-pc-00p0ix" );
gibbsFormation
{
    dHf_298   -367960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     912.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219880.0
    phase     gas;
}
