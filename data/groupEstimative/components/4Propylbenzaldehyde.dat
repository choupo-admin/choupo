/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-propylbenzaldehyde  (C10H12O, CAS 28785-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H12O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Propylbenzaldehyde;
formula     C10H12O;
CAS         28785-06-0;
InChIKey    MAUCRURSQMOFGV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          641.41;      // K   [origin=predictive method=joback]
Pc          30.256;      // bar [origin=predictive method=joback]
omega       0.3412;      // -   [origin=predictive method=lee-kesler]
Tb          436.48;      // K   [origin=predictive method=joback]
HvapTb      38419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.308 0.82352 -0.00063736 2.051e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-n-propylbenzaldehyde" "benzaldehyde, 4-propyl-" "p-propylbenzaldehyde" "4-propylbenzaldehyd" "benzaldehyde, p-propyl-" "4-propyl-benzaldehyde" "p-propyl-benzaldehyde, e" "benzaldehyde,p-propyl- (8ci); 4-(n-propyl)benzaldehyde; 4-propylbenzaldehyde;p-propylbenzaldehyde" );
gibbsFormation
{
    dHf_298   51780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180060.0
    phase     gas;
}
