name        brn2454368;
formula     C16H14O;
CAS         6809-95-6;
InChIKey    MWRCQJJQFQLAJJ-UHFFFAOYSA-N;
MW          222.287;      // g/mol [origin=calculated method=formula-sum]
Tc          926.15;      // K   [origin=predictive method=joback]
Pc          26.598;      // bar [origin=predictive method=joback]
omega       0.7022;      // -   [origin=predictive method=lee-kesler]
Tb          680.36;      // K   [origin=predictive method=joback]
HvapTb      62911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-102.929 1.439 -0.00108986 3.2546e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(7-bicyclo[4.2.0]octa-1,3,5-trienyl)-2-phenyl-ethanone" "bicyclo[4.2.0]octa-1,3,5-trien-7-yl benzyl ketone" "benzyl bicyclo(4.2.0)octa-1,3,5-trien-7-yl ketone" "bicyclo(4.2.0)octa-1,3,5-trien-7-yl benzyl ketone" "ketone, bicyclo(4.2.0)octa-1,3,5-trien-7-yl benzyl" "1-(7-bicyclo[4.2.0]octa-1,3,5-trienyl)-2-phenylethanone" );
gibbsFormation
{
    dHf_298   54400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=242960.0
    phase     gas;
}
