/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxyphenethylamine  (C10H15NO, CAS 39590-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethoxyphenethylamine;
formula     C10H15NO;
CAS         39590-27-7;
InChIKey    VDSGSZWDSYFYCJ-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          769.56;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       0.6441;      // -   [origin=predictive method=lee-kesler]
Tb          555.01;      // K   [origin=predictive method=joback]
HvapTb      53843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.183 0.81412 -0.00041676 6.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-ethoxyphenyl)ethanamine" "benzeneethanamine,2-ethoxy-" "2-(2-ethoxyphenyl)ethan-1-amine" );
gibbsFormation
{
    dHf_298   -123100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=97550.0
    phase     gas;
}
