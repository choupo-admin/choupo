/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hexen-2-one  (C6H10O, CAS 109-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hexen2One;
formula     C6H10O;
CAS         109-49-9;
InChIKey    RNDVGJZUHCKENF-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          568.84;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.4024;      // -   [origin=predictive method=lee-kesler]
Tb          387.43;      // K   [origin=predictive method=joback]
HvapTb      35026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.802 0.52582 -0.0003068 6.856e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-5-en-2-one" "allylacetone" "5-hexene-2-one" "1-hexen-5-one" "3-buten-1-yl methyl ketone" "allyl acetone" );
standardThermochemistry
{
    dHf_298   -154320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-41440.0
}
