/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene,3-cyclohexyl-  (C12H20, CAS 1808-09-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene3Cyclohexyl;
formula     C12H20;
CAS         1808-09-9;
InChIKey    KWMKLXOPDTWVIT-UHFFFAOYSA-N;
MW          164.292;      // g/mol [origin=calculated method=formula-sum]
Tc          746.99;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.3314;      // -   [origin=predictive method=lee-kesler]
Tb          512.42;      // K   [origin=predictive method=joback]
HvapTb      43456.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.45 1.332 -0.00077828 1.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group CH_ring; count 2; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-cyclohexylcyclohexene" "3-cyclohexyl-1-cyclohexene" "cyclohexene, 3-cyclohexyl-" );
standardThermochemistry
{
    dHf_298   -124590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=129020.0
}
