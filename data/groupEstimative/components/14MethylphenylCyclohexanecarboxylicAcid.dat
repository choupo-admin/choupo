/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-methylphenyl)cyclohexanecarboxylic acid  (C14H18O2, CAS 84682-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14MethylphenylCyclohexanecarboxylicAcid;
formula     C14H18O2;
CAS         84682-27-9;
InChIKey    BEVYUARQHKRBMH-UHFFFAOYSA-N;
MW          218.296;      // g/mol [origin=calculated method=formula-sum]
Tc          966.28;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.7915;      // -   [origin=predictive method=lee-kesler]
Tb          716.88;      // K   [origin=predictive method=joback]
HvapTb      66138.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.44 1.66022 -0.00138816 4.916e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-methylphenyl)cyclohexane-1-carboxylic acid" "1-(4-methylphenyl)-1-cyclohexanecarboxylic acid" "1-p-tolyl-cyclohexanecarboxylic acid" "1-(p-tolyl)cyclohexanecarboxylic acid" "cyclohexanecarboxylicacid, 1-(4-methylphenyl)-" );
standardThermochemistry
{
    dHf_298   -387940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     680.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155170.0
}
