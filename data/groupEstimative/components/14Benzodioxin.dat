/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzodioxin  (C8H6O2, CAS 255-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Benzodioxin;
formula     C8H6O2;
CAS         255-37-8;
InChIKey    HPARLNRMYDSBNO-UHFFFAOYSA-N;
MW          134.134;      // g/mol [origin=calculated method=formula-sum]
Tc          722.57;      // K   [origin=predictive method=joback]
Pc          46.657;      // bar [origin=predictive method=joback]
omega       0.4258;      // -   [origin=predictive method=lee-kesler]
Tb          483.04;      // K   [origin=predictive method=joback]
HvapTb      46046.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.87 0.7312 -0.00056424 1.69e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 6; } { group dC_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-benzodioxine" "benzodioxine" );
standardThermochemistry
{
    dHf_298   -102630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     187.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33340.0
}
