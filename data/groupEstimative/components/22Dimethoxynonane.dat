/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethoxynonane  (C11H24O2, CAS 52972-16-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethoxynonane;
formula     C11H24O2;
CAS         52972-16-4;
InChIKey    WGTYPPXGEJLTCK-UHFFFAOYSA-N;
MW          188.311;      // g/mol [origin=calculated method=formula-sum]
Tc          663.73;      // K   [origin=predictive method=joback]
Pc          19.086;      // bar [origin=predictive method=joback]
omega       0.5948;      // -   [origin=predictive method=lee-kesler]
Tb          492.89;      // K   [origin=predictive method=joback]
HvapTb      43604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.416 1.04828 -0.0005244 8.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonane, 2,2-dimethoxy-" "isononylaldehyde dimethyl acetal" "2-nonanonedimethyl acetal;2,2-dimethoxynonane;isononylaldehyde dimethyl acetal;" );
standardThermochemistry
{
    dHf_298   -543560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     568.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-165420.0
}
