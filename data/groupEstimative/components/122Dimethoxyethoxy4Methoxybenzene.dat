/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2,2-dimethoxyethoxy)-4-methoxybenzene  (C11H16O4, CAS 68426-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122Dimethoxyethoxy4Methoxybenzene;
formula     C11H16O4;
CAS         68426-08-4;
InChIKey    IXFSBZBRNIRRLO-UHFFFAOYSA-N;
MW          212.245;      // g/mol [origin=calculated method=formula-sum]
Tc          772.73;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       0.7147;      // -   [origin=predictive method=lee-kesler]
Tb          572.18;      // K   [origin=predictive method=joback]
HvapTb      52270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.601 0.66356 -9.796e-05 -9.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 3; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2,2-dimethoxyethoxy)-4-methoxy-benzene" "p-(2,2-dimethoxyethoxy)anisole" "benzene, 1-(2,2-dimethoxyethoxy)-4-methoxy-" "p-methoxyphenoxyacetaldehyde dimethylacetal" );
standardThermochemistry
{
    dHf_298   -579470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277920.0
}
