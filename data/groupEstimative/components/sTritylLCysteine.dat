/*--------------------------------*- Choupo -*-----------------------*\
  Component: s-trityl-l-cysteine  (C22H21NO2S, CAS 2799-07-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        sTritylLCysteine;
formula     C22H21NO2S;
CAS         2799-07-7;
InChIKey    DLMYFMLKORXJPO-FQEVSTJZSA-N;
MW          363.475;      // g/mol [origin=calculated method=formula-sum]
Tc          1347.12;      // K   [origin=predictive method=joback]
Pc          21.694;      // bar [origin=predictive method=joback]
omega       1.2435;      // -   [origin=predictive method=lee-kesler]
Tb          1066.15;      // K   [origin=predictive method=joback]
HvapTb      104332.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.289 2.09589 -0.0015174 4.099e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 15; } { group AC; count 3; } { group CHNH2; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group COOH; count 1; } { group NH2; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanyl-3-(triphenylmethyl)sulfanyl-propanoic acid" "s-(triphenylmethyl)-l-cysteine" "s-tritylcysteine" "3-tritylthio-l-alanine" "l-alanine, 3-(tritylthio)-" "(2r)-2-amino-3-[(triphenylmethyl)sulfanyl]propanoic acid" "alanine, 3-(tritylthio)-, l-" "zzd" "(+)-s-trityl-l-cysteine" "s-trityl-l-cysteine (stlc), 1" "l-cysteine, s-(triphenylmethyl)-," "l-cysteine, s-(triphenylmethyl)-, (9ci)" );
gibbsFormation
{
    dHf_298   -76460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     811.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=227650.0
    phase     gas;
}
