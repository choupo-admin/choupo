/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl cyclohexylacetate  (C10H18O2, CAS 5452-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylCyclohexylacetate;
formula     C10H18O2;
CAS         5452-75-5;
InChIKey    ZBDAMDWKXGTKBT-UHFFFAOYSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          708.71;      // K   [origin=predictive method=joback]
Pc          25.820;      // bar [origin=predictive method=joback]
omega       0.5118;      // -   [origin=predictive method=lee-kesler]
Tb          506.17;      // K   [origin=predictive method=joback]
HvapTb      45690.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.398 1.02112 -0.0005066 6.03e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-cyclohexylethanoate" "ethyl 2-cyclohexylacetate" "ethyl cyclohexaneacetate" "cyclohexaneacetic acid, ethyl ester" "cyclohexylacetic acid ethyl ester" "cyclohexyl acetic acid ethyl ester" "zbdamdwkxgtkbt-uhfffaoysa-" "cyclohexaneacetic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -512690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     566.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252600.0
    phase     gas;
}
