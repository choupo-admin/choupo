/*--------------------------------*- Choupo -*-----------------------*\
  Component: diiododifluoromethane  (CF2I2, CAS 1184-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diiododifluoromethane;
formula     CF2I2;
CAS         1184-76-5;
InChIKey    SOEBNUZZZSSRNB-UHFFFAOYSA-N;
MW          303.807;      // g/mol [origin=calculated method=formula-sum]
Tc          648.37;      // K   [origin=predictive method=joback]
Pc          48.971;      // bar [origin=predictive method=joback]
omega       0.1822;      // -   [origin=predictive method=lee-kesler]
Tb          404.07;      // K   [origin=predictive method=joback]
HvapTb      33636.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.07 0.3262 -0.000398 1.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group I; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group F; count 2; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(fluoranyl)-bis(iodanyl)methane" "difluorodiiodomethane" "difluoro(diiodo)methane" "difluorodiiodomethane;methane, difluorodiiodo-;difluoro(diiodo)methane;" );
standardThermochemistry
{
    dHf_298   -311200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-313000.0
}
