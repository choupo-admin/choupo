/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylcyclohexanamine;2-[(e)-dodec-1-enyl]butanedioic acid  (C32H62N2O4, CAS 65166-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylcyclohexanamine2EDodec1EnylButanedioicAcid;
formula     C32H62N2O4;
CAS         65166-20-3;
InChIKey    MHJOLFLDTOPWMP-YHPRVSEPSA-N;
MW          538.858;      // g/mol [origin=calculated method=formula-sum]
Tc          1619.80;      // K   [origin=predictive method=joback]
Pc          6.846;      // bar [origin=predictive method=joback]
omega       0.4285;      // -   [origin=predictive method=lee-kesler]
Tb          1293.28;      // K   [origin=predictive method=joback]
HvapTb      126256.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.82 3.251 -0.0015068 1.321e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 20; } { group CH; count 3; } { group CH=CH; count 1; } { group CH3N; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 10; } { group CH; count 1; } { group dCH; count 2; } { group CH2_ring; count 10; } { group CH_ring; count 2; } { group COOH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecenylsuccinic acid, compound with n,n-dimethylcyclohexylamine (1:2)" "butanedioic acid, 2-dodecenyl-, compd. with n,n-dimethylcyclohexanamine (1:2)" "succinic acid, dodecenyl-, compd. with n,n-dimethylcyclohexylamine (1:2)" );
gibbsFormation
{
    dHf_298   -1271950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1679.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-330540.0
    phase     gas;
}
