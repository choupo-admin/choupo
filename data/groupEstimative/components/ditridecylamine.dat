/*--------------------------------*- Choupo -*-----------------------*\
  Component: ditridecylamine  (C26H55N, CAS 101012-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ditridecylamine;
formula     C26H55N;
CAS         101012-97-9;
InChIKey    PZFYOFFTIYJCEW-UHFFFAOYSA-N;
MW          381.733;      // g/mol [origin=calculated method=formula-sum]
Tc          1035.14;      // K   [origin=predictive method=joback]
Pc          7.301;      // bar [origin=predictive method=joback]
omega       0.6719;      // -   [origin=predictive method=lee-kesler]
Tb          844.65;      // K   [origin=predictive method=joback]
HvapTb      79906.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.956 2.55004 -0.0014392 3.087e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 23; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 24; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-tridecyltridecan-1-amine" "1-tridecanamine, n-tridecyl-" "di(tridecyl)amine" "bis(tridecyl)amine" "di-n-tridecylamine" "tridecanamine, n-tridecyl-, branched and linear" "ditridecyl amine" "n-tridecyl-1-tridecanamine" );
standardThermochemistry
{
    dHf_298   -526500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1209.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=257430.0
}
