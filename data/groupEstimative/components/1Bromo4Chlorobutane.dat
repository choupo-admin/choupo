/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-4-chlorobutane  (C4H8BrCl, CAS 6940-78-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo4Chlorobutane;
formula     C4H8BrCl;
CAS         6940-78-9;
InChIKey    NIDSRGCVYOEDFW-UHFFFAOYSA-N;
MW          171.462;      // g/mol [origin=calculated method=formula-sum]
Tc          589.08;      // K   [origin=predictive method=joback]
Pc          40.570;      // bar [origin=predictive method=joback]
omega       0.3849;      // -   [origin=predictive method=lee-kesler]
Tb          394.71;      // K   [origin=predictive method=joback]
HvapTb      35318.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.334 0.4288 -0.0002856 7.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2Cl; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group Cl; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-4-chloranyl-butane" "butane, 1-bromo-4-chloro-" "tetramethylene chlorobromide" "1-brom-4-chlorbutan" "1-chloro-4-bromobutane" "4-bromo-1-chlorobutane" "4-bromobutyl chloride" "4-chlorobutyl bromide" );
gibbsFormation
{
    dHf_298   -115300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     396.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-14810.0
    phase     gas;
}
