/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl mandelate  (C14H20O3, CAS 5431-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexylMandelate;
formula     C14H20O3;
CAS         5431-31-2;
InChIKey    WTWKQARYVVXCNG-UHFFFAOYSA-N;
MW          236.311;      // g/mol [origin=calculated method=formula-sum]
Tc          888.01;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       1.1575;      // -   [origin=predictive method=lee-kesler]
Tb          696.56;      // K   [origin=predictive method=joback]
HvapTb      72732.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.725 1.24002 -0.000708 1.331e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 2-oxidanyl-2-phenyl-ethanoate" "mandelic acid, hexyl ester" "hexylester kyseliny mandlove" "hexyl 2-hydroxy-2-phenylacetate" "benzeneacetic acid, alpha-hydroxy-, hexyl ester" "benzeneacetic acid, alpha-hydroxy-, hexyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -570550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-270220.0
}
