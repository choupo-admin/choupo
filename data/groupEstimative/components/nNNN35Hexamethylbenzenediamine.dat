/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n',3,5-hexamethylbenzenediamine  (C12H20N2, CAS 66102-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNNN35Hexamethylbenzenediamine;
formula     C12H20N2;
CAS         66102-30-5;
InChIKey    VWQKJWSKWLGZHW-UHFFFAOYSA-N;
MW          192.306;      // g/mol [origin=calculated method=formula-sum]
Tc          738.19;      // K   [origin=predictive method=joback]
Pc          22.937;      // bar [origin=predictive method=joback]
omega       0.6040;      // -   [origin=predictive method=lee-kesler]
Tb          540.66;      // K   [origin=predictive method=joback]
HvapTb      50654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.41 1.13432 -0.00068428 1.572e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n1,n1,n2,n2,3,6-hexamethylbenzene-1,2-diamine" "1-n,1-n,2-n,2-n,3,6-hexamethylbenzene-1,2-diamine" );
gibbsFormation
{
    dHf_298   46170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355240.0
    phase     gas;
}
