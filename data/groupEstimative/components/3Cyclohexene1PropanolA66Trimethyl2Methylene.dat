/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-cyclohexene-1-propanol, |a,6,6-trimethyl-2-methylene-  (C13H22O, CAS 57069-87-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Cyclohexene1PropanolA66Trimethyl2Methylene;
formula     C13H22O;
CAS         57069-87-1;
InChIKey    MLNIJFIYPHXCKI-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          795.00;      // K   [origin=predictive method=joback]
Pc          22.806;      // bar [origin=predictive method=joback]
omega       0.8465;      // -   [origin=predictive method=lee-kesler]
Tb          602.22;      // K   [origin=predictive method=joback]
HvapTb      60243.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.908 1.49276 -0.00117008 4.073e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(6,6-dimethyl-2-methylidene-cyclohex-3-en-1-yl)butan-2-ol" "4-(6,6-dimethyl-2-methylidenecyclohex-3-en-1-yl)butan-2-ol" "3-cyclohexene-1-propanol, .alpha.,6,6-trimethyl-2-methylene-" "3-cyclohexene-1-propanol, alpha,6,6-trimethyl-2-methylene-" "alpha,6,6-trimethyl-2-methylenecyclohex-3-ene-1-propan-1-ol" );
gibbsFormation
{
    dHf_298   -277920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     636.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=13610.0
    phase     gas;
}
