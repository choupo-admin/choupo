/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,2-tribromopropane  (C3H5Br3, CAS 14476-30-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122Tribromopropane;
formula     C3H5Br3;
CAS         14476-30-3;
InChIKey    IELJYJRPJJILHQ-UHFFFAOYSA-N;
MW          280.785;      // g/mol [origin=calculated method=formula-sum]
Tc          708.18;      // K   [origin=predictive method=joback]
Pc          61.035;      // bar [origin=predictive method=joback]
omega       0.4273;      // -   [origin=predictive method=lee-kesler]
Tb          463.49;      // K   [origin=predictive method=joback]
HvapTb      40281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.261 0.52922 -0.0005254 1.987e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,2-tris(bromanyl)propane" "propane, 1,2,2-tribromo-" );
standardThermochemistry
{
    dHf_298   -35010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     387.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=20180.0
}
