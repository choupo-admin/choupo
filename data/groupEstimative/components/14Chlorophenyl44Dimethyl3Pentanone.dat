/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)-4,4-dimethyl-3-pentanone  (C13H17ClO, CAS 66346-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Chlorophenyl44Dimethyl3Pentanone;
formula     C13H17ClO;
CAS         66346-01-8;
InChIKey    ILQGIJDYSLHIOX-UHFFFAOYSA-N;
MW          224.728;      // g/mol [origin=calculated method=formula-sum]
Tc          839.00;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.6194;      // -   [origin=predictive method=lee-kesler]
Tb          616.77;      // K   [origin=predictive method=joback]
HvapTb      57305.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.758 1.20506 -0.00082106 2.1596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group CH2CO; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)-4,4-dimethyl-pentan-3-one" "3-pentanone, 1-(4-chlorophenyl)-4,4-dimethyl-" "hwg 1608-alkylketon" "4-chlorobenzyl pinacolone" "1-(4-chlorphenyl)-4,4-dimethylpentan-3-on" "1-(4-chlorophenyl)-4,4-dimethylpentan-3-one" "s698" "1-(4-chlorophenyl)-4,4-dimethylpentan-3-one;hwg 1608-alkylketon;" );
gibbsFormation
{
    dHf_298   -223660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     571.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23350.0
    phase     gas;
}
