/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-3-heptanone  (C8H16O, CAS 6137-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl3Heptanone;
formula     C8H16O;
CAS         6137-11-7;
InChIKey    MVLRILUUXLBENA-UHFFFAOYSA-N;
MW          128.215;      // g/mol [origin=calculated method=formula-sum]
Tc          615.48;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.4928;      // -   [origin=predictive method=lee-kesler]
Tb          436.07;      // K   [origin=predictive method=joback]
HvapTb      39760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.293 0.74176 -0.0003959 7.446e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylheptan-3-one" );
standardThermochemistry
{
    dHf_298   -326310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114880.0
}
