/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclooctane, (1-methylethylidene)-  (C11H20, CAS 30718-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclooctane1Methylethylidene;
formula     C11H20;
CAS         30718-63-9;
InChIKey    YJAGWWNYVGDQAH-UHFFFAOYSA-N;
MW          152.281;      // g/mol [origin=calculated method=formula-sum]
Tc          712.58;      // K   [origin=predictive method=joback]
Pc          26.245;      // bar [origin=predictive method=joback]
omega       0.3354;      // -   [origin=predictive method=lee-kesler]
Tb          490.56;      // K   [origin=predictive method=joback]
HvapTb      42029.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.49 1.10064 -0.000589 1.004e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-ylidenecyclooctane" "cyclooctane,(1-methylethylidene)-" "cyclooctane,isopropylidene- (8ci)" );
gibbsFormation
{
    dHf_298   -141790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86610.0
    phase     gas;
}
