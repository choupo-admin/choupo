/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromobenzotrifluoride  (C7H4BrF3, CAS 392-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromobenzotrifluoride;
formula     C7H4BrF3;
CAS         392-83-6;
InChIKey    RWXUNIMBRXGNEP-UHFFFAOYSA-N;
MW          225.007;      // g/mol [origin=calculated method=formula-sum]
Tc          663.45;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.4375;      // -   [origin=predictive method=lee-kesler]
Tb          452.16;      // K   [origin=predictive method=joback]
HvapTb      36802.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.09 0.7298 -0.00061356 1.955e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-(trifluoromethyl)benzene" "o-bromobenzotrifluoride" "benzene, 1-bromo-2-(trifluoromethyl)-" "1-bromo-2-(trifluoromethyl)benzene" "2-bromo-alpha,alpha,alpha-trifluorotoluene" "o-bromobenzyltrifluoride" "2-bromotrifluorotoluene" "o-(trifluoromethyl)bromobenzene" "1-bromo-2-trifluoromethyl-benzene" "2-(trifluoromethyl)bromobenzene" "2-bromo-a,a,a-trifluorotoluene" "4-bromo-3-(trifluoromethyl)benzene" );
standardThermochemistry
{
    dHf_298   -533500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-456430.0
}
