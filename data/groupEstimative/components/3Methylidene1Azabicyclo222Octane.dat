/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylidene-1-azabicyclo[2.2.2]octane  (C8H13N, CAS 22207-84-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylidene1Azabicyclo222Octane;
formula     C8H13N;
CAS         22207-84-7;
InChIKey    LWKDQGSBGMZMNO-UHFFFAOYSA-N;
MW          123.199;      // g/mol [origin=calculated method=formula-sum]
Tc          618.12;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.3736;      // -   [origin=predictive method=lee-kesler]
Tb          416.66;      // K   [origin=predictive method=joback]
HvapTb      35911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.33 1.0889 -0.000881 2.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH2=C; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-azabicyclo(2.2.2)octane, 3-methylene-" "1-azabicyclo[2.2.2]octane, 3-methylene-" "1-azabicyclo[2.2.2]octane,3-methylene-" "quinuclidine,3-methylene- (8ci); 3-methylenequinuclidine" );
gibbsFormation
{
    dHf_298   103100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     339.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=297450.0
    phase     gas;
}
