/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-1-cyclohexan-1-amine  (C8H15N, CAS 13815-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl1Cyclohexan1Amine;
formula     C8H15N;
CAS         13815-46-8;
InChIKey    YQMFWWIHWNGOEK-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          626.15;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.3528;      // -   [origin=predictive method=lee-kesler]
Tb          423.44;      // K   [origin=predictive method=joback]
HvapTb      37137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.54 0.92084 -0.00058064 1.385e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylcyclohexen-1-amine" "n,n-dimethyl-1-cyclohex-1-amine" "1-cyclohexenyl-dimethyl-amine" );
standardThermochemistry
{
    dHf_298   -19950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=179750.0
}
