/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenol, 1-silyl-2,2-bis(2,4,6-trimethylphenyl)-  (C20H26OSi, CAS 111189-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C20H26OSi (delta H+3Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        ethenol1Silyl22Bis246Trimethylphenyl;
formula     C20H26OSi;
CAS         111189-83-4;
InChIKey    HYPVLYQCKWUMBM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          310.512;      // g/mol [origin=calculated method=formula-sum]
Tc          1053.58;      // K   [origin=predictive method=joback]
Pc          16.051;      // bar [origin=predictive method=joback]
omega       1.0394;      // -   [origin=predictive method=lee-kesler]
Tb          835.84;      // K   [origin=predictive method=joback]
HvapTb      85288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.99 1.54602 -0.00105056 2.978e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group ACCH3; count 6; } { group OH; count 1; } { group C=C; count 1; } { group SiH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dC; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-silanyl-2,2-bis(2,4,6-trimethylphenyl)ethenol" );
gibbsFormation
{
    dHf_298   -50670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     882.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263240.0
    phase     gas;
}
