/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenylmalonic acid  (C9H8O4, CAS 2613-89-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenylmalonicAcid;
formula     C9H8O4;
CAS         2613-89-0;
InChIKey    WWYDYZMNFQIYPT-UHFFFAOYSA-N;
MW          180.159;      // g/mol [origin=calculated method=formula-sum]
Tc          959.87;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       1.1448;      // -   [origin=predictive method=lee-kesler]
Tb          722.78;      // K   [origin=predictive method=joback]
HvapTb      71844.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.68 0.8874 -0.0006454 1.769e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylpropanedioic acid" "2-phenylmalonic acid" "propanedioic acid, phenyl-" "phenylpropanedioc acid" "malonic acid, phenyl-" "propanedioic acid, 2-phenyl-" ".alpha.-carboxyphenylacetic acid" "toluene-.alpha.,.alpha.-dicarboxylic acid" "phenylpropanedioic acid" "2-phenyl-malonic acid" "phenyl malonic acid" "alpha-carboxyphenylacetic acid" );
standardThermochemistry
{
    dHf_298   -698380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-552950.0
}
