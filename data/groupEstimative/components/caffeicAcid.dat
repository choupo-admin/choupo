/*--------------------------------*- Choupo -*-----------------------*\
  Component: caffeic acid  (C9H8O4, CAS 331-39-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        caffeicAcid;
formula     C9H8O4;
CAS         331-39-5;
InChIKey    QAIPRVGONGVQAS-DUXPYHPUSA-N;
MW          180.159;      // g/mol [origin=calculated method=formula-sum]
Tc          993.32;      // K   [origin=predictive method=joback]
Pc          58.094;      // bar [origin=predictive method=joback]
omega       1.2881;      // -   [origin=predictive method=lee-kesler]
Tb          743.11;      // K   [origin=predictive method=joback]
HvapTb      81054.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.62 1.1599 -0.00116612 4.63e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACOH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-[3,4-bis(oxidanyl)phenyl]prop-2-enoic acid" "3,4-dihydroxycinnamic acid" "trans-caffeate" "3-(3,4-dihydroxyphenyl)acrylic acid" "cinnamic acid, 3,4-dihydroxy-" "3,4-dihydroxybenzeneacrylic acid" "2-propenoic acid, 3-(3,4-dihydroxyphenyl)-" "3,4-dihydroxy-trans-cinnamate" "(2e)-3-(3,4-dihydroxyphenyl)prop-2-enoic acid" "3-(3,4-dihydroxyphenyl)propenoic acid" "4-(2'-carboxyvinyl)-1,2-dihydroxybenzene" "4-(2-carboxyethenyl)-1,2-dihydroxybenzene" );
gibbsFormation
{
    dHf_298   -580230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-435620.0
    phase     gas;
}
