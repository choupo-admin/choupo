/*--------------------------------*- Choupo -*-----------------------*\
  Component: retinyl palmitate  (C36H60O2, CAS 79-81-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        retinylPalmitate;
formula     C36H60O2;
CAS         79-81-2;
InChIKey    VYGQUTWHTHXGQB-FFHKNEKCSA-N;
MW          524.874;      // g/mol [origin=calculated method=formula-sum]
Tc          1395.71;      // K   [origin=predictive method=joback]
Pc          5.682;      // bar [origin=predictive method=joback]
omega       0.3596;      // -   [origin=predictive method=lee-kesler]
Tb          1126.81;      // K   [origin=predictive method=joback]
HvapTb      104023.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-139.755 3.68792 -0.0026466 8.153e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 17; } { group C; count 1; } { group CH=CH; count 2; } { group CH=C; count 2; } { group CH2COO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 15; } { group dCH; count 6; } { group dC; count 2; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(2e,4e,6e,8e)-3,7-dimethyl-9-(2,6,6-trimethylcyclohexen-1-yl)nona-2,4,6,8-tetraenyl] hexadecanoate" "vitamin a palmitate" "retinol palmitate" "all-trans-retinyl palmitate" "arovit" "retinol, hexadecanoate" "aquapalm" "dispatabs tabs" "vitazyme a" "optovit a" "optovit-a" "all-trans-retinol palmitate" );
standardThermochemistry
{
    dHf_298   -549950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1564.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=275310.0
}
