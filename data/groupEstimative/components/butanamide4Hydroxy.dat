/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanamide, 4-hydroxy-  (C4H9NO2, CAS 927-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanamide4Hydroxy;
formula     C4H9NO2;
CAS         927-60-6;
InChIKey    LOESDOAIWSCMKM-UHFFFAOYSA-N;
MW          103.121;      // g/mol [origin=calculated method=formula-sum]
Tc          695.31;      // K   [origin=predictive method=joback]
Pc          51.757;      // bar [origin=predictive method=joback]
omega       1.0386;      // -   [origin=predictive method=lee-kesler]
Tb          509.70;      // K   [origin=predictive method=joback]
HvapTb      58564.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.393 0.4517 -0.0002489 4.816e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group OH; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylbutanamide" "4-hydroxybutyramide" "4-hydroxybutanamide" "4-hydroxy-butyramide" "butyramide, 4-hydroxy-" "4-hydroxybutyric acid amide" "hydroxybutyramide" "4-hydroxybutryamide" "gamma-hydroxybutyramide" ".gamma.-hydroxybutyramide" );
gibbsFormation
{
    dHf_298   -356910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216490.0
    phase     gas;
}
