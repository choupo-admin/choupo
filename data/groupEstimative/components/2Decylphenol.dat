/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-decylphenol  (C16H26O, CAS 27157-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Decylphenol;
formula     C16H26O;
CAS         27157-66-0;
InChIKey    FDIPWBUDOCPIMH-UHFFFAOYSA-N;
MW          234.383;      // g/mol [origin=calculated method=formula-sum]
Tc          872.32;      // K   [origin=predictive method=joback]
Pc          19.338;      // bar [origin=predictive method=joback]
omega       0.8986;      // -   [origin=predictive method=lee-kesler]
Tb          672.98;      // K   [origin=predictive method=joback]
HvapTb      66500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.481 1.59952 -0.00113416 3.378e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decylphenol" "phenol, 2-decyl-" );
gibbsFormation
{
    dHf_298   -314350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=41630.0
    phase     gas;
}
