/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-chloropropyl)benzene  (C9H11Cl, CAS 10304-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloropropylBenzene;
formula     C9H11Cl;
CAS         10304-81-1;
InChIKey    CKWAHIDVXZGPES-UHFFFAOYSA-N;
MW          154.637;      // g/mol [origin=calculated method=formula-sum]
Tc          688.07;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.3667;      // -   [origin=predictive method=lee-kesler]
Tb          469.19;      // K   [origin=predictive method=joback]
HvapTb      41901.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.989 0.79262 -0.0005206 1.299e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranylpropylbenzene" "2-chloropropylbenzene" "benzene, (2-chloropropyl)-" "1-phenyl-2-chloropropane" "2-chloro-1-phenylpropane" "benzene,(2-chloropropyl)-" );
standardThermochemistry
{
    dHf_298   -13580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=122940.0
}
