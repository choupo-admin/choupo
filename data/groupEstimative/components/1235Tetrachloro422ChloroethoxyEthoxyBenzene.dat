/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,5-tetrachloro-4-[2-(2-chloroethoxy)ethoxy]benzene  (C10H9Cl5O2, CAS 5335-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1235Tetrachloro422ChloroethoxyEthoxyBenzene;
formula     C10H9Cl5O2;
CAS         5335-26-2;
InChIKey    MUFFSGFNYHDFMP-UHFFFAOYSA-N;
MW          338.43;      // g/mol [origin=calculated method=formula-sum]
Tc          931.87;      // K   [origin=predictive method=joback]
Pc          22.125;      // bar [origin=predictive method=joback]
omega       0.8405;      // -   [origin=predictive method=lee-kesler]
Tb          706.99;      // K   [origin=predictive method=joback]
HvapTb      69523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (132.544 0.5445 -0.00016324 -3.09e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 1; } { group AC; count 1; } { group CH2O; count 2; } { group CH2Cl; count 1; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 5; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,5-tetrakis(chloranyl)-4-[2-(2-chloroethyloxy)ethoxy]benzene" "1-(2-chloroethoxy)-2-(2,2,4,6 tetrachlorophenoxy)ethane" "benzene,1,2,3,5-tetrachloro-4-[2-(2-chloroethoxy)ethoxy]-" "1-(2-chloroethoxy)-2-(2,4,6-tetrachlorophenoxy)ethane" );
standardThermochemistry
{
    dHf_298   -402220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-162440.0
}
