/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-diisocyanato-3,3'-dimethylbiphenyl  (C16H12N2O2, CAS 91-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Diisocyanato33Dimethylbiphenyl;
formula     C16H12N2O2;
CAS         91-97-4;
InChIKey    ICLCCFKUSALICQ-UHFFFAOYSA-N;
MW          264.284;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.76;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       0.9496;      // -   [origin=predictive method=lee-kesler]
Tb          772.30;      // K   [origin=predictive method=joback]
HvapTb      77474.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 6; } { group AC; count 4; } { group ACCH3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 2; } { group dCd; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-(4-isocyanato-3-methyl-phenyl)-2-methyl-benzene" "bitolylene diisocyanate" "3,3'-dimethyl-4,4'-biphenylene diisocyanate" "3,3'-dimethyl-4,4'-diphenylene diisocyanate" "3,3'-bitolylene-4,4'-diisocyanate" "3,3'-dimethylbiphenyl-4,4'-diyl diisocyanate" "4,4'-diisocyanato-3,3'-bitolyl" "1,1'-biphenyl, 4,4'-diisocyanato-3,3'-dimethyl-" "3,3'-dimethylbiphenyl 4,4'-diisocyanate" "3,3'-dimethyl-4,4'-biphenylene isocyanate" "3,3'-dimethyl-4,4'-biphenylylene diisocyanate" "isocyanic acid, 3,3'-dimethyl-4,4'-biphenylene ester" );
