/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4(10)-thujen-3-ol, (1s,3r,5s)-(+)-  (C10H16O, CAS 59905-55-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        410Thujen3Ol1s3r5s;
formula     C10H16O;
CAS         59905-55-4;
InChIKey    MDFQXBNVOAKNAY-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          720.87;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.7726;      // -   [origin=predictive method=lee-kesler]
Tb          528.35;      // K   [origin=predictive method=joback]
HvapTb      52670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.84 1.44344 -0.001379 5.564e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 3; } { group C; count 1; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methylidene-1-propan-2-yl-bicyclo[3.1.0]hexan-3-ol" "bicyclo[3.1.0]hexan-3-ol, 4-methylene-1-(1-methylethyl)-, [1s-(1.alpha.,3.beta.,5.alpha.)]-" "(1s,3r,5s)-4-methylidene-1-propan-2-ylbicyclo[3.1.0]hexan-3-ol" "bicyclo[3.1.0]hexan-3-ol, 4-methylene-1-(1-methylethyl)-, (1s,3r,5s)-" "4(10)-thujen-3-ol, stereoisomer" "2-methylidene-5-propan-2-ylbicyclo[3.1.0]hexan-3-ol" "bicyclo[3.1.0]hexan-3-ol, 4-methylene-1-(1-methylethyl)-" "bicyclo[3.1.0]hexan-3-ol, 4-methylene-1-(1-methylethyl)-, (1.alpha.,3.alpha.,5.alpha.)-" );
gibbsFormation
{
    dHf_298   -182500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     407.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55440.0
    phase     gas;
}
