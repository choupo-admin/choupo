/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-benzenediamine,2,5-dichloro-3,6-dimethyl-  (C8H10Cl2N2, CAS 40200-66-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Benzenediamine25Dichloro36Dimethyl;
formula     C8H10Cl2N2;
CAS         40200-66-6;
InChIKey    WQBSENUQIHTWTB-UHFFFAOYSA-N;
MW          205.082;      // g/mol [origin=calculated method=formula-sum]
Tc          899.20;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       0.7771;      // -   [origin=predictive method=lee-kesler]
Tb          654.14;      // K   [origin=predictive method=joback]
HvapTb      69040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (71.97 0.52484 -0.000235 2.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH3; count 2; } { group ACNH2; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC_ring; count 6; } { group Cl; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-bis(chloranyl)-3,6-dimethyl-benzene-1,4-diamine" "2,5-dichloro-3,6-dimethylbenzene-1,4-diamine" );
gibbsFormation
{
    dHf_298   6830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=189780.0
    phase     gas;
}
