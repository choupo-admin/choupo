/*--------------------------------*- Choupo -*-----------------------*\
  Component: alternariol monomethyl ether  (C15H12O5, CAS 26894-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alternariolMonomethylEther;
formula     C15H12O5;
CAS         26894-49-5;
InChIKey    LCSDQFNUYFTXMT-UHFFFAOYSA-N;
MW          272.256;      // g/mol [origin=calculated method=formula-sum]
Tc          1099.43;      // K   [origin=predictive method=joback]
Pc          35.347;      // bar [origin=predictive method=joback]
omega       1.4147;      // -   [origin=predictive method=lee-kesler]
Tb          856.56;      // K   [origin=predictive method=joback]
HvapTb      91735.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.11 1.43044 -0.00130836 4.902e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 5; } { group ACCH3; count 1; } { group ACOH; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-methoxy-1-methyl-3,7-bis(oxidanyl)benzo[c]chromen-6-one" "djalonensone" "alternariol-9-methyl ether" "alternariol methyl ether" "alternariol monomethylether" "3,7-dihydroxy-9-methoxy-1-methyl-6h-dibenzo(b,d)pyran-6-one" "6h-dibenzo(b,d)pyran-6-one, 3,7-dihydroxy-9-methoxy-1-methyl-" "alternariol 5-o-methyl ether" "3,7-dihydroxy-9-methoxy-1-methylbenzo[c]chromen-6-one" "3,7-dihydroxy-9-methoxy-1-methyl-6h-benzo[c]chromen-6-one" "alternariol monomethyl ether from alternaria alternata (tenuis)" "2-biphenylcarboxylic acid, 2',3',4'-trihydroxy-5-methoxy-6'-methyl-, delta-lactone" );
gibbsFormation
{
    dHf_298   -618250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-358130.0
    phase     gas;
}
