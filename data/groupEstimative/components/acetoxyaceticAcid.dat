/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetoxyacetic acid  (C4H6O4, CAS 13831-30-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetoxyaceticAcid;
formula     C4H6O4;
CAS         13831-30-6;
InChIKey    MLXDUYUQINCFFV-UHFFFAOYSA-N;
MW          118.088;      // g/mol [origin=calculated method=formula-sum]
Tc          694.11;      // K   [origin=predictive method=joback]
Pc          43.974;      // bar [origin=predictive method=joback]
omega       0.7509;      // -   [origin=predictive method=lee-kesler]
Tb          494.85;      // K   [origin=predictive method=joback]
HvapTb      49069.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.261 0.37982 -0.0001718 7.3e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3COO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-acetyloxyethanoic acid" "2-acetoxyacetic acid" "2-acetyloxyacetic acid" "glycolic acid, acetate" "acetic acid, (acetyloxy)-" "(acetyloxy)acetic acid" "substrate analogue, 13" "acetic acid,2-(acetyloxy)-" "o325" );
gibbsFormation
{
    dHf_298   -793440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-671480.0
    phase     gas;
}
