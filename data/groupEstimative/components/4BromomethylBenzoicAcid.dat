/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(bromomethyl)benzoic acid  (C8H7BrO2, CAS 6232-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4BromomethylBenzoicAcid;
formula     C8H7BrO2;
CAS         6232-88-8;
InChIKey    CQQSQBRPAJSTFB-UHFFFAOYSA-N;
MW          215.046;      // g/mol [origin=calculated method=formula-sum]
Tc          868.40;      // K   [origin=predictive method=joback]
Pc          43.742;      // bar [origin=predictive method=joback]
omega       0.8236;      // -   [origin=predictive method=lee-kesler]
Tb          625.97;      // K   [origin=predictive method=joback]
HvapTb      59939.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.199 0.7144 -0.00051956 1.467e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromomethylbenzoic acid" "alpha-bromo-p-toluic acid" "benzoic acid, 4-(bromomethyl)-" "p-(bromomethyl)benzoic acid" "4-bromomethyl benzoic acid" ".alpha.-bromo-p-toluic acid" "alpha-bromotoluic acid" "4-carboxybenzyl bromide" "a-bromo-p-toluic acid" "4-bromomethyl-benzoic acid" "p-toluic acid, alpha-bromo-" "a-bromo-p-toluic acid" );
gibbsFormation
{
    dHf_298   -307330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     459.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210330.0
    phase     gas;
}
