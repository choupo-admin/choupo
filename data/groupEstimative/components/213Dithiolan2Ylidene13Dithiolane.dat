/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1,3-dithiolan-2-ylidene)-1,3-dithiolane  (C6H8S4, CAS 24719-68-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        213Dithiolan2Ylidene13Dithiolane;
formula     C6H8S4;
CAS         24719-68-4;
InChIKey    AXNVPCNWUNJLRI-UHFFFAOYSA-N;
MW          208.37;      // g/mol [origin=calculated method=formula-sum]
Tc          885.68;      // K   [origin=predictive method=joback]
Pc          52.056;      // bar [origin=predictive method=joback]
omega       0.3568;      // -   [origin=predictive method=lee-kesler]
Tb          577.22;      // K   [origin=predictive method=joback]
HvapTb      54946.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.75 0.77284 -0.0005962 1.852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C=C; count 1; } { group CH2S; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dC_ring; count 2; } { group S_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dithiolane, 2-(1,3-dithiolan-2-ylidene)-" );
gibbsFormation
{
    dHf_298   210350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=258300.0
    phase     gas;
}
