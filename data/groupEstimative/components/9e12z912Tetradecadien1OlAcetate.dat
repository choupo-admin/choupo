/*--------------------------------*- Choupo -*-----------------------*\
  Component: (9e,12z)-9,12-tetradecadien-1-ol acetate  (C16H28O2, CAS 30507-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9e12z912Tetradecadien1OlAcetate;
formula     C16H28O2;
CAS         30507-70-1;
InChIKey    ZZGJZGSVLNSDPG-UHFFFAOYSA-N;
MW          252.398;      // g/mol [origin=calculated method=formula-sum]
Tc          807.67;      // K   [origin=predictive method=joback]
Pc          14.294;      // bar [origin=predictive method=joback]
omega       0.8205;      // -   [origin=predictive method=lee-kesler]
Tb          632.22;      // K   [origin=predictive method=joback]
HvapTb      58533.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.611 1.50904 -0.0009196 2.169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH=CH; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group dCH; count 4; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradeca-9,12-dienyl ethanoate" "9,12-tetradecadien-1-ol, 1-acetate, (9e,12z)-" "9,12-tetradecadien-1-ol, 1-acetate, (9z,12e)-" "agn-pc-00jy8a" "tetradeca-9,12-dienyl acetate" "[(9z,12z)-tetradeca-9,12-dienyl] acetate" );
standardThermochemistry
{
    dHf_298   -456410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66090.0
}
