/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexahydroazocine-5-one, 1-ethyl-  (C9H17NO, CAS 37727-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexahydroazocine5One1Ethyl;
formula     C9H17NO;
CAS         37727-90-5;
InChIKey    BJYGRXJOOASJTR-UHFFFAOYSA-N;
MW          155.241;      // g/mol [origin=calculated method=formula-sum]
Tc          736.43;      // K   [origin=predictive method=joback]
Pc          31.350;      // bar [origin=predictive method=joback]
omega       0.4781;      // -   [origin=predictive method=lee-kesler]
Tb          514.27;      // K   [origin=predictive method=joback]
HvapTb      42828.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.219 0.95342 -0.0004244 2.82e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2CO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 6; } { group CdO_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethylazocan-5-one" );
standardThermochemistry
{
    dHf_298   -230760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     475.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=33150.0
}
