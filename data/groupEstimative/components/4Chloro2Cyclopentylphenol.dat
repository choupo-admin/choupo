/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-2-cyclopentylphenol  (C11H13ClO, CAS 13347-42-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro2Cyclopentylphenol;
formula     C11H13ClO;
CAS         13347-42-7;
InChIKey    LZUKCYHMVDGDBK-UHFFFAOYSA-N;
MW          196.674;      // g/mol [origin=calculated method=formula-sum]
Tc          869.18;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.6243;      // -   [origin=predictive method=lee-kesler]
Tb          616.27;      // K   [origin=predictive method=joback]
HvapTb      60674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.23 1.2035 -0.00094292 3.019e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 3; } { group ACCH; count 1; } { group ACOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2-cyclopentyl-phenol" "dowicide 9" "dowicide 9 (obs.)" "phenol, 4-chloro-2-cyclopentyl-" "2-cyclopentyl-p-chlorophenol" "4-chloro-2-cyclopentyl phenol" "4-chloro-2-cyclopentyl-phenol" "phenol,4-chloro-2-cyclopentyl-" "2-cyclopentyl-4-chlorophenol" "2-cyclopentyl-4-chlorophenol;4-chloro-2-cyclopentylphenol; dowicide 9" );
gibbsFormation
{
    dHf_298   -177880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14520.0
    phase     gas;
}
