/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylcyclohexylamine  (C8H17N, CAS 98-94-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylcyclohexylamine;
formula     C8H17N;
CAS         98-94-2;
InChIKey    SVYKKECYCPFKGB-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          613.33;      // K   [origin=predictive method=joback]
Pc          31.456;      // bar [origin=predictive method=joback]
omega       0.3281;      // -   [origin=predictive method=lee-kesler]
Tb          414.63;      // K   [origin=predictive method=joback]
HvapTb      35874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.68 1.00984 -0.000605 1.31e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethylcyclohexanamine" "cyclohexyldimethylamine" "polycat 8" "n-cyclohexyldimethylamine" "cyclohexanamine, n,n-dimethyl-" "dimethylcyclohexylamine" "(dimethylamino)cyclohexane" "n,n-dimethyl-n-cyclohexylamine" "cyclohexylamine, n,n-dimethyl-" "n,n-dimethylaminocyclohexane" "dimethylaminocyclohexane" "dimethylcyclicsiloxane hydrolyzate" );
gibbsFormation
{
    dHf_298   -86600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151710.0
    phase     gas;
}
