/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-chloroethoxy)-3-methyl-1-butene  (C7H13ClO, CAS 56798-14-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Chloroethoxy3Methyl1Butene;
formula     C7H13ClO;
CAS         56798-14-2;
InChIKey    JBPGDBXWROOKKP-UHFFFAOYSA-N;
MW          148.63;      // g/mol [origin=calculated method=formula-sum]
Tc          598.65;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.4027;      // -   [origin=predictive method=lee-kesler]
Tb          415.73;      // K   [origin=predictive method=joback]
HvapTb      36993.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.552 0.59824 -0.0002948 4.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group CH2O; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-chloroethyloxy)-3-methyl-but-1-ene" "2-(2-chloroethoxy)-3-methylbut-1-ene" );
gibbsFormation
{
    dHf_298   -225410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32020.0
    phase     gas;
}
