/*--------------------------------*- Choupo -*-----------------------*\
  Component: |a-methylbicyclo(2.2.1)heptane-2-propanol  (C11H20O, CAS 67969-64-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aMethylbicyclo221Heptane2Propanol;
formula     C11H20O;
CAS         67969-64-6;
InChIKey    WSDRMOFXYSCZJK-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          744.07;      // K   [origin=predictive method=joback]
Pc          27.070;      // bar [origin=predictive method=joback]
omega       0.8393;      // -   [origin=predictive method=lee-kesler]
Tb          556.10;      // K   [origin=predictive method=joback]
HvapTb      56060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.168 1.35442 -0.0009468 2.695e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 4; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(3-bicyclo[2.2.1]heptanyl)-2-methyl-propan-1-ol" "beta-methylbicyclo(2.2.1)heptane-2-propanol" "bicyclo(2.2.1)heptane-2-propanol, beta-methyl-" "bicyclo[2.2.1]heptane-2-propanol, .beta.-methyl-" "2-methyl-3-(bicyclo(2.2.1)hept-2-yl)-1-propanol" "3-(3-bicyclo[2.2.1]heptanyl)-2-methylpropan-1-ol" );
standardThermochemistry
{
    dHf_298   -308780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4170.0
}
