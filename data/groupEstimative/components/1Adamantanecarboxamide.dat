/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-adamantanecarboxamide  (C11H17NO, CAS 5511-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Adamantanecarboxamide;
formula     C11H17NO;
CAS         5511-18-2;
InChIKey    CKBZJTAMRPPVSR-UHFFFAOYSA-N;
MW          179.263;      // g/mol [origin=calculated method=formula-sum]
Tc          836.25;      // K   [origin=predictive method=joback]
Pc          33.529;      // bar [origin=predictive method=joback]
omega       0.6399;      // -   [origin=predictive method=lee-kesler]
Tb          597.74;      // K   [origin=predictive method=joback]
HvapTb      55918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-193.16 1.7912 -0.0016907 6.5946e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 3; } { group C_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "adamantane-1-carboxamide" "adamantanecarboxamide" "tricyclo[3.3.1.1~3,7~]decane-1-carboxamide" "2-carbamoyladamantane" "ambap5511-18-2" "adamantane-1-carboxylic acid amide" "tricyclo(3.3.1.13,7)decane-1-carboxamide" "tricyclo(3.3.1.1(sup 3,7))decane-1-carboxamide" "tricyclo(3.3.1.1(sup 3,7))decane-1-carboxamide (9ci)" );
gibbsFormation
{
    dHf_298   -142020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136220.0
    phase     gas;
}
