/*--------------------------------*- Choupo -*-----------------------*\
  Component: chlorendic acid  (C9H4Cl6O4, CAS 115-28-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        chlorendicAcid;
formula     C9H4Cl6O4;
CAS         115-28-6;
InChIKey    DJKGDNKYTKCJKD-UHFFFAOYSA-N;
MW          388.827;      // g/mol [origin=calculated method=formula-sum]
Tc          1200.63;      // K   [origin=predictive method=joback]
Pc          30.899;      // bar [origin=predictive method=joback]
omega       1.3116;      // -   [origin=predictive method=lee-kesler]
Tb          934.70;      // K   [origin=predictive method=joback]
HvapTb      93500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-120.13 1.9146 -0.0024122 1.1384e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group COOH; count 2; } { group CCl2; count 1; } { group Cl_C=C_; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:2
    joback ( { group CH_ring; count 2; } { group C_ring; count 3; } { group dC_ring; count 2; } { group Cl; count 6; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,7,7-hexakis(chloranyl)bicyclo[2.2.1]hept-2-ene-5,6-dicarboxylic acid" "het acid" "1,4,5,6,7,7-hexachlorobicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid" "kyselina het" "chlorendic acid (van)" "hexachloro-endo-methylenetetrahydrophthalic acid" "1,4,5,6,7,7-hexachloro-5-norbornene-2,3-dicarboxylic acid" "hexachloroendomethylenetetrahydrophthalic acid" "5-norbornene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-" "bicyclo[2.2.1]hept-5-ene-2,3-dicarboxylic acid, 1,4,5,6,7,7-hexachloro-" "1,4,5,6,7,7-hexachlorbicyclo[2.2.1]hept-5-en-2,3-dicarbons" "1,4,5,6,7,7-hexachlorobicyclo(2.2.1)-5-heptene-2,3-dicarboxylic acid" );
standardThermochemistry
{
    dHf_298   -865090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     684.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-654000.0
}
