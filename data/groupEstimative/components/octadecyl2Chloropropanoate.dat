/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecyl 2-chloropropanoate  (C21H41ClO2, CAS 88104-31-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecyl2Chloropropanoate;
formula     C21H41ClO2;
CAS         88104-31-8;
InChIKey    YQCZLISEEYFBDQ-UHFFFAOYSA-N;
MW          361.007;      // g/mol [origin=calculated method=formula-sum]
Tc          953.10;      // K   [origin=predictive method=joback]
Pc          9.421;      // bar [origin=predictive method=joback]
omega       0.8684;      // -   [origin=predictive method=lee-kesler]
Tb          775.29;      // K   [origin=predictive method=joback]
HvapTb      73744.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.417 1.95674 -0.0010476 1.901e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 17; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 17; } { group CH; count 1; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecyl 2-chloranylpropanoate" "2- chloropropionic acid, octadecyl ester" "propanoic acid, 2-chloro-, octadecyl ester" );
gibbsFormation
{
    dHf_298   -815070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1049.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-198800.0
    phase     gas;
}
