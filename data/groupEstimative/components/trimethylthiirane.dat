/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylthiirane  (C5H10S, CAS 53971-47-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylthiirane;
formula     C5H10S;
CAS         53971-47-4;
InChIKey    TWNJQGQIVBDVAB-UHFFFAOYSA-N;
MW          102.195;      // g/mol [origin=calculated method=formula-sum]
Tc          570.03;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.2077;      // -   [origin=predictive method=lee-kesler]
Tb          364.14;      // K   [origin=predictive method=joback]
HvapTb      30989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.13 0.90957 -0.0009643 4.262e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3-trimethylthiirane" "thiirane, trimethyl-" "thiirane,2,2,3-trimethyl-" "butane,2,3-epithio-2-methyl- (7ci); thiirane, trimethyl- (9ci); trimethylethylenesulfide" );
standardThermochemistry
{
    dHf_298   -33570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     337.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=78630.0
}
