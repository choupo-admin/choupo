/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,2,2,3,4,4,5,5,6-decafluoro-3,6-bis(trifluoromethyl)cyclohexane  (C8F16, CAS 374-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1122344556Decafluoro36BisTrifluoromethylCyclohexane;
formula     C8F16;
CAS         374-77-6;
InChIKey    LYMIGLGNHPPIQP-UHFFFAOYSA-N;
MW          400.056;      // g/mol [origin=calculated method=formula-sum]
Tc          485.51;      // K   [origin=predictive method=joback]
Pc          17.985;      // bar [origin=predictive method=joback]
omega       0.5908;      // -   [origin=predictive method=lee-kesler]
Tb          362.14;      // K   [origin=predictive method=joback]
HvapTb      9716.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-291.73 2.9452 -0.004017 1.974e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF3; count 2; } { group CF2; count 4; } { group CF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group C_ring; count 6; } { group F; count 16; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,4,4,5,5,6-decakis(fluoranyl)-3,6-bis(trifluoromethyl)cyclohexane" "perfluoro(1,4-dimethylcyclohexane)" "s060" "perfluoro(1,4-dimethylcyclohexane), (p-pdmch)" "cyclohexane,1,1,2,2,3,4,4,5,5,6-decafluoro-3,6-bis(trifluoromethyl)-" "cyclohexane,1,2,2,3,4,4,5,5,6-decafluoro-3,6-bis(trifluoromethyl)-" );
gibbsFormation
{
    dHf_298   -3319650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1071.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3141840.0
    phase     gas;
}
