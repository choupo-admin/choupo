/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-amino-4-methylcoumarin  (C10H9NO2, CAS 26093-31-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Amino4Methylcoumarin;
formula     C10H9NO2;
CAS         26093-31-2;
InChIKey    GLNDAGDHSLMOKX-UHFFFAOYSA-N;
MW          175.187;      // g/mol [origin=calculated method=formula-sum]
Tc          839.46;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.7564;      // -   [origin=predictive method=lee-kesler]
Tb          607.07;      // K   [origin=predictive method=joback]
HvapTb      60506.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.59 0.83452 -0.00060836 1.741e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-azanyl-4-methyl-chromen-2-one" "4-methyl-7-aminocoumarin" "7-amino-4-methyl-2h-chromen-2-one" "2h-1-benzopyran-2-one, 7-amino-4-methyl-" "coumarin, 7-amino-4-methyl-" "7-amino-4-methylchromen-2-one" "mcm" "7-amino-4-methylcoumarin (amc)" "sdccgmls-0028516.p002" "7-amino-4-methyl-chromen-2-one" "l872" "7-amino-4-methyl-2h-chromen-2-one; 2h-1-benzopyran-2-one, 7-amino-4-methyl-" );
gibbsFormation
{
    dHf_298   -174020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16560.0
    phase     gas;
}
