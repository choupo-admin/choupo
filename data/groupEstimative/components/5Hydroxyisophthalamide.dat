/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-hydroxyisophthalamide  (C8H8N2O3, CAS 68052-43-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Hydroxyisophthalamide;
formula     C8H8N2O3;
CAS         68052-43-7;
InChIKey    DAKUZVFMMZMWMT-UHFFFAOYSA-N;
MW          180.163;      // g/mol [origin=calculated method=formula-sum]
Tc          1002.52;      // K   [origin=predictive method=joback]
Pc          60.940;      // bar [origin=predictive method=joback]
omega       1.2853;      // -   [origin=predictive method=lee-kesler]
Tb          747.72;      // K   [origin=predictive method=joback]
HvapTb      84128.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.21 0.8478 -0.00068132 2.2162e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-oxidanylbenzene-1,3-dicarboxamide" "5-hydroxybenzene-1,3-dicarboxamide" "1,3-benzenedicarboxamide, 5-hydroxy-" "5-hydroxyisophthaldiamide" );
standardThermochemistry
{
    dHf_298   -318280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-160300.0
}
