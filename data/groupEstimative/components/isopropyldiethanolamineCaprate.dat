/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyldiethanolamine caprate  (C17H37NO4, CAS 67939-86-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropyldiethanolamineCaprate;
formula     C17H37NO4;
CAS         67939-86-0;
InChIKey    ZASLDYNTECQJSD-UHFFFAOYSA-N;
MW          319.486;      // g/mol [origin=calculated method=formula-sum]
Tc          1143.94;      // K   [origin=predictive method=joback]
Pc          14.144;      // bar [origin=predictive method=joback]
omega       1.2476;      // -   [origin=predictive method=lee-kesler]
Tb          931.83;      // K   [origin=predictive method=joback]
HvapTb      105907.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.062 1.66126 -0.0007354 5.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 1; } { group OH; count 2; } { group CH2N; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 1; } { group OH; count 2; } { group COOH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanoic acid;2-[2-hydroxyethyl(propan-2-yl)amino]ethanol" "decanoic acid compd. with 2,2'-[(1-methylethyl)imino]bis[ethanol] (1:1)" "decanoic acid isopropyldiethanolamine salt" "decanoic acid - 2,2'-(propan-2-ylimino)diethanol (1:1)" "decanoic acid; 2-[2-hydroxyethyl(propan-2-yl)amino]ethanol" "decanoic acid, compound with 2,2'-(isopropylimino)diethanol (1:1)" "decanoic acid, compd. with 2,2'-((1-methylethyl)imino)bis(ethanol) (1:1)" );
standardThermochemistry
{
    dHf_298   -1098310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1087.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-521710.0
}
