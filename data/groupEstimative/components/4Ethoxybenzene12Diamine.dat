/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-ethoxybenzene-1,2-diamine  (C8H12N2O, CAS 1197-37-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethoxybenzene12Diamine;
formula     C8H12N2O;
CAS         1197-37-1;
InChIKey    KLLREYQZEOLXHA-UHFFFAOYSA-N;
MW          152.197;      // g/mol [origin=calculated method=formula-sum]
Tc          818.84;      // K   [origin=predictive method=joback]
Pc          39.655;      // bar [origin=predictive method=joback]
omega       0.7356;      // -   [origin=predictive method=lee-kesler]
Tb          586.76;      // K   [origin=predictive method=joback]
HvapTb      60694.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.791 0.62652 -0.00028432 2.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-diaminophenetole" "1,2-benzenediamine, 4-ethoxy-" "1,2-diamino-4-ethoxybenzene" "4-ethoxy-1,2-phenylenediamine" "4-ethoxy-1,2-benzenediamine" "o-phenylenediamine, 4-ethoxy-" "1,2-benzenediamine,4-ethoxy-" "4-ethoxy-benzene-1,2-diamine" "2-amino-4-ethoxyphenylamine" "4-ethoxy-1,2-diaminobenzene" "o-phenylenediamine,4-ethoxy- (6ci,7ci,8ci);1,2-diamino-4-ethoxybenzene;3,4-diaminophenetole;4-ethoxy-1,2-benzenediamine;4-ethoxy-1,2-phenylenediamine;4-ethoxy-o-phenylenediamine;" );
standardThermochemistry
{
    dHf_298   -59500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=137530.0
}
