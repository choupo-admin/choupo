/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-dimethylaminoethyl 2-methylprop-2-enoate; 2-methylpropyl prop-2-enoate  (C15H27NO4, CAS 68227-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Dimethylaminoethyl2Methylprop2Enoate2MethylpropylProp2Enoat;
formula     C15H27NO4;
CAS         68227-09-8;
InChIKey    WSSRNRLMKOBGQZ-UHFFFAOYSA-N;
MW          285.384;      // g/mol [origin=calculated method=formula-sum]
Tc          848.35;      // K   [origin=predictive method=joback]
Pc          14.337;      // bar [origin=predictive method=joback]
omega       0.8478;      // -   [origin=predictive method=lee-kesler]
Tb          665.88;      // K   [origin=predictive method=joback]
HvapTb      64487.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (62.843 1.2028 -0.0003521 -9.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH3N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethyl 2-methylprop-2-enoate;2-methylpropyl prop-2-enoate" "2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, polymer with 2-methylpropyl 2-propenoate" );
gibbsFormation
{
    dHf_298   -795790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     943.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-374610.0
    phase     gas;
}
