/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(octyloxy)pyridine  (C13H21NO, CAS 70289-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OctyloxyPyridine;
formula     C13H21NO;
CAS         70289-27-9;
InChIKey    YRRNIRAKWMOLTK-UHFFFAOYSA-N;
MW          207.317;      // g/mol [origin=calculated method=formula-sum]
Tc          802.71;      // K   [origin=predictive method=joback]
Pc          21.613;      // bar [origin=predictive method=joback]
omega       0.7089;      // -   [origin=predictive method=lee-kesler]
Tb          599.84;      // K   [origin=predictive method=joback]
HvapTb      55428.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.273 1.13048 -0.00061286 1.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2O; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octoxypyridine" "pyridine, 2-(octyloxy)-" "octyl 2-pyridyl ether" "2-octyloxypyridine" "octyl pyridin-2-yl ether" );
gibbsFormation
{
    dHf_298   -174550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143040.0
    phase     gas;
}
