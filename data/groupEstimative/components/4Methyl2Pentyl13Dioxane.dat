/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methyl-2-pentyl-1,3-dioxane  (C10H20O2, CAS 5455-66-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methyl2Pentyl13Dioxane;
formula     C10H20O2;
CAS         5455-66-3;
InChIKey    PAZFSHXCNQDZKF-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          692.67;      // K   [origin=predictive method=joback]
Pc          24.411;      // bar [origin=predictive method=joback]
omega       0.5131;      // -   [origin=predictive method=lee-kesler]
Tb          497.18;      // K   [origin=predictive method=joback]
HvapTb      46994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.226 1.04344 -0.000518 7.18e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxane, 4-methyl-2-pentyl-" "hexaldehyde-1,3-butylene glycol acetal" "1, 4-methyl-2-pentyl-" );
standardThermochemistry
{
    dHf_298   -479750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     370.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122180.0
}
