/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isopropylnaphthalene  (C13H14, CAS 6158-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isopropylnaphthalene;
formula     C13H14;
CAS         6158-45-8;
InChIKey    PMPBFICDXLLSRM-UHFFFAOYSA-N;
MW          170.255;      // g/mol [origin=calculated method=formula-sum]
Tc          778.62;      // K   [origin=predictive method=joback]
Pc          27.789;      // bar [origin=predictive method=joback]
omega       0.4588;      // -   [origin=predictive method=lee-kesler]
Tb          547.24;      // K   [origin=predictive method=joback]
HvapTb      48722.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.66 1.10264 -0.00078748 2.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 7; } { group AC; count 2; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-ylnaphthalene" "naphthalene, 1-(1-methylethyl)-" ".alpha.-isopropylnaphthalene" "isopropylnaphthalene" "naphthalene, (1-methylethyl)-" "naphthalene, 1-isopropyl-" "1-isopropyl-naphthalene" "naphthalene, isopropyl-" "alpha-isopropylnaphthalene" "naphthalene, 1-isopropyl- (8ci)" );
standardThermochemistry
{
    dHf_298   99200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=265570.0
}
