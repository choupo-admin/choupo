/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dipropanoyloxydiphenyldiacetylene  (C22H18O4, CAS 92341-24-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dipropanoyloxydiphenyldiacetylene;
formula     C22H18O4;
CAS         92341-24-7;
InChIKey    YLZSROSRPJTIPP-UHFFFAOYSA-N;
MW          346.382;      // g/mol [origin=calculated method=formula-sum]
Tc          1153.44;      // K   [origin=predictive method=joback]
Pc          17.834;      // bar [origin=predictive method=joback]
omega       0.9562;      // -   [origin=predictive method=lee-kesler]
Tb          900.72;      // K   [origin=predictive method=joback]
HvapTb      89560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (29.612 1.40784 -0.00072784 9.556e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2COO; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group tC; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-[4-(4-propanoyloxyphenyl)buta-1,3-diynyl]phenyl] propanoate" "buta-1,3-diyne-1,4-diyldibenzene-4,1-diyl dipropanoate" );
gibbsFormation
{
    dHf_298   -137250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     833.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124780.0
    phase     gas;
}
