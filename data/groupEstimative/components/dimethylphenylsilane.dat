/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylphenylsilane  (C8H11Si, CAS 766-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H11Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        dimethylphenylsilane;
formula     C8H11Si;
CAS         766-77-8;
InChIKey    OIKHZBFJHONJJB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          135.261;      // g/mol [origin=calculated method=formula-sum]
Tc          623.50;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.2413;      // -   [origin=predictive method=lee-kesler]
Tb          410.02;      // K   [origin=predictive method=joback]
HvapTb      35825.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.88 0.58184 -0.0002352 9e-10);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl(phenyl)silicon" "silane, dimethylphenyl-" "phenyldimethylsilane" "dimethylphenyl silane" "benzene, (dimethylsilyl)-" "dimethyl-phenylsilicon" );
gibbsFormation
{
    dHf_298   -27730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     433.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76510.0
    phase     gas;
}
