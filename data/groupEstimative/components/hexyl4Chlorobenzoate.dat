/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexyl 4-chlorobenzoate  (C13H17ClO2, CAS 58435-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexyl4Chlorobenzoate;
formula     C13H17ClO2;
CAS         58435-21-5;
InChIKey    WNIDDGDBCDWAIE-UHFFFAOYSA-N;
MW          240.727;      // g/mol [origin=calculated method=formula-sum]
Tc          829.88;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       0.7425;      // -   [origin=predictive method=lee-kesler]
Tb          624.35;      // K   [origin=predictive method=joback]
HvapTb      59262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.765 1.05242 -0.00057336 9.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl 4-chloranylbenzoate" "4-chlorobenzoic acid, hexyl ester" );
standardThermochemistry
{
    dHf_298   -419610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     634.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-160940.0
}
