/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(chloromethyl)dimethylsilane  (C4H10Cl2Si, CAS 2917-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H10Cl2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        bisChloromethylDimethylsilane;
formula     C4H10Cl2Si;
CAS         2917-46-6;
InChIKey    TVRFAOJPBXYIRM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          157.109;      // g/mol [origin=calculated method=formula-sum]
Tc          556.31;      // K   [origin=predictive method=joback]
Pc          31.002;      // bar [origin=predictive method=joback]
omega       0.2312;      // -   [origin=predictive method=lee-kesler]
Tb          367.38;      // K   [origin=predictive method=joback]
HvapTb      33562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.852 0.19124 0.0001802 -1.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2Cl; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(chloromethyl)-dimethyl-silane" "(ch3)2si(ch2cl)2" "bis(chloromethyl)-dimethylsilane" "bis(chloromethyl)(dimethyl)silane" "tvrfaojpbxyirm-uhfffaoysa-" "silane,bis(chloromethyl)dimethyl-" );
gibbsFormation
{
    dHf_298   -268990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-145820.0
    phase     gas;
}
