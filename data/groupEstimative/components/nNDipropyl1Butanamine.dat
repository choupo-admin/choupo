/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dipropyl-1-butanamine  (C10H23N, CAS 4444-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDipropyl1Butanamine;
formula     C10H23N;
CAS         4444-71-7;
InChIKey    VJIRBKSBSKOOLV-UHFFFAOYSA-N;
MW          157.301;      // g/mol [origin=calculated method=formula-sum]
Tc          602.14;      // K   [origin=predictive method=joback]
Pc          21.042;      // bar [origin=predictive method=joback]
omega       0.5563;      // -   [origin=predictive method=lee-kesler]
Tb          440.84;      // K   [origin=predictive method=joback]
HvapTb      39897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.893 1.07776 -0.0006328 1.452e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dipropylbutan-1-amine" "1-butanamine, n,n-dipropyl-" "1-butanamine,n,n-dipropyl-" "n,n-dipropylbutylamine" "butylamine,n,n-dipropyl- (8ci); butyldi-n-propylamine; butyldipropylamine;dipropylbutylamine" );
gibbsFormation
{
    dHf_298   -182200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=144100.0
    phase     gas;
}
