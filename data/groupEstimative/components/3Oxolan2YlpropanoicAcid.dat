/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-oxolan-2-ylpropanoic acid  (C7H12O3, CAS 935-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Oxolan2YlpropanoicAcid;
formula     C7H12O3;
CAS         935-12-6;
InChIKey    WUPHOULIZUERAE-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          762.05;      // K   [origin=predictive method=joback]
Pc          37.638;      // bar [origin=predictive method=joback]
omega       0.7280;      // -   [origin=predictive method=lee-kesler]
Tb          547.50;      // K   [origin=predictive method=joback]
HvapTb      53107.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.038 0.8483 -0.0005431 1.309e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group FCH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group O_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(oxolan-2-yl)propanoic acid" "3-(tetrahydrofuran-2-yl)propionic acid" "3-(tetrahydro-furan-2-yl)-propionic acid" "2-furanpropanoic acid, tetrahydro-" "3-tetrahydrofuran-2-ylpropanoic acid" "wt962" "3-tetrahydro-2-furanylpropanoic acid" "935-12-6 3-(oxolan-2-yl)propanoic acid" );
gibbsFormation
{
    dHf_298   -609600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-385420.0
    phase     gas;
}
