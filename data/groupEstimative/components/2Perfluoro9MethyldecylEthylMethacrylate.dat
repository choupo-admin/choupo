\*---------------------------------------------------------------------------*/

name        2Perfluoro9MethyldecylEthylMethacrylate;
formula     C17H9F23O2;
CAS         74256-14-7;
InChIKey    PVMWMBHAEVDBQR-UHFFFAOYSA-N;
MW          682.211;      // g/mol [origin=calculated method=formula-sum]
Tc          724.40;      // K   [origin=predictive method=joback]
Pc          7.614;      // bar [origin=predictive method=joback]
omega       0.7087;      // -   [origin=predictive method=lee-kesler]
Tb          591.02;      // K   [origin=predictive method=joback]
HvapTb      27206.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.948 3.19912 -0.0030986 1.0729e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group CF3; count 2; } { group CF2; count 8; } { group CF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 11; } { group dCH2; count 1; } { group dC; count 1; } { group F; count 23; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
