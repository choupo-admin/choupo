/*--------------------------------*- Choupo -*-----------------------*\
  Component: 17-ethylestr-4-en-17-ol  (C20H32O, CAS 965-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        17Ethylestr4En17Ol;
formula     C20H32O;
CAS         965-90-2;
InChIKey    AOXRBFRFYPMWLR-UHFFFAOYSA-N;
MW          288.475;      // g/mol [origin=calculated method=formula-sum]
Tc          1016.50;      // K   [origin=predictive method=joback]
Pc          18.016;      // bar [origin=predictive method=joback]
omega       0.9535;      // -   [origin=predictive method=lee-kesler]
Tb          792.97;      // K   [origin=predictive method=joback]
HvapTb      75339.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-302.599 2.90874 -0.00261804 1.0032e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "17-ethyl-13-methyl-2,3,6,7,8,9,10,11,12,14,15,16-dodecahydro-1h-cyclopenta[a]phenanthren-17-ol" "agn-pc-00po1s" "estr-4-en-17.beta.-ol, 17-ethyl-" "19-nor-17.alpha.-pregn-4-en-17.beta.-ol" );
gibbsFormation
{
    dHf_298   -311850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     735.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=157130.0
    phase     gas;
}
