/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenyl-1-heptyne  (C13H16, CAS 14374-45-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Phenyl1Heptyne;
formula     C13H16;
CAS         14374-45-9;
InChIKey    MDKGOJZZRHBMQU-UHFFFAOYSA-N;
MW          172.271;      // g/mol [origin=calculated method=formula-sum]
Tc          755.01;      // K   [origin=predictive method=joback]
Pc          25.637;      // bar [origin=predictive method=joback]
omega       0.4431;      // -   [origin=predictive method=lee-kesler]
Tb          532.72;      // K   [origin=predictive method=joback]
HvapTb      48960.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.276 1.01012 -0.00062246 1.4798e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hept-1-ynylbenzene" "benzene, 1-heptynyl-" "1-heptynylbenzene" "hept-1-yn-1-ylbenzene" "benzene, 1-heptyn-1-yl-" "1-heptyne,1-phenyl- (7ci,8ci); benzene, 1-heptynyl- (9ci); 1-heptynylbenzene;1-phenyl-1-heptyne; 1-phenylheptyne" );
gibbsFormation
{
    dHf_298   197180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=373790.0
    phase     gas;
}
