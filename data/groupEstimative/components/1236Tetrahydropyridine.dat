/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3,6-tetrahydropyridine  (C5H9N, CAS 694-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1236Tetrahydropyridine;
formula     C5H9N;
CAS         694-05-3;
InChIKey    FTAHXMZRJCZXDL-UHFFFAOYSA-N;
MW          83.134;      // g/mol [origin=calculated method=formula-sum]
Tc          605.10;      // K   [origin=predictive method=joback]
Pc          51.093;      // bar [origin=predictive method=joback]
omega       0.2702;      // -   [origin=predictive method=lee-kesler]
Tb          385.93;      // K   [origin=predictive method=joback]
HvapTb      34512.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.5 0.558 -0.00031128 5.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group dCH_ring; count 2; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pyridine, 1,2,3,6-tetrahydro-" "1,2,5,6-tetrahydropyridine" "3-piperideine" "delta3-piperidine" "delta(3)-piperideine" ".delta.3-piperidine" "1,3,6-tetrahydropyridine" "1,5,6-tetrahydropyridine" "pyridine, 1,2,3,6-tetrahydro- (8ci)(9ci)" );
gibbsFormation
{
    dHf_298   23720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     319.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=141050.0
    phase     gas;
}
