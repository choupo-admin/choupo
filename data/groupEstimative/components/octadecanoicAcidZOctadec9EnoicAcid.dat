/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanoic acid; (z)-octadec-9-enoic acid  (C36H70O4, CAS 68311-06-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanoicAcidZOctadec9EnoicAcid;
formula     C36H70O4;
CAS         68311-06-8;
InChIKey    QWIDXEUVWSDDQX-SVMKZPJVSA-N;
MW          566.952;      // g/mol [origin=calculated method=formula-sum]
Tc          1811.07;      // K   [origin=predictive method=joback]
Pc          4.869;      // bar [origin=predictive method=joback]
omega       -0.2237;      // -   [origin=predictive method=lee-kesler]
Tb          1319.86;      // K   [origin=predictive method=joback]
HvapTb      130310.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.0 3.33924 -0.0017488 3.034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 30; } { group CH=CH; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 30; } { group dCH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecanoic acid;(z)-octadec-9-enoic acid" "9-octadecenoic acid (9z)-, polymer with octadecanoic acid" "oleic acid, stearic acid polymer" );
gibbsFormation
{
    dHf_298   -1481310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1765.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-460120.0
    phase     gas;
}
