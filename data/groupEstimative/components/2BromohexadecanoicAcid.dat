/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromohexadecanoic acid  (C16H31BrO2, CAS 18263-25-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2BromohexadecanoicAcid;
formula     C16H31BrO2;
CAS         18263-25-7;
InChIKey    DPRAYRYQQAXQPE-UHFFFAOYSA-N;
MW          335.326;      // g/mol [origin=calculated method=formula-sum]
Tc          966.51;      // K   [origin=predictive method=joback]
Pc          14.930;      // bar [origin=predictive method=joback]
omega       1.1291;      // -   [origin=predictive method=lee-kesler]
Tb          776.91;      // K   [origin=predictive method=joback]
HvapTb      74421.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.547 1.61872 -0.0009938 2.408e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanylhexadecanoic acid" "2-bromopalmitic acid" "hexadecanoic acid, 2-bromo-" "alpha-bromopalmitic acid" "2-bromo-hexadecanoic acid" ".alpha.-bromopalmitic acid" "2-bromopalmitate" "2-bromopalmitate, (+-)-isomer" "hexadecanoic acid,2-bromo-" "l213" );
standardThermochemistry
{
    dHf_298   -702790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     873.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-248190.0
}
