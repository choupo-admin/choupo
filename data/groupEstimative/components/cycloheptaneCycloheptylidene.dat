/*--------------------------------*- Choupo -*-----------------------*\
  Component: cycloheptane, cycloheptylidene-  (C14H24, CAS 51175-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cycloheptaneCycloheptylidene;
formula     C14H24;
CAS         51175-34-9;
InChIKey    JPWJQIKXWASNOD-UHFFFAOYSA-N;
MW          192.346;      // g/mol [origin=calculated method=formula-sum]
Tc          830.86;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.4165;      // -   [origin=predictive method=lee-kesler]
Tb          586.02;      // K   [origin=predictive method=joback]
HvapTb      50194.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-126.79 1.4368 -0.000771 1.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 12; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 12; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cycloheptylidenecycloheptane" );
gibbsFormation
{
    dHf_298   -160450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117820.0
    phase     gas;
}
