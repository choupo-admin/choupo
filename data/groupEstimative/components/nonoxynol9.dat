/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonoxynol 9  (C33H60O10, CAS 26571-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonoxynol9;
formula     C33H60O10;
CAS         26571-11-9;
InChIKey    FBWNMEQMRUMQSO-UHFFFAOYSA-N;
MW          616.833;      // g/mol [origin=calculated method=formula-sum]
Tc          1775.94;      // K   [origin=predictive method=joback]
Pc          5.860;      // bar [origin=predictive method=joback]
omega       -0.1615;      // -   [origin=predictive method=lee-kesler]
Tb          1280.26;      // K   [origin=predictive method=joback]
HvapTb      130359.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (188.076 2.46562 -0.00076696 -1.013e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 8; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 26; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-[2-[2-[2-[2-[2-(4-nonylphenoxy)ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethoxy]ethanol" "nonoxynol-9" "today" "gynoll" "nonoxynol, n=9" "nonaethylene glycol nonylphenyl ether" "nonylphenol octa(oxyethylene) ethanol" "nonaethylene glycol mono(nonylphenyl) ether" "26-(nonylphenoxy)-3,6,9,12,15,18,21,24-octaoxahexacosan-1-ol" "n-9" "vcf" "staycept" );
gibbsFormation
{
    dHf_298   -1841600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1481.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-752060.0
    phase     gas;
}
