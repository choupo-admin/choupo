/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-3-phenylpentanenitrile  (C12H15N, CAS 50843-73-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl3Phenylpentanenitrile;
formula     C12H15N;
CAS         50843-73-7;
InChIKey    XWSORJFXTDXNIZ-UHFFFAOYSA-N;
MW          173.259;      // g/mol [origin=calculated method=formula-sum]
Tc          828.48;      // K   [origin=predictive method=joback]
Pc          23.912;      // bar [origin=predictive method=joback]
omega       0.5523;      // -   [origin=predictive method=lee-kesler]
Tb          599.69;      // K   [origin=predictive method=joback]
HvapTb      53764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.398 1.12554 -0.000801 2.227e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-3-phenyl-pentanenitrile" "hydrocinnamonitrile, .beta.-ethyl-.beta.-methyl" );
gibbsFormation
{
    dHf_298   101650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=298590.0
    phase     gas;
}
