/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenol, reaction products with isobutylene and 2,2,4-trimethylpentene  (C18H30O, CAS 68457-76-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenolReactionProductsWithIsobutyleneAnd224Trimethylpentene;
formula     C18H30O;
CAS         68457-76-1;
InChIKey    GZQSDZURPWPHHN-UHFFFAOYSA-N;
MW          262.437;      // g/mol [origin=calculated method=formula-sum]
Tc          946.60;      // K   [origin=predictive method=joback]
Pc          15.949;      // bar [origin=predictive method=joback]
omega       0.5965;      // -   [origin=predictive method=lee-kesler]
Tb          713.93;      // K   [origin=predictive method=joback]
HvapTb      69030.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.99 1.56234 -0.0007635 9.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group ACOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylprop-1-ene;phenol;2,4,4-trimethylpent-2-ene" "2-methylprop-1-ene; phenol; 2,4,4-trimethylpent-2-ene" );
gibbsFormation
{
    dHf_298   -353080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     940.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12380.0
    phase     gas;
}
