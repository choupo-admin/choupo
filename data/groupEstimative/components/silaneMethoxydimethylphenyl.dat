/*--------------------------------*- Choupo -*-----------------------*\
  Component: silane, methoxydimethylphenyl-  (C9H14OSi, CAS 17881-88-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H14OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        silaneMethoxydimethylphenyl;
formula     C9H14OSi;
CAS         17881-88-8;
InChIKey    REQXNMOSXYEQLM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          166.295;      // g/mol [origin=calculated method=formula-sum]
Tc          669.33;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.3169;      // -   [origin=predictive method=lee-kesler]
Tb          456.02;      // K   [origin=predictive method=joback]
HvapTb      40608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.12 0.51056 2.88e-05 -1.506e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH3O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methoxy-dimethyl-phenyl-silane" "dimethylmethoxyphenylsilane" "dimethylphenylmethoxysilane" "methoxydimethylphenylsilane" "methoxy-dimethyl-phenylsilane" "benzene,(methoxydimethylsilyl)-" "silane,methoxydimethylphenyl- (6ci,8ci,9ci);methoxy(phenyl)dimethylsilane;methoxydimethylphenylsilane;phenyldimethylmethoxysilane;" );
gibbsFormation
{
    dHf_298   -236400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-72450.0
    phase     gas;
}
