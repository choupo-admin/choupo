/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methylenebornane  (C11H18, CAS 27538-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methylenebornane;
formula     C11H18;
CAS         27538-47-2;
InChIKey    ZASFWGOMAIPHLN-UHFFFAOYSA-N;
MW          150.265;      // g/mol [origin=calculated method=formula-sum]
Tc          678.06;      // K   [origin=predictive method=joback]
Pc          27.326;      // bar [origin=predictive method=joback]
omega       0.3254;      // -   [origin=predictive method=lee-kesler]
Tb          464.00;      // K   [origin=predictive method=joback]
HvapTb      37626.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-184.47 1.78086 -0.001886 8.271e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7,7-trimethyl-3-methylidene-bicyclo[2.2.1]heptane" "1,7,7-trimethyl-2-methylenebicyclo[2.2.1]heptane" "4,7,7-trimethyl-3-methylidenebicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane,1,7,7-trimethyl-2-methylene-" "(1s,4r)-1,7,7-trimethyl-2-methylidenebicyclo[2.2.1]heptane" "bornane,2-methylene- (6ci,7ci,8ci); 1,7,7-trimethyl-2-methylenebicyclo[2.2.1]heptane;1,7,7-trimethyl-2-methylenenorbornane; 2-methylenebornane" );
standardThermochemistry
{
    dHf_298   -36550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=185530.0
}
