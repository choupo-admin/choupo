/*--------------------------------*- Choupo -*-----------------------*\
  Component: (r)-ethyl 4-cyano-3-hydroxybutyrate  (C7H11NO3, CAS 141942-85-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        rEthyl4Cyano3Hydroxybutyrate;
formula     C7H11NO3;
CAS         141942-85-0;
InChIKey    LOQFROBMBSKWQY-ZCFIWIBFSA-N;
MW          157.169;      // g/mol [origin=calculated method=formula-sum]
Tc          797.81;      // K   [origin=predictive method=joback]
Pc          30.524;      // bar [origin=predictive method=joback]
omega       1.1420;      // -   [origin=predictive method=lee-kesler]
Tb          611.80;      // K   [origin=predictive method=joback]
HvapTb      65352.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.543 0.58872 -0.000265 1.8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2COO; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group COO; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl (3r)-4-cyano-3-oxidanyl-butanoate" "ethyl (r)-(-)-4-cyano-3-hydroxybutyate" "ethyl (r)-(-)-4-cyano-3-hydroxybutyrate" "ethyl (3r)-4-cyano-3-hydroxybutanoate" "ethyl-(r)-(+)-4-cyano-3-hydroxybutanoate" "(r)-4-cyano-3-hydroxybutyric acid ethyl ester" "(r)-4-cyano-3-hydroxy-butyricacidethylester" "(r)-(-)-4-cyano-3-hydroxybutyric acid ethyl ester" "(r)-(-)-4-cyano-3-hydroxybutyratic acid, ethyl ester" "ats-5" "ethyl (r)-4-cyano-3-hydroxybutyrate" "ethyl ((r)-4-cyano-3-hydroxybutyrate" );
standardThermochemistry
{
    dHf_298   -497720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-308390.0
}
