/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methylspiro(2.4)hepta-4,6-diene  (C8H10, CAS 67487-86-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methylspiro24Hepta46Diene;
formula     C8H10;
CAS         67487-86-9;
InChIKey    TYRKZHXFLRLILE-UHFFFAOYSA-N;
MW          106.168;      // g/mol [origin=calculated method=formula-sum]
Tc          626.17;      // K   [origin=predictive method=joback]
Pc          40.777;      // bar [origin=predictive method=joback]
omega       0.2805;      // -   [origin=predictive method=lee-kesler]
Tb          408.60;      // K   [origin=predictive method=joback]
HvapTb      33804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.06 1.20292 -0.00130092 5.624e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-methylspiro[2.4]hepta-4,6-diene" );
gibbsFormation
{
    dHf_298   70660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     337.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178390.0
    phase     gas;
}
