/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethoxypropane  (C5H12O2, CAS 77-76-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethoxypropane;
formula     C5H12O2;
CAS         77-76-9;
InChIKey    HEWZVZIVELJPQZ-UHFFFAOYSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          532.38;      // K   [origin=predictive method=joback]
Pc          34.079;      // bar [origin=predictive method=joback]
omega       0.3084;      // -   [origin=predictive method=lee-kesler]
Tb          355.61;      // K   [origin=predictive method=joback]
HvapTb      30248.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.87 0.47828 -0.000198 1.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "acetone dimethyl acetal" "propane, 2,2-dimethoxy-" "acetone, dimethyl acetal" "acetone dimethyl ketal" "acetone-dimethyl acetal" "acetone dimethylacetal" "propane,2-dimethoxy-" "acetone, dimethyl acetal (8ci)" );
gibbsFormation
{
    dHf_298   -419720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215940.0
    phase     gas;
}
