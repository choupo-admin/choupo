/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-bis(3-methylbutoxy)propan-2-ol  (C13H28O3, CAS 626-78-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Bis3MethylbutoxyPropan2Ol;
formula     C13H28O3;
CAS         626-78-8;
InChIKey    ARRCKRNGGJHASO-UHFFFAOYSA-N;
MW          232.364;      // g/mol [origin=calculated method=formula-sum]
Tc          798.38;      // K   [origin=predictive method=joback]
Pc          17.595;      // bar [origin=predictive method=joback]
omega       1.0991;      // -   [origin=predictive method=lee-kesler]
Tb          632.74;      // K   [origin=predictive method=joback]
HvapTb      64867.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.316 1.16418 -0.0005014 4.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 3; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-diisoamyloxy-2-propanol" "1,3-diisoamyl glycerol diether" "2-propanol, 1,3-diisopentyloxy-" "2-propanol, 1,3-di(isopentyloxy)-" "2-propanol, 1,3-bis(3-methylbutoxy)-" "2-propanol,3-di(isopentyloxy)-" "2-propanol,3-bis(isopentyloxy)-" "2-propanol,3-bis(3-methylbutoxy)-" "2-propanol, 1,3-bis(isopentyloxy)-" "2-propanol, 1,3-bis(isopentyloxy)- (8ci)" );
gibbsFormation
{
    dHf_298   -744160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     707.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295560.0
    phase     gas;
}
