/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxypropyl)-2-picolylamine  (C9H14N2O, CAS 68892-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2Hydroxypropyl2Picolylamine;
formula     C9H14N2O;
CAS         68892-16-0;
InChIKey    SVJCONVIKRDPJV-UHFFFAOYSA-N;
MW          166.224;      // g/mol [origin=calculated method=formula-sum]
Tc          835.10;      // K   [origin=predictive method=joback]
Pc          37.317;      // bar [origin=predictive method=joback]
omega       1.0764;      // -   [origin=predictive method=lee-kesler]
Tb          627.81;      // K   [origin=predictive method=joback]
HvapTb      66841.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.738 0.92978 -0.00058846 1.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group OH; count 1; } { group NH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(pyridin-2-ylmethylamino)propan-2-ol" "2-propanol, 1-((2-pyridinylmethyl)amino)-" "2-propanol, 1-[(2-pyridinylmethyl)amino]-" "1-[(2-pyridinylmethyl)amino]-2-propanol" "n-(2-hydroxypropyl)-2-picolylamine;2-propanol, 1-((2-pyridinylmethyl)amino)-;" );
gibbsFormation
{
    dHf_298   -63810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164490.0
    phase     gas;
}
