/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-propyl-9h-fluorene  (C16H16, CAS 158599-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Propyl9hFluorene;
formula     C16H16;
CAS         158599-21-4;
InChIKey    ZTBWLZNGULENBG-UHFFFAOYSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          859.85;      // K   [origin=predictive method=joback]
Pc          23.982;      // bar [origin=predictive method=joback]
omega       0.6011;      // -   [origin=predictive method=lee-kesler]
Tb          627.20;      // K   [origin=predictive method=joback]
HvapTb      56655.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.868 1.41712 -0.00108792 3.395e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9h-fluorene, 9-propyl-" "9-propyl-9h-fluoren" "fluorene,9-propyl- (6ci,7ci,8ci); 9-propylfluorene" );
gibbsFormation
{
    dHf_298   161670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=374350.0
    phase     gas;
}
