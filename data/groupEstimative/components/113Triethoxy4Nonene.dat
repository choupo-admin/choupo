/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-triethoxy-4-nonene  (C15H30O3, CAS 72152-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Triethoxy4Nonene;
formula     C15H30O3;
CAS         72152-76-2;
InChIKey    GMJRSWGCHBIIBV-GETOMWPZSA-N;
MW          258.402;      // g/mol [origin=calculated method=formula-sum]
Tc          783.67;      // K   [origin=predictive method=joback]
Pc          14.337;      // bar [origin=predictive method=joback]
omega       0.8213;      // -   [origin=predictive method=lee-kesler]
Tb          613.34;      // K   [origin=predictive method=joback]
HvapTb      55396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.207 1.27108 -0.0005494 4.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 2; } { group dCH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e,3r)-1,1,3-triethoxynon-4-ene" );
standardThermochemistry
{
    dHf_298   -642930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     748.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164240.0
}
