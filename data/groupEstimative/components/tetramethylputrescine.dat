/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetramethylputrescine  (C8H20N2, CAS 111-51-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetramethylputrescine;
formula     C8H20N2;
CAS         111-51-3;
InChIKey    VEAZEPMQWHPHAG-UHFFFAOYSA-N;
MW          144.262;      // g/mol [origin=calculated method=formula-sum]
Tc          568.76;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.5194;      // -   [origin=predictive method=lee-kesler]
Tb          407.52;      // K   [origin=predictive method=joback]
HvapTb      37488.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.766 1.01168 -0.0006366 1.588e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetramethylbutane-1,4-diamine" "n,n,n',n'-tetramethyl-1,4-butanediamine" "1,4-bis(dimethylamino)butane" "1,4-butanediamine, n,n,n',n'-tetramethyl-" "tetramethyldiaminobutane" "n,n,n',n'-tetramethyl-1,4-diaminobutane" "n,n,n',n'-tetramethyltetramethylenediamine" "alpha,delta-(tetramethyldiamino)butane" ".alpha.,.delta.-(tetramethyldiamino)butane" "n,n,n',n'-tetramethyl-1,4'-butanediamine" "1,4-butanediamine, n1,n1,n4,n4-tetramethyl-" "[4-(dimethylamino)butyl]dimethylamine" );
gibbsFormation
{
    dHf_298   -73390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=238040.0
    phase     gas;
}
