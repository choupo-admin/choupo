/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dihydro-2h-1,5-propanonaphtho[1,8-bc][1,5]diazocine  (C16H18N2, CAS 59950-40-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dihydro2h15Propanonaphtho18Bc15Diazocine;
formula     C16H18N2;
CAS         59950-40-2;
InChIKey    AFDLYDVPEJSOKP-UHFFFAOYSA-N;
MW          238.334;      // g/mol [origin=calculated method=formula-sum]
Tc          907.59;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.7560;      // -   [origin=predictive method=lee-kesler]
Tb          669.00;      // K   [origin=predictive method=joback]
HvapTb      60980.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.15 1.9248 -0.00165684 5.658e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 6; } { group AC; count 4; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-1,5-propano-1h-naphtho[1,8-bc]-1,5-diazocine,3,4-dihydro-" "2h-1,5-propano-1h-naphtho(1,8-bc)-1,5-diazocine, 3,4-dihydro-" );
standardThermochemistry
{
    dHf_298   352430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=642120.0
}
