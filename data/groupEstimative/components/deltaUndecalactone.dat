/*--------------------------------*- Choupo -*-----------------------*\
  Component: delta-undecalactone  (C11H20O2, CAS 710-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deltaUndecalactone;
formula     C11H20O2;
CAS         710-04-3;
InChIKey    YZRXRLLRSPQHDK-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          706.85;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.6261;      // -   [origin=predictive method=lee-kesler]
Tb          520.51;      // K   [origin=predictive method=joback]
HvapTb      47572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.065 1.13532 -0.0006538 1.32e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-hexyloxan-2-one" "2h-pyran-2-one, 6-hexyltetrahydro-" "5-undecanolide" "undecanolide-1,5" "delta-undecanolactone" "5-hydroxyundecanoic acid lactone" "delta-hexylvalerolactone" "undecanoic delta-lactone" "6-hexyltetrahydro-2h-pyran-2-one" ".delta.-hexylvalerolactone" "2h-pyran-2-one, tetrahydro-3-hexyl-" "5-hexyl-5-hydroxypentanoic acid lactone" );
gibbsFormation
{
    dHf_298   -521010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-219980.0
    phase     gas;
}
