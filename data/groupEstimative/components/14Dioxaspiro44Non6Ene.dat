/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dioxaspiro[4.4]non-6-ene  (C7H10O2, CAS 695-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dioxaspiro44Non6Ene;
formula     C7H10O2;
CAS         695-56-7;
InChIKey    ATFWVBMLTLPOHI-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          677.93;      // K   [origin=predictive method=joback]
Pc          46.977;      // bar [origin=predictive method=joback]
omega       0.3421;      // -   [origin=predictive method=lee-kesler]
Tb          444.02;      // K   [origin=predictive method=joback]
HvapTb      39988.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.83 1.1982 -0.00120568 4.94e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dioxaspiro[4.4]non-8-ene" "2-cyclopenten-1-one ethylene ketal" "6,9-dioxaspiro[4.4]non-3-ene" "2-cyclopenten-1-one ethyl ene ketal" "cyclopent-2-en-1-one-ethyleneacetal" );
standardThermochemistry
{
    dHf_298   -231330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     279.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-46800.0
}
