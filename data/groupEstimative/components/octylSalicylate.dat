/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl salicylate  (C15H22O3, CAS 6969-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octylSalicylate;
formula     C15H22O3;
CAS         6969-49-9;
InChIKey    WCJLCOAEJIHPCW-UHFFFAOYSA-N;
MW          250.338;      // g/mol [origin=calculated method=formula-sum]
Tc          913.07;      // K   [origin=predictive method=joback]
Pc          21.178;      // bar [origin=predictive method=joback]
omega       1.0122;      // -   [origin=predictive method=lee-kesler]
Tb          708.32;      // K   [origin=predictive method=joback]
HvapTb      71681.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.163 1.44972 -0.00098516 2.688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octyl 2-oxidanylbenzoate" "salicylic acid, octyl ester" "octyl 2-hydroxybenzoate" "n-octyl o-hydroxybenzoate" "n-octyl salicylate" "benzoic acid, 2-hydroxy-, octyl ester" "octyl o-hydroxybenzoate" "salicylate de n-octyle" "benzoic acid, o-hydroxy-, octyl ester" "s 8" "salicylic acid, n-octyl ester" "2-hydroxybenzoic acid octyl ester" );
standardThermochemistry
{
    dHf_298   -610990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277160.0
}
