/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenyloctane  (C14H22, CAS 777-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Phenyloctane;
formula     C14H22;
CAS         777-22-0;
InChIKey    GTYIGAUPHJCMLF-UHFFFAOYSA-N;
MW          190.33;      // g/mol [origin=calculated method=formula-sum]
Tc          744.29;      // K   [origin=predictive method=joback]
Pc          20.236;      // bar [origin=predictive method=joback]
omega       0.5499;      // -   [origin=predictive method=lee-kesler]
Tb          546.16;      // K   [origin=predictive method=joback]
HvapTb      48646.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.425 1.26084 -0.0007722 1.804e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octan-2-ylbenzene" "octane, 2-phenyl-" "benzene, (1-methylheptyl)-" "(1-methylheptyl)benzene" "(methylheptyl)benzene" );
standardThermochemistry
{
    dHf_298   -101040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=176970.0
}
