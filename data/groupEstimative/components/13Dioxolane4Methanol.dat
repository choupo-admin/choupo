/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxolane-4-methanol  (C4H8O3, CAS 5464-28-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxolane4Methanol;
formula     C4H8O3;
CAS         5464-28-8;
InChIKey    BOHGAOWOIJMTPZ-UHFFFAOYSA-N;
MW          104.105;      // g/mol [origin=calculated method=formula-sum]
Tc          643.86;      // K   [origin=predictive method=joback]
Pc          55.033;      // bar [origin=predictive method=joback]
omega       0.7598;      // -   [origin=predictive method=lee-kesler]
Tb          452.48;      // K   [origin=predictive method=joback]
HvapTb      50454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.299 0.5435 -0.0003238 6.83e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolan-4-ylmethanol" "glycerin formal" "sericosol-n" "(1,3-dioxolan-4-yl)methanol" "4-(hydroxymethyl)-1,3-dioxolane" "1,2-(methylidene)glycerol" "glycerol, 1,2-o-methylene-" "glycerol,2-o-methylene-" "agn-pc-04t8s4" );
gibbsFormation
{
    dHf_298   -481640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     209.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-289710.0
    phase     gas;
}
