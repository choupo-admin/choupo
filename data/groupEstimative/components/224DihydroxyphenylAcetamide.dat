/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,4-dihydroxyphenyl)acetamide  (C8H9NO3, CAS 68929-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224DihydroxyphenylAcetamide;
formula     C8H9NO3;
CAS         68929-11-3;
InChIKey    RYKUFCHWCAZVNL-UHFFFAOYSA-N;
MW          167.164;      // g/mol [origin=calculated method=formula-sum]
Tc          948.08;      // K   [origin=predictive method=joback]
Pc          65.352;      // bar [origin=predictive method=joback]
omega       1.1869;      // -   [origin=predictive method=lee-kesler]
Tb          696.96;      // K   [origin=predictive method=joback]
HvapTb      79093.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.279 1.028 -0.00098002 3.7766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(oxidanyl)phenyl]ethanamide" "benzeneacetamide, 2,4-dihydroxy-" "2,4-resorcylic acetamide" );
gibbsFormation
{
    dHf_298   -405330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242820.0
    phase     gas;
}
