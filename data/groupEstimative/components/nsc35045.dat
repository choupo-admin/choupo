/*--------------------------------*- Choupo -*-----------------------*\
  Component: nsc 35045  (C21H27NO4, CAS 2688-77-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nsc35045;
formula     C21H27NO4;
CAS         2688-77-9;
InChIKey    KGPAYJZAMGEDIQ-KRWDZBQOSA-N;
MW          357.45;      // g/mol [origin=calculated method=formula-sum]
Tc          1086.18;      // K   [origin=predictive method=joback]
Pc          14.942;      // bar [origin=predictive method=joback]
omega       1.0522;      // -   [origin=predictive method=lee-kesler]
Tb          867.20;      // K   [origin=predictive method=joback]
HvapTb      81798.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.551 1.5656 -0.0007346 8.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 4; } { group ACCH2; count 2; } { group ACCH; count 1; } { group CH3O; count 4; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group O; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s)-1-[(3,4-dimethoxyphenyl)methyl]-6,7-dimethoxy-2-methyl-3,4-dihydro-1h-isoquinoline" "l-laudanosine" "o-methylcodamine" "(s)-laudanosine" "(+)-laudanosine" "(+)-laudanosine," "l-(+)-laudanosine" "(s)-(+)-laudanosine" "1-(3,4-dimethoxybenzyl)-6,7-dimethoxy-2-methyl-1,2,3,4-tetrahydroisoquinoline" "isoquinoline, 1-[(3,4-dimethoxyphenyl)methyl]-1,2,3,4-tetrahydro-6,7-dimethoxy-2-methyl-" "(1s)-1-[(3,4-dimethoxyphenyl)methyl]-1,2,3,4-tetrahydro-6,7-dimethoxy-2-methyl-isoquinoline" );
gibbsFormation
{
    dHf_298   -449610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     701.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54140.0
    phase     gas;
}
