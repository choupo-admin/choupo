/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecanoic acid;morpholine  (C16H33NO3, CAS 21778-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecanoicAcidMorpholine;
formula     C16H33NO3;
CAS         21778-29-0;
InChIKey    XOCPFOARSHYLBQ-UHFFFAOYSA-N;
MW          287.444;      // g/mol [origin=calculated method=formula-sum]
Tc          1018.06;      // K   [origin=predictive method=joback]
Pc          16.013;      // bar [origin=predictive method=joback]
omega       1.1006;      // -   [origin=predictive method=lee-kesler]
Tb          812.31;      // K   [origin=predictive method=joback]
HvapTb      80674.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.54 1.50062 -0.0005663 -1.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group COOH; count 1; } { group Morpholine; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group CH2_ring; count 4; } { group O_ring; count 1; } { group COOH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodecanoic acid, compd. with morpholine(1:1)" "lauric acid, compound with morpholine (1:1)" "dodecanoic acid, compd. with morpholine (1:1)" "dodecanoic acid; morpholine" "dodecanoic acid - morpholine (1:1)" "lauric acid, compound with morpholine (1:1);dodecanoic acid, compd. with morpholine;dodecanoic acid,compd. with morpholine" );
standardThermochemistry
{
    dHf_298   -854990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     894.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-331080.0
}
