/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetrahydrophthalic acid dimethyl ester  (C10H14O4, CAS 4336-19-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetrahydrophthalicAcidDimethylEster;
formula     C10H14O4;
CAS         4336-19-0;
InChIKey    APGUUZNLMFETAH-UHFFFAOYSA-N;
MW          198.218;      // g/mol [origin=calculated method=formula-sum]
Tc          788.79;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.6953;      // -   [origin=predictive method=lee-kesler]
Tb          578.18;      // K   [origin=predictive method=joback]
HvapTb      55022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.45 0.81784 -0.0003206 -1.42e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C=C; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl cyclohexene-1,2-dicarboxylate" "dimethyl tetrahydrophthalate" "1-cyclohexene-1,2-dicarboxylic acid, dimethyl ester" "dimethylester kyseliny tetrahydroftalove" "dimethyl cyclohex-1-ene-1,2-dicarboxylate" "cyclohexene-1,2-dicarboxylic acid dimethyl ester" );
gibbsFormation
{
    dHf_298   -774790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-544560.0
    phase     gas;
}
