/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-octanediol  (C8H18O2, CAS 629-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Octanediol;
formula     C8H18O2;
CAS         629-41-4;
InChIKey    OEIJHBUUFURJLI-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          723.88;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       1.3807;      // -   [origin=predictive method=lee-kesler]
Tb          567.00;      // K   [origin=predictive method=joback]
HvapTb      66760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.198 0.8318 -0.0004722 1.036e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane-1,8-diol" "octamethylene glycol" "1,8-octandiol" "1,8-dihydroxyoctane" "1, 8-octandiol" "odi" "octamethylene glycol; 1,8-dihydroxyoctane" "octane-1,8-diol;18-octanediol;1,8-octandiol;" );
standardThermochemistry
{
    dHf_298   -512910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-257160.0
}
