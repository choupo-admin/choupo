/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(piperidin-3-ylcarbonyl)piperidine  (C11H20N2O, CAS 40576-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Piperidin3YlcarbonylPiperidine;
formula     C11H20N2O;
CAS         40576-21-4;
InChIKey    OSZRYTYCKGZYLB-UHFFFAOYSA-N;
MW          196.294;      // g/mol [origin=calculated method=formula-sum]
Tc          842.09;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.6549;      // -   [origin=predictive method=lee-kesler]
Tb          605.64;      // K   [origin=predictive method=joback]
HvapTb      56622.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-125.55 1.4116 -0.0008717 1.9246e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH2NH; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group CH_ring; count 1; } { group CdO; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "piperidin-1-yl(piperidin-3-yl)methanone" "piperidino 3-piperidyl ketone" "1,3'-carbonyldi(piperidine)" "ketone, piperidino 3-piperidyl" "3-(piperidinocarbonyl)piperidine" "piperidine, 1-(3-piperidyl)carbonyl-" "piperidin-3-yl-piperidin-1-yl-methanone" "3-piperidyl piperidyl ketone" "1-(piperidine-3-carbonyl)piperidine" "3-(piperidine-1-carbonyl)piperidine" "1-(3-piperidinylcarbonyl)-piperidine" "piperidin-1-yl-piperidin-3-yl-methanone" );
gibbsFormation
{
    dHf_298   -142470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180020.0
    phase     gas;
}
