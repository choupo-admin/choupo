/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,5,6-tetrachloroanisole  (C7H4Cl4O, CAS 6936-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2356Tetrachloroanisole;
formula     C7H4Cl4O;
CAS         6936-40-9;
InChIKey    WMMFIDNWZNCBCT-UHFFFAOYSA-N;
MW          245.908;      // g/mol [origin=calculated method=formula-sum]
Tc          817.12;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.5532;      // -   [origin=predictive method=lee-kesler]
Tb          578.50;      // K   [origin=predictive method=joback]
HvapTb      56050.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (96.88 0.31592 -9.064e-05 -2.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 1; } { group AC; count 1; } { group CH3O; count 1; } { group ACCl; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group Cl; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetrakis(chloranyl)-3-methoxy-benzene" "anisole, 2,3,5,6-tetrachloro-" "benzene, 1,2,4,5-tetrachloro-3-methoxy-" "1,2,4,5-tetrachloro-3-methoxybenzene" "tetrachloromethoxybenzene" "benzene, tetrachloromethoxy-" "anisole,3,5,6-tetrachloro-" "benzene,2,4,5-tetrachloro-3-methoxy-" "benzene,1,2,4,5-tetrachloro-3-methoxy-" "benzene, 1,2,4,5-tetrachloro-3-methoxy- (9ci)" );
standardThermochemistry
{
    dHf_298   -192340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70770.0
}
