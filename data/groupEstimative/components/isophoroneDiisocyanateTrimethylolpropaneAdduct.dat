/*--------------------------------*- Choupo -*-----------------------*\
  Component: isophorone diisocyanate, trimethylolpropane adduct  (C18H32N2O5, CAS 68479-05-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isophoroneDiisocyanateTrimethylolpropaneAdduct;
formula     C18H32N2O5;
CAS         68479-05-0;
InChIKey    NCNFJZCCVWIZNK-UHFFFAOYSA-N;
MW          356.463;      // g/mol [origin=calculated method=formula-sum]
Tc          1262.89;      // K   [origin=predictive method=joback]
Pc          17.924;      // bar [origin=predictive method=joback]
omega       1.4802;      // -   [origin=predictive method=lee-kesler]
Tb          1030.18;      // K   [origin=predictive method=joback]
HvapTb      121270.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 8; } { group CH; count 1; } { group C; count 3; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group C; count 1; } { group dCd; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group OH; count 3; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethyl-2-(hydroxymethyl)propane-1,3-diol;5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethyl-cyclohexane" "1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-, polymer with 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane, 2-ethyl-1-hexanol-blocked" "1,3-propanediol, 2-ethyl-2-(hydroxymethyl)-, reaction products with 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane" "isophorone diisocyanate, trimethylolpropane, polymer, reaction product with 2-ethylhexanol" "2-ethyl-2-(hydroxymethyl)propane-1,3-diol; 5-isocyanato-1-(isocyanatomethyl)-1,3,3-trimethylcyclohexane" );
