/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethyl-4-octanol  (C10H22O, CAS 66719-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethyl4Octanol;
formula     C10H22O;
CAS         66719-30-0;
InChIKey    JEBZCASOCDXENQ-UHFFFAOYSA-N;
MW          158.285;      // g/mol [origin=calculated method=formula-sum]
Tc          686.79;      // K   [origin=predictive method=joback]
Pc          23.588;      // bar [origin=predictive method=joback]
omega       0.8145;      // -   [origin=predictive method=lee-kesler]
Tb          516.91;      // K   [origin=predictive method=joback]
HvapTb      52849.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.066 1.11958 -0.0007256 1.89e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethyloctan-4-ol" );
standardThermochemistry
{
    dHf_298   -415990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     548.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103100.0
}
