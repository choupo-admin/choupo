/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-1,4-pentadiene  (C7H12, CAS 1112-35-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl14Pentadiene;
formula     C7H12;
CAS         1112-35-2;
InChIKey    BHZUNHXTRRNKST-UHFFFAOYSA-N;
MW          96.173;      // g/mol [origin=calculated method=formula-sum]
Tc          532.20;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.2186;      // -   [origin=predictive method=lee-kesler]
Tb          349.89;      // K   [origin=predictive method=joback]
HvapTb      28540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.93 0.75464 -0.0005746 1.788e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-dimethylpenta-1,4-diene" "1,4-pentadiene, 3,3-dimethyl-" "1,4-pentadiene,3,3-dimethyl-" );
gibbsFormation
{
    dHf_298   54300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     380.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186580.0
    phase     gas;
}
