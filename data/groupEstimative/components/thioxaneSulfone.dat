/*--------------------------------*- Choupo -*-----------------------*\
  Component: thioxane sulfone  (C4H8O3S, CAS 107-61-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C4H8O3S (delta S+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        thioxaneSulfone;
formula     C4H8O3S;
CAS         107-61-9;
InChIKey    WWRUZECKUVNAPB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          136.165;      // g/mol [origin=calculated method=formula-sum]
Tc          485.10;      // K   [origin=predictive method=joback]
Pc          59.907;      // bar [origin=predictive method=joback]
omega       0.4147;      // -   [origin=predictive method=lee-kesler]
Tb          317.02;      // K   [origin=predictive method=joback]
HvapTb      41392.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.21 0.5782 -0.0003373 5.98e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group FCH2O; count 1; } { group CH2SuCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group O_ring; count 1; } { group dO_oth; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-oxathiane 4,4-dioxide" "p-thioxane sulfone" "1,4-thioxane-1,1-dioxide" "oxathiane 4,4-dioxide" "1,4-oxathiane, 4,4-dioxide" "usaf do-38" "4,4-dioxo-1,4-oxathiane" "1, 4,4-dioxide" "1,4-thioxane 1,1-dioxide" );
gibbsFormation
{
    dHf_298   -672290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-560720.0
    phase     gas;
}
