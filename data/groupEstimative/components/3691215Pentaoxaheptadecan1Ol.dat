/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6,9,12,15-pentaoxaheptadecan-1-ol  (C12H26O6, CAS 4353-29-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3691215Pentaoxaheptadecan1Ol;
formula     C12H26O6;
CAS         4353-29-1;
InChIKey    NJRFAMBTWHGSDE-UHFFFAOYSA-N;
MW          266.334;      // g/mol [origin=calculated method=formula-sum]
Tc          841.40;      // K   [origin=predictive method=joback]
Pc          17.909;      // bar [origin=predictive method=joback]
omega       1.3197;      // -   [origin=predictive method=lee-kesler]
Tb          678.44;      // K   [origin=predictive method=joback]
HvapTb      71035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.771 0.86182 -0.0001044 -1.326e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2O; count 4; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group OH; count 1; } { group O; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(2-ethoxyethoxy)ethoxy]ethoxy]ethoxy]ethanol" "pentaethylene glycol, monoethyl ether" "ae4" );
standardThermochemistry
{
    dHf_298   -1104340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-611660.0
}
