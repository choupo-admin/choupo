/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tetradecyne  (C14H26, CAS 765-10-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tetradecyne;
formula     C14H26;
CAS         765-10-6;
InChIKey    DZEFNRWGWQDGTR-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          678.81;      // K   [origin=predictive method=joback]
Pc          17.160;      // bar [origin=predictive method=joback]
omega       0.6137;      // -   [origin=predictive method=lee-kesler]
Tb          510.04;      // K   [origin=predictive method=joback]
HvapTb      46616.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.941 1.23992 -0.00073373 1.7379e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group tCH; count 1; } { group tC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradec-1-yne" "tetradec-1-in" "1-c14h26" "tetradecyne" "1-tetradecyne;timtec-bb sbb008951;1-c14h26;1-tetradecyne,tech.90%;1-tetradecyne: tech., 90%" );
gibbsFormation
{
    dHf_298   -40390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=290070.0
    phase     gas;
}
