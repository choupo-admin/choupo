/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-phenylethyl isovalerate  (C13H18O2, CAS 56961-73-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PhenylethylIsovalerate;
formula     C13H18O2;
CAS         56961-73-0;
InChIKey    WYWVAOQKWGNZHN-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          789.99;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.6184;      // -   [origin=predictive method=lee-kesler]
Tb          581.06;      // K   [origin=predictive method=joback]
HvapTb      53439.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.789 1.11696 -0.0006264 1.109e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenylethyl 3-methylbutanoate" "butanoic acid, 3-methyl-, 1-phenylethyl ester" "styrallyl isovalerate" );
gibbsFormation
{
    dHf_298   -402960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144260.0
    phase     gas;
}
