/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethyl-1,6-heptadien-4-ol  (C9H16O, CAS 29765-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethyl16Heptadien4Ol;
formula     C9H16O;
CAS         29765-76-2;
InChIKey    BUCLVUABDUWMHW-UHFFFAOYSA-N;
MW          140.226;      // g/mol [origin=calculated method=formula-sum]
Tc          664.11;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.7676;      // -   [origin=predictive method=lee-kesler]
Tb          490.38;      // K   [origin=predictive method=joback]
HvapTb      50739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.048 0.85854 -0.0005498 1.436e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-dimethylhepta-1,6-dien-4-ol" );
standardThermochemistry
{
    dHf_298   -155320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=44220.0
}
