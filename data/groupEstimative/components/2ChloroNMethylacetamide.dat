/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-n-methylacetamide  (C3H6ClNO, CAS 96-30-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroNMethylacetamide;
formula     C3H6ClNO;
CAS         96-30-0;
InChIKey    HOZLOOPIXHWKCI-UHFFFAOYSA-N;
MW          107.537;      // g/mol [origin=calculated method=formula-sum]
Tc          603.59;      // K   [origin=predictive method=joback]
Pc          46.466;      // bar [origin=predictive method=joback]
omega       0.4957;      // -   [origin=predictive method=lee-kesler]
Tb          409.71;      // K   [origin=predictive method=joback]
HvapTb      39839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.201 0.34382 -0.0001897 3.496e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2Cl; count 1; } { group CONHCH3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group Cl; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-n-methyl-ethanamide" "acetamide, 2-chloro-n-methyl-" "n-methylchloroacetamide" "n-methyl-2-chloroacetamide" "usaf do-35" "alpha-chloro-n-methylacetamide" "2-chloro-n-methyl-acetamide" ".alpha.-chloro-n-methylacetamide" );
standardThermochemistry
{
    dHf_298   -180100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77080.0
}
