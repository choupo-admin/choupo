/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[3.4]oct-5-ene  (C8H12, CAS 14783-50-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro34Oct5Ene;
formula     C8H12;
CAS         14783-50-7;
InChIKey    GSTBLMRSOPHVLU-UHFFFAOYSA-N;
MW          108.184;      // g/mol [origin=calculated method=formula-sum]
Tc          631.59;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.2520;      // -   [origin=predictive method=lee-kesler]
Tb          408.73;      // K   [origin=predictive method=joback]
HvapTb      33022.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-163.26 1.3088 -0.00133428 5.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[3.4]oct-7-ene" "spiro(3.4)oct-5-ene" );
gibbsFormation
{
    dHf_298   18190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     401.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=145960.0
    phase     gas;
}
