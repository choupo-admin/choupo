/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-((3-methylundecyl)amino)ethyl methacrylate  (C18H35NO2, CAS 67905-50-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23MethylundecylAminoEthylMethacrylate;
formula     C18H35NO2;
CAS         67905-50-4;
InChIKey    TVZYQAQDHXWCER-UHFFFAOYSA-N;
MW          297.483;      // g/mol [origin=calculated method=formula-sum]
Tc          891.03;      // K   [origin=predictive method=joback]
Pc          12.115;      // bar [origin=predictive method=joback]
omega       0.9513;      // -   [origin=predictive method=lee-kesler]
Tb          715.95;      // K   [origin=predictive method=joback]
HvapTb      68527.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.361 1.72106 -0.0009378 1.751e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 1; } { group CH2=C; count 1; } { group CH2NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methylundecylamino)ethyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 2-((3-methylundecyl)amino)ethyl ester" "2-propenoic acid, 2-methyl-, 2-[(3-methylundecyl)amino]ethyl ester" "2-((3-methylundecyl)amino)ethyl 2-methyl-2-propenoate" );
standardThermochemistry
{
    dHf_298   -568300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     930.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-43450.0
}
