/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diphenyl-2-propyn-1-ol  (C15H12O, CAS 3923-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diphenyl2Propyn1Ol;
formula     C15H12O;
CAS         3923-52-2;
InChIKey    SMCLTAARQYTXLW-UHFFFAOYSA-N;
MW          208.26;      // g/mol [origin=calculated method=formula-sum]
Tc          918.95;      // K   [origin=predictive method=joback]
Pc          33.144;      // bar [origin=predictive method=joback]
omega       0.8210;      // -   [origin=predictive method=lee-kesler]
Tb          675.23;      // K   [origin=predictive method=joback]
HvapTb      68777.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.96 1.3369 -0.00105273 3.1839e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-diphenylprop-2-yn-1-ol" "diphenylethinylcarbinol" "ethynyldiphenylmethanol" "1,1-diphenylpropargyl alcohol" "diphenylethynylcarbinol" "benzenemethanol, .alpha.-ethynyl-.alpha.-phenyl-" "3,3-diphenyl-3-hydroxy-1-propyne" "benzenemethanol, alpha-ethynyl-alpha-phenyl-" "diphenyl ethynyl carbinol" "2-propyn-1-ol,1-diphenyl-" "smcltaarqytxlw-uhfffaoysa-" "1,1-di(phenyl)prop-2-yn-1-ol" );
gibbsFormation
{
    dHf_298   251050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=389330.0
    phase     gas;
}
