/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-phenyl-1-cyclohexene  (C12H14, CAS 4994-16-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Phenyl1Cyclohexene;
formula     C12H14;
CAS         4994-16-5;
InChIKey    XWCWNUSFQVJNDI-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          762.99;      // K   [origin=predictive method=joback]
Pc          30.933;      // bar [origin=predictive method=joback]
omega       0.3527;      // -   [origin=predictive method=lee-kesler]
Tb          519.55;      // K   [origin=predictive method=joback]
HvapTb      45303.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.75 1.131 -0.00072848 1.709e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH=CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclohex-3-en-1-ylbenzene" "4-phenylcyclohexene" "benzene, 3-cyclohexen-1-yl-" "3-cyclohexen-1-ylbenzene" "1,2,3,3,6,6-hexadeuterio-4-phenylcyclohexene" "(3-cyclohexen-1-yl)benzene;4-phenyl-1-cyclohexene; 4-phenylcyclohexene" );
gibbsFormation
{
    dHf_298   57620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=216980.0
    phase     gas;
}
