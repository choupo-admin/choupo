/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4-carbomethoxy)benzyl p-toluate  (C17H16O4, CAS 55044-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4CarbomethoxyBenzylPToluate;
formula     C17H16O4;
CAS         55044-52-5;
InChIKey    KUNUTDVIDIBBOU-UHFFFAOYSA-N;
MW          284.311;      // g/mol [origin=calculated method=formula-sum]
Tc          997.85;      // K   [origin=predictive method=joback]
Pc          20.512;      // bar [origin=predictive method=joback]
omega       0.9202;      // -   [origin=predictive method=lee-kesler]
Tb          768.32;      // K   [origin=predictive method=joback]
HvapTb      74126.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.959 1.23244 -0.00064012 7.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methoxycarbonylphenyl)methyl 4-methylbenzoate" "benzoic acid, 4-methyl-, (4-(methoxycarbonyl)phenyl)methyl ester" "benzoic acid, 4-methyl-, [4-(methoxycarbonyl)phenyl]methyl ester" "4-methyl-benzoic acid [4-(methoxycarbonyl)phenyl]methyl ester" "(4-(methoxycarbonyl)phenyl)methyl p-toluate" );
gibbsFormation
{
    dHf_298   -578650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     695.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-322920.0
    phase     gas;
}
