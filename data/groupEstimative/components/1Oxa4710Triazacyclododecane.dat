/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-oxa-4,7,10-triazacyclododecane  (C8H19N3O, CAS 53835-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Oxa4710Triazacyclododecane;
formula     C8H19N3O;
CAS         53835-21-5;
InChIKey    NLINGGCQUVARNS-UHFFFAOYSA-N;
MW          173.26;      // g/mol [origin=calculated method=formula-sum]
Tc          874.77;      // K   [origin=predictive method=joback]
Pc          42.607;      // bar [origin=predictive method=joback]
omega       0.5574;      // -   [origin=predictive method=lee-kesler]
Tb          605.08;      // K   [origin=predictive method=joback]
HvapTb      59956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-38.57 0.8116 -7.37e-05 -1.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group FCH2O; count 1; } { group CH2NH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group O_ring; count 1; } { group NH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-oxa-4,7,10-triaza-cyclododecane" );
standardThermochemistry
{
    dHf_298   -189320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=153050.0
}
