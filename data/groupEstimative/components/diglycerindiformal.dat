/*--------------------------------*- Choupo -*-----------------------*\
  Component: diglycerindiformal  (C8H14O5, CAS 56552-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diglycerindiformal;
formula     C8H14O5;
CAS         56552-15-9;
InChIKey    GBTVFZDADUZIIQ-UHFFFAOYSA-N;
MW          190.195;      // g/mol [origin=calculated method=formula-sum]
Tc          763.62;      // K   [origin=predictive method=joback]
Pc          35.473;      // bar [origin=predictive method=joback]
omega       0.6393;      // -   [origin=predictive method=lee-kesler]
Tb          543.42;      // K   [origin=predictive method=joback]
HvapTb      54366.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.568 0.952 -0.0004996 7.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 2; } { group CH2O; count 1; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group O; count 1; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(1,3-dioxolan-4-ylmethoxymethyl)-1,3-dioxolane" "4,4'-oxi-(bismethyl)-bis-1,3-dioxolan" "4,4'-(oxybis(methylene))bis-1,3-dioxolone" "4,4'-[oxybis(methylene)]bis(1,3-dioxolane)" "1,3-dioxolane, 4,4'-(oxybis(methylene))bis-" "1,3-dioxolone, 4,4'-(oxybis(methylene))bis-" "1,3-dioxolane, 4,4'-[oxybis(methylene)]bis-" "1,3-dioxolane,4,4'-[oxybis(methylene)]bis-" "4,4'-(oxy-(bismethylene))-bis-1,3-dioxolane" );
standardThermochemistry
{
    dHf_298   -747710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     172.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-359900.0
}
