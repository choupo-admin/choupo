/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-2,3-diphenyl-2-butene  (C16H16, CAS 782-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans23Diphenyl2Butene;
formula     C16H16;
CAS         782-06-9;
InChIKey    ATYQGOFMEQUNMJ-BUHFOSPRSA-N;
MW          208.304;      // g/mol [origin=calculated method=formula-sum]
Tc          872.23;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.4825;      // -   [origin=predictive method=lee-kesler]
Tb          622.96;      // K   [origin=predictive method=joback]
HvapTb      55880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-93.03 1.38584 -0.0009974 2.812e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 10; } { group AC; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-3-phenylbut-2-en-2-yl]benzene" "[(1e)-1-methyl-2-phenyl-1-propenyl]benzene" "[(e)-1-methyl-2-phenyl-prop-1-enyl]-benzene" "benzene, 1,1'-(1,2-dimethyl-1,2-ethenediyl)bis-, (e)-" );
gibbsFormation
{
    dHf_298   197130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=371780.0
    phase     gas;
}
