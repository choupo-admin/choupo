/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-cyclopropyl methyl p-tolyl carbinol  (C12H16O, CAS 16145-97-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlCyclopropylMethylPTolylCarbinol;
formula     C12H16O;
CAS         16145-97-4;
InChIKey    IJYCFWNBUFSFNP-UHFFFAOYSA-N;
MW          176.259;      // g/mol [origin=calculated method=formula-sum]
Tc          814.54;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.8123;      // -   [origin=predictive method=lee-kesler]
Tb          601.51;      // K   [origin=predictive method=joback]
HvapTb      60540.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-97.05 1.31614 -0.00101556 3.132e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopropyl-1-(4-methylphenyl)ethanol" "dl-1-cyclopropyl-1-(p-tolyl)ethanol" "ethanol, 1-cyclopropyl-1-(p-tolyl)-, dl-" "dl-alpha-cyclopropyl-alpha,p-dimethylbenzyl alcohol" "benzyl alcohol, alpha-cyclopropyl-alpha,p-dimethyl-, dl-" "ethanol, dl-" "benzyl alcohol,p-dimethyl-, dl-" "benzyl alcohol,.alpha.-dimethyl-, (.+-.)-" "alpha-cyclopropyl-alpha,p-dimethylbenzyl alcohol" "alpha-cyclopropyl-alpha-4-dimethylbenzyl alcohol" "dl-.alpha.-cyclopropyl-.alpha.,p-dimethylbenzyl alcohol" "benzyl alcohol, alpha-cyclopropyl-p,alpha-dimethyl-, (+-)-" );
standardThermochemistry
{
    dHf_298   -154130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=79710.0
}
