/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]hept-2-ylmethylacetate  (C10H16O2, CAS 53075-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Hept2Ylmethylacetate;
formula     C10H16O2;
CAS         53075-46-0;
InChIKey    PNHMYWBHPUEEDK-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          702.51;      // K   [origin=predictive method=joback]
Pc          27.099;      // bar [origin=predictive method=joback]
omega       0.5117;      // -   [origin=predictive method=lee-kesler]
Tb          499.70;      // K   [origin=predictive method=joback]
HvapTb      44950.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.459 1.16472 -0.0007642 1.912e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 3; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bicyclo[2.2.1]heptanylmethyl ethanoate" "bicyclo(2.2.1)heptane-2-methanol, acetate" "bicyclo[2.2.1]heptane-2-methanol, acetate" "bicyclo(2.2.1)heptane-2-methanol, 2-acetate" "bicyclo[2.2.1]heptane-2-methanol, 2-acetate" "agn-pc-02ltbu" "bicyclo[2.2.1]hept-2-ylmethyl acetate" "3-bicyclo[2.2.1]heptanylmethyl acetate" "bicyclo[2.2.1]heptan-2-ylmethyl acetate" "(bicyclo(2.2.1)hept-2-yl)methyl acetate" "[(1r,3r,4s)-3-bicyclo[2.2.1]heptanyl]methyl acetate" );
gibbsFormation
{
    dHf_298   -447910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-175360.0
    phase     gas;
}
