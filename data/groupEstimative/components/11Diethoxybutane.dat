/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethoxybutane  (C8H18O2, CAS 3658-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diethoxybutane;
formula     C8H18O2;
CAS         3658-95-5;
InChIKey    UVHXZFGCCJLFMX-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          594.90;      // K   [origin=predictive method=joback]
Pc          24.703;      // bar [origin=predictive method=joback]
omega       0.5194;      // -   [origin=predictive method=lee-kesler]
Tb          427.04;      // K   [origin=predictive method=joback]
HvapTb      37834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.934 0.64336 -0.0001926 -2.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butane, 1,1-diethoxy-" "butyraldehyde, diethyl acetal" "butyraldehyde diethyl acetal" "butyraldehyde,diethyl acetal (6ci,7ci,8ci); 1,1-diethoxybutane; butanal diethyl acetal;butylaldehyde diethyl acetal; butyraldehyde ethyl acetal" );
standardThermochemistry
{
    dHf_298   -478170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     480.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-195960.0
}
