/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibenzyloxybenzene  (C20H18O2, CAS 621-91-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibenzyloxybenzene;
formula     C20H18O2;
CAS         621-91-0;
InChIKey    DYULYMCXVSRUPB-UHFFFAOYSA-N;
MW          290.362;      // g/mol [origin=calculated method=formula-sum]
Tc          1036.10;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       0.8120;      // -   [origin=predictive method=lee-kesler]
Tb          787.06;      // K   [origin=predictive method=joback]
HvapTb      72424.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.708 1.4812 -0.00086876 1.688e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 14; } { group AC; count 4; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(phenylmethoxy)benzene" "hydroquinone dibenzyl ether" "1,4-bis(benzyloxy)benzene" "p-bis(benzyloxy)benzene" "benzene, 1,4-bis(phenylmethoxy)-" );
gibbsFormation
{
    dHf_298   -22450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=235120.0
    phase     gas;
}
