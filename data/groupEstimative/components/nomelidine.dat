/*--------------------------------*- Choupo -*-----------------------*\
  Component: nomelidine  (C15H15BrN2, CAS 60324-59-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nomelidine;
formula     C15H15BrN2;
CAS         60324-59-6;
InChIKey    AZFZKANGXPSDEA-NVNXTCNLSA-N;
MW          303.203;      // g/mol [origin=calculated method=formula-sum]
Tc          1038.42;      // K   [origin=predictive method=joback]
Pc          28.566;      // bar [origin=predictive method=joback]
omega       0.8612;      // -   [origin=predictive method=lee-kesler]
Tb          775.21;      // K   [origin=predictive method=joback]
HvapTb      73317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.089 1.37958 -0.00100292 2.89e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3NH; count 1; } { group C5H4N; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group Br; count 1; } { group NH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-3-(4-bromophenyl)-n-methyl-3-pyridin-3-yl-prop-2-en-1-amine" "nomelidinum [inn-latin]" "(z)-3-(4-bromphenyl)-n-methyl-3-(3-pyridyl)allylamin" "(z)-3-(1-(p-bromophenyl)-3-(methylamino)propenyl)pyridine" "(z)-3-[1-(p-bromophenyl)-3-(methylamino)propenyl]pyridine" "nomelidina" "nomelidinum" "enediyne antibiotics" "nomelidine [inn]" "norzimelidine, (z)-isomer" "(z)-3-(4-bromophenyl)-n-methyl-3-pyridin-3-ylprop-2-en-1-amine" );
standardThermochemistry
{
    dHf_298   328680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     614.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=543040.0
}
