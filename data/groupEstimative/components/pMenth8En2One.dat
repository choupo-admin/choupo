/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-menth-8-en-2-one  (C10H16O, CAS 7764-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMenth8En2One;
formula     C10H16O;
CAS         7764-50-3;
InChIKey    AZOCECCLWFDTAP-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          730.07;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.3934;      // -   [origin=predictive method=lee-kesler]
Tb          507.66;      // K   [origin=predictive method=joback]
HvapTb      41631.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.12 0.86104 -0.000327 -4.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-5-prop-1-en-2-yl-cyclohexan-1-one" "dihydrocarvone" "cyclohexanone, 2-methyl-5-(1-methylethenyl)-" "(+)-dihydrocarvone" "8-p-menthen-2-one" "2-methyl-5-(1-methylethenyl)cyclohexanone" "(+)-dihydrocarvone, mixture of isomers" "p-menth-8(9)-en-2-one" "2-methyl-5-(prop-1-en-2-yl)cyclohexanone" "2-methyl-5-(1-methylvinyl)cyclohexan-1-one" "2-methyl-5-prop-1-en-2-ylcyclohexan-1-one" "(2r,5r)-5-isopropenyl-2-methylcyclohexanone" );
standardThermochemistry
{
    dHf_298   -237810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6760.0
}
