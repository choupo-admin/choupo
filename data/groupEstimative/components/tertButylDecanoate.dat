/*--------------------------------*- Choupo -*-----------------------*\
  Component: tert-butyl decanoate  (C14H28O2, CAS 16474-41-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tertButylDecanoate;
formula     C14H28O2;
CAS         16474-41-2;
InChIKey    IZUZIVIUDTZPFE-UHFFFAOYSA-N;
MW          228.376;      // g/mol [origin=calculated method=formula-sum]
Tc          748.23;      // K   [origin=predictive method=joback]
Pc          15.524;      // bar [origin=predictive method=joback]
omega       0.7187;      // -   [origin=predictive method=lee-kesler]
Tb          574.91;      // K   [origin=predictive method=joback]
HvapTb      52869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.902 1.40488 -0.000815 1.702e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 7; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 8; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decanoic acid tert-butyl ester" );
gibbsFormation
{
    dHf_298   -658320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     713.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-240530.0
    phase     gas;
}
