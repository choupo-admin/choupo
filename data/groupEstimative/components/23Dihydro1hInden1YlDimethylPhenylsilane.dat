/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dihydro-1h-inden-1-yl(dimethyl)phenylsilane  (C17H20Si, CAS 41273-54-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C17H20Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        23Dihydro1hInden1YlDimethylPhenylsilane;
formula     C17H20Si;
CAS         41273-54-5;
InChIKey    HXYKYKQQUONANK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          252.432;      // g/mol [origin=calculated method=formula-sum]
Tc          905.33;      // K   [origin=predictive method=joback]
Pc          20.793;      // bar [origin=predictive method=joback]
omega       0.4801;      // -   [origin=predictive method=lee-kesler]
Tb          655.04;      // K   [origin=predictive method=joback]
HvapTb      58857.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-75.5 1.34624 -0.00070176 9.93e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dihydro-1h-inden-1-yl-dimethyl-phenyl-silane" "silane,(2,3-dihydro-1h-inden-1-yl)dimethylphenyl-" "2,3-dihydro-1h-inden-1-yl-dimethyl-phenylsilane" "silane, (2,3-dihydro-1h-inden-1-yl)dimethylphenyl-" );
standardThermochemistry
{
    dHf_298   28560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     635.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263440.0
}
