/*--------------------------------*- Choupo -*-----------------------*\
  Component: agn-pc-030nch  (C34H52O2, CAS 67785-69-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        agnPc030nch;
formula     C34H52O2;
CAS         67785-69-7;
InChIKey    OAUIRXVDLGQWKJ-UHFFFAOYSA-N;
MW          492.788;      // g/mol [origin=calculated method=formula-sum]
Tc          1310.31;      // K   [origin=predictive method=joback]
Pc          6.602;      // bar [origin=predictive method=joback]
omega       0.5775;      // -   [origin=predictive method=lee-kesler]
Tb          1068.80;      // K   [origin=predictive method=joback]
HvapTb      98176.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.97 3.13404 -0.0020687 5.548e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 8; } { group CH; count 1; } { group CH=C; count 5; } { group ACH; count 5; } { group AC; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 10; } { group CH; count 1; } { group dCH; count 5; } { group dC; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[bis(3,7-dimethylocta-2,6-dienoxy)methyl]hept-1-enylbenzene" "benzene, [2-[bis[(3,7-dimethyl-2,6-octadien-1-yl)oxy]methyl]-1-hepten-1-yl]-" "[(z)-2-[bis[(2e)-3,7-dimethylocta-2,6-dienoxy]methyl]hept-1-enyl]benzene" );
gibbsFormation
{
    dHf_298   -241130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1333.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=493720.0
    phase     gas;
}
