/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3-[bis(2-chloroethyl)amino]phenyl]-morpholin-4-ylmethanone  (C15H20Cl2N2O2, CAS 4587-15-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bis2ChloroethylAminoPhenylMorpholin4Ylmethanone;
formula     C15H20Cl2N2O2;
CAS         4587-15-9;
InChIKey    KMZZDAZLILAJHI-UHFFFAOYSA-N;
MW          331.237;      // g/mol [origin=calculated method=formula-sum]
Tc          999.14;      // K   [origin=predictive method=joback]
Pc          21.573;      // bar [origin=predictive method=joback]
omega       1.0233;      // -   [origin=predictive method=lee-kesler]
Tb          774.97;      // K   [origin=predictive method=joback]
HvapTb      76600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.696 1.679 -0.00117256 3.1066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } { group CH2Cl; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 2; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3-[bis(2-chloroethyl)amino]phenyl]-morpholin-4-yl-methanone" );
gibbsFormation
{
    dHf_298   -188050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     694.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=205120.0
    phase     gas;
}
