/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-(2-chloroethoxy)ethoxy]-2-(2-methyloctyl)benzene  (C19H31ClO2, CAS 68953-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122ChloroethoxyEthoxy22MethyloctylBenzene;
formula     C19H31ClO2;
CAS         68953-81-1;
InChIKey    BHFYOCZGQADWRU-UHFFFAOYSA-N;
MW          326.905;      // g/mol [origin=calculated method=formula-sum]
Tc          939.17;      // K   [origin=predictive method=joback]
Pc          12.856;      // bar [origin=predictive method=joback]
omega       0.9043;      // -   [origin=predictive method=lee-kesler]
Tb          747.81;      // K   [origin=predictive method=joback]
HvapTb      69643.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.22 1.55674 -0.00077556 1.144e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2O; count 2; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(2-chloroethyloxy)ethoxy]-2-(2-methyloctyl)benzene" );
gibbsFormation
{
    dHf_298   -495890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     829.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-12490.0
    phase     gas;
}
