/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-octanedione  (C8H14O2, CAS 3214-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Octanedione;
formula     C8H14O2;
CAS         3214-41-3;
InChIKey    SPDFSSLYVRCMDZ-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          676.22;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.6588;      // -   [origin=predictive method=lee-kesler]
Tb          490.38;      // K   [origin=predictive method=joback]
HvapTb      46894.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.334 0.70784 -0.000374 6.592e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH3CO; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octane-2,5-dione" );
standardThermochemistry
{
    dHf_298   -433610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     521.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-241360.0
}
