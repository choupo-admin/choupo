/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclo[2.2.1]heptane-1-carboxylic acid  (C8H12O2, CAS 18720-30-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclo221Heptane1CarboxylicAcid;
formula     C8H12O2;
CAS         18720-30-4;
InChIKey    LKXGYGYFPTZHLC-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          776.61;      // K   [origin=predictive method=joback]
Pc          40.725;      // bar [origin=predictive method=joback]
omega       0.6309;      // -   [origin=predictive method=lee-kesler]
Tb          546.14;      // K   [origin=predictive method=joback]
HvapTb      49413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-155.38 1.3987 -0.0014106 5.787e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]heptane-4-carboxylic acid" "1-norbornanecarboxylic acid" "bicyclo(2.2.1)heptane-1-carboxylic acid" "1-norbornane carboxylic acid" "bicyclo[2.2.1]heptane-1-carboxylicacid" "bicyclo[2.2.1]heptane-1-carboxylic acid (221)" );
gibbsFormation
{
    dHf_298   -404040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     429.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-223520.0
    phase     gas;
}
