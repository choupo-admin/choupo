/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,7-dimethylbicyclo[2.2.1]heptane  (C9H16, CAS 2034-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        77Dimethylbicyclo221Heptane;
formula     C9H16;
CAS         2034-53-9;
InChIKey    NGSMAXPULGPQNT-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          626.97;      // K   [origin=predictive method=joback]
Pc          31.385;      // bar [origin=predictive method=joback]
omega       0.2790;      // -   [origin=predictive method=lee-kesler]
Tb          418.84;      // K   [origin=predictive method=joback]
HvapTb      34166.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-154.95 1.41644 -0.001337 5.344e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7,7-dimethyl-bicyclo(2.2.1)heptane" "7,7-dimethyl-bicyclo[2.2.1]heptane" "7,7-dimethylnorbornane" "agn-pc-01m4cv" "bicyclo[2.2.1]heptane, 7,7-dimethyl-" "7,7-dimethylbicyclo[2.2.1]hepta-1,3,5-triene" );
standardThermochemistry
{
    dHf_298   -94750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121100.0
}
