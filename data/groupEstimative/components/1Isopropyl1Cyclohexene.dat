/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-isopropyl-1-cyclohexene  (C9H16, CAS 4292-04-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Isopropyl1Cyclohexene;
formula     C9H16;
CAS         4292-04-0;
InChIKey    ZYMCVIZKLGUPBG-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          641.30;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.3136;      // -   [origin=predictive method=lee-kesler]
Tb          433.44;      // K   [origin=predictive method=joback]
HvapTb      36932.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.44 0.89784 -0.00052564 1.125e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propan-2-ylcyclohexene" "1-isopropylcyclohexene" "1-isopropylcyclohexene-1" "cyclohexene,1-(1-methylethyl)-" "cyclohexene,1-isopropyl- (6ci,7ci,8ci); 1-isopropyl-1-cyclohexene; 1-isopropylcyclohexene" );
standardThermochemistry
{
    dHf_298   -113400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74950.0
}
