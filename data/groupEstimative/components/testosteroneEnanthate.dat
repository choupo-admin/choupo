/*--------------------------------*- Choupo -*-----------------------*\
  Component: testosterone enanthate  (C26H40O3, CAS 315-37-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        testosteroneEnanthate;
formula     C26H40O3;
CAS         315-37-7;
InChIKey    VOCBWIIFXDYGNZ-IXKNJLPQSA-N;
MW          400.603;      // g/mol [origin=calculated method=formula-sum]
Tc          1197.93;      // K   [origin=predictive method=joback]
Pc          11.231;      // bar [origin=predictive method=joback]
omega       0.9056;      // -   [origin=predictive method=lee-kesler]
Tb          964.11;      // K   [origin=predictive method=joback]
HvapTb      83670.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-251.505 3.22166 -0.00257544 8.947e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(8r,9s,10r,13s,14s,17s)-10,13-dimethyl-3-oxidanylidene-1,2,6,7,8,9,11,12,14,15,16,17-dodecahydrocyclopenta[a]phenanthren-17-yl] heptanoate" "testosterone heptanoate" "andropository" "testostroval" "androtardyl" "atlatest" "durathate" "testanthate" "testinon" "testoenant" "everone" "orquisteron-e" );
standardThermochemistry
{
    dHf_298   -738440.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     890.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-88490.0
}
