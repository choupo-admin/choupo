/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylglyoxal  (C3H4O2, CAS 78-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylglyoxal;
formula     C3H4O2;
CAS         78-98-8;
InChIKey    AIJULSRZWUXGPQ-UHFFFAOYSA-N;
MW          72.063;      // g/mol [origin=calculated method=formula-sum]
Tc          559.44;      // K   [origin=predictive method=joback]
Pc          53.357;      // bar [origin=predictive method=joback]
omega       0.4355;      // -   [origin=predictive method=lee-kesler]
Tb          370.77;      // K   [origin=predictive method=joback]
HvapTb      35738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.92 0.23532 -0.0001137 1.336e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3CO; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CdO; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oxidanylidenepropanal" "pyruvaldehyde" "2-oxopropanal" "acetylformaldehyde" "pyruvic aldehyde" "acetylformyl" "propanal, 2-oxo-" "2-ketopropionaldehyde" "propanedione" "propanolone" "alpha-ketopropionaldehyde" "pyroracemic aldehyde" );
standardThermochemistry
{
    dHf_298   -303410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     318.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-254060.0
}
