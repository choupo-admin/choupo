/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,4s)-2,4-dimethylthiane  (C7H14S, CAS 61568-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s4s24Dimethylthiane;
formula     C7H14S;
CAS         61568-43-2;
InChIKey    ZUJJNQJNBRWNQH-BQBZGAKWSA-N;
MW          130.249;      // g/mol [origin=calculated method=formula-sum]
Tc          641.66;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.2485;      // -   [origin=predictive method=lee-kesler]
Tb          422.47;      // K   [origin=predictive method=joback]
HvapTb      37108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.32 0.77885 -0.0004013 6.23e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -108570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=64660.0
}
