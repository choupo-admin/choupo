/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-styryl-3,4-benzopyrene  (C28H18, CAS 63019-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Styryl34Benzopyrene;
formula     C28H18;
CAS         63019-73-8;
InChIKey    FUSTYROFQLNAPQ-DTQAZKPQSA-N;
MW          354.452;      // g/mol [origin=calculated method=formula-sum]
Tc          1258.33;      // K   [origin=predictive method=joback]
Pc          17.985;      // bar [origin=predictive method=joback]
omega       0.9951;      // -   [origin=predictive method=lee-kesler]
Tb          985.90;      // K   [origin=predictive method=joback]
HvapTb      91004.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.67 2.3484 -0.00202984 7.008e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 16; } { group AC; count 10; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 16; } { group dC_ring; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-[(e)-2-phenylethenyl]benzo[a]pyrene" "benzo(a)pyrene, 6-styryl-" );
gibbsFormation
{
    dHf_298   641970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=872240.0
    phase     gas;
}
