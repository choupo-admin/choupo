/*--------------------------------*- Choupo -*-----------------------*\
  Component: naphthalene, undecyl-  (C21H30, CAS 100766-72-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        naphthaleneUndecyl;
formula     C21H30;
CAS         100766-72-1;
InChIKey    DDAIBSKPPVQJSU-UHFFFAOYSA-N;
MW          282.471;      // g/mol [origin=calculated method=formula-sum]
Tc          931.17;      // K   [origin=predictive method=joback]
Pc          13.996;      // bar [origin=predictive method=joback]
omega       0.8281;      // -   [origin=predictive method=lee-kesler]
Tb          730.72;      // K   [origin=predictive method=joback]
HvapTb      66918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.25 1.85672 -0.00121948 3.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group ACH; count 7; } { group AC; count 2; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-undecylnaphthalene" "undecane, 1-(1-naphthyl)-" "1-(n-undecyl)naphthalene" "1-.alpha.-naphthylhendecane" );
standardThermochemistry
{
    dHf_298   -60640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=335370.0
}
