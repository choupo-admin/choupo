/*--------------------------------*- Choupo -*-----------------------*\
  Component: ketone, 2-methylcyclohexyl 4-methylpiperidino  (C14H25NO, CAS 64387-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ketone2Methylcyclohexyl4Methylpiperidino;
formula     C14H25NO;
CAS         64387-77-5;
InChIKey    BJZXFKCHSKEWII-UHFFFAOYSA-N;
MW          223.36;      // g/mol [origin=calculated method=formula-sum]
Tc          836.54;      // K   [origin=predictive method=joback]
Pc          21.653;      // bar [origin=predictive method=joback]
omega       0.6124;      // -   [origin=predictive method=lee-kesler]
Tb          616.39;      // K   [origin=predictive method=joback]
HvapTb      55924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.32 1.65704 -0.0009847 2.0466e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 3; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methylcyclohexyl)-(4-methylpiperidin-1-yl)methanone" "4-methyl-1-((2-methylcyclohexyl)carbonyl)piperidine" "piperidine, 4-methyl-1-((2-methylcyclohexyl)carbonyl)-" );
gibbsFormation
{
    dHf_298   -282880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102150.0
    phase     gas;
}
