/*--------------------------------*- Choupo -*-----------------------*\
  Component: methoxy-d3 radical  (CD3O, CAS 7263-60-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula CD3O (delta D+3H-3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methoxyD3Radical;
formula     CD3O;
CAS         7263-60-7;
InChIKey    GRVDJDISBSALJP-FIBGUPNXSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          34.052;      // g/mol [origin=calculated method=formula-sum]
Tc          346.02;      // K   [origin=predictive method=joback]
Pc          69.329;      // bar [origin=predictive method=joback]
omega       0.2155;      // -   [origin=predictive method=lee-kesler]
Tb          211.28;      // K   [origin=predictive method=joback]
HvapTb      23582.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.61 0.22152 -0.0002253 9.15e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group dO_oth; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trideuterio($l^{1}-oxidanyl)methane" "cd3o" );
standardThermochemistry
{
    dHf_298   -255770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     254.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-240910.0
}
