/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-4-methoxytoluene  (C8H9ClO, CAS 22002-44-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Chloro4Methoxytoluene;
formula     C8H9ClO;
CAS         22002-44-4;
InChIKey    VUZBRBKYGIQXMP-UHFFFAOYSA-N;
MW          156.609;      // g/mol [origin=calculated method=formula-sum]
Tc          696.85;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.4234;      // -   [origin=predictive method=lee-kesler]
Tb          479.13;      // K   [origin=predictive method=joback]
HvapTb      43797.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.7 0.50954 -0.00021792 1.39e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group CH3O; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-1-methoxy-4-methyl-benzene" "2-chloro-1-methoxy-4-methylbenzene" "benzene,2-chloro-1-methoxy-4-methyl-" "2-chloro-1-methoxy-4-methyl-benzene" );
gibbsFormation
{
    dHf_298   -142820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     393.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-7300.0
    phase     gas;
}
