/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s,3r,4s)-1,6,8-trihydroxy-3,4,5-trimethyl-3,4-dihydro-1h-isochromene-7-carboxylic acid  (C13H16O6, CAS 157643-56-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s3r4s168Trihydroxy345Trimethyl34Dihydro1hIsochromene7Carbox;
formula     C13H16O6;
CAS         157643-56-6;
InChIKey    MBTAFMZUDOUGPS-CGKQSRJASA-N;
MW          268.265;      // g/mol [origin=calculated method=formula-sum]
Tc          1199.66;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       1.9375;      // -   [origin=predictive method=lee-kesler]
Tb          966.21;      // K   [origin=predictive method=joback]
HvapTb      112642.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.05 1.46076 -0.0011783 4.026e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH; count 2; } { group OH; count 1; } { group ACOH; count 2; } { group CH-O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH_ring; count 3; } { group dC_ring; count 6; } { group OH; count 1; } { group OH_phenol; count 2; } { group O_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,3r,4s)-3,4,5-trimethyl-1,6,8-tris(oxidanyl)-3,4-dihydro-1h-isochromene-7-carboxylic acid" "citrinin hydrate" "3,4-dihydro-1,6,8-trihydroxy-3,4,5-trimethyl-1h-2-benzopyran-7-carboxylic acid" "1h-2-benzopyran-7-carboxylicacid, 3,4-dihydro-1,6,8-trihydroxy-3,4,5-trimethyl-, (1a,3b,4a)-" "1h-2-benzopyran-7-carboxylicacid, 3,4-dihydro-1,6,8-trihydroxy-3,4,5-trimethyl-, (1r,3s,4r)-rel-" );
standardThermochemistry
{
    dHf_298   -1072690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     488.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-700760.0
}
