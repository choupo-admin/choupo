/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-3-methylbut-1-ene  (C7H14, CAS 7357-93-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl3Methylbut1Ene;
formula     C7H14;
CAS         7357-93-9;
InChIKey    ADHCYQWFCLQBFG-UHFFFAOYSA-N;
MW          98.189;      // g/mol [origin=calculated method=formula-sum]
Tc          530.41;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.2759;      // -   [origin=predictive method=lee-kesler]
Tb          355.88;      // K   [origin=predictive method=joback]
HvapTb      30198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.839 0.65466 -0.0003854 9.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-methylidene-pentane" "2-ethyl-3-methyl-1-butene" "3-methyl-2-ethyl-1-butene" "1-butene, 2-ethyl-3-methyl-" "2-methyl-3-methylidenepentane" "pentane,2-methyl-3-methylene-" "2-ethyl-3-methyl-butene" );
gibbsFormation
{
    dHf_298   -77450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=84910.0
    phase     gas;
}
