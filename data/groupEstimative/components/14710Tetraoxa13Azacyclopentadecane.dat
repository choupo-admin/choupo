/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,7,10-tetraoxa-13-azacyclopentadecane  (C10H21NO4, CAS 66943-05-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14710Tetraoxa13Azacyclopentadecane;
formula     C10H21NO4;
CAS         66943-05-3;
InChIKey    BJUOQSZSDIHZNP-UHFFFAOYSA-N;
MW          219.281;      // g/mol [origin=calculated method=formula-sum]
Tc          914.78;      // K   [origin=predictive method=joback]
Pc          33.567;      // bar [origin=predictive method=joback]
omega       0.5811;      // -   [origin=predictive method=lee-kesler]
Tb          647.40;      // K   [origin=predictive method=joback]
HvapTb      64938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.63 0.9906 -0.0001228 -1.912e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group FCH2O; count 4; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group O_ring; count 4; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aza-15-crown-5" "1-aza-15-crown-5" "1-aza-15-crown-5-ether" "1-aza-15-crown 5-ether" "1-aza-4,7,10,13-tetraoxacyclopentadecane;1-aza-15-crown-5;13-aza-15-crown-5;aza-15-crown-5;monoaza-15-crown-5;1,4,7,10-tetraoxa-15-azacyclopentadecane;" );
gibbsFormation
{
    dHf_298   -720700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-300190.0
    phase     gas;
}
