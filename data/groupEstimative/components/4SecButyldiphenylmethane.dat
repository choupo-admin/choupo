/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-sec-butyldiphenylmethane  (C17H20, CAS 101646-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4SecButyldiphenylmethane;
formula     C17H20;
CAS         101646-63-3;
InChIKey    YCCATRPFNIUXHS-UHFFFAOYSA-N;
MW          224.347;      // g/mol [origin=calculated method=formula-sum]
Tc          877.76;      // K   [origin=predictive method=joback]
Pc          20.755;      // bar [origin=predictive method=joback]
omega       0.5866;      // -   [origin=predictive method=lee-kesler]
Tb          646.46;      // K   [origin=predictive method=joback]
HvapTb      58262.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.758 1.40744 -0.00089956 2.167e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butan-2-yl-4-(phenylmethyl)benzene" "1-benzyl-4-butan-2-ylbenzene" "benzene, (1-methylpropyl)(phenylmethyl)-" "benzene, 1-(1-methylpropyl)-4-(phenylmethyl)-" );
gibbsFormation
{
    dHf_298   62100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=305010.0
    phase     gas;
}
