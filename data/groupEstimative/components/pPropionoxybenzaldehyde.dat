/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-propionoxybenzaldehyde  (C10H10O3, CAS 50262-48-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H10O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pPropionoxybenzaldehyde;
formula     C10H10O3;
CAS         50262-48-1;
InChIKey    NKXPJXVTMWLHBC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          705.50;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.4865;      // -   [origin=predictive method=lee-kesler]
Tb          494.70;      // K   [origin=predictive method=joback]
HvapTb      45826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.899 0.76872 -0.00054276 1.48e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methanoylphenyl) propanoate" "4-formylphenyl propanoate" "4-formylphenyl propionate" "4-propionyloxybenzaldehyde" "4-n-propionyloxybenzaldehyde" "benzaldehyde, 4-(1-oxopropoxy)-" "(4-formylphenyl) propanoate" "4-(propionyloxy)-benzaldehyde" "p-formylphenyl propionate" "benzaldehyde,4-(1-oxopropoxy)-" "propanoic acid (4-formylphenyl) ester" "4-(1-oxopropoxy)benzaldehyde;4-(propionyloxy)benzaldehyde; 4-propionoxybenzaldehyde;p-(propionyloxy)benzaldehyde" );
standardThermochemistry
{
    dHf_298   -265500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-130310.0
}
