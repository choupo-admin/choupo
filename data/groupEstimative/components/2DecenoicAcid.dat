/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-decenoic acid  (C10H18O2, CAS 334-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DecenoicAcid;
formula     C10H18O2;
CAS         334-49-6;
InChIKey    WXBXVVIUZANZAU-CMDGGOBGSA-N;
MW          170.252;      // g/mol [origin=calculated method=formula-sum]
Tc          766.41;      // K   [origin=predictive method=joback]
Pc          24.100;      // bar [origin=predictive method=joback]
omega       0.8446;      // -   [origin=predictive method=lee-kesler]
Tb          578.07;      // K   [origin=predictive method=joback]
HvapTb      54976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.784 1.02462 -0.0006766 1.832e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH=CH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-dec-2-enoic acid" "(e)-2-decenoic acid" "e-2-decenoic acid" "trans-dec-2-enoic acid" "(2e)-2-decenoic acid" "milk lactone" "c10:1n-8" "2-decensaeure" "2-decenoic acids" "2-decylenic acid" "dec-2-en-saeure" "dec-2-enoic acids" );
gibbsFormation
{
    dHf_298   -482780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230370.0
    phase     gas;
}
