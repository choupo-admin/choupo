/*--------------------------------*- Choupo -*-----------------------*\
  Component: .alpha.-santalene  (C15H24, CAS 512-61-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaSantalene;
formula     C15H24;
CAS         512-61-8;
InChIKey    KWFJIXPIFLVMPM-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          755.46;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       0.4922;      // -   [origin=predictive method=lee-kesler]
Tb          549.66;      // K   [origin=predictive method=joback]
HvapTb      45497.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-253.208 2.45148 -0.0025861 1.1138e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 3; } { group C; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6,7-dimethyl-7-(4-methylpent-3-enyl)-2,3,4,5-tetrahydro-1h-tricyclo[2.2.1.0^{2,6}]heptane" "1,7-dimethyl-7-(4-methyl-3-pentenyl)-tricyclo[2.2.1.0(2,6)]heptane" "(+)-alpha-santalene" "tricyclo[2.2.1.0(2,6)]heptane, 1,7-dimethyl-7-(4-methyl-3-pentenyl)-, (-)-" "santalene" "tricyclo(2.2.1.0(2,6))heptane, 1,7-dimethyl-7-(4-methyl-3-pentenyl)-, (-)-" "1,7-dimethyl-7-(4-methylpent-3-en-1-yl)tricyclo[2.2.1.02,6]heptane" );
gibbsFormation
{
    dHf_298   -24980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=327140.0
    phase     gas;
}
