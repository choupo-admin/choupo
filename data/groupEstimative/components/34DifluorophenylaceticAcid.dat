/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-difluorophenylacetic acid  (C8H6F2O2, CAS 658-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DifluorophenylaceticAcid;
formula     C8H6F2O2;
CAS         658-93-5;
InChIKey    YCAKYFIYUHHCKW-UHFFFAOYSA-N;
MW          172.13;      // g/mol [origin=calculated method=formula-sum]
Tc          771.79;      // K   [origin=predictive method=joback]
Pc          35.179;      // bar [origin=predictive method=joback]
omega       0.8034;      // -   [origin=predictive method=lee-kesler]
Tb          563.33;      // K   [origin=predictive method=joback]
HvapTb      52532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.091 0.6403 -0.00041392 9.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group COOH; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3,4-bis(fluoranyl)phenyl]ethanoic acid" "2-(3,4-difluorophenyl)acetic acid" "(3,4-difluorophenyl)acetic acid" "benzeneacetic acid, 3,4-difluoro-" "3,4-difluorophenylaceticacid" "3,4-difluorobenzeneacetic acid" "qv1r cf df" "l427" "2-(3,4-difluorophenyl)acetic acid;2-(3,4-difluorophenyl)acetate;3,4-difluoro phenylacetic acid;" );
standardThermochemistry
{
    dHf_298   -737350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-623900.0
}
