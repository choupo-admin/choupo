/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-trithiane  (C3H6S3, CAS 291-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Trithiane;
formula     C3H6S3;
CAS         291-21-4;
InChIKey    LORRLQMLLQLPSJ-UHFFFAOYSA-N;
MW          138.261;      // g/mol [origin=calculated method=formula-sum]
Tc          706.36;      // K   [origin=predictive method=joback]
Pc          60.467;      // bar [origin=predictive method=joback]
omega       0.2113;      // -   [origin=predictive method=lee-kesler]
Tb          435.95;      // K   [origin=predictive method=joback]
HvapTb      40446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.92 0.48063 -0.0003319 8.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2S; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group S_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "s-trithiane" "trithioformaldehyde" "thioform" "sym-trithian" "trimethylene trisulfide" "thioformaldehyde trimer" "sym-trithiane" "sym.-trithiane" "1,3,5-trithiacyclohexane" "trimethylentrisulfid" "formaldehyde, thio-, trimer" "thioforr" );
gibbsFormation
{
    dHf_298   105190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126120.0
    phase     gas;
}
