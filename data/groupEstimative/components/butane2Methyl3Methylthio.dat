/*--------------------------------*- Choupo -*-----------------------*\
  Component: butane, 2-methyl-3-(methylthio)-  (C6H14S, CAS 53897-51-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butane2Methyl3Methylthio;
formula     C6H14S;
CAS         53897-51-1;
InChIKey    AUNQXXJGFDKEMS-UHFFFAOYSA-N;
MW          118.238;      // g/mol [origin=calculated method=formula-sum]
Tc          602.94;      // K   [origin=predictive method=joback]
Pc          32.246;      // bar [origin=predictive method=joback]
omega       0.3085;      // -   [origin=predictive method=lee-kesler]
Tb          404.78;      // K   [origin=predictive method=joback]
HvapTb      34991.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.67 0.58007 -0.0002688 3.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 2; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-3-methylsulfanyl-butane" "2-methyl-3-(methylsulfanyl)butane" "3,4-dimethyl-2-thiapentane" "2-methyl-3-methylsulfanylbutane" );
standardThermochemistry
{
    dHf_298   -135860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=27880.0
}
