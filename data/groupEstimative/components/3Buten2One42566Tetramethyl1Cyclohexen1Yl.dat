/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-buten-2-one, 4-(2,5,6,6-tetramethyl-1-cyclohexen-1-yl)-  (C14H22O, CAS 79-70-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Buten2One42566Tetramethyl1Cyclohexen1Yl;
formula     C14H22O;
CAS         79-70-9;
InChIKey    BGKCUGPVLVNPSG-CMDGGOBGSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          817.52;      // K   [origin=predictive method=joback]
Pc          20.218;      // bar [origin=predictive method=joback]
omega       0.5735;      // -   [origin=predictive method=lee-kesler]
Tb          602.19;      // K   [origin=predictive method=joback]
HvapTb      54047.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.94 1.5384 -0.0012143 4.2756e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH3CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-(2,5,6,6-tetramethylcyclohexen-1-yl)but-3-en-2-one" "4-(2,5,6,6-tetramethylcyclohex-1-en-1-yl)but-3-en-2-one" "beta-irone" "4-(2,5,6,6-tetramehtyl-1-cyclohexenyl)-3-buten-2-one" "(e)-4-(2,5,6,6-tetramethyl-1-cyclohexenyl)but-3-en-2-one" "4-(2,5,6,6-tetramethyl-1-cyclohexen-1-yl)-3-buten-2-one" );
standardThermochemistry
{
    dHf_298   -243590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     668.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40250.0
}
