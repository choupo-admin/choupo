/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecahydro-1,4:5,8:9,10-trimethanoanthracene-2-methanamine  (C18H27N, CAS 52794-34-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecahydro1458910Trimethanoanthracene2Methanamine;
formula     C18H27N;
CAS         52794-34-0;
InChIKey    RIZITHXTPOYYMA-UHFFFAOYSA-N;
MW          257.421;      // g/mol [origin=calculated method=formula-sum]
Tc          920.79;      // K   [origin=predictive method=joback]
Pc          18.920;      // bar [origin=predictive method=joback]
omega       0.7242;      // -   [origin=predictive method=lee-kesler]
Tb          696.79;      // K   [origin=predictive method=joback]
HvapTb      64064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-273.619 2.5582 -0.0020894 6.987e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 11; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 6; } { group CH_ring; count 11; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4:5,8:9,10-trimethanoanthracene-2-methanamine, tetradecahydro-" "tetradecahydro-1,4:5,8:9,10-trimethylanthracene-2-methylamine" "1-(hexacyclo[6.6.1.13,6.110,13.02,7.09,14]heptadec-4-yl)methanamine (non-preferred name)" );
gibbsFormation
{
    dHf_298   -39800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     135.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=505180.0
    phase     gas;
}
