/*--------------------------------*- Choupo -*-----------------------*\
  Component: cadina-3,9-diene  (C15H24, CAS 523-47-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cadina39Diene;
formula     C15H24;
CAS         523-47-7;
InChIKey    USDOQCCMRDNVAH-KKUMJFAQSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          792.00;      // K   [origin=predictive method=joback]
Pc          19.220;      // bar [origin=predictive method=joback]
omega       0.4751;      // -   [origin=predictive method=lee-kesler]
Tb          576.53;      // K   [origin=predictive method=joback]
HvapTb      50709.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.3 1.44068 -0.00083528 1.762e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 4; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,4ar,8as)-4,7-dimethyl-1-propan-2-yl-1,2,4a,5,8,8a-hexahydronaphthalene" "beta-cadinene" "cadine-3,9-diene" "beta-cadinene, (-)-" "cadinene" "naphthalene, 1,2,4a,5,8,8a-hexahydro-4,7-dimethyl-1-(1-methylethyl)-, (1s-(1alpha,4abeta,8aalpha))-" "(+)-beta-cadinene" "(-)-beta-cadinene" "(-)-.beta.-cadinene" ".beta.-cadinene, (-)-" "cadina-3,9-diene (8ci)" "naphthalene, 1,2,4a,5,8,8a-hexahydro-4,7-dimethyl-1-(1-methylethyl)-, [1s-(1.alpha.,4a.beta.,8a.alpha.)]-" );
standardThermochemistry
{
    dHf_298   -164970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=179030.0
}
