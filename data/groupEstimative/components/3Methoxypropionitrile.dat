/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methoxypropionitrile  (C4H7NO, CAS 110-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methoxypropionitrile;
formula     C4H7NO;
CAS         110-67-8;
InChIKey    OOWFYDWAMOKVSF-UHFFFAOYSA-N;
MW          85.106;      // g/mol [origin=calculated method=formula-sum]
Tc          607.49;      // K   [origin=predictive method=joback]
Pc          37.000;      // bar [origin=predictive method=joback]
omega       0.4447;      // -   [origin=predictive method=lee-kesler]
Tb          415.62;      // K   [origin=predictive method=joback]
HvapTb      37386.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (41.752 0.25542 -5.18e-05 -2.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxypropanenitrile" "propanenitrile, 3-methoxy-" "propionitrile, 3-methoxy-" "beta-methoxypropionitrile" "2-cyanoethyl methyl ether" "3-methoxypropylnitrile" "1-cyano-2-methoxyethane" "3-methoxypropiononitrile" "beta-methyoxypropionitrile" "methyl beta-cyanoethyl ether" "beta-methoxypropionitril [german]" ".beta.-methoxypropionitrile" );
standardThermochemistry
{
    dHf_298   -93230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     329.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10980.0
}
