/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentane, decyl-  (C15H30, CAS 1795-21-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentaneDecyl;
formula     C15H30;
CAS         1795-21-7;
InChIKey    WOUVLFFZQCUYOL-UHFFFAOYSA-N;
MW          210.405;      // g/mol [origin=calculated method=formula-sum]
Tc          737.97;      // K   [origin=predictive method=joback]
Pc          16.285;      // bar [origin=predictive method=joback]
omega       0.6282;      // -   [origin=predictive method=lee-kesler]
Tb          558.08;      // K   [origin=predictive method=joback]
HvapTb      49241.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.231 1.56052 -0.0009196 2.068e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group CH2_ring; count 4; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decylcyclopentane" "decane, 1-cyclopentyl-" "n-decylcyclopentane" "1-cyclopentyldecane" );
standardThermochemistry
{
    dHf_298   -292450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     689.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=111970.0
}
