/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-isopropyl-10-methyl-1,5-dioxaspiro[5.5]undecan-3-ol  (C13H24O3, CAS 67785-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Isopropyl10Methyl15Dioxaspiro55Undecan3Ol;
formula     C13H24O3;
CAS         67785-70-0;
InChIKey    GECFTYLLVUKXOY-UHFFFAOYSA-N;
MW          228.332;      // g/mol [origin=calculated method=formula-sum]
Tc          880.02;      // K   [origin=predictive method=joback]
Pc          24.507;      // bar [origin=predictive method=joback]
omega       0.9134;      // -   [origin=predictive method=lee-kesler]
Tb          668.41;      // K   [origin=predictive method=joback]
HvapTb      68760.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.88 1.76546 -0.0013194 4.261e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 4; } { group C; count 1; } { group OH; count 1; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-methyl-11-propan-2-yl-1,5-dioxaspiro[5.5]undecan-3-ol" "1,5-dioxaspiro(5.5)undecan-3-ol, 10-methyl-7-(1-methylethyl)-" "1,5-dioxaspiro[5.5]undecan-3-ol, 10-methyl-7-(1-methylethyl)-" "menthone cyclic ketal with 1,2,3 propanetriol" "2-methyl-5-propan-2-yl-7,11-dioxaspiro[5.5]undecan-9-ol" );
gibbsFormation
{
    dHf_298   -643800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     505.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-212830.0
    phase     gas;
}
