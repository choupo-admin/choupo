/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-methanoindan-2,5-dicarboxylic acid, hexahydro-  (C12H16O4, CAS 87324-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47Methanoindan25DicarboxylicAcidHexahydro;
formula     C12H16O4;
CAS         87324-44-5;
InChIKey    RKLMSTQEVORNHJ-UHFFFAOYSA-N;
MW          224.256;      // g/mol [origin=calculated method=formula-sum]
Tc          1004.42;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       1.1662;      // -   [origin=predictive method=lee-kesler]
Tb          775.66;      // K   [origin=predictive method=joback]
HvapTb      75618.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-136.85 1.609 -0.0012222 3.71e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 6; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 6; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octahydro-1h-4,7-methanoindene-2,5-dicarboxylic acid" "4,7-methano-1h-indene-2,5-dicarboxylic acid, octahydro-" "4,7-methano-1h-indene-2,5-dicarboxylicacid, octahydro-" );
standardThermochemistry
{
    dHf_298   -840330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-490640.0
}
