/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-triisopropyl-2-methylbenzene  (C16H26, CAS 6319-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Triisopropyl2Methylbenzene;
formula     C16H26;
CAS         6319-85-3;
InChIKey    CHVOYGXBBWPDEU-UHFFFAOYSA-N;
MW          218.384;      // g/mol [origin=calculated method=formula-sum]
Tc          809.39;      // K   [origin=predictive method=joback]
Pc          16.742;      // bar [origin=predictive method=joback]
omega       0.5748;      // -   [origin=predictive method=lee-kesler]
Tb          605.98;      // K   [origin=predictive method=joback]
HvapTb      54308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.71 1.28424 -0.00068628 1.285e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group ACH; count 2; } { group ACCH3; count 1; } { group ACCH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-1,3,5-tri(propan-2-yl)benzene" );
standardThermochemistry
{
    dHf_298   -187290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160040.0
}
