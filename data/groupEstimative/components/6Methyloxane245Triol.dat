/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-methyloxane-2,4,5-triol  (C6H12O4, CAS 51020-42-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Methyloxane245Triol;
formula     C6H12O4;
CAS         51020-42-9;
InChIKey    FDWRIIDFYSUTDP-UHFFFAOYSA-N;
MW          148.158;      // g/mol [origin=calculated method=formula-sum]
Tc          822.50;      // K   [origin=predictive method=joback]
Pc          49.524;      // bar [origin=predictive method=joback]
omega       1.7597;      // -   [origin=predictive method=lee-kesler]
Tb          645.91;      // K   [origin=predictive method=joback]
HvapTb      82999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.16 0.71542 -0.0002947 5.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 3; } { group OH; count 3; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 4; } { group OH; count 3; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4s,5r,6r)-6-methyloxane-2,4,5-triol" "(4s,5s,2r,6r)-6-methyl-2h-3,4,5,6-tetrahydropyran-2,4,5-triol" );
standardThermochemistry
{
    dHf_298   -762560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     333.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-495620.0
}
