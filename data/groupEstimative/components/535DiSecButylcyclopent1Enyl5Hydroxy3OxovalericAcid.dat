/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-(3,5-di-sec-butylcyclopent-1-enyl)-5-hydroxy-3-oxovaleric acid  (C18H30O4, CAS 53109-18-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        535DiSecButylcyclopent1Enyl5Hydroxy3OxovalericAcid;
formula     C18H30O4;
CAS         53109-18-5;
InChIKey    MQETZQLZTJUQHR-UHFFFAOYSA-N;
MW          310.434;      // g/mol [origin=calculated method=formula-sum]
Tc          1125.87;      // K   [origin=predictive method=joback]
Pc          15.873;      // bar [origin=predictive method=joback]
omega       1.3407;      // -   [origin=predictive method=lee-kesler]
Tb          916.43;      // K   [origin=predictive method=joback]
HvapTb      95989.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.736 1.77808 -0.00104154 2.2086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 5; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 3; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-[3,5-di(butan-2-yl)cyclopenten-1-yl]-5-oxidanyl-3-oxidanylidene-pentanoic acid" "5-(3,5-di-sec-butylcyclopent-1-en-1-yl)-5-hydroxy-3-oxopentanoic acid" "auxinb (6ci)" "5-[3,5-di(butan-2-yl)cyclopenten-1-yl]-5-hydroxy-3-oxopentanoic acid" "1-cyclopentene-1-pentanoicacid, d-hydroxy-3,5-bis(1-methylpropyl)-b-oxo- (9ci)" );
gibbsFormation
{
    dHf_298   -959320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     822.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-467120.0
    phase     gas;
}
