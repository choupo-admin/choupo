/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-2-(phenylmethyl)propane-1,3-diol  (C11H16O2, CAS 2109-99-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl2PhenylmethylPropane13Diol;
formula     C11H16O2;
CAS         2109-99-1;
InChIKey    XEDJJCRGHSVDKQ-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          849.12;      // K   [origin=predictive method=joback]
Pc          33.029;      // bar [origin=predictive method=joback]
omega       1.3242;      // -   [origin=predictive method=lee-kesler]
Tb          659.09;      // K   [origin=predictive method=joback]
HvapTb      74418.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.907 1.16372 -0.0008384 2.367e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -347050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-116650.0
}
