/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-pyrrolidinebutanenitrile  (C8H14N2, CAS 35543-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Pyrrolidinebutanenitrile;
formula     C8H14N2;
CAS         35543-25-0;
InChIKey    OSDDDHPYSNZBPF-UHFFFAOYSA-N;
MW          138.214;      // g/mol [origin=calculated method=formula-sum]
Tc          717.41;      // K   [origin=predictive method=joback]
Pc          30.024;      // bar [origin=predictive method=joback]
omega       0.5882;      // -   [origin=predictive method=lee-kesler]
Tb          512.84;      // K   [origin=predictive method=joback]
HvapTb      46317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.377 0.9903 -0.0007222 2.127e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pyrrolidin-1-ylbutanenitrile" "1-pyrrolidinebutyronitrile" "4-pyrrolidinylbutanenitrile" "1-(3-cyanopropyl)pyrrolidine" "4-(1-pyrrolidine)butyronitrile" "4-pyrrolidin-1-yl-butyronitrile" "4-(pyrrolidin-1-yl)butanenitrile" "4-pyrrolidin-1-ylbutyronitrile" "4-(n-pyrrolidino)butyronitrile" "4-pyrrolidinobutyronitrile" );
standardThermochemistry
{
    dHf_298   110940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=316800.0
}
