/*--------------------------------*- Choupo -*-----------------------*\
  Component: tridecane, 1-iodo-  (C13H27I, CAS 35599-77-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tridecane1Iodo;
formula     C13H27I;
CAS         35599-77-0;
InChIKey    XGAMQNYEIPCUIZ-UHFFFAOYSA-N;
MW          310.259;      // g/mol [origin=calculated method=formula-sum]
Tc          774.84;      // K   [origin=predictive method=joback]
Pc          16.155;      // bar [origin=predictive method=joback]
omega       0.6761;      // -   [origin=predictive method=lee-kesler]
Tb          590.18;      // K   [origin=predictive method=joback]
HvapTb      53905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.762 1.27782 -0.0007648 1.834e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 12; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyltridecane" "tridecyl iodide" "1-iodotridecane" "1-iodotridecane;tridecyl iodide" );
standardThermochemistry
{
    dHf_298   -234780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     718.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116700.0
}
