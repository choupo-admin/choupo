/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-pyridylamino)ethyldimethylamine  (C9H15N3, CAS 23826-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22PyridylaminoEthyldimethylamine;
formula     C9H15N3;
CAS         23826-72-4;
InChIKey    PBPMFHCGVZTYHV-UHFFFAOYSA-N;
MW          165.24;      // g/mol [origin=calculated method=formula-sum]
Tc          764.05;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.6604;      // -   [origin=predictive method=lee-kesler]
Tb          548.51;      // K   [origin=predictive method=joback]
HvapTb      52593.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.038 1.0138 -0.00066746 1.711e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2NH; count 1; } { group CH3N; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group NH; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-dimethyl-n-pyridin-2-yl-ethane-1,2-diamine" "r.518" "2-(2-(dimethylamino)ethylamino)pyridine" "pyridine, 2-(2-(dimethylamino)ethylamino)-" "pyridine, 2-((2-(dimethylamino)ethyl)amino)-" "pyridine, 2-[[2-(dimethylamino)ethyl]amino]-" "1, n,n-dimethyl-n'-2-pyridinyl-" "pyridine, 2-[[(2-(dimethylamino)ethyl]amino]-" "1,2-ethanediamine, n,n-dimethyl-n'-2-pyridinyl-" "n',n'-dimethyl-n-pyridin-2-ylethane-1,2-diamine" "1,2-ethanediamine,n1,n1-dimethyl-n2-2-pyridinyl-" "n1,n1-dimethyl-n2-(2-pyridinyl)-1,2-ethanediamine" );
standardThermochemistry
{
    dHf_298   161230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=414530.0
}
