/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,5,7,9-dodecatetrayne, 2,2,11,11-tetramethyl-  (C16H18, CAS 20264-61-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3579Dodecatetrayne221111Tetramethyl;
formula     C16H18;
CAS         20264-61-3;
InChIKey    JQHQQGSOCODBOQ-UHFFFAOYSA-N;
MW          210.32;      // g/mol [origin=calculated method=formula-sum]
Tc          874.02;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.2410;      // -   [origin=predictive method=lee-kesler]
Tb          595.22;      // K   [origin=predictive method=joback]
HvapTb      57226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.63 1.17632 -0.00082164 2.3892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group C_C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group tC; count 8; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,11,11-tetramethyldodeca-3,5,7,9-tetrayne" );
standardThermochemistry
{
    dHf_298   698130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=900720.0
}
