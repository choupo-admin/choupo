/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(dimethoxymethyl)-4-methylbenzene  (C10H14O2, CAS 3395-83-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dimethoxymethyl4Methylbenzene;
formula     C10H14O2;
CAS         3395-83-3;
InChIKey    MKZGLAOLSFUPRT-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          711.81;      // K   [origin=predictive method=joback]
Pc          28.054;      // bar [origin=predictive method=joback]
omega       0.5073;      // -   [origin=predictive method=lee-kesler]
Tb          504.46;      // K   [origin=predictive method=joback]
HvapTb      45224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.51 0.69496 -0.00026556 -1.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(dimethoxymethyl)-4-methyl-benzene" "p-(dimethoxymethyl)toluene" "benzene, 1-(dimethoxymethyl)-4-methyl-" "benzene, 1-methyl-4-(dimethoxymethyl)-" "benzene,1-(dimethoxymethyl)-4-methyl-" "p-tolualdehyde,dimethyl acetal (7ci,8ci); 1-(dimethoxymethyl)-4-methylbenzene;4-(dimethoxymethyl)toluene; 4-methylbenzaldehyde dimethyl acetal;dimethoxy(4-methylphenyl)methane; p-methylbenzaldehyde dimethyl acetal;p-tolylaldehyde dimethyl acetal" );
gibbsFormation
{
    dHf_298   -294390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76340.0
    phase     gas;
}
