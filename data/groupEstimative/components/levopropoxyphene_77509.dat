/*--------------------------------*- Choupo -*-----------------------*\
  Component: levopropoxyphene  (C22H29NO2, CAS 77-50-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        levopropoxyphene;
formula     C22H29NO2;
CAS         77-50-9;
InChIKey    XLMALTXPSGQGBX-UHFFFAOYSA-N;
MW          339.479;      // g/mol [origin=calculated method=formula-sum]
Tc          1045.25;      // K   [origin=predictive method=joback]
Pc          14.370;      // bar [origin=predictive method=joback]
omega       0.8827;      // -   [origin=predictive method=lee-kesler]
Tb          823.31;      // K   [origin=predictive method=joback]
HvapTb      76884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-96.357 2.13688 -0.0014284 3.533e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2COO; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4-(dimethylamino)-3-methyl-1,2-diphenyl-butan-2-yl] propanoate" "2-butanol, 4-(dimethylamino)-3-methyl-1,2-diphenyl-, propionate (ester)" "propoxyphene hcl 65" "propoxyphene" "l-propoxyphene" "levopropoxiphenum" "1,2-diphenyl-2-propionoxy-3-methyl-4-dimethylaminobutane" "(l)-propoxyphene" "4-(dimethylamino)-3-methyl-1,2-diphenyl-2-butanol propionate" "(-)-propoxyphene" "alpha-4-dimethylamino-1,2-diphenyl-3-methyl-4-propionyloxybutane" "alpha-4-dimethylamino-3-methyl-1,2-diphenyl-2-butanolpropionate" );
gibbsFormation
{
    dHf_298   -288130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     819.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=159990.0
    phase     gas;
}
