/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethanone, 1-(octahydro-3,6,8,8-tetramethyl-1h-3a,7-methanoazulenyl)-, didehydro deriv.  (C17H26O, CAS 68867-57-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethanone1Octahydro3688Tetramethyl1h3a7MethanoazulenylDidehyd;
formula     C17H26O;
CAS         68867-57-2;
InChIKey    UTLJUSIICBRVLA-UHFFFAOYSA-N;
MW          246.394;      // g/mol [origin=calculated method=formula-sum]
Tc          886.00;      // K   [origin=predictive method=joback]
Pc          18.341;      // bar [origin=predictive method=joback]
omega       0.6116;      // -   [origin=predictive method=lee-kesler]
Tb          661.80;      // K   [origin=predictive method=joback]
HvapTb      57990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-226.26 2.4132 -0.00226934 9.1086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2_ring; count 3; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(octahydro-3,6,8,8-tetramethyl-1h-3a,7-methanoazulenyl)acetone, didehydro derivative" );
gibbsFormation
{
    dHf_298   -284940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     582.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107610.0
    phase     gas;
}
