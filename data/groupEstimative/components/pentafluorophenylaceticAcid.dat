/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluorophenylacetic acid  (C8H3F5O2, CAS 653-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentafluorophenylaceticAcid;
formula     C8H3F5O2;
CAS         653-21-4;
InChIKey    LGCODSNZJOVMHV-UHFFFAOYSA-N;
MW          226.1;      // g/mol [origin=calculated method=formula-sum]
Tc          760.34;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.9893;      // -   [origin=predictive method=lee-kesler]
Tb          576.08;      // K   [origin=predictive method=joback]
HvapTb      52067.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (68.261 0.4972 -0.000262 4.1e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH2; count 1; } { group COOH; count 1; } { group ACF; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dC_ring; count 6; } { group F; count 5; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,3,4,5,6-pentakis(fluoranyl)phenyl]ethanoic acid" "2,3,4,5,6-pentafluorophenylacetic acid" "(pentafluorophenyl)acetic acid" "2,3,4,5,6-pentafluorphenylacetic acid" "2-(2,3,4,5,6-pentafluorophenyl)acetic acid" "2-(perfluorophenyl)acetic acid" "2-(pentafluorophenyl)acetic acid" "l016" "benzeneacetic acid,2,3,4,5,6-pentafluoro-" );
gibbsFormation
{
    dHf_298   -1360090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     541.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1237220.0
    phase     gas;
}
