/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanoic acid, 2-ethyl-, 3-hydroxy-2,2-bis(hydroxymethyl)propyl ester  (C13H26O5, CAS 70913-83-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanoicAcid2Ethyl3Hydroxy22BisHydroxymethylPropylEster;
formula     C13H26O5;
CAS         70913-83-6;
InChIKey    YNCUWXXRGAOWRU-UHFFFAOYSA-N;
MW          262.346;      // g/mol [origin=calculated method=formula-sum]
Tc          1013.98;      // K   [origin=predictive method=joback]
Pc          21.473;      // bar [origin=predictive method=joback]
omega       1.6622;      // -   [origin=predictive method=lee-kesler]
Tb          828.13;      // K   [origin=predictive method=joback]
HvapTb      100292.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.198 1.41774 -0.000855 1.872e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group C; count 1; } { group OH; count 3; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group C; count 1; } { group OH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,2-bis(hydroxymethyl)-3-oxidanyl-propyl] 2-ethylhexanoate" "1,3-propanediol, 2,2-bis(hydroxymethyl)-, homopolymer, 2-ethylhexanoate" "2-ethylhexoic acid, polypentaerythritol ester" );
standardThermochemistry
{
    dHf_298   -1099650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     817.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-661850.0
}
