/*--------------------------------*- Choupo -*-----------------------*\
  Component: dodecahydro-1,1-dimethyl-1h-naphtho(1,2-c)pyran  (C15H26O, CAS 50526-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dodecahydro11Dimethyl1hNaphtho12CPyran;
formula     C15H26O;
CAS         50526-53-9;
InChIKey    KDPFJSKAMCNRLJ-UHFFFAOYSA-N;
MW          222.372;      // g/mol [origin=calculated method=formula-sum]
Tc          836.68;      // K   [origin=predictive method=joback]
Pc          21.178;      // bar [origin=predictive method=joback]
omega       0.4600;      // -   [origin=predictive method=lee-kesler]
Tb          602.22;      // K   [origin=predictive method=joback]
HvapTb      52324.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-207.87 2.06944 -0.0016287 5.486e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 4; } { group C; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-dimethyl-3,4,4a,5,6,6a,7,8,9,10,10a,10b-dodecahydrobenzo[h]isochromene" "1h-naphtho[1,2-c]pyran, dodecahydro-1,1-dimethyl-" "dodecahydro-1,1-dimethyl-1h-naphtho[1,2-c]pyran" "1h-naphtho(1,2-c)pyran, dodecahydro-1,1-dimethyl-" );
standardThermochemistry
{
    dHf_298   -322770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     502.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=90140.0
}
