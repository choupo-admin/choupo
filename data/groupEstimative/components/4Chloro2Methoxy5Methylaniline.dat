/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chloro-2-methoxy-5-methylaniline  (C8H10ClNO, CAS 6376-14-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Chloro2Methoxy5Methylaniline;
formula     C8H10ClNO;
CAS         6376-14-3;
InChIKey    XBAPOWUMJRIKAV-UHFFFAOYSA-N;
MW          171.624;      // g/mol [origin=calculated method=formula-sum]
Tc          785.66;      // K   [origin=predictive method=joback]
Pc          34.725;      // bar [origin=predictive method=joback]
omega       0.6031;      // -   [origin=predictive method=lee-kesler]
Tb          556.64;      // K   [origin=predictive method=joback]
HvapTb      55100.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.49 0.51194 -0.00019428 -0.0);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group CH3O; count 1; } { group ACNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 1; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-chloranyl-2-methoxy-5-methyl-aniline" "chlorocresidine" "o-anisidine, 4-chloro-5-methyl-" "4-chloro-2-methoxy-5-methylphenylamine" "benzenamine,4-chloro-2-methoxy-5-methyl-" "4-chloro-2-methoxy-5-methylaniline, 85%" "o-anisidine,4-chloro-5-methyl- (7ci,8ci);2-methoxy-4-chloro-5-methylaniline;4-chloro-2-methoxy-5-methylaniline;4-chloro-2-methoxy-5-methylbenzenamine;" );
standardThermochemistry
{
    dHf_298   -120500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=49520.0
}
