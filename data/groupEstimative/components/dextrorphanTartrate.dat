/*--------------------------------*- Choupo -*-----------------------*\
  Component: dextrorphan tartrate  (C21H29NO7, CAS 143-98-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dextrorphanTartrate;
formula     C21H29NO7;
CAS         143-98-6;
InChIKey    RWTWIZDKEIWLKQ-XCPWPWHNSA-N;
MW          407.463;      // g/mol [origin=calculated method=formula-sum]
Tc          1610.14;      // K   [origin=predictive method=joback]
Pc          24.483;      // bar [origin=predictive method=joback]
omega       1.6654;      // -   [origin=predictive method=lee-kesler]
Tb          1305.43;      // K   [origin=predictive method=joback]
HvapTb      146299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-204.02 2.84912 -0.00239612 8.332e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 4; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 2; } { group ACOH; count 1; } { group CH3N; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group CH2_ring; count 7; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group OH_phenol; count 1; } { group COOH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dextrophan tartrate" "d-3-hydroxy-n-methylmorphinan tartrate" "dextrorphan d-tartrate" "(+)-3-hydroxy-n-methylmorphinan (+)-tartrate salt" "morphinan-3-ol, 17-methyl-, tartrate (1:1) (salt), (+)-" "1,3,4,9,10,10a-hexahydro-11-methyl-2h-10,4a-iminoethanophenanthren-6-ol tartrate, d-" "dextrorphan tartrate salt" );
gibbsFormation
{
    dHf_298   -1261190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1019.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-721560.0
    phase     gas;
}
