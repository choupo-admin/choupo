/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4-diaminobutanoic acid  (C4H10N2O2, CAS 305-62-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DiaminobutanoicAcid;
formula     C4H10N2O2;
CAS         305-62-4;
InChIKey    OGNSCSPNOLGXSM-UHFFFAOYSA-N;
MW          118.136;      // g/mol [origin=calculated method=formula-sum]
Tc          800.13;      // K   [origin=predictive method=joback]
Pc          51.683;      // bar [origin=predictive method=joback]
omega       0.9646;      // -   [origin=predictive method=lee-kesler]
Tb          581.25;      // K   [origin=predictive method=joback]
HvapTb      62556.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.152 0.5643 -0.0003564 8.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH2; count 1; } { group CHNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group COOH; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-bis(azanyl)butanoic acid" "2,4-diaminobutyric acid" "2,4-diamino-butyric acid" "alpha,gamma-diaminobutyric acid" "butanoic acid, 2,4-diamino-" "2,4-diamino-butanoic acid" "dl-2,4-diaminobutyric acid" "butyric acid, 2,4-diamino-" "2,4-diaminobutanoate" "l-2,4-diaminobutyric acid hydrobromine" "?-cyano-l-alanine" "2,4-diaminobutyrate" );
gibbsFormation
{
    dHf_298   -413860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230650.0
    phase     gas;
}
