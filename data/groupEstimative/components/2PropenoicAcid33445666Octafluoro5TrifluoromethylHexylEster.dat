/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid,3,3,4,4,5,6,6,6-octafluoro-5-(trifluoromethyl)hexyl ester  (C10H7F11O2, CAS 86217-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid33445666Octafluoro5TrifluoromethylHexylEster;
formula     C10H7F11O2;
CAS         86217-01-8;
InChIKey    UXVXKXDSDYDRTQ-UHFFFAOYSA-N;
MW          368.142;      // g/mol [origin=calculated method=formula-sum]
Tc          596.41;      // K   [origin=predictive method=joback]
Pc          15.610;      // bar [origin=predictive method=joback]
omega       0.7375;      // -   [origin=predictive method=lee-kesler]
Tb          459.12;      // K   [origin=predictive method=joback]
HvapTb      29124.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.148 1.6378 -0.0014879 4.892e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 1; } { group CF3; count 2; } { group CF2; count 2; } { group CF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group C; count 5; } { group dCH2; count 1; } { group dCH; count 1; } { group F; count 11; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[3,3,4,4,5,6,6,6-octakis(fluoranyl)-5-(trifluoromethyl)hexyl] prop-2-enoate" );
standardThermochemistry
{
    dHf_298   -2642540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-2317920.0
}
