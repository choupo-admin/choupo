/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,7,10-tetraoxaundecane, 6-ethyl-  (C9H20O4, CAS 71563-31-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25710Tetraoxaundecane6Ethyl;
formula     C9H20O4;
CAS         71563-31-0;
InChIKey    BSPVHDPHFUHFRW-UHFFFAOYSA-N;
MW          192.255;      // g/mol [origin=calculated method=formula-sum]
Tc          661.35;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       0.7219;      // -   [origin=predictive method=lee-kesler]
Tb          494.76;      // K   [origin=predictive method=joback]
HvapTb      44880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (95.025 0.61196 -2.5e-05 -1.238e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH3O; count 2; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(2-methoxyethoxy)propane" "1,1-di(beta-methoxyethoxy)propane" );
gibbsFormation
{
    dHf_298   -763250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397540.0
    phase     gas;
}
