/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(methylamino)benzoic acid  (C8H9NO2, CAS 10541-83-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethylaminoBenzoicAcid;
formula     C8H9NO2;
CAS         10541-83-0;
InChIKey    ZVIDMSBTYRSMAR-UHFFFAOYSA-N;
MW          151.165;      // g/mol [origin=calculated method=formula-sum]
Tc          838.16;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.8566;      // -   [origin=predictive method=lee-kesler]
Tb          609.98;      // K   [origin=predictive method=joback]
HvapTb      59940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.6 0.75242 -0.00049676 1.231e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group CH3NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzoic acid, 4-(methylamino)-" "p-methylaminobenzoic acid" "benzoic acid, p-(methylamino)-" "4-methylaminobenzoic acid" "n-methyl-4-aminobenzoate" "4-methylamino-benzoic acid" "p-(methylamino)benzoic acid" "n-methyl-4-aminobenzoic acid" "4-(n-methylamino)benzoic acid" "4-(methylamino)benzoic" "benzoic acid, p-(methylamino)- (8ci)" "535da2ae-a158-46f5-afd0-ca8f157e14d4" );
standardThermochemistry
{
    dHf_298   -280190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     448.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-135260.0
}
