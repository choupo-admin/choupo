/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1s,12s)-2,5,8,11-tetraoxabicyclo[10.4.0]hexadecane  (C12H22O4, CAS 17454-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1s12s25811Tetraoxabicyclo1040Hexadecane;
formula     C12H22O4;
CAS         17454-42-1;
InChIKey    ILCAEFFUYHJPAL-RYUDHWBXSA-N;
MW          230.304;      // g/mol [origin=calculated method=formula-sum]
Tc          892.37;      // K   [origin=predictive method=joback]
Pc          27.818;      // bar [origin=predictive method=joback]
omega       0.5542;      // -   [origin=predictive method=lee-kesler]
Tb          638.14;      // K   [origin=predictive method=joback]
HvapTb      61892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.43 1.3376 -0.0005498 -3.6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group FCH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 2; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -735010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-293820.0
    phase     gas;
}
