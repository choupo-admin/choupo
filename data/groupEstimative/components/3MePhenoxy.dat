/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-me-phenoxy  (C7H7O, CAS 41115-75-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C7H7O (delta O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3MePhenoxy;
formula     C7H7O;
CAS         41115-75-7;
InChIKey    UGRMITBWUVWUEB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          107.132;      // g/mol [origin=calculated method=formula-sum]
Tc          600.04;      // K   [origin=predictive method=joback]
Pc          40.986;      // bar [origin=predictive method=joback]
omega       0.2743;      // -   [origin=predictive method=lee-kesler]
Tb          390.72;      // K   [origin=predictive method=joback]
HvapTb      33967.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.49 0.63352 -0.00052856 1.813e-07);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-$l^{1}-oxidanyl-3-methyl-benzene" "3-methyl-phenoxy" );
standardThermochemistry
{
    dHf_298   93060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=163220.0
}
