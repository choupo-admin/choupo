/*--------------------------------*- Choupo -*-----------------------*\
  Component: butorphanol  (C21H29NO2, CAS 42408-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butorphanol;
formula     C21H29NO2;
CAS         42408-82-2;
InChIKey    IFKLAQQSCNILHL-QHAWAJNXSA-N;
MW          327.468;      // g/mol [origin=calculated method=formula-sum]
Tc          1173.81;      // K   [origin=predictive method=joback]
Pc          24.532;      // bar [origin=predictive method=joback]
omega       1.3904;      // -   [origin=predictive method=lee-kesler]
Tb          932.96;      // K   [origin=predictive method=joback]
HvapTb      94708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-361.319 3.3411 -0.00333532 1.353e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 2; } { group C; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butorfanol" "beforal" "moradol" "stadol" "butorphanol tartrate" "butorphanolum [inn-latin]" "stadol ns" "17-(cyclobutylmethyl)morphinan-3,14-diol" "butorphanolum" "(-)-17-(cyclobutylmethyl)morphinan-3,14-diol" "morphinan-3,14-diol, 17-(cyclobutylmethyl)-" "(-)-butorphanol" );
gibbsFormation
{
    dHf_298   -204360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     772.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=255880.0
    phase     gas;
}
