/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4,5-dimethylphenol  (C8H9BrO, CAS 22802-39-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo45Dimethylphenol;
formula     C8H9BrO;
CAS         22802-39-7;
InChIKey    GJLPLXXEHFEMBL-UHFFFAOYSA-N;
MW          201.063;      // g/mol [origin=calculated method=formula-sum]
Tc          809.95;      // K   [origin=predictive method=joback]
Pc          46.466;      // bar [origin=predictive method=joback]
omega       0.6520;      // -   [origin=predictive method=lee-kesler]
Tb          566.06;      // K   [origin=predictive method=joback]
HvapTb      56451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.42 0.75874 -0.00063628 2.269e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4,5-dimethyl-phenol" "3,4-xylenol, 6-bromo-" "3,4-xylenol, 6-bromo-," "6-bromo-3,4-xylenol" "phenol,2-bromo-4,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -145840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-30670.0
}
