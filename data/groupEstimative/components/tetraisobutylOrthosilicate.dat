/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetraisobutyl orthosilicate  (C16H36O4Si, CAS 681-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H36O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetraisobutylOrthosilicate;
formula     C16H36O4Si;
CAS         681-98-1;
InChIKey    QKCMIPQMYBKEPP-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          320.545;      // g/mol [origin=calculated method=formula-sum]
Tc          828.29;      // K   [origin=predictive method=joback]
Pc          11.809;      // bar [origin=predictive method=joback]
omega       0.7724;      // -   [origin=predictive method=lee-kesler]
Tb          655.00;      // K   [origin=predictive method=joback]
HvapTb      59592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.434 1.08856 -6e-07 -2.592e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH; count 4; } { group CH2O; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2; count 4; } { group CH; count 4; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(2-methylpropyl) silicate" "tetrakis(2-methylpropyl) orthosilicate" "silicic acid (h4sio4),tetrakis(2-methylpropyl) ester" );
gibbsFormation
{
    dHf_298   -1035190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     912.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-450680.0
    phase     gas;
}
