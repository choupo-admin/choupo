/*--------------------------------*- Choupo -*-----------------------*\
  Component: triisooctylamine  (C24H51N, CAS 25549-16-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triisooctylamine;
formula     C24H51N;
CAS         25549-16-0;
InChIKey    YKGBNAGNNUEZQC-UHFFFAOYSA-N;
MW          353.679;      // g/mol [origin=calculated method=formula-sum]
Tc          932.92;      // K   [origin=predictive method=joback]
Pc          8.163;      // bar [origin=predictive method=joback]
omega       0.7539;      // -   [origin=predictive method=lee-kesler]
Tb          759.84;      // K   [origin=predictive method=joback]
HvapTb      69897.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.665 2.42552 -0.001404 3.103e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 14; } { group CH; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 15; } { group CH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-methyl-n,n-bis(6-methylheptyl)heptan-1-amine" "tris(6-methylheptyl)amine" "1-heptanamine, 6-methyl-n,n-bis(6-methylheptyl)-" "isooctanamine, n,n-diisooctyl-" "triheptylamine, 6,6',6''-trimethyl-" "triisooctylamine, tech" "isooctanamine, n ,n -diisooctyl-" "triisooctylamine(6ci,8ci);azamine t 8b;adogen 381;alamine 330;hostarex 324;n,n-diisooctylisooctanamine;tioa;" );
gibbsFormation
{
    dHf_298   -487000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1078.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254660.0
    phase     gas;
}
