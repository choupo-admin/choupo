/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dimethyl-2,5-hexanediol  (C8H18O2, CAS 110-03-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dimethyl25Hexanediol;
formula     C8H18O2;
CAS         110-03-2;
InChIKey    ZWNMRZQYWRLGMM-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          732.34;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       1.1564;      // -   [origin=predictive method=lee-kesler]
Tb          560.54;      // K   [origin=predictive method=joback]
HvapTb      64168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.748 1.08348 -0.0008158 2.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-dimethylhexane-2,5-diol" "2,5-hexanediol, 2,5-dimethyl-" "1,1,4,4-tetramethyl-1,4-butanediol" "2,5-dihydroxy-2,5-dimethylhexane" "dimethylhexanediol" "2,5-dimethylhexanediol" "2,5-dimethyl-hexane-2,5-diol" "1,4,4-tetramethyl-1,4-butanediol" "l099" );
gibbsFormation
{
    dHf_298   -530410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251480.0
    phase     gas;
}
