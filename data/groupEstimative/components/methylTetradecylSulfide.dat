/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl tetradecyl sulfide  (C15H32S, CAS 7289-45-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylTetradecylSulfide;
formula     C15H32S;
CAS         7289-45-4;
InChIKey    HMRLUJVOJIHNDQ-UHFFFAOYSA-N;
MW          244.481;      // g/mol [origin=calculated method=formula-sum]
Tc          785.98;      // K   [origin=predictive method=joback]
Pc          14.337;      // bar [origin=predictive method=joback]
omega       0.7698;      // -   [origin=predictive method=lee-kesler]
Tb          611.58;      // K   [origin=predictive method=joback]
HvapTb      55801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.853 1.42323 -0.000752 1.397e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 13; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylsulfanyltetradecane" "methyl tetradecylsulfide" "methyl tetradecyl sulphide" "tetradecane,1-(methylthio)-" "sulfide,methyl tetradecyl (6ci,7ci,8ci);methyl tetradecyl sulfide;" );
gibbsFormation
{
    dHf_298   -311060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108540.0
    phase     gas;
}
