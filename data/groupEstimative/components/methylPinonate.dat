/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl pinonate  (C11H18O3, CAS 16978-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylPinonate;
formula     C11H18O3;
CAS         16978-11-3;
InChIKey    DVAHCHCZPNEYNF-UHFFFAOYSA-N;
MW          198.262;      // g/mol [origin=calculated method=formula-sum]
Tc          767.00;      // K   [origin=predictive method=joback]
Pc          23.293;      // bar [origin=predictive method=joback]
omega       0.6533;      // -   [origin=predictive method=lee-kesler]
Tb          565.28;      // K   [origin=predictive method=joback]
HvapTb      52549.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.819 1.34628 -0.0010569 3.6456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group C; count 1; } { group CH3CO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group C_ring; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-(3-ethanoyl-2,2-dimethyl-cyclobutyl)ethanoate" "methyl(3-acetyl-2,2-dimethylcyclobutyl)acetate" "cyclobutaneacetic acid, 3-acetyl-2,2-dimethyl-, methyl ester" "methyl 3-acetyl-2,2-dimethylcyclobutaneacetate" "cyclobutaneacetic acid,2-dimethyl-, methyl ester" "methyl (3-acetyl-2,2-dimethylcyclobutyl)acetate" "methyl 2-(3-acetyl-2,2-dimethylcyclobutyl)acetate" );
standardThermochemistry
{
    dHf_298   -659030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-369810.0
}
