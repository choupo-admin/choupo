/*--------------------------------*- Choupo -*-----------------------*\
  Component: .beta.-guaiene  (C15H24, CAS 88-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaGuaiene;
formula     C15H24;
CAS         88-84-6;
InChIKey    GIBQERSGRNPMEH-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          808.47;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.4903;      // -   [origin=predictive method=lee-kesler]
Tb          589.00;      // K   [origin=predictive method=joback]
HvapTb      51981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.93 1.43968 -0.000871 2.034e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-dimethyl-7-propan-2-ylidene-2,3,4,5,6,8-hexahydro-1h-azulene" "guaiene, beta-" "guaiene" "guaia-1(5),7(11)-diene" "azulene, 1,2,3,4,5,6,7,8-octahydro-1,4-dimethyl-7-(1-methylethylidene)-, (1s-cis)-" "1,4-dimethyl-7-(propan-2-ylidene)-1,2,3,4,5,6,7,8-octahydroazulene" "azulene, 1,2,3,4,5,6,7,8-octahydro-1,4-dimethyl-7-(1-methylethylidene)-, (1s,4s)-" "(1s-cis)-1,2,3,4,5,6,7,8-octahydro-7-isopropylidene-1,4-dimethylazulene" "1,2,3,4,5,6,7,8-octahydro-1,4-dimethyl-7-(1-methylethylidene)-azulene, (1s,cis)" "agn-pc-00po7l" "azulene, 1,2,3,4,5,6,7,8-octahydro-1,4-dimethyl-7-(1-methylethylidene)-" "azulene,1,2,3,4,5,6,7,8-octahydro-1,4-dimethyl-7-(1-methylethylidene)-, (1s,4s)-" );
gibbsFormation
{
    dHf_298   -130890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196130.0
    phase     gas;
}
