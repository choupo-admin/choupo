/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-buten-3-yn-1-amine, n,n-diethyl-  (C8H13N, CAS 1809-53-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Buten3Yn1AmineNNDiethyl;
formula     C8H13N;
CAS         1809-53-6;
InChIKey    UDQMVAYZZYCMOT-BQYQJAHWSA-N;
MW          123.199;      // g/mol [origin=calculated method=formula-sum]
Tc          572.11;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.3546;      // -   [origin=predictive method=lee-kesler]
Tb          389.36;      // K   [origin=predictive method=joback]
HvapTb      35261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.478 0.81384 -0.00060373 1.8719e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH=CH; count 1; } { group CH2N; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 2; } { group tCH; count 1; } { group tC; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-n,n-diethylbut-1-en-3-yn-1-amine" "[(e)-but-1-en-3-ynyl]-diethyl-amine" );
gibbsFormation
{
    dHf_298   268200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=430550.0
    phase     gas;
}
