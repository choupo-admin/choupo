/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-cyclohexylethanolamine  (C8H17NO, CAS 2842-38-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nCyclohexylethanolamine;
formula     C8H17NO;
CAS         2842-38-8;
InChIKey    MGUMZJAQENFQKN-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          736.84;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.9038;      // -   [origin=predictive method=lee-kesler]
Tb          544.54;      // K   [origin=predictive method=joback]
HvapTb      56946.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.908 0.9961 -0.0005714 1.139e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(cyclohexylamino)ethanol" "abbomeen e-25 aerosol" "ethanol, 2-(cyclohexylamino)-" "cyclohexlaminoethanol" "abromeen e-25" "n-(2-hydroxyethyl)cyclohexylamine" "cyclohexylamine, hydroxyethyl-" "n-cyclohexylaminoethanol" "2-cyclohexylaminoethanol" "n-(2-hydroxyethyl) cyclohexylamine" "n-hydroxyethylcyclohexylamine" "2-(cyclohexylamino)ethan-1-ol" );
standardThermochemistry
{
    dHf_298   -252890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     528.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-6500.0
}
