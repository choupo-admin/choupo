/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dimethylocta-1,3,7-triene  (C10H16, CAS 51703-69-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dimethylocta137Triene;
formula     C10H16;
CAS         51703-69-6;
InChIKey    JWMIAIJDECOUIA-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          610.19;      // K   [origin=predictive method=joback]
Pc          24.290;      // bar [origin=predictive method=joback]
omega       0.3600;      // -   [origin=predictive method=lee-kesler]
Tb          425.36;      // K   [origin=predictive method=joback]
HvapTb      36164.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.739 0.93964 -0.0006553 1.913e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 3; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,7-octatriene, 2,6-dimethyl-, (e)-" );
gibbsFormation
{
    dHf_298   103280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278230.0
    phase     gas;
}
