/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-propylcyclopentene  (C8H14, CAS 34067-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Propylcyclopentene;
formula     C8H14;
CAS         34067-75-9;
InChIKey    RBEROAUIKMEYDR-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          591.88;      // K   [origin=predictive method=joback]
Pc          31.919;      // bar [origin=predictive method=joback]
omega       0.3020;      // -   [origin=predictive method=lee-kesler]
Tb          397.08;      // K   [origin=predictive method=joback]
HvapTb      33951.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.088 0.83952 -0.00052608 1.277e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentene, 3-propyl-" "3-propyl-1-cyclopentene" );
gibbsFormation
{
    dHf_298   -90190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     379.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82990.0
    phase     gas;
}
