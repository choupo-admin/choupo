/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethyl-4-iodobenzene  (C8H9I, CAS 25309-64-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethyl4Iodobenzene;
formula     C8H9I;
CAS         25309-64-2;
InChIKey    OOLSRHZMXAYDFB-UHFFFAOYSA-N;
MW          232.06;      // g/mol [origin=calculated method=formula-sum]
Tc          755.78;      // K   [origin=predictive method=joback]
Pc          34.930;      // bar [origin=predictive method=joback]
omega       0.3385;      // -   [origin=predictive method=lee-kesler]
Tb          507.44;      // K   [origin=predictive method=joback]
HvapTb      45713.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.299 0.66442 -0.00045696 1.245e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-4-iodanyl-benzene" "4-ethyliodobenzene" "benzene, 1-ethyl-4-iodo-" "p-ethyliodobenzene" );
gibbsFormation
{
    dHf_298   93480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=177380.0
    phase     gas;
}
