/*--------------------------------*- Choupo -*-----------------------*\
  Component: perfluorophenanthrene  (C14F24, CAS 306-91-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        perfluorophenanthrene;
formula     C14F24;
CAS         306-91-2;
InChIKey    QKENRHXGDUPTEM-UHFFFAOYSA-N;
MW          624.106;      // g/mol [origin=calculated method=formula-sum]
Tc          626.16;      // K   [origin=predictive method=joback]
Pc          12.226;      // bar [origin=predictive method=joback]
omega       0.8138;      // -   [origin=predictive method=lee-kesler]
Tb          495.96;      // K   [origin=predictive method=joback]
HvapTb      8236.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-674.53 5.8168 -0.008407 4.3e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CF2; count 10; } { group CF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C_ring; count 14; } { group F; count 24; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2,3,3,4,4,4a,4b,5,5,6,6,7,7,8,8,8a,9,9,10,10,10a-tetracosakis(fluoranyl)phenanthrene" "flutec pp11" "tetracosafluorotetradecahydrophenanthrene" "phenanthrene, tetracosafluorotetradecahydro-" "phenanthrene, 1,1,2,2,3,3,4,4,4a,4b,5,5,6,6,7,7,8,8,8a,9,9,10,10,10a-tetracosafluorotetradecahydro-" "perfluoroperhydrophenanthrene" "perfluoro(perhydrophenanthrene)" "perfluoroperhydrophenanthrene 80%" "phenanthrene,tetracosafluorotetradecahydro-" "flutec pp11, tetracosafluorotetradecahydrophenanthrene" "1,1,2,2,3,3,4,4,4a,4b,5,5,6,6,7,7,8,8,8a,9,9,10,10,10a-tetracosafluorophenanthrene" "phenanthrene,1,1,2,2,3,3,4,4,4a,4b,5,5,6,6,7,7,8,8,8a,9,9,10,10,10a-tetracosafluorotetradecahydro-" );
standardThermochemistry
{
    dHf_298   -4861710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1798.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-4648360.0
}
