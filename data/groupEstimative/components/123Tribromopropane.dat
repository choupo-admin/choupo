/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-tribromopropane  (C3H5Br3, CAS 96-11-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Tribromopropane;
formula     C3H5Br3;
CAS         96-11-7;
InChIKey    FHCLGDLYRUPKAM-UHFFFAOYSA-N;
MW          280.785;      // g/mol [origin=calculated method=formula-sum]
Tc          700.17;      // K   [origin=predictive method=joback]
Pc          59.999;      // bar [origin=predictive method=joback]
omega       0.4991;      // -   [origin=predictive method=lee-kesler]
Tb          466.28;      // K   [origin=predictive method=joback]
HvapTb      41189.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.052 0.4093 -0.0003568 1.263e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group Br; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-tris(bromanyl)propane" "s-tribromopropane" "glyceryl tribromohydrin" "sym-tribromopropane" "propane, 1,2,3-tribromo-" "glycerol tribromohydrin" "1,3-tribromopropane" "propane,2,3-tribromo-" "1,2,3-tribromo-propane" );
gibbsFormation
{
    dHf_298   -31540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=14900.0
    phase     gas;
}
