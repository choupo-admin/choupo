/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-2,4,4-trimethylpentane  (C8H17Cl, CAS 6111-88-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Chloro244Trimethylpentane;
formula     C8H17Cl;
CAS         6111-88-2;
InChIKey    MJMQIMYDFATMEH-UHFFFAOYSA-N;
MW          148.674;      // g/mol [origin=calculated method=formula-sum]
Tc          607.81;      // K   [origin=predictive method=joback]
Pc          25.379;      // bar [origin=predictive method=joback]
omega       0.2729;      // -   [origin=predictive method=lee-kesler]
Tb          413.61;      // K   [origin=predictive method=joback]
HvapTb      35195.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.439 1.0223 -0.0007754 2.368e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-chloranyl-2,4,4-trimethyl-pentane" "pentane, 2-chloro-2,4,4-trimethyl-" "2-chloro-2,4,4-trimethyl-pentane" );
standardThermochemistry
{
    dHf_298   -241690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     423.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=10230.0
}
