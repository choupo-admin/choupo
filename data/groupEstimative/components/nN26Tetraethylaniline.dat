/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,2,6-tetraethylaniline  (C14H23N, CAS 81506-16-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nN26Tetraethylaniline;
formula     C14H23N;
CAS         81506-16-3;
InChIKey    AZUFGGNZBIWWQA-UHFFFAOYSA-N;
MW          205.345;      // g/mol [origin=calculated method=formula-sum]
Tc          762.74;      // K   [origin=predictive method=joback]
Pc          19.527;      // bar [origin=predictive method=joback]
omega       0.6386;      // -   [origin=predictive method=lee-kesler]
Tb          569.00;      // K   [origin=predictive method=joback]
HvapTb      52401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.836 1.25988 -0.00074752 1.685e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,2,6-tetramethylbenzeneamine" "n,n,2,6-tetramethylbenzenamine" );
gibbsFormation
{
    dHf_298   -51170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     598.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=270930.0
    phase     gas;
}
