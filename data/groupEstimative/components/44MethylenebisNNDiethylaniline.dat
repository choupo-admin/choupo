/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-methylenebis(n,n-diethylaniline)  (C21H30N2, CAS 135-91-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44MethylenebisNNDiethylaniline;
formula     C21H30N2;
CAS         135-91-1;
InChIKey    MIERBLCDXYWVTF-UHFFFAOYSA-N;
MW          310.485;      // g/mol [origin=calculated method=formula-sum]
Tc          977.23;      // K   [origin=predictive method=joback]
Pc          14.725;      // bar [origin=predictive method=joback]
omega       0.8826;      // -   [origin=predictive method=lee-kesler]
Tb          768.28;      // K   [origin=predictive method=joback]
HvapTb      72302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.795 1.96988 -0.00127212 3.147e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group CH2N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[[4-(diethylamino)phenyl]methyl]-n,n-diethyl-aniline" "benzenamine, 4,4'-methylenebis[n,n-diethyl-" "n1,n1-diethyl-4-[4-(diethylamino)benzyl]aniline" "benzenamine, 4,4'-methylenebis(n,n-diethyl-" "4-[[4-(diethylamino)phenyl]methyl]-n,n-diethylaniline" "4-{[4-(diethylamino)phenyl]methyl}-n,n-diethylaniline" );
standardThermochemistry
{
    dHf_298   108410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     780.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=553060.0
}
