/*--------------------------------*- Choupo -*-----------------------*\
  Component: pyrrolidine,1-(1-buten-3-ynyl)-  (C8H11N, CAS 19352-85-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pyrrolidine11Buten3Ynyl;
formula     C8H11N;
CAS         19352-85-3;
InChIKey    LOHBTCFJVVZEEX-UHFFFAOYSA-N;
MW          121.183;      // g/mol [origin=calculated method=formula-sum]
Tc          632.04;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.3034;      // -   [origin=predictive method=lee-kesler]
Tb          416.44;      // K   [origin=predictive method=joback]
HvapTb      37321.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.81 0.8857 -0.00068396 2.1538e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2=CH; count 1; } { group CH2N; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group tC; count 2; } { group CH2_ring; count 4; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-but-3-en-1-ynylpyrrolidine" "pyrrolidine, 1-(1-buten-3-ynyl)-" );
gibbsFormation
{
    dHf_298   343790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=474260.0
    phase     gas;
}
