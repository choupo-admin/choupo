/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e) isopropyl-1-propenylsulfide  (C6H12S, CAS 61865-99-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eIsopropyl1Propenylsulfide;
formula     C6H12S;
CAS         61865-99-4;
InChIKey    IZLJYHRILGAGIM-SNAWJCMRSA-N;
MW          116.222;      // g/mol [origin=calculated method=formula-sum]
Tc          613.09;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.3053;      // -   [origin=predictive method=lee-kesler]
Tb          409.38;      // K   [origin=predictive method=joback]
HvapTb      35337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.17 0.59415 -0.0003494 7.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=CH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 2; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1-propan-2-ylsulfanylprop-1-ene" "(e)-isopropyl-1-propenylsulfide" );
standardThermochemistry
{
    dHf_298   -13360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     435.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=110540.0
}
