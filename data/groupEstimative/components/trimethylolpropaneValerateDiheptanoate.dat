/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane valerate diheptanoate  (C25H46O6, CAS 71426-94-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneValerateDiheptanoate;
formula     C25H46O6;
CAS         71426-94-3;
InChIKey    UHSSSGAJFCVTIU-UHFFFAOYSA-N;
MW          442.637;      // g/mol [origin=calculated method=formula-sum]
Tc          1157.56;      // K   [origin=predictive method=joback]
Pc          7.785;      // bar [origin=predictive method=joback]
omega       0.7139;      // -   [origin=predictive method=lee-kesler]
Tb          943.03;      // K   [origin=predictive method=joback]
HvapTb      92169.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.917 2.34028 -0.0012242 1.869e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 14; } { group C; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 17; } { group C; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(heptanoyloxymethyl)-2-(pentanoyloxymethyl)butyl] heptanoate" "heptanoic acid, 1,1'-(2-ethyl-2-(((1-oxopentyl)oxy)methyl)-1,3-propanediyl) ester" "heptanoic acid, 1,1'-[2-ethyl-2-[[(1-oxopentyl)oxy]methyl]-1,3-propanediyl] ester" "trimethylolpropane pentanoate, diheptanoate" "heptanoic acid, 2-ethyl-2-(((1-oxopentyl)oxy)methyl)-1,3-propanediyl ester" );
gibbsFormation
{
    dHf_298   -1519920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1244.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-768650.0
    phase     gas;
}
