/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclohexyl phthalate  (C20H26O4, CAS 84-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclohexylPhthalate;
formula     C20H26O4;
CAS         84-61-7;
InChIKey    VOWAEIGWURALJQ-UHFFFAOYSA-N;
MW          330.424;      // g/mol [origin=calculated method=formula-sum]
Tc          1087.30;      // K   [origin=predictive method=joback]
Pc          17.332;      // bar [origin=predictive method=joback]
omega       0.8844;      // -   [origin=predictive method=lee-kesler]
Tb          844.40;      // K   [origin=predictive method=joback]
HvapTb      78724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.29 1.9 -0.00100116 1.324e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 10; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclohexyl benzene-1,2-dicarboxylate" "ergoplast fdc" "phthalic acid, dicyclohexyl ester" "unimoll 66" "ergoplast.fdc" "howflex cp" "dicyclohexylphthalat" "1,2-benzenedicarboxylic acid, dicyclohexyl ester" "phthalic acid dicyclohexyl ester" "diclohexyl 1,2-benzenedicarboxylate" "ai3-00515 (usda)" "1,2-benzenedicarboxylic acid, 1,2-dicyclohexyl ester" );
standardThermochemistry
{
    dHf_298   -756990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     864.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351540.0
}
