/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,7,10,13,16-hexaoxacyclooctadecane-2-methanol  (C13H26O7, CAS 70069-04-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        147101316Hexaoxacyclooctadecane2Methanol;
formula     C13H26O7;
CAS         70069-04-4;
InChIKey    HFRGASADQCZXHH-UHFFFAOYSA-N;
MW          294.344;      // g/mol [origin=calculated method=formula-sum]
Tc          1062.56;      // K   [origin=predictive method=joback]
Pc          27.042;      // bar [origin=predictive method=joback]
omega       1.1474;      // -   [origin=predictive method=lee-kesler]
Tb          821.71;      // K   [origin=predictive method=joback]
HvapTb      90764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.769 1.2617 -0.0001546 -2.481e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group OH; count 1; } { group FCH2O; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 11; } { group CH_ring; count 1; } { group OH; count 1; } { group O_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4,7,10,13,16-hexaoxacyclooctadec-2-ylmethanol" "18-crown-6-methanol" "2-hydroxymethyl-18-crown-6" "hfrgasadqczxhh-uhfffaoysa-" "2-(hydroxymethyl)-18-crown 6-ether" "(2,5,8,11,14,17-hexaoxacyclooctadecyl)methan-1-ol" );
standardThermochemistry
{
    dHf_298   -1275480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-715710.0
}
