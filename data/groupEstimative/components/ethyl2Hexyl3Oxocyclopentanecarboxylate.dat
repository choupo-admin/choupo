/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-hexyl-3-oxocyclopentanecarboxylate  (C14H24O3, CAS 37172-54-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Hexyl3Oxocyclopentanecarboxylate;
formula     C14H24O3;
CAS         37172-54-6;
InChIKey    INTQBOZOCPYNQM-UHFFFAOYSA-N;
MW          240.343;      // g/mol [origin=calculated method=formula-sum]
Tc          854.46;      // K   [origin=predictive method=joback]
Pc          17.729;      // bar [origin=predictive method=joback]
omega       0.8062;      // -   [origin=predictive method=lee-kesler]
Tb          656.57;      // K   [origin=predictive method=joback]
HvapTb      58360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.544 1.21594 -0.0004712 -3.4e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 2; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-hexyl-3-oxidanylidene-cyclopentane-1-carboxylate" "cyclopentanecarboxylic acid, 2-hexyl-3-oxo-, ethyl ester" "ethyl  2-hexyl-3-oxocyclopentanecarboxylate" "ethyl2-hexyl-3-oxocyclopentanecarboxylate" "ethyl 2-hexyl-3-oxocyclopentane-1-carboxylate" "cyclopentanecarboxylicacid, 2-hexyl-3-oxo-, ethyl ester" "2-hexyl-3-oxo-1-cyclopentanecarboxylic acid, ethyl ester" );
gibbsFormation
{
    dHf_298   -747130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     581.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-337120.0
    phase     gas;
}
