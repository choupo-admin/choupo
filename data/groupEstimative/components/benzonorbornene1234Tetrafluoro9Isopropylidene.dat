/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzonorbornene, 1,2,3,4-tetrafluoro-9-isopropylidene-  (C14H12F4, CAS 51716-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzonorbornene1234Tetrafluoro9Isopropylidene;
formula     C14H12F4;
CAS         51716-04-2;
InChIKey    MBNUUWWMGXQCCK-UHFFFAOYSA-N;
MW          256.242;      // g/mol [origin=calculated method=formula-sum]
Tc          776.55;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       0.7247;      // -   [origin=predictive method=lee-kesler]
Tb          584.31;      // K   [origin=predictive method=joback]
HvapTb      49597.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.84 1.23844 -0.000957 3.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACCH; count 2; } { group C=C; count 1; } { group ACF; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dC_ring; count 7; } { group F; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -719550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     458.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-477470.0
    phase     gas;
}
