/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-alanylglycine  (C5H10N2O3, CAS 2672-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaAlanylglycine;
formula     C5H10N2O3;
CAS         2672-88-0;
InChIKey    QDHYJVJAGQLHBA-UHFFFAOYSA-N;
MW          146.146;      // g/mol [origin=calculated method=formula-sum]
Tc          846.04;      // K   [origin=predictive method=joback]
Pc          45.902;      // bar [origin=predictive method=joback]
omega       1.1994;      // -   [origin=predictive method=lee-kesler]
Tb          636.08;      // K   [origin=predictive method=joback]
HvapTb      67711.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.583 0.6397 -0.0003941 8.876e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2NH2; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CdO; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-azanylpropanoylamino)ethanoic acid" "glycine, b-alanyl-" ".beta.-alanylglycine" "[(3-ammoniopropanoyl)amino]acetate" "2-(3-aminopropanoylamino)acetic acid" );
standardThermochemistry
{
    dHf_298   -522120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-325770.0
}
