/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(3-methoxyphenyl)piperazine  (C11H16N2O, CAS 16015-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13MethoxyphenylPiperazine;
formula     C11H16N2O;
CAS         16015-71-7;
InChIKey    PZIBVWUXWNYTNL-UHFFFAOYSA-N;
MW          192.262;      // g/mol [origin=calculated method=formula-sum]
Tc          820.90;      // K   [origin=predictive method=joback]
Pc          33.067;      // bar [origin=predictive method=joback]
omega       0.6285;      // -   [origin=predictive method=lee-kesler]
Tb          586.30;      // K   [origin=predictive method=joback]
HvapTb      54795.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.41 1.11592 -0.00066256 1.377e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(3-methoxyphenyl)-piperazine" "3-methoxy-1-piperazinylbenzene" "3-(1-piperazinyl)anisole" "n-(3-methylphenyl)piperazine" "n-(3-methoxyphenyl)piperazine" "1-(3-methoxy-phenyl)-piperazine" "sdccgmls-0065814.p001" "1-(3-methoxy-phenyl)-piperazine 2hcl salt" "1-(3-methoxyphenyl)piperazine dinydrochloride" "brd-k49785567-300-01-3" "piperazine,1-(m-methoxyphenyl)- (8ci);1-(3'-methoxyphenyl)piperazine;1-(m-methoxyphenyl)piperazine;1-m-anisylpiperazine;4-(3-methoxyphenyl)piperazine;n-(3-methoxyphenyl)piperazine;" );
standardThermochemistry
{
    dHf_298   8630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=282270.0
}
