/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-cyclohexanediethanol  (C10H20O2, CAS 3187-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Cyclohexanediethanol;
formula     C10H20O2;
CAS         3187-27-7;
InChIKey    WFUUAJVRMXKBBI-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          816.21;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       1.3034;      // -   [origin=predictive method=lee-kesler]
Tb          632.55;      // K   [origin=predictive method=joback]
HvapTb      70490.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-111.216 1.4358 -0.0011946 4.35e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1-(2-hydroxyethyl)cyclohexyl]ethanol" "cyclohexane-1,1-diethanol" "2,2'-cyclohexane-1,1-diyldiethanol" "2-[(2-hydroxyethyl)cyclohexyl]ethan-1-ol" );
standardThermochemistry
{
    dHf_298   -484630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     686.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-221360.0
}
