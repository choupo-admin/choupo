/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-iodooctane  (C8H17I, CAS 629-27-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Iodooctane;
formula     C8H17I;
CAS         629-27-6;
InChIKey    UWLHSHAHTBJTBA-UHFFFAOYSA-N;
MW          240.124;      // g/mol [origin=calculated method=formula-sum]
Tc          671.66;      // K   [origin=predictive method=joback]
Pc          24.801;      // bar [origin=predictive method=joback]
omega       0.4486;      // -   [origin=predictive method=lee-kesler]
Tb          475.78;      // K   [origin=predictive method=joback]
HvapTb      42775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.307 0.80282 -0.0004928 1.239e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanyloctane" "n-octyl iodide" "octyl iodide" "octane, 1-iodo-" "1-octyl iodide" "1-n-octyl iodide" "1-iodo-octane" "1-jodoktan" "uwlhshahtbjtba-uhfffaoysa-" "u396" "1-iodo-n-octane;1-iodooctane;1-octyl iodide;1-n-octyl iodide;octyl iodide;n-octyl iodide;" );
standardThermochemistry
{
    dHf_298   -131580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     523.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74600.0
}
