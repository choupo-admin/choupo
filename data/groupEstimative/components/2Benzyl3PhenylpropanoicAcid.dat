/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-benzyl-3-phenylpropanoic acid  (C16H16O2, CAS 618-68-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Benzyl3PhenylpropanoicAcid;
formula     C16H16O2;
CAS         618-68-8;
InChIKey    RBLAOGBEJPHFHW-UHFFFAOYSA-N;
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          1005.57;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.9327;      // -   [origin=predictive method=lee-kesler]
Tb          764.11;      // K   [origin=predictive method=joback]
HvapTb      72538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.548 1.4227 -0.0009848 2.577e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenyl-2-(phenylmethyl)propanoic acid" "dibenzylacetic acid" "2-(benzyl)-3-phenyl-propionic acid" "benzenepropanoic acid, .alpha.-(phenylmethyl)-" "hydrocinnamic acid, .alpha.-benzyl-" "3-phenyl-2-benzylpropanoic acid" "hydrocinnamic acid, alpha-benzyl-" "benzenepropanoic acid, alpha-(phenylmethyl)-" );
standardThermochemistry
{
    dHf_298   -256060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     610.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37690.0
}
