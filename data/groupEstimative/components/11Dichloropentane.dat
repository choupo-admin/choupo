/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloropentane  (C5H10Cl2, CAS 110675-51-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloropentane;
formula     C5H10Cl2;
CAS         110675-51-9;
InChIKey    PGEVTVXEERFABN-UHFFFAOYSA-N;
MW          141.035;      // g/mol [origin=calculated method=formula-sum]
Tc          573.99;      // K   [origin=predictive method=joback]
Pc          32.137;      // bar [origin=predictive method=joback]
omega       0.3404;      // -   [origin=predictive method=lee-kesler]
Tb          388.42;      // K   [origin=predictive method=joback]
HvapTb      35106.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.443 0.49832 -0.0002922 6.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)pentane" "pentane, dichloro-" "dichloropentane" );
standardThermochemistry
{
    dHf_298   -183290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     408.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-35080.0
}
