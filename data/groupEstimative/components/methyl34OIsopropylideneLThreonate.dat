/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 3,4-o-isopropylidene-l-threonate  (C8H14O5, CAS 92973-40-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl34OIsopropylideneLThreonate;
formula     C8H14O5;
CAS         92973-40-5;
InChIKey    JSFASCPVVJBLRD-NTSWFWBYSA-N;
MW          190.195;      // g/mol [origin=calculated method=formula-sum]
Tc          794.90;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       1.0233;      // -   [origin=predictive method=lee-kesler]
Tb          597.35;      // K   [origin=predictive method=joback]
HvapTb      64917.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.26 1.14006 -0.0009272 3.281e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group OH; count 1; } { group O_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl (2r)-2-[(4s)-2,2-dimethyl-1,3-dioxolan-4-yl]-2-oxidanyl-ethanoate" "3,4-o-isopropylidene-l-threonic acid methyl ester" "(alphar,4s)-2,2-dimethyl-alpha-hydroxy-1,3-dioxolane-4-acetic acid methyl ester" "jsfascpvvjblrd-ntswfwbysa-" "(" "ar,4s)-2,2-dimethyl-" "a-hydroxy-1,3-dioxolane-4-acetic acid methyl ester" );
gibbsFormation
{
    dHf_298   -891860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-582040.0
    phase     gas;
}
