/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3,5-dichlorophenyl)-2-propanol  (C9H10Cl2O, CAS 68575-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        235Dichlorophenyl2Propanol;
formula     C9H10Cl2O;
CAS         68575-35-9;
InChIKey    LZJXTXRCENENLT-UHFFFAOYSA-N;
MW          205.078;      // g/mol [origin=calculated method=formula-sum]
Tc          823.80;      // K   [origin=predictive method=joback]
Pc          32.878;      // bar [origin=predictive method=joback]
omega       0.8249;      // -   [origin=predictive method=lee-kesler]
Tb          605.97;      // K   [origin=predictive method=joback]
HvapTb      63381.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.0 0.83434 -0.00060592 1.713e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 3; } { group AC; count 1; } { group OH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3,5-bis(chloranyl)phenyl]propan-2-ol" "2-(3,5-dichlorophenyl)propan-2-ol" "benzenemethanol, 3,5-dichloro-alpha,alpha-dimethyl-" "2-(3,5-dichlorophenyl)-2-propanol;" "benzenemethanol,3,5-dichloro-a,a-dimethyl-" "benzenemethanol, 3,5-dichloro-.alpha.,.alpha.-dimethyl-" );
gibbsFormation
{
    dHf_298   -207960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-39790.0
    phase     gas;
}
