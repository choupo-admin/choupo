/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-paracyclophane  (C21H26, CAS 6169-94-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Paracyclophane;
formula     C21H26;
CAS         6169-94-4;
InChIKey    DMCPGMNUZQZGNM-UHFFFAOYSA-N;
MW          278.439;      // g/mol [origin=calculated method=formula-sum]
Tc          1048.87;      // K   [origin=predictive method=joback]
Pc          19.086;      // bar [origin=predictive method=joback]
omega       0.6080;      // -   [origin=predictive method=lee-kesler]
Tb          780.43;      // K   [origin=predictive method=joback]
HvapTb      69470.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.32 1.8418 -0.00104412 1.88e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   29530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     820.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=327360.0
    phase     gas;
}
