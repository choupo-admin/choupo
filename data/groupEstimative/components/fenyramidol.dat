/*--------------------------------*- Choupo -*-----------------------*\
  Component: fenyramidol  (C13H14N2O, CAS 553-69-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fenyramidol;
formula     C13H14N2O;
CAS         553-69-5;
InChIKey    ZEAJXCPGHPJVNP-UHFFFAOYSA-N;
MW          214.268;      // g/mol [origin=calculated method=formula-sum]
Tc          978.17;      // K   [origin=predictive method=joback]
Pc          35.013;      // bar [origin=predictive method=joback]
omega       1.1749;      // -   [origin=predictive method=lee-kesler]
Tb          746.01;      // K   [origin=predictive method=joback]
HvapTb      78021.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.279 1.23086 -0.00083726 2.161e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group ACCH; count 1; } { group OH; count 1; } { group CH2NH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 2; } { group OH; count 1; } { group NH; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-2-(pyridin-2-ylamino)ethanol" "evasprine" "phenyramidol" "bonapar" "cabral" "evasprin" "vilexin" "(+-)-phenyramidol" "feniramidolo [dcit]" "fenyramidol [inn:ban]" "fenyramidolum [inn-latin]" "benzenemethanol, .alpha.-[(2-pyridinylamino)methyl]-" );
standardThermochemistry
{
    dHf_298   90160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     544.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=310580.0
}
