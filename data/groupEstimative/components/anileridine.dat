/*--------------------------------*- Choupo -*-----------------------*\
  Component: anileridine  (C22H28N2O2, CAS 144-14-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anileridine;
formula     C22H28N2O2;
CAS         144-14-9;
InChIKey    LKYQLAWMNBFNJT-UHFFFAOYSA-N;
MW          352.478;      // g/mol [origin=calculated method=formula-sum]
Tc          1163.50;      // K   [origin=predictive method=joback]
Pc          17.390;      // bar [origin=predictive method=joback]
omega       1.0653;      // -   [origin=predictive method=lee-kesler]
Tb          920.01;      // K   [origin=predictive method=joback]
HvapTb      88977.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-159.887 2.43112 -0.00188976 6.055e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 1-[2-(4-aminophenyl)ethyl]-4-phenyl-piperidine-4-carboxylate" "apodol" "anileridinum" "anileridina" "leritine" "nipecotan" "adopol" "alidine" "leritin" "anileridinum [inn-latin]" "apidol" "n-beta-(p-aminophenyl)ethylnormeperidine" );
gibbsFormation
{
    dHf_298   -176060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     932.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=247470.0
    phase     gas;
}
