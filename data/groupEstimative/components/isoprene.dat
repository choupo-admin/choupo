/*--------------------------------*- Choupo -*-----------------------*\
  Component: isoprene  (C5H8, CAS 78-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isoprene;
formula     C5H8;
CAS         78-79-5;
InChIKey    RRHGJUQNOFWUDK-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          480.52;      // K   [origin=predictive method=joback]
Pc          38.627;      // bar [origin=predictive method=joback]
omega       0.1924;      // -   [origin=predictive method=lee-kesler]
Tb          307.24;      // K   [origin=predictive method=joback]
HvapTb      25464.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.33 0.43872 -0.0002963 8.49e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylbuta-1,3-diene" "2-methyl-1,3-butadiene" "isopentadiene" "1,3-butadiene, 2-methyl-" "2-methylbutadiene" "2-methyldivinyl" "beta-methylbivinyl" "isopreno" "isoterpene" "isopren" "3-methyl-1,3-butadiene" "1,3-butadiene, 2-methyl-, homopolymer" );
gibbsFormation
{
    dHf_298   94540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     337.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=158350.0
    phase     gas;
}
