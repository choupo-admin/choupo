/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene, 1,4-dichloro-2-methyl-  (C5H8Cl2, CAS 29843-58-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene14Dichloro2Methyl;
formula     C5H8Cl2;
CAS         29843-58-1;
InChIKey    WYQWPAZKDKRBIG-GORDUTHDSA-N;
MW          139.019;      // g/mol [origin=calculated method=formula-sum]
Tc          587.66;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.3112;      // -   [origin=predictive method=lee-kesler]
Tb          392.90;      // K   [origin=predictive method=joback]
HvapTb      35532.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.252 0.51232 -0.0003751 1.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=C; count 1; } { group CH2Cl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-1,4-bis(chloranyl)-2-methyl-but-2-ene" "(e)-1,4-dichloro-2-methylbut-2-ene" );
standardThermochemistry
{
    dHf_298   -70580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     406.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=39030.0
}
