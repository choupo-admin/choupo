/*--------------------------------*- Choupo -*-----------------------*\
  Component: di(phenoxyethyl) maleate  (C20H20O6, CAS 10534-77-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diPhenoxyethylMaleate;
formula     C20H20O6;
CAS         10534-77-7;
InChIKey    HRYREZUFSWGBTI-QXMHVHEDSA-N;
MW          356.374;      // g/mol [origin=calculated method=formula-sum]
Tc          1099.11;      // K   [origin=predictive method=joback]
Pc          16.687;      // bar [origin=predictive method=joback]
omega       1.1207;      // -   [origin=predictive method=lee-kesler]
Tb          876.00;      // K   [origin=predictive method=joback]
HvapTb      84258.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.534 1.53 -0.0007992 1.014e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(2-phenoxyethyl) (z)-but-2-enedioate" "2-butenedioic acid (2z)-, bis(2-phenoxyethyl) ester" "2-butenedioic acid (2z)-, 1,4-bis(2-phenoxyethyl) ester" "2-butenedioic acid (z)-, bis(2-phenoxyethyl) ester" "2-butenedioic acid (z)-, bis(2-phenoxyethyl) ester (9ci)" );
gibbsFormation
{
    dHf_298   -764850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     840.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-408180.0
    phase     gas;
}
