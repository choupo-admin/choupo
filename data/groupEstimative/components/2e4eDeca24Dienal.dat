/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2e,4e)-deca-2,4-dienal  (C10H16O, CAS 25152-84-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2e4eDeca24Dienal;
formula     C10H16O;
CAS         25152-84-5;
InChIKey    JZQKTMZYLHNFPL-BLHCBFLLSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          669.66;      // K   [origin=predictive method=joback]
Pc          25.000;      // bar [origin=predictive method=joback]
omega       0.5827;      // -   [origin=predictive method=lee-kesler]
Tb          485.38;      // K   [origin=predictive method=joback]
HvapTb      44490.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.166 0.96832 -0.0006808 2.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH=CH; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group dCH; count 4; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e,e)-2,4-decadienal" "trans,trans-2,4-decadienal" "2,4-decadienal" "2,4-decadienal, (e,e)-" "(2e,4e)-2,4-decadienal" "(2e,4e)-decadienal" "2,4-decadienal, trans,trans-" "2,4-decadienal, (2e,4e)-" "(2e,4e)deca-2,4-dienal" "deca-2,4-dienal" "2,4-decadienal (natural)" "2-trans-4-trans-decadienal" );
standardThermochemistry
{
    dHf_298   -100870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     551.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94240.0
}
