/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentafluoropropyl iodide  (C3H2F5I, CAS 354-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentafluoropropylIodide;
formula     C3H2F5I;
CAS         354-69-8;
InChIKey    HENALDZJQYAUBN-UHFFFAOYSA-N;
MW          259.939;      // g/mol [origin=calculated method=formula-sum]
Tc          527.16;      // K   [origin=predictive method=joback]
Pc          33.999;      // bar [origin=predictive method=joback]
omega       0.2978;      // -   [origin=predictive method=lee-kesler]
Tb          351.27;      // K   [origin=predictive method=joback]
HvapTb      24968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.639 0.6384 -0.0006464 2.362e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group I; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group C; count 2; } { group F; count 5; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1,2,2-pentakis(fluoranyl)-3-iodanyl-propane" "2,2,3,3,3-pentafluoropropyl iodide" "1,1,1,2,2-pentafluoro-3-iodopropane" "1h,1h-pentafluoropropyl iodide" "propane, 1,1,1,2,2-pentafluoro-3-iodo-" "2,3,3,3-pentafluoropropyl iodide" "propane,1,1,2,2-pentafluoro-3-iodo-" "2,2,3,3,3-pentafluoroprop-1-yl iodide" "propane,1,1,1,2,2-pentafluoro-3-iodo-" "1-iodo-2,2,3,3,3-pentafluoropropane" "1,1,1,2,2-pentafluoro-3-iodopropane;2,2,3,3,3-pentafluoropropyl iodide;" );
standardThermochemistry
{
    dHf_298   -1026430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-935870.0
}
