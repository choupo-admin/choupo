/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,7,11,13-octadecatetrayne-1,18-diol  (C18H22O2, CAS 76379-67-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        571113Octadecatetrayne118Diol;
formula     C18H22O2;
CAS         76379-67-4;
InChIKey    DXLYLRZSEWFXDB-UHFFFAOYSA-N;
MW          270.372;      // g/mol [origin=calculated method=formula-sum]
Tc          1039.64;      // K   [origin=predictive method=joback]
Pc          22.208;      // bar [origin=predictive method=joback]
omega       1.3964;      // -   [origin=predictive method=lee-kesler]
Tb          831.80;      // K   [origin=predictive method=joback]
HvapTb      97628.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.34 1.1826 -0.00064764 1.3852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group OH; count 2; } { group C_C; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group tC; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadeca-5,7,11,13-tetrayne-1,18-diol" "5,7,11,13-octadecatrayne-1,18-diol" );
standardThermochemistry
{
    dHf_298   369890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     845.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=638240.0
}
