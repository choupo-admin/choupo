/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(1-hydroxycyclohexyl)ethanone  (C8H14O2, CAS 1123-27-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11HydroxycyclohexylEthanone;
formula     C8H14O2;
CAS         1123-27-9;
InChIKey    JKAKPUWJSRMKFH-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          755.96;      // K   [origin=predictive method=joback]
Pc          40.007;      // bar [origin=predictive method=joback]
omega       0.8258;      // -   [origin=predictive method=lee-kesler]
Tb          548.48;      // K   [origin=predictive method=joback]
HvapTb      56105.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-107.33 1.18382 -0.0010367 3.9236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(1-oxidanylcyclohexyl)ethanone" "ethanone, 1-(1-hydroxycyclohexyl)-" "1-(1-hydroxycyclohexyl)ethan-1-one" "1-acetylcyclohexanol" "1-(1-hydroxy-cyclohexyl)-ethanone" "ethanone,1-(1-hydroxycyclohexyl)-" );
gibbsFormation
{
    dHf_298   -403700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-230300.0
    phase     gas;
}
