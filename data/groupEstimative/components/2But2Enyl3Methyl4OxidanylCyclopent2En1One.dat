/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-but-2-enyl-3-methyl-4-oxidanyl-cyclopent-2-en-1-one  (C10H14O2, CAS 17190-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2But2Enyl3Methyl4OxidanylCyclopent2En1One;
formula     C10H14O2;
CAS         17190-74-8;
InChIKey    YLKLJBPHNWWPSF-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          821.39;      // K   [origin=predictive method=joback]
Pc          30.423;      // bar [origin=predictive method=joback]
omega       0.9482;      // -   [origin=predictive method=lee-kesler]
Tb          616.96;      // K   [origin=predictive method=joback]
HvapTb      60611.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.769 0.79624 -0.000371 4.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(z)-but-2-enyl]-4-hydroxy-3-methyl-cyclopent-2-en-1-one" "2-cyclopenten-1-one,2-(2z)-2-buten-1-yl-4-hydroxy-3-methyl-" "2-cyclopenten-1-one,2-(2-butenyl)-4-hydroxy-3-methyl-, (z)- (8ci); 2-cyclopenten-1-one,2-(2z)-2-butenyl-4-hydroxy-3-methyl- (9ci); (?a'a a'a currency)-z-cinerolone; cinerolon; cinerolone" );
standardThermochemistry
{
    dHf_298   -327120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     410.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-98620.0
}
