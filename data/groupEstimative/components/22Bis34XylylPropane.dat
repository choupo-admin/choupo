/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(3,4-xylyl)propane  (C19H24, CAS 6970-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Bis34XylylPropane;
formula     C19H24;
CAS         6970-01-0;
InChIKey    BGTZYQSCNQIZER-UHFFFAOYSA-N;
MW          252.401;      // g/mol [origin=calculated method=formula-sum]
Tc          937.70;      // K   [origin=predictive method=joback]
Pc          17.061;      // bar [origin=predictive method=joback]
omega       0.6084;      // -   [origin=predictive method=lee-kesler]
Tb          704.37;      // K   [origin=predictive method=joback]
HvapTb      63792.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.47 1.53892 -0.00097584 2.382e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group ACH; count 6; } { group AC; count 2; } { group ACCH3; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-(3,4-dimethylphenyl)propan-2-yl]-1,2-dimethyl-benzene" "propane, 2,2-bis(3,4-xylyl)-," "benzene,1,1'-(1-methylethylidene)bis[3,4-dimethyl-" "4-[2-(3,4-dimethylphenyl)propan-2-yl]-1,2-dimethylbenzene" );
standardThermochemistry
{
    dHf_298   -17060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     619.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=298240.0
}
