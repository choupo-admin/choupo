/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1z,5z,8s)-1,5-dimethyl-8-prop-1-en-2-yl-cyclodeca-1,5-diene  (C15H24, CAS 28387-44-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1z5z8s15Dimethyl8Prop1En2YlCyclodeca15Diene;
formula     C15H24;
CAS         28387-44-2;
InChIKey    XMRKUJJDDKYUHV-UHFFFAOYSA-N;
MW          204.357;      // g/mol [origin=calculated method=formula-sum]
Tc          810.69;      // K   [origin=predictive method=joback]
Pc          19.510;      // bar [origin=predictive method=joback]
omega       0.4269;      // -   [origin=predictive method=lee-kesler]
Tb          584.27;      // K   [origin=predictive method=joback]
HvapTb      51419.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.36 1.26146 -0.00055328 3.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,5-dimethyl-8-prop-1-en-2-yl-cyclodeca-1,5-diene" "agn-pc-00kfd9" "1,5-dimethyl-8-prop-1-en-2-ylcyclodeca-1,5-diene" "1,5-cyclodecadiene, 1,5-dimethyl-8-(1-methylethenyl)-" "1,5-dimethyl-8-(prop-1-en-2-yl)cyclodeca-1,5-diene" );
gibbsFormation
{
    dHf_298   -114990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171420.0
    phase     gas;
}
