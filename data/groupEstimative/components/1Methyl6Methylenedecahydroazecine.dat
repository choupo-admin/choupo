/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-6-methylenedecahydroazecine  (C11H21N, CAS 57839-84-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl6Methylenedecahydroazecine;
formula     C11H21N;
CAS         57839-84-6;
InChIKey    ARRHTPVLVSIURT-UHFFFAOYSA-N;
MW          167.296;      // g/mol [origin=calculated method=formula-sum]
Tc          717.07;      // K   [origin=predictive method=joback]
Pc          26.461;      // bar [origin=predictive method=joback]
omega       0.3971;      // -   [origin=predictive method=lee-kesler]
Tb          499.91;      // K   [origin=predictive method=joback]
HvapTb      43536.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-82.42 1.17502 -0.000592 7.61e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH2=C; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group CH2_ring; count 8; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-6-methylidene-azecane" "1-methyl-6-methylideneazecane" );
gibbsFormation
{
    dHf_298   -62420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201460.0
    phase     gas;
}
