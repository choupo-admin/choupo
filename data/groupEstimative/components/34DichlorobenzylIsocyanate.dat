/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dichlorobenzyl isocyanate  (C8H5Cl2NO, CAS 19752-09-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DichlorobenzylIsocyanate;
formula     C8H5Cl2NO;
CAS         19752-09-1;
InChIKey    WLNAHQZFPSSVTP-UHFFFAOYSA-N;
MW          202.034;      // g/mol [origin=calculated method=formula-sum]
Tc          794.22;      // K   [origin=predictive method=joback]
Pc          35.221;      // bar [origin=predictive method=joback]
omega       0.5899;      // -   [origin=predictive method=lee-kesler]
Tb          560.81;      // K   [origin=predictive method=joback]
HvapTb      55304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH2; count 1; } { group dCd; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-4-(isocyanatomethyl)benzene" "1,2-dichloro-4-(isocyanatomethyl)benzene" "(3,4-dichlorophenyl)methanisocyanate" "3,4-dichlorobenzylisocyanate" "u893" "benzene,1,2-dichloro-4-(isocyanatomethyl)-" "1,2-dichloro-4-isocyanatomethyl-benzene" "isocyanicacid, 3,4-dichlorobenzyl ester (8ci);1,2-dichloro-4-isocyanatomethylbenzene;" );
