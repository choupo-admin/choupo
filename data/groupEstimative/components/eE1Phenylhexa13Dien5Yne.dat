/*--------------------------------*- Choupo -*-----------------------*\
  Component: e,e-1-phenylhexa-1,3-dien-5-yne  (C12H10, CAS 940-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        eE1Phenylhexa13Dien5Yne;
formula     C12H10;
CAS         940-50-1;
InChIKey    SEQZAYGOCMKLRP-JAFPNSLJSA-N;
MW          154.212;      // g/mol [origin=calculated method=formula-sum]
Tc          735.06;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       0.3465;      // -   [origin=predictive method=lee-kesler]
Tb          499.28;      // K   [origin=predictive method=joback]
HvapTb      44356.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.51 1.011 -0.00082373 2.7029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 4; } { group tCH; count 1; } { group tC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(1e,3e)-hexa-1,3-dien-5-ynyl]benzene" "(e,e)-1-phenylhexa-1,3-dien-5-yne" );
gibbsFormation
{
    dHf_298   471860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=546080.0
    phase     gas;
}
