/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptane, 3-iodo-  (C7H15I, CAS 31294-92-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptane3Iodo;
formula     C7H15I;
CAS         31294-92-5;
InChIKey    LVPGHYVXKUXNQR-UHFFFAOYSA-N;
MW          226.097;      // g/mol [origin=calculated method=formula-sum]
Tc          655.33;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       0.3688;      // -   [origin=predictive method=lee-kesler]
Tb          452.46;      // K   [origin=predictive method=joback]
HvapTb      40161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.534 0.71374 -0.0004416 1.115e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-iodanylheptane" "3-iodoheptane" );
gibbsFormation
{
    dHf_298   -116220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63740.0
    phase     gas;
}
