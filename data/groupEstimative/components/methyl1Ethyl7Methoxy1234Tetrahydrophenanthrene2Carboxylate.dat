/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 1-ethyl-7-methoxy-1,2,3,4-tetrahydrophenanthrene-2-carboxylate  (C19H22O3, CAS 5684-13-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl1Ethyl7Methoxy1234Tetrahydrophenanthrene2Carboxylate;
formula     C19H22O3;
CAS         5684-13-9;
InChIKey    OJFWJATUXXVABM-UHFFFAOYSA-N;
MW          298.382;      // g/mol [origin=calculated method=formula-sum]
Tc          1006.30;      // K   [origin=predictive method=joback]
Pc          17.347;      // bar [origin=predictive method=joback]
omega       0.8897;      // -   [origin=predictive method=lee-kesler]
Tb          781.90;      // K   [origin=predictive method=joback]
HvapTb      73383.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.349 1.54456 -0.0008894 1.761e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group AC; count 3; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 5; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-1,2,3,4-tetrahydro-7-methoxy-2-methyl-2-phenanthrenecarboxylic acid" "2-phenanthrenecarboxylic acid, 1-ethyl-1,2,3,4-tetrahydro-7-methoxy-2-methyl-" );
gibbsFormation
{
    dHf_298   -445500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75160.0
    phase     gas;
}
