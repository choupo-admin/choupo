/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichlorobutanoic acid  (C4H6Cl2O2, CAS 13023-00-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DichlorobutanoicAcid;
formula     C4H6Cl2O2;
CAS         13023-00-2;
InChIKey    OBLYWUBMZGHQDN-UHFFFAOYSA-N;
MW          156.99;      // g/mol [origin=calculated method=formula-sum]
Tc          726.75;      // K   [origin=predictive method=joback]
Pc          40.673;      // bar [origin=predictive method=joback]
omega       0.5984;      // -   [origin=predictive method=lee-kesler]
Tb          508.26;      // K   [origin=predictive method=joback]
HvapTb      49136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.161 0.57402 -0.000479 1.543e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group COOH; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group C; count 1; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)butanoic acid" "butanoic acid,2,2-dichloro-" "butyric acid, 2,2-dichloro-" "butanoic acid, 2,2-dichloro-" "2,2-dichlorobutyric acid" "butyricacid, 2,2-dichloro- (6ci,7ci,8ci); 2,2-dichlorobutanoic acid" );
gibbsFormation
{
    dHf_298   -516390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-382130.0
    phase     gas;
}
