/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-di-tert-butylthiophene  (C12H20S, CAS 1689-77-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DiTertButylthiophene;
formula     C12H20S;
CAS         1689-77-6;
InChIKey    ISYGRXKYALZEIS-UHFFFAOYSA-N;
MW          196.352;      // g/mol [origin=calculated method=formula-sum]
Tc          773.67;      // K   [origin=predictive method=joback]
Pc          23.047;      // bar [origin=predictive method=joback]
omega       0.3762;      // -   [origin=predictive method=lee-kesler]
Tb          543.76;      // K   [origin=predictive method=joback]
HvapTb      48000.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.41 1.33713 -0.00101458 3.105e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-ditert-butylthiophene" "thiophene, 2,5-bis(1,1-dimethylethyl)-" "thiophene, 2,5-di-tert-butyl-" "2,5-ditert-butyl-thiophene" "thiophene,5-di-tert-butyl-" "thiophene,5-bis(1,1-dimethylethyl)-" );
standardThermochemistry
{
    dHf_298   -89810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=180620.0
}
