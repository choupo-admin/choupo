/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-ethyl-4-biphenylamine  (C14H15N, CAS 5728-70-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Ethyl4Biphenylamine;
formula     C14H15N;
CAS         5728-70-1;
InChIKey    NMCSKBJWADPKPK-UHFFFAOYSA-N;
MW          197.281;      // g/mol [origin=calculated method=formula-sum]
Tc          904.06;      // K   [origin=predictive method=joback]
Pc          28.505;      // bar [origin=predictive method=joback]
omega       0.6534;      // -   [origin=predictive method=lee-kesler]
Tb          655.77;      // K   [origin=predictive method=joback]
HvapTb      63275.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.559 1.11892 -0.00070952 1.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-ethylphenyl)aniline" "agn-pc-03gcry" "[1,1'-biphenyl]-4-amine, 4'-ethyl-" );
standardThermochemistry
{
    dHf_298   151620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=339010.0
}
