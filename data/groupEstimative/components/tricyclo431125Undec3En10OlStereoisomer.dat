/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[4.3.1.1(2,5)]undec-3-en-10-ol, stereoisomer  (C11H16O, CAS 70220-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo431125Undec3En10OlStereoisomer;
formula     C11H16O;
CAS         70220-95-0;
InChIKey    XKEDIGAHBBTICC-UHFFFAOYSA-N;
MW          164.248;      // g/mol [origin=calculated method=formula-sum]
Tc          767.68;      // K   [origin=predictive method=joback]
Pc          31.847;      // bar [origin=predictive method=joback]
omega       0.7735;      // -   [origin=predictive method=lee-kesler]
Tb          562.04;      // K   [origin=predictive method=joback]
HvapTb      56516.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-143.13 1.4073 -0.00104928 3.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 5; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 5; } { group dCH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-03d2g1" "tricyclo(4.3.1.12,5)undec-3-en-10-ol, stereoisomer" );
gibbsFormation
{
    dHf_298   -199420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     282.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=77510.0
    phase     gas;
}
