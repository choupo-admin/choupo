/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4,4,4-trifluorobut-2-enoate  (C5H5F3O2, CAS 85694-31-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl444Trifluorobut2Enoate;
formula     C5H5F3O2;
CAS         85694-31-1;
InChIKey    DMMZYYLXAGRBDO-UHFFFAOYSA-N;
MW          154.087;      // g/mol [origin=calculated method=formula-sum]
Tc          536.74;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       0.4399;      // -   [origin=predictive method=lee-kesler]
Tb          370.96;      // K   [origin=predictive method=joback]
HvapTb      30342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.37 0.60522 -0.0004584 1.273e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH=CH; count 1; } { group CF3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH; count 2; } { group F; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4,4,4-tris(fluoranyl)but-2-enoate" "2-butenoic acid, 4,4,4-trifluoro-, methyl ester" "2-butenoic acid, 4,4,4-trifluoro-, methyl ester, (2e)-" "methyl 4,4,4-trifluorocrotonate;4,4,4-trifluorocrotonic acid methyl ester;" );
standardThermochemistry
{
    dHf_298   -943670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     451.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-820520.0
}
