/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-3-pentyn-2-ol  (C6H10O, CAS 590-38-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl3Pentyn2Ol;
formula     C6H10O;
CAS         590-38-5;
InChIKey    JPKQHUHDYLMRJW-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          629.73;      // K   [origin=predictive method=joback]
Pc          43.112;      // bar [origin=predictive method=joback]
omega       0.5530;      // -   [origin=predictive method=lee-kesler]
Tb          434.83;      // K   [origin=predictive method=joback]
HvapTb      46485.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.19 0.58386 -0.00041266 1.2088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpent-3-yn-2-ol" "3-pentyn-2-ol, 2-methyl-" "3-pentyn-2-ol,2-methyl-" "3-pentyn-2-ol, 3-methyl-" "1,1-dimethylbut-2-yn-1-ol;2-methyl-3-pentyn-2-ol; 2-pentyne-4-methyl-4-ol" );
gibbsFormation
{
    dHf_298   -55850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     373.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=68460.0
    phase     gas;
}
