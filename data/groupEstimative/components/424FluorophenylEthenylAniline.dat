/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-[2-(4-fluorophenyl)ethenyl]aniline  (C14H12FN, CAS 10010-36-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        424FluorophenylEthenylAniline;
formula     C14H12FN;
CAS         10010-36-3;
InChIKey    AAVIHGPUAGOTOM-UHFFFAOYSA-N;
MW          213.255;      // g/mol [origin=calculated method=formula-sum]
Tc          905.86;      // K   [origin=predictive method=joback]
Pc          28.719;      // bar [origin=predictive method=joback]
omega       0.6783;      // -   [origin=predictive method=lee-kesler]
Tb          659.20;      // K   [origin=predictive method=joback]
HvapTb      62416.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.65 1.1507 -0.00080972 2.206e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 2; } { group ACNH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group F; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-03emet" "benzenamine,4-[2-(4-fluorophenyl)ethenyl]-" "benzenamine, 4-[2-(4-fluorophenyl)ethenyl]-" "4-stilbenamine,4'-fluoro- (6ci,7ci,8ci); 4'-fluoro-4-stilbenamine" );
standardThermochemistry
{
    dHf_298   72730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     552.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=224420.0
}
