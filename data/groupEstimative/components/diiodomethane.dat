/*--------------------------------*- Choupo -*-----------------------*\
  Component: diiodomethane  (CH2I2, CAS 75-11-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diiodomethane;
formula     CH2I2;
CAS         75-11-6;
InChIKey    NZZFYRREKKOMAT-UHFFFAOYSA-N;
MW          267.827;      // g/mol [origin=calculated method=formula-sum]
Tc          665.40;      // K   [origin=predictive method=joback]
Pc          54.225;      // bar [origin=predictive method=joback]
omega       0.1677;      // -   [origin=predictive method=lee-kesler]
Tb          408.76;      // K   [origin=predictive method=joback]
HvapTb      36566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.361 0.1768 -0.0001934 8.05e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(iodanyl)methane" "methylene iodide" "methane, diiodo-" "methylene diiodide" "mi-gee" "di-iodomethane; methylene iodide" "dijodmethan" "methylenjodid" "diiodo-methane" "qmablzqih@" "k284" "diiodomethane, stabilized with copper chip" );
standardThermochemistry
{
    dHf_298   89770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     306.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=73780.0
}
