/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6,8-dimethylnon-5-en-2-one  (C11H20O, CAS 689-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        68Dimethylnon5En2One;
formula     C11H20O;
CAS         689-39-4;
InChIKey    ALNHSGHECMTZKH-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          694.56;      // K   [origin=predictive method=joback]
Pc          21.714;      // bar [origin=predictive method=joback]
omega       0.5758;      // -   [origin=predictive method=lee-kesler]
Tb          508.75;      // K   [origin=predictive method=joback]
HvapTb      46476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.307 1.04668 -0.0006452 1.5936e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-nonen-2-one, 6,8-dimethyl-" );
standardThermochemistry
{
    dHf_298   -280800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     590.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-17950.0
}
