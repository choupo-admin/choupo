/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl ethyl cyclopentene  (C8H14, CAS 19780-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylEthylCyclopentene;
formula     C8H14;
CAS         19780-56-4;
InChIKey    MMYZGQDXYZNAQW-UHFFFAOYSA-N;
MW          110.2;      // g/mol [origin=calculated method=formula-sum]
Tc          610.10;      // K   [origin=predictive method=joback]
Pc          32.028;      // bar [origin=predictive method=joback]
omega       0.3274;      // -   [origin=predictive method=lee-kesler]
Tb          411.71;      // K   [origin=predictive method=joback]
HvapTb      35584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-34.429 0.74704 -0.0004474 1.061e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 3; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethyl-2-methyl-cyclopentene" "1-ethyl-2-methylcyclopentene" "cyclopentene, 1-ethyl-2-methyl-" "2-methyl-1-ethylcyclopentene" "1-ethyl-2-methyl cyclopentene" "cyclopentene,1-ethyl-2-methyl-" "1-ethyl-2-methylcyclopent-1-ene" );
gibbsFormation
{
    dHf_298   -92790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71440.0
    phase     gas;
}
