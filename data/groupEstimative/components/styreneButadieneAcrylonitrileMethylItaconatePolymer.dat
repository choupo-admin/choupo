/*--------------------------------*- Choupo -*-----------------------*\
  Component: styrene, butadiene, acrylonitrile, methyl itaconate polymer  (C22H27NO4, CAS 115341-09-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        styreneButadieneAcrylonitrileMethylItaconatePolymer;
formula     C22H27NO4;
CAS         115341-09-8;
InChIKey    BLFQPGAETOJGLI-UHFFFAOYSA-N;
MW          369.461;      // g/mol [origin=calculated method=formula-sum]
Tc          1164.17;      // K   [origin=predictive method=joback]
Pc          10.659;      // bar [origin=predictive method=joback]
omega       0.8476;      // -   [origin=predictive method=lee-kesler]
Tb          935.64;      // K   [origin=predictive method=joback]
HvapTb      89746.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (124.611 1.12144 0.0001436 -4.072e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2=CH; count 3; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } { group ACRY; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 5; } { group dCH; count 4; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "buta-1,3-diene;dimethyl 2-methylidenebutanedioate;ethenylbenzene;prop-2-enenitrile" "2-propenenitrile, polymer with 1,3-butadiene, ethenylbenzene and methyl hydrogen 2-methylenebutanedioate" "2-propenenitrile, polymer with 1,3-butadiene, ethenylbenzene and methyl hydrogen methylenebutanedioate" "1,3-butadiene, polymer with ethenylbenzene, methyl hydrogen methylenebutanedioate and 2-propenenitrile" "benzene, ethenyl-, polymer with 1,3-butadiene, methyl hydrogen methylenebutanedioate and 2-propenenitrile" "butanedioic acid, methylene-, methyl ester, polymer with 1,3-butadiene, ethenylbenzene and 2-propenenitrile" );
gibbsFormation
{
    dHf_298   -448060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1311.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-124420.0
    phase     gas;
}
