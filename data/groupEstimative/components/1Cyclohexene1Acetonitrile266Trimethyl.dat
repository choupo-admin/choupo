/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-cyclohexene-1-acetonitrile, 2,6,6-trimethyl-  (C11H17N, CAS 57576-15-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Cyclohexene1Acetonitrile266Trimethyl;
formula     C11H17N;
CAS         57576-15-5;
InChIKey    UYIKUHRHWRRKCH-UHFFFAOYSA-N;
MW          163.264;      // g/mol [origin=calculated method=formula-sum]
Tc          807.15;      // K   [origin=predictive method=joback]
Pc          23.959;      // bar [origin=predictive method=joback]
omega       0.5331;      // -   [origin=predictive method=lee-kesler]
Tb          582.27;      // K   [origin=predictive method=joback]
HvapTb      51452.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.329 1.22266 -0.0010104 3.754e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group CH2CN; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH2_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,6,6-trimethylcyclohexen-1-yl)ethanenitrile" "2,6,6-trimethyl-1-cyclohexene-1-acetonitrile" "2-(2,6,6-trimethylcyclohexen-1-yl)acetonitrile" );
standardThermochemistry
{
    dHf_298   -1090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204580.0
}
