/*--------------------------------*- Choupo -*-----------------------*\
  Component: amides, c16 and c18-unsatd, n,n-bis(hydroxyethyl)  (C22H45NO2, CAS 68155-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        amidesC16AndC18UnsatdNNBisHydroxyethyl;
formula     C22H45NO2;
CAS         68155-08-8;
InChIKey    HJULJDDQIMNLPS-AATRIKPKSA-N;
MW          355.607;      // g/mol [origin=calculated method=formula-sum]
Tc          1115.75;      // K   [origin=predictive method=joback]
Pc          10.433;      // bar [origin=predictive method=joback]
omega       0.9138;      // -   [origin=predictive method=lee-kesler]
Tb          903.92;      // K   [origin=predictive method=joback]
HvapTb      99925.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.401 2.30572 -0.0014302 3.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group CH=CH; count 1; } { group OH; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 19; } { group dCH; count 2; } { group OH; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-hydroxyethyl-[(e)-octadec-13-enyl]amino]ethanol" "(c16 and c18)unsaturated alkylcarboxylic acid, diethanolamide" );
standardThermochemistry
{
    dHf_298   -617120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1124.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=51720.0
}
