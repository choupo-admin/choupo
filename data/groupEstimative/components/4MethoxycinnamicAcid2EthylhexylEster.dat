/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxycinnamic acid 2-ethylhexyl ester  (C18H26O3, CAS 5466-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethoxycinnamicAcid2EthylhexylEster;
formula     C18H26O3;
CAS         5466-77-3;
InChIKey    YBGZDTIWKVFICR-UHFFFAOYSA-N;
MW          290.403;      // g/mol [origin=calculated method=formula-sum]
Tc          926.22;      // K   [origin=predictive method=joback]
Pc          15.000;      // bar [origin=predictive method=joback]
omega       0.8868;      // -   [origin=predictive method=lee-kesler]
Tb          727.46;      // K   [origin=predictive method=joback]
HvapTb      67987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.965 1.48336 -0.00080096 1.386e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl 3-(4-methoxyphenyl)prop-2-enoate" "2-ethylhexyl 4-methoxycinnamate" "2-ethylhexyl-4-methoxycinnamate" "2-ethylhexyl trans-4-methoxycinnamate" "2-propenoicacid, 3-(4-methoxyphenyl)-, 2-ethylhexyl ester, (e)-;" );
standardThermochemistry
{
    dHf_298   -527350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     791.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134130.0
}
