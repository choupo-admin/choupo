  Component: brn 4184260  (C15H22O2, CAS 28399-17-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn4184260;
formula     C15H22O2;
CAS         28399-17-9;
InChIKey    UTXMCYDEIZPGME-VNHYZAJKSA-N;
MW          234.339;      // g/mol [origin=calculated method=formula-sum]
Tc          948.77;      // K   [origin=predictive method=joback]
Pc          22.062;      // bar [origin=predictive method=joback]
omega       0.7863;      // -   [origin=predictive method=lee-kesler]
Tb          715.14;      // K   [origin=predictive method=joback]
HvapTb      65566.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-151.77 1.87284 -0.00154224 5.426e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[(2r,4ar,8ar)-4a,8-dimethyl-2,3,4,5,6,8a-hexahydro-1h-naphthalen-2-yl]prop-2-enoic acid" "eudesma-3,11(13)-dien-12-oic acid" "2-[(2r,4ar,8ar)-4a,8-dimethyl-1,2,3,4,4a,5,6,8a-octahydronaphthalen-2-yl]prop-2-enoic acid" "brd-k88821347-001-01-9" "2-naphthaleneaceticacid, 1,2,3,4,4a,5,6,8a-octahydro-4a,8-dimethyl-a-methylene-, (2r,4ar,8ar)-" "2-naphthaleneaceticacid, 1,2,3,4,4a,5,6,8a-octahydro-4a,8-dimethyl-a-methylene-, [2r-(2a,4aa,8ab)]-; eudesma-3,11(13)-dien-12-oicacid (8ci); a-costicacid" );
standardThermochemistry
{
    dHf_298   -425390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-108970.0
}
