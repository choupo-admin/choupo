/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane-1,2-diol;phthalic acid;prop-2-enoic acid  (C13H16O8, CAS 54066-04-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane12DiolPhthalicAcidProp2EnoicAcid;
formula     C13H16O8;
CAS         54066-04-5;
InChIKey    QFYRUUVGUHEGGS-UHFFFAOYSA-N;
MW          300.263;      // g/mol [origin=calculated method=formula-sum]
Tc          1407.99;      // K   [origin=predictive method=joback]
Pc          29.763;      // bar [origin=predictive method=joback]
omega       1.9463;      // -   [origin=predictive method=lee-kesler]
Tb          1149.07;      // K   [origin=predictive method=joback]
HvapTb      132238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (74.492 0.8884 -0.00011946 -1.693e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 3; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-benzenedicarboxylic acid, polymer with 1,2-ethanediol, 2-propenoate" "ethane-1,2-diol; phthalic acid; prop-2-enoic acid" );
gibbsFormation
{
    dHf_298   -1539670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1021.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1265690.0
    phase     gas;
}
