/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butylcyclopentene  (C9H16, CAS 2423-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butylcyclopentene;
formula     C9H16;
CAS         2423-01-0;
InChIKey    MHIRRFYTMFZXHD-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          624.63;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.3756;      // -   [origin=predictive method=lee-kesler]
Tb          429.61;      // K   [origin=predictive method=joback]
HvapTb      37148.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.637 0.90152 -0.00056884 1.429e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentene, 1-butyl-" "1-butyl-1-cyclopentene;1-butylcyclopentene" );
standardThermochemistry
{
    dHf_298   -101960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=89490.0
}
