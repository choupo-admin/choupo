/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopentyl phenethyl ether  (C13H20O, CAS 56011-02-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopentylPhenethylEther;
formula     C13H20O;
CAS         56011-02-0;
InChIKey    BHQBQWOZHYUVTL-UHFFFAOYSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          744.89;      // K   [origin=predictive method=joback]
Pc          21.755;      // bar [origin=predictive method=joback]
omega       0.5777;      // -   [origin=predictive method=lee-kesler]
Tb          545.70;      // K   [origin=predictive method=joback]
HvapTb      48830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.016 1.10264 -0.0006068 1.137e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-methylbutoxy)ethylbenzene" "anther" "green ether" "isoamyl phenylethyl ether" "2-phenylethyl isopentyl ether" "phenylethyl isoamyl ether" "(2-(3-methylbutoxy)ethyl)benzene" "benzene, (2-(3-methylbutoxy)ethyl)-" "benzene, [2-(3-methylbutoxy)ethyl]-" "bhqbqwozhyuvtl-uhfffaoysa-" "benzene,[2-(3-methylbutoxy)ethyl]-" "2-phenylethylisoamyl ether; anther; anther (ether); isoamyl phenethyl ether; phenylethylisoamyl ether; [2-(3-methylbutoxy)ethyl]benzene" );
gibbsFormation
{
    dHf_298   -212620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=63550.0
    phase     gas;
}
