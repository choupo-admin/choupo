/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tetradecanol, propanoate  (C17H34O2, CAS 6221-95-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TetradecanolPropanoate;
formula     C17H34O2;
CAS         6221-95-0;
InChIKey    YRZGMTHQPGNLEK-UHFFFAOYSA-N;
MW          270.457;      // g/mol [origin=calculated method=formula-sum]
Tc          811.77;      // K   [origin=predictive method=joback]
Pc          12.355;      // bar [origin=predictive method=joback]
omega       0.8795;      // -   [origin=predictive method=lee-kesler]
Tb          646.78;      // K   [origin=predictive method=joback]
HvapTb      60843.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.844 1.56404 -0.0008064 1.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 14; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetradecyl propanoate" "tetradecyl propionate" "myristyl propionate" "1-tetradecanol, 1-propanoate" "propanoic acid, tetradecyl ester" "1-tetradecanol,1-propanoate" "we(14:0/3:0)" "1-tetradecanol,propanoate (9ci);1-tetradecanol, propionate (7ci,8ci);myristyl propionate;tetradecyl propanoate;tetradecyl propionate;n-tetradecyl propionate;" );
gibbsFormation
{
    dHf_298   -711490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     869.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-218110.0
    phase     gas;
}
