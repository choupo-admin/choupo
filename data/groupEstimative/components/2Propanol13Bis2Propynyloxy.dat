/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propanol, 1,3-bis(2-propynyloxy)-  (C9H12O3, CAS 16169-22-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propanol13Bis2Propynyloxy;
formula     C9H12O3;
CAS         16169-22-5;
InChIKey    RKPDVCWTSQFIPR-UHFFFAOYSA-N;
MW          168.192;      // g/mol [origin=calculated method=formula-sum]
Tc          703.91;      // K   [origin=predictive method=joback]
Pc          33.802;      // bar [origin=predictive method=joback]
omega       0.9080;      // -   [origin=predictive method=lee-kesler]
Tb          522.34;      // K   [origin=predictive method=joback]
HvapTb      56455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (76.874 0.5845 -0.00026926 3.238e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2O; count 1; } { group CH_C; count 2; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group tCH; count 2; } { group tC; count 2; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-bis(prop-2-ynoxy)propan-2-ol" "1,3-bis(2-propynyloxy)propan-2-ol" "2-propanol, 1,3-bis(2-propyn-1-yloxy)-" "1,3-dipropargyl glycerol ether" );
gibbsFormation
{
    dHf_298   -67240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121780.0
    phase     gas;
}
