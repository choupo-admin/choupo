/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5,6-trimethylhepta-1,3,6-triene  (C10H16, CAS 42123-66-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        256Trimethylhepta136Triene;
formula     C10H16;
CAS         42123-66-0;
InChIKey    PSZBPDGPFVFTSW-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          613.71;      // K   [origin=predictive method=joback]
Pc          24.411;      // bar [origin=predictive method=joback]
omega       0.3345;      // -   [origin=predictive method=lee-kesler]
Tb          425.24;      // K   [origin=predictive method=joback]
HvapTb      36244.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.43 0.93956 -0.0006576 1.931e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   93490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     511.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=269680.0
    phase     gas;
}
