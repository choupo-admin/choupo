/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-di(1-naphthyl)anthracene  (C34H22, CAS 26979-27-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910Di1NaphthylAnthracene;
formula     C34H22;
CAS         26979-27-1;
InChIKey    GWNJZSGBZMLRBW-UHFFFAOYSA-N;
MW          430.55;      // g/mol [origin=calculated method=formula-sum]
Tc          1448.38;      // K   [origin=predictive method=joback]
Pc          14.977;      // bar [origin=predictive method=joback]
omega       1.0734;      // -   [origin=predictive method=lee-kesler]
Tb          1158.38;      // K   [origin=predictive method=joback]
HvapTb      107976.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-184.01 2.6848 -0.00213108 6.698e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 22; } { group AC; count 12; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 22; } { group dC_ring; count 12; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-dinaphthalen-1-ylanthracene" "9,10-di-(1-naphthyl)anthracene" "9,10-dinaphthylanthracene" "anthracene,10-di-1-naphthyl-" "anthracene,10-di-1-naphthalenyl-" "anthracene, 9,10-di-1-naphthyl-" "9,10-di(naphthalen-1-yl)anthracene" "anthracene,9,10-di-1-naphthalenyl-" "r494" );
gibbsFormation
{
    dHf_298   671430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     694.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=951080.0
    phase     gas;
}
