/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-methyl-1-trimethylsilyl-n-(trimethylsilylmethyl)methanamine  (C9H25NSi2, CAS 69320-67-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C9H25NSi2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nMethyl1TrimethylsilylNTrimethylsilylmethylMethanamine;
formula     C9H25NSi2;
CAS         69320-67-8;
InChIKey    JICBIWIIOAGBJY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          203.476;      // g/mol [origin=calculated method=formula-sum]
Tc          593.87;      // K   [origin=predictive method=joback]
Pc          18.515;      // bar [origin=predictive method=joback]
omega       0.3162;      // -   [origin=predictive method=lee-kesler]
Tb          420.76;      // K   [origin=predictive method=joback]
HvapTb      38259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (65.652 0.57044 0.0002512 -3.011e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH3N; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methanamine, n-methyl-1-(trimethylsilyl)-n-[(trimethylsilyl)methyl]-" "methanamine, n-methyl-1-(trimethylsilyl)-n-((trimethylsilyl)methyl)-" "methanamine,n-methyl-1-(trimethylsilyl)-n-[(trimethylsilyl)methyl]-" );
gibbsFormation
{
    dHf_298   -384800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     775.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73840.0
    phase     gas;
}
