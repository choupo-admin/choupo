/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-2-iodoethane  (C2H4ClI, CAS 624-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro2Iodoethane;
formula     C2H4ClI;
CAS         624-70-4;
InChIKey    JTWWWQGSFTWWDL-UHFFFAOYSA-N;
MW          190.404;      // g/mol [origin=calculated method=formula-sum]
Tc          592.82;      // K   [origin=predictive method=joback]
Pc          46.340;      // bar [origin=predictive method=joback]
omega       0.2210;      // -   [origin=predictive method=lee-kesler]
Tb          375.93;      // K   [origin=predictive method=joback]
HvapTb      33804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.652 0.2396 -0.0001868 6.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2Cl; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Cl; count 1; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-2-iodanyl-ethane" "1,2-chloroiodoethane" "2-chloroethyl iodide" "2-iodoethyl chloride" "jtwwwqgsftwwdl-uhfffaoysa-" "1-chloro-2-iodoethane;2-chloro-1-iodoethane;2-chloroethyl iodide;ethylene iodochloride;" );
gibbsFormation
{
    dHf_298   -23480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     322.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12150.0
    phase     gas;
}
