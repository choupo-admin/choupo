/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-mannitol diacetonide  (C12H22O6, CAS 1707-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dMannitolDiacetonide;
formula     C12H22O6;
CAS         1707-77-3;
InChIKey    ODYBCPSCYHAGHA-ZYUZMQFOSA-N;
MW          262.302;      // g/mol [origin=calculated method=formula-sum]
Tc          992.15;      // K   [origin=predictive method=joback]
Pc          30.123;      // bar [origin=predictive method=joback]
omega       1.5261;      // -   [origin=predictive method=lee-kesler]
Tb          787.14;      // K   [origin=predictive method=joback]
HvapTb      90522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-140.59 2.00588 -0.0018498 7.34e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 2; } { group C; count 2; } { group OH; count 2; } { group CH-O; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 2; } { group OH; count 2; } { group O_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1s,2s)-1,2-bis[(4r)-2,2-dimethyl-1,3-dioxolan-4-yl]ethane-1,2-diol" "1,2:5,6-bis-o-(1-methylethylidene)-d-mannitol" "1,2:5,6-di-o-isopropylidene-d-mannitol" "1,2:5,6-di-o-isopropylidene-d-manitol" "(1s,2s)-1,2-bis[(4r)-2,2-dimethyl-1,3-dioxolan-4-yl]ethane-1,2-diol(non-preferred name)" "diacetone-d-mannitol" "diacetone-d-man" "mannitol diacetonide" "s187" "1,2,5,6-diacetone-d-mannitol" "1,2:5,6-diacetone-d-mannitol" "1,2,5,6-di-o-isopropylidene-d-mannitol" );
standardThermochemistry
{
    dHf_298   -1023270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     454.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-526140.0
}
