/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-hexyl-1,2,3,4-tetrahydronaphthalene  (C16H24, CAS 66325-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Hexyl1234Tetrahydronaphthalene;
formula     C16H24;
CAS         66325-11-9;
InChIKey    XEERAPSBBRYSRL-UHFFFAOYSA-N;
MW          216.368;      // g/mol [origin=calculated method=formula-sum]
Tc          828.60;      // K   [origin=predictive method=joback]
Pc          19.492;      // bar [origin=predictive method=joback]
omega       0.6361;      // -   [origin=predictive method=lee-kesler]
Tb          618.00;      // K   [origin=predictive method=joback]
HvapTb      55204.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.265 1.49372 -0.00097292 2.525e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 3; } { group ACCH2; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-hexyltetralin" "6-hexyl-1,2,3,4-tetrahydro-naphthalene" );
gibbsFormation
{
    dHf_298   -73000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=233350.0
    phase     gas;
}
