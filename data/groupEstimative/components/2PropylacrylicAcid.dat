/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propylacrylic acid  (C6H10O2, CAS 5650-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropylacrylicAcid;
formula     C6H10O2;
CAS         5650-75-9;
InChIKey    HEBDGRTWECSNNT-UHFFFAOYSA-N;
MW          114.144;      // g/mol [origin=calculated method=formula-sum]
Tc          675.63;      // K   [origin=predictive method=joback]
Pc          36.377;      // bar [origin=predictive method=joback]
omega       0.6276;      // -   [origin=predictive method=lee-kesler]
Tb          478.95;      // K   [origin=predictive method=joback]
HvapTb      45524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.648 0.60452 -0.0004004 1.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH2=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylidenepentanoic acid" "2-methylene-pentanoic acid" "2-propylacrylic acid  99;2-propylacrylic acid" );
gibbsFormation
{
    dHf_298   -401800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-264980.0
    phase     gas;
}
