/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-[diethyl(methyl)silyl]propan-1-amine  (C8H21NSi, CAS 13014-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H21NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3DiethylMethylSilylPropan1Amine;
formula     C8H21NSi;
CAS         13014-84-1;
InChIKey    LSSHHSHIJANGKT-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          159.348;      // g/mol [origin=calculated method=formula-sum]
Tc          639.89;      // K   [origin=predictive method=joback]
Pc          23.819;      // bar [origin=predictive method=joback]
omega       0.4684;      // -   [origin=predictive method=lee-kesler]
Tb          456.57;      // K   [origin=predictive method=joback]
HvapTb      44337.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.925 0.61956 -4e-05 -1.222e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH2NH2; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "aminopropyldiethylmethylsilane" "1-propanamine, 3-(diethylmethylsilyl)-" "3-(diethylmethylsilyl)propylamine" "(3-aminopropyl)diethylmethylsilane" "propylamine, 3-(diethylmethylsilyl)-" "silane, (3-aminopropyl)diethylmethyl-" );
gibbsFormation
{
    dHf_298   -286280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21830.0
    phase     gas;
}
