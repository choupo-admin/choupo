/*--------------------------------*- Choupo -*-----------------------*\
  Component: (24r)-24,25-dihydroxyvitamin d3  (C27H44O3, CAS 55721-11-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24r2425DihydroxyvitaminD3;
formula     C27H44O3;
CAS         55721-11-4;
InChIKey    FCKJYANJHNLEEP-SUUCIXNTSA-N;
MW          416.646;      // g/mol [origin=calculated method=formula-sum]
Tc          1409.66;      // K   [origin=predictive method=joback]
Pc          12.140;      // bar [origin=predictive method=joback]
omega       1.0618;      // -   [origin=predictive method=lee-kesler]
Tb          1143.64;      // K   [origin=predictive method=joback]
HvapTb      124705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-214.638 3.19648 -0.0024184 7.714e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 5; } { group C; count 2; } { group CH2=C; count 1; } { group CH=C; count 2; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dC_ring; count 3; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,6r)-6-[(1r,3as,7ar)-7a-methyl-4-[2-[(5s)-2-methylidene-5-oxidanyl-cyclohexylidene]ethylidene]-2,3,3a,5,6,7-hexahydro-1h-inden-1-yl]-2-methyl-heptane-2,3-diol" "(3r,6r)-6-[(1r,3as,7ar)-4-[2-[(5s)-5-hydroxy-2-methylidenecyclohexylidene]ethylidene]-7a-methyl-2,3,3a,5,6,7-hexahydro-1h-inden-1-yl]-2-methylheptane-2,3-diol" );
standardThermochemistry
{
    dHf_298   -663970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1095.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=4410.0
}
