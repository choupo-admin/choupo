/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dibromooctane  (C8H16Br2, CAS 62168-26-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dibromooctane;
formula     C8H16Br2;
CAS         62168-26-7;
InChIKey    STBMZSJLFYGOJU-UHFFFAOYSA-N;
MW          272.024;      // g/mol [origin=calculated method=formula-sum]
Tc          715.15;      // K   [origin=predictive method=joback]
Pc          29.537;      // bar [origin=predictive method=joback]
omega       0.6194;      // -   [origin=predictive method=lee-kesler]
Tb          514.52;      // K   [origin=predictive method=joback]
HvapTb      45884.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.316 0.84612 -0.0005574 1.517e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group CH; count 1; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(bromanyl)octane" "octane, dibromo-" );
standardThermochemistry
{
    dHf_298   -161070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     560.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42680.0
}
