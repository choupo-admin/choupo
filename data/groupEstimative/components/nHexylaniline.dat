/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-hexylaniline  (C12H19N, CAS 4746-32-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nHexylaniline;
formula     C12H19N;
CAS         4746-32-1;
InChIKey    OXHJCNSXYDSOFN-UHFFFAOYSA-N;
MW          177.291;      // g/mol [origin=calculated method=formula-sum]
Tc          751.49;      // K   [origin=predictive method=joback]
Pc          24.362;      // bar [origin=predictive method=joback]
omega       0.6430;      // -   [origin=predictive method=lee-kesler]
Tb          551.01;      // K   [origin=predictive method=joback]
HvapTb      51018.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.135 1.14112 -0.0007088 1.676e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexyl-phenyl-amine" );
gibbsFormation
{
    dHf_298   -1010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251960.0
    phase     gas;
}
