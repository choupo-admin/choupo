/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3s)-4-cyclohexyl-3-(methoxycarbonyl)butanoic acid  (C12H20O4, CAS 220497-69-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3s4Cyclohexyl3MethoxycarbonylButanoicAcid;
formula     C12H20O4;
CAS         220497-69-8;
InChIKey    TYYNOKUMAOAVBK-JTQLQIEISA-N;
MW          228.288;      // g/mol [origin=calculated method=formula-sum]
Tc          909.60;      // K   [origin=predictive method=joback]
Pc          23.496;      // bar [origin=predictive method=joback]
omega       0.9652;      // -   [origin=predictive method=lee-kesler]
Tb          697.00;      // K   [origin=predictive method=joback]
HvapTb      66918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.298 1.26782 -0.0006912 1.116e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 2; } { group COOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s)-3-(cyclohexylmethyl)-4-methoxy-4-oxidanylidene-butanoic acid" "(s)-4-methoxy-3-cyclohexylmethyl-4-oxobutanoic acid" "butanedioic acid,2-(cyclohexylmethyl)-, 1-methyl ester, (2s)-" "butanedioicacid, (cyclohexylmethyl)-, 1-methyl ester, (2s)- (9ci);(s)-2-(cyclohexylmethyl)succinic acid-1-methyl ester;" );
standardThermochemistry
{
    dHf_298   -909520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-582110.0
}
