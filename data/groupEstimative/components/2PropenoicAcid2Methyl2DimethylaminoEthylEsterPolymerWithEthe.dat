/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-methyl-, 2-(dimethylamino)ethyl ester, polymer with ethenyl acetate  (C12H21NO4, CAS 53489-11-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2Methyl2DimethylaminoEthylEsterPolymerWithEthe;
formula     C12H21NO4;
CAS         53489-11-5;
InChIKey    JSKZWVSFDCNZJJ-UHFFFAOYSA-N;
MW          243.303;      // g/mol [origin=calculated method=formula-sum]
Tc          781.46;      // K   [origin=predictive method=joback]
Pc          17.939;      // bar [origin=predictive method=joback]
omega       0.7750;      // -   [origin=predictive method=lee-kesler]
Tb          597.68;      // K   [origin=predictive method=joback]
HvapTb      58197.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (67.252 0.91188 -0.0001857 -1.258e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH3COO; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dimethylamino)ethyl 2-methylprop-2-enoate;ethenyl ethanoate" "2-dimethylaminoethyl 2-methylprop-2-enoate; ethenyl acetate" "ethenyl acetate, polymer with 2-methyl-2-propenoic acid, 2-(dimethylamino)ethyl ester" );
standardThermochemistry
{
    dHf_298   -728590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     836.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397430.0
}
