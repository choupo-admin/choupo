/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-bis(2-hydroxyethoxy)benzene  (C10H14O4, CAS 10234-40-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bis2HydroxyethoxyBenzene;
formula     C10H14O4;
CAS         10234-40-9;
InChIKey    JWTDCPGVNRBTKT-UHFFFAOYSA-N;
MW          198.218;      // g/mol [origin=calculated method=formula-sum]
Tc          872.47;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       1.5646;      // -   [origin=predictive method=lee-kesler]
Tb          689.26;      // K   [origin=predictive method=joback]
HvapTb      78970.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.774 0.757 -0.00032316 1.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 2; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-hydroxyethyloxy)phenoxy]ethanol" "2,2'-(1,2-phenylenebis(oxy))diethanol" "2,2'-(o-phenylenedioxy)diethanol" "2-[2-(2-hydroxyethoxy)phenoxy]ethanol" "2-[2-(2-hydroxyethoxy)phenoxy]ethan-1-ol" "ethanol,2,2'-[1,2-phenylenebis(oxy)]bis-" "2,2'-(1,2-phenylenedioxy)diethanol" "2,2 inverted exclamation marka-(o-phenylenedioxy)diethanol" "ethanol,2,2'-(o-phenylenedioxy)di- (7ci,8ci);1,2-bis(2-hydroxyethoxy)benzene;2,2'-(1,2-phenylenedioxy)diethanol;2,2'-[1,2-phenylenebis(oxy)]bis[ethanol];catechol bis(2-hydroxyethyl) ether;o-bis(2-hydroxyethoxy)benzene;" );
standardThermochemistry
{
    dHf_298   -593570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     557.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-347540.0
}
