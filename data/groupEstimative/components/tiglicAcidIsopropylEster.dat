/*--------------------------------*- Choupo -*-----------------------*\
  Component: tiglic acid isopropyl ester  (C8H14O2, CAS 25859-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tiglicAcidIsopropylEster;
formula     C8H14O2;
CAS         25859-51-2;
InChIKey    QQVQBUXUAZCLLZ-UHFFFAOYSA-N;
MW          142.198;      // g/mol [origin=calculated method=formula-sum]
Tc          632.02;      // K   [origin=predictive method=joback]
Pc          27.240;      // bar [origin=predictive method=joback]
omega       0.4529;      // -   [origin=predictive method=lee-kesler]
Tb          444.46;      // K   [origin=predictive method=joback]
HvapTb      40459.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.47 0.73488 -0.0004061 7.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl 3-methylbut-2-enoate" "isopropyl 2-methylcrotonate" "isopropyl alpha-methylcrotonate" "isopropyl 2-methyl-2-butenoate" "isopropyl alpha-methyl crotonate" "(e)-1-methylethyl 2-methyl-2-butenoate" "3-methyl,2-butenoic acid,isopropyl ester" "1-methylethyl 2-methyl-2-butenoate, (e)-" "2-butenoic acid, 2-methyl-, 1-isopropyl ester, (e)-" "2-butenoic acid, 2-methyl-, 1-methylethyl ester, (2e)-" "isopropyltiglate" "isopropyl 3-methylbut-2-enoate" );
gibbsFormation
{
    dHf_298   -423580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     498.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224660.0
    phase     gas;
}
