/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(hexyloxy)ethanol  (C8H18O2, CAS 112-25-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2HexyloxyEthanol;
formula     C8H18O2;
CAS         112-25-4;
InChIKey    UPGSWASWQBLSKZ-UHFFFAOYSA-N;
MW          146.23;      // g/mol [origin=calculated method=formula-sum]
Tc          657.13;      // K   [origin=predictive method=joback]
Pc          27.383;      // bar [origin=predictive method=joback]
omega       0.9488;      // -   [origin=predictive method=lee-kesler]
Tb          497.24;      // K   [origin=predictive method=joback]
HvapTb      52491.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.407 0.73462 -0.0003308 3.9e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexoxyethanol" "ethanol, 2-(hexyloxy)-" "n-hexyl cellosolve" "ethylene glycol monohexyl ether" "2-hexyloxyethanol" "hexyl cellosolve" "glycol monohexyl ether" "cellosolve, n-hexyl-" "ethanol, 2-hexyloxy-" "ethylene glycol n-hexyl ether" "ethylene glycol-n-monohexyl ether" "2-hexyloxyethan-1-ol" );
standardThermochemistry
{
    dHf_298   -492900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-225340.0
}
