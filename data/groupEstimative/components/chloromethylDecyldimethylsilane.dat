/*--------------------------------*- Choupo -*-----------------------*\
  Component: (chloromethyl)decyldimethylsilane  (C13H29ClSi, CAS 70715-16-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H29ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        chloromethylDecyldimethylsilane;
formula     C13H29ClSi;
CAS         70715-16-1;
InChIKey    ZJQQABUOLGYXCA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.91;      // g/mol [origin=calculated method=formula-sum]
Tc          706.14;      // K   [origin=predictive method=joback]
Pc          14.535;      // bar [origin=predictive method=joback]
omega       0.5832;      // -   [origin=predictive method=lee-kesler]
Tb          535.87;      // K   [origin=predictive method=joback]
HvapTb      49211.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.78 1.03946 -0.000289 -6.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 9; } { group CH2Cl; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 10; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chloromethyl-decyl-dimethyl-silane" "(chloromethyl)(decyl)dimethylsilane" "silane, (chloromethyl)decyldimethyl-" "chloromethyl-decyl-dimethylsilane" "silane,(chloromethyl)decyldimethyl-" );
gibbsFormation
{
    dHf_298   -439010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     822.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-58110.0
    phase     gas;
}
