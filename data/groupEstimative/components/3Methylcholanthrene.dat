/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylcholanthrene  (C21H16, CAS 56-49-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methylcholanthrene;
formula     C21H16;
CAS         56-49-5;
InChIKey    PPQNQXQZIWHJRB-UHFFFAOYSA-N;
MW          268.359;      // g/mol [origin=calculated method=formula-sum]
Tc          1052.09;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.8274;      // -   [origin=predictive method=lee-kesler]
Tb          795.74;      // K   [origin=predictive method=joback]
HvapTb      72896.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.0 1.79832 -0.00154676 5.404e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 6; } { group ACCH3; count 1; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-1,2-dihydrobenzo[j]aceanthrylene" "methylcholanthrene" "20-methylcholanthrene" "3-methylchloanthrene" "3-mca" "3-methoxycholanthrene" "cholanthrene, 3-methyl-" "benz[j]aceanthrylene, 1,2-dihydro-3-methyl-" "1,2-dihydro-3-methylbenz(j)aceanthrylene" "3-methyl-1,2-dihydrocyclopenta[ij]tetraphene" "3-meca" "3-methylbenz(j)aceanthrene" );
standardThermochemistry
{
    dHf_298   374920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=590710.0
}
