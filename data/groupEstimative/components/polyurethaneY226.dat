/*--------------------------------*- Choupo -*-----------------------*\
  Component: polyurethane y-226  (C28H42N4O4, CAS 56386-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polyurethaneY226;
formula     C28H42N4O4;
CAS         56386-98-2;
InChIKey    QNFGVTNUSXDWEW-UHFFFAOYSA-N;
MW          498.668;      // g/mol [origin=calculated method=formula-sum]
Tc          1550.85;      // K   [origin=predictive method=joback]
Pc          11.437;      // bar [origin=predictive method=joback]
omega       1.0834;      // -   [origin=predictive method=lee-kesler]
Tb          1266.01;      // K   [origin=predictive method=joback]
HvapTb      130669.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 13; } { group CH; count 4; } { group ACH; count 3; } { group ACCH3; count 1; } { group CH2COO; count 1; } { group ACNH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCd; count 2; } { group CH2_ring; count 13; } { group CH_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COO; count 1; } { group dO_oth; count 2; } { group NH2; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane;2-methylbenzene-1,4-diamine;oxepan-2-one" "1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane; 2-methylbenzene-1,4-diamine; oxepan-2-one" );
