/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methylbenzyl chloride  (C8H9Cl, CAS 620-19-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3MethylbenzylChloride;
formula     C8H9Cl;
CAS         620-19-9;
InChIKey    LZBOHNCMCCSTJX-UHFFFAOYSA-N;
MW          140.61;      // g/mol [origin=calculated method=formula-sum]
Tc          670.00;      // K   [origin=predictive method=joback]
Pc          34.319;      // bar [origin=predictive method=joback]
omega       0.3496;      // -   [origin=predictive method=lee-kesler]
Tb          451.73;      // K   [origin=predictive method=joback]
HvapTb      40725.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.099 0.63222 -0.00039596 9.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH3; count 1; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(chloromethyl)-3-methyl-benzene" "1-(chloromethyl)-3-methylbenzene" "m-xylyl chloride" "alpha-chloro-m-xylene" "m-methylbenzyl chloride" "m-xylene, .alpha.-chloro-" "m-(chloromethyl)toluene" "3-(chloromethyl)toluene" "benzene, 1-(chloromethyl)-3-methyl-" "m-xylyl-alpha-chloride" ".alpha.-chloro-m-xylene" "a-chloro-m-xylene" );
standardThermochemistry
{
    dHf_298   870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=107330.0
}
