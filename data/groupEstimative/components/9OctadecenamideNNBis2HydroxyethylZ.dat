/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-octadecenamide, n,n-bis(2-hydroxyethyl)-, (z)-  (C22H43NO3, CAS 93-83-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9OctadecenamideNNBis2HydroxyethylZ;
formula     C22H43NO3;
CAS         93-83-4;
InChIKey    LPMBTLLQQJBUOO-KTKRTIGZSA-N;
MW          369.59;      // g/mol [origin=calculated method=formula-sum]
Tc          1187.34;      // K   [origin=predictive method=joback]
Pc          10.871;      // bar [origin=predictive method=joback]
omega       0.9025;      // -   [origin=predictive method=lee-kesler]
Tb          957.79;      // K   [origin=predictive method=joback]
HvapTb      106671.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.042 2.27772 -0.0014115 3.4596e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH=CH; count 1; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH; count 2; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(z)-n,n-bis(2-hydroxyethyl)octadec-9-enamide" "oleic diethanolamide" "(9z)-n,n-bis(2-hydroxyethyl)octadec-9-enamide" "oleic acid diethanolamine condensate" "9-octadecenamide, n,n-bis(2-hydroxyethyl)-, (9z)-" );
gibbsFormation
{
    dHf_298   -729700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1150.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77200.0
    phase     gas;
}
