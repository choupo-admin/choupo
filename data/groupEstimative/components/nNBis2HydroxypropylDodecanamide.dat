/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-bis(2-hydroxypropyl)dodecanamide  (C18H37NO3, CAS 54914-38-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNBis2HydroxypropylDodecanamide;
formula     C18H37NO3;
CAS         54914-38-4;
InChIKey    ITQLLPIWYFCLTO-UHFFFAOYSA-N;
MW          315.498;      // g/mol [origin=calculated method=formula-sum]
Tc          1055.04;      // K   [origin=predictive method=joback]
Pc          13.871;      // bar [origin=predictive method=joback]
omega       1.2579;      // -   [origin=predictive method=lee-kesler]
Tb          861.23;      // K   [origin=predictive method=joback]
HvapTb      97033.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.588 1.88956 -0.0011165 2.4996e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 2; } { group OH; count 2; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 12; } { group CH; count 2; } { group OH; count 2; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-bis(2-oxidanylpropyl)dodecanamide" "dodecanamide, n,n-bis(2-hydroxypropyl)-" "lauric diisopropanolamide" );
gibbsFormation
{
    dHf_298   -774920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     982.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-195980.0
    phase     gas;
}
