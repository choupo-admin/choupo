/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexane, 2,3,4,5-tetramethyl-  (C10H22, CAS 52897-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexane2345Tetramethyl;
formula     C10H22;
CAS         52897-15-1;
InChIKey    BHGNYYIOYPFWKC-UHFFFAOYSA-N;
MW          142.286;      // g/mol [origin=calculated method=formula-sum]
Tc          603.98;      // K   [origin=predictive method=joback]
Pc          21.714;      // bar [origin=predictive method=joback]
omega       0.3741;      // -   [origin=predictive method=lee-kesler]
Tb          426.64;      // K   [origin=predictive method=joback]
HvapTb      36302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.93 0.97752 -0.000533 1.058e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,4,5-tetramethylhexane" "agn-pc-0cm7u1" );
standardThermochemistry
{
    dHf_298   -270850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=23560.0
}
