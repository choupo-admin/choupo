/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexadecamethylheptasiloxane  (C16H48O6Si7, CAS 541-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H48O6Si7 (delta Si+7; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexadecamethylheptasiloxane;
formula     C16H48O6Si7;
CAS         541-01-5;
InChIKey    NFVSFLUJRHRSJG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          533.149;      // g/mol [origin=calculated method=formula-sum]
Tc          895.97;      // K   [origin=predictive method=joback]
Pc          7.320;      // bar [origin=predictive method=joback]
omega       0.4246;      // -   [origin=predictive method=lee-kesler]
Tb          710.00;      // K   [origin=predictive method=joback]
HvapTb      67728.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (427.07 -0.29848 0.002723 -1.67e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 16; } { group Si; count 1; } { group SiO; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 16; } { group O; count 6; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis[[[dimethyl(trimethylsilyloxy)silyl]oxy-dimethylsilyl]oxy]-dimethylsilane" "1,1,1,3,3,5,5,7,7,9,9,11,11,13,13,13-hexadecamethylheptasiloxane" "heptasiloxane, 1,1,1,3,3,5,5,7,7,9,9,11,11,13,13,13-hexadecamethyl-" "heptasiloxane, hexadecamethyl-" "hexadecamethyl heptasiloxane" "heptasiloxane, hexadecamethyl" "C16H48O6Si7" "hexadecamethylheptasiloxane basic information" "ds-19609" "DB-254913" "CS-0186278" "NS00043171" );
standardThermochemistry
{
    dHf_298   -1948230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1732.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1279480.0
}
