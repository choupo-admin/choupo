/*--------------------------------*- Choupo -*-----------------------*\
  Component: metaraminol  (C9H13NO2, CAS 54-49-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        metaraminol;
formula     C9H13NO2;
CAS         54-49-9;
InChIKey    WXFIGDLSSYIKKV-RCOVLWMOSA-N;
MW          167.208;      // g/mol [origin=calculated method=formula-sum]
Tc          898.12;      // K   [origin=predictive method=joback]
Pc          48.427;      // bar [origin=predictive method=joback]
omega       1.2518;      // -   [origin=predictive method=lee-kesler]
Tb          676.65;      // K   [origin=predictive method=joback]
HvapTb      77462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.7 1.04222 -0.00083356 2.743e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group OH_phenol; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(1r,2s)-2-azanyl-1-oxidanyl-propyl]phenol" "pressonex" "l-metaraminol" "hydroxynorephedrine" "m-hydroxypropadrine" "metaraminolum" "metaradrine" "pressorol" "1-metaraminol" "m-hydroxy norephedrine" "icoral b" "m-hydroxynorephedrine" );
gibbsFormation
{
    dHf_298   -298870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-92560.0
    phase     gas;
}
