/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-trimethylanisole  (C10H14O, CAS 4028-66-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Trimethylanisole;
formula     C10H14O;
CAS         4028-66-4;
InChIKey    NNVKEOMPDSKFGZ-UHFFFAOYSA-N;
MW          150.221;      // g/mol [origin=calculated method=formula-sum]
Tc          699.38;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.4626;      // -   [origin=predictive method=lee-kesler]
Tb          492.44;      // K   [origin=predictive method=joback]
HvapTb      44526.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.29 0.63328 -0.00023928 3.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxy-1,3,5-trimethyl-benzene" "mesityl methyl ether" "benzene, 2-methoxy-1,3,5-trimethyl-" "anisole, 2,4,6-trimethyl-" "2-methoxy-1,3,5-trimethylbenzene" "2-methoxymesitylene" "methyl 2,4,6-trimethylphenyl ether" "benzene,1-methoxy-2,3,5-trimethyl-" );
standardThermochemistry
{
    dHf_298   -179830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.87;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11840.0
}
