/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tert-butyl-4-isopropylbenzene  (C13H20, CAS 4132-49-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1TertButyl4Isopropylbenzene;
formula     C13H20;
CAS         4132-49-4;
InChIKey    QLPNXSSDHYYKBS-UHFFFAOYSA-N;
MW          176.303;      // g/mol [origin=calculated method=formula-sum]
Tc          739.95;      // K   [origin=predictive method=joback]
Pc          22.187;      // bar [origin=predictive method=joback]
omega       0.4062;      // -   [origin=predictive method=lee-kesler]
Tb          525.03;      // K   [origin=predictive method=joback]
HvapTb      45786.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.69 1.2322 -0.00082256 2.155e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-tert-butyl-4-propan-2-yl-benzene" "1-tert-butyl-4-propan-2-ylbenzene" "1-tert-butyl-4-(propan-2-yl)benzene" "benzene, 1-(1,1-dimethylethyl)-4-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   -100620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=161760.0
    phase     gas;
}
