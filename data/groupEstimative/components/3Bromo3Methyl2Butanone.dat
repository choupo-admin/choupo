/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-3-methyl-2-butanone  (C5H9BrO, CAS 2648-71-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo3Methyl2Butanone;
formula     C5H9BrO;
CAS         2648-71-7;
InChIKey    XHCWDDGZFBAXRT-UHFFFAOYSA-N;
MW          165.03;      // g/mol [origin=calculated method=formula-sum]
Tc          642.29;      // K   [origin=predictive method=joback]
Pc          41.785;      // bar [origin=predictive method=joback]
omega       0.4002;      // -   [origin=predictive method=lee-kesler]
Tb          430.80;      // K   [origin=predictive method=joback]
HvapTb      38609.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.58 0.61486 -0.0004727 1.4526e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH3CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-3-methyl-butan-2-one" "(ch3)2cbrcoch3" "3-bromo-3-methylbutan-2-one" "2-butanone,3-bromo-3-methyl-" "2-butanone, 3-bromo-3-methyl-" "1-bromo-1-methylethyl methyl ketone" );
gibbsFormation
{
    dHf_298   -241530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-120540.0
    phase     gas;
}
