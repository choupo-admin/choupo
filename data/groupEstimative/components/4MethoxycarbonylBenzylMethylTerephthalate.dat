/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(methoxycarbonyl)benzyl methyl terephthalate  (C18H16O6, CAS 55334-51-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4MethoxycarbonylBenzylMethylTerephthalate;
formula     C18H16O6;
CAS         55334-51-5;
InChIKey    ITTJRGPCQAAFGL-UHFFFAOYSA-N;
MW          328.32;      // g/mol [origin=calculated method=formula-sum]
Tc          1077.29;      // K   [origin=predictive method=joback]
Pc          18.920;      // bar [origin=predictive method=joback]
omega       1.0983;      // -   [origin=predictive method=lee-kesler]
Tb          849.42;      // K   [origin=predictive method=joback]
HvapTb      83759.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.541 1.27264 -0.00059992 3.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o4-[(4-methoxycarbonylphenyl)methyl] o1-methyl benzene-1,4-dicarboxylate" "1,4-benzenedicarboxylic acid, [4-(methoxycarbonyl)phenyl]methyl methyl ester" "methyl [4-(methoxycarbonyl)phenyl]methyl 1,4-benzenedicarboxylate" "methyl (4-(methoxycarbonyl)phenyl)methyl terephthalate" "methyl [4-(methoxycarbonyl)phenyl]methyl terephthalate" "methyl (4-(methoxycarbonyl)phenyl)methyl 1,4-benzenedicarboxylate" "1,4-benzenedicarboxylic acid, (4-(methoxycarbonyl)phenyl)methyl methyl ester" "1,4-benzenedicarboxylic acid, 1-((4-(methoxycarbonyl)phenyl)methyl) 4-methyl ester" "1,4-benzenedicarboxylic acid, 1-[[4-(methoxycarbonyl)phenyl]methyl] 4-methyl ester" "(4-(methoxycarbonyl)phenyl)methyl methyl terephthalate" "4-(methoxycarbonyl)benzyl methyl benzene-1,4-dicarboxylate" "4-o-[(4-methoxycarbonylphenyl)methyl] 1-o-methyl benzene-1,4-dicarboxylate" );
standardThermochemistry
{
    dHf_298   -916570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     785.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-624870.0
}
