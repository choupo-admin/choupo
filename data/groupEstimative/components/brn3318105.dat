/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 3318105  (C19H14S, CAS 63018-59-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn3318105;
formula     C19H14S;
CAS         63018-59-7;
InChIKey    RTKQFAVQPMAHIH-UHFFFAOYSA-N;
MW          274.381;      // g/mol [origin=calculated method=formula-sum]
Tc          1069.83;      // K   [origin=predictive method=joback]
Pc          26.111;      // bar [origin=predictive method=joback]
omega       0.7818;      // -   [origin=predictive method=lee-kesler]
Tb          795.74;      // K   [origin=predictive method=joback]
HvapTb      73807.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.829 1.5676 -0.00127244 4.146e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 11; } { group AC; count 7; } { group CH2SH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 11; } { group dC_ring; count 7; } { group SH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo[a]anthracen-7-ylmethanethiol" "benz(a)anthracene-7-methanethiol" "tetraphen-7-ylmethanethiol" "benzo[b]phenanthren-7-yl-methanethiol" );
gibbsFormation
{
    dHf_298   378320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     507.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=541960.0
    phase     gas;
}
