/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-morpholino-5-trifluoromethylaniline  (C11H13F3N2O, CAS 784-57-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Morpholino5Trifluoromethylaniline;
formula     C11H13F3N2O;
CAS         784-57-6;
InChIKey    CNVOJNRNRNAOOP-UHFFFAOYSA-N;
MW          246.232;      // g/mol [origin=calculated method=formula-sum]
Tc          834.57;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.7790;      // -   [origin=predictive method=lee-kesler]
Tb          614.37;      // K   [origin=predictive method=joback]
HvapTb      57693.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.92 1.3531 -0.00101762 2.915e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 3; } { group AC; count 2; } { group FCH2O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group O_ring; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-morpholin-4-yl-5-(trifluoromethyl)aniline" "3-amino-4-(4-morpholino)benzotrifluoride" "2-morpholino-5-(trifluoromethyl)aniline" "2-(4-morpholinyl)-5-(trifluoromethyl)aniline" "n-(2-amino-4-trifluoromethylphenyl)morpholine" "2-(morpholin-4-yl)-5-(trifluoromethyl)aniline" "2-morpholin-4-yl-5-trifluoromethyl-phenylamine" "n-[2-amino-4-(trifluoromethyl)phenyl]-morpholine" "2-morpholin-4-yl-5-(trifluoromethyl)phenylamine" "n-(2-amino-4-(trifluoromethyl)phenyl)morpholine" "n-[2-amino-4-(trifluoromethyl)phenyl]morpholine" "3-amino-4-(morpholino)benzotrifluoride" );
standardThermochemistry
{
    dHf_298   -603720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-311330.0
}
