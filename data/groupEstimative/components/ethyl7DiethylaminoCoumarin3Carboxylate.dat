/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 7-diethylamino-coumarin-3-carboxylate  (C16H19NO4, CAS 28705-46-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl7DiethylaminoCoumarin3Carboxylate;
formula     C16H19NO4;
CAS         28705-46-6;
InChIKey    MSOLGAJLRIINNF-UHFFFAOYSA-N;
MW          289.331;      // g/mol [origin=calculated method=formula-sum]
Tc          946.72;      // K   [origin=predictive method=joback]
Pc          19.136;      // bar [origin=predictive method=joback]
omega       1.0500;      // -   [origin=predictive method=lee-kesler]
Tb          742.48;      // K   [origin=predictive method=joback]
HvapTb      72671.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.817 1.41176 -0.00090936 2.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 3; } { group AC; count 3; } { group CH2N; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 7-(diethylamino)-2-oxidanylidene-chromene-3-carboxylate" "ethyl 7-(diethylamino)coumarin-3-carboxylate" "ethyl 7-(diethylamino)-2-oxo-2h-chromene-3-carboxylate" "ethyl 7-(diethylamino)-2-oxochromene-3-carboxylate" "2h-1-benzopyran-3-carboxylic acid, 7-(diethylamino)-2-oxo-, ethyl ester" "7-(diethylamino)coumarin-3-carboxylic acid ethyl ester" "2h-1-benzopyran-3-carboxylicacid, 7-(diethylamino)-2-oxo-, ethyl ester" );
gibbsFormation
{
    dHf_298   -581400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     667.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-232080.0
    phase     gas;
}
