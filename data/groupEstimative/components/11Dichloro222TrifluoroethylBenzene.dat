/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,1-dichloro-2,2,2-trifluoroethyl)benzene  (C8H5Cl2F3, CAS 309-10-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloro222TrifluoroethylBenzene;
formula     C8H5Cl2F3;
CAS         309-10-4;
InChIKey    VCGJIIDFWDVVQE-UHFFFAOYSA-N;
MW          229.022;      // g/mol [origin=calculated method=formula-sum]
Tc          691.61;      // K   [origin=predictive method=joback]
Pc          29.992;      // bar [origin=predictive method=joback]
omega       0.3839;      // -   [origin=predictive method=lee-kesler]
Tb          475.53;      // K   [origin=predictive method=joback]
HvapTb      39405.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.18 0.9855 -0.0008762 2.881e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CCl2; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group F; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[1,1-bis(chloranyl)-2,2,2-tris(fluoranyl)ethyl]benzene" "benzene, (1,1-dichloro-2,2,2-trifluoroethyl)-" );
standardThermochemistry
{
    dHf_298   -609230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     445.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-473720.0
}
