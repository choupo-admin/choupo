/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-methyl-1,2,4,5,6,7,8,9-octahydrobenzo[8]annulene-3,10-dione  (C13H18O2, CAS 24569-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Methyl12456789Octahydrobenzo8Annulene310Dione;
formula     C13H18O2;
CAS         24569-29-7;
InChIKey    JXNLDAYITIUFSC-UHFFFAOYSA-N;
MW          206.285;      // g/mol [origin=calculated method=formula-sum]
Tc          943.89;      // K   [origin=predictive method=joback]
Pc          26.380;      // bar [origin=predictive method=joback]
omega       0.6228;      // -   [origin=predictive method=lee-kesler]
Tb          685.57;      // K   [origin=predictive method=joback]
HvapTb      55809.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.84 0.99792 -0.000266 -8.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2CO; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 7; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group CdO_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzocyclooctene-1,8(2h),(7h)-dione, 3,4,5,6,9,10-hexahydro-4- methyl-," );
standardThermochemistry
{
    dHf_298   -423230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-119290.0
}
