/*--------------------------------*- Choupo -*-----------------------*\
  Component: koolizer 1  (C10H24N2, CAS 111-18-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        koolizer1;
formula     C10H24N2;
CAS         111-18-2;
InChIKey    TXXWBTOATXBWDR-UHFFFAOYSA-N;
MW          172.316;      // g/mol [origin=calculated method=formula-sum]
Tc          613.35;      // K   [origin=predictive method=joback]
Pc          21.003;      // bar [origin=predictive method=joback]
omega       0.6155;      // -   [origin=predictive method=lee-kesler]
Tb          453.28;      // K   [origin=predictive method=joback]
HvapTb      41940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.584 1.20168 -0.0007454 1.826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n,n',n'-tetramethylhexane-1,6-diamine" "n,n,n',n'-tetramethyl-1,6-hexanediamine" "1,6-bis(dimethylamino)hexane" "hexamethylenebis(dimethylamine)" "toyocat mr" "minico tmhd" "n,n,n',n`-tetramethylhexanediamine" "u 1000 (amine)" "1,6-hexanediamine, n,n,n',n'-tetramethyl-" "n,n,n',n'-tetramethylhexamethylenediamine" "n,n,n',n'-tetramethyl-1,6-diaminohexane" "n,n,n',n'-tetramethylhexamethylene diamine" );
standardThermochemistry
{
    dHf_298   -114670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     577.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=254880.0
}
