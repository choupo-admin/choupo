/*--------------------------------*- Choupo -*-----------------------*\
  Component: itaconic-acrylic acid copolymer  (C8H10O6, CAS 25948-33-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        itaconicAcrylicAcidCopolymer;
formula     C8H10O6;
CAS         25948-33-8;
InChIKey    ABPJHHHWWYDYFZ-UHFFFAOYSA-N;
MW          202.162;      // g/mol [origin=calculated method=formula-sum]
Tc          1037.06;      // K   [origin=predictive method=joback]
Pc          33.881;      // bar [origin=predictive method=joback]
omega       1.4727;      // -   [origin=predictive method=lee-kesler]
Tb          813.81;      // K   [origin=predictive method=joback]
HvapTb      83928.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.561 0.6699 -0.0002625 -1.26e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "chembond liquid" "2-methylidenebutanedioic acid;prop-2-enoic acid" "poly(acrylic acid-itaconic acid)" "acrylic acid-itaconic acid polymer" "butanedioic acid, methylene-, polymer with 2-propenoic acid" "methylenesuccinic acid polymer with acrylic acid" "succinic acid, methylene-, polymer with acrylic acid" "methylenebutanedioic acid polymer with 2-propenoic acid" "2-methylidenebutanedioic acid- prop-2-enoic acid(1:1)" "succinic acid, methylene-, polymer with acrylic acid (8ci)" "butanedioic acid, 2-methylene-, polymer with 2-propenoic acid" "succinic acid, polymer with acrylic acid" );
gibbsFormation
{
    dHf_298   -1129810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     721.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-952880.0
    phase     gas;
}
