/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-4-hydroxy-5-methoxyphenylacetonitrile  (C9H8BrNO2, CAS 81038-44-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo4Hydroxy5Methoxyphenylacetonitrile;
formula     C9H8BrNO2;
CAS         81038-44-0;
InChIKey    VMARCRAWRNPBBQ-UHFFFAOYSA-N;
MW          242.072;      // g/mol [origin=calculated method=formula-sum]
Tc          960.59;      // K   [origin=predictive method=joback]
Pc          38.819;      // bar [origin=predictive method=joback]
omega       0.9925;      // -   [origin=predictive method=lee-kesler]
Tb          713.44;      // K   [origin=predictive method=joback]
HvapTb      71565.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.171 0.72532 -0.00054868 1.777e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group CH3O; count 1; } { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 1; } { group OH_phenol; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-bromanyl-5-methoxy-4-oxidanyl-phenyl)ethanenitrile" "2-(3-bromo-4-hydroxy-5-methoxyphenyl)acetonitrile" "2-bromo-4-(cyanomethyl)-6-methoxyphenol" "3-bromo-4-hydroxy-5-methoxybenzyl cyanide" "3-bromo-4-hydroxy-5(-methoxyphenyl)acetonitrile" "benzeneacetonitrile, 3-bromo-4-hydroxy-5-methoxy-" "2-(5-bromo-4-hydroxy-3-methoxyphenyl)ethanenitrile" );
gibbsFormation
{
    dHf_298   -133820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     482.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=5930.0
    phase     gas;
}
