/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-allyloxy-4,8-dimethylcoumarin  (C14H14O3, CAS 3993-43-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Allyloxy48Dimethylcoumarin;
formula     C14H14O3;
CAS         3993-43-9;
InChIKey    CWBNOQSQEHMTNZ-UHFFFAOYSA-N;
MW          230.263;      // g/mol [origin=calculated method=formula-sum]
Tc          862.02;      // K   [origin=predictive method=joback]
Pc          22.959;      // bar [origin=predictive method=joback]
omega       0.8149;      // -   [origin=predictive method=lee-kesler]
Tb          650.14;      // K   [origin=predictive method=joback]
HvapTb      61171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.091 1.00994 -0.00062742 1.484e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,8-dimethyl-7-prop-2-enoxy-chromen-2-one" "4,8-dimethyl-7-(prop-2-en-1-yloxy)-2h-chromen-2-one" "bim-0045278.p001" "4,8-dimethyl-7-prop-2-enoxychromen-2-one" "7-allyl-oxy-4,8-dimethyl-chromen-2-one" "4,8-dimethyl-7-prop-2-enyloxychromen-2-one" "coumarin, 7-(allyloxy)-4,8-dimethyl- (8ci)" "2h-1-benzopyran-2-one,8-dimethyl-7-(2-propenyloxy)-" "7-(allyloxy)-4,8-dimethyl-2h-chromen-2-one; 2h-1-benzopyran-2-one, 4,8-dimethyl-7-(2-propenyloxy)-; 7-allyloxy-4, 8-dimethylcoumarin; coumarin, 7-(allyloxy)-4,8-dimethyl-" );
gibbsFormation
{
    dHf_298   -308630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-76120.0
    phase     gas;
}
