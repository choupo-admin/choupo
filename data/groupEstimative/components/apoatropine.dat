/*--------------------------------*- Choupo -*-----------------------*\
  Component: apoatropine  (C17H21NO2, CAS 500-55-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        apoatropine;
formula     C17H21NO2;
CAS         500-55-0;
InChIKey    WPUIZWXOSDVQJU-UHFFFAOYSA-N;
MW          271.36;      // g/mol [origin=calculated method=formula-sum]
Tc          921.18;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       0.7511;      // -   [origin=predictive method=lee-kesler]
Tb          695.54;      // K   [origin=predictive method=joback]
HvapTb      64261.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-134.1 1.85462 -0.001314 3.566e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(8-methyl-8-azabicyclo[3.2.1]octan-3-yl) 2-phenylprop-2-enoate" "apoatropin" "apohyoscyamin" "apohyoscyamine" "atropamine" "atropyltropeine" "atropamin" "tropine, atropate (ester)" "1-.alpha.-h,5-.alpha.-h-tropan-3-.alpha.-ol, atropate" "1-alpha-h,5-alpha-h-tropan-3-alpha-ol, atropate (ester)" "benzeneacetic acid, .alpha.-methylene-, 8-methyl-8-azabicyclo[3.2.1]oct-3-yl ester, endo-" "benzeneacetic acid, alpha-methylene-, (3-endo)-8-methyl-8-azabicyclo(3.2.1)oct-3-yl ester" );
gibbsFormation
{
    dHf_298   -172690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     567.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=186060.0
    phase     gas;
}
