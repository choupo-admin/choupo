/*--------------------------------*- Choupo -*-----------------------*\
  Component: ac1l3p4o  (C17H20O, CAS 70289-24-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ac1l3p4o;
formula     C17H20O;
CAS         70289-24-6;
InChIKey    HDPGMMYAJHHREL-UHFFFAOYSA-N;
MW          240.346;      // g/mol [origin=calculated method=formula-sum]
Tc          909.90;      // K   [origin=predictive method=joback]
Pc          21.938;      // bar [origin=predictive method=joback]
omega       0.6358;      // -   [origin=predictive method=lee-kesler]
Tb          672.08;      // K   [origin=predictive method=joback]
HvapTb      60779.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-173.25 2.02056 -0.00184226 7.051e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH-O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 3; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 4; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -53010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288670.0
}
