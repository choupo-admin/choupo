/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexanoic acid, 3,5,5-trimethylhexyl ester  (C15H30O2, CAS 73019-16-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexanoicAcid355TrimethylhexylEster;
formula     C15H30O2;
CAS         73019-16-6;
InChIKey    WZMVJDFJGFHBEJ-UHFFFAOYSA-N;
MW          242.403;      // g/mol [origin=calculated method=formula-sum]
Tc          772.43;      // K   [origin=predictive method=joback]
Pc          14.501;      // bar [origin=predictive method=joback]
omega       0.7257;      // -   [origin=predictive method=lee-kesler]
Tb          597.35;      // K   [origin=predictive method=joback]
HvapTb      54707.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.493 1.5058 -0.0008726 1.816e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 6; } { group CH; count 1; } { group C; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 7; } { group CH; count 1; } { group C; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5,5-trimethylhexyl hexanoate" "hexanoic acid 3,5,5-trimethylhexyl ester" );
gibbsFormation
{
    dHf_298   -684240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     743.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-234550.0
    phase     gas;
}
