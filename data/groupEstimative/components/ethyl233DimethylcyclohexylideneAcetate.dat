/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-(3,3-dimethylcyclohexylidene)acetate  (C12H20O2, CAS 37722-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl233DimethylcyclohexylideneAcetate;
formula     C12H20O2;
CAS         37722-77-3;
InChIKey    BKHNGPZOPOPDCJ-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          770.00;      // K   [origin=predictive method=joback]
Pc          22.981;      // bar [origin=predictive method=joback]
omega       0.5479;      // -   [origin=predictive method=lee-kesler]
Tb          558.81;      // K   [origin=predictive method=joback]
HvapTb      49778.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.109 1.42556 -0.0011165 3.83e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-(3,3-dimethylcyclohexylidene)ethanoate" "acetic acid, (3,3-dimethylcyclohexylidene)-, ethyl ester, (2e)-" "acetic acid, (3,3-dimethylcyclohexylidene)-, ethyl ester, (2z)-" "acetic acid, 2-(3,3-dimethylcyclohexylidene)-, ethyl ester, (2e)-" "acetic acid, 2-(3,3-dimethylcyclohexylidene)-, ethyl ester, (2z)-" "acetic acid, (3,3-dimethylcyclohexylidene)-, ethyl ester, (z)-" );
gibbsFormation
{
    dHf_298   -462700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-195790.0
    phase     gas;
}
