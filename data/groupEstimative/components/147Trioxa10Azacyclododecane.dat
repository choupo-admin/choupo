/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4,7-trioxa-10-azacyclododecane  (C8H17NO3, CAS 41775-76-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        147Trioxa10Azacyclododecane;
formula     C8H17NO3;
CAS         41775-76-2;
InChIKey    QNSRHBOZQLXYNV-UHFFFAOYSA-N;
MW          175.228;      // g/mol [origin=calculated method=formula-sum]
Tc          817.72;      // K   [origin=predictive method=joback]
Pc          39.062;      // bar [origin=predictive method=joback]
omega       0.4876;      // -   [origin=predictive method=lee-kesler]
Tb          561.88;      // K   [origin=predictive method=joback]
HvapTb      55460.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.77 0.8324 -0.0001671 -1.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group FCH2O; count 3; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 8; } { group O_ring; count 3; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-aza-12-crown-4" "1-aza-12-crown 4-ether" "1-aza-12-crown-4;1-aza-4,7,10-trioxacyclododecane; 10-aza-12-crown-4; 12-crown-o3n;aza-12-crown-4; monoaza-12-crown-4" );
gibbsFormation
{
    dHf_298   -528940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194610.0
    phase     gas;
}
