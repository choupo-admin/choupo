/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-piperidinesuccinic acid, dimethyl ester  (C11H19NO4, CAS 16217-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1PiperidinesuccinicAcidDimethylEster;
formula     C11H19NO4;
CAS         16217-48-4;
InChIKey    AAXAJRVDHFSOFM-UHFFFAOYSA-N;
MW          229.276;      // g/mol [origin=calculated method=formula-sum]
Tc          798.15;      // K   [origin=predictive method=joback]
Pc          23.912;      // bar [origin=predictive method=joback]
omega       0.8087;      // -   [origin=predictive method=lee-kesler]
Tb          599.67;      // K   [origin=predictive method=joback]
HvapTb      57115.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.089 1.22724 -0.000684 1.101e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CH2COO; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 5; } { group COO; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl 2-piperidin-1-ylbutanedioate" "butanedioic acid,2-(1-piperidinyl)-, 1,4-dimethyl ester" "1-piperidinesuccinicacid, dimethyl ester (8ci); butanedioic acid, 1-piperidinyl-, dimethyl ester(9ci); dimethyl piperidinosuccinate" );
gibbsFormation
{
    dHf_298   -761860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     685.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-426400.0
    phase     gas;
}
