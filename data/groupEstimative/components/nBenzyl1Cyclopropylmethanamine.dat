/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyl-1-cyclopropylmethanamine  (C11H15N, CAS 116373-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nBenzyl1Cyclopropylmethanamine;
formula     C11H15N;
CAS         116373-23-0;
InChIKey    QONMRPMQMVTSLW-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          753.96;      // K   [origin=predictive method=joback]
Pc          30.864;      // bar [origin=predictive method=joback]
omega       0.5567;      // -   [origin=predictive method=lee-kesler]
Tb          534.87;      // K   [origin=predictive method=joback]
HvapTb      48705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.468 1.197 -0.0008746 2.55e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopropyl-n-(phenylmethyl)methanamine" "n-benzyl(cyclopropyl)methanamine" "benzyl-cyclopropylmethyl-amine" "(cyclopropylmethyl)benzylamine" "benzyl(cyclopropylmethyl)amine" "n-benzylcyclopropylmethylamine" );
gibbsFormation
{
    dHf_298   92430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=304290.0
    phase     gas;
}
