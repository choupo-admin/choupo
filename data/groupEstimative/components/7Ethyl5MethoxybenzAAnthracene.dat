/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-ethyl-5-methoxybenz(a)anthracene  (C21H18O, CAS 63020-60-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Ethyl5MethoxybenzAAnthracene;
formula     C21H18O;
CAS         63020-60-0;
InChIKey    XXPLOVQYXLTUEV-UHFFFAOYSA-N;
MW          286.374;      // g/mol [origin=calculated method=formula-sum]
Tc          1050.31;      // K   [origin=predictive method=joback]
Pc          19.841;      // bar [origin=predictive method=joback]
omega       0.8689;      // -   [origin=predictive method=lee-kesler]
Tb          806.04;      // K   [origin=predictive method=joback]
HvapTb      74594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-61.739 1.60764 -0.0011808 3.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group AC; count 7; } { group ACCH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-ethyl-5-methoxy-benzo[a]anthracene" "3-methoxy-10-ethyl-1,2-benzanthracene" "benz(a)anthracene, 7-ethyl-5-methoxy-" "7-ethyl-5-methoxytetraphene" "7-ethyl-5-methoxybenzo[a]anthracene" );
standardThermochemistry
{
    dHf_298   154870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=414780.0
}
