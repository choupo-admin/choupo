/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromofluoroform  (CBrF3, CAS 75-63-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromofluoroform;
formula     CBrF3;
CAS         75-63-8;
InChIKey    RJCQBQGAPKAMLL-UHFFFAOYSA-N;
MW          148.909;      // g/mol [origin=calculated method=formula-sum]
Tc          447.71;      // K   [origin=predictive method=joback]
Pc          53.986;      // bar [origin=predictive method=joback]
omega       0.2586;      // -   [origin=predictive method=lee-kesler]
Tb          283.22;      // K   [origin=predictive method=joback]
HvapTb      20508.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.97 0.2982 -0.000323 1.235e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group F; count 3; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanyl-tris(fluoranyl)methane" "bromotrifluoromethane" "methane, bromotrifluoro-" "trifluorobromomethane" "trifluoromethyl bromide" "bromo(trifluoro)methane" "monobromotrifluoromethane" "halocarbon 13b1" "carbon monobromide trifluoride" "refrigerant 13b1" "daiflon 13b1" "khladon 13b1" );
standardThermochemistry
{
    dHf_298   -634720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     302.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-609730.0
}
