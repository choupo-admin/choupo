/*--------------------------------*- Choupo -*-----------------------*\
  Component: methanediylbis(benzene-4,1-diyloxy-2-hydroxypropane-3,1-diyl) bisprop-2-enoate  (C25H28O8, CAS 64448-68-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methanediylbisBenzene41Diyloxy2Hydroxypropane31DiylBisprop2E;
formula     C25H28O8;
CAS         64448-68-6;
InChIKey    VAIGCMUJWUZYRJ-UHFFFAOYSA-N;
MW          456.491;      // g/mol [origin=calculated method=formula-sum]
Tc          1451.84;      // K   [origin=predictive method=joback]
Pc          13.457;      // bar [origin=predictive method=joback]
omega       1.1023;      // -   [origin=predictive method=lee-kesler]
Tb          1173.04;      // K   [origin=predictive method=joback]
HvapTb      127996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.005 1.9058 -0.00096632 1.171e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACCH2; count 1; } { group COO; count 2; } { group C2H4O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 5; } { group CH; count 2; } { group dCH2; count 2; } { group dCH; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 2; } { group O; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-oxidanyl-3-[4-[[4-(2-oxidanyl-3-prop-2-enoyloxy-propoxy)phenyl]methyl]phenoxy]propyl] prop-2-enoate" "methylenebis(4,1-phenyleneoxy(2-hydroxy-3,1-propanediyl)) acrylate" "methylenebis[4,1-phenyleneoxy(2-hydroxy-3,1-propanediyl)] acrylate" "2-propenoic acid, 1,1'-(methylenebis(4,1-phenyleneoxy(2-hydroxy-3,1-propanediyl))) ester" "2-propenoic acid, 1,1'-[methylenebis[4,1-phenyleneoxy(2-hydroxy-3,1-propanediyl)]] ester" "bisphenol f, epichlorohydrin, acrylic acid adduct" "2-propenoic acid, methylenebis(4,1-phenyleneoxy(2-hydroxy-3,1-propanediyl)) ester" "[2-hydroxy-3-[4-[[4-(2-hydroxy-3-prop-2-enoyloxypropoxy)phenyl]methyl]phenoxy]propyl] prop-2-enoate" );
gibbsFormation
{
    dHf_298   -1072370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1103.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-568400.0
    phase     gas;
}
