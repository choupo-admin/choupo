/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetracyclo[6.2.1.1(3,6).0(2,7)]dodec-4-ene  (C12H16, CAS 21635-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetracyclo621136027Dodec4Ene;
formula     C12H16;
CAS         21635-90-5;
InChIKey    XBFJAVXCNXDMBH-UHFFFAOYSA-N;
MW          160.26;      // g/mol [origin=calculated method=formula-sum]
Tc          709.18;      // K   [origin=predictive method=joback]
Pc          28.293;      // bar [origin=predictive method=joback]
omega       0.3917;      // -   [origin=predictive method=lee-kesler]
Tb          490.94;      // K   [origin=predictive method=joback]
HvapTb      41632.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-189.33 1.6384 -0.00138628 4.766e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 6; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 6; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4:5,8-dimethano-naphthalene,1,2,4,4a,8,8,8a-octahydro-" "tetracyclo[6.2.1.1(3,6).0(2,7)]dodec-9-ene" "1,2,3,4,4a,5,8,8a-octahydro-1,4:5,8-dimethanonaphthalene" "1,4:5,8-dimethanonaphthalene, 1,2,3,4,4a,5,8,8a-octahydro-, (1alpha,4alpha,5beta,8beta)-" "1.4:5.8-dimethano-1,2,3,4,4a,5,8,8a-octahydronaphthalene" "1,4:5,8-dimethanonaphthalene, (1 alpha,4 alpha,4a beta,5 alpha,8 alpha,8a beta) 1,2,3,4,4a,5,8,8a-octahydro-" "1,4:5,8-dimethanonaphthalene, (1alpha,4alpha,4abeta,5alpha,8alpha,8abeta) 1,2,3,4,4a,5,8,8a-octahydro-" "1,4:5,8-dimethanonaphthalene, 1,2,3,4,4a,5,8,8a-octahydro-, (1.alpha.,4.alpha.,4a.alpha.,5.beta.,8.beta.,8a.alpha.)-" "1,4:5,8-dimethanonaphthalene, 1,2,3,4,4a,5,8,8a-octahydro-, (1.alpha.,4.alpha.,5.beta.,8.beta.)-" "1,4:5,8-dimethanonaphthalene, 1,2,3,4,4a,5,8,8a-octahydro-, (1alpha,4alpha,4aalpha,5beta,8beta,8aalpha)-" );
standardThermochemistry
{
    dHf_298   17290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     140.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=307700.0
}
