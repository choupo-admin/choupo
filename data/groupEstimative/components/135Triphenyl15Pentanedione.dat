/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-triphenyl-1,5-pentanedione  (C23H20O2, CAS 6263-84-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Triphenyl15Pentanedione;
formula     C23H20O2;
CAS         6263-84-9;
InChIKey    SQFIJFCIFAVGEG-UHFFFAOYSA-N;
MW          328.411;      // g/mol [origin=calculated method=formula-sum]
Tc          1167.66;      // K   [origin=predictive method=joback]
Pc          18.920;      // bar [origin=predictive method=joback]
omega       1.0132;      // -   [origin=predictive method=lee-kesler]
Tb          913.18;      // K   [origin=predictive method=joback]
HvapTb      86724.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.698 1.902 -0.0012868 3.2042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 2; } { group ACCH; count 1; } { group CH2CO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } { group CdO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-triphenylpentane-1,5-dione" "1,3,5-triphenyl-1,5-pentadione" );
standardThermochemistry
{
    dHf_298   -38900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     776.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=219730.0
}
