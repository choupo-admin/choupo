/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2266470  (C14H20O3, CAS 58344-42-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2266470;
formula     C14H20O3;
CAS         58344-42-6;
InChIKey    KZMOPPALPUQHAR-SOFGYWHQSA-N;
MW          236.311;      // g/mol [origin=calculated method=formula-sum]
Tc          959.47;      // K   [origin=predictive method=joback]
Pc          26.488;      // bar [origin=predictive method=joback]
omega       1.2087;      // -   [origin=predictive method=lee-kesler]
Tb          747.29;      // K   [origin=predictive method=joback]
HvapTb      80073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.91 1.47258 -0.00113652 3.629e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group OH; count 1; } { group ACOH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH; count 1; } { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(e)-4,4-dimethyl-3-oxidanyl-pent-1-enyl]-2-methoxy-phenol" "phenol, 4-(4,4-dimethyl-3-hydroxy-1-pentenyl)-2-methoxy-" "4-hydroxy stiripentol" "p-hydroxy stiripentol" "4-(3-hydroxy-4,4-dimethyl-1-penten-1-yl)-2-methoxyphenol" "4-[(e)-3-hydroxy-4,4-dimethylpent-1-enyl]-2-methoxyphenol" );
standardThermochemistry
{
    dHf_298   -465800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-146040.0
}
