/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl tiglate  (C8H12O2, CAS 7493-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allylTiglate;
formula     C8H12O2;
CAS         7493-71-2;
InChIKey    ODOZNBUSHKFCSH-FNORWQNLSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          628.83;      // K   [origin=predictive method=joback]
Pc          28.233;      // bar [origin=predictive method=joback]
omega       0.4613;      // -   [origin=predictive method=lee-kesler]
Tb          441.58;      // K   [origin=predictive method=joback]
HvapTb      40177.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.161 0.70894 -0.0004258 9.35e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl (e)-2-methylbut-2-enoate" "tiglic acid, allyl ester" "2-butenoic acid, 2-methyl-, 2-propenyl ester, (e)-" "allyl 2-methylcrotonate" "ambap7493-71-2" "allyl trans-2-methyl-2-butenoate" "prop-2-en-1-yl 2-methylbut-2-enoate" "2-propenyl 2-methyl-2-butenoate, (e)-" );
gibbsFormation
{
    dHf_298   -292870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-134380.0
    phase     gas;
}
