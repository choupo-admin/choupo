/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-dibromooctafluorobutane  (C4Br2F8, CAS 335-48-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Dibromooctafluorobutane;
formula     C4Br2F8;
CAS         335-48-8;
InChIKey    RWWUGYJWSVESJC-UHFFFAOYSA-N;
MW          359.836;      // g/mol [origin=calculated method=formula-sum]
Tc          577.29;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.5169;      // -   [origin=predictive method=lee-kesler]
Tb          404.68;      // K   [origin=predictive method=joback]
HvapTb      25648.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.53 1.0578 -0.001155 4.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group Br; count 2; } { group CF2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 4; } { group F; count 8; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(bromanyl)-1,1,2,2,3,3,4,4-octakis(fluoranyl)butane" "1,4-dibromoperfluorobutane" "1,4-dibromo-1,1,2,2,3,3,4,4-octafluorobutane" "butane,1,4-dibromo-1,1,2,2,3,3,4,4-octafluoro-" );
gibbsFormation
{
    dHf_298   -1677110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1535680.0
    phase     gas;
}
