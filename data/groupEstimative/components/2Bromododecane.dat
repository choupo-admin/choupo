/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromododecane  (C12H25Br, CAS 13187-99-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromododecane;
formula     C12H25Br;
CAS         13187-99-0;
InChIKey    GIUUCQVKMWBSRT-UHFFFAOYSA-N;
MW          249.236;      // g/mol [origin=calculated method=formula-sum]
Tc          717.89;      // K   [origin=predictive method=joback]
Pc          19.019;      // bar [origin=predictive method=joback]
omega       0.6808;      // -   [origin=predictive method=lee-kesler]
Tb          539.88;      // K   [origin=predictive method=joback]
HvapTb      48353.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.511 1.18794 -0.0007036 1.652e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyldodecane" "2-bromo dodecane" "dodecane, 2-bromo-" "agn-pc-04t8qr" "2-bromododecane;dodecane, 2-bromo-;2-bromododecane, tech., 85%" );
gibbsFormation
{
    dHf_298   -269960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     664.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62040.0
    phase     gas;
}
