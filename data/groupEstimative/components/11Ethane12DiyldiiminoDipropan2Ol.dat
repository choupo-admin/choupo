/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1'-(ethane-1,2-diyldiimino)dipropan-2-ol  (C8H20N2O2, CAS 3270-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Ethane12DiyldiiminoDipropan2Ol;
formula     C8H20N2O2;
CAS         3270-73-3;
InChIKey    NXNQLKPBPWLUSX-UHFFFAOYSA-N;
MW          176.26;      // g/mol [origin=calculated method=formula-sum]
Tc          835.61;      // K   [origin=predictive method=joback]
Pc          32.283;      // bar [origin=predictive method=joback]
omega       1.6533;      // -   [origin=predictive method=lee-kesler]
Tb          666.46;      // K   [origin=predictive method=joback]
HvapTb      78856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.414 0.99604 -0.0005758 1.236e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 2; } { group CH2NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group OH; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[2-(2-oxidanylpropylamino)ethylamino]propan-2-ol" "2-propanol, 1,1'-(1,2-ethanediyldiimino)bis-" "1,1'-(ethylenediimino)dipropan-2-ol" "2-propanol, 1,1'-(ethylenediimino)di-" "n,n'-bis(2-hydroxypropyl)-1,2-ethanediamine" "1-[2-(2-hydroxypropylamino)ethylamino]propan-2-ol" );
gibbsFormation
{
    dHf_298   -416530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     631.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-83260.0
    phase     gas;
}
