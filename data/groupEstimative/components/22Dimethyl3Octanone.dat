/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethyl-3-octanone  (C10H20O, CAS 5340-64-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethyl3Octanone;
formula     C10H20O;
CAS         5340-64-7;
InChIKey    FNSYCTJZGJAYCQ-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          662.30;      // K   [origin=predictive method=joback]
Pc          22.762;      // bar [origin=predictive method=joback]
omega       0.5232;      // -   [origin=predictive method=lee-kesler]
Tb          479.04;      // K   [origin=predictive method=joback]
HvapTb      43304.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.316 1.05168 -0.0006733 1.7066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyloctan-3-one" "2,2-dimethyl-octan-3-one" "3-octanone,2,2-dimethyl-" );
gibbsFormation
{
    dHf_298   -371060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-92760.0
    phase     gas;
}
