/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-butanediol, 2,2-dimethyl-  (C6H14O2, CAS 76-35-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Butanediol22Dimethyl;
formula     C6H14O2;
CAS         76-35-7;
InChIKey    QXKKYNIWAYERHT-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          686.15;      // K   [origin=predictive method=joback]
Pc          39.906;      // bar [origin=predictive method=joback]
omega       1.1477;      // -   [origin=predictive method=lee-kesler]
Tb          517.57;      // K   [origin=predictive method=joback]
HvapTb      60624.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.139 0.77356 -0.0005384 1.512e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 1; } { group C; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylbutane-1,3-diol" "2,2-dimethyl-1,3-butanediol" );
standardThermochemistry
{
    dHf_298   -485660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     443.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273600.0
}
