/*--------------------------------*- Choupo -*-----------------------*\
  Component: decyl formate  (C11H22O2, CAS 5451-52-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H22O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        decylFormate;
formula     C11H22O2;
CAS         5451-52-5;
InChIKey    BCLJZFLDSCTULJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          587.64;      // K   [origin=predictive method=joback]
Pc          19.544;      // bar [origin=predictive method=joback]
omega       0.4827;      // -   [origin=predictive method=lee-kesler]
Tb          427.70;      // K   [origin=predictive method=joback]
HvapTb      37707.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.611 1.05692 -0.0007276 2.164e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "decyl methanoate" "formic acid, decyl ester" "n-decyl methanoate" "n-decyl formate" "formic acid, decylester" "formic acid decyl ester" "we(10:0/1:0)" );
gibbsFormation
{
    dHf_298   -193920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85700.0
    phase     gas;
}
