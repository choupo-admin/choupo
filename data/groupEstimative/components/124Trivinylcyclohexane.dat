/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4-trivinylcyclohexane  (C12H18, CAS 2855-27-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124Trivinylcyclohexane;
formula     C12H18;
CAS         2855-27-8;
InChIKey    KTRQRAQRHBLCSQ-UHFFFAOYSA-N;
MW          162.276;      // g/mol [origin=calculated method=formula-sum]
Tc          678.75;      // K   [origin=predictive method=joback]
Pc          22.568;      // bar [origin=predictive method=joback]
omega       0.3408;      // -   [origin=predictive method=lee-kesler]
Tb          474.41;      // K   [origin=predictive method=joback]
HvapTb      40107.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.72 1.1529 -0.0006679 1.37e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 3; } { group CH2=CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 3; } { group dCH; count 3; } { group CH2_ring; count 3; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4-tris(ethenyl)cyclohexane" "cyclohexane, 1,2,4-triethenyl-" "cyclohexane, 1,2,4-trivinyl-" "cyclohexane-1,2,4-triyltris(ethylene)" "1,2,4-trivinylcyclohexane, mixture of isomers" "trivinyl cyclohexane" "1,4-trivinylcyclohexane" "cyclohexane,2,4-trivinyl-" "cyclohexane,2,4-triethenyl-" );
standardThermochemistry
{
    dHf_298   98920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=322710.0
}
