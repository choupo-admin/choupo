/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzopinacol  (C26H22O2, CAS 464-72-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzopinacol;
formula     C26H22O2;
CAS         464-72-2;
InChIKey    MFEWNFVBWPABCX-UHFFFAOYSA-N;
MW          366.46;      // g/mol [origin=calculated method=formula-sum]
Tc          1337.40;      // K   [origin=predictive method=joback]
Pc          21.276;      // bar [origin=predictive method=joback]
omega       1.4745;      // -   [origin=predictive method=lee-kesler]
Tb          1079.10;      // K   [origin=predictive method=joback]
HvapTb      113340.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-194.73 2.4778 -0.0019198 5.636e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group ACH; count 20; } { group AC; count 4; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dCH_ring; count 20; } { group dC_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,2-tetraphenylethane-1,2-diol" "benzopinacole" "tetraphenylethylene glycol" "benzopinacone" "benzpinacol" "benzpinacone" "1,2-ethanediol, 1,1,2,2-tetraphenyl-" "tetraphenyl-1,2-ethanediol" "a,a'-bibenzhydrol" "benzophenone pinacol" "1,1,2,2-tetraphenyl-1,2-ethanediol" "alpha,alpha'-bibenzhydrol" );
gibbsFormation
{
    dHf_298   44190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     767.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=349720.0
    phase     gas;
}
