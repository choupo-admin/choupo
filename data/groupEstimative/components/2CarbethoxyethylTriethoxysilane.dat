/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2-carbethoxyethyl)triethoxysilane  (C11H24O5Si, CAS 6439-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H24O5Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2CarbethoxyethylTriethoxysilane;
formula     C11H24O5Si;
CAS         6439-39-0;
InChIKey    FSTSIHBJBSLSQV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          264.393;      // g/mol [origin=calculated method=formula-sum]
Tc          749.96;      // K   [origin=predictive method=joback]
Pc          16.797;      // bar [origin=predictive method=joback]
omega       0.7983;      // -   [origin=predictive method=lee-kesler]
Tb          578.16;      // K   [origin=predictive method=joback]
HvapTb      55011.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (135.616 0.59828 0.0002678 -3.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH2COO; count 1; } { group CH2O; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group O; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-triethoxysilylpropanoate" "triethoxy(2-ethoxycarbonylethyl) silane" "silane, ((2-ethoxycarbonyl)ethyl)triethoxy-" "propionic acid, 3-(triethoxysilyl)-, ethyl ester" "3-(triethoxysilyl)propanoic acid, ethyl ester" "ethyl 3-(triethoxysilyl)propanoate" "triethoxy (2-ethoxycarbonylethyl) silane" );
gibbsFormation
{
    dHf_298   -1095930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     796.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-688390.0
    phase     gas;
}
