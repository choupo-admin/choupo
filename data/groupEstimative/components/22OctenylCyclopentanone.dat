/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-octenyl)-cyclopentanone  (C13H22O, CAS 65737-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22OctenylCyclopentanone;
formula     C13H22O;
CAS         65737-52-2;
InChIKey    QHEUOYOHVATZEB-UHFFFAOYSA-N;
MW          194.318;      // g/mol [origin=calculated method=formula-sum]
Tc          789.81;      // K   [origin=predictive method=joback]
Pc          20.680;      // bar [origin=predictive method=joback]
omega       0.6140;      // -   [origin=predictive method=lee-kesler]
Tb          584.30;      // K   [origin=predictive method=joback]
HvapTb      48994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-47.165 1.22222 -0.0006506 1.174e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 5; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-oct-2-enylcyclopentan-1-one" "cyclopentanone, 2-(2-octen-1-yl)-" );
gibbsFormation
{
    dHf_298   -271650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     526.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52760.0
    phase     gas;
}
