/*--------------------------------*- Choupo -*-----------------------*\
  Component: decafluoro-p-xylol  (C8F10, CAS 651-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        decafluoroPXylol;
formula     C8F10;
CAS         651-89-8;
InChIKey    WWZNHODBHBVRID-UHFFFAOYSA-N;
MW          286.068;      // g/mol [origin=calculated method=formula-sum]
Tc          566.15;      // K   [origin=predictive method=joback]
Pc          21.795;      // bar [origin=predictive method=joback]
omega       0.6694;      // -   [origin=predictive method=lee-kesler]
Tb          420.46;      // K   [origin=predictive method=joback]
HvapTb      28226.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.17 0.757 -0.000615 1.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group AC; count 2; } { group ACF; count 4; } { group CF3; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dC_ring; count 6; } { group F; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,4,5-tetrakis(fluoranyl)-3,6-bis(trifluoromethyl)benzene" "perfluoro-4-xylene" "1,2,4,5-tetrafluoro-3,6-bis(trifluoromethyl)benzene" "benzene, 1,2,4,5-tetrafluoro-3,6-bis(trifluoromethyl)-" "perfluoro-p-xylene" "tetrafluoro-1,4-bis(trifluoromethyl)benzene" "benzene,1,2,4,5-tetrafluoro-3,6-bis(trifluoromethyl)-" "p-xylene,decafluoro- (6ci,7ci); p-xylene, a,a,a,a',a',a',2,3,5,6-decafluoro- (8ci); decafluoro-p-xylene;p-perfluoroxylene" );
standardThermochemistry
{
    dHf_298   -2007870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     569.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1861680.0
}
