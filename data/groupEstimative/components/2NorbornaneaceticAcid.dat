/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-norbornaneacetic acid  (C9H14O2, CAS 1007-01-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2NorbornaneaceticAcid;
formula     C9H14O2;
CAS         1007-01-8;
InChIKey    FYHBMPWRHCWNBC-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          781.31;      // K   [origin=predictive method=joback]
Pc          32.992;      // bar [origin=predictive method=joback]
omega       0.6960;      // -   [origin=predictive method=lee-kesler]
Tb          564.11;      // K   [origin=predictive method=joback]
HvapTb      52481.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.359 1.1753 -0.000877 2.644e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH; count 3; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(3-bicyclo[2.2.1]heptanyl)ethanoic acid" "bicyclo[2.2.1]heptane-2-acetic acid" "2-bicyclo[2.2.1]hept-2-ylacetic acid" "2-norbornaneacetate" "norborn-2-ylacetic acid" "norbornaneacetate (nba)" "norbornyl-2-acetic acid" "fyhbmpwrhcwnbc-uhfffaoysa-" "bicyclo[2.2.1]heptane-2-aceticacid" "bicyclo[2.2.1]hept-2-ylacetic acid" "bicyclo[2.2.1]heptan-2-ylacetic acid" "2-(3-bicyclo[2.2.1]heptanyl)acetic acid" );
standardThermochemistry
{
    dHf_298   -460260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     356.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-217320.0
}
