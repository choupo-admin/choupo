/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-decylthiophene  (C14H24S, CAS 65016-55-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Decylthiophene;
formula     C14H24S;
CAS         65016-55-9;
InChIKey    JAYBIBLZTQMCAY-UHFFFAOYSA-N;
MW          224.406;      // g/mol [origin=calculated method=formula-sum]
Tc          787.48;      // K   [origin=predictive method=joback]
Pc          18.937;      // bar [origin=predictive method=joback]
omega       0.6634;      // -   [origin=predictive method=lee-kesler]
Tb          591.00;      // K   [origin=predictive method=joback]
HvapTb      54382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.581 1.33493 -0.00084682 2.154e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3- decylthiophene" );
gibbsFormation
{
    dHf_298   -102120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     662.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=201410.0
    phase     gas;
}
