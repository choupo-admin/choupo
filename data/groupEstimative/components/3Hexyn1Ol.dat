/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexyn-1-ol  (C6H10O, CAS 1002-28-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexyn1Ol;
formula     C6H10O;
CAS         1002-28-4;
InChIKey    ODEHKVYXWLXRRR-UHFFFAOYSA-N;
MW          98.145;      // g/mol [origin=calculated method=formula-sum]
Tc          620.91;      // K   [origin=predictive method=joback]
Pc          42.056;      // bar [origin=predictive method=joback]
omega       0.6645;      // -   [origin=predictive method=lee-kesler]
Tb          438.06;      // K   [origin=predictive method=joback]
HvapTb      47781.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.283 0.45802 -0.00024086 4.898e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hex-3-yn-1-ol" "3-hexynol" "3-hexynol;" );
standardThermochemistry
{
    dHf_298   -47100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65620.0
}
