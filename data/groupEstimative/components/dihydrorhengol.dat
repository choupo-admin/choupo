/*--------------------------------*- Choupo -*-----------------------*\
  Component: dihydrorhengol  (C21H36O2, CAS 492-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dihydrorhengol;
formula     C21H36O2;
CAS         492-89-7;
InChIKey    DQTMTQZSOJMZSF-UHFFFAOYSA-N;
MW          320.517;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.92;      // K   [origin=predictive method=joback]
Pc          14.736;      // bar [origin=predictive method=joback]
omega       1.1958;      // -   [origin=predictive method=lee-kesler]
Tb          868.00;      // K   [origin=predictive method=joback]
HvapTb      90644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-67.946 2.22912 -0.00166252 5.304e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 13; } { group ACH; count 3; } { group ACCH2; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 14; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-pentadecylbenzene-1,2-diol" "3-pentadecylcatechol" "hydroureshiol" "tetrahydrourushiol" "3-n-pentadecylcatechol" "3-n-pentadecylpyrocatechol" "3-pentadecacatechol" "hydrourushiol" "pyrocatechol, 3-pentadecyl-" "3-pentadecylpyrocatechol" "1, 3-pentadecyl-" "3-pdc" );
gibbsFormation
{
    dHf_298   -594860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     920.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-70890.0
    phase     gas;
}
