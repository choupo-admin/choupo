/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)propionic acid  (C5H10O4, CAS 4767-03-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylPropionicAcid;
formula     C5H10O4;
CAS         4767-03-7;
InChIKey    PTBDIHRZYDMNKB-UHFFFAOYSA-N;
MW          134.131;      // g/mol [origin=calculated method=formula-sum]
Tc          823.28;      // K   [origin=predictive method=joback]
Pc          50.586;      // bar [origin=predictive method=joback]
omega       1.6507;      // -   [origin=predictive method=lee-kesler]
Tb          640.64;      // K   [origin=predictive method=joback]
HvapTb      75950.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.948 0.72342 -0.0005534 1.678e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hydroxymethyl)-2-methyl-3-oxidanyl-propanoic acid" "dimethylolpropionic acid" "3-hydroxy-2-(hydroxymethyl)-2-methylpropanoic acid" "2,2-bis(hydroxymethyl)propanoic acid" "propanoic acid, 3-hydroxy-2-(hydroxymethyl)-2-methyl-" "2,2-dimethylolpropionic acid" "hydracrylic acid, 2-(hydroxymethyl)-2-methyl-" "dimethylol propionic" "dimethylol propionic acid" "dmpa(r)" "dimethylolpropionic acid(dmpa)" "bis(hydroxymethyl)propionic acid" );
standardThermochemistry
{
    dHf_298   -810010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-623490.0
}
