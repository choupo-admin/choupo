/*--------------------------------*- Choupo -*-----------------------*\
  Component: gamma-terpinyl acetate  (C12H20O2, CAS 10235-63-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gammaTerpinylAcetate;
formula     C12H20O2;
CAS         10235-63-9;
InChIKey    ZKKBZSOYCMSYRW-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          773.74;      // K   [origin=predictive method=joback]
Pc          23.092;      // bar [origin=predictive method=joback]
omega       0.5204;      // -   [origin=predictive method=lee-kesler]
Tb          558.69;      // K   [origin=predictive method=joback]
HvapTb      49858.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.8 1.42548 -0.0011188 3.848e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group C; count 1; } { group CH3COO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dC; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methyl-4-propan-2-ylidene-cyclohexyl) ethanoate" "cyclohexanol, 1-methyl-4-(1-methylethylidene)-, acetate" "cyclohexanol, 1-methyl-4-(1-methylethylidene)-, 1-acetate" "4-isopropylidene-1-methylcyclohexyl acetate" "1-methyl-4-(1-methylethylidene)cyclohexyl acetate" "p-menth-4-en-1-yl acetate" "(1-methyl-4-propan-2-ylidenecyclohexyl) acetate" );
standardThermochemistry
{
    dHf_298   -472490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     681.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204340.0
}
