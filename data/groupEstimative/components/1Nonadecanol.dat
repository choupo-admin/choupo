/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-nonadecanol  (C19H40O, CAS 1454-84-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Nonadecanol;
formula     C19H40O;
CAS         1454-84-8;
InChIKey    XGFDHKJUZCCPKQ-UHFFFAOYSA-N;
MW          284.528;      // g/mol [origin=calculated method=formula-sum]
Tc          892.64;      // K   [origin=predictive method=joback]
Pc          11.491;      // bar [origin=predictive method=joback]
omega       1.0512;      // -   [origin=predictive method=lee-kesler]
Tb          726.50;      // K   [origin=predictive method=joback]
HvapTb      74567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.092 1.84282 -0.0010402 2.247e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 18; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonadecan-1-ol" "nonadecyl alcohol" "nonadecanol" );
gibbsFormation
{
    dHf_298   -587720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     946.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-27720.0
    phase     gas;
}
