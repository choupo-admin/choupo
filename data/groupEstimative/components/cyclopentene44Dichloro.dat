/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclopentene,4,4-dichloro-  (C5H6Cl2, CAS 5296-48-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopentene44Dichloro;
formula     C5H6Cl2;
CAS         5296-48-0;
InChIKey    GVZSEVSNGREDBC-UHFFFAOYSA-N;
MW          137.003;      // g/mol [origin=calculated method=formula-sum]
Tc          630.88;      // K   [origin=predictive method=joback]
Pc          43.800;      // bar [origin=predictive method=joback]
omega       0.2327;      // -   [origin=predictive method=lee-kesler]
Tb          403.54;      // K   [origin=predictive method=joback]
HvapTb      34892.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-78.57 0.86 -0.00093628 4.08e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH=CH; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 2; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,4-bis(chloranyl)cyclopentene" "4,4-dichlorocyclopentene" "cyclopentene, 4,4-dichloro-" );
gibbsFormation
{
    dHf_298   -44510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     399.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28380.0
    phase     gas;
}
