/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n'-ethane-1,2-diylbis(n-ethyloctadecanamide)  (C42H84N2O2, CAS 61702-61-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNEthane12DiylbisNEthyloctadecanamide;
formula     C42H84N2O2;
CAS         61702-61-2;
InChIKey    SBNDFCBFYATLME-UHFFFAOYSA-N;
MW          649.146;      // g/mol [origin=calculated method=formula-sum]
Tc          1889.96;      // K   [origin=predictive method=joback]
Pc          3.803;      // bar [origin=predictive method=joback]
omega       -0.4581;      // -   [origin=predictive method=lee-kesler]
Tb          1293.18;      // K   [origin=predictive method=joback]
HvapTb      126664.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.954 4.18568 -0.0024488 5.4532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 32; } { group CON_CH2_2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 36; } { group CdO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-ethyl-n-[2-[ethyl(octadecanoyl)amino]ethyl]octadecanamide" "octadecanamide, n,n'-1,2-ethanediylbis(n-ethyl-" "octadecanamide, n,n'-1,2-ethanediylbis[n-ethyl-" "n,n'-ethane-1,2-diylbis(n-ethylstearamide)" );
standardThermochemistry
{
    dHf_298   -1000310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1877.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=266480.0
}
