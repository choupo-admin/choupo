/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(4-formylphenoxy)propyltrimethoxysilane  (C13H20O5Si, CAS 72136-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H20O5Si (delta C+1H+1O+1Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        34FormylphenoxyPropyltrimethoxysilane;
formula     C13H20O5Si;
CAS         72136-46-0;
InChIKey    BKCYLOLTKVUVPA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          284.383;      // g/mol [origin=calculated method=formula-sum]
Tc          793.00;      // K   [origin=predictive method=joback]
Pc          19.003;      // bar [origin=predictive method=joback]
omega       0.6783;      // -   [origin=predictive method=lee-kesler]
Tb          596.20;      // K   [origin=predictive method=joback]
HvapTb      55031.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (94.783 0.64956 5.824e-05 -1.956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH3O; count 3; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(3-trimethoxysilylpropoxy)benzaldehyde" "benzaldehyde,4-[3-(trimethoxysilyl)propoxy]-" );
standardThermochemistry
{
    dHf_298   -650640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     802.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-319440.0
}
