/*--------------------------------*- Choupo -*-----------------------*\
  Component: (tert-butyldimethylsilyloxy)acetaldehyde  (C8H18O2Si, CAS 102191-92-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H18O2Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tertButyldimethylsilyloxyAcetaldehyde;
formula     C8H18O2Si;
CAS         102191-92-4;
InChIKey    MEBFFOKESLAUSJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          174.315;      // g/mol [origin=calculated method=formula-sum]
Tc          639.36;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       0.4271;      // -   [origin=predictive method=lee-kesler]
Tb          451.89;      // K   [origin=predictive method=joback]
HvapTb      41530.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (48.861 0.5948 -5.04e-05 -1.182e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group C; count 1; } { group CHO; count 1; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group C; count 1; } { group O; count 1; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[tert-butyl(dimethyl)silyl]oxyethanal" "2-(tert-butyldimethylsilyloxy)acetaldehyde" "2-((tert-butyldimethylsilyl)oxy)acetaldehyde" "2-[tert-butyl(dimethyl)silyl]oxyacetaldehyde" );
gibbsFormation
{
    dHf_298   -546620.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     585.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-289960.0
    phase     gas;
}
