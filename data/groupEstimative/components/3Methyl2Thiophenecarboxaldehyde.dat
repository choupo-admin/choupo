/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-2-thiophenecarboxaldehyde  (C6H6OS, CAS 5834-16-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H6OS (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3Methyl2Thiophenecarboxaldehyde;
formula     C6H6OS;
CAS         5834-16-2;
InChIKey    BSQKBHXYEKVKMN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          126.173;      // g/mol [origin=calculated method=formula-sum]
Tc          609.19;      // K   [origin=predictive method=joback]
Pc          44.385;      // bar [origin=predictive method=joback]
omega       0.2341;      // -   [origin=predictive method=lee-kesler]
Tb          389.36;      // K   [origin=predictive method=joback]
HvapTb      34863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.51 0.52353 -0.00049758 1.92e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CHO; count 1; } { group C4H2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylthiophene-2-carbaldehyde" "3-methylthiophene-2-carboxaldehyde" "3-methylthiophene-2-aldehyde" "2-formyl-3-methylthiophene" "3-methyl-2-thiophene carboxaldehyde" "thiophenecarboxaldehyde, methyl-" "3-methyl-2-thiophenecarbaldehyde" "u420" );
standardThermochemistry
{
    dHf_298   127980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     425.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=168380.0
}
