/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxymethyl-2-methyl-1,3-propanediol tetrahydrate  (C5H20O7, CAS 142381-76-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H20O7 (delta H+8O+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Hydroxymethyl2Methyl13PropanediolTetrahydrate;
formula     C5H20O7;
CAS         142381-76-8;
InChIKey    LEHRMCOOEVWCNU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          192.208;      // g/mol [origin=calculated method=formula-sum]
Tc          749.67;      // K   [origin=predictive method=joback]
Pc          31.315;      // bar [origin=predictive method=joback]
omega       1.3951;      // -   [origin=predictive method=lee-kesler]
Tb          587.31;      // K   [origin=predictive method=joback]
HvapTb      75465.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.257 0.70662 -0.0005112 1.496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group OH; count 3; } { group H2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group C; count 1; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hydroxymethyl)-2-methyl-propane-1,3-diol;tetrahydrate" "2-(hydroxymethyl)-2-methylpropane-1,3-diol tetrahydrate" "1,3-propanediol,2-(hydroxymethyl)-2-methyl-, hydrate (1:4)" "1,3-propanediol,2-(hydroxymethyl)-2-methyl-, tetrahydrate (9ci)" );
standardThermochemistry
{
    dHf_298   -611970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1397.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-416400.0
}
