/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7,10-bis(hydroxymethyl)-3,3-dimethoxy-2-oxa-7,10-diaza-3-silaundecan-11-ol  (C11H28N2O6Si, CAS 68140-42-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H28N2O6Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        710BisHydroxymethyl33Dimethoxy2Oxa710Diaza3Silaundecan11Ol;
formula     C11H28N2O6Si;
CAS         68140-42-1;
InChIKey    AWVHRDYKXCUVBI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          312.438;      // g/mol [origin=calculated method=formula-sum]
Tc          1005.95;      // K   [origin=predictive method=joback]
Pc          21.178;      // bar [origin=predictive method=joback]
omega       1.6455;      // -   [origin=predictive method=lee-kesler]
Tb          821.36;      // K   [origin=predictive method=joback]
HvapTb      101727.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (104.698 1.00286 -0.0001432 -1.577e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group OH; count 3; } { group CH3O; count 3; } { group CH2N; count 2; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group OH; count 3; } { group O; count 3; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-[bis(hydroxymethyl)amino]ethyl-(3-trimethoxysilylpropyl)amino]methanol" "10-oxa-2,5-diaza-9-silaundecan-1-ol, 2,5-bis(hydroxymethyl)-9,9-dimethoxy-" "2-oxa-7,10-diaza-3-silaundecan-11-ol, 7,10-bis(hydroxymethyl)-3,3-dimethoxy-" "formaldehyde, adduct with n-(beta-aminoethyl)-omega-aminopropyltrimethoxysilane" );
standardThermochemistry
{
    dHf_298   -1100280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     929.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-566920.0
}
