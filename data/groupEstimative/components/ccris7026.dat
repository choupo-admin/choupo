/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 7026  (C20H14O2, CAS 151258-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris7026;
formula     C20H14O2;
CAS         151258-40-1;
InChIKey    RRKIIWROEQLDQF-UHFFFAOYSA-N;
MW          286.33;      // g/mol [origin=calculated method=formula-sum]
Tc          1172.87;      // K   [origin=predictive method=joback]
Pc          28.414;      // bar [origin=predictive method=joback]
omega       1.6649;      // -   [origin=predictive method=lee-kesler]
Tb          942.90;      // K   [origin=predictive method=joback]
HvapTb      102748.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-114.93 1.7778 -0.0015094 5.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH=C; count 1; } { group ACH; count 9; } { group AC; count 6; } { group ACCH; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 8; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzo(j)fluoranthen-4,5-diol, 4,5-dihydro-" "benzo[j]fluoranthene-8,9-diol,8,9-dihydro-" "4,5-dihydro-4,5-dihydroxybenzo(j)fluoranthene" "benzo(j)fluoranthene-4,5-diol, 4,5-dihydro-" "benzo[j]fluoranthene-4,5-diol, 4,5-dihydro-" "benzo[j]fluoranthene-4,5-diol,4,5-dihydro- (9ci)" );
gibbsFormation
{
    dHf_298   61890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=302860.0
    phase     gas;
}
