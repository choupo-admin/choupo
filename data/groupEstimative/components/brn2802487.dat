MW          193.365;      // g/mol [origin=calculated method=formula-sum]
Tc          698.00;      // K   [origin=predictive method=joback]
Pc          23.451;      // bar [origin=predictive method=joback]
omega       0.3961;      // -   [origin=predictive method=lee-kesler]
Tb          491.80;      // K   [origin=predictive method=joback]
HvapTb      44693.0;      // J/mol [origin=predictive method=joback]

