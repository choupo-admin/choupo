}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3N; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
