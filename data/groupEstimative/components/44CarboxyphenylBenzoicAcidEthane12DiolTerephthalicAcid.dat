/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-carboxyphenyl)benzoic acid;ethane-1,2-diol;terephthalic acid  (C24H22O10, CAS 72986-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44CarboxyphenylBenzoicAcidEthane12DiolTerephthalicAcid;
formula     C24H22O10;
CAS         72986-53-9;
InChIKey    RNHZPWUXQCALTF-UHFFFAOYSA-N;
MW          470.43;      // g/mol [origin=calculated method=formula-sum]
Tc          2080.76;      // K   [origin=predictive method=joback]
Pc          20.475;      // bar [origin=predictive method=joback]
omega       0.9814;      // -   [origin=predictive method=lee-kesler]
Tb          1612.90;      // K   [origin=predictive method=joback]
HvapTb      180434.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.872 1.7274 -0.00069588 -2.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 6; } { group COOH; count 4; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH; count 2; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1,1'-biphenyl)-4,4'-dicarboxylic acid, 1,4-benzenedicarboxylic acid, 1,2-ethanediol polymer" "(1,1'-biphenyl)-4,4'-dicarboxylic acid, polymer with 1,4-benzenedicarboxylic acid and 1,2-ethanediol" );
standardThermochemistry
{
    dHf_298   -1792290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1282.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1399260.0
}
