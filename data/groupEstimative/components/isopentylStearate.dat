/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopentyl stearate  (C23H46O2, CAS 627-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopentylStearate;
formula     C23H46O2;
CAS         627-88-3;
InChIKey    WDQOEAOLRIMQDA-UHFFFAOYSA-N;
MW          354.619;      // g/mol [origin=calculated method=formula-sum]
Tc          960.85;      // K   [origin=predictive method=joback]
Pc          8.585;      // bar [origin=predictive method=joback]
omega       0.8129;      // -   [origin=predictive method=lee-kesler]
Tb          783.62;      // K   [origin=predictive method=joback]
HvapTb      73811.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.708 2.13996 -0.001136 2.049e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 17; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 18; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutyl octadecanoate" "3-methylbutyl stearate" "3-methyl-2-butenyl octadecanoate" "octadecanoic acid,3-methylbutyl ester" "we(4:1(2)(3me)/18:0)" "stearicacid, isopentyl ester (8ci); isopentyl alcohol, stearate (8ci); 3-methylbutylstearate" );
gibbsFormation
{
    dHf_298   -840610.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1093.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170030.0
    phase     gas;
}
