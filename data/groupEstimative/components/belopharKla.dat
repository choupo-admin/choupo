/*--------------------------------*- Choupo -*-----------------------*\
  Component: belophar kla  (C16H12O4, CAS 734-88-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        belopharKla;
formula     C16H12O4;
CAS         734-88-3;
InChIKey    FYOZSKRVTISLHE-UHFFFAOYSA-N;
MW          268.268;      // g/mol [origin=calculated method=formula-sum]
Tc          977.26;      // K   [origin=predictive method=joback]
Pc          24.053;      // bar [origin=predictive method=joback]
omega       0.9825;      // -   [origin=predictive method=lee-kesler]
Tb          749.02;      // K   [origin=predictive method=joback]
HvapTb      72268.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.569 1.28412 -0.00093348 2.585e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=C; count 1; } { group ACH; count 6; } { group AC; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 5; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-oxidanylidenebenzo[f]chromene-2-carboxylate" "ethyl 3-oxo-3h-benzo[f]chromene-2-carboxylate" "ethyl 5,6-benzocoumarin-3-carboxylate" "ethyl 3-oxobenzo[f]chromene-2-carboxylate" "5,6-benzocumarin-3-carbonic acid ethyl ether" "5,6-benzocoumarin-3-carboxylic acid ethyl ester" "3-carboxy-2h-naphtho(2,1-b)pyran-2-one, ethyl ester" "3-oxo-3h-naphtho(2,1-b)pyran-2-carboxylic acid ethyl ester" "3h-naphtho(2,1-b)pyran-2-carboxylic acid, 3-oxo-, ethyl ester" "3h-naphtho[2,1-b]pyran-2-carboxylic acid, 3-oxo-, ethyl ester" "3-oxo-3h-benzo[f]chromene-2-carboxylic acid ethyl ester" "3h-naphtho[2,1-b]pyran-2-carboxylicacid, 3-oxo-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -457860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     542.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-236210.0
}
