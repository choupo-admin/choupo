/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-aminoethyl)butane-1,4-diamine  (C6H17N3, CAS 35513-87-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2AminoethylButane14Diamine;
formula     C6H17N3;
CAS         35513-87-2;
InChIKey    VRPPEXGZBZBARW-UHFFFAOYSA-N;
MW          131.223;      // g/mol [origin=calculated method=formula-sum]
Tc          726.80;      // K   [origin=predictive method=joback]
Pc          35.986;      // bar [origin=predictive method=joback]
omega       0.8376;      // -   [origin=predictive method=lee-kesler]
Tb          532.11;      // K   [origin=predictive method=joback]
HvapTb      56668.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.206 0.7738 -0.000438 9.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2NH2; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group NH2; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n'-(2-azanylethyl)butane-1,4-diamine" "n-(2-aminoethyl)-1,4-diaminobutane" "1,4-butanediamine, n-(2-aminoethyl)-" "1,4-butanediamine, n1-(2-aminoethyl)-" "1-(aminoethyl)amino-4-aminobutane" "pa(24)" "n-(2-aminoethyl)-1,4-butanediamine" "n'-(2-aminoethyl)butane-1,4-diamine" "n-(2-aminoethyl)tetramethylene diamine" );
standardThermochemistry
{
    dHf_298   -46120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221930.0
}
