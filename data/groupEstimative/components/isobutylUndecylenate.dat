/*--------------------------------*- Choupo -*-----------------------*\
  Component: isobutyl undecylenate  (C15H28O2, CAS 5421-27-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isobutylUndecylenate;
formula     C15H28O2;
CAS         5421-27-2;
InChIKey    YXJSBTYPYXKWDB-UHFFFAOYSA-N;
MW          240.387;      // g/mol [origin=calculated method=formula-sum]
Tc          767.11;      // K   [origin=predictive method=joback]
Pc          14.759;      // bar [origin=predictive method=joback]
omega       0.7954;      // -   [origin=predictive method=lee-kesler]
Tb          597.26;      // K   [origin=predictive method=joback]
HvapTb      55333.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.989 1.35994 -0.0007237 1.271e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methylpropyl undec-10-enoate" "10-undecenoic acid, 2-methylpropyl ester" "isobutyl undec-10-enoate" "10-undecenoic acid,2-methylpropyl ester" );
standardThermochemistry
{
    dHf_298   -550060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     777.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-149550.0
}
