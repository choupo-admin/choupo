/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-dodecyn-1-ol  (C12H22O, CAS 71084-08-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Dodecyn1Ol;
formula     C12H22O;
CAS         71084-08-7;
InChIKey    MIDXCKJJIFQOLT-UHFFFAOYSA-N;
MW          182.307;      // g/mol [origin=calculated method=formula-sum]
Tc          748.83;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.9554;      // -   [origin=predictive method=lee-kesler]
Tb          575.34;      // K   [origin=predictive method=joback]
HvapTb      61137.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.829 1.02802 -0.00056726 1.2038e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group tC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-9-yn-1-ol" "9-dodecyn-1-ol;timtec-bb sbb008814;9-dodecyn-1-ol, 98+%;9-dodecyn-1-ol,97%;9-dodecyne-1-ol" );
standardThermochemistry
{
    dHf_298   -170940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     646.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=116140.0
}
