/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-acetoxyethyl)-n-ethylaniline  (C12H17NO2, CAS 38954-40-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2AcetoxyethylNEthylaniline;
formula     C12H17NO2;
CAS         38954-40-4;
InChIKey    GPCCXIVDZANEJZ-UHFFFAOYSA-N;
MW          207.273;      // g/mol [origin=calculated method=formula-sum]
Tc          772.39;      // K   [origin=predictive method=joback]
Pc          24.124;      // bar [origin=predictive method=joback]
omega       0.6996;      // -   [origin=predictive method=lee-kesler]
Tb          571.50;      // K   [origin=predictive method=joback]
HvapTb      54032.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.207 1.13404 -0.0006782 1.374e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 5; } { group AC; count 1; } { group CH3COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[ethyl(phenyl)amino]ethyl ethanoate" "2-(ethyl(phenyl)amino)ethyl acetate" "ethanol, 2-(ethylphenylamino)-, 1-acetate" "ethanol, 2-(ethylphenylamino)-, acetate (ester)" "2-(ethylphenylamino)ethyl acetate" "n-ethyl-n-acetoxyethyl aniline" "2-(n-ethylanilino)ethyl acetate" "2-(ethylphenylamino)ethyl acetate;2-(ethyl-phenyl-amino)ethyl acetate;ethanol, 2-(ethylphenylamino)-, acetate (ester);" );
standardThermochemistry
{
    dHf_298   -304230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     584.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-37020.0
}
