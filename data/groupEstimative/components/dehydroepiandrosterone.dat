/*--------------------------------*- Choupo -*-----------------------*\
  Component: dehydroepiandrosterone  (C19H28O2, CAS 53-43-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dehydroepiandrosterone;
formula     C19H28O2;
CAS         53-43-0;
InChIKey    FMGSKLZLMKYGDP-USOAJAOKSA-N;
MW          288.431;      // g/mol [origin=calculated method=formula-sum]
Tc          1074.38;      // K   [origin=predictive method=joback]
Pc          20.199;      // bar [origin=predictive method=joback]
omega       1.0320;      // -   [origin=predictive method=lee-kesler]
Tb          837.91;      // K   [origin=predictive method=joback]
HvapTb      77360.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-265.26 2.64544 -0.00231964 8.783e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 4; } { group C; count 2; } { group CH=C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,8r,9s,10r,13s,14s)-10,13-dimethyl-3-oxidanyl-1,2,3,4,7,8,9,11,12,14,15,16-dodecahydrocyclopenta[a]phenanthren-17-one" "dhea" "androstenolone" "dehydroisoandrosterone" "diandrone" "prasterone" "psicosterone" "trans-dehydroandrosterone" "diandron" "17-hormoforin" "17-chetovis" "prestara" );
standardThermochemistry
{
    dHf_298   -428910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=26120.0
}
