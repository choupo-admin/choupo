/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-tribromoiodobenzene  (C6H2Br3I, CAS 21521-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Tribromoiodobenzene;
formula     C6H2Br3I;
CAS         21521-51-7;
InChIKey    BEUHDGOCAVMIQO-UHFFFAOYSA-N;
MW          440.694;      // g/mol [origin=calculated method=formula-sum]
Tc          977.40;      // K   [origin=predictive method=joback]
Pc          57.132;      // bar [origin=predictive method=joback]
omega       0.6288;      // -   [origin=predictive method=lee-kesler]
Tb          670.12;      // K   [origin=predictive method=joback]
HvapTb      61890.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.69 0.47 -0.00042828 1.532e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 4; } { group I; count 1; } { group Br; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Br; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(bromanyl)-2-iodanyl-benzene" "1,3,5-tribromo-2-iodobenzene" "benzene,1,3,5-tribromo-2-iodo-" "benzene, 1-iodo-2,4,6-tribromo-" "benzene, 1-iodo-2,4,6-tribromo-," "iodo-2,4,6-tribromo benzene" );
standardThermochemistry
{
    dHf_298   190810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=184240.0
}
