/*--------------------------------*- Choupo -*-----------------------*\
  Component: .alpha.-bromo-.gamma.-valerolactone  (C5H7BrO2, CAS 25966-39-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaBromoGammaValerolactone;
formula     C5H7BrO2;
CAS         25966-39-6;
InChIKey    FLOKBGAYTGLYGR-UHFFFAOYSA-N;
MW          179.013;      // g/mol [origin=calculated method=formula-sum]
Tc          649.65;      // K   [origin=predictive method=joback]
Pc          42.887;      // bar [origin=predictive method=joback]
omega       0.4591;      // -   [origin=predictive method=lee-kesler]
Tb          440.45;      // K   [origin=predictive method=joback]
HvapTb      40170.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.36 0.58662 -0.0003898 9.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 2; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanyl-5-methyl-oxolan-2-one" "3-bromo-5-methyldihydrofuran-2(3h)-one" ".alpha.-bromo-.gamma.-valerolactone(c,t)" "alpha-bromo-gamma-valerolactone, mixture of cis and trans" "alpha-bromo-gamma-valerolactone" "3-bromo-5-methyloxolan-2-one" "2-bromo-4-hydroxyvaleric acid " "a-lactone" "2(3h)-furanone, 3-bromodihydro-5-methyl-" "2-bromo-4-hydroxyvaleric acid gamma-lactone" "a-bromo-" "a-valerolactone, mixture of cis and trans" );
gibbsFormation
{
    dHf_298   -385020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     320.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-251790.0
    phase     gas;
}
