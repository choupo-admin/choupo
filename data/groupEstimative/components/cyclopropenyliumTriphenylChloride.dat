/*--------------------------------*- Choupo -*-----------------------*\
  Component: (cyclopropenylium,triphenyl-,chloride  (C21H15Cl, CAS 58090-78-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclopropenyliumTriphenylChloride;
formula     C21H15Cl;
CAS         58090-78-1;
InChIKey    JALDHEDTMTXAGO-UHFFFAOYSA-N;
MW          302.801;      // g/mol [origin=calculated method=formula-sum]
Tc          1096.40;      // K   [origin=predictive method=joback]
Pc          22.741;      // bar [origin=predictive method=joback]
omega       0.6879;      // -   [origin=predictive method=lee-kesler]
Tb          813.65;      // K   [origin=predictive method=joback]
HvapTb      73931.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-168.88 2.0367 -0.0018386 6.759e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 15; } { group AC; count 3; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?46:1
    joback ( { group C_ring; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 5; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-chloranyl-2,3-diphenyl-cycloprop-2-en-1-yl)benzene" "(1-chloro-2,3-diphenylcycloprop-2-en-1-yl)benzene" );
gibbsFormation
{
    dHf_298   339960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     617.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=517200.0
    phase     gas;
}
