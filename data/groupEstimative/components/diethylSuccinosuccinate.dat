/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl succinosuccinate  (C12H16O6, CAS 787-07-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylSuccinosuccinate;
formula     C12H16O6;
CAS         787-07-5;
InChIKey    KSKWGMNRWCYVAT-UHFFFAOYSA-N;
MW          256.254;      // g/mol [origin=calculated method=formula-sum]
Tc          963.99;      // K   [origin=predictive method=joback]
Pc          22.292;      // bar [origin=predictive method=joback]
omega       0.9611;      // -   [origin=predictive method=lee-kesler]
Tb          741.12;      // K   [origin=predictive method=joback]
HvapTb      65734.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.992 0.79324 2.26e-05 -2.272e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH2CO; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group CdO_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2,5-bis(oxidanylidene)cyclohexane-1,4-dicarboxylate" "diethyl succinylsuccinate" "diethyl 2,5-dioxocyclohexane-1,4-dicarboxylate" "diethyl succinylo succinate" "2,5-dicarbethoxy-1,4-cyclohexanedione" "succinylsuccinic acid ethyl ester" "diethyl 2,5-dioxo-1,4-cyclohexanedicarboxylate" "2,4 cyclohexanedione" "2,4-cyclohexanedione" "diethyl 1,5-dicarboxylate" "diethyl 1,4-cyclohexanedione-2,5-dicarboxylate" "1, 2,5-dioxo-, diethyl ester" );
standardThermochemistry
{
    dHf_298   -1166990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     495.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-799020.0
}
