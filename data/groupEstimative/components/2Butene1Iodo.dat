/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butene, 1-iodo-  (C4H7I, CAS 627-24-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butene1Iodo;
formula     C4H7I;
CAS         627-24-7;
InChIKey    LOPHPAWGOMDGMA-UHFFFAOYSA-N;
MW          182.0;      // g/mol [origin=calculated method=formula-sum]
Tc          604.07;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.2256;      // -   [origin=predictive method=lee-kesler]
Tb          388.42;      // K   [origin=predictive method=joback]
HvapTb      33829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.239 0.44282 -0.000359 1.237e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH=CH; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH; count 2; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-iodanylbut-2-ene" "2-butene, 1-iodo-, (z)-" );
standardThermochemistry
{
    dHf_298   68200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     360.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=121140.0
}
