/*--------------------------------*- Choupo -*-----------------------*\
  Component: succinamide  (C4H8N2O2, CAS 110-14-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        succinamide;
formula     C4H8N2O2;
CAS         110-14-5;
InChIKey    SNCZNSNPXMPCGN-UHFFFAOYSA-N;
MW          116.12;      // g/mol [origin=calculated method=formula-sum]
Tc          761.43;      // K   [origin=predictive method=joback]
Pc          53.907;      // bar [origin=predictive method=joback]
omega       0.8602;      // -   [origin=predictive method=lee-kesler]
Tb          543.92;      // K   [origin=predictive method=joback]
HvapTb      59272.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.952 0.4516 -0.0002432 4.032e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CONH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CdO; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanediamide" "succindiamide" "succinic amide" "succinic acid diamide" "succinic diamide" "ethane-1,2-dicarboxamide" "succinamide(6ci,8ci);succindiamide;succinic acid diamide;succinic amide;" );
gibbsFormation
{
    dHf_298   -283470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-142140.0
    phase     gas;
}
