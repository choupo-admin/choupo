/*--------------------------------*- Choupo -*-----------------------*\
  Component: mesitaldehyde  (C10H12O, CAS 487-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H12O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        mesitaldehyde;
formula     C10H12O;
CAS         487-68-3;
InChIKey    HIKRJHFHGKZKRI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          148.205;      // g/mol [origin=calculated method=formula-sum]
Tc          654.21;      // K   [origin=predictive method=joback]
Pc          29.282;      // bar [origin=predictive method=joback]
omega       0.3406;      // -   [origin=predictive method=lee-kesler]
Tb          446.44;      // K   [origin=predictive method=joback]
HvapTb      39743.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.71 0.70456 -0.00050328 1.553e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-trimethylbenzaldehyde" "mesitylaldehyde" "benzaldehyde, 2,4,6-trimethyl-" "2-mesitylenecarboxaldehyde" "2-formylmesitylene" "mesitylenecarboxaldehyde" "2-formyl-1,3,5-trimethylbenzene" "2,6-trimethylbenzaldehyde" "benzaldehyde,4,6-trimethyl-" "2,4,6-trimethyl-benzaldehyde" );
standardThermochemistry
{
    dHf_298   28840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     501.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=160800.0
}
