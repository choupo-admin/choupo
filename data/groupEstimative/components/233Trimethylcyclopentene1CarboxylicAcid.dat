/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,3-trimethylcyclopentene-1-carboxylic acid  (C9H14O2, CAS 5587-63-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        233Trimethylcyclopentene1CarboxylicAcid;
formula     C9H14O2;
CAS         5587-63-3;
InChIKey    CVPXQMUHAZMTEO-UHFFFAOYSA-N;
MW          154.209;      // g/mol [origin=calculated method=formula-sum]
Tc          797.59;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.6820;      // -   [origin=predictive method=lee-kesler]
Tb          575.67;      // K   [origin=predictive method=joback]
HvapTb      53514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.79 1.15826 -0.0010516 4.158e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group COOH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopentene-1-carboxylicacid, 2,3,3-trimethyl-" );
standardThermochemistry
{
    dHf_298   -468800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     529.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-277250.0
}
