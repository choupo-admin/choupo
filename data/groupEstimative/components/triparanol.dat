/*--------------------------------*- Choupo -*-----------------------*\
  Component: triparanol  (C27H32ClNO2, CAS 78-41-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triparanol;
formula     C27H32ClNO2;
CAS         78-41-1;
InChIKey    SYHDSBBKRLVLFF-UHFFFAOYSA-N;
MW          438.008;      // g/mol [origin=calculated method=formula-sum]
Tc          1316.51;      // K   [origin=predictive method=joback]
Pc          12.692;      // bar [origin=predictive method=joback]
omega       1.1644;      // -   [origin=predictive method=lee-kesler]
Tb          1073.58;      // K   [origin=predictive method=joback]
HvapTb      108731.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.955 2.38096 -0.00156168 3.852e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 12; } { group AC; count 3; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH2O; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group C; count 1; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group Cl; count 1; } { group OH; count 1; } { group O; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-chlorophenyl)-1-[4-[2-(diethylamino)ethoxy]phenyl]-1-(4-methylphenyl)ethanol" "metasqualene" "mer 29" "valip" "triparanolo [dcit]" "triparanolum [inn-latin]" "triparanolum" "alpha-(p-chlorobenzyl)-4-diethylaminoethoxy-4'-methylbenzhydrol" "2-p-chlorophenyl-1-(p-(2-diethylaminoethoxy)phenyl)-1-p-tolylethanol" "1-(4-(2-(diethylamino)ethoxy)phenyl)-1-(p-tolyl)-2-(p-chlorophenyl)ethanol" "1-(4-(2-diethylaminoethoxy)phenyl)-1-p-tolyl-2-(4-chlorophenyl)ethanol" "1-(p-(beta-diethylaminoethoxy)phenyl)-1-(p-tolyl)-2-(p-chlorophenyl)ethanol" );
standardThermochemistry
{
    dHf_298   -166840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     942.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=344670.0
}
