/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetradecyl cyanide  (C15H29N, CAS 18300-91-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tetradecylCyanide;
formula     C15H29N;
CAS         18300-91-9;
InChIKey    KRKQHNVYOWTEQO-UHFFFAOYSA-N;
MW          223.404;      // g/mol [origin=calculated method=formula-sum]
Tc          819.58;      // K   [origin=predictive method=joback]
Pc          13.892;      // bar [origin=predictive method=joback]
omega       0.8476;      // -   [origin=predictive method=lee-kesler]
Tb          644.88;      // K   [origin=predictive method=joback]
HvapTb      59462.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.253 1.36362 -0.0007612 1.61e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 12; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 13; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadecanenitrile" "pentadecanonitrile" "pentadecannitril" "myristyl cyanide" "1-tetradecylcyanide; pentadecanonitrile; tetradecyl cyanide" );
standardThermochemistry
{
    dHf_298   -188050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     746.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=208600.0
}
