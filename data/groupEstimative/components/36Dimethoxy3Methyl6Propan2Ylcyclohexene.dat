/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-dimethoxy-3-methyl-6-propan-2-ylcyclohexene  (C12H22O2, CAS 59880-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Dimethoxy3Methyl6Propan2Ylcyclohexene;
formula     C12H22O2;
CAS         59880-81-8;
InChIKey    UMUMWRMLCKTGAC-UHFFFAOYSA-N;
MW          198.306;      // g/mol [origin=calculated method=formula-sum]
Tc          744.33;      // K   [origin=predictive method=joback]
Pc          22.719;      // bar [origin=predictive method=joback]
omega       0.4664;      // -   [origin=predictive method=lee-kesler]
Tb          533.08;      // K   [origin=predictive method=joback]
HvapTb      44848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.57 1.6468 -0.00148828 6.031e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 2; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH; count 1; } { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,6-dimethoxy-3-methyl-6-propan-2-yl-cyclohexene" "cyclohexene, 3,6-dimethoxy-3-methyl-6-(1-methylethyl)-, cis-" );
standardThermochemistry
{
    dHf_298   -438490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-126560.0
}
