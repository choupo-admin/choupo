/*--------------------------------*- Choupo -*-----------------------*\
  Component: anemonin  (C10H8O4, CAS 90921-11-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anemonin;
formula     C10H8O4;
CAS         90921-11-2;
InChIKey    JLUQTCXCAFSSLD-UHFFFAOYSA-N;
MW          192.17;      // g/mol [origin=calculated method=formula-sum]
Tc          793.48;      // K   [origin=predictive method=joback]
Pc          38.675;      // bar [origin=predictive method=joback]
omega       0.6749;      // -   [origin=predictive method=lee-kesler]
Tb          564.26;      // K   [origin=predictive method=joback]
HvapTb      50826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-191.35 1.8048 -0.00213316 9.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group C; count 2; } { group CH=CH; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group C_ring; count 2; } { group dCH_ring; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,7-dioxadispiro[4.0.4^{6}.2^{5}]dodeca-1,9-diene-3,8-dione" "anemone camphor" "pulsatilla camphor" "1,7-dioxadispiro[4.0.4.2]dodeca-3,9-diene-2,8-dione" "1,2-cyclobutanediacrylic acid, 1,2-dihydroxy-, di-gamma-lactone" "1,7-dioxadispiro(4.0.4.2)dodeca-3,9-diene-2,8-dione, trans-" "1,7-dioxadispiro(4.0.4.2)dodeca-3,9-diene-2,8-dione" );
gibbsFormation
{
    dHf_298   -493350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-336420.0
    phase     gas;
}
