/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-1-cyclohexene  (C6H9Br, CAS 2044-08-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo1Cyclohexene;
formula     C6H9Br;
CAS         2044-08-8;
InChIKey    QBUMXSSCYUMVAW-UHFFFAOYSA-N;
MW          161.042;      // g/mol [origin=calculated method=formula-sum]
Tc          662.26;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.3177;      // -   [origin=predictive method=lee-kesler]
Tb          431.40;      // K   [origin=predictive method=joback]
HvapTb      37077.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.84 0.6451 -0.00043064 1.114e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH=C; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanylcyclohexene" "cyclohexene, 1-bromo-" "1-bromocyclohexene" "1-bromo-cyclohexene" "1-bromocyclohex-1-ene" "1-bromo-1-cyclohexene;1-bromocyclohexene" );
standardThermochemistry
{
    dHf_298   -19870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     409.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66450.0
}
