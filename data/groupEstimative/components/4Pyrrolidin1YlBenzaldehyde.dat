/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(pyrrolidin-1-yl)benzaldehyde  (C11H13NO, CAS 51980-54-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H13NO (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4Pyrrolidin1YlBenzaldehyde;
formula     C11H13NO;
CAS         51980-54-2;
InChIKey    DATXHLPRESKQJK-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          175.231;      // g/mol [origin=calculated method=formula-sum]
Tc          712.52;      // K   [origin=predictive method=joback]
Pc          33.490;      // bar [origin=predictive method=joback]
omega       0.4052;      // -   [origin=predictive method=lee-kesler]
Tb          487.48;      // K   [origin=predictive method=joback]
HvapTb      43082.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-118.21 1.2102 -0.00103356 3.52e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-pyrrolidin-1-ylbenzaldehyde" "4-(1-pyrrolidinyl)benzaldehyde" "1-(4-formylphenyl)pyrrolidine" "4-(1-pyrrolidino)benzaldehyde" "4-(1-pyrrolidino)-benzaldehyde" "4-pyrrolidinylbenzaldehyde" "4-(1-pyrrolidine)benzaldehyde" "4-pyrrolidin-1-yl-benzaldehyde" );
gibbsFormation
{
    dHf_298   185650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355620.0
    phase     gas;
}
