/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-diethoxynon-2-ene  (C13H26O2, CAS 40564-00-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Diethoxynon2Ene;
formula     C13H26O2;
CAS         40564-00-9;
InChIKey    MUWPHRMERVXBEL-UHFFFAOYSA-N;
MW          214.349;      // g/mol [origin=calculated method=formula-sum]
Tc          715.13;      // K   [origin=predictive method=joback]
Pc          16.797;      // bar [origin=predictive method=joback]
omega       0.7134;      // -   [origin=predictive method=lee-kesler]
Tb          545.60;      // K   [origin=predictive method=joback]
HvapTb      48922.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.207 1.13836 -0.0005484 8.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 7; } { group CH; count 1; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-nonene, 1,1-diethoxy-" "trans-2-nonene-1-al diethyl acetal" );
standardThermochemistry
{
    dHf_298   -464150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     668.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73640.0
}
