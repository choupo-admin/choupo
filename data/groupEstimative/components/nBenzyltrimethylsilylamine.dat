/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-benzyltrimethylsilylamine  (C10H17NSi, CAS 14856-79-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H17NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nBenzyltrimethylsilylamine;
formula     C10H17NSi;
CAS         14856-79-2;
InChIKey    OVONARZNQIKMGQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          179.338;      // g/mol [origin=calculated method=formula-sum]
Tc          720.11;      // K   [origin=predictive method=joback]
Pc          26.191;      // bar [origin=predictive method=joback]
omega       0.4380;      // -   [origin=predictive method=lee-kesler]
Tb          506.65;      // K   [origin=predictive method=joback]
HvapTb      46860.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.499 0.74496 -0.0001852 -7.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2NH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-n-trimethylsilyl-methanamine" "silylamine, n-benzyl-1,1,1-trimethyl-" "n-(trimethylsilyl)benzylamine" "silanamine, 1,1,1-trimethyl-n-(phenylmethyl)-" "benzylamino-trimethylsilane" "(benzylamino)trimethylsilane" "1-phenyl-n-trimethylsilylmethanamine" "benzenemethanamine,n-(trimethylsilyl)-" "silanamine,1,1,1-trimethyl-n-(phenylmethyl)- (9ci); silylamine, n-benzyl-1,1,1-trimethyl-(6ci,8ci); (benzylamino)trimethylsilane; benzyl(trimethylsilyl)amine;n-(trimethylsilyl)benzylamine; n-benzyltrimethylsilylamine" );
gibbsFormation
{
    dHf_298   -71350.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     606.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=130360.0
    phase     gas;
}
