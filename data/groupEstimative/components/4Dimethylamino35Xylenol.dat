/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-dimethylamino-3,5-xylenol  (C10H15NO, CAS 6120-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Dimethylamino35Xylenol;
formula     C10H15NO;
CAS         6120-10-1;
InChIKey    GZPBVLUEICLBOA-UHFFFAOYSA-N;
MW          165.236;      // g/mol [origin=calculated method=formula-sum]
Tc          775.45;      // K   [origin=predictive method=joback]
Pc          33.412;      // bar [origin=predictive method=joback]
omega       0.6815;      // -   [origin=predictive method=lee-kesler]
Tb          558.10;      // K   [origin=predictive method=joback]
HvapTb      56511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.12 1.03448 -0.00078628 2.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 2; } { group ACOH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(dimethylamino)-3,5-dimethyl-phenol" "4-(dimethylamino)-3,5-dimethylphenol" "4-(dimethylamino)-3,5-xylenol" "phenol, 4-(dimethylamino)-3,5-dimethyl-" "3,5-xylenol, 4-(dimethylamino)-" "zectran phenol" );
gibbsFormation
{
    dHf_298   -145920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     469.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=82630.0
    phase     gas;
}
