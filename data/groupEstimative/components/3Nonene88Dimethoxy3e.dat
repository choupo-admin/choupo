/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-nonene, 8,8-dimethoxy-, (3e)-  (C11H22O2, CAS 71317-74-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Nonene88Dimethoxy3e;
formula     C11H22O2;
CAS         71317-74-3;
InChIKey    MZARQPPJRGXWQY-UHFFFAOYSA-N;
MW          186.295;      // g/mol [origin=calculated method=formula-sum]
Tc          675.41;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       0.5613;      // -   [origin=predictive method=lee-kesler]
Tb          497.05;      // K   [origin=predictive method=joback]
HvapTb      43562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.234 1.06828 -0.0006082 1.294e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group dCH; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8,8-dimethoxynon-3-ene" "3-nonene, 8,8-dimethoxy-, (3z)-" );
standardThermochemistry
{
    dHf_298   -426340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-85200.0
}
