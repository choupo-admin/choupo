/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-diethoxy-n,n-diethylbenzene-1,4-diamine  (C14H24N2O2, CAS 67828-52-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25DiethoxyNNDiethylbenzene14Diamine;
formula     C14H24N2O2;
CAS         67828-52-8;
InChIKey    ILVYHPABHVLWQB-UHFFFAOYSA-N;
MW          252.358;      // g/mol [origin=calculated method=formula-sum]
Tc          890.96;      // K   [origin=predictive method=joback]
Pc          19.666;      // bar [origin=predictive method=joback]
omega       0.9637;      // -   [origin=predictive method=lee-kesler]
Tb          691.35;      // K   [origin=predictive method=joback]
HvapTb      68524.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.954 1.13588 -0.00050188 4.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 3; } { group CH2O; count 2; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group O; count 2; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,5-diethoxy-n1,n1-diethyl-benzene-1,4-diamine" "1,4-benzenediamine, 2,5-diethoxy-n,n-diethyl-" "1,4-benzenediamine, 2,5-diethoxy-n1,n1-diethyl-" "n,n-diethyl-2,5-diethoxy-p-phenylenediamine" "2,5-diethoxy-1-n,1-n-diethylbenzene-1,4-diamine" );
gibbsFormation
{
    dHf_298   -293290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     666.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=117750.0
    phase     gas;
}
