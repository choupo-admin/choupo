/*--------------------------------*- Choupo -*-----------------------*\
  Component: ambucetamide  (C17H28N2O2, CAS 519-88-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ambucetamide;
formula     C17H28N2O2;
CAS         519-88-0;
InChIKey    WUSAVCGXMSWMQM-UHFFFAOYSA-N;
MW          292.423;      // g/mol [origin=calculated method=formula-sum]
Tc          984.42;      // K   [origin=predictive method=joback]
Pc          17.005;      // bar [origin=predictive method=joback]
omega       1.0848;      // -   [origin=predictive method=lee-kesler]
Tb          781.04;      // K   [origin=predictive method=joback]
HvapTb      77826.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.194 1.58096 -0.00089466 1.7576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } { group CH2N; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(dibutylamino)-2-(4-methoxyphenyl)ethanamide" "ambucetamid" "dibutamide" "meritin" "bersen" "dibutamid [german]" "ambucetamidum [inn-latin]" "2-dibutylamino-2-(p-methoxyphenyl)acetamide" "alpha-dibutyl-amino-p-methoxyphenylacetamide" "alpha-(dibutylamino)-4-methoxybenzeneacetamide" "2-(dibutylamino)-2-(4-methoxyphenyl)acetamide" "alpha-p-methoxyphenyl-alpha-di-n-butylaminoacetamide" );
standardThermochemistry
{
    dHf_298   -317910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=135910.0
}
