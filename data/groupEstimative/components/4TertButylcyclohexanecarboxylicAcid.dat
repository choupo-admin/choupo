/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylcyclohexanecarboxylic acid  (C11H20O2, CAS 943-29-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4TertButylcyclohexanecarboxylicAcid;
formula     C11H20O2;
CAS         943-29-3;
InChIKey    QVQKEGYITJBHRQ-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          830.40;      // K   [origin=predictive method=joback]
Pc          25.151;      // bar [origin=predictive method=joback]
omega       0.6550;      // -   [origin=predictive method=lee-kesler]
Tb          608.44;      // K   [origin=predictive method=joback]
HvapTb      56068.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-86.65 1.32106 -0.0008446 2.01e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-tert-butylcyclohexane-1-carboxylic acid" "trans-4-tert-butylcyclohexanecarboxylic acid" "cis-4-tert-butylcyclohexanecarboxylic acid" "trans-4-(tert-butyl)cyclohexanecarboxylic acid" "cyclohexanecarboxylic acid, 4-tert-butyl-, cis-" "cyclohexanecarboxylic acid, 4-tert-butyl-, trans-" "cyclohexanecarboxylic acid, 4-(1,1-dimethylethyl)-, cis-" "cyclohexanecarboxylic acid, 4-(1,1-dimethylethyl)-, trans-" "4-(tert-butyl)cyclohexanecarboxylic acid" "4-tert-butylcyclohexane carboxylic acid" "4-tert-butyl-1-cyclohexanecarboxylic acid" "u024" );
gibbsFormation
{
    dHf_298   -595410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     525.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-282590.0
    phase     gas;
}
