/*--------------------------------*- Choupo -*-----------------------*\
  Component: zeaxanthin  (C40H56O2, CAS 144-68-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        zeaxanthin;
formula     C40H56O2;
CAS         144-68-3;
InChIKey    JKQXZKUSFCKOGQ-QAYBQHTQSA-N;
MW          568.886;      // g/mol [origin=calculated method=formula-sum]
Tc          1752.93;      // K   [origin=predictive method=joback]
Pc          6.442;      // bar [origin=predictive method=joback]
omega       0.3045;      // -   [origin=predictive method=lee-kesler]
Tb          1384.60;      // K   [origin=predictive method=joback]
HvapTb      139104.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-295.85 4.4766 -0.0037992 1.3858e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group CH2; count 4; } { group CH; count 2; } { group C; count 2; } { group CH=CH; count 5; } { group CH=C; count 4; } { group OH; count 2; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group dCH; count 14; } { group dC; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 2; } { group dC_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r)-3,5,5-trimethyl-4-[(1e,3e,5e,7e,9e,11e,13e,15e,17e)-3,7,12,16-tetramethyl-18-[(4r)-2,6,6-trimethyl-4-oxidanyl-cyclohexen-1-yl]octadeca-1,3,5,7,9,11,13,15,17-nonaenyl]cyclohex-3-en-1-ol" "anchovyxanthin" "zeaxanthol" "xanthophyll 3" "beta,beta-carotene-3,3'-diol" "(3r,3'r)-beta,beta-carotene-3,3'-diol" "all-trans-zeaxanthin" "3r 3'r zeaxanthin" "3r,3'r-zeaxanthin" "all-trans-anchovyxanthin" "(3r,3'r)-zeaxanthin" "ambap144-68-3" );
standardThermochemistry
{
    dHf_298   10550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1633.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=743960.0
}
