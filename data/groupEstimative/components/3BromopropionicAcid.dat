/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromopropionic acid  (C3H5BrO2, CAS 590-92-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3BromopropionicAcid;
formula     C3H5BrO2;
CAS         590-92-1;
InChIKey    DHXNZYCXMFBMHE-UHFFFAOYSA-N;
MW          152.975;      // g/mol [origin=calculated method=formula-sum]
Tc          692.82;      // K   [origin=predictive method=joback]
Pc          55.033;      // bar [origin=predictive method=joback]
omega       0.6717;      // -   [origin=predictive method=lee-kesler]
Tb          479.91;      // K   [origin=predictive method=joback]
HvapTb      45871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.952 0.3778 -0.0002834 8.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group Br; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylpropanoic acid" "3-bromopropanoic acid" "propanoic acid, 3-bromo-" "beta-bromopropionic acid" "propionic acid, 3-bromo-" "2-carboxyethyl bromide" "beta-propionic acid" "beta-bromopropanoic acid" "b-bromopropionic acid" "a-bromopropionic acid" "3 - bromopropionic acid" "propanoicacid, 3-bromo-" );
gibbsFormation
{
    dHf_298   -429190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-355210.0
    phase     gas;
}
