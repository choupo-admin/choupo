/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-bromo-4,6-dichloroaniline  (C6H4BrCl2N, CAS 697-86-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Bromo46Dichloroaniline;
formula     C6H4BrCl2N;
CAS         697-86-9;
InChIKey    DTPADCOGQUOGHT-UHFFFAOYSA-N;
MW          240.909;      // g/mol [origin=calculated method=formula-sum]
Tc          852.98;      // K   [origin=predictive method=joback]
Pc          47.171;      // bar [origin=predictive method=joback]
omega       0.6189;      // -   [origin=predictive method=lee-kesler]
Tb          592.05;      // K   [origin=predictive method=joback]
HvapTb      59058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.89 0.4301 -0.00028828 7.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACNH2; count 1; } { group ACCl; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group Br; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-bromanyl-4,6-bis(chloranyl)aniline" "6-bromo-2,4-dichlorophenylamine" "benzenamine,2-bromo-4,6-dichloro-" "aniline,2-bromo-4,6-dichloro- (8ci);2,4-dichloro-6-bromoaniline;2-bromo-4,6-dichloroaniline;6-bromo-2,4-dichloroaniline;" );
gibbsFormation
{
    dHf_298   63590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     434.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=140070.0
    phase     gas;
}
