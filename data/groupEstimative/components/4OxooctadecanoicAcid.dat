/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-oxooctadecanoic acid  (C18H34O3, CAS 16694-30-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4OxooctadecanoicAcid;
formula     C18H34O3;
CAS         16694-30-7;
InChIKey    NARNRJNUUFXXBI-UHFFFAOYSA-N;
MW          298.467;      // g/mol [origin=calculated method=formula-sum]
Tc          998.29;      // K   [origin=predictive method=joback]
Pc          12.810;      // bar [origin=predictive method=joback]
omega       1.1226;      // -   [origin=predictive method=lee-kesler]
Tb          810.82;      // K   [origin=predictive method=joback]
HvapTb      79572.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.515 1.73662 -0.0010093 2.2196e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH2CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylideneoctadecanoic acid" "4-ketostearic acid" "stearic acid, 4-oxo-" "octadecanoic acid, 4-oxo- (7ci,8ci,9ci)" "4-keto stearic acid" "4-oxo-octadecanoic acid" "octadecanoic acid,4-oxo-" "4-oxo-stearic acid" "4-ketostearicacid; 4-oxooctadecanoic acid" );
standardThermochemistry
{
    dHf_298   -877700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     936.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-372150.0
}
