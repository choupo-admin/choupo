/*--------------------------------*- Choupo -*-----------------------*\
  Component: azelaic acid  (C9H16O4, CAS 123-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azelaicAcid;
formula     C9H16O4;
CAS         123-99-9;
InChIKey    BDJRBEYXGGNYIS-UHFFFAOYSA-N;
MW          188.223;      // g/mol [origin=calculated method=formula-sum]
Tc          893.07;      // K   [origin=predictive method=joback]
Pc          27.585;      // bar [origin=predictive method=joback]
omega       1.2526;      // -   [origin=predictive method=lee-kesler]
Tb          696.54;      // K   [origin=predictive method=joback]
HvapTb      69956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.907 0.9604 -0.000611 1.519e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanedioic acid" "finacea" "azelex" "anchoic acid" "skinoren" "lepargylic acid" "1,7-heptanedicarboxylic acid" "finevin" "heptanedicarboxylic acid" "1,9-nonanedioic acid" "acide azelaique" "n-nonanedioic acid" );
gibbsFormation
{
    dHf_298   -929630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-662920.0
    phase     gas;
}
