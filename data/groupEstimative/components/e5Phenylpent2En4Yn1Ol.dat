/*--------------------------------*- Choupo -*-----------------------*\
  Component: (e)-5-phenylpent-2-en-4-yn-1-ol  (C11H10O, CAS 40317-08-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        e5Phenylpent2En4Yn1Ol;
formula     C11H10O;
CAS         40317-08-6;
InChIKey    JSNIMQCVEHRHSB-QHHAFSJGSA-N;
MW          158.2;      // g/mol [origin=calculated method=formula-sum]
Tc          805.50;      // K   [origin=predictive method=joback]
Pc          37.226;      // bar [origin=predictive method=joback]
omega       0.7760;      // -   [origin=predictive method=lee-kesler]
Tb          583.30;      // K   [origin=predictive method=joback]
HvapTb      61145.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.349 0.8741 -0.00062786 1.8138e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH; count 2; } { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-penten-4-yn-1-ol, 5-phenyl-, (e)-" );
gibbsFormation
{
    dHf_298   203450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.11;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=300350.0
    phase     gas;
}
