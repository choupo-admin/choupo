/*--------------------------------*- Choupo -*-----------------------*\
  Component: bicyclohexyl, 2-ethyl-, cis-  (C14H26, CAS 50991-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bicyclohexyl2EthylCis;
formula     C14H26;
CAS         50991-12-3;
InChIKey    UGQREFNYSITUMG-UHFFFAOYSA-N;
MW          194.362;      // g/mol [origin=calculated method=formula-sum]
Tc          777.99;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       0.4011;      // -   [origin=predictive method=lee-kesler]
Tb          554.35;      // K   [origin=predictive method=joback]
HvapTb      47307.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.109 1.55152 -0.0008444 1.464e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-2-ethyl-cyclohexane" "1,1'-bicyclohexyl, 2-ethyl-, cis-" "1,1'-bicyclohexyl, 2-ethyl-, trans-" "bicyclohexyl, 2-ethyl-, trans-" "1-cyclohexyl-2-ethylcyclohexane" "(1s,2r)-1-cyclohexyl-2-ethylcyclohexane" );
gibbsFormation
{
    dHf_298   -243990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     597.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=108190.0
    phase     gas;
}
