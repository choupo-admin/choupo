/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n,n',n'-tetra(2-hydroxy-3-(methacryloyloxy)propyl)benzenedimethanamine  (C22H26N2O6, CAS 72928-58-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        nNNNTetra2Hydroxy3MethacryloyloxyPropylBenzenedimethanamine;
formula     C22H26N2O6;
CAS         72928-58-6;
InChIKey    VHVHVKYQOWSJOL-UHFFFAOYSA-N;
role        radical;
MW          414.458;      // g/mol [origin=calculated method=formula-sum]
Tc          1282.25;      // K   [origin=predictive method=joback]
Pc          17.390;      // bar [origin=predictive method=joback]
omega       1.4699;      // -   [origin=predictive method=lee-kesler]
Tb          1047.20;      // K   [origin=predictive method=joback]
HvapTb      113939.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-184.95 2.93604 -0.00274616 1.053e-06);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH2; count 4; } { group dC; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 2; } { group COO; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propenoic acid, 2-methyl-, 1,1'-(phenylenebis(methylenenitrilobis(2-hydroxy-3,1-propanediyl))) ester" "2-propenoic acid, 2-methyl-, phenylenebis(methylenenitrilobis(2-hydroxy-3,1-propanediyl)) ester" );
standardThermochemistry
{
    dHf_298   -554770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1003.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-69170.0
}
