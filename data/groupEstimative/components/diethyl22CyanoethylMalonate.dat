/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2-(2-cyanoethyl)malonate  (C10H15NO4, CAS 17216-62-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl22CyanoethylMalonate;
formula     C10H15NO4;
CAS         17216-62-5;
InChIKey    YJJLOESDBPRZIP-UHFFFAOYSA-N;
MW          213.233;      // g/mol [origin=calculated method=formula-sum]
Tc          839.66;      // K   [origin=predictive method=joback]
Pc          20.946;      // bar [origin=predictive method=joback]
omega       0.9336;      // -   [origin=predictive method=lee-kesler]
Tb          646.48;      // K   [origin=predictive method=joback]
HvapTb      62758.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (59.934 0.78494 -0.0003032 -1.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group CH2CN; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group COO; count 2; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-(2-cyanoethyl)propanedioate" "diethyl (2-cyanoethyl)malonate" "diethyl(2-cyanoethyl)malonate" "diethyl 2-(2-cyanoethyl)-malonate" "diethyl2-(2-cyanoethyl)malonate" "diethyl 2-(2-cyanoethyl)propane-1,3-dioate" "(2-cyanoethyl)malonic acid diethyl ester" "1,3-diethyl 2-(2-cyanoethyl)propanedioate" "propanedioic acid,2-(2-cyanoethyl)-, 1,3-diethyl ester" "3-cyano-2-methylpyridine;3-pyridinecarbonitrile, 2-methyl-" );
gibbsFormation
{
    dHf_298   -724690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-456680.0
    phase     gas;
}
