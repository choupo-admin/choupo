/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentacyclo[4.2.0.02,5.03,8.04,7]octanecarboxylic acid (7ci,9ci)  (C9H8O2, CAS 53578-15-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pentacyclo420025038047OctanecarboxylicAcid7ci9ci;
formula     C9H8O2;
CAS         53578-15-7;
InChIKey    NVBIDTXRBMYRGD-UHFFFAOYSA-N;
MW          148.161;      // g/mol [origin=calculated method=formula-sum]
Tc          753.23;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.7618;      // -   [origin=predictive method=lee-kesler]
Tb          541.07;      // K   [origin=predictive method=joback]
HvapTb      49075.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-248.23 1.9437 -0.0023306 1.0431e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 7; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 7; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cubane-1-carboxylic acid" "pentacyclo[4.2.0.02,5.03,8.04,7]octanecarboxylic acid" );
gibbsFormation
{
    dHf_298   -218020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -88.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=40820.0
    phase     gas;
}
