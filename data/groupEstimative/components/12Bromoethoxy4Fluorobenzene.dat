/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(2-bromoethoxy)-4-fluorobenzene  (C8H8BrFO, CAS 332-48-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Bromoethoxy4Fluorobenzene;
formula     C8H8BrFO;
CAS         332-48-9;
InChIKey    JXSPKRUNMHMICQ-UHFFFAOYSA-N;
MW          219.053;      // g/mol [origin=calculated method=formula-sum]
Tc          717.59;      // K   [origin=predictive method=joback]
Pc          36.159;      // bar [origin=predictive method=joback]
omega       0.5508;      // -   [origin=predictive method=lee-kesler]
Tb          502.15;      // K   [origin=predictive method=joback]
HvapTb      44368.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.792 0.6122 -0.00035236 6.95e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group Br; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(2-bromoethyloxy)-4-fluoranyl-benzene" "4-(2-bromoethoxy)fluorobenzene" "4-fluorophenoxy-ethylbromide" "4-fluorophenoxyethylbromide" "2-bromo-1-(4-fluorophenoxy)ethane" "4-fluorophenoxyethyl bromide" "2-bromoethyl 4-fluorophenyl ether" "(p-fluorophenoxy)ethylbromide" "benzene,1-(2-bromoethoxy)-4-fluoro-" "2-(4-fluorophenoxy)ethyl bromide" "benzene, 1-(2-bromoethoxy)-4-fluoro-" "phenetole, b-bromo-p-fluoro- (6ci,7ci,8ci);1-bromo-2-(4-fluorophenoxy)ethane;2-(4-fluorophenoxy)ethylbromide;b-bromo-p-fluorophenetole;" );
gibbsFormation
{
    dHf_298   -285390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166230.0
    phase     gas;
}
