/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,6-dimethyl-1,10-phenanthroline  (C14H12N2, CAS 3002-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        56Dimethyl110Phenanthroline;
formula     C14H12N2;
CAS         3002-81-1;
InChIKey    BRPQDJPJBCQFSR-UHFFFAOYSA-N;
MW          208.264;      // g/mol [origin=calculated method=formula-sum]
Tc          974.47;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.7030;      // -   [origin=predictive method=lee-kesler]
Tb          706.90;      // K   [origin=predictive method=joback]
HvapTb      66720.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.61 1.13656 -0.00085984 2.72e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH3; count 2; } { group C5H3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group Nd_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,10-phenanthroline, 5,6-dimethyl-" "5,6-dimethyl-o-phenanthroline;" "brpqdjpjbcqfsr-uhfffaoysa-" "5,6-dimethylpyridino[3,2-h]quinoline" );
standardThermochemistry
{
    dHf_298   317550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     384.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=517920.0
}
