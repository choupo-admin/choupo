/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(trimethylsilyl)-1-pentyne  (C8H16Si, CAS 18270-17-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H16Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Trimethylsilyl1Pentyne;
formula     C8H16Si;
CAS         18270-17-2;
InChIKey    CABCDUQQPBAHEE-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          140.301;      // g/mol [origin=calculated method=formula-sum]
Tc          587.40;      // K   [origin=predictive method=joback]
Pc          26.407;      // bar [origin=predictive method=joback]
omega       0.2223;      // -   [origin=predictive method=lee-kesler]
Tb          393.04;      // K   [origin=predictive method=joback]
HvapTb      35848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (53.992 0.40788 9.554e-05 -1.5422e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C_C; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl(pent-1-ynyl)silane" "1-trimethylsilyl-1-pentyne" "1-pentyn-1-yltrimethylsilane" "1-tms-1-pentyne" "trimethyl(pent-1-yn-1-yl)silane" "silane,trimethyl-1-pentynyl- (6ci,7ci,8ci,9ci);1-(trimethylsilyl)-1-pentyne;silane,trimethyl-1-pentynyl- (6ci,7ci,8ci,9ci);propyl(trimethylsilyl)acetylene;trimethyl-1-pentynylsilane;propyl(trimethylsilyl)acetylene;" );
gibbsFormation
{
    dHf_298   -47770.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114520.0
    phase     gas;
}
