/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanal, pentafluoro-  (C3HF5O, CAS 422-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanalPentafluoro;
formula     C3HF5O;
CAS         422-06-0;
InChIKey    IRPGOXJVTQTAAN-UHFFFAOYSA-N;
MW          148.03;      // g/mol [origin=calculated method=formula-sum]
Tc          454.06;      // K   [origin=predictive method=joback]
Pc          38.151;      // bar [origin=predictive method=joback]
omega       0.3987;      // -   [origin=predictive method=lee-kesler]
Tb          306.79;      // K   [origin=predictive method=joback]
HvapTb      22315.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.93 0.5739 -0.000558 1.942e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CHO; count 1; } { group CF3; count 1; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group F; count 5; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,3,3,3-pentakis(fluoranyl)propanal" "propionaldehyde, pentafluoro-" "2,2,3,3,3-pentafluoropropanal" "pentafluoropropionaldehyde hydrate" "pentafluoropropionaldehyde" "1,1-propanediol,2,2,3,3,3-pentafluoro-" "pentafluoropropionaldehyde hydrate;pentafluoropropionaldehyde monohydrate;2,2,3,3,3-pentafluoro-1,1-propanediol;2,2,3,3,3-pentafluoro-1-propanediol;2,2,3,3,3-pentafluoropropane-1,1-diol;1h-pentafluoropropane-1,1-diol" );
standardThermochemistry
{
    dHf_298   -1188880.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1093510.0
}
