/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloro-3,7,11-trimethyldodeca-2,6,10-triene  (C15H25Cl, CAS 67023-84-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloro3711Trimethyldodeca2610Triene;
formula     C15H25Cl;
CAS         67023-84-1;
InChIKey    BJVUJIDTICYHLL-UHFFFAOYSA-N;
MW          240.815;      // g/mol [origin=calculated method=formula-sum]
Tc          783.90;      // K   [origin=predictive method=joback]
Pc          15.697;      // bar [origin=predictive method=joback]
omega       0.6003;      // -   [origin=predictive method=lee-kesler]
Tb          592.35;      // K   [origin=predictive method=joback]
HvapTb      53483.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-39.475 1.49538 -0.0010709 3.239e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH=C; count 3; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group dCH; count 3; } { group dC; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-3,7,11-trimethyl-dodeca-2,6,10-triene" "2,6,10-dodecatriene, 1-chloro-3,7,11-trimethyl-" "2,6,10-dodecatriene, 1-chloro-3,7,11-trimethyl-, (z,e)-" "2,6,10-dodecatriene, 1-chloro-3,7,11-trimethyl-, (2e,6e)-" );
standardThermochemistry
{
    dHf_298   -46380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     741.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278500.0
}
