/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethylolpropane tris(3-aziridinyl-2-methylpropanoate)  (C24H41N3O6, CAS 63870-28-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylolpropaneTris3Aziridinyl2Methylpropanoate;
formula     C24H41N3O6;
CAS         63870-28-0;
InChIKey    AQYCJIBMNCSKNS-VAMGGRTRSA-N;
MW          467.607;      // g/mol [origin=calculated method=formula-sum]
Tc          1197.25;      // K   [origin=predictive method=joback]
Pc          10.708;      // bar [origin=predictive method=joback]
omega       1.0263;      // -   [origin=predictive method=lee-kesler]
Tb          977.57;      // K   [origin=predictive method=joback]
HvapTb      95058.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-157.473 3.19568 -0.0024832 7.579e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 10; } { group CH; count 3; } { group C; count 1; } { group CH2N; count 3; } { group COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 7; } { group CH; count 3; } { group C; count 1; } { group CH2_ring; count 6; } { group COO; count 3; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis[[(2r)-3-(aziridin-1-yl)-2-methyl-propanoyl]oxymethyl]butyl (2r)-3-(aziridin-1-yl)-2-methyl-propanoate" "1-aziridinepropanoic acid, alpha-methyl-, 1,1'-(2-((3-(1-aziridinyl)-2-methyl-1-oxopropoxy)methyl)-2-ethyl-1,3-propanediyl) ester" "1-aziridinepropanoic acid, alpha-methyl-, 2-((3-(1-aziridinyl)-2-methyl-1-oxopropoxy)methyl)-2-ethyl-1,3-propanediyl ester" "2,2-bis[[(2r)-3-(aziridin-1-yl)-2-methylpropanoyl]oxymethyl]butyl (2r)-3-(aziridin-1-yl)-2-methylpropanoate" );
standardThermochemistry
{
    dHf_298   -1014630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1022.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-210370.0
}
