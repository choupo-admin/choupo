/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dichlorotetradecanoic acid  (C14H26Cl2O2, CAS 93347-74-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DichlorotetradecanoicAcid;
formula     C14H26Cl2O2;
CAS         93347-74-1;
InChIKey    ZBCCODJDJLXMQT-UHFFFAOYSA-N;
MW          297.26;      // g/mol [origin=calculated method=formula-sum]
Tc          929.24;      // K   [origin=predictive method=joback]
Pc          15.648;      // bar [origin=predictive method=joback]
omega       1.0176;      // -   [origin=predictive method=lee-kesler]
Tb          737.06;      // K   [origin=predictive method=joback]
HvapTb      71396.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.929 1.52402 -0.001023 2.733e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group COOH; count 1; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group C; count 1; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(chloranyl)tetradecanoic acid" );
gibbsFormation
{
    dHf_298   -722790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     782.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-297930.0
    phase     gas;
}
