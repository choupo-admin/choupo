/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-diphenylhexane  (C18H22, CAS 1087-49-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Diphenylhexane;
formula     C18H22;
CAS         1087-49-6;
InChIKey    DVGPMIRVCZNXMD-UHFFFAOYSA-N;
MW          238.374;      // g/mol [origin=calculated method=formula-sum]
Tc          886.42;      // K   [origin=predictive method=joback]
Pc          19.169;      // bar [origin=predictive method=joback]
omega       0.6656;      // -   [origin=predictive method=lee-kesler]
Tb          664.80;      // K   [origin=predictive method=joback]
HvapTb      60214.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.284 1.556 -0.0010178 2.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 10; } { group ACCH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-phenylhexylbenzene" "hexane, 1,6-diphenyl-" "benzene, 1,1'-(1,6-hexanediyl)bis-" "hexane,6-diphenyl-" "(6-phenylhexyl)benzene" "benzene,1'-(1,6-hexanediyl)bis-" );
standardThermochemistry
{
    dHf_298   58210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.3;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=325500.0
}
