/*--------------------------------*- Choupo -*-----------------------*\
  Component: azelanitrile  (C9H14N2, CAS 1675-69-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azelanitrile;
formula     C9H14N2;
CAS         1675-69-0;
InChIKey    QXOYPGTWWXJFDI-UHFFFAOYSA-N;
MW          150.225;      // g/mol [origin=calculated method=formula-sum]
Tc          808.80;      // K   [origin=predictive method=joback]
Pc          22.000;      // bar [origin=predictive method=joback]
omega       0.7852;      // -   [origin=predictive method=lee-kesler]
Tb          609.68;      // K   [origin=predictive method=joback]
HvapTb      56584.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.707 0.7284 -0.0004038 8.33e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonanedinitrile" "1,7-dicyanoheptane" "azelaonitrile" "azeleonitrile" "heptane-1,7-dicarbonitrile" "azelonitrile" "1,9-nonanedinitrile" "heptamethylene dicyanide" );
gibbsFormation
{
    dHf_298   100670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=291260.0
    phase     gas;
}
