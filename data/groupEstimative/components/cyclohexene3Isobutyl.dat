/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 3-isobutyl-  (C10H18, CAS 4104-56-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene3Isobutyl;
formula     C10H18;
CAS         4104-56-7;
InChIKey    NVLNRIBMCIJLQD-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          650.25;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.3353;      // -   [origin=predictive method=lee-kesler]
Tb          446.67;      // K   [origin=predictive method=joback]
HvapTb      38187.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-65.709 1.02584 -0.00059168 1.211e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 2; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylpropyl)cyclohexene" "cyclohexene, 3-(2-methylpropyl)-" "agn-pc-0ckkim" "3-(2-methyl-propyl)-cyclohexene" "3-(2-methylpropyl)-1-cyclohexene" );
gibbsFormation
{
    dHf_298   -142910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=85290.0
    phase     gas;
}
