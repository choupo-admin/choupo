/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3,4,5,6-pentamethylbenzyl alcohol  (C12H18O, CAS 484-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23456PentamethylbenzylAlcohol;
formula     C12H18O;
CAS         484-66-2;
InChIKey    CMBCAWNOBIGGTE-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          810.47;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       0.9454;      // -   [origin=predictive method=lee-kesler]
Tb          617.92;      // K   [origin=predictive method=joback]
HvapTb      64571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.861 0.8015 -0.0003554 4.24e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACCH3; count 5; } { group ACCH2; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dC_ring; count 6; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,3,4,5,6-pentamethylphenyl)methanol" "(2,3,4,5,6-pentamethylphenyl)methan-1-ol" "(pentamethylphenyl)methanol" "benzenemethanol,2,3,4,5,6-pentamethyl-" "(2,3,4,5,6-pentamethyl-phenyl)-methanol" );
gibbsFormation
{
    dHf_298   -264060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-22400.0
    phase     gas;
}
