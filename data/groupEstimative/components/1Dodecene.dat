/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-dodecene  (C12H24, CAS 112-41-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Dodecene;
formula     C12H24;
CAS         112-41-4;
InChIKey    CRSBERNSMYQZNG-UHFFFAOYSA-N;
MW          168.324;      // g/mol [origin=calculated method=formula-sum]
Tc          634.83;      // K   [origin=predictive method=joback]
Pc          18.452;      // bar [origin=predictive method=joback]
omega       0.5677;      // -   [origin=predictive method=lee-kesler]
Tb          470.84;      // K   [origin=predictive method=joback]
HvapTb      41636.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.011 1.12382 -0.0006519 1.49e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dodec-1-ene" "adacene 12" "dodecene" ".alpha.-dodecene" "n-dodec-1-ene" "dodecylene" "alpha-dodecene" "alpha-dodecylene" "4-bromocyclopropylbenzene" "dodecene-1" "a-dodecene" ".alpha.-dodecylene" );
standardThermochemistry
{
    dHf_298   -165580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     618.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138000.0
}
