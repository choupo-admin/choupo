/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 4-methoxysalicylate  (C9H10O4, CAS 5446-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl4Methoxysalicylate;
formula     C9H10O4;
CAS         5446-02-6;
InChIKey    ZICRWXFGZCVTBZ-UHFFFAOYSA-N;
MW          182.175;      // g/mol [origin=calculated method=formula-sum]
Tc          821.96;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.8205;      // -   [origin=predictive method=lee-kesler]
Tb          598.44;      // K   [origin=predictive method=joback]
HvapTb      61397.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.09 0.75704 -0.00048072 1.177e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACOH; count 1; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 4-methoxy-2-oxidanyl-benzoate" "methyl 2-hydroxy-4-methoxybenzoate" "2-hydroxy-4-methoxybenzoic acid methyl ester" "benzoic acid, 2-hydroxy-4-methoxy-, methyl ester" "methyl 2-hydroxy-p-anisate" "4-methoxysalicylic acid methyl ester" "m661" );
gibbsFormation
{
    dHf_298   -630840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-442310.0
    phase     gas;
}
