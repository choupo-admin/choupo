/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(perfluoro-5-methylhexyl)-2-hydroxypropyl methacrylate  (C14H11F15O3, CAS 16083-81-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Perfluoro5Methylhexyl2HydroxypropylMethacrylate;
formula     C14H11F15O3;
CAS         16083-81-1;
InChIKey    RPDBRTLKDYJCCE-UHFFFAOYSA-N;
MW          512.209;      // g/mol [origin=calculated method=formula-sum]
Tc          777.77;      // K   [origin=predictive method=joback]
Pc          11.475;      // bar [origin=predictive method=joback]
omega       1.0476;      // -   [origin=predictive method=lee-kesler]
Tb          632.88;      // K   [origin=predictive method=joback]
HvapTb      48539.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.448 2.35642 -0.0021506 7.141e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group CH2=C; count 1; } { group OH; count 1; } { group CF3; count 2; } { group CF2; count 4; } { group CF; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group C; count 7; } { group dCH2; count 1; } { group dC; count 1; } { group F; count 15; } { group OH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4,4,5,5,6,6,7,7,8,9,9,9-dodecakis(fluoranyl)-2-oxidanyl-8-(trifluoromethyl)nonyl] 2-methylprop-2-enoate" "4,4,5,5,6,6,7,7,8,9,9,9-dodecafluoro-2-hydroxy-8-(trifluoromethyl)nonyl methacrylate" "[4,4,5,5,6,6,7,7,8,9,9,9-dodecafluoro-2-hydroxy-8-(trifluoromethyl)nonyl] 2-methylprop-2-enoate" "3-(perfluoro-5-methylhexyl)-2-hydroxypropylmethacrylate" "2-methyl-2-propenoic acid [4,4,5,5,6,6,7,7,8,9,9,9-dodecafluoro-2-hydroxy-8-(trifluoromethyl)nonyl] ester" "4,4,5,5,6,6,7,7,8,9,9,9-dodecafluoro-2-hydroxy-8-(trifluoromethyl)nonyl 2-methylprop-2-enoate" );
gibbsFormation
{
    dHf_298   -3694340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     988.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3205610.0
    phase     gas;
}
