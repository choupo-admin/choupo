/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(diisobutylamino)-1-butanol  (C12H27NO, CAS 70289-33-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Diisobutylamino1Butanol;
formula     C12H27NO;
CAS         70289-33-7;
InChIKey    CGMXEHSYBRPJJL-UHFFFAOYSA-N;
MW          201.354;      // g/mol [origin=calculated method=formula-sum]
Tc          739.83;      // K   [origin=predictive method=joback]
Pc          19.510;      // bar [origin=predictive method=joback]
omega       1.0230;      // -   [origin=predictive method=lee-kesler]
Tb          577.90;      // K   [origin=predictive method=joback]
HvapTb      60252.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.784 1.31358 -0.0007784 1.778e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 6; } { group CH; count 2; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[bis(2-methylpropyl)amino]butan-1-ol" "1-butanol, 4-diisobutylamino-" "1-butanol, 4-diisobutylamino-," );
gibbsFormation
{
    dHf_298   -386270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=19240.0
    phase     gas;
}
