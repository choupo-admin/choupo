/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3,3,5,5,7,7-octamethyl-1,3,5,7-tetrasilacyclooctane  (C12H32Si4, CAS 1747-57-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H32Si4 (delta Si+4; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        11335577Octamethyl1357Tetrasilacyclooctane;
formula     C12H32Si4;
CAS         1747-57-5;
InChIKey    IJLLHKKTJFVIDZ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          288.728;      // g/mol [origin=calculated method=formula-sum]
Tc          699.67;      // K   [origin=predictive method=joback]
Pc          14.112;      // bar [origin=predictive method=joback]
omega       0.1900;      // -   [origin=predictive method=lee-kesler]
Tb          495.44;      // K   [origin=predictive method=joback]
HvapTb      43876.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.95 0.48696 0.000801 -6.396e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH2; count 4; } { group Si; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH2_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,3,3,5,5,7,7-octamethyl-1,3,5,7-tetrasilocane" "1,3,5,7-tetrasilacyclooctane, 1,1,3,3,5,5,7,7-octamethyl-" );
standardThermochemistry
{
    dHf_298   -650510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1101.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-312520.0
}
