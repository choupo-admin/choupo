/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,6-triiodophenol  (C6H3I3O, CAS 609-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        246Triiodophenol;
formula     C6H3I3O;
CAS         609-23-4;
InChIKey    VAPDZNUFNKUROY-UHFFFAOYSA-N;
MW          471.789;      // g/mol [origin=calculated method=formula-sum]
Tc          1072.54;      // K   [origin=predictive method=joback]
Pc          50.299;      // bar [origin=predictive method=joback]
omega       0.5649;      // -   [origin=predictive method=lee-kesler]
Tb          733.56;      // K   [origin=predictive method=joback]
HvapTb      73683.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.28 0.6475 -0.00070028 2.887e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 3; } { group ACOH; count 1; } { group I; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group I; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,6-tris(iodanyl)phenol" "phenol, 2,4,6-triiodo-" "2,6-triiodophenol" "2,4,6-trijodfenol" "phenol,4,6-triiodo-" "2,4,6-triiodo-phenol" "2,4,6-triiodo-phenol(tip)" "2,4,6-trijodfenol;bobel24;phenol, 2,4,6-triiodo-;2,4,6-triiodophenol, 98+%" );
gibbsFormation
{
    dHf_298   99720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112530.0
    phase     gas;
}
