/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenenitrile, polymer with (chloromethyl)ethenylbenzene and diethenylbenzene  (C22H22ClN, CAS 9082-27-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenenitrilePolymerWithChloromethylEthenylbenzeneAndDieth;
formula     C22H22ClN;
CAS         9082-27-3;
InChIKey    PMOMUADWDWUDHT-UHFFFAOYSA-N;
MW          335.875;      // g/mol [origin=calculated method=formula-sum]
Tc          1143.45;      // K   [origin=predictive method=joback]
Pc          13.052;      // bar [origin=predictive method=joback]
omega       0.7575;      // -   [origin=predictive method=lee-kesler]
Tb          895.31;      // K   [origin=predictive method=joback]
HvapTb      83213.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (43.241 1.2662 -0.00035272 -1.103e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 3; } { group ACH; count 8; } { group AC; count 4; } { group CH2Cl; count 1; } { group ACRY; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH2; count 4; } { group dCH; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(ethenyl)benzene;1-(chloromethyl)-2-ethenyl-benzene;prop-2-enenitrile" "acrylonitrile, divinylbenzene, vinylbenzyl chloride polymer" );
gibbsFormation
{
    dHf_298   380330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1024.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=603010.0
    phase     gas;
}
