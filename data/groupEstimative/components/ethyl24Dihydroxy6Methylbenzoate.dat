/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2,4-dihydroxy-6-methylbenzoate  (C10H12O4, CAS 2524-37-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl24Dihydroxy6Methylbenzoate;
formula     C10H12O4;
CAS         2524-37-0;
InChIKey    UQSRXQMIXSZGLA-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          910.63;      // K   [origin=predictive method=joback]
Pc          41.144;      // bar [origin=predictive method=joback]
omega       1.0660;      // -   [origin=predictive method=lee-kesler]
Tb          679.52;      // K   [origin=predictive method=joback]
HvapTb      74227.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.239 1.06984 -0.00090248 3.175e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-methyl-4,6-bis(oxidanyl)benzoate" "ethyl orsellinate" "orsellinic acid, ethyl ester" "o-orsellinic acid, ethyl ester" "benzoic acid, 2,4-dihydroxy-6-methyl-, ethyl ester" "4-carbethoxy-5-methylresorcinol" "2-carbethoxy-3,5-dihydroxytoluene" "4-ethoxycarbonyl-5-methylresorcinol" ".beta.-resorcylic acid, ethyl ester" "2-ethoxycarbonyl-3,5-dihydroxytoluene" "sdccgmls-0066439.p001" ".beta.-resorcylic acid, 6-methyl-, ethyl ester" );
gibbsFormation
{
    dHf_298   -696570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     537.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-483510.0
    phase     gas;
}
