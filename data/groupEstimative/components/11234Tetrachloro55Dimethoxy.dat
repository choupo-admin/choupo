/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1, 1,2,3,4-tetrachloro-5,5-dimethoxy-  (C7H6Cl4O2, CAS 2207-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11234Tetrachloro55Dimethoxy;
formula     C7H6Cl4O2;
CAS         2207-27-4;
InChIKey    UHSMEJQTFMHABA-UHFFFAOYSA-N;
MW          263.923;      // g/mol [origin=calculated method=formula-sum]
Tc          821.20;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.5937;      // -   [origin=predictive method=lee-kesler]
Tb          588.08;      // K   [origin=predictive method=joback]
HvapTb      55874.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.37 0.64324 -0.000583 2.448e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 1; } { group CH3O; count 2; } { group Cl_C=C_; count 4; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C_ring; count 1; } { group dC_ring; count 4; } { group Cl; count 4; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4-tetrakis(chloranyl)-5,5-dimethoxy-cyclopenta-1,3-diene" "5,5-dimethoxy-1,2,3,4-tetrachlorocyclopentadiene" "1,2,3,4-tetrachloro-5,5-dimethoxycyclopentadiene" "1,2,3,4-tetrachloro-5,5-dimethoxycyclopenta-1,3-diene" "1,3-cyclopentadiene, 1,2,3,4-tetrachloro-5,5-dimethoxy-" );
gibbsFormation
{
    dHf_298   -369810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197200.0
    phase     gas;
}
