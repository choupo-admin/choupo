/*--------------------------------*- Choupo -*-----------------------*\
  Component: alpha-terpinene  (C10H16, CAS 99-86-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaTerpinene;
formula     C10H16;
CAS         99-86-5;
InChIKey    YHQGMYUVUMAZJR-UHFFFAOYSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          669.21;      // K   [origin=predictive method=joback]
Pc          27.995;      // bar [origin=predictive method=joback]
omega       0.3593;      // -   [origin=predictive method=lee-kesler]
Tb          460.46;      // K   [origin=predictive method=joback]
HvapTb      40112.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-35.27 0.87736 -0.00050028 1.037e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-propan-2-yl-cyclohexa-1,3-diene" "p-mentha-1,3-diene" "terpilene" "1-isopropyl-4-methyl-1,3-cyclohexadiene" "1,3-cyclohexadiene, 1-methyl-4-(1-methylethyl)-" "alpha-terpinen" ".alpha.-terpinen" "1-methyl-4-(1-methylethyl)-1,3-cyclohexadiene" "1-methyl-4-isopropylcyclohexadiene-1,3" "1,3-cyclohexadiene, 1-methyl-4-isopropyl-" "1-methyl-4-(propan-2-yl)cyclohexa-1,3-diene" "ambap99-86-5" );
gibbsFormation
{
    dHf_298   -87730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     460.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103700.0
    phase     gas;
}
