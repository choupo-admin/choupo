/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-decen-1-ol, (3e)-  (C10H20O, CAS 10339-60-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Decen1Ol3e;
formula     C10H20O;
CAS         10339-60-3;
InChIKey    MTIJDFJGPCJFKE-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          689.53;      // K   [origin=predictive method=joback]
Pc          24.171;      // bar [origin=predictive method=joback]
omega       0.9216;      // -   [origin=predictive method=lee-kesler]
Tb          524.74;      // K   [origin=predictive method=joback]
HvapTb      54491.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-15.093 1.00782 -0.0006344 1.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 7; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dec-3-en-1-ol" "3-decen-1-ol, (3z)-" "(e)-3-decenol" "3-decen-1-ol,(e)- (8ci); trans-3-decen-1-ol" "3-decen-1-ol,(z)- (8ci);(z)-3-decen-1-ol;" );
standardThermochemistry
{
    dHf_298   -284740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     589.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-23280.0
}
