/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-propyl-n-methylcyclopropylamine  (C7H15N, CAS 67990-21-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nPropylNMethylcyclopropylamine;
formula     C7H15N;
CAS         67990-21-0;
InChIKey    HFFBUTJCQGSVLC-UHFFFAOYSA-N;
MW          113.204;      // g/mol [origin=calculated method=formula-sum]
Tc          555.77;      // K   [origin=predictive method=joback]
Pc          32.210;      // bar [origin=predictive method=joback]
omega       0.3742;      // -   [origin=predictive method=lee-kesler]
Tb          378.94;      // K   [origin=predictive method=joback]
HvapTb      33132.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.408 0.94364 -0.0006898 2.088e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-methyl-n-propyl-cyclopropanamine" "cyclopropanamine, n-methyl-n-propyl-" "n-methyl-n-propylcyclopropanamine" "n-methyl-n-propylcyclopropylamine" "n-propyl cyclopropyl methyl amine" );
gibbsFormation
{
    dHf_298   -47480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     354.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=179590.0
    phase     gas;
}
