/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-benzenedicarboxylic acid, 2-ethylhexyl isodecyl ester  (C26H42O4, CAS 53272-22-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BenzenedicarboxylicAcid2EthylhexylIsodecylEster;
formula     C26H42O4;
CAS         53272-22-3;
InChIKey    KRVAUPJDDLBZBB-UHFFFAOYSA-N;
MW          418.618;      // g/mol [origin=calculated method=formula-sum]
Tc          1153.02;      // K   [origin=predictive method=joback]
Pc          8.795;      // bar [origin=predictive method=joback]
omega       0.8504;      // -   [origin=predictive method=lee-kesler]
Tb          941.70;      // K   [origin=predictive method=joback]
HvapTb      90446.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.102 2.23768 -0.00117196 1.836e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group CH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-(2-ethylhexyl) o1-(8-methylnonyl) benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, 1-(2-ethylhexyl) 2-isodecyl ester" "2-ethylhexyl isodecyl phthalate" "1,2-benzenedicarboxylic acid, mixed 2-ethylhexyl and isodecyl esters" "1,2-benzenedicarboxylic acid 2-ethylhexyl isodecyl ester" "2-o-(2-ethylhexyl) 1-o-(8-methylnonyl) benzene-1,2-dicarboxylate" );
gibbsFormation
{
    dHf_298   -1000030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1139.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-354800.0
    phase     gas;
}
