/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-menthane-1,3-diol  (C10H20O2, CAS 1612-98-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pMenthane13Diol;
formula     C10H20O2;
CAS         1612-98-2;
InChIKey    IIZCEIWXLSJQFP-UHFFFAOYSA-N;
MW          172.268;      // g/mol [origin=calculated method=formula-sum]
Tc          809.09;      // K   [origin=predictive method=joback]
Pc          30.796;      // bar [origin=predictive method=joback]
omega       1.1859;      // -   [origin=predictive method=lee-kesler]
Tb          622.77;      // K   [origin=predictive method=joback]
HvapTb      69484.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-101.02 1.38876 -0.001087 3.781e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 3; } { group C; count 1; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methyl-4-propan-2-yl-cyclohexane-1,3-diol" "4-isopropyl-1-methyl-1,3-cyclohexanediol" "1,3-cyclohexanediol, 1-methyl-4-(1-methylethyl)-" "agn-pc-00m5pv" "1-methyl-4-propan-2-ylcyclohexane-1,3-diol" );
gibbsFormation
{
    dHf_298   -530590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-239220.0
    phase     gas;
}
