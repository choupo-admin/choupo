/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-methoxybutan-2-one  (C5H10O2, CAS 6975-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Methoxybutan2One;
formula     C5H10O2;
CAS         6975-85-5;
InChIKey    DRWOJIIXBYNGGW-UHFFFAOYSA-N;
MW          102.133;      // g/mol [origin=calculated method=formula-sum]
Tc          568.95;      // K   [origin=predictive method=joback]
Pc          36.642;      // bar [origin=predictive method=joback]
omega       0.4536;      // -   [origin=predictive method=lee-kesler]
Tb          390.29;      // K   [origin=predictive method=joback]
HvapTb      35880.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.202 0.38764 -0.0001185 -1.554e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH3CO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-methoxy-2-butanone" "2-butanone, 4-methoxy-" "4-methoxy-butan-2-one" );
standardThermochemistry
{
    dHf_298   -391330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     388.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-242700.0
}
