/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-hexadecyloxyaniline  (C22H39NO, CAS 7502-06-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pHexadecyloxyaniline;
formula     C22H39NO;
CAS         7502-06-9;
InChIKey    DETPMDIIFZGDAE-UHFFFAOYSA-N;
MW          333.56;      // g/mol [origin=calculated method=formula-sum]
Tc          1024.14;      // K   [origin=predictive method=joback]
Pc          11.306;      // bar [origin=predictive method=joback]
omega       0.9817;      // -   [origin=predictive method=lee-kesler]
Tb          829.57;      // K   [origin=predictive method=joback]
HvapTb      80555.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.725 1.95412 -0.00106956 2.074e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group ACH; count 4; } { group AC; count 1; } { group CH2O; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-hexadecoxyaniline" "4-(hexadecyloxy)aniline" "4-hexadecyloxyphenylamine" "4-n-hexadecyloxyaniline" );
gibbsFormation
{
    dHf_298   -370780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     963.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=198590.0
    phase     gas;
}
