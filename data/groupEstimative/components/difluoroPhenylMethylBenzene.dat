/*--------------------------------*- Choupo -*-----------------------*\
  Component: [difluoro(phenyl)methyl]benzene  (C13H10F2, CAS 360-11-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        difluoroPhenylMethylBenzene;
formula     C13H10F2;
CAS         360-11-2;
InChIKey    LVTDRHCAWKTYCQ-UHFFFAOYSA-N;
MW          204.219;      // g/mol [origin=calculated method=formula-sum]
Tc          780.53;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.4422;      // -   [origin=predictive method=lee-kesler]
Tb          545.71;      // K   [origin=predictive method=joback]
HvapTb      46154.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.03 1.2304 -0.0009504 2.776e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 2; } { group CF2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group F; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[bis(fluoranyl)-phenyl-methyl]benzene" "difluoro diphenyl methane" "difluorodiphenylmethane" "(difluorophenylmethyl)benzene" "benzene,1,1'-(difluoromethylene)bis-" "benzene, 1,1'-(difluoromethylene)bis-" "methane,difluorodiphenyl- (6ci,7ci,8ci);difluorodiphenylmethane;diphenyldifluoromethane;" );
gibbsFormation
{
    dHf_298   -239560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     474.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-103380.0
    phase     gas;
}
