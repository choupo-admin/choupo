/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9,10-bis(phenylethynyl)-9,10-dihydroanthracene-9,10-diol  (C30H20O2, CAS 14825-85-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        910BisPhenylethynyl910Dihydroanthracene910Diol;
formula     C30H20O2;
CAS         14825-85-5;
InChIKey    QLNUHXMKEJWHAP-UHFFFAOYSA-N;
MW          412.488;      // g/mol [origin=calculated method=formula-sum]
Tc          1486.19;      // K   [origin=predictive method=joback]
Pc          21.877;      // bar [origin=predictive method=joback]
omega       1.5477;      // -   [origin=predictive method=lee-kesler]
Tb          1203.32;      // K   [origin=predictive method=joback]
HvapTb      127594.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-224.87 2.9054 -0.00275184 1.07256e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group C; count 2; } { group ACH; count 18; } { group AC; count 6; } { group OH; count 2; } { group C_C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 4; } { group C_ring; count 2; } { group dCH_ring; count 18; } { group dC_ring; count 6; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9,10-bis(2-phenylethynyl)anthracene-9,10-diol" "9,10-anthracenediol, 9,10-dihydro-9,10-bis(phenylethynyl)-" "9,10-anthracenediol, 9,10-dihydro-9,10-bis(2-phenylethynyl)-" "9, 9,10-dihydro-9,10-bis(phenylethynyl)-" );
standardThermochemistry
{
    dHf_298   589890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     918.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=818220.0
}
