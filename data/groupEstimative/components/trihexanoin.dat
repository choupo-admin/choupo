/*--------------------------------*- Choupo -*-----------------------*\
  Component: trihexanoin  (C21H38O6, CAS 621-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trihexanoin;
formula     C21H38O6;
CAS         621-70-5;
InChIKey    MAYCICSNZYXLHB-UHFFFAOYSA-N;
MW          386.529;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.19;      // K   [origin=predictive method=joback]
Pc          9.699;      // bar [origin=predictive method=joback]
omega       0.9374;      // -   [origin=predictive method=lee-kesler]
Tb          854.30;      // K   [origin=predictive method=joback]
HvapTb      84173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (58.344 1.84036 -0.000838 6.69e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 1; } { group CH2COO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-di(hexanoyloxy)propyl hexanoate" "glycerol trihexanoate" "tricaproin" "tricapronin" "hexanoin, tri-" "caproic triglyceride" "glycerol tricaproate" "glyceryl tricaproate" "trihexanoyl glycerol" "palmitic acid triglyceride" "hexanoic acid, 1,2,3-propanetriyl ester" "tricaproylglycerol" );
standardThermochemistry
{
    dHf_298   -1433890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1118.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-807610.0
}
