/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl alcohol, o-(methylamino)-  (C8H11NO, CAS 29055-08-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylAlcoholOMethylamino;
formula     C8H11NO;
CAS         29055-08-1;
InChIKey    ZWIBBLPQTVLYKW-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          756.46;      // K   [origin=predictive method=joback]
Pc          40.829;      // bar [origin=predictive method=joback]
omega       0.9439;      // -   [origin=predictive method=lee-kesler]
Tb          556.65;      // K   [origin=predictive method=joback]
HvapTb      59455.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.909 0.73562 -0.00045456 1.049e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2-(methylamino)phenyl]methanol" "benzenemethanol, 2-(methylamino)-" "(2-methylamino-phenyl)-methanol" "(2-(methylamino)phenyl)methanol" "o-(methylamino)benzyl alcohol" "(2-methylamino-phenyl)methanol" "benzenemethanol,2-(methylamino)-" );
standardThermochemistry
{
    dHf_298   -82150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     446.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=71830.0
}
