/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-dodecylthiophene  (C16H28S, CAS 104934-52-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Dodecylthiophene;
formula     C16H28S;
CAS         104934-52-3;
InChIKey    RFKWIEFTBMACPZ-UHFFFAOYSA-N;
MW          252.46;      // g/mol [origin=calculated method=formula-sum]
Tc          828.53;      // K   [origin=predictive method=joback]
Pc          16.129;      // bar [origin=predictive method=joback]
omega       0.7456;      // -   [origin=predictive method=lee-kesler]
Tb          636.76;      // K   [origin=predictive method=joback]
HvapTb      58834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.399 1.52493 -0.00095562 2.392e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 11; } { group C4H3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 11; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-laurylthiophene" "3-n-dodecylthiophene" "thiophene, 3-dodecyl-" "1-(thien-3-yl)dodecane" "3-(dodec-1-yl)thiophene" "l528" );
standardThermochemistry
{
    dHf_298   -143400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     740.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=218250.0
}
