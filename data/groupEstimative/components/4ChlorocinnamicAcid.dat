/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-chlorocinnamic acid  (C9H7ClO2, CAS 1615-02-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4ChlorocinnamicAcid;
formula     C9H7ClO2;
CAS         1615-02-7;
InChIKey    GXLIFJYFGMHYDY-ZZXKWVIFSA-N;
MW          182.603;      // g/mol [origin=calculated method=formula-sum]
Tc          863.04;      // K   [origin=predictive method=joback]
Pc          36.202;      // bar [origin=predictive method=joback]
omega       0.7546;      // -   [origin=predictive method=lee-kesler]
Tb          624.28;      // K   [origin=predictive method=joback]
HvapTb      60073.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.59 0.798 -0.00060676 1.809e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-(4-chlorophenyl)prop-2-enoic acid" "p-chlorocinnamic acid" "3-(4-chlorophenyl)acrylic acid" "2-propenoic acid, 3-(4-chlorophenyl)-" "(2e)-3-(4-chlorophenyl)prop-2-enoic acid" "cinnamic acid, p-chloro-" "(e)-p-chlorocinnamic acid" "trans-p-chlorocinnamic acid" "(2e)-3-(4-chlorophenyl)acrylic acid" "trans-3-(4-chlorophenyl)propenoic acid" "3-(p-chlorophenyl)acrylic acid" "trans-4-chlorocinnamic acid" );
gibbsFormation
{
    dHf_298   -252820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-147940.0
    phase     gas;
}
