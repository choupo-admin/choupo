/*--------------------------------*- Choupo -*-----------------------*\
  Component: isopropyl 10-undecenate  (C14H26O2, CAS 5459-98-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        isopropyl10Undecenate;
formula     C14H26O2;
CAS         5459-98-3;
InChIKey    SJMKHCGKNIXLKH-UHFFFAOYSA-N;
MW          226.36;      // g/mol [origin=calculated method=formula-sum]
Tc          745.14;      // K   [origin=predictive method=joback]
Pc          15.911;      // bar [origin=predictive method=joback]
omega       0.7612;      // -   [origin=predictive method=lee-kesler]
Tb          574.38;      // K   [origin=predictive method=joback]
HvapTb      53107.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.898 1.26494 -0.0006693 1.152e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propan-2-yl undec-10-enoate" "10-undecenoic acid, 1-methylethyl ester" "isopropyl 10-undecenoate" "isopropyl undec-10-enoate" "10-undecenoic acid,1-methylethyl ester" );
standardThermochemistry
{
    dHf_298   -529420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     738.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-157970.0
}
