/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-amino-2-methoxyphenyl)pyrrolidine  (C11H16N2O, CAS 16089-42-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Amino2MethoxyphenylPyrrolidine;
formula     C11H16N2O;
CAS         16089-42-2;
InChIKey    YVEZBGKUTDESAG-UHFFFAOYSA-N;
MW          192.262;      // g/mol [origin=calculated method=formula-sum]
Tc          842.68;      // K   [origin=predictive method=joback]
Pc          32.765;      // bar [origin=predictive method=joback]
omega       0.7207;      // -   [origin=predictive method=lee-kesler]
Tb          610.99;      // K   [origin=predictive method=joback]
HvapTb      59168.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.42 1.14132 -0.00074592 1.866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 3; } { group AC; count 2; } { group CH3O; count 1; } { group CH2N; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group NH2; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methoxy-4-pyrrolidin-1-yl-aniline" "benzenamine, 3-methoxy-4-(1-pyrrolidinyl)-" "3-methoxy-4-pyrrolidin-1-ylaniline" "3-methoxy-4-(pyrrolidin-1-yl)aniline" "n-(4-amino-2-methoxyphenyl)pyrrolidine" "pyrrolidine, 1-(4-amino-2-methoxyphenyl)-" );
gibbsFormation
{
    dHf_298   -700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263480.0
    phase     gas;
}
