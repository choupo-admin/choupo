/*--------------------------------*- Choupo -*-----------------------*\
  Component: nonyl 4-aminobenzoate  (C16H25NO2, CAS 37139-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nonyl4Aminobenzoate;
formula     C16H25NO2;
CAS         37139-21-2;
InChIKey    KKGIDNSPWHBLLE-UHFFFAOYSA-N;
MW          263.381;      // g/mol [origin=calculated method=formula-sum]
Tc          929.67;      // K   [origin=predictive method=joback]
Pc          17.714;      // bar [origin=predictive method=joback]
omega       0.9800;      // -   [origin=predictive method=lee-kesler]
Tb          728.09;      // K   [origin=predictive method=joback]
HvapTb      72196.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.638 1.39252 -0.00075956 1.337e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonyl 4-azanylbenzoate" "benzoic acid, 4-amino-, nonyl ester" );
standardThermochemistry
{
    dHf_298   -432000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     769.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-57300.0
}
