/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,4-dimethylphenoxy)acetic acid  (C10H12O3, CAS 13334-49-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24DimethylphenoxyAceticAcid;
formula     C10H12O3;
CAS         13334-49-1;
InChIKey    XRTZHWXWLUGOAT-UHFFFAOYSA-N;
MW          180.203;      // g/mol [origin=calculated method=formula-sum]
Tc          852.12;      // K   [origin=predictive method=joback]
Pc          30.693;      // bar [origin=predictive method=joback]
omega       0.8624;      // -   [origin=predictive method=lee-kesler]
Tb          632.97;      // K   [origin=predictive method=joback]
HvapTb      61028.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (18.591 0.74354 -0.00037892 5.67e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CH2O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4-dimethylphenoxy)ethanoic acid" "2-(2,4-dimethylphenoxy)acetic acid" "2,4-dimethylphenoxyaceticacid" "2,4-dimethylphenoxyacetic acid" "2,4-xylyloxyacetic acid" "acetic acid,2-(2,4-dimethylphenoxy)-" "acetic acid, 2-(2,4-dimethylphenoxy)-" "brd-k47179683-001-01-4" );
gibbsFormation
{
    dHf_298   -518630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     491.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-322440.0
    phase     gas;
}
