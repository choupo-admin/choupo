/*--------------------------------*- Choupo -*-----------------------*\
  Component: methane, dichlorodiiodo-  (CCl2I2, CAS 594-23-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methaneDichlorodiiodo;
formula     CCl2I2;
CAS         594-23-0;
InChIKey    ZOWYTDVMTPRWGU-UHFFFAOYSA-N;
MW          336.711;      // g/mol [origin=calculated method=formula-sum]
Tc          772.15;      // K   [origin=predictive method=joback]
Pc          50.086;      // bar [origin=predictive method=joback]
omega       0.1834;      // -   [origin=predictive method=lee-kesler]
Tb          480.39;      // K   [origin=predictive method=joback]
HvapTb      44040.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.67 0.3162 -0.000406 1.704e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 1; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group Cl; count 2; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bis(chloranyl)-bis(iodanyl)methane" );
gibbsFormation
{
    dHf_298   49540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     334.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52760.0
    phase     gas;
}
