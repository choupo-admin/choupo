/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(1,2-dichloroethyl)-4-methyl-1,3-dioxolane  (C6H10Cl2O2, CAS 10232-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        212Dichloroethyl4Methyl13Dioxolane;
formula     C6H10Cl2O2;
CAS         10232-90-3;
InChIKey    BNSRVFGXRITOQK-UHFFFAOYSA-N;
MW          185.044;      // g/mol [origin=calculated method=formula-sum]
Tc          691.01;      // K   [origin=predictive method=joback]
Pc          33.374;      // bar [origin=predictive method=joback]
omega       0.4341;      // -   [origin=predictive method=lee-kesler]
Tb          475.81;      // K   [origin=predictive method=joback]
HvapTb      46300.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (1.631 0.69252 -0.0003908 7.16e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group Cl; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[1,2-bis(chloranyl)ethyl]-4-methyl-1,3-dioxolane" "1,3-dioxolane, 2-(1,2-dichloroethyl)-4-methyl-" "2-(1,3-dioxolane" "1, 2-(1,2-dichloroethyl)-4-methyl-" "1,3-dioxolane,2-(1,2-dichloroethyl)-4-methyl-" );
standardThermochemistry
{
    dHf_298   -427790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     251.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-170060.0
}
