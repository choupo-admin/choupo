/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1-methylpiperidin-3-yl)(piperidin-1-yl)methanone  (C12H22N2O, CAS 40576-23-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylpiperidin3YlPiperidin1YlMethanone;
formula     C12H22N2O;
CAS         40576-23-6;
InChIKey    LJZSMGYSNXRFQB-UHFFFAOYSA-N;
MW          210.321;      // g/mol [origin=calculated method=formula-sum]
Tc          805.52;      // K   [origin=predictive method=joback]
Pc          27.183;      // bar [origin=predictive method=joback]
omega       0.6722;      // -   [origin=predictive method=lee-kesler]
Tb          588.14;      // K   [origin=predictive method=joback]
HvapTb      53961.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-148.95 1.65352 -0.0011457 3.0456e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 1; } { group CH3N; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 9; } { group CH_ring; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methylpiperidin-3-yl)-piperidin-1-yl-methanone" "1-methyl-3-piperidyl piperidino ketone" "ketone, 1-methyl-3-piperidyl piperidino" "1-methyl-3-(piperidinocarbonyl)piperidine" "piperidine, 1-((1-methyl-3-piperidinyl)carbonyl)-" "(1-methylpiperidin-3-yl)-piperidin-1-ylmethanone" );
gibbsFormation
{
    dHf_298   -127230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223610.0
    phase     gas;
}
