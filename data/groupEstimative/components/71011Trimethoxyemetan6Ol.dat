/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7',10,11-trimethoxyemetan-6'-ol  (C28H38N2O4, CAS 483-17-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        71011Trimethoxyemetan6Ol;
formula     C28H38N2O4;
CAS         483-17-0;
InChIKey    DTGZHCFJNDAHEN-UHFFFAOYSA-N;
MW          466.622;      // g/mol [origin=calculated method=formula-sum]
Tc          1411.06;      // K   [origin=predictive method=joback]
Pc          12.838;      // bar [origin=predictive method=joback]
omega       1.1833;      // -   [origin=predictive method=lee-kesler]
Tb          1151.46;      // K   [origin=predictive method=joback]
HvapTb      114603.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.098 2.69108 -0.00171436 4.316e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 2; } { group ACH; count 4; } { group AC; count 3; } { group ACCH2; count 2; } { group ACCH; count 2; } { group ACOH; count 1; } { group CH3O; count 3; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH2_ring; count 6; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 8; } { group OH_phenol; count 1; } { group O; count 3; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-[(3-ethyl-9,10-dimethoxy-2,3,4,6,7,11b-hexahydro-1h-benzo[a]quinolizin-2-yl)methyl]-7-methoxy-1,2,3,4-tetrahydroisoquinolin-6-ol" "emetan-6'-ol, 7',10,11-trimethoxy-" "(2xi,14xi)-7',10,11-trimethoxyemetan-6'-ol" );
standardThermochemistry
{
    dHf_298   -488430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     799.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=240760.0
}
