/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-bis(hydroxymethyl)propane-1,3-diol; heptanoic acid; nonanoic acid; pentanoic acid  (C26H54O10, CAS 7322-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22BisHydroxymethylPropane13DiolHeptanoicAcidNonanoicAcidPent;
formula     C26H54O10;
CAS         7322-47-6;
InChIKey    OWFZZECENILGEX-UHFFFAOYSA-N;
MW          526.708;      // g/mol [origin=calculated method=formula-sum]
Tc          2642.07;      // K   [origin=predictive method=joback]
Pc          9.051;      // bar [origin=predictive method=joback]
omega       -0.3339;      // -   [origin=predictive method=lee-kesler]
Tb          1600.70;      // K   [origin=predictive method=joback]
HvapTb      191264.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (112.199 2.26946 -0.0006574 -1.583e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 19; } { group C; count 1; } { group OH; count 4; } { group COOH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 19; } { group C; count 1; } { group OH; count 4; } { group COOH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(hydroxymethyl)propane-1,3-diol;heptanoic acid;nonanoic acid;pentanoic acid" "nonanoic acid, mixed esters with heptanoic acid, pentaerythritol and valeric acid" "nonanoic acid mixed esters with heptanoic acid pentaerythritol and valeric acid" "pentaerythritol, esters with valeric acid, enanthylic acid, pelargonic acid" );
standardThermochemistry
{
    dHf_298   -2583310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1815.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1722410.0
}
