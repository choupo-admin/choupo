/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenoic acid, 2-chloro-, 1,1-dimethylethyl ester, polymer with ethyl 2-chloro-2-propenoate  (C12H18Cl2O4, CAS 72088-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropenoicAcid2Chloro11DimethylethylEsterPolymerWithEthyl2Ch;
formula     C12H18Cl2O4;
CAS         72088-91-6;
InChIKey    WWAYBJSLUNLVAX-UHFFFAOYSA-N;
MW          297.172;      // g/mol [origin=calculated method=formula-sum]
Tc          863.58;      // K   [origin=predictive method=joback]
Pc          17.232;      // bar [origin=predictive method=joback]
omega       0.7046;      // -   [origin=predictive method=lee-kesler]
Tb          656.75;      // K   [origin=predictive method=joback]
HvapTb      63708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (79.561 0.92728 -0.000288 -7.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH2=C; count 2; } { group Cl_C=C_; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group Cl; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tert-butyl 2-chloranylprop-2-enoate;ethyl 2-chloranylprop-2-enoate" "tert-butyl alpha-chloroacrylate, ethyl alpha-chloroacrylate polymer" );
standardThermochemistry
{
    dHf_298   -846140.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     844.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-537780.0
}
