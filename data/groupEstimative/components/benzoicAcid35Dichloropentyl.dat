/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 3,5-dichloropentyl  (C12H14Cl2O2, CAS 27070-22-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid35Dichloropentyl;
formula     C12H14Cl2O2;
CAS         27070-22-0;
InChIKey    IBJYWOZLBVBSHK-UHFFFAOYSA-N;
MW          261.142;      // g/mol [origin=calculated method=formula-sum]
Tc          849.17;      // K   [origin=predictive method=joback]
Pc          22.676;      // bar [origin=predictive method=joback]
omega       0.7239;      // -   [origin=predictive method=lee-kesler]
Tb          633.48;      // K   [origin=predictive method=joback]
HvapTb      60371.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.584 1.0296 -0.0006096 1.175e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 5; } { group AC; count 1; } { group CH2Cl; count 1; } { group CHCl; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,5-bis(chloranyl)pentyl benzoate" "3,5-dichloropentyl benzoate" "benzoic acid, 3,5-dichloropentyl ester" );
standardThermochemistry
{
    dHf_298   -408520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     625.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174100.0
}
