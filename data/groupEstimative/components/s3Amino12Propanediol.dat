/*--------------------------------*- Choupo -*-----------------------*\
  Component: (s)-3-amino-1,2-propanediol  (C3H9NO2, CAS 61278-21-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        s3Amino12Propanediol;
formula     C3H9NO2;
CAS         61278-21-5;
InChIKey    KQIGMPWTAHJUMN-VKHMYHEASA-N;
MW          91.11;      // g/mol [origin=calculated method=formula-sum]
Tc          698.31;      // K   [origin=predictive method=joback]
Pc          63.289;      // bar [origin=predictive method=joback]
omega       1.3827;      // -   [origin=predictive method=lee-kesler]
Tb          524.69;      // K   [origin=predictive method=joback]
HvapTb      65883.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (15.552 0.4246 -0.0002468 5.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group OH; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s)-3-azanylpropane-1,2-diol" "(s)-3-aminopropane-1,2-diol" "(s)-(-)-3-amino-1,2-propanediol" "(s)-(-)-3-amino-1,2-propandiol" "(2s)-2,3-dihydroxypropylamine" "(2s)-3-amino-1,2-dihydroxypropane" "1,2-propanediol,3-amino-, hydrochloride, (2s)- (9ci); (2s)-3-aminopropane-1,2-diolhydrochloride" );
standardThermochemistry
{
    dHf_298   -381200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235250.0
}
