/*--------------------------------*- Choupo -*-----------------------*\
  Component: coumarin, 8-tert-butyl-4,6-dimethyl-  (C15H18O2, CAS 17874-34-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        coumarin8TertButyl46Dimethyl;
formula     C15H18O2;
CAS         17874-34-9;
InChIKey    SIOLFBILQBRZOC-UHFFFAOYSA-N;
MW          230.307;      // g/mol [origin=calculated method=formula-sum]
Tc          869.17;      // K   [origin=predictive method=joback]
Pc          20.869;      // bar [origin=predictive method=joback]
omega       0.7020;      // -   [origin=predictive method=lee-kesler]
Tb          650.69;      // K   [origin=predictive method=joback]
HvapTb      60361.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.8 1.314 -0.00094172 2.696e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 2; } { group AC; count 3; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8-tert-butyl-4,6-dimethyl-chromen-2-one" "4,6-dimethyl-8-tert-butylcoumarin" "8-tert-butyl-4,6-dimethylcoumarin" "8-tert-butyl-4,6-dimethyl-2-benzopyrone" "2h-1-benzopyran-2-one, 8-(1,1-dimethylethyl)-4,6-dimethyl-" "coumarin, 4,6-dimethyl-8-(1,1-dimethylethy)-" "8-tert-butyl-4,6-dimethylchromen-2-one" );
standardThermochemistry
{
    dHf_298   -331230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     516.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-47700.0
}
