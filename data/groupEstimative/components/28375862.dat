/*--------------------------------*- Choupo -*-----------------------*\
  Component: 28375-86-2  (C15H22, CAS 28375-86-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        28375862;
formula     C15H22;
CAS         28375-86-2;
InChIKey    XCSWTEQBPOHNPL-UHFFFAOYSA-N;
MW          202.341;      // g/mol [origin=calculated method=formula-sum]
Tc          767.14;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       0.4775;      // -   [origin=predictive method=lee-kesler]
Tb          553.55;      // K   [origin=predictive method=joback]
HvapTb      47141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-233.08 2.08692 -0.001718 5.809e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 9; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 9; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -64130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     99.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=360430.0
    phase     gas;
}
