/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propylpiperidine  (C8H17N, CAS 3238-60-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propylpiperidine;
formula     C8H17N;
CAS         3238-60-6;
InChIKey    NDNUANOUGZGEPO-UHFFFAOYSA-N;
MW          127.231;      // g/mol [origin=calculated method=formula-sum]
Tc          659.66;      // K   [origin=predictive method=joback]
Pc          32.430;      // bar [origin=predictive method=joback]
omega       0.3866;      // -   [origin=predictive method=lee-kesler]
Tb          450.74;      // K   [origin=predictive method=joback]
HvapTb      40589.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.068 0.87252 -0.0004318 6.07e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "conicine" "cicutin" "coniine" "2-propyl-piperidine" "cicutine" "koniin" "dl-coniine" "piperidine, 2-propyl-, (s)-" "d-conicine" "coniin" "(s)-coniine" "piperidine, 2-propyl-" );
gibbsFormation
{
    dHf_298   -116320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=128640.0
    phase     gas;
}
