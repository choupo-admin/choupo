/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-diphenylethylamine  (C14H15N, CAS 3963-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Diphenylethylamine;
formula     C14H15N;
CAS         3963-62-0;
InChIKey    RXMTUVIKZRXSSM-UHFFFAOYSA-N;
MW          197.281;      // g/mol [origin=calculated method=formula-sum]
Tc          897.25;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.6204;      // -   [origin=predictive method=lee-kesler]
Tb          645.37;      // K   [origin=predictive method=joback]
HvapTb      61563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.839 1.2438 -0.0008468 2.169e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-diphenylethanamine" "2,2-diphenyl-ethylamine" "1-amino-2,2-diphenylethane" "2,2-di(phenyl)ethanamine" "2,2-diphenyl-ethyl-amine" "2,2-diphenylethan-1-amine" "benzeneethanamine, b-phenyl-" "diphenylalkylamine (dpa), 4a" "rxmtuvikzrxssm-uhfffaoysa-" "ppa-0-0" "1-amino-2,2-diphenyl ethane" "l010" );
standardThermochemistry
{
    dHf_298   169280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355830.0
}
