/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-cyclopentadien-1-ol  (C5H6O, CAS 103905-54-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Cyclopentadien1Ol;
formula     C5H6O;
CAS         103905-54-0;
InChIKey    BFAIMMGBWGSCPF-UHFFFAOYSA-N;
MW          82.102;      // g/mol [origin=calculated method=formula-sum]
Tc          624.57;      // K   [origin=predictive method=joback]
Pc          56.026;      // bar [origin=predictive method=joback]
omega       0.6367;      // -   [origin=predictive method=lee-kesler]
Tb          429.43;      // K   [origin=predictive method=joback]
HvapTb      45215.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.93 0.4995 -0.00036892 1.093e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopenta-1,4-dien-1-ol" "agn-pc-00o0ug" );
gibbsFormation
{
    dHf_298   -113850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     312.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51050.0
    phase     gas;
}
