/*--------------------------------*- Choupo -*-----------------------*\
  Component: 710-f  (C17H25N3O, CAS 551-01-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        710F;
formula     C17H25N3O;
CAS         551-01-9;
InChIKey    WIPRQKODGRKUEW-UHFFFAOYSA-N;
MW          287.407;      // g/mol [origin=calculated method=formula-sum]
Tc          996.19;      // K   [origin=predictive method=joback]
Pc          18.757;      // bar [origin=predictive method=joback]
omega       1.0570;      // -   [origin=predictive method=lee-kesler]
Tb          782.91;      // K   [origin=predictive method=joback]
HvapTb      75775.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-25.655 1.58792 -0.0009943 2.428e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group ACH; count 2; } { group AC; count 2; } { group CH3O; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group dCH_ring; count 5; } { group dC_ring; count 4; } { group O; count 1; } { group NH; count 1; } { group N; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n',n'-diethyl-n-(6-methoxyquinolin-8-yl)propane-1,3-diamine" "plasmocid" "304-24-5 (hydriodide)" "1,3-propanediamine, n,n-diethyl-n'-(6-methoxy-8-quinolinyl)-" "1,3-propanediamine,n1,n1-diethyl-n3-(6-methoxy-8-quinolinyl)-" "1,3-propanediamine,n,n-diethyl-n'-(6-methoxy-8-quinolinyl)- (9ci); quinoline, 8-[[3-(diethylamino)propyl]amino]-6-methoxy-(6ci,7ci,8ci); 6-methoxy-8-(3-diethylaminopropylamino)quinoline; 710f;8-(3-diethylaminopropylamino)-6-methoxyquinoline; antimalarine; fourneau 710;plasmocid; rhodochin; rhodoquine; s. n. 3115; sn 3,115" );
standardThermochemistry
{
    dHf_298   32020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     671.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=464280.0
}
