/*--------------------------------*- Choupo -*-----------------------*\
  Component: ctk0h6811  (C8H12O2, CAS 10279-96-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ctk0h6811;
formula     C8H12O2;
CAS         10279-96-6;
InChIKey    ULUSIRSODBCBJW-UHFFFAOYSA-N;
MW          140.182;      // g/mol [origin=calculated method=formula-sum]
Tc          674.24;      // K   [origin=predictive method=joback]
Pc          38.010;      // bar [origin=predictive method=joback]
omega       0.4053;      // -   [origin=predictive method=lee-kesler]
Tb          456.36;      // K   [origin=predictive method=joback]
HvapTb      42024.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.65 1.1744 -0.0009424 3.064e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 4; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -280550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     71.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=6680.0
}
