/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2,5-dichloro-3-fluorobenzene  (C6H2BrCl2F, CAS 202865-57-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo25Dichloro3Fluorobenzene;
formula     C6H2BrCl2F;
CAS         202865-57-4;
InChIKey    CAYJMDVKWMVOLG-UHFFFAOYSA-N;
MW          243.884;      // g/mol [origin=calculated method=formula-sum]
Tc          757.72;      // K   [origin=predictive method=joback]
Pc          41.197;      // bar [origin=predictive method=joback]
omega       0.4911;      // -   [origin=predictive method=lee-kesler]
Tb          518.79;      // K   [origin=predictive method=joback]
HvapTb      47600.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.49 0.38 -0.00026128 6.87e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACCl; count 2; } { group Br; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group F; count 1; } { group Cl; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2,5-bis(chloranyl)-3-fluoranyl-benzene" "2,5-dichloro-3-fluorobromobenzene" "3-bromo-2,5-dichloro-1-fluorobenzene" "benzene, 1-bromo-2,5-dichloro-3-fluoro-" "1-bromo-2,5-dichloro-3-fluorobenzene;3-bromo-2,5-dichloro-1-fluorobenzene;" );
gibbsFormation
{
    dHf_298   -166310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-121190.0
    phase     gas;
}
