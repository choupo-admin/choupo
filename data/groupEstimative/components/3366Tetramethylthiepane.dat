/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3,6,6-tetramethylthiepane  (C10H20S, CAS 53561-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3366Tetramethylthiepane;
formula     C10H20S;
CAS         53561-47-0;
InChIKey    KYRUZIUZBMLVTF-UHFFFAOYSA-N;
MW          172.33;      // g/mol [origin=calculated method=formula-sum]
Tc          733.98;      // K   [origin=predictive method=joback]
Pc          27.789;      // bar [origin=predictive method=joback]
omega       0.2784;      // -   [origin=predictive method=lee-kesler]
Tb          495.86;      // K   [origin=predictive method=joback]
HvapTb      41656.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.15 1.63809 -0.0015833 6.641e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 2; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group C_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-thiacycloheptane,3,3,6,6-tetramethyl-" "1-thiacycloheptane, 3,3,6,6-tetramethyl-" );
standardThermochemistry
{
    dHf_298   -146170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     681.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66840.0
}
