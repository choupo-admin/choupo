/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, 1,1'-[(1-methyl-1,2-ethanediyl)bis(oxy)]bis-  (C15H16O2, CAS 69813-63-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzene111Methyl12EthanediylBisOxyBis;
formula     C15H16O2;
CAS         69813-63-4;
InChIKey    PUNWJRNLMGKRDH-UHFFFAOYSA-N;
MW          228.291;      // g/mol [origin=calculated method=formula-sum]
Tc          873.48;      // K   [origin=predictive method=joback]
Pc          24.459;      // bar [origin=predictive method=joback]
omega       0.6461;      // -   [origin=predictive method=lee-kesler]
Tb          640.56;      // K   [origin=predictive method=joback]
HvapTb      57968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.239 1.15052 -0.0006358 1.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2O; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenoxypropan-2-yloxybenzene" "agn-pc-02volf" );
gibbsFormation
{
    dHf_298   -149590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.47;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=87800.0
    phase     gas;
}
