/*--------------------------------*- Choupo -*-----------------------*\
  Component: deoxycholic acid  (C24H40O4, CAS 83-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        deoxycholicAcid;
formula     C24H40O4;
CAS         83-44-3;
InChIKey    KXGVEGMKQFWNSR-LLQZFEROSA-N;
MW          392.58;      // g/mol [origin=calculated method=formula-sum]
Tc          1351.48;      // K   [origin=predictive method=joback]
Pc          14.017;      // bar [origin=predictive method=joback]
omega       1.2720;      // -   [origin=predictive method=lee-kesler]
Tb          1103.59;      // K   [origin=predictive method=joback]
HvapTb      115817.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-302.288 3.41546 -0.0028554 1.0242e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 10; } { group CH; count 8; } { group C; count 2; } { group OH; count 2; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 7; } { group C_ring; count 2; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4r)-4-[(3r,5r,8r,9s,10s,12s,13r,14s,17r)-10,13-dimethyl-3,12-bis(oxidanyl)-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-17-yl]pentanoic acid" "deoxycholate" "desoxycholic acid" "choleic acid" "7-deoxycholic acid" "(3alpha,5beta,12alpha)-3,12-dihydroxycholan-24-oic acid" "7alpha-deoxycholic acid" "desoxycholsaeure" "cholerebic" "cholorebic" "degalol" "deoxycholatic acid" );
standardThermochemistry
{
    dHf_298   -1009520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     902.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-335820.0
}
