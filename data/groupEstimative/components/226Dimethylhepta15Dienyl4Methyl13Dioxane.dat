/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,6-dimethylhepta-1,5-dienyl)-4-methyl-1,3-dioxane  (C14H24O2, CAS 57282-45-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        226Dimethylhepta15Dienyl4Methyl13Dioxane;
formula     C14H24O2;
CAS         57282-45-8;
InChIKey    TXTBETUBCFNUNQ-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          805.23;      // K   [origin=predictive method=joback]
Pc          19.003;      // bar [origin=predictive method=joback]
omega       0.5792;      // -   [origin=predictive method=lee-kesler]
Tb          596.78;      // K   [origin=predictive method=joback]
HvapTb      55974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.608 1.46328 -0.0009078 2.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 2; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group dCH; count 2; } { group dC; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "agn-pc-03dcme" "1,3-dioxane, 2-(2,6-dimethyl-1,5-heptadienyl)-4-methyl-" "1,3-dioxane, 2-(2,6-dimethyl-1,5-heptadien-1-yl)-4-methyl-" "(2s,4r)-2-[(1z)-2,6-dimethylhepta-1,5-dienyl]-4-methyl-1,3-dioxane" );
standardThermochemistry
{
    dHf_298   -347450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     504.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54840.0
}
