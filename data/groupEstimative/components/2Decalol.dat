/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-decalol  (C10H18O, CAS 825-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Decalol;
formula     C10H18O;
CAS         825-51-4;
InChIKey    UPMAOXLCTXPPAG-UHFFFAOYSA-N;
MW          154.253;      // g/mol [origin=calculated method=formula-sum]
Tc          753.00;      // K   [origin=predictive method=joback]
Pc          32.320;      // bar [origin=predictive method=joback]
omega       0.7200;      // -   [origin=predictive method=lee-kesler]
Tb          546.47;      // K   [origin=predictive method=joback]
HvapTb      54738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.94 1.2247 -0.00075 1.684e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 3; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,4,4a,5,6,7,8,8a-decahydronaphthalen-2-ol" "2-naphthalenol, decahydro-" "2-hydroxydecalin" "2-decalinol" "2-naphthol, decahydro-" "decahydronapthol-2" "decahydro-2-naphthol" "decalin-2-ol" "decahydronaphthol-2" "naphthalen-2-ol, decahydro-" "decahydro-beta-naphthol" "trans-decahydro-2-naphthol" );
standardThermochemistry
{
    dHf_298   -301340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-38110.0
}
