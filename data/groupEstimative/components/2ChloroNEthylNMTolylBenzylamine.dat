/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-chloro-n-ethyl-n-(m-tolyl)benzylamine  (C16H18ClN, CAS 65151-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2ChloroNEthylNMTolylBenzylamine;
formula     C16H18ClN;
CAS         65151-24-8;
InChIKey    QJVZEZUKVBECII-UHFFFAOYSA-N;
MW          259.777;      // g/mol [origin=calculated method=formula-sum]
Tc          910.15;      // K   [origin=predictive method=joback]
Pc          21.414;      // bar [origin=predictive method=joback]
omega       0.6902;      // -   [origin=predictive method=lee-kesler]
Tb          678.87;      // K   [origin=predictive method=joback]
HvapTb      63514.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-48.668 1.37774 -0.00090792 2.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[(2-chlorophenyl)methyl]-n-ethyl-3-methyl-aniline" "benzenemethanamine, 2-chloro-n-ethyl-n-(3-methylphenyl)-" "m-toluidine, n-(o-chlorobenzyl)-n-ethyl-" "n-[(2-chlorophenyl)methyl]-n-ethyl-3-methylaniline" "benzenemethanamine,2-chloro-n-ethyl-n-(3-methylphenyl)-" );
standardThermochemistry
{
    dHf_298   128340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     603.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=388250.0
}
