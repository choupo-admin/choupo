/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,4-triacetoxy-2,2-dichlorobutane  (C10H14Cl2O6, CAS 141942-59-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        114Triacetoxy22Dichlorobutane;
formula     C10H14Cl2O6;
CAS         141942-59-8;
InChIKey    PRCAGFHSFZDMCU-UHFFFAOYSA-N;
MW          301.116;      // g/mol [origin=calculated method=formula-sum]
Tc          874.50;      // K   [origin=predictive method=joback]
Pc          20.475;      // bar [origin=predictive method=joback]
omega       0.9312;      // -   [origin=predictive method=lee-kesler]
Tb          674.25;      // K   [origin=predictive method=joback]
HvapTb      67161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.652 0.93476 -0.0004522 2.59e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH3COO; count 3; } { group CCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group Cl; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[4,4-diacetyloxy-3,3-bis(chloranyl)butyl] ethanoate" "(4,4-diacetyloxy-3,3-dichlorobutyl) acetate" );
gibbsFormation
{
    dHf_298   -1247080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     717.82;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-921250.0
    phase     gas;
}
