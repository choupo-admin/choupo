/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-isopropoxyethanol  (C5H12O2, CAS 109-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Isopropoxyethanol;
formula     C5H12O2;
CAS         109-59-1;
InChIKey    HCGFUIQPSOCUHI-UHFFFAOYSA-N;
MW          104.149;      // g/mol [origin=calculated method=formula-sum]
Tc          593.68;      // K   [origin=predictive method=joback]
Pc          38.340;      // bar [origin=predictive method=joback]
omega       0.7626;      // -   [origin=predictive method=lee-kesler]
Tb          428.16;      // K   [origin=predictive method=joback]
HvapTb      45425.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (27.452 0.45554 -0.0001708 2.8e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propan-2-yloxyethanol" "isopropyl oxitol" "ethanol, 2-(1-methylethoxy)-" "ethanol, 2-isopropoxy-" "isopropyl cellosolve" "isopropoxyethanol" "isopropyl glycol" "dowanal eipat" "isopropylethanediol" "ucar ac" "ethylene glycol monoisopropyl ether" "ethylene glycol isopropyl ether" );
gibbsFormation
{
    dHf_298   -436260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-253040.0
    phase     gas;
}
