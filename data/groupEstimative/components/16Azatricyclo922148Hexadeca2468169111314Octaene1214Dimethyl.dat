/*--------------------------------*- Choupo -*-----------------------*\
  Component: 16-azatricyclo[9.2.2.14,8]hexadeca-2,4,6,8(16),9,11,13,14-octaene,12,14-dimethyl-  (C17H15N, CAS 64000-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Azatricyclo922148Hexadeca2468169111314Octaene1214Dimethyl;
formula     C17H15N;
CAS         64000-97-1;
InChIKey    VTQYKNBJAMJQKU-VRHVFUOLSA-N;
MW          233.314;      // g/mol [origin=calculated method=formula-sum]
Tc          992.71;      // K   [origin=predictive method=joback]
Pc          25.328;      // bar [origin=predictive method=joback]
omega       0.6789;      // -   [origin=predictive method=lee-kesler]
Tb          729.54;      // K   [origin=predictive method=joback]
HvapTb      67824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-58.86 1.3126 -0.00090826 2.503e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 2; } { group ACH; count 2; } { group AC; count 2; } { group ACCH3; count 2; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 6; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "16-azatricyclo(9.2.2.14,8)hexadeca-2,4,6,8(16),9,11,13,14-octaene, 12,14-dimethyl-" );
standardThermochemistry
{
    dHf_298   268300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     490.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=471890.0
}
