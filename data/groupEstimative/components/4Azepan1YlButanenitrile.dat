/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(azepan-1-yl)butanenitrile  (C10H18N2, CAS 3194-43-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Azepan1YlButanenitrile;
formula     C10H18N2;
CAS         3194-43-2;
InChIKey    OQPSAQBHEQYYMJ-UHFFFAOYSA-N;
MW          166.268;      // g/mol [origin=calculated method=formula-sum]
Tc          779.87;      // K   [origin=predictive method=joback]
Pc          25.846;      // bar [origin=predictive method=joback]
omega       0.6203;      // -   [origin=predictive method=lee-kesler]
Tb          567.14;      // K   [origin=predictive method=joback]
HvapTb      51113.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-71.437 1.1611 -0.0007382 1.767e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH2N; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 6; } { group N; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(hexamethyleneimino)butyronitrile" "hexahydro-1h-azepine-1-butyronitrile" "1h-azepine-1-butyronitrile, hexahydro-" "1-(hexahydro-1h-azepin-1-yl)butyronitrile" "butyronitrile, 1-(hexahydro-1h-azepin-1-yl)-" "4-azaperhydroepinylbutanenitrile" "1h-azepine-1-butanenitrile,hexahydro-" "4-hexamethyleneiminobutyronitrile" );
gibbsFormation
{
    dHf_298   57340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     579.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=309440.0
    phase     gas;
}
