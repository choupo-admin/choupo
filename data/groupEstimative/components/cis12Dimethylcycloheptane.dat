/*--------------------------------*- Choupo -*-----------------------*\
  Component: cis-1,2-dimethylcycloheptane  (C9H18, CAS 13151-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cis12Dimethylcycloheptane;
formula     C9H18;
CAS         13151-51-4;
InChIKey    CLYDEJQPKBFLJW-UHFFFAOYSA-N;
MW          126.243;      // g/mol [origin=calculated method=formula-sum]
Tc          631.50;      // K   [origin=predictive method=joback]
Pc          28.143;      // bar [origin=predictive method=joback]
omega       0.2649;      // -   [origin=predictive method=lee-kesler]
Tb          424.67;      // K   [origin=predictive method=joback]
HvapTb      35920.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.08 0.94484 -0.000445 4.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-dimethylcycloheptane" "(1s,2s)-1,2-dimethylcycloheptane" );
standardThermochemistry
{
    dHf_298   -201270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     453.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=29540.0
}
