/*--------------------------------*- Choupo -*-----------------------*\
  Component: octahydro-1:2:5:6-dibenzanthracene  (C22H22, CAS 63021-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octahydro1256Dibenzanthracene;
formula     C22H22;
CAS         63021-67-0;
InChIKey    VSNBWRZXEXDEHO-UHFFFAOYSA-N;
MW          286.418;      // g/mol [origin=calculated method=formula-sum]
Tc          1044.18;      // K   [origin=predictive method=joback]
Pc          19.237;      // bar [origin=predictive method=joback]
omega       0.6875;      // -   [origin=predictive method=lee-kesler]
Tb          785.26;      // K   [origin=predictive method=joback]
HvapTb      70336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-198.45 2.1776 -0.0016474 4.958e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH; count 2; } { group CH=CH; count 1; } { group ACH; count 8; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6a,7,7a,12,13,13a,14,14a-octahydronaphtho[1,2-b]phenanthrene" "dibenz(a,h)anthracene, octahydro-" "5,6,6a,7,7a,13a,14,14a-octahydrobenzo[k]tetraphene" );
standardThermochemistry
{
    dHf_298   202390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=532320.0
}
