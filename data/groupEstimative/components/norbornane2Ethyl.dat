/*--------------------------------*- Choupo -*-----------------------*\
  Component: norbornane, 2-ethyl-  (C9H16, CAS 2146-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        norbornane2Ethyl;
formula     C9H16;
CAS         2146-41-0;
InChIKey    DEMFSGPWYVAINM-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          617.63;      // K   [origin=predictive method=joback]
Pc          29.861;      // bar [origin=predictive method=joback]
omega       0.3189;      // -   [origin=predictive method=lee-kesler]
Tb          418.60;      // K   [origin=predictive method=joback]
HvapTb      35317.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.959 1.12452 -0.0008044 2.364e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethylbicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane, 2-ethyl-" "2-ethylbicyclo[2.2.1]heptane" "bicyclo(2.2.1)heptane, 2-ethyl-" "5-ethylnorbornane" "agn-pc-00c60i" "2-ethyl bicyclo(2.2.1)heptane" "bicyclo[2.2.1]heptane,2-ethyl-" );
gibbsFormation
{
    dHf_298   -109990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     303.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=126590.0
    phase     gas;
}
