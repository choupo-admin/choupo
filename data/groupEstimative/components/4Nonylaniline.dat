/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-nonylaniline  (C15H25N, CAS 37529-29-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Nonylaniline;
formula     C15H25N;
CAS         37529-29-6;
InChIKey    FDECURPHVMNAKO-UHFFFAOYSA-N;
MW          219.372;      // g/mol [origin=calculated method=formula-sum]
Tc          847.72;      // K   [origin=predictive method=joback]
Pc          19.153;      // bar [origin=predictive method=joback]
omega       0.7995;      // -   [origin=predictive method=lee-kesler]
Tb          646.99;      // K   [origin=predictive method=joback]
HvapTb      62563.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-23.862 1.35232 -0.00079976 1.789e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 4; } { group ACCH2; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-nonylaniline" "p-n-nonylaniline" "4-n-nonylaniline" "benzenamine, 4-nonyl-" "1-amino-4-n-nonylbenzene" "aniline,p-nonyl- (6ci,7ci);4-nonylphenylamine;4-n-nonylaniline;p-nonylaniline;p-n-nonylaniline;" );
gibbsFormation
{
    dHf_298   -94080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     679.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=244650.0
    phase     gas;
}
