/*--------------------------------*- Choupo -*-----------------------*\
  Component: l-isoleucinol  (C6H15NO, CAS 24629-25-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        lIsoleucinol;
formula     C6H15NO;
CAS         24629-25-2;
InChIKey    VTQHAQXFSHDMHT-NTSWFWBYSA-N;
MW          117.192;      // g/mol [origin=calculated method=formula-sum]
Tc          680.86;      // K   [origin=predictive method=joback]
Pc          37.684;      // bar [origin=predictive method=joback]
omega       0.8961;      // -   [origin=predictive method=lee-kesler]
Tb          500.71;      // K   [origin=predictive method=joback]
HvapTb      55494.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.852 0.68154 -0.0003828 8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2s,3s)-2-azanyl-3-methyl-pentan-1-ol" "(s)-(+)-isoleucinol" "(2s,3s)-2-amino-3-methylpentan-1-ol" "l-(+)-isoleucinol" "h-isoleucinol" "l(+)-isoleucinol" "(2s,3s)-2-amino-3-methyl-1-pentanol" "(2s,3s)-(+)-2-amino-3-methyl-1-pentanol" "1-pentanol,2-amino-3-methyl-, l-erythro- (8ci);(2s,3s)-2-amino-3-methylpentan-1-ol;(2s,3s)-isoleucinol;(s)-isoleucinol;(s)-sec-leucinol;l-isoleucinol;[(1s,2s)-1-(hydroxymethyl)-2-methylbutyl]amine;l-ile-ol;h-isoleucinol;" );
gibbsFormation
{
    dHf_298   -296170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     473.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-75610.0
    phase     gas;
}
