name        4Bis2CyanoethylAminoBenzaldehyde;
formula     C13H13N3O;
CAS         17354-79-9;
InChIKey    VWILPRABHZNINB-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          227.267;      // g/mol [origin=calculated method=formula-sum]
Tc          944.43;      // K   [origin=predictive method=joback]
Pc          21.473;      // bar [origin=predictive method=joback]
omega       0.8830;      // -   [origin=predictive method=lee-kesler]
Tb          721.72;      // K   [origin=predictive method=joback]
HvapTb      68096.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.726 1.102 -0.00085116 2.656e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2N; count 1; } { group CH2CN; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group N; count 1; } { group CN; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-cyanoethyl-(4-methanoylphenyl)amino]propanenitrile" "p-[bis(2-cyanoethyl)amino]benzaldehyde" "p-(bis(2-cyanoethyl)amino)benzaldehyde" "4-[bis(2-cyanoethyl)amino]benzaldehyde" "4-(n,n-bis(2-cyanoethyl)amino)benzaldehyde" "4-[n,n-bis(2-cyanoethyl)amino]benzaldehyde" "propanenitrile, 3,3'-((4-formylphenyl)imino)bis-" "propanenitrile, 3,3'-[(4-formylphenyl)imino]bis-" "3-[(2-cyanoethyl)(4-formylphenyl)amino]propanenitrile" "p-bis(beta-cyanoethyl)aminobenzaldehyde" "p-bis(.beta.-cyanoethyl)aminobenzaldehyde" "propionitrile,3'-[(p-formylphenyl)imino]di-" );
standardThermochemistry
