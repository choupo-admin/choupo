/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiirane, (ethylthiomethyl)-  (C5H10S2, CAS 93248-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiiraneEthylthiomethyl;
formula     C5H10S2;
CAS         93248-08-9;
InChIKey    BTEBOOYKWHVXIP-UHFFFAOYSA-N;
MW          134.255;      // g/mol [origin=calculated method=formula-sum]
Tc          661.55;      // K   [origin=predictive method=joback]
Pc          41.250;      // bar [origin=predictive method=joback]
omega       0.3347;      // -   [origin=predictive method=lee-kesler]
Tb          437.35;      // K   [origin=predictive method=joback]
HvapTb      39266.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-10.478 0.63852 -0.0004469 1.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group S; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(ethylsulfanylmethyl)thiirane" "ethylthiothiiran-2-ylmethane" );
gibbsFormation
{
    dHf_298   13400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     372.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124950.0
    phase     gas;
}
