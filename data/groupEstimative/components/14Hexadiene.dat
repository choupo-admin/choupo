/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-hexadiene  (C6H10, CAS 592-45-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Hexadiene;
formula     C6H10;
CAS         592-45-0;
InChIKey    PRBHEGAFLDMLAL-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          513.87;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.2514;      // -   [origin=predictive method=lee-kesler]
Tb          337.72;      // K   [origin=predictive method=joback]
HvapTb      28238.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-19.739 0.57382 -0.0004093 1.25e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-1,4-diene" "trans-1,4-hexadiene" "1,4-hexadiene, (4e)-" "1,4-hexadiene, (4z)-" "1,4-hexadiene,cis-trans" );
standardThermochemistry
{
    dHf_298   75480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     378.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=167700.0
}
