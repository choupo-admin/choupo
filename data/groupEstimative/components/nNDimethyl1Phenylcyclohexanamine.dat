/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyl-1-phenylcyclohexanamine  (C14H21N, CAS 2201-17-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyl1Phenylcyclohexanamine;
formula     C14H21N;
CAS         2201-17-4;
InChIKey    FQPQJXVSQZUUQU-UHFFFAOYSA-N;
MW          203.329;      // g/mol [origin=calculated method=formula-sum]
Tc          816.07;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       0.4669;      // -   [origin=predictive method=lee-kesler]
Tb          578.83;      // K   [origin=predictive method=joback]
HvapTb      50355.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-170.03 1.79284 -0.0014952 5.259e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-1-phenyl-cyclohexan-1-amine" "cyclohexylamine, n,n-dimethyl-1-phenyl-," "cyclohexylamine, n,n-dimethyl-1-phenyl-" "cyclohexanamine,n,n-dimethyl-1-phenyl-" "n,n-dimethyl-1-phenylcyclohexan-1-amine" "cyclohexylamine,n,n-dimethyl-1-phenyl- (6ci,7ci,8ci); n,n-dimethyl-1-phenylcyclohexylamine" );
standardThermochemistry
{
    dHf_298   41330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=309150.0
}
