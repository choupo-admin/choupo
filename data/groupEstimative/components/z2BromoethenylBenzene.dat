/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(z)-2-bromoethenyl]benzene  (C8H7Br, CAS 588-73-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        z2BromoethenylBenzene;
formula     C8H7Br;
CAS         588-73-8;
InChIKey    YMOONIIMQBGTDU-SREVYHEPSA-N;
MW          183.048;      // g/mol [origin=calculated method=formula-sum]
Tc          719.98;      // K   [origin=predictive method=joback]
Pc          42.496;      // bar [origin=predictive method=joback]
omega       0.3770;      // -   [origin=predictive method=lee-kesler]
Tb          479.64;      // K   [origin=predictive method=joback]
HvapTb      42071.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.28 0.7431 -0.0005978 1.91e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(z)-2-bromanylethenyl]benzene" "benzene, (2-bromoethenyl)-, (z)-" "bromostyrene" "benzene, ((1z)-2-bromoethenyl)-" "cis-styryl bromide" "(z)-styryl bromide" "cis-beta-bromostyrene" "(z)-beta-bromostyrene" "beta-bromostyrene, (z)-" "(z)-(2-bromovinyl)benzene" "cis-1-bromo-2-phenylethylene" "(z)-1-bromo-2-phenylethene" );
gibbsFormation
{
    dHf_298   171630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     405.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223430.0
    phase     gas;
}
