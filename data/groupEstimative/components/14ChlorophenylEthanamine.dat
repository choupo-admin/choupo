/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-chlorophenyl)ethanamine  (C8H10ClN, CAS 6299-02-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14ChlorophenylEthanamine;
formula     C8H10ClN;
CAS         6299-02-1;
InChIKey    PINPOEWMCLFRRB-UHFFFAOYSA-N;
MW          155.625;      // g/mol [origin=calculated method=formula-sum]
Tc          758.93;      // K   [origin=predictive method=joback]
Pc          37.090;      // bar [origin=predictive method=joback]
omega       0.4890;      // -   [origin=predictive method=lee-kesler]
Tb          523.82;      // K   [origin=predictive method=joback]
HvapTb      50978.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.29 0.70002 -0.00044256 1.041e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CHNH2; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-chlorophenyl)ethylamine" "4-chloro-alpha-methylbenzylamine" "1-(4-chlorophenyl)-ethyl-amine" "4-chloro-alpha-methyl benzylamine" "1-(4-chlorophenyl)ethan-1-amine" "4-chloro-" "a-methyl-benzenemethanamine; 4-chloro-" "a-methylbenzylamine" "rac-1-(4-chlorophenyl)ethylamine; 1-(4-chloro-phenyl)-ethylamine; r-1-(4-chlorophenyl)ethylamine; (4-chlorophenyl)-1-ethylamine; 4-chloro-" "a-methylbenzylamine; p-chloro-" "a-methylbenzylamine" );
standardThermochemistry
{
    dHf_298   29380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     430.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171340.0
}
