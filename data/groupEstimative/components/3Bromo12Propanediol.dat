/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-bromo-1,2-propanediol  (C3H7BrO2, CAS 4704-77-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Bromo12Propanediol;
formula     C3H7BrO2;
CAS         4704-77-2;
InChIKey    SIBFQOUHOCRXDL-UHFFFAOYSA-N;
MW          154.991;      // g/mol [origin=calculated method=formula-sum]
Tc          695.15;      // K   [origin=predictive method=joback]
Pc          64.515;      // bar [origin=predictive method=joback]
omega       1.3149;      // -   [origin=predictive method=lee-kesler]
Tb          518.32;      // K   [origin=predictive method=joback]
HvapTb      61677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.252 0.4009 -0.0002748 7.77e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group OH; count 2; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-bromanylpropane-1,2-diol" "monobromoglycerol" "3-bromopropane-1,2-diol" "alpha-bromohydrin" "1,2-propanediol, 3-bromo-" "bromodeoxyglycerol" "glycerol bromohydrin" "1-bromo-2,3-propanediol" "(rs)-3-bromo-1,2-propanediol" "alpha-glycerol bromohydrin" "1,2-propanediol,3-bromo-, (2s)-" "(s)-3-bromo-1,2-propanediol" );
gibbsFormation
{
    dHf_298   -388660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     416.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-287380.0
    phase     gas;
}
