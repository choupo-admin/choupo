/*--------------------------------*- Choupo -*-----------------------*\
  Component: apomorphine  (C17H17NO2, CAS 58-00-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        apomorphine;
formula     C17H17NO2;
CAS         58-00-4;
InChIKey    VMWNQDUVQKEIOC-CYBMUJFWSA-N;
MW          267.328;      // g/mol [origin=calculated method=formula-sum]
Tc          1093.49;      // K   [origin=predictive method=joback]
Pc          34.848;      // bar [origin=predictive method=joback]
omega       1.2481;      // -   [origin=predictive method=lee-kesler]
Tb          840.15;      // K   [origin=predictive method=joback]
HvapTb      87836.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-162.19 2.06312 -0.0019762 7.576e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group AC; count 2; } { group ACCH2; count 2; } { group ACCH; count 1; } { group ACOH; count 2; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 7; } { group OH_phenol; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(6ar)-6-methyl-5,6,6a,7-tetrahydro-4h-dibenzo[de,g]quinoline-10,11-diol" "uprima" "apomorfin" "apomorphin" "apokyn" "ixense" "l-apomorphine" "r-(-)-apomorphine" "(-)-10,11-dihydroxyaporphine" "apormorphine" "6abeta-aporphine-10,11-diol" "iv apomorphine" );
standardThermochemistry
{
    dHf_298   -64390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.84;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=243140.0
}
