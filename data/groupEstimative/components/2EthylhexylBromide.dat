/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl bromide  (C8H17Br, CAS 18908-66-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylBromide;
formula     C8H17Br;
CAS         18908-66-2;
InChIKey    NZWIYPLSXWYKLH-UHFFFAOYSA-N;
MW          193.128;      // g/mol [origin=calculated method=formula-sum]
Tc          633.42;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       0.4906;      // -   [origin=predictive method=lee-kesler]
Tb          448.36;      // K   [origin=predictive method=joback]
HvapTb      39449.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.125 0.80794 -0.000486 1.176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(bromomethyl)heptane" "1-bromo-2-ethylhexane" "heptane, 3-(bromomethyl)-" "2-ethylhexylbromide" "3-(bromomethyl)-heptane" "agn-pc-04t8qs" "dl-1-bromo-2-ethylhexane" "1-bromo-2-ethylhexane;2-ethyl-1-hexyl bromide;3-(bromomethyl)heptane;" );
gibbsFormation
{
    dHf_298   -187400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     509.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=28360.0
    phase     gas;
}
