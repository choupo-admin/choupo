/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-cyclohexylbenzoic acid  (C13H16O2, CAS 20029-52-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4CyclohexylbenzoicAcid;
formula     C13H16O2;
CAS         20029-52-1;
InChIKey    QCIWHVKGVVQHIY-UHFFFAOYSA-N;
MW          204.269;      // g/mol [origin=calculated method=formula-sum]
Tc          939.39;      // K   [origin=predictive method=joback]
Pc          29.030;      // bar [origin=predictive method=joback]
omega       0.7873;      // -   [origin=predictive method=lee-kesler]
Tb          693.76;      // K   [origin=predictive method=joback]
HvapTb      65063.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-89.54 1.2733 -0.00080116 1.817e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-cyclohexyl-benzoic acid" "(4-carboxyphenyl)cyclohexane" );
gibbsFormation
{
    dHf_298   -382540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     572.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158100.0
    phase     gas;
}
