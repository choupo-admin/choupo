/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-dodecoxy-3-tetradecoxypropan-1-ol  (C29H60O3, CAS 1561-56-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Dodecoxy3Tetradecoxypropan1Ol;
formula     C29H60O3;
CAS         1561-56-4;
InChIKey    LHKQPLMRPKTZHX-UHFFFAOYSA-N;
MW          456.796;      // g/mol [origin=calculated method=formula-sum]
Tc          1264.13;      // K   [origin=predictive method=joback]
Pc          6.455;      // bar [origin=predictive method=joback]
omega       0.3141;      // -   [origin=predictive method=lee-kesler]
Tb          999.70;      // K   [origin=predictive method=joback]
HvapTb      101259.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.136 2.67234 -0.0013654 2.336e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 24; } { group CH2O; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 26; } { group CH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-dodecoxy-3-tetradecoxy-propan-1-ol" "1-propanol, 2-dodecyloxy-3-tetradecyloxy-" "1-propanol, 2-dodecyloxy-3-tetradecyloxy-," "2-(dodecyloxy)-3-(tetradecyloxy)propan-1-ol" );
gibbsFormation
{
    dHf_298   -1063840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1349.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155960.0
    phase     gas;
}
