/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,6-dimethylhepta-1,5-dienyl)-4,5-dimethyl-1,3-dioxolane  (C14H24O2, CAS 68140-51-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        226Dimethylhepta15Dienyl45Dimethyl13Dioxolane;
formula     C14H24O2;
CAS         68140-51-2;
InChIKey    XPCRVJQZWNHAQD-UHFFFAOYSA-N;
MW          224.344;      // g/mol [origin=calculated method=formula-sum]
Tc          789.52;      // K   [origin=predictive method=joback]
Pc          18.077;      // bar [origin=predictive method=joback]
omega       0.5817;      // -   [origin=predictive method=lee-kesler]
Tb          587.84;      // K   [origin=predictive method=joback]
HvapTb      55493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.548 1.4464 -0.0008988 2.195e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 2; } { group CH-O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 2; } { group dCH; count 2; } { group dC; count 2; } { group CH_ring; count 3; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-(2,6-dimethyl-1,5-heptadienyl)-4,5-dimethyl-" "1,3-dioxolane, 2-(2,6-dimethyl-1,5-heptadien-1-yl)-4,5-dimethyl-" );
standardThermochemistry
{
    dHf_298   -361630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=59230.0
}
