/*--------------------------------*- Choupo -*-----------------------*\
  Component: octadecanedioic acid  (C18H34O4, CAS 871-70-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octadecanedioicAcid;
formula     C18H34O4;
CAS         871-70-5;
InChIKey    BNJOQKFENDDGSC-UHFFFAOYSA-N;
MW          314.466;      // g/mol [origin=calculated method=formula-sum]
Tc          1105.51;      // K   [origin=predictive method=joback]
Pc          13.052;      // bar [origin=predictive method=joback]
omega       1.2031;      // -   [origin=predictive method=lee-kesler]
Tb          902.46;      // K   [origin=predictive method=joback]
HvapTb      89990.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.274 1.8154 -0.0011006 2.59e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 16; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 16; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecandis" "1,16-hexadecanedicarboxylic acid" "hexadecanedicarboxylic acid" "octadecanedioate" "1,18-octadecanedioate" "1,18-octadecanedioic acid" "1,16-hexadecanedicarboxylate" "octadecane-1,18-dioic acid" "1,16-dicarboxyhexadecane;1,16-hexadecanedicarboxylic acid;1,18-octadecanedioic acid;emerox 118;" );
standardThermochemistry
{
    dHf_298   -1115390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     963.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-587140.0
}
