/*--------------------------------*- Choupo -*-----------------------*\
  Component: aminoacetaldehyde dimethyl acetal  (C4H11NO2, CAS 22483-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        aminoacetaldehydeDimethylAcetal;
formula     C4H11NO2;
CAS         22483-09-6;
InChIKey    QKWWDTYDYOFRJL-UHFFFAOYSA-N;
MW          105.137;      // g/mol [origin=calculated method=formula-sum]
Tc          594.47;      // K   [origin=predictive method=joback]
Pc          40.518;      // bar [origin=predictive method=joback]
omega       0.4971;      // -   [origin=predictive method=lee-kesler]
Tb          408.05;      // K   [origin=predictive method=joback]
HvapTb      39571.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (55.061 0.32524 -1.84e-05 -6.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH3O; count 2; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group O; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethoxyethanamine" "2,2-dimethoxyethylamine" "ethanamine, 2,2-dimethoxy-" "dimethylaminoacetal" "amino acetaldehyde dimethyl acetal" "ethanamine,2-dimethoxy-" "2,2-dimethoxyethan-1-amine" "1-amino-2,2-dimethoxyethane" "i402" "2-aminoacetaldehyde dimethyl acetal" "acetaldehyde, amino-, dimethyl acetal (8ci)" );
standardThermochemistry
{
    dHf_298   -361820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     376.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-163190.0
}
