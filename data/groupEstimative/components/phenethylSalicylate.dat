/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenethyl salicylate  (C15H14O3, CAS 87-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenethylSalicylate;
formula     C15H14O3;
CAS         87-22-9;
InChIKey    YNMSDIQQNIRGDP-UHFFFAOYSA-N;
MW          242.274;      // g/mol [origin=calculated method=formula-sum]
Tc          978.28;      // K   [origin=predictive method=joback]
Pc          29.473;      // bar [origin=predictive method=joback]
omega       0.9318;      // -   [origin=predictive method=lee-kesler]
Tb          735.00;      // K   [origin=predictive method=joback]
HvapTb      73957.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.068 1.3708 -0.00101636 2.943e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 9; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenylethyl 2-oxidanylbenzoate" "2-phenylethyl 2-hydroxybenzoate" "2-phenylethyl salicylate" "phenylethyl salicyalte" "benzylcarbinyl salicylate" ".beta.-phenylethyl salicylate" "salicylic acid, phenethyl ester" "benzoic acid, 2-hydroxy-, 2-phenylethyl ester" "benzyl carbinyl salicylate" "beta-phenylethyl salicylate" "phenethyl 2-hydroxybenzoate" "benzylcarbinyl 2-hydroxybenzoate" );
standardThermochemistry
{
    dHf_298   -374460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     605.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164750.0
}
