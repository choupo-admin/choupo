/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-tritriacontene  (C33H66, CAS 61868-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tritriacontene;
formula     C33H66;
CAS         61868-11-9;
InChIKey    DRJAAODMPBOZLH-UHFFFAOYSA-N;
MW          462.891;      // g/mol [origin=calculated method=formula-sum]
Tc          1186.59;      // K   [origin=predictive method=joback]
Pc          5.299;      // bar [origin=predictive method=joback]
omega       0.2512;      // -   [origin=predictive method=lee-kesler]
Tb          951.32;      // K   [origin=predictive method=joback]
HvapTb      88382.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-30.1 3.11882 -0.0017943 3.989e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 30; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 30; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tritriacont-1-ene" "tritriacontene" );
gibbsFormation
{
    dHf_298   -599020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1436.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=314820.0
    phase     gas;
}
