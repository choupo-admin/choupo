/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethynyl-1-cyclooctanol  (C10H16O, CAS 55373-76-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethynyl1Cyclooctanol;
formula     C10H16O;
CAS         55373-76-7;
InChIKey    DHAPUKCAOFQTIT-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          761.09;      // K   [origin=predictive method=joback]
Pc          37.271;      // bar [origin=predictive method=joback]
omega       0.6331;      // -   [origin=predictive method=lee-kesler]
Tb          539.03;      // K   [origin=predictive method=joback]
HvapTb      54013.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.97 1.2887 -0.00106733 3.8379e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group C; count 1; } { group OH; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tCH; count 1; } { group tC; count 1; } { group CH2_ring; count 7; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethynylcyclooctan-1-ol" "cyclooctanol, 1-ethynyl-" "1-ethynylcyclooctanol" "1-aethinyl-cyclooctanol-(1) [german]" "1-aethinyl-cyclooctanol-(1)" );
standardThermochemistry
{
    dHf_298   -52820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     644.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=114330.0
}
