/*--------------------------------*- Choupo -*-----------------------*\
  Component: piminodine  (C23H30N2O2, CAS 13495-09-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        piminodine;
formula     C23H30N2O2;
CAS         13495-09-5;
InChIKey    PXXKIYPSXYFATG-UHFFFAOYSA-N;
MW          366.505;      // g/mol [origin=calculated method=formula-sum]
Tc          1149.88;      // K   [origin=predictive method=joback]
Pc          15.710;      // bar [origin=predictive method=joback]
omega       1.0619;      // -   [origin=predictive method=lee-kesler]
Tb          915.55;      // K   [origin=predictive method=joback]
HvapTb      86336.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-182.796 2.59992 -0.0020164 6.418e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group C; count 1; } { group ACH; count 10; } { group AC; count 2; } { group CH2NH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 4-phenyl-1-(3-phenylazanylpropyl)piperidine-4-carboxylate" "anopridine" "alvodine" "cimadon" "pimadin" "pimadine" "pimadin (analgesic)" "piminodine [inn:ban]" "piminodinum [inn-latin]" "piminodine dihydrochloride" "4-phenyl-1-(3-(phenylamino)propyl)-4-piperidinecarboxylic acid ethyl ester" "isonipecotic acid, 1-(3-anilinopropyl)-4-phenyl-, ethyl ester (7ci,8ci)" );
gibbsFormation
{
    dHf_298   -165550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     966.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=288460.0
    phase     gas;
}
