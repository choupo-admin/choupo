/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[4.4]nona-6,8-diene  (C9H12, CAS 766-29-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro44Nona68Diene;
formula     C9H12;
CAS         766-29-0;
InChIKey    FHTXZDURQDIVCD-UHFFFAOYSA-N;
MW          120.195;      // g/mol [origin=calculated method=formula-sum]
Tc          666.85;      // K   [origin=predictive method=joback]
Pc          39.209;      // bar [origin=predictive method=joback]
omega       0.2665;      // -   [origin=predictive method=lee-kesler]
Tb          435.04;      // K   [origin=predictive method=joback]
HvapTb      35712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-161.51 1.3382 -0.00132956 5.394e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro[4.4]nona-1,3-diene" "spiro(4.4)nona-1,3-diene" );
standardThermochemistry
{
    dHf_298   49170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=172240.0
}
