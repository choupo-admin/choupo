/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-2-hydroxycyclohexanecarboxamide  (C7H13NO2, CAS 24947-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2r2Hydroxycyclohexanecarboxamide;
formula     C7H13NO2;
CAS         24947-95-3;
InChIKey    ZYAHCVLOLCHGMC-PHDIDXHHSA-N;
MW          143.186;      // g/mol [origin=calculated method=formula-sum]
Tc          804.42;      // K   [origin=predictive method=joback]
Pc          44.091;      // bar [origin=predictive method=joback]
omega       1.0029;      // -   [origin=predictive method=lee-kesler]
Tb          593.22;      // K   [origin=predictive method=joback]
HvapTb      65362.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-44.0 0.8323 -0.0004377 6.526e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2r)-2-oxidanylcyclohexane-1-carboxamide" "trans-2-hydroxy-1-cyclohexanecarboxamide" "(1r,2r)-2-hydroxycyclohexane-1-carboxamide" "cyclohexanecarboxamide,2-hydroxy-, (1r,2r)-rel-" "cyclohexanecarboxamide,2-hydroxy-, trans- (8ci); trans-2-hydroxycyclohexanecarboxamide" );
standardThermochemistry
{
    dHf_298   -384850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     484.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-174490.0
}
