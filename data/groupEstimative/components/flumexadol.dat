/*--------------------------------*- Choupo -*-----------------------*\
  Component: flumexadol  (C11H12F3NO, CAS 30914-89-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        flumexadol;
formula     C11H12F3NO;
CAS         30914-89-7;
InChIKey    GXPYCYWPUGKQIJ-UHFFFAOYSA-N;
MW          231.217;      // g/mol [origin=calculated method=formula-sum]
Tc          798.69;      // K   [origin=predictive method=joback]
Pc          29.124;      // bar [origin=predictive method=joback]
omega       0.5907;      // -   [origin=predictive method=lee-kesler]
Tb          572.57;      // K   [origin=predictive method=joback]
HvapTb      50968.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.28 1.1773 -0.00076626 1.77e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group FCH2O; count 1; } { group CH2NH; count 1; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 3; } { group O_ring; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[3-(trifluoromethyl)phenyl]morpholine" "flumexadolum [inn-latin]" "1841 cerm" "2-(3-(trifluoromethyl)phenyl)morpholine" "2-(alpha,alpha,alpha-trifluoro-m-tolyl)morpholine" "tetrahydro-2-(alpha,alpha,alpha-trifluoro-m-tolyl)-1,4-oxazine" "1,4-oxazine, tetrahydro-2-(alpha,alpha,alpha-trifluoro-m-tolyl)-" "flumexadolum" "flumexadol [inn]" );
standardThermochemistry
{
    dHf_298   -682260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     440.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-411030.0
}
