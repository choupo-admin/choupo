/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-{2-[(5-ethoxypentan-2-yl)oxy]ethoxy}-2-methylpropan-1-ol  (C13H28O4, CAS 55934-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        325Ethoxypentan2YlOxyEthoxy2Methylpropan1Ol;
formula     C13H28O4;
CAS         55934-93-5;
InChIKey    QVIFIIFBFORLSL-UHFFFAOYSA-N;
MW          248.363;      // g/mol [origin=calculated method=formula-sum]
Tc          820.05;      // K   [origin=predictive method=joback]
Pc          17.232;      // bar [origin=predictive method=joback]
omega       1.1819;      // -   [origin=predictive method=lee-kesler]
Tb          655.60;      // K   [origin=predictive method=joback]
HvapTb      67665.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (69.498 1.09506 -0.0003872 -1.21e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 2; } { group OH; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 8; } { group CH; count 2; } { group OH; count 1; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[2-(5-ethoxypentan-2-yloxy)ethoxy]-2-methyl-propan-1-ol" "tripropylene glycol n-butyl ether" "3-[2-(5-ethoxypentan-2-yloxy)ethoxy]-2-methylpropan-1-ol" );
gibbsFormation
{
    dHf_298   -871100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     728.04;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-398120.0
    phase     gas;
}
