/*--------------------------------*- Choupo -*-----------------------*\
  Component: crotylidene dicrotonate  (C12H16O4, CAS 10141-07-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        crotylideneDicrotonate;
formula     C12H16O4;
CAS         10141-07-8;
InChIKey    BADIPRCUJPQNIE-OTWDQPKHSA-N;
MW          224.256;      // g/mol [origin=calculated method=formula-sum]
Tc          799.04;      // K   [origin=predictive method=joback]
Pc          20.736;      // bar [origin=predictive method=joback]
omega       0.7539;      // -   [origin=predictive method=lee-kesler]
Tb          602.64;      // K   [origin=predictive method=joback]
HvapTb      56606.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.43 1.10016 -0.0006944 1.591e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group CH=CH; count 3; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group dCH; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(e)-1-[(e)-but-2-enoyl]oxybut-2-enyl] (e)-but-2-enoate" "2-butenylidene crotonate" "crotonic acid, 2-butenylidene ester" "2-butenoic acid, 2-butenylidene ester, (e,e,e)- (8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -579190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     696.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-332360.0
}
