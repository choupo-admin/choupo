/*--------------------------------*- Choupo -*-----------------------*\
  Component: (methoxymethyl)trimethoxysilane  (C5H14O4Si, CAS 22859-36-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H14O4Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        methoxymethylTrimethoxysilane;
formula     C5H14O4Si;
CAS         22859-36-5;
InChIKey    IBMUMCCOQRVIMN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          166.248;      // g/mol [origin=calculated method=formula-sum]
Tc          577.69;      // K   [origin=predictive method=joback]
Pc          28.114;      // bar [origin=predictive method=joback]
omega       0.4520;      // -   [origin=predictive method=lee-kesler]
Tb          405.08;      // K   [origin=predictive method=joback]
HvapTb      36658.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (141.161 0.01988 0.0006106 -3.881e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH3O; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group O; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethoxy(methoxymethyl)silane" "methyl (trimethoxysilylmethyl) ether" "ether, methyl (trimethoxysilylmethyl)" "silane,trimethoxy(methoxymethyl)-" );
gibbsFormation
{
    dHf_298   -787030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     522.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-533540.0
    phase     gas;
}
