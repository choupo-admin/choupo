/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-octen-3-ol, 3-methyl-  (C9H18O, CAS 24089-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Octen3Ol3Methyl;
formula     C9H18O;
CAS         24089-00-7;
InChIKey    DRKRLMZMGTWUSQ-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          662.02;      // K   [origin=predictive method=joback]
Pc          26.874;      // bar [origin=predictive method=joback]
omega       0.7787;      // -   [origin=predictive method=lee-kesler]
Tb          491.15;      // K   [origin=predictive method=joback]
HvapTb      50341.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-27.466 0.99864 -0.0006909 1.95e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group CH2=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyloct-1-en-3-ol" "3-methyl-1-octen-3-ol" "3-methyl-1-octen-ol" );
gibbsFormation
{
    dHf_298   -264640.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-21240.0
    phase     gas;
}
