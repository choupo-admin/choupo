/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethyltetradecan-2-amine  (C16H35N, CAS 56505-81-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethyltetradecan2Amine;
formula     C16H35N;
CAS         56505-81-8;
InChIKey    KOMQGNYXBSXJTG-UHFFFAOYSA-N;
MW          241.463;      // g/mol [origin=calculated method=formula-sum]
Tc          738.14;      // K   [origin=predictive method=joback]
Pc          13.242;      // bar [origin=predictive method=joback]
omega       0.7638;      // -   [origin=predictive method=lee-kesler]
Tb          577.68;      // K   [origin=predictive method=joback]
HvapTb      52865.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-24.029 1.65368 -0.0009624 2.161e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 11; } { group CH; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 11; } { group CH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tetradecanamine, n,n-dimethyl-" "2-tetradecyldimethylamine" );
standardThermochemistry
{
    dHf_298   -311320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     785.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192180.0
}
