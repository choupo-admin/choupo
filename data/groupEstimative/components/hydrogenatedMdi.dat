/*--------------------------------*- Choupo -*-----------------------*\
  Component: hydrogenated MDI  (C15H22N2O2, CAS 5124-30-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hydrogenatedMdi;
formula     C15H22N2O2;
CAS         5124-30-1;
InChIKey    KORSJDCBLAPZEQ-UHFFFAOYSA-N;
MW          262.353;      // g/mol [origin=calculated method=formula-sum]
Tc          935.83;      // K   [origin=predictive method=joback]
Pc          21.315;      // bar [origin=predictive method=joback]
omega       0.7714;      // -   [origin=predictive method=lee-kesler]
Tb          705.90;      // K   [origin=predictive method=joback]
HvapTb      68288.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 1; } { group dCd; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" "1,1-Methylene bis(4-isocyanatocyclohexane)" "1,1′-methylenebis[4-isocyanatocyclohexane]" "4,4′-(Methylene)di(isocyanatocyclohexane)" "4,4′-cyclohexylmethanediisocyanate" "4,4′-Di(isocyanatocyclohexyl)methane" "4,4′-dicyclohexylmethylene diisocyanate" "4,4′-diisocyanatodicyclohexylmethane" "4,4′-Methylenebis(4-cyclohexylisocyanate)" "4,4′-Methylenebis(cyclohexyl isocyanate)" "4,4′-methylenedicyclohexyl diisocyanate" "4,4′-methylenedicyclohexylene diisocyanate" );
