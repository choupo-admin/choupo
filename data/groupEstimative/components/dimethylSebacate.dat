/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethyl sebacate  (C12H22O4, CAS 106-79-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylSebacate;
formula     C12H22O4;
CAS         106-79-6;
InChIKey    ALOUNLDAKADEEB-UHFFFAOYSA-N;
MW          230.304;      // g/mol [origin=calculated method=formula-sum]
Tc          763.05;      // K   [origin=predictive method=joback]
Pc          17.955;      // bar [origin=predictive method=joback]
omega       0.8780;      // -   [origin=predictive method=lee-kesler]
Tb          590.60;      // K   [origin=predictive method=joback]
HvapTb      57120.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (42.798 1.03424 -0.0004398 1.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 8; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl decanedioate" "methyl sebacate" "decanedioic acid, dimethyl ester" "sebacic acid dimethyl ester" "sebacic acid, dimethyl ester" "dimethyl octane-1,8-dicarboxylate" "decanedioic acid, 1,10-dimethyl ester" "dimethyl decane-1,10-dioate" "1,10-dimethyl decanedioate" "decanedioic acid dimethyl ester" "sebacic acid, dimethyl ester (8ci)" "i811" );
standardThermochemistry
{
    dHf_298   -925570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     726.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-570580.0
}
