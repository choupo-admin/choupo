/*--------------------------------*- Choupo -*-----------------------*\
  Component: polycaprolactone, dipropylene glycol, methylenebis(phenyl isocyanate) polymer  (C27H38N2O7, CAS 154336-14-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        polycaprolactoneDipropyleneGlycolMethylenebisPhenylIsocyanat;
formula     C27H38N2O7;
CAS         154336-14-8;
InChIKey    GSOYLJHOEWCFFV-UHFFFAOYSA-N;
MW          502.608;      // g/mol [origin=calculated method=formula-sum]
Tc          1576.79;      // K   [origin=predictive method=joback]
Pc          12.674;      // bar [origin=predictive method=joback]
omega       1.0572;      // -   [origin=predictive method=lee-kesler]
Tb          1274.67;      // K   [origin=predictive method=joback]
HvapTb      138813.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 12; } { group C; count 2; } { group CH=CH; count 4; } { group OH; count 2; } { group CH2COO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 7; } { group dCd; count 2; } { group CH2_ring; count 7; } { group C_ring; count 2; } { group dCH_ring; count 8; } { group OH; count 2; } { group O; count 1; } { group COO; count 1; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-isocyanato-5-[(1-isocyanatocyclohexa-2,4-dien-1-yl)methyl]cyclohexa-1,3-diene;oxepan-2-one;3-(3-oxidanylpropoxy)propan-1-ol" "2-oxepanone, polymer with 1,1'-methylenebis(isocyanatobenzene) and oxybis(propanol)" );
