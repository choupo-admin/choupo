/*--------------------------------*- Choupo -*-----------------------*\
  Component: butanedioic acid;2,2-dimethylpropane-1,3-diol  (C9H18O6, CAS 212555-40-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butanedioicAcid22Dimethylpropane13Diol;
formula     C9H18O6;
CAS         212555-40-3;
InChIKey    GXTJJXHLTYJRLX-UHFFFAOYSA-N;
MW          222.237;      // g/mol [origin=calculated method=formula-sum]
Tc          1081.93;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       1.9139;      // -   [origin=predictive method=lee-kesler]
Tb          879.07;      // K   [origin=predictive method=joback]
HvapTb      102312.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (30.834 0.94804 -0.0004288 2.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group OH; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group C; count 1; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanedioicacid,polymerwith2,2-dimethyl-1,3-propanediol;succinate neopentylglycol polyester;poly(neopentyl glycol succinate);neopentyl glycol succinate polyester;poly(neopentyl glycol succinate) [liquid phase for gc]" );
standardThermochemistry
{
    dHf_298   -1354460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     783.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1038480.0
}
