/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-dioxocane  (C6H12O2, CAS 6572-90-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Dioxocane;
formula     C6H12O2;
CAS         6572-90-3;
InChIKey    CJSITSBWCLTCAP-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          647.14;      // K   [origin=predictive method=joback]
Pc          43.056;      // bar [origin=predictive method=joback]
omega       0.3099;      // -   [origin=predictive method=lee-kesler]
Tb          423.54;      // K   [origin=predictive method=joback]
HvapTb      39052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-49.71 0.6972 -0.0003184 2.08e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxacyclooctane" );
gibbsFormation
{
    dHf_298   -368830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     338.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-164640.0
    phase     gas;
}
