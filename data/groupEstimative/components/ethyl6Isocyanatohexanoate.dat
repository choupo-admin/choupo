/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 6-isocyanatohexanoate  (C9H15NO3, CAS 5100-36-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl6Isocyanatohexanoate;
formula     C9H15NO3;
CAS         5100-36-7;
InChIKey    ZCLBSYCOBSMTMV-UHFFFAOYSA-N;
MW          185.223;      // g/mol [origin=calculated method=formula-sum]
Tc          710.20;      // K   [origin=predictive method=joback]
Pc          24.925;      // bar [origin=predictive method=joback]
omega       0.7864;      // -   [origin=predictive method=lee-kesler]
Tb          530.41;      // K   [origin=predictive method=joback]
HvapTb      52567.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCd; count 1; } { group COO; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-isocyanatohexanoic acid ethyl ester" );
// formation datum unavailable (element entropy missing): dHf_298=-551780.0 dGf_298=None
