/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3,5-triethoxybenzene  (C12H18O3, CAS 2437-88-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        135Triethoxybenzene;
formula     C12H18O3;
CAS         2437-88-9;
InChIKey    CPEDYIVPGWUOGI-UHFFFAOYSA-N;
MW          210.273;      // g/mol [origin=calculated method=formula-sum]
Tc          774.61;      // K   [origin=predictive method=joback]
Pc          22.250;      // bar [origin=predictive method=joback]
omega       0.7157;      // -   [origin=predictive method=lee-kesler]
Tb          578.06;      // K   [origin=predictive method=joback]
HvapTb      53136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (63.173 0.75636 -0.00019312 -5.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 3; } { group AC; count 3; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, 1,3,5-triethoxy-" "benzene,1,3,5-triethoxy-" );
standardThermochemistry
{
    dHf_298   -474080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     538.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-171690.0
}
