/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-furaldehyde  (C5H4O2, CAS 98-01-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H4O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Furaldehyde;
formula     C5H4O2;
CAS         98-01-1;
InChIKey    HYBBIBNJHNGZAN-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          96.085;      // g/mol [origin=calculated method=formula-sum]
Tc          541.85;      // K   [origin=predictive method=joback]
Pc          51.534;      // bar [origin=predictive method=joback]
omega       0.2240;      // -   [origin=predictive method=lee-kesler]
Tb          340.62;      // K   [origin=predictive method=joback]
HvapTb      30673.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.4 0.4706 -0.00047762 1.875e-07);
    Trange        (200 1000);
}
groups
{
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?61:1
    joback ( { group dCH_ring; count 3; } { group dC_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "furan-2-carbaldehyde" "furfural" "2-furancarboxaldehyde" "furaldehyde" "fural" "2-furanaldehyde" "2-furancarbonal" "2-formylfuran" "2-furfural" "pyromucic aldehyde" "2-furyl-methanal" "artificial ant oil" );
gibbsFormation
{
    dHf_298   -17170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     291.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=43610.0
    phase     gas;
}
