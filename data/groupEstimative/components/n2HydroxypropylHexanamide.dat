/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxypropyl)hexanamide  (C9H19NO2, CAS 23054-59-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxypropylHexanamide;
formula     C9H19NO2;
CAS         23054-59-3;
InChIKey    WEJHDPCZRFVRCX-UHFFFAOYSA-N;
MW          173.256;      // g/mol [origin=calculated method=formula-sum]
Tc          774.79;      // K   [origin=predictive method=joback]
Pc          27.527;      // bar [origin=predictive method=joback]
omega       1.1969;      // -   [origin=predictive method=lee-kesler]
Tb          601.30;      // K   [origin=predictive method=joback]
HvapTb      65101.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.465 0.94694 -0.0005293 1.0666e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group OH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-(2-oxidanylpropyl)hexanamide" "hexanamide, n-(2-hydroxypropyl)-" "caproic isopropanolamide" );
standardThermochemistry
{
    dHf_298   -445710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     615.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-153890.0
}
