/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(.alpha.-methylbenzyl)amine  (C16H19N, CAS 10024-74-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisAlphaMethylbenzylAmine;
formula     C16H19N;
CAS         10024-74-5;
InChIKey    NXLACVVNHYIYJN-UHFFFAOYSA-N;
MW          225.335;      // g/mol [origin=calculated method=formula-sum]
Tc          906.06;      // K   [origin=predictive method=joback]
Pc          23.496;      // bar [origin=predictive method=joback]
omega       0.6638;      // -   [origin=predictive method=lee-kesler]
Tb          668.33;      // K   [origin=predictive method=joback]
HvapTb      61422.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-84.04 1.45404 -0.000964 2.397e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 10; } { group AC; count 1; } { group ACCH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-n-(1-phenylethyl)ethanamine" "amine, diethyl, 1,1'-diphenyl" "bis(alpha-methylbenzyl)amine" "dibenzylamine, alpha,alpha'-dimethyl-" "benzenemethanamine, alpha-methyl-n-(1-phenylethyl)-" "benzenemethanamine, .alpha.-methyl-n-(1-phenylethyl)-" "bis(1-phenylethyl)amine" "dibenzylamine,.alpha.'-dimethyl-" "alpha,alpha'-dimethyldibenzylamine" "(r,r)-(+)-bis(alpha-methylbenzyl)aminehydrochloride" "(r)-bis(1-phenylethyl)amine hydrochloride" "benzenemethanamine, alpha-methyl-n-(1-phenylethyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   142400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     588.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=393170.0
}
