/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,5-hexadiene, 1,1,2,3,3,4,4,5,6,6-decachloro-  (C6Cl10, CAS 29030-84-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        15Hexadiene1123344566Decachloro;
formula     C6Cl10;
CAS         29030-84-0;
InChIKey    ZCSVEBNKFRWCBM-UHFFFAOYSA-N;
MW          426.566;      // g/mol [origin=calculated method=formula-sum]
Tc          995.02;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.5106;      // -   [origin=predictive method=lee-kesler]
Tb          712.56;      // K   [origin=predictive method=joback]
HvapTb      70444.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.27 0.933 -0.001027 3.96e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CCl2; count 2; } { group Cl_C=C_; count 6; } { group C=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 2; } { group dC; count 4; } { group Cl; count 10; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,2,3,3,4,4,5,6,6-decakis(chloranyl)hexa-1,5-diene" );
standardThermochemistry
{
    dHf_298   -146790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=12260.0
}
