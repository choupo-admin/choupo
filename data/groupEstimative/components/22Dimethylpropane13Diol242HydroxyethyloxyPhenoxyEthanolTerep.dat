/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethylpropane-1,3-diol;2-[4-(2-hydroxyethyloxy)phenoxy]ethanol;terephthalic acid  (C23H32O10, CAS 131718-99-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethylpropane13Diol242HydroxyethyloxyPhenoxyEthanolTerep;
formula     C23H32O10;
CAS         131718-99-5;
InChIKey    HFOZRJWPZWMJAX-UHFFFAOYSA-N;
MW          468.499;      // g/mol [origin=calculated method=formula-sum]
Tc          2017.47;      // K   [origin=predictive method=joback]
Pc          16.810;      // bar [origin=predictive method=joback]
omega       0.5035;      // -   [origin=predictive method=lee-kesler]
Tb          1493.31;      // K   [origin=predictive method=joback]
HvapTb      177824.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (81.296 1.73664 -0.00054272 -1.132e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group OH; count 2; } { group COOH; count 2; } { group C2H5O2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group C; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH; count 4; } { group O; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-benzenedicarboxylic acid, polymer with 2,2-dimethyl-1,3-propanediol and 2,2'-(1,4-phenylenebis(oxy))bis(ethanol)" );
gibbsFormation
{
    dHf_298   -1873820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1335.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1303440.0
    phase     gas;
}
