/*--------------------------------*- Choupo -*-----------------------*\
  Component: strophanthidin  (C23H32O6, CAS 66-28-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        strophanthidin;
formula     C23H32O6;
CAS         66-28-4;
InChIKey    ODJLBQGVINUMMR-HZXDTFASSA-N;
MW          404.503;      // g/mol [origin=calculated method=formula-sum]
Tc          1415.89;      // K   [origin=predictive method=joback]
Pc          20.774;      // bar [origin=predictive method=joback]
omega       1.6190;      // -   [origin=predictive method=lee-kesler]
Tb          1155.40;      // K   [origin=predictive method=joback]
HvapTb      126804.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-402.22 3.88962 -0.00397044 1.6664e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 10; } { group CH; count 4; } { group C; count 4; } { group CH=C; count 1; } { group OH; count 3; } { group CHO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 4; } { group C_ring; count 4; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group OH; count 3; } { group OdCH_al; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,5s,8r,9s,10s,13r,14s,17r)-13-methyl-3,5,14-tris(oxidanyl)-17-(5-oxidanylidene-2h-furan-3-yl)-2,3,4,6,7,8,9,11,12,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthrene-10-carbaldehyde" "convallatoxigenin" "strophanthidine" "corchsularin" "corchorgenin" "erysimupicrone" "corchorin" "corchoside a aglycon" "k-strophanthidin" "strophanthidin k" "apocynamarin" "erysimupikron" );
gibbsFormation
{
    dHf_298   -998150.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1030.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-459080.0
    phase     gas;
}
