/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-dimethylbenzamide  (C9H11NO, CAS 5580-33-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34Dimethylbenzamide;
formula     C9H11NO;
CAS         5580-33-6;
InChIKey    INGCXEIJXKQPJH-UHFFFAOYSA-N;
MW          149.193;      // g/mol [origin=calculated method=formula-sum]
Tc          799.09;      // K   [origin=predictive method=joback]
Pc          36.246;      // bar [origin=predictive method=joback]
omega       0.6482;      // -   [origin=predictive method=lee-kesler]
Tb          568.56;      // K   [origin=predictive method=joback]
HvapTb      56615.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.25 0.69484 -0.00038762 7.356e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 2; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethylbenzamide;" "benzamide,3,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -94290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     466.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55580.0
    phase     gas;
}
