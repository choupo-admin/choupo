/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dimethoxyhexadecane  (C18H38O2, CAS 2791-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dimethoxyhexadecane;
formula     C18H38O2;
CAS         2791-29-9;
InChIKey    LACZJJJYINHZIR-UHFFFAOYSA-N;
MW          286.5;      // g/mol [origin=calculated method=formula-sum]
Tc          818.74;      // K   [origin=predictive method=joback]
Pc          11.321;      // bar [origin=predictive method=joback]
omega       0.8634;      // -   [origin=predictive method=lee-kesler]
Tb          655.84;      // K   [origin=predictive method=joback]
HvapTb      60094.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (35.844 1.59336 -0.0007366 9.29e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 14; } { group CH; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecanal dimethyl acetal" "hexadecane, 1,1-dimethoxy-" "1,1-dimethoxy-hexadecane" "hexadecane,1,1-dimethoxy-" "palmitaldehyde, dimethyl acetal" "palmitaldehyde,dimethyl acetal (6ci,7ci,8ci); hexadecanal dimethyl acetal" );
gibbsFormation
{
    dHf_298   -684570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     870.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-111760.0
    phase     gas;
}
