/*--------------------------------*- Choupo -*-----------------------*\
  Component: dicyclopropylmethanol  (C7H12O, CAS 14300-33-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dicyclopropylmethanol;
formula     C7H12O;
CAS         14300-33-5;
InChIKey    PIXLZMHERIHLJL-UHFFFAOYSA-N;
MW          112.172;      // g/mol [origin=calculated method=formula-sum]
Tc          655.38;      // K   [origin=predictive method=joback]
Pc          42.719;      // bar [origin=predictive method=joback]
omega       0.7063;      // -   [origin=predictive method=lee-kesler]
Tb          464.98;      // K   [origin=predictive method=joback]
HvapTb      47293.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-100.35 1.0105 -0.000831 2.8e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 3; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dicyclopropyl carbinol" "cyclopropanemethanol, .alpha.-cyclopropyl-" "dicyclopropyl-methanol" "dicyclopropylmethan-1-ol" "cyclopropanemethanol, a-cyclopropyl-" "methanol,dicyclopropyl- (6ci,7ci,8ci);dicyclopropyl carbinol;dicyclopropylmethan-1-ol;dicyclopropylmethanol;dicyclopropylmethyl alcohol;" );
gibbsFormation
{
    dHf_298   -199720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     289.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-9700.0
    phase     gas;
}
