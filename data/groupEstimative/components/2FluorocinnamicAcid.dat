/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluorocinnamic acid  (C9H7FO2, CAS 451-69-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2FluorocinnamicAcid;
formula     C9H7FO2;
CAS         451-69-4;
InChIKey    IOUDZAFBPDDAMK-AATRIKPKSA-N;
MW          166.151;      // g/mol [origin=calculated method=formula-sum]
Tc          809.87;      // K   [origin=predictive method=joback]
Pc          35.856;      // bar [origin=predictive method=joback]
omega       0.7533;      // -   [origin=predictive method=lee-kesler]
Tb          586.12;      // K   [origin=predictive method=joback]
HvapTb      54871.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.39 0.803 -0.00060276 1.775e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group COOH; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-3-(2-fluorophenyl)prop-2-enoic acid" "cinnamic acid, o-fluoro-" "o-fluorocinnamic acid" "2-propenoic acid, 3-(2-fluorophenyl)-" "(2e)-3-(2-fluorophenyl)prop-2-enoic acid" "3-(2-fluorophenyl)prop-2-enoic acid" "(2e)-3-(2-fluorophenyl)acrylic acid" "trans-2-fluorocinnamic acid" "(2e)-3-(2-fluorophenyl)-2-propenoic acid" "3-(2-fluorophenyl)acrylic acid" "3-(2-fluoro-phenyl)-acrylic acid" "3-(2-fluorophenyl)-2-propenoic acid" );
standardThermochemistry
{
    dHf_298   -433190.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     472.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-330820.0
}
