/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene distearate  (C38H74O4, CAS 627-83-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneDistearate;
formula     C38H74O4;
CAS         627-83-8;
InChIKey    FPVVYTCTZKCSOJ-UHFFFAOYSA-N;
MW          595.006;      // g/mol [origin=calculated method=formula-sum]
Tc          1611.00;      // K   [origin=predictive method=joback]
Pc          4.241;      // bar [origin=predictive method=joback]
omega       -0.2701;      // -   [origin=predictive method=lee-kesler]
Tb          1185.48;      // K   [origin=predictive method=joback]
HvapTb      114996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.164 3.50424 -0.0018542 3.268e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 32; } { group CH2COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 34; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-octadecanoyloxyethyl octadecanoate" "ethylene glycol distearate" "glycol distearate" "stearic acid, ethylene ester" "ethylene stearate" "ethylene glycol dioctadecanoate" "octadecanoic acid, 1,2-ethanediyl ester" "octadecanoic acid, 1,1'-(1,2-ethanediyl) ester" "ethane-1,2-diyl dioctadecanoate" "glycol distearate (usan)" "ethylene glycol, distearate" "1,2-ethanediyl bis(octadecanoate)" );
standardThermochemistry
{
    dHf_298   -1462210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1738.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-351660.0
}
