/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminobenzoic acid  (C7H7NO2, CAS 99-05-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3AminobenzoicAcid;
formula     C7H7NO2;
CAS         99-05-8;
InChIKey    XFDUHJPVQKIXHO-UHFFFAOYSA-N;
MW          137.138;      // g/mol [origin=calculated method=formula-sum]
Tc          851.35;      // K   [origin=predictive method=joback]
Pc          49.039;      // bar [origin=predictive method=joback]
omega       0.8304;      // -   [origin=predictive method=lee-kesler]
Tb          609.46;      // K   [origin=predictive method=joback]
HvapTb      61919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.99 0.6431 -0.00043716 1.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-azanylbenzoic acid" "m-aminobenzoic acid" "m-carboxyaniline" "benzoic acid, 3-amino-" "gabaculine" "3-carboxyaniline" "benzoic acid, m-amino-" "maba" "aniline-3-carboxylic acid" "3-aminobenzoicacid" "3-aminobenzoate" "meta-aminobenzoic acid" );
standardThermochemistry
{
    dHf_298   -279230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166620.0
}
