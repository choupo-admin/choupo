/*--------------------------------*- Choupo -*-----------------------*\
  Component: propane-2,2-diylbis(benzene-4,1-diyloxyethane-2,1-diyloxyethane-2,1-diyloxyethane-2,1-diyl) bis(2-methylprop-2-enoate)  (C35H48O10, CAS 56744-46-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propane22DiylbisBenzene41Diyloxyethane21Diyloxyethane21Diylo;
formula     C35H48O10;
CAS         56744-46-8;
InChIKey    MUEIBZIYMWAANR-UHFFFAOYSA-N;
MW          628.759;      // g/mol [origin=calculated method=formula-sum]
Tc          1658.05;      // K   [origin=predictive method=joback]
Pc          6.491;      // bar [origin=predictive method=joback]
omega       0.2848;      // -   [origin=predictive method=lee-kesler]
Tb          1304.57;      // K   [origin=predictive method=joback]
HvapTb      126178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (105.842 2.64888 -0.00117552 7.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group C; count 1; } { group CH2=C; count 2; } { group ACH; count 8; } { group AC; count 4; } { group CH2O; count 6; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 12; } { group C; count 1; } { group dCH2; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group O; count 6; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[4-[2-[4-[2-[2-[2-(2-methylprop-2-enoyloxy)ethoxy]ethoxy]ethoxy]phenyl]propan-2-yl]phenoxy]ethoxy]ethoxy]ethyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, (1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyloxy-2,1-ethanediyl) ester" "2-propenoic acid, 2-methyl-, 1,1'-((1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyloxy-2,1-ethanediyl)) ester" "2-propenoic acid, 2-methyl-, 1,1'-[(1-methylethylidene)bis(4,1-phenyleneoxy-2,1-ethanediyloxy-2,1-ethanediyloxy-2,1-ethanediyl)] ester" );
standardThermochemistry
{
    dHf_298   -1520960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1407.96;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-639940.0
}
