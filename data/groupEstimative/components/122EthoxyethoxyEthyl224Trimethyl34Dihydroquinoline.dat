/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-[2-(2-ethoxyethoxy)ethyl]-2,2,4-trimethyl-3,4-dihydroquinoline  (C18H29NO2, CAS 71673-20-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        122EthoxyethoxyEthyl224Trimethyl34Dihydroquinoline;
formula     C18H29NO2;
CAS         71673-20-6;
InChIKey    LHUHRYNUYWOJFX-UHFFFAOYSA-N;
MW          291.435;      // g/mol [origin=calculated method=formula-sum]
Tc          901.53;      // K   [origin=predictive method=joback]
Pc          15.697;      // bar [origin=predictive method=joback]
omega       0.8485;      // -   [origin=predictive method=lee-kesler]
Tb          702.69;      // K   [origin=predictive method=joback]
HvapTb      63916.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-87.065 1.98928 -0.00150756 5.005e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 2; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 2; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "quinoline, 1-(2-(2-ethoxyethoxy)ethyl)-1,2,3,4-tetrahydro-2,2,4-trimethyl-" "quinoline, 1-[2-(2-ethoxyethoxy)ethyl]-1,2,3,4-tetrahydro-2,2,4-trimethyl-" "1-[2-(2-ethoxyethoxy)ethyl]-2,2,4-trimethyl-1,2,3,4-tetrahydroquinoline" "1-[2-(2-ethoxyethoxy)ethyl]-1,2,3,4-tetrahydro-2,2,4-trimethylquinoline" );
standardThermochemistry
{
    dHf_298   -319000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     720.08;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=151790.0
}
