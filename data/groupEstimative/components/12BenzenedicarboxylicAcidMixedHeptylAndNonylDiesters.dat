/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-benzenedicarboxylic acid, mixed heptyl and nonyl diesters  (C24H38O8, CAS 70955-56-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12BenzenedicarboxylicAcidMixedHeptylAndNonylDiesters;
formula     C24H38O8;
CAS         70955-56-5;
InChIKey    OMISUVPZAZHMSF-UHFFFAOYSA-N;
MW          454.56;      // g/mol [origin=calculated method=formula-sum]
Tc          1718.95;      // K   [origin=predictive method=joback]
Pc          10.921;      // bar [origin=predictive method=joback]
omega       0.7521;      // -   [origin=predictive method=lee-kesler]
Tb          1365.22;      // K   [origin=predictive method=joback]
HvapTb      141200.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.502 1.93624 -0.00070676 -4.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 12; } { group ACH; count 4; } { group AC; count 2; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 12; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptanoic acid;nonanoic acid;phthalic acid" "heptanoic acid; nonanoic acid; phthalic acid" );
standardThermochemistry
{
    dHf_298   -1937950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1406.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1331180.0
}
