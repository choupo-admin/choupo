/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2-(methylamino)benzoate  (C9H11NO2, CAS 85-91-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl2MethylaminoBenzoate;
formula     C9H11NO2;
CAS         85-91-6;
InChIKey    GVOWHGSUZUUUDR-UHFFFAOYSA-N;
MW          165.192;      // g/mol [origin=calculated method=formula-sum]
Tc          760.49;      // K   [origin=predictive method=joback]
Pc          32.728;      // bar [origin=predictive method=joback]
omega       0.6510;      // -   [origin=predictive method=lee-kesler]
Tb          545.57;      // K   [origin=predictive method=joback]
HvapTb      52409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.7 0.74184 -0.00038396 4.99e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CH3NH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dimethyl anthranilate" "methyl n-methylanthranilate" "methyl methylaminobenzoate" "methyl methanthranilate" "benzoic acid, 2-(methylamino)-, methyl ester" "methyl methylanthranilate" "2-methylaminomethyl benzoate" "methyl o-(methylamino)benzoate" "methyl n-methyl-o-anthranilate" "anthranilic acid, n-methyl-, methyl ester" "methyl-n-methylanthranilate" "n-methylanthranilic acid, methyl ester" );
standardThermochemistry
{
    dHf_298   -267840.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-93300.0
}
