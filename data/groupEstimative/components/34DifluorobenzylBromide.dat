/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4-difluorobenzyl bromide  (C7H5BrF2, CAS 85118-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        34DifluorobenzylBromide;
formula     C7H5BrF2;
CAS         85118-01-0;
InChIKey    JJIFTOPVKWDHJI-UHFFFAOYSA-N;
MW          207.017;      // g/mol [origin=calculated method=formula-sum]
Tc          671.40;      // K   [origin=predictive method=joback]
Pc          38.579;      // bar [origin=predictive method=joback]
omega       0.4800;      // -   [origin=predictive method=lee-kesler]
Tb          461.10;      // K   [origin=predictive method=joback]
HvapTb      39577.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.591 0.5327 -0.00035832 9.31e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group ACCH2; count 1; } { group Br; count 1; } { group ACF; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 2; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(bromomethyl)-1,2-bis(fluoranyl)benzene" "4-(bromomethyl)-1,2-difluorobenzene" "alpha-bromo-3,4-difluorotoluene" "3,4-difluorobenzylbromide" "fr bf d1e" "3, 4-difluorobenzyl bromide" "3 4-difluorobenzyl bromide" ".alpha.-bromo-3,4-difluorotoluene" "a-bromo-3,4-difluorotoluene" "alpha-bromo-3,4-difluorotoluen" "benzene, 4-(bromomethyl)-1,2-difluoro-" "l425" );
gibbsFormation
{
    dHf_298   -340110.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     424.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-274090.0
    phase     gas;
}
