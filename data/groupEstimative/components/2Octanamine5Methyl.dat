/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-octanamine, 5-methyl-  (C9H21N, CAS 67953-04-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Octanamine5Methyl;
formula     C9H21N;
CAS         67953-04-2;
InChIKey    JHLSRARFRAZKEV-UHFFFAOYSA-N;
MW          143.274;      // g/mol [origin=calculated method=formula-sum]
Tc          660.67;      // K   [origin=predictive method=joback]
Pc          24.777;      // bar [origin=predictive method=joback]
omega       0.5567;      // -   [origin=predictive method=lee-kesler]
Tb          477.17;      // K   [origin=predictive method=joback]
HvapTb      45493.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-2.166 0.93256 -0.0005156 1.059e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 1; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group CH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyloctan-2-amine" );
standardThermochemistry
{
    dHf_298   -205860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=86470.0
}
