/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6-etheno-1,8-benzodioxecin-2,7-dione, 9,10,11,12-tetrabromo-  (C14H4Br4O4, CAS 71215-80-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36Etheno18Benzodioxecin27Dione9101112Tetrabromo;
formula     C14H4Br4O4;
CAS         71215-80-0;
InChIKey    YKUNDRZGOVMKHT-UHFFFAOYSA-N;
MW          555.798;      // g/mol [origin=calculated method=formula-sum]
Tc          1256.43;      // K   [origin=predictive method=joback]
Pc          38.293;      // bar [origin=predictive method=joback]
omega       1.5213;      // -   [origin=predictive method=lee-kesler]
Tb          982.84;      // K   [origin=predictive method=joback]
HvapTb      95542.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.91 1.0684 -0.00090916 2.964e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 8; } { group Br; count 4; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 8; } { group Br; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,5,6-tetrabromocatechol terephthalic acid cyclic ester" "9,10,11,12-tetrabromo-3,6-etheno-1,8-benzodioxecine-2,7-dione" );
gibbsFormation
{
    dHf_298   -345670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224660.0
    phase     gas;
}
