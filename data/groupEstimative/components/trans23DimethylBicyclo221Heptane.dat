/*--------------------------------*- Choupo -*-----------------------*\
  Component: trans-2,3-dimethyl-bicyclo(2.2.1)heptane  (C9H16, CAS 20558-16-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trans23DimethylBicyclo221Heptane;
formula     C9H16;
CAS         20558-16-1;
InChIKey    ADNHKZRYBOUYGM-UHFFFAOYSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          612.50;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.2934;      // -   [origin=predictive method=lee-kesler]
Tb          413.93;      // K   [origin=predictive method=joback]
HvapTb      35008.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-99.02 1.09804 -0.000749 2.082e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3-dimethylbicyclo[2.2.1]heptane" "trans-2,3-dimethyl-bicyclo[2.2.1]heptane" "adnhkzrybouygm-jbdrjprfsa-" "adnhkzrybouygm-kzvjfyersa-" "bicyclo[2.2.1]heptane, 2,3-dimethyl-, (1r,2r,3s,4r)-" "bicyclo[2.2.1]heptane, 2,3-dimethyl-" "(1r,2r,3s,4r)-2,3-dimethylbicyclo[2.2.1]heptane" "bicyclo[2.2.1]heptane, 2,3-dimethyl-, (2-endo,3-exo)-" );
standardThermochemistry
{
    dHf_298   -130330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     261.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=118880.0
}
