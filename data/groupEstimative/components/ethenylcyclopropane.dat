/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenylcyclopropane  (C5H8, CAS 693-86-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethenylcyclopropane;
formula     C5H8;
CAS         693-86-7;
InChIKey    YIWFBNMYFYINAD-UHFFFAOYSA-N;
MW          68.119;      // g/mol [origin=calculated method=formula-sum]
Tc          499.68;      // K   [origin=predictive method=joback]
Pc          42.943;      // bar [origin=predictive method=joback]
omega       0.2037;      // -   [origin=predictive method=lee-kesler]
Tb          317.42;      // K   [origin=predictive method=joback]
HvapTb      25967.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-54.89 0.6097 -0.0004913 1.65e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "vinylcyclopropane" "cyclopropane,ethenyl-" "cyclopropane, ethenyl-" "yiwfbnmyfyinad-uhfffaoysa-" "cyclopropane,ethenyl-;cyclopropyl-;" );
standardThermochemistry
{
    dHf_298   51700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     255.9;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=139810.0
}
