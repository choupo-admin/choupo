/*--------------------------------*- Choupo -*-----------------------*\
  Component: methyl 2,2-dichloro-1-methylcyclopropanecarboxylate  (C6H8Cl2O2, CAS 1447-13-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methyl22Dichloro1Methylcyclopropanecarboxylate;
formula     C6H8Cl2O2;
CAS         1447-13-8;
InChIKey    JGCAZFUFORGMFB-UHFFFAOYSA-N;
MW          183.028;      // g/mol [origin=calculated method=formula-sum]
Tc          692.56;      // K   [origin=predictive method=joback]
Pc          35.600;      // bar [origin=predictive method=joback]
omega       0.4164;      // -   [origin=predictive method=lee-kesler]
Tb          472.51;      // K   [origin=predictive method=joback]
HvapTb      42429.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.66 1.24084 -0.0014788 6.882e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CCl2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group C_ring; count 2; } { group Cl; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2,2-bis(chloranyl)-1-methyl-cyclopropane-1-carboxylate" "methyl 2,2-dichloro-1-methylcyclopropane-1-carboxylate" "cyclopropanecarboxylic acid, 2,2-dichloro-1-methyl-, methyl ester" "cyclopropanecarboxylicacid, 2,2-dichloro-1-methyl-, methyl ester" );
gibbsFormation
{
    dHf_298   -432990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     514.27;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-292530.0
    phase     gas;
}
