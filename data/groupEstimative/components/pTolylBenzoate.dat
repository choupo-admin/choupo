/*--------------------------------*- Choupo -*-----------------------*\
  Component: p-tolyl benzoate  (C14H12O2, CAS 614-34-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        pTolylBenzoate;
formula     C14H12O2;
CAS         614-34-6;
InChIKey    LLRZUDIHEZXFGV-UHFFFAOYSA-N;
MW          212.248;      // g/mol [origin=calculated method=formula-sum]
Tc          878.35;      // K   [origin=predictive method=joback]
Pc          27.412;      // bar [origin=predictive method=joback]
omega       0.6273;      // -   [origin=predictive method=lee-kesler]
Tb          636.48;      // K   [origin=predictive method=joback]
HvapTb      59379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.94 1.06172 -0.00063856 1.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACCH3; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methylphenyl) benzoate" "4-methylphenyl benzoate" "benzoic acid, 4-methylphenyl ester" "p-cresol benzoate" "p-cresyl benzoate" "4-cresyl benzoate" "benzoic acid, p-tolyl ester" );
standardThermochemistry
{
    dHf_298   -187980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-28180.0
}
