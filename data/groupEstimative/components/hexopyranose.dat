/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexopyranose  (C6H12O6, CAS 492-61-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hexopyranose;
formula     C6H12O6;
CAS         492-61-5;
InChIKey    WQZGKKKJIJFFOK-UHFFFAOYSA-N;
MW          180.156;      // g/mol [origin=calculated method=formula-sum]
Tc          1011.38;      // K   [origin=predictive method=joback]
Pc          62.000;      // bar [origin=predictive method=joback]
omega       2.6162;      // -   [origin=predictive method=lee-kesler]
Tb          825.60;      // K   [origin=predictive method=joback]
HvapTb      116048.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.639 0.7569 -0.0003001 -2.7e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 4; } { group OH; count 5; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH_ring; count 5; } { group OH; count 5; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-(hydroxymethyl)oxane-2,3,4,5-tetrol" "d-galactose" "d-mannose" "dextrose" ".beta.-d-glucopyranose" ".alpha.-d-glucose" "d-mannopyranose" ".alpha.-d-glucopyranose" "d(+)glucose, anhydrous" "hexose" "d-allose" "galactopyranose" );
gibbsFormation
{
    dHf_298   -1087360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     392.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-776970.0
    phase     gas;
}
