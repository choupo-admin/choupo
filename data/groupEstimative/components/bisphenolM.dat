/*--------------------------------*- Choupo -*-----------------------*\
  Component: bisphenol m  (C24H26O2, CAS 13595-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bisphenolM;
formula     C24H26O2;
CAS         13595-25-0;
InChIKey    PVFQHGDIOXNKIC-UHFFFAOYSA-N;
MW          346.47;      // g/mol [origin=calculated method=formula-sum]
Tc          1260.50;      // K   [origin=predictive method=joback]
Pc          20.512;      // bar [origin=predictive method=joback]
omega       1.1000;      // -   [origin=predictive method=lee-kesler]
Tb          988.52;      // K   [origin=predictive method=joback]
HvapTb      99944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-173.13 2.54848 -0.00216468 7.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group C; count 2; } { group ACH; count 12; } { group AC; count 4; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[2-[3-[2-(4-hydroxyphenyl)propan-2-yl]phenyl]propan-2-yl]phenol" "1,3-bis[2-(4-hydroxyphenyl)-2-propyl]benzene" "4,4'-(1,3-phenylenediisopropylidene)bisphenol" "1,3-bis(2-(4-hydroxyphenyl)-2-propyl)benzene" "phenol, 4,4'-(1,3-phenylenebis(1-methylethylidene))bis-" "phenol, 4,4'-[1,3-phenylenebis(1-methylethylidene)]bis-" "4-(1-{3-[1-(4-hydroxyphenyl)-isopropyl]phenyl}-isopropyl)phenol" "bisphenol m;" "pvfqhgdioxnkic-uhfffaoysa-" "phenol, 4,4'-(m-phenylenediisopropylidene)di" "phenol, 4, 4'-[1, 3-phenylenebis(1-methylethylidene)]bis-" "4,4 inverted exclamation marka-(1,3-phenylenediisopropylidene)bisphenol" );
standardThermochemistry
{
    dHf_298   -212690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     740.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175240.0
}
