/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 1,1-dicyclopentyl-  (C12H22, CAS 4413-21-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane11Dicyclopentyl;
formula     C12H22;
CAS         4413-21-2;
InChIKey    XWKIKXOZAGBKSO-UHFFFAOYSA-N;
MW          166.308;      // g/mol [origin=calculated method=formula-sum]
Tc          724.56;      // K   [origin=predictive method=joback]
Pc          24.950;      // bar [origin=predictive method=joback]
omega       0.3640;      // -   [origin=predictive method=lee-kesler]
Tb          504.28;      // K   [origin=predictive method=joback]
HvapTb      42432.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-130.67 1.41312 -0.000887 2.101e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclopentylethylcyclopentane" "cyclopentane, 1,1'-ethylidenebis-" "1,1-dicyclopentylethane" "ethane,1-dicyclopentyl-" "cyclopentane,1'-ethylidenebis-" );
standardThermochemistry
{
    dHf_298   -175330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=120820.0
}
