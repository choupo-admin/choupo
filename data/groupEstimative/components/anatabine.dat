/*--------------------------------*- Choupo -*-----------------------*\
  Component: anatabine  (C10H12N2, CAS 581-49-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anatabine;
formula     C10H12N2;
CAS         581-49-7;
InChIKey    SOPPBXUYQGUQHE-JTQLQIEISA-N;
MW          160.22;      // g/mol [origin=calculated method=formula-sum]
Tc          842.95;      // K   [origin=predictive method=joback]
Pc          40.058;      // bar [origin=predictive method=joback]
omega       0.4705;      // -   [origin=predictive method=lee-kesler]
Tb          576.04;      // K   [origin=predictive method=joback]
HvapTb      53819.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.95 0.96136 -0.00056834 1.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH=CH; count 1; } { group CH2NH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 1; } { group NH_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-[(2s)-1,2,3,6-tetrahydropyridin-2-yl]pyridine" "(-)-anatabine" "1,2,3,6-tetrahydro-2,3'-bipyridine" "(s)-1,2,3,6-tetrahydro-2,3'-bipyridine" "2,3'-bipyridine, 1,2,3,6-tetrahydro-, (s)-" "2,3'-bipyridine, 1,2,3,6-tetrahydro-, (s)- (9ci)" );
standardThermochemistry
{
    dHf_298   169500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     377.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=364900.0
}
