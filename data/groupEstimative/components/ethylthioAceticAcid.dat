/*--------------------------------*- Choupo -*-----------------------*\
  Component: (ethylthio)acetic acid  (C4H8O2S, CAS 627-04-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethylthioAceticAcid;
formula     C4H8O2S;
CAS         627-04-3;
InChIKey    VJIKFWJCVWFZIN-UHFFFAOYSA-N;
MW          120.166;      // g/mol [origin=calculated method=formula-sum]
Tc          720.49;      // K   [origin=predictive method=joback]
Pc          44.682;      // bar [origin=predictive method=joback]
omega       0.6569;      // -   [origin=predictive method=lee-kesler]
Tb          505.41;      // K   [origin=predictive method=joback]
HvapTb      48479.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.452 0.42901 -0.0002262 3.68e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group COOH; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group COOH; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylsulfanylethanoic acid" "acetic acid, (ethylthio)-" "ethylthioacetic acid" "(ethylmercapto)acetic acid" "acetic acid,(ethylthio)-" "carboxymethyl ethyl sulfide" "acetic acid, 2-(ethylthio)-" "s-(carboxymethyl)ethyl mercaptan" "2-ethylthioacetic acid" "2-(ethylthio)acetic acid" "(ethylsulfanyl)acetic acid" "(ethyl thio)acetic acid" );
gibbsFormation
{
    dHf_298   -434290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     426.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-327990.0
    phase     gas;
}
