/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3-chloropropyl)dimethylsilane  (C5H12ClSi, CAS 18157-31-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H12ClSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        3ChloropropylDimethylsilane;
formula     C5H12ClSi;
CAS         18157-31-8;
InChIKey    UDIMUNKNMFGPJH-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
role        radical;
MW          135.686;      // g/mol [origin=calculated method=formula-sum]
Tc          527.96;      // K   [origin=predictive method=joback]
Pc          30.490;      // bar [origin=predictive method=joback]
omega       0.2622;      // -   [origin=predictive method=lee-kesler]
Tb          352.13;      // K   [origin=predictive method=joback]
HvapTb      31256.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (31.643 0.38254 -6.12e-05 -5.13e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranylpropyl(dimethyl)silicon" "3-chloropropyl(dimethyl)silicon" "silane, (3-chloropropyl)dimethyl-" );
standardThermochemistry
{
    dHf_298   -218080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-73090.0
}
