/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-diethyl-2-methyldecahydro-4-quinolinol  (C14H27NO, CAS 38463-60-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Diethyl2Methyldecahydro4Quinolinol;
formula     C14H27NO;
CAS         38463-60-4;
InChIKey    MFCNLJAJNKZFCG-UHFFFAOYSA-N;
MW          225.376;      // g/mol [origin=calculated method=formula-sum]
Tc          835.43;      // K   [origin=predictive method=joback]
Pc          21.473;      // bar [origin=predictive method=joback]
omega       0.9288;      // -   [origin=predictive method=lee-kesler]
Tb          641.73;      // K   [origin=predictive method=joback]
HvapTb      64053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-169.198 2.00366 -0.0016038 5.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 6; } { group CH; count 3; } { group C; count 1; } { group OH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH2_ring; count 5; } { group CH_ring; count 3; } { group C_ring; count 1; } { group OH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-diethyl-2-methyl-2,3,4a,5,6,7,8,8a-octahydroquinolin-4-ol" "4-quinolinol,1,4-diethyldecahydro-2-methyl-(2.alpha.,4.alpha.,4a.alpha.,8a.beta." "4-quinolinol,1,4-diethyldecahydro-2-methyl-(2.alpha.,4.alpha.,4a.beta.,8a.alpha.)" "4-quinolinol,1,4-diethyldecahydro-2-methyl-(2.alpha.,4.beta.,4a.alpha.,8a.beta.)" "4-quinolinol, 1,4-diethyldecahydro-2-methyl-, (2alpha,4beta,4aalpha,8abeta)-" "(2s,4r,4ar,8ar)-1,4-diethyl-2-methyl-2,3,4a,5,6,7,8,8a-octahydroquinolin-4-ol" "4-quinolinol, 1,4-diethyldecahydro-2-methyl-, (2alpha,4alpha,4aalpha,8abeta)-" "4-quinolinol, 1,4-diethyldecahydro-2-methyl-, (2alpha,4alpha,4abeta,8aalpha)-" );
standardThermochemistry
{
    dHf_298   -315310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105250.0
}
