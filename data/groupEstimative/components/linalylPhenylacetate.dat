/*--------------------------------*- Choupo -*-----------------------*\
  Component: linalyl phenylacetate  (C18H24O2, CAS 7143-69-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        linalylPhenylacetate;
formula     C18H24O2;
CAS         7143-69-3;
InChIKey    RROUXOOIXJRTOM-UHFFFAOYSA-N;
MW          272.388;      // g/mol [origin=calculated method=formula-sum]
Tc          905.36;      // K   [origin=predictive method=joback]
Pc          16.103;      // bar [origin=predictive method=joback]
omega       0.7217;      // -   [origin=predictive method=lee-kesler]
Tb          693.83;      // K   [origin=predictive method=joback]
HvapTb      63417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-63.307 1.70586 -0.0011728 3.099e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } { group CH=C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 2; } { group dC; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,7-dimethylocta-1,6-dien-3-yl 2-phenylethanoate" "linalyl alpha-toluate" "benzeneacetic acid, 1-ethenyl-1,5-dimethyl-4-hexenyl ester" "3,7-dimethylocta-1,6-dien-3-yl phenylacetate" "1,5-dimethyl-1-vinyl-4-hexenyl phenylacetate" "3,7-dimethyl-1,6-octadien-3-yl phenylacetate" "1-ethenyl-1,5-dimethyl-4-hexenyl benzeneacetate" "acetic acid, phenyl-, 1,5-dimethyl-1-vinyl-4-hexenyl ester" "benzeneacetic acid, 1,5-dimethyl-1-ethenyl-4-hexenyl ester" "benzeneacetic acid, 1-ethenyl-1,5-dimethyl-4-hexen-1-yl ester" "benzeneacetic acid,5-dimethyl-4-hexenyl ester" "3,7-dimethylocta-1,6-dien-3-yl 2-phenylacetate" );
standardThermochemistry
{
    dHf_298   -271490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     747.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=65070.0
}
