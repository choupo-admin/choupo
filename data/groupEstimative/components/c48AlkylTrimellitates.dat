/*--------------------------------*- Choupo -*-----------------------*\
  Component: c4-8-alkyl trimellitates  (C12H12O8, CAS 70955-60-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        c48AlkylTrimellitates;
formula     C12H12O8;
CAS         70955-60-1;
InChIKey    BJXIAMDLGFJMPD-UHFFFAOYSA-N;
MW          284.22;      // g/mol [origin=calculated method=formula-sum]
Tc          1346.75;      // K   [origin=predictive method=joback]
Pc          30.830;      // bar [origin=predictive method=joback]
omega       1.9021;      // -   [origin=predictive method=lee-kesler]
Tb          1094.24;      // K   [origin=predictive method=joback]
HvapTb      114856.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (45.891 0.94292 -0.00040172 2.1e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 3; } { group COOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group COOH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,2,4-tricarboxylic acid;propanoic acid" "trimellitic acid, (c4-c8)alkyl esters" "1,2,4-benzenetricarboxylic acid, c4-8-alkyl esters" "benzene-1,2,4-tricarboxylic acid; propanoic acid" "benzene-1,2,4-tricarboxylic acid - propanoic acid (1:1)" );
gibbsFormation
{
    dHf_298   -1590120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     824.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1337090.0
    phase     gas;
}
