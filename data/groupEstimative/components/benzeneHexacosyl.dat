/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, hexacosyl-  (C32H58, CAS 13024-80-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneHexacosyl;
formula     C32H58;
CAS         13024-80-1;
InChIKey    IKTAPDJXVHLCBS-UHFFFAOYSA-N;
MW          442.816;      // g/mol [origin=calculated method=formula-sum]
Tc          1178.49;      // K   [origin=predictive method=joback]
Pc          6.380;      // bar [origin=predictive method=joback]
omega       0.5203;      // -   [origin=predictive method=lee-kesler]
Tb          958.44;      // K   [origin=predictive method=joback]
HvapTb      89102.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.105 2.96492 -0.0017482 3.951e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 24; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 25; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexacosylbenzene" );
gibbsFormation
{
    dHf_298   -467280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1296.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=330970.0
    phase     gas;
}
