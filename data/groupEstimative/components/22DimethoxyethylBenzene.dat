/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2,2-dimethoxyethyl)benzene  (C10H14O2, CAS 101-48-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22DimethoxyethylBenzene;
formula     C10H14O2;
CAS         101-48-4;
InChIKey    WNJSKZBEWNVKGU-UHFFFAOYSA-N;
MW          166.22;      // g/mol [origin=calculated method=formula-sum]
Tc          705.64;      // K   [origin=predictive method=joback]
Pc          28.505;      // bar [origin=predictive method=joback]
omega       0.5079;      // -   [origin=predictive method=lee-kesler]
Tb          499.48;      // K   [origin=predictive method=joback]
HvapTb      44562.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.211 0.75444 -0.0003326 2.32e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethoxyethylbenzene" "phenylacetaldehyde dimethyl acetal" "viridine" "hyscylene p" "benzene, (2,2-dimethoxyethyl)-" "acetaldehyde, phenyl-, dimethyl acetal" "1,1-dimethoxy-2-phenylethane" "padma" "phenacetaldehyde dimethyl acetal" "alpha-tolyl aldehyde dimethyl acetal" "phenylacetic aldehyde dimethyl acetal" "2,2-dimethoxy-1-phenylethane" );
gibbsFormation
{
    dHf_298   -282920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     452.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-66710.0
    phase     gas;
}
