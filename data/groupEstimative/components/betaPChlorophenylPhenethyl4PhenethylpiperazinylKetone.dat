/*--------------------------------*- Choupo -*-----------------------*\
  Component: beta-(p-chlorophenyl)phenethyl 4-phenethylpiperazinyl ketone  (C27H29ClN2O, CAS 23902-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        betaPChlorophenylPhenethyl4PhenethylpiperazinylKetone;
formula     C27H29ClN2O;
CAS         23902-89-8;
InChIKey    PRMKKOJZFTYWJG-UHFFFAOYSA-N;
MW          432.992;      // g/mol [origin=calculated method=formula-sum]
Tc          1286.53;      // K   [origin=predictive method=joback]
Pc          14.635;      // bar [origin=predictive method=joback]
omega       1.1085;      // -   [origin=predictive method=lee-kesler]
Tb          1033.80;      // K   [origin=predictive method=joback]
HvapTb      98409.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-173.187 2.6729 -0.00193086 5.3356e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 14; } { group AC; count 1; } { group ACCH2; count 1; } { group ACCH; count 1; } { group CH2N; count 1; } { group ACCl; count 1; } { group CON_CH2_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 14; } { group dC_ring; count 4; } { group Cl; count 1; } { group CdO; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(4-chlorophenyl)-3-phenyl-1-[4-(2-phenylethyl)piperazin-1-yl]propan-1-one" "1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-phenethylpiperazine" "ketone, beta-(p-chlorophenyl)phenethyl 4-phenethylpiperazinyl" "piperazine, 1-(3-(p-chlorophenyl)-3-phenylpropionyl)-4-phenethyl-" "3-(4-chlorophenyl)-1-(4-phenethylpiperazin-1-yl)-3-phenylpropan-1-one" );
gibbsFormation
{
    dHf_298   185950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     937.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=638690.0
    phase     gas;
}
