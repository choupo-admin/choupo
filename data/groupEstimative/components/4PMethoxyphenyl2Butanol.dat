/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(p-methoxyphenyl)-2-butanol  (C11H16O2, CAS 67952-38-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4PMethoxyphenyl2Butanol;
formula     C11H16O2;
CAS         67952-38-9;
InChIKey    UOACSUDCGMMDFW-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          790.44;      // K   [origin=predictive method=joback]
Pc          28.444;      // bar [origin=predictive method=joback]
omega       0.9571;      // -   [origin=predictive method=lee-kesler]
Tb          597.10;      // K   [origin=predictive method=joback]
HvapTb      61719.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.392 0.88714 -0.00046136 7.48e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-methoxyphenyl)butan-2-ol" "benzenepropanol, 4-methoxy-.alpha.-methyl-" "agn-pc-00gj25" "4-(p-methoxyphenyl)butan-2-ol" "(2s)-4-(4-methoxyphenyl)butan-2-ol" "benzenepropanol, 4-methoxy-alpha-methyl-" );
standardThermochemistry
{
    dHf_298   -335040.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     524.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-99740.0
}
