/*--------------------------------*- Choupo -*-----------------------*\
  Component: succinaldehyde  (C4H6O2, CAS 638-37-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        succinaldehyde;
formula     C4H6O2;
CAS         638-37-9;
InChIKey    PCSMJKASWLYICJ-UHFFFAOYSA-N;
MW          86.09;      // g/mol [origin=calculated method=formula-sum]
Tc          570.63;      // K   [origin=predictive method=joback]
Pc          47.301;      // bar [origin=predictive method=joback]
omega       0.5166;      // -   [origin=predictive method=lee-kesler]
Tb          388.44;      // K   [origin=predictive method=joback]
HvapTb      37938.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.052 0.3328 -0.0001798 3.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CHO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group OdCH_al; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "butanedial" "succindialdehyde" "succinic aldehyde" "1,4-butanedione" "succinic dialdehyde" "beta-formylpropionaldehyde" ".beta.-formylpropionaldehyde" );
standardThermochemistry
{
    dHf_298   -297050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     349.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-216240.0
}
