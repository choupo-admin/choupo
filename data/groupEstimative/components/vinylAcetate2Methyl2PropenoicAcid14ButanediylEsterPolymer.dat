/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl acetate, 2-methyl-2-propenoic acid, 1,4-butanediyl ester polymer  (C16H24O6, CAS 67970-04-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylAcetate2Methyl2PropenoicAcid14ButanediylEsterPolymer;
formula     C16H24O6;
CAS         67970-04-1;
InChIKey    RVXNHOHJYISKFL-UHFFFAOYSA-N;
MW          312.362;      // g/mol [origin=calculated method=formula-sum]
Tc          921.01;      // K   [origin=predictive method=joback]
Pc          13.809;      // bar [origin=predictive method=joback]
omega       0.9352;      // -   [origin=predictive method=lee-kesler]
Tb          731.54;      // K   [origin=predictive method=joback]
HvapTb      71875.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (97.034 1.09306 -0.0002213 -1.535e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH2=CH; count 1; } { group CH2=C; count 2; } { group CH3COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 4; } { group dCH2; count 3; } { group dCH; count 1; } { group dC; count 2; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl ethanoate;4-(2-methylprop-2-enoyloxy)butyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, 1,1'-(1,4-butanediyl) ester, polymer with ethenyl acetate" "ethenyl acetate; 4-(2-methylprop-2-enoyloxy)butyl 2-methylprop-2-enoate" );
standardThermochemistry
{
    dHf_298   -1080320.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1018.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-705610.0
}
