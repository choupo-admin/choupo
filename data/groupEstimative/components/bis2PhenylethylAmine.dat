/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(2-phenylethyl)amine  (C16H19N, CAS 6308-98-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis2PhenylethylAmine;
formula     C16H19N;
CAS         6308-98-1;
InChIKey    ACSAKRLPJQIBFB-UHFFFAOYSA-N;
MW          225.335;      // g/mol [origin=calculated method=formula-sum]
Tc          897.52;      // K   [origin=predictive method=joback]
Pc          23.136;      // bar [origin=predictive method=joback]
omega       0.7316;      // -   [origin=predictive method=lee-kesler]
Tb          669.21;      // K   [origin=predictive method=joback]
HvapTb      62198.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.676 1.4422 -0.0009576 2.407e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 10; } { group ACCH2; count 2; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-phenyl-n-(2-phenylethyl)ethanamine" "diphenethylamine" "benzeneethanamine, n-(2-phenylethyl)-" "n-phenethyl-2-phenylethanamine" "n-phenethyl-2-phenyl-ethanamine" );
gibbsFormation
{
    dHf_298   152960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     607.06;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=398050.0
    phase     gas;
}
