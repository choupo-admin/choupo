/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-6-methylene-2,7-octadien-4-ol  (C10H16O, CAS 54809-53-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl6Methylene27Octadien4Ol;
formula     C10H16O;
CAS         54809-53-9;
InChIKey    NHMKYUHMPXBMFI-UHFFFAOYSA-N;
MW          152.237;      // g/mol [origin=calculated method=formula-sum]
Tc          697.12;      // K   [origin=predictive method=joback]
Pc          26.791;      // bar [origin=predictive method=joback]
omega       0.7803;      // -   [origin=predictive method=lee-kesler]
Tb          517.42;      // K   [origin=predictive method=joback]
HvapTb      52923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.139 0.97354 -0.000688 2.029e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 2; } { group dCH; count 2; } { group dC; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-6-methylidene-octa-2,7-dien-4-ol" "2-methyl-6-methyleneocta-2,7-dien-4-ol" "2-methyl-6-methylideneocta-2,7-dien-4-ol" "2,7-octadien-4-ol, 2-methyl-6-methylene-, (s)-" "ipsdienol" "(+-)-ipsdienol" "(4s)-2-methyl-6-methylideneocta-2,7-dien-4-ol" "2,7-octadien-4-ol, 2-methyl-6-methylene-, (4s)-" "(+-)-2-methyl-6-methylene-2,7-octadien-4-ol" "2,7-octadien-4-ol, 2-methyl-6-methylene-, (+-)-" );
gibbsFormation
{
    dHf_298   -58740.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=132860.0
    phase     gas;
}
