/*--------------------------------*- Choupo -*-----------------------*\
  Component: laplen  (C4H5Cl3, CAS 9011-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        laplen;
formula     C4H5Cl3;
CAS         9011-06-7;
InChIKey    DHZSIQDUYCWNSB-UHFFFAOYSA-N;
MW          159.434;      // g/mol [origin=calculated method=formula-sum]
Tc          608.87;      // K   [origin=predictive method=joback]
Pc          34.119;      // bar [origin=predictive method=joback]
omega       0.2276;      // -   [origin=predictive method=lee-kesler]
Tb          398.05;      // K   [origin=predictive method=joback]
HvapTb      36687.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (73.07 0.1579 0.0001117 -1.172e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group CH2=C; count 1; } { group Cl_C=C_; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group Cl; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)ethene;chloranylethene" "saran" "daran" "velon" "kurehalon a0" "latex svkh" "viniden 60" "winiden 60" "vkhvd 40" "ikhs 1" "svkh 1" "ethene, 1,1-dichloro-, polymer with chloroethene" );
gibbsFormation
{
    dHf_298   -43660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=9380.0
    phase     gas;
}
