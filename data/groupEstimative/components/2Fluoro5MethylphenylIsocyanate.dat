/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-fluoro-5-methylphenyl isocyanate  (C8H6FNO, CAS 190774-50-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Fluoro5MethylphenylIsocyanate;
formula     C8H6FNO;
CAS         190774-50-6;
InChIKey    GLSUJZPVKMKUPJ-UHFFFAOYSA-N;
MW          151.14;      // g/mol [origin=calculated method=formula-sum]
Tc          697.04;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.5261;      // -   [origin=predictive method=lee-kesler]
Tb          485.22;      // K   [origin=predictive method=joback]
HvapTb      45717.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group CH3; count 1; } { group dCd; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 1; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-fluoranyl-2-isocyanato-4-methyl-benzene" "1-fluoro-2-isocyanato-4-methylbenzene" "2-fluoro-5-methylphenylisocyanate" "2-fluoro-5-methylbenzenisocyanate" "4-fluoro-3-isocyanatotoluene" "benzene,1-fluoro-2-isocyanato-4-methyl-" "1-fluoro-2-isocyanato-4-methyl-benzene" "1-fluoro-2-isocyanato-4-methylbenzene;2-fluoro-5-methylphenyl isocyanate;" );
