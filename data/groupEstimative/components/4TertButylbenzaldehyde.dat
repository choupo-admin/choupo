/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-tert-butylbenzaldehyde  (C11H14O, CAS 939-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H14O (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        4TertButylbenzaldehyde;
formula     C11H14O;
CAS         939-97-9;
InChIKey    OTXINXDGSUFPNU-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          672.41;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       0.2958;      // -   [origin=predictive method=lee-kesler]
Tb          456.13;      // K   [origin=predictive method=joback]
HvapTb      39349.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-70.69 1.04436 -0.00086356 2.889e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-t-butylbenzaldehyde" "p-tertbutyl benzaldehyde" "4-(tert-butyl)benzaldehyde" "benzaldehyde, 4-(1,1-dimethylethyl)-" "p-tert-butylbenzaldehyde" "4-tert-butyl benzaldehyde" "4-tert-butyl-benzaldehyde" "p-tert-butylbenzaldehyde, g" "benzaldehyde, p-tert-butyl-" "p-tertiary-butyl benzaldehyde" "4-(1,1-dimethylethyl)-benzaldehyde" "o223" );
gibbsFormation
{
    dHf_298   22390.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=191320.0
    phase     gas;
}
