/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,7-ethano-1h-indene, octahydro-  (C11H18, CAS 38255-97-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        47Ethano1hIndeneOctahydro;
formula     C11H18;
CAS         38255-97-9;
InChIKey    QQFHDKGHMOYHPI-UHFFFAOYSA-N;
MW          150.265;      // g/mol [origin=calculated method=formula-sum]
Tc          694.45;      // K   [origin=predictive method=joback]
Pc          28.689;      // bar [origin=predictive method=joback]
omega       0.3461;      // -   [origin=predictive method=lee-kesler]
Tb          475.37;      // K   [origin=predictive method=joback]
HvapTb      39854.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-162.14 1.4558 -0.001087 3.296e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[5.2.2.0(2.6)]undecane" );
standardThermochemistry
{
    dHf_298   -84630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     311.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=192080.0
}
