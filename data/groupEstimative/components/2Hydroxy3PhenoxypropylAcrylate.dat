/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-3-phenoxypropyl acrylate  (C12H14O4, CAS 16969-10-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Hydroxy3PhenoxypropylAcrylate;
formula     C12H14O4;
CAS         16969-10-1;
InChIKey    HHQAGBQXOWLTLL-UHFFFAOYSA-N;
MW          222.24;      // g/mol [origin=calculated method=formula-sum]
Tc          866.86;      // K   [origin=predictive method=joback]
Pc          27.440;      // bar [origin=predictive method=joback]
omega       1.1500;      // -   [origin=predictive method=lee-kesler]
Tb          669.90;      // K   [origin=predictive method=joback]
HvapTb      70020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.602 0.9668 -0.0005111 7.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COO; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-oxidanyl-3-phenoxy-propyl) prop-2-enoate" "2-hydroxy-3-phenoxypropyl prop-2-enoate" "(2-hydroxy-3-phenoxypropyl) prop-2-enoate" );
standardThermochemistry
{
    dHf_298   -536060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     616.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-304220.0
}
