/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-phenylethyl methyl ether  (C9H12O, CAS 3558-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PhenylethylMethylEther;
formula     C9H12O;
CAS         3558-60-9;
InChIKey    CQLYXIUHVFRXLT-UHFFFAOYSA-N;
MW          136.194;      // g/mol [origin=calculated method=formula-sum]
Tc          660.51;      // K   [origin=predictive method=joback]
Pc          31.992;      // bar [origin=predictive method=joback]
omega       0.4149;      // -   [origin=predictive method=lee-kesler]
Tb          454.62;      // K   [origin=predictive method=joback]
HvapTb      40314.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.698 0.71672 -0.000386 6.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxyethylbenzene" "(2-methoxyethyl)benzene" "benzene, (2-methoxyethyl)-" "methyl phenethyl ether" "phenylethyl methyl ether" "ether, methyl phenethyl" "methyl phenethyl oxide" "methyl phenylethyl ether" "kedwa ether" "kewda ether" "methyl 2-phenethyl ether" "phenethyl methyl ether" );
standardThermochemistry
{
    dHf_298   -124780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     411.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32310.0
}
