/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl benzoate  (C14H12O2, CAS 120-51-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylBenzoate;
formula     C14H12O2;
CAS         120-51-4;
InChIKey    SESFRYSPDFLNCH-UHFFFAOYSA-N;
MW          212.248;      // g/mol [origin=calculated method=formula-sum]
Tc          872.43;      // K   [origin=predictive method=joback]
Pc          27.847;      // bar [origin=predictive method=joback]
omega       0.6283;      // -   [origin=predictive method=lee-kesler]
Tb          631.50;      // K   [origin=predictive method=joback]
HvapTb      58717.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.239 1.1212 -0.0007056 1.493e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl) benzoate" "ascabiol" "novoscabin" "scabitox" "benzoic acid, phenylmethyl ester" "antiscabiosum" "benylate" "benzylets" "colebenz" "peruscabin" "scabagen" "scabanca" );
gibbsFormation
{
    dHf_298   -176510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     539.78;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-18550.0
    phase     gas;
}
