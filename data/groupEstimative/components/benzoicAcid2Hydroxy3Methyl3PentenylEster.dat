/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 2-hydroxy-, 3-methyl-3-pentenyl ester  (C13H16O3, CAS 65416-15-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid2Hydroxy3Methyl3PentenylEster;
formula     C13H16O3;
CAS         65416-15-1;
InChIKey    DUVODKYLTOFNJW-UHFFFAOYSA-N;
MW          220.268;      // g/mol [origin=calculated method=formula-sum]
Tc          888.76;      // K   [origin=predictive method=joback]
Pc          27.014;      // bar [origin=predictive method=joback]
omega       0.8665;      // -   [origin=predictive method=lee-kesler]
Tb          666.60;      // K   [origin=predictive method=joback]
HvapTb      67267.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-40.218 1.27964 -0.00096246 2.942e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACOH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylpent-3-enyl 2-oxidanylbenzoate" "benzoic acid, 2-hydroxy-, 3-methyl-3-penten-1-yl ester" );
standardThermochemistry
{
    dHf_298   -462280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     622.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-222330.0
}
