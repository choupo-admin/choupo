/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(3,7-dimethylocta-2,6-dienyl)-1,3-dioxolane  (C13H22O2, CAS 31180-93-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        237Dimethylocta26Dienyl13Dioxolane;
formula     C13H22O2;
CAS         31180-93-5;
InChIKey    XCESWGXOHXDKAJ-UHFFFAOYSA-N;
MW          210.317;      // g/mol [origin=calculated method=formula-sum]
Tc          779.24;      // K   [origin=predictive method=joback]
Pc          20.850;      // bar [origin=predictive method=joback]
omega       0.5936;      // -   [origin=predictive method=lee-kesler]
Tb          574.30;      // K   [origin=predictive method=joback]
HvapTb      53885.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-62.517 1.40436 -0.0009552 2.64e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group CH=C; count 2; } { group FCH2O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group dCH; count 2; } { group dC; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-(3,7-dimethyl-2,6-octadienyl)-" "1,3-dioxolane, 2-(3,7-dimethyl-2,6-octadien-1-yl)-" "1,3-dioxolane,2-(3,7-dimethyl-2,6-octadien-1-yl)-" "1,3-dioxolane,2-(3,7-dimethyl-2,6-octadienyl)- (8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -300310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=66230.0
}
