/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-methoxyquinoline  (C10H9NO, CAS 938-33-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Methoxyquinoline;
formula     C10H9NO;
CAS         938-33-0;
InChIKey    ZLKGGEBOALGXJZ-UHFFFAOYSA-N;
MW          159.188;      // g/mol [origin=calculated method=formula-sum]
Tc          800.40;      // K   [origin=predictive method=joback]
Pc          37.500;      // bar [origin=predictive method=joback]
omega       0.5188;      // -   [origin=predictive method=lee-kesler]
Tb          555.16;      // K   [origin=predictive method=joback]
HvapTb      51052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.69 0.78228 -0.00051934 1.365e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group CH3O; count 1; } { group C5H3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 3; } { group O; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 8-quinolyl ether" "quinoline, 8-methoxy-" "8-methoxy-quinoline" "8-methoxyquinoline," "zlkggeboalgxjz-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   66970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     348.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214800.0
}
