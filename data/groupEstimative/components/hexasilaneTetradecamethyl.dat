/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexasilane, tetradecamethyl-  (C14H42Si6, CAS 812-53-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H42Si6 (delta Si+6; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexasilaneTetradecamethyl;
formula     C14H42Si6;
CAS         812-53-3;
InChIKey    MYVYLCKNQVLMQO-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          379.0;      // g/mol [origin=calculated method=formula-sum]
Tc          718.29;      // K   [origin=predictive method=joback]
Pc          9.284;      // bar [origin=predictive method=joback]
omega       0.1478;      // -   [origin=predictive method=lee-kesler]
Tb          528.32;      // K   [origin=predictive method=joback]
HvapTb      48522.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (235.07 0.09688 0.001751 -1.1478e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 14; } { group Si; count 6; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 14; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[dimethyl(trimethylsilyl)silyl]-[[dimethyl(trimethylsilyl)silyl]-dimethyl-silyl]-dimethyl-silane" "tetradecamethylhexasilane" "[dimethyl(trimethylsilyl)silyl]-[[dimethyl(trimethylsilyl)silyl]-dimethylsilyl]-dimethylsilane" );
gibbsFormation
{
    dHf_298   -1002010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1460.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-561560.0
    phase     gas;
}
