/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-iodobutyl acetate  (C6H11IO2, CAS 40596-44-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4IodobutylAcetate;
formula     C6H11IO2;
CAS         40596-44-9;
InChIKey    FLPVVTDEKLGZDZ-UHFFFAOYSA-N;
MW          242.052;      // g/mol [origin=calculated method=formula-sum]
Tc          694.88;      // K   [origin=predictive method=joback]
Pc          30.490;      // bar [origin=predictive method=joback]
omega       0.4982;      // -   [origin=predictive method=lee-kesler]
Tb          488.24;      // K   [origin=predictive method=joback]
HvapTb      45730.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.534 0.55802 -0.0002894 4.3e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3COO; count 1; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group I; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-iodanylbutyl ethanoate" "1-acetoxy-4-iodobutane" "4-iodobutyl acetate (tech.)" "acetic acid 4-iodo-butyl ester" "1-butanol, 4-iodo-,1-acetate" "1-butanol,4-iodo-, acetate (6ci,9ci);4-acetoxybutyl iodide;4-iodo-1-butanol acetate;4-iodobutyl acetate;" );
gibbsFormation
{
    dHf_298   -407580.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     496.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-252610.0
    phase     gas;
}
