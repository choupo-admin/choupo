/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-isobutoxy-2-cyclohexenone  (C10H16O2, CAS 23074-59-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Isobutoxy2Cyclohexenone;
formula     C10H16O2;
CAS         23074-59-1;
InChIKey    FKJAZODXPHIGOL-UHFFFAOYSA-N;
MW          168.236;      // g/mol [origin=calculated method=formula-sum]
Tc          765.95;      // K   [origin=predictive method=joback]
Pc          27.906;      // bar [origin=predictive method=joback]
omega       0.5433;      // -   [origin=predictive method=lee-kesler]
Tb          546.56;      // K   [origin=predictive method=joback]
HvapTb      45815.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.581 0.76134 -0.00022504 -4.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group O; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-methylpropoxy)cyclohex-2-en-1-one" "3-isobutoxycyclohex-2-en-1-one" "2-cyclohexen-1-one,3-(2-methylpropoxy)-" "2-cyclohexen-1-one,3-isobutoxy- (6ci,8ci);3-(2-methylpropoxy)-2-cyclohexen-1-one;3-isobutoxy-2-cyclohexen-1-one;3-isobutoxy-2-cyclohexenone;3-iso-butoxy-2-cyclohexenone;" );
gibbsFormation
{
    dHf_298   -403960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     436.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144220.0
    phase     gas;
}
