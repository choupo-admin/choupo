/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-[2-(2-ethylhexoxy)ethoxy]ethanol  (C12H26O3, CAS 1559-36-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        222EthylhexoxyEthoxyEthanol;
formula     C12H26O3;
CAS         1559-36-0;
InChIKey    OADIZUFHUPTFAG-UHFFFAOYSA-N;
MW          218.337;      // g/mol [origin=calculated method=formula-sum]
Tc          771.94;      // K   [origin=predictive method=joback]
Pc          18.838;      // bar [origin=predictive method=joback]
omega       1.1323;      // -   [origin=predictive method=lee-kesler]
Tb          610.74;      // K   [origin=predictive method=joback]
HvapTb      63417.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (46.589 1.05734 -0.0004406 3.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH; count 1; } { group CH2O; count 1; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 9; } { group CH; count 1; } { group OH; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2-[2-[(2-ethylhexyl)oxy]ethoxy]-" "ethanol, 2-(2-((2-ethylhexyl)oxy)ethoxy)-" );
standardThermochemistry
{
    dHf_298   -712960.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     687.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-299100.0
}
