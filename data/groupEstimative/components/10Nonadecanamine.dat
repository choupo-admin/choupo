/*--------------------------------*- Choupo -*-----------------------*\
  Component: 10-nonadecanamine  (C19H41N, CAS 3241-23-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        10Nonadecanamine;
formula     C19H41N;
CAS         3241-23-4;
InChIKey    DEKCSXCNXGALFT-UHFFFAOYSA-N;
MW          283.544;      // g/mol [origin=calculated method=formula-sum]
Tc          878.14;      // K   [origin=predictive method=joback]
Pc          11.283;      // bar [origin=predictive method=joback]
omega       0.9045;      // -   [origin=predictive method=lee-kesler]
Tb          706.41;      // K   [origin=predictive method=joback]
HvapTb      68141.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-9.574 1.87664 -0.0010564 2.254e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 16; } { group CHNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 16; } { group CH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "nonadecan-10-amine" "10-aminononadecane" "decylamine,1-nonyl- (7ci,8ci); 1-nonyldecylamine" );
standardThermochemistry
{
    dHf_298   -406980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     938.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=173110.0
}
