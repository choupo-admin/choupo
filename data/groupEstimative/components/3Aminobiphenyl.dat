/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-aminobiphenyl  (C12H11N, CAS 2243-47-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Aminobiphenyl;
formula     C12H11N;
CAS         2243-47-2;
InChIKey    MUNOBADFTHUUFG-UHFFFAOYSA-N;
MW          169.227;      // g/mol [origin=calculated method=formula-sum]
Tc          864.10;      // K   [origin=predictive method=joback]
Pc          36.029;      // bar [origin=predictive method=joback]
omega       0.5524;      // -   [origin=predictive method=lee-kesler]
Tb          605.03;      // K   [origin=predictive method=joback]
HvapTb      58161.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.04 0.9884 -0.00066776 1.687e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group AC; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 9; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-phenylaniline" "m-aminobiphenyl" "3-biphenylamine" "biphenyl-3-ylamine" "[1,1'-biphenyl]-3-amine" "m-phenylaniline" "biphenyl-3-amine" "3-phenylphenylamine" "(1,1'-biphenyl)-3-amine" "3-aminodiphenyl" "aminobiphenyl(3-)" "(1,1'-biphenyl)amine" );
standardThermochemistry
{
    dHf_298   204370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     456.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=331800.0
}
