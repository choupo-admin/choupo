/*--------------------------------*- Choupo -*-----------------------*\
  Component: acitretin  (C21H26O3, CAS 55079-83-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acitretin;
formula     C21H26O3;
CAS         55079-83-9;
InChIKey    IHUNBGSDBOWDMA-AQFIFDHZSA-N;
MW          326.436;      // g/mol [origin=calculated method=formula-sum]
Tc          1135.86;      // K   [origin=predictive method=joback]
Pc          13.996;      // bar [origin=predictive method=joback]
omega       1.0501;      // -   [origin=predictive method=lee-kesler]
Tb          911.01;      // K   [origin=predictive method=joback]
HvapTb      86830.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.92 1.74942 -0.00118304 3.31e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=CH; count 2; } { group CH=C; count 2; } { group ACH; count 1; } { group AC; count 2; } { group ACCH3; count 3; } { group CH3O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group dCH; count 6; } { group dC; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 5; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2e,4e,6e,8e)-9-(4-methoxy-2,3,6-trimethyl-phenyl)-3,7-dimethyl-nona-2,4,6,8-tetraenoic acid" "soriatane" "neotigason" "etretin" "acitretine" "acitretina" "acitretinum" "retinoid etretin" "all-trans-acitretin" "acitretine [french]" "acitretinum [latin]" "tmmp" );
standardThermochemistry
{
    dHf_298   -319310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=54700.0
}
