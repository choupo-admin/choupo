/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexene, 6-(2-butenylidene)-1,5,5-trimethyl-  (C13H20, CAS 55497-53-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexene62Butenylidene155Trimethyl;
formula     C13H20;
CAS         55497-53-5;
InChIKey    BYDQKMZEOZVIJM-UHFFFAOYSA-N;
MW          176.303;      // g/mol [origin=calculated method=formula-sum]
Tc          748.69;      // K   [origin=predictive method=joback]
Pc          22.376;      // bar [origin=predictive method=joback]
omega       0.4153;      // -   [origin=predictive method=lee-kesler]
Tb          531.77;      // K   [origin=predictive method=joback]
HvapTb      45509.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.53 1.47988 -0.00126954 4.787e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 3; } { group CH2_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-but-2-enylidene-1,5,5-trimethyl-cyclohexene" "cyclohexene, 6-(2-buten-1-ylidene)-1,5,5-trimethyl-" "6-but-2-enylidene-1,5,5-trimethylcyclohexene" );
standardThermochemistry
{
    dHf_298   -2530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     623.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=223550.0
}
