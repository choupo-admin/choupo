/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,4-benzenetricarboxylic acid, polymer with hexanedioic acid and 1,6-hexanediol  (C21H30O12, CAS 71156-03-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        124BenzenetricarboxylicAcidPolymerWithHexanedioicAcidAnd16He;
formula     C21H30O12;
CAS         71156-03-1;
InChIKey    JZQWZVPJFFVMIF-UHFFFAOYSA-N;
MW          474.459;      // g/mol [origin=calculated method=formula-sum]
Tc          2278.94;      // K   [origin=predictive method=joback]
Pc          16.259;      // bar [origin=predictive method=joback]
omega       0.3047;      // -   [origin=predictive method=lee-kesler]
Tb          1631.43;      // K   [origin=predictive method=joback]
HvapTb      185706.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (93.71 1.7105 -0.00060992 -6.04e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 10; } { group ACH; count 3; } { group AC; count 3; } { group OH; count 2; } { group COOH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 10; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH; count 2; } { group COOH; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene-1,2,4-tricarboxylic acid;hexanedioic acid;hexane-1,6-diol" "adipic acid, trimellitic acid, 1,6-hexanediol polymer" );
standardThermochemistry
{
    dHf_298   -2542230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1437.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-1983620.0
}
