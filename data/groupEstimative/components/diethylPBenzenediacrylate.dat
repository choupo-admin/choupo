/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl p-benzenediacrylate  (C16H18O4, CAS 17088-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylPBenzenediacrylate;
formula     C16H18O4;
CAS         17088-28-7;
InChIKey    QYGWZBFQWUBYAT-UHFFFAOYSA-N;
MW          274.316;      // g/mol [origin=calculated method=formula-sum]
Tc          933.15;      // K   [origin=predictive method=joback]
Pc          18.515;      // bar [origin=predictive method=joback]
omega       0.8969;      // -   [origin=predictive method=lee-kesler]
Tb          722.10;      // K   [origin=predictive method=joback]
HvapTb      68878.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-8.808 1.31584 -0.00078916 1.604e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH=CH; count 2; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-[4-(3-ethoxy-3-oxidanylidene-prop-1-enyl)phenyl]prop-2-enoate" "diethyl 1,4-phenylenediacrylate" "2-propenoic acid, 3,3'-(1,4-phenylene)bis-, 1,1'-diethyl ester" "diethyl 3,3'-(1,4-phenylene)bisacrylate" "2-propenoic acid, 3,3'-(1,4-phenylene)bis-, diethyl ester" "ethyl 3-[4-(3-ethoxy-3-oxoprop-1-enyl)phenyl]prop-2-enoate" "2-propenoic acid,3,3'-(1,4-phenylene)bis-, 1,1'-diethyl ester" "2-propenoicacid, 3,3'-(1,4-phenylene)bis-, diethyl ester (9ci); p-benzenediacrylic acid,diethyl ester (8ci); 1,4-bis(2-ethoxycarbonylethenyl)benzene; diethylp-phenylenediacrylate; p-bis(ethoxycarbonylvinyl)benzene; p-phenylenediacrylicacid diethyl ester" );
standardThermochemistry
{
    dHf_298   -548630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     756.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-273680.0
}
