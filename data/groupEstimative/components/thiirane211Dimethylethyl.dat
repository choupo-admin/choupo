/*--------------------------------*- Choupo -*-----------------------*\
  Component: thiirane, 2-(1,1-dimethylethyl)-  (C6H12S, CAS 37523-44-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        thiirane211Dimethylethyl;
formula     C6H12S;
CAS         37523-44-7;
InChIKey    KEPSIDHSAFAUSG-UHFFFAOYSA-N;
MW          116.222;      // g/mol [origin=calculated method=formula-sum]
Tc          598.00;      // K   [origin=predictive method=joback]
Pc          36.686;      // bar [origin=predictive method=joback]
omega       0.2271;      // -   [origin=predictive method=lee-kesler]
Tb          388.22;      // K   [origin=predictive method=joback]
HvapTb      33379.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-55.46 0.86497 -0.0007133 2.402e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH; count 1; } { group C; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-tert-butylthiirane" );
gibbsFormation
{
    dHf_298   -57860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     310.74;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=103090.0
    phase     gas;
}
