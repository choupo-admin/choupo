/*--------------------------------*- Choupo -*-----------------------*\
  Component: bromocyclopentane  (C5H9Br, CAS 137-43-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bromocyclopentane;
formula     C5H9Br;
CAS         137-43-9;
InChIKey    BRTFVKHPEHKBQF-UHFFFAOYSA-N;
MW          149.031;      // g/mol [origin=calculated method=formula-sum]
Tc          615.07;      // K   [origin=predictive method=joback]
Pc          47.628;      // bar [origin=predictive method=joback]
omega       0.2766;      // -   [origin=predictive method=lee-kesler]
Tb          395.44;      // K   [origin=predictive method=joback]
HvapTb      33416.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-53.95 0.6487 -0.000447 1.219e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bromanylcyclopentane" "cyclopentyl bromide" "cyclopentane, bromo-" "cyclopentylbromide" "bromo cyclopentane" "bromo-cyclopentane" "sfphabilimup@" );
standardThermochemistry
{
    dHf_298   -59720.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     351.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=42090.0
}
