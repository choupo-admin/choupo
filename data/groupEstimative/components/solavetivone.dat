/*--------------------------------*- Choupo -*-----------------------*\
  Component: solavetivone  (C15H22O, CAS 54878-25-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        solavetivone;
formula     C15H22O;
CAS         54878-25-0;
InChIKey    FGCUSSRGQNHZRW-HCYNLOQUSA-N;
MW          218.34;      // g/mol [origin=calculated method=formula-sum]
Tc          875.40;      // K   [origin=predictive method=joback]
Pc          20.984;      // bar [origin=predictive method=joback]
omega       0.5220;      // -   [origin=predictive method=lee-kesler]
Tb          637.45;      // K   [origin=predictive method=joback]
HvapTb      52649.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-119.94 1.65376 -0.00122564 4.016e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 2; } { group C; count 1; } { group CH2=C; count 1; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3r,6r)-6,10-dimethyl-3-prop-1-en-2-yl-spiro[4.5]dec-9-en-8-one" "(2r,10r)-6,10-dimethyl-2-(prop-1-en-2-yl)spiro[4.5]dec-6-en-8-one" "katahdinone" "(-)-solavetivone" "(3r,6r)-6,10-dimethyl-3-prop-1-en-2-ylspiro[4.5]dec-9-en-8-one" "spiro(4.5)dec-6-en-8-one, 6,10-dimethyl-2-(1-methylethenyl)-, (2r,5s,10r)-" "spiro[4.5]dec-6-en-8-one,6,10-dimethyl-2-(1-methylethenyl)-, (2r,5s,10r)-" "spiro[4.5]dec-6-en-8-one,6,10-dimethyl-2-(1-methylethenyl)-, [2r-[2a,5a(r*)]]-; (-)-solavetivone; katahdinone; solavetivone;spirovetiva-1(10),11-dien-2-one" );
standardThermochemistry
{
    dHf_298   -212820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     535.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=112350.0
}
