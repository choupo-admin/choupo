/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-diphenyl-1,3,5-hexatriene  (C18H16, CAS 1720-32-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Diphenyl135Hexatriene;
formula     C18H16;
CAS         1720-32-7;
InChIKey    BOBLSBAZCVBABY-UHFFFAOYSA-N;
MW          232.326;      // g/mol [origin=calculated method=formula-sum]
Tc          927.68;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       0.5641;      // -   [origin=predictive method=lee-kesler]
Tb          677.28;      // K   [origin=predictive method=joback]
HvapTb      60088.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.83 1.616 -0.0012692 3.962e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 3; } { group ACH; count 10; } { group AC; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH; count 6; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-phenylhexa-1,3,5-trienylbenzene" "1,6-diphenyl-1,3,5-hexatriene, scint" "benzene, 1,1'-(1e,3z,5e)-1,3,5-hexatriene-1,6-diylbis-" );
standardThermochemistry
{
    dHf_298   409870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     624.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=566160.0
}
