/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylisopentanoic acid  (C11H14O2, CAS 1010-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3PhenylisopentanoicAcid;
formula     C11H14O2;
CAS         1010-48-6;
InChIKey    JTZZMXVIHNHASS-UHFFFAOYSA-N;
MW          178.231;      // g/mol [origin=calculated method=formula-sum]
Tc          849.42;      // K   [origin=predictive method=joback]
Pc          29.698;      // bar [origin=predictive method=joback]
omega       0.7186;      // -   [origin=predictive method=lee-kesler]
Tb          620.24;      // K   [origin=predictive method=joback]
HvapTb      58224.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.889 1.14654 -0.0008502 2.451e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-3-phenyl-butanoic acid" "3-methyl-3-phenylbutanoic acid" "beta-phenylisovaleric acid" "beta,beta-dimethylhydrocinnamic acid" "beta,beta-dimethylbenzenepropanoic acid" "hydrocinnamic acid, beta,beta-dimethyl-" ".beta.-phenylisovaleric acid" "hydrocinnamic acid,.beta.-dimethyl-" "benzenepropanoic acid,.beta.-dimethyl-" "3-methyl-3-phenylbutyricacid" "3-methyl-3-phenyl-butyric acid" "benzenepropanoic acid, beta,beta-dimethyl-" );
gibbsFormation
{
    dHf_298   -392860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     492.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-186920.0
    phase     gas;
}
