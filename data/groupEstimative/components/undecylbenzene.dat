/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecylbenzene  (C17H28, CAS 6742-54-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecylbenzene;
formula     C17H28;
CAS         6742-54-7;
InChIKey    XBEADGFTLHRJRB-UHFFFAOYSA-N;
MW          232.411;      // g/mol [origin=calculated method=formula-sum]
Tc          802.57;      // K   [origin=predictive method=joback]
Pc          15.760;      // bar [origin=predictive method=joback]
omega       0.7101;      // -   [origin=predictive method=lee-kesler]
Tb          615.24;      // K   [origin=predictive method=joback]
HvapTb      55712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.47 1.53992 -0.0009322 2.166e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group ACH; count 5; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "benzene, undecyl-" "undecane, 1-phenyl-" "undecanylbenzene" "n-undecylbenzene" "undecyl-benzene" "benzene, c10-13-alkyl derivs." "benzene, mono-c10-13-alkyl derivs." "undecane, 1-phenyl- (8ci)" );
standardThermochemistry
{
    dHf_298   -157680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     711.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=204670.0
}
