/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzyl isoamyl ether  (C12H18O, CAS 122-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzylIsoamylEther;
formula     C12H18O;
CAS         122-73-6;
InChIKey    RXXCIBALSKQCAE-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          724.87;      // K   [origin=predictive method=joback]
Pc          23.842;      // bar [origin=predictive method=joback]
omega       0.5297;      // -   [origin=predictive method=lee-kesler]
Tb          522.82;      // K   [origin=predictive method=joback]
HvapTb      46604.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-18.107 1.00764 -0.0005524 1.018e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylbutoxymethylbenzene" "benzyl isopentyl ether" "isoamyl benzyl ether" "ether, benzyl isopentyl" "benzene, [(3-methylbutoxy)methyl]-" "benzene, ((3-methylbutoxy)methyl)-" "benzyl-isoamyl ether" "benzyl 3-methylbutyl ether" "benzene,[(3-methylbutoxy)methyl]-" );
gibbsFormation
{
    dHf_298   -191980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55130.0
    phase     gas;
}
