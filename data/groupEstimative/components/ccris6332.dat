/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 6332  (C24H16O2, CAS 130063-43-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris6332;
formula     C24H16O2;
CAS         130063-43-3;
InChIKey    NDCWEARXOFJOPX-UHFFFAOYSA-N;
MW          336.39;      // g/mol [origin=calculated method=formula-sum]
Tc          1303.24;      // K   [origin=predictive method=joback]
Pc          24.267;      // bar [origin=predictive method=joback]
omega       1.6834;      // -   [origin=predictive method=lee-kesler]
Tb          1058.38;      // K   [origin=predictive method=joback]
HvapTb      113954.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-135.71 2.0946 -0.00179668 6.204e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 8; } { group ACCH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 2; } { group dCH_ring; count 12; } { group dC_ring; count 10; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dibenzo(a,l)pyrene 8,9-dihydrodiol" "dibenzo(a,l)pyrene-8,9-dihydrodiol" "dibenzo(def,p)chrysene-8,9-diol, 8,9-dihydro-" "8,9-dihydronaphtho[1,2,3,4-pqr]tetraphene-8,9-diol" );
standardThermochemistry
{
    dHf_298   158930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     467.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=433560.0
}
