/*--------------------------------*- Choupo -*-----------------------*\
  Component: allyl 2-bromo-2-methylpropionate  (C7H11BrO2, CAS 40630-82-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        allyl2Bromo2Methylpropionate;
formula     C7H11BrO2;
CAS         40630-82-8;
InChIKey    WIPLNCYPGHUSGF-UHFFFAOYSA-N;
MW          207.067;      // g/mol [origin=calculated method=formula-sum]
Tc          683.16;      // K   [origin=predictive method=joback]
Pc          32.467;      // bar [origin=predictive method=joback]
omega       0.4989;      // -   [origin=predictive method=lee-kesler]
Tb          477.59;      // K   [origin=predictive method=joback]
HvapTb      43052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.661 0.75804 -0.0005285 1.384e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group CH2=CH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group Br; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "prop-2-enyl 2-bromanyl-2-methyl-propanoate" "prop-2-enyl 2-bromo-2-methylpropanoate" "propanoic acid, 2-bromo-2-methyl-, 2-propenyl ester" );
standardThermochemistry
{
    dHf_298   -362080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     487.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-197310.0
}
