/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-acetylvaleric acid  (C7H12O3, CAS 3128-07-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5AcetylvalericAcid;
formula     C7H12O3;
CAS         3128-07-2;
InChIKey    IZOQMUVIDMLRDC-UHFFFAOYSA-N;
MW          144.17;      // g/mol [origin=calculated method=formula-sum]
Tc          754.78;      // K   [origin=predictive method=joback]
Pc          33.106;      // bar [origin=predictive method=joback]
omega       0.8829;      // -   [origin=predictive method=lee-kesler]
Tb          559.14;      // K   [origin=predictive method=joback]
HvapTb      55086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.484 0.69162 -0.0004109 9.106e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH3CO; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CdO; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-oxidanylideneheptanoic acid" "6-oxoheptanoic acid" "heptanoic acid, 6-oxo-" "5-aceto valeric acid" "6-oxo-heptanoic acid" "6-oxoenanthic acid" "5-acetylpentanoic acid" );
standardThermochemistry
{
    dHf_298   -650660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     508.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-464770.0
}
