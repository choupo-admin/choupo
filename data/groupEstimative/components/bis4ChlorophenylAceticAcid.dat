/*--------------------------------*- Choupo -*-----------------------*\
  Component: bis(4-chlorophenyl)acetic acid  (C14H10Cl2O2, CAS 83-05-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bis4ChlorophenylAceticAcid;
formula     C14H10Cl2O2;
CAS         83-05-6;
InChIKey    YIOCIFXUGBYCJR-UHFFFAOYSA-N;
MW          281.132;      // g/mol [origin=calculated method=formula-sum]
Tc          1060.07;      // K   [origin=predictive method=joback]
Pc          27.498;      // bar [origin=predictive method=joback]
omega       0.9627;      // -   [origin=predictive method=lee-kesler]
Tb          803.17;      // K   [origin=predictive method=joback]
HvapTb      78180.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-20.35 1.1273 -0.00078272 2.021e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 1; } { group ACCH; count 1; } { group COOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-bis(4-chlorophenyl)ethanoic acid" "2,2-bis(4-chlorophenyl)acetic acid" "p,p'-dda" "bis(p-chlorophenyl)acetic acid" "dichlorodiphenylacetic acid" "p,p'-dichlorodiphenylacetic acid" "di(p-chlorophenyl)acetic acid" "acetic acid, bis(p-chlorophenyl)-" "2,2-bis(p-chlorophenyl)acetic acid" "bis(p-chlorphenyl)essigsaeure" "dda (degradation product)" "benzeneacetic acid, 4-chloro-.alpha.-(4-chlorophenyl)-" );
standardThermochemistry
{
    dHf_298   -269200.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     586.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-97650.0
}
