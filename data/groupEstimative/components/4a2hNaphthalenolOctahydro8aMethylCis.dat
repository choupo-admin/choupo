/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4a-(2h)-naphthalenol, octahydro-8a-methyl-, cis-  (C11H20O, CAS 5173-74-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4a2hNaphthalenolOctahydro8aMethylCis;
formula     C11H20O;
CAS         5173-74-0;
InChIKey    UWRUMJPLZZBUCM-UHFFFAOYSA-N;
MW          168.28;      // g/mol [origin=calculated method=formula-sum]
Tc          794.35;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.7124;      // -   [origin=predictive method=lee-kesler]
Tb          574.50;      // K   [origin=predictive method=joback]
HvapTb      54971.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-222.77 1.93002 -0.001925 8.045e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group C; count 2; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 8; } { group C_ring; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "8a-methyl-1,2,3,4,5,6,7,8-octahydronaphthalen-4a-ol" "4a(2h)-naphthalenol,octahydro-8a-methyl-cis-" "4a(2h)-naphthalenol,octahydro-8a-methyl-trans-" "4a-(2h)-naphthalenol, octahydro-8a-methyl-, trans-" );
standardThermochemistry
{
    dHf_298   -271160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     673.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-32960.0
}
