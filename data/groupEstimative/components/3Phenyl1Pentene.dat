/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenyl-1-pentene  (C11H14, CAS 19947-22-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenyl1Pentene;
formula     C11H14;
CAS         19947-22-9;
InChIKey    HAGOWDKLLDRZAS-UHFFFAOYSA-N;
MW          146.233;      // g/mol [origin=calculated method=formula-sum]
Tc          685.48;      // K   [origin=predictive method=joback]
Pc          27.906;      // bar [origin=predictive method=joback]
omega       0.3826;      // -   [origin=predictive method=lee-kesler]
Tb          474.20;      // K   [origin=predictive method=joback]
HvapTb      41298.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.689 0.95582 -0.0006319 1.621e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH2=CH; count 1; } { group ACH; count 5; } { group ACCH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pent-1-en-3-ylbenzene" "benzene, (1-ethyl-2-propenyl)-" "1-pentene, 3-phenyl-" "benzene,(1-ethyl-2-propen-1-yl)-" "1-pentene,3-phenyl- (7ci,8ci); benzene, (1-ethyl-2-propenyl)- (9ci); 3-phenyl-1-pentene;benzene, (1-ethylallyl)-" );
standardThermochemistry
{
    dHf_298   86310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     463.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=239550.0
}
