/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-trimethylsiloxyhexadecane  (C19H42OSi, CAS 6221-90-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C19H42OSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        1Trimethylsiloxyhexadecane;
formula     C19H42OSi;
CAS         6221-90-5;
InChIKey    JTMICAOGVLZKRG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          314.629;      // g/mol [origin=calculated method=formula-sum]
Tc          821.67;      // K   [origin=predictive method=joback]
Pc          9.895;      // bar [origin=predictive method=joback]
omega       0.7531;      // -   [origin=predictive method=lee-kesler]
Tb          658.14;      // K   [origin=predictive method=joback]
HvapTb      60592.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (51.935 1.53948 -0.000484 -5.71e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 14; } { group CH2O; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 15; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexadecoxy(trimethyl)silane" "silane, (hexadecyloxy)trimethyl-" "(hexadecyloxy)trimethylsilane" );
gibbsFormation
{
    dHf_298   -679330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1033.85;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-100660.0
    phase     gas;
}
