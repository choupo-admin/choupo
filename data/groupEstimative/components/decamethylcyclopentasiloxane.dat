/*--------------------------------*- Choupo -*-----------------------*\
  Component: decamethylcyclopentasiloxane  (C10H30O5Si5, CAS 541-02-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H30O5Si5 (delta Si+5; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        decamethylcyclopentasiloxane;
formula     C10H30O5Si5;
CAS         541-02-6;
InChIKey    XMSXQFUHVRWGNA-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          370.77;      // g/mol [origin=calculated method=formula-sum]
Tc          806.97;      // K   [origin=predictive method=joback]
Pc          14.680;      // bar [origin=predictive method=joback]
omega       0.3611;      // -   [origin=predictive method=lee-kesler]
Tb          590.10;      // K   [origin=predictive method=joback]
HvapTb      62440.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (218.07 0.0662 0.0014405 -9.54e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group SiO; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group O_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6,8,8,10,10-decamethyl-1,3,5,7,9,2,4,6,8,10-pentaoxapentasilecane" "cyclopentasiloxane, decamethyl-" "dow corning 345 fluid" "cyclic dimethylsiloxane pentamer" "dimethylsiloxane pentamer" "union carbide 7158 silicone fluid" "cyclopentasiloxane, 2,2,4,4,6,6,8,8,10,10-decamethyl-" "cyclomethicone" "cyclopentamethicone" "pentacyclomethicone" "silicon plus " "a" "silbione v 5" );
gibbsFormation
{
    dHf_298   -1387010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     913.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-876820.0
    phase     gas;
}
