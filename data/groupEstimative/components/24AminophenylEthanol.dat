/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(4-aminophenyl)ethanol  (C8H11NO, CAS 104-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        24AminophenylEthanol;
formula     C8H11NO;
CAS         104-10-9;
InChIKey    QXHDYMUPPXAMPQ-UHFFFAOYSA-N;
MW          137.182;      // g/mol [origin=calculated method=formula-sum]
Tc          787.09;      // K   [origin=predictive method=joback]
Pc          43.226;      // bar [origin=predictive method=joback]
omega       0.9719;      // -   [origin=predictive method=lee-kesler]
Tb          579.01;      // K   [origin=predictive method=joback]
HvapTb      63660.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-12.208 0.7213 -0.00044936 1.054e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group ACH; count 4; } { group ACCH2; count 1; } { group OH; count 1; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group OH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-aminophenethyl alcohol" "p-aminophenethyl alcohol" "p-aminophenylethanol" "benzeneethanol, 4-amino-" "2-(p-aminophenyl)ethanol" "2-(4-aminophenyl)ethan-1-ol" "benzeneethanol, ar-amino-" "p-(2-hydroxyethyl)aniline" "4-(2-hydroxyethyl)aniline" "phenethyl alcohol, p-amino-" "4-(hydroxyethyl)aniline" "benzeneethanol, ar-amino" );
standardThermochemistry
{
    dHf_298   -101830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=48890.0
}
