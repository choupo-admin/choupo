/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,5,7,12,12,14-hexamethyl-1,4,8,11-tetraazacyclotetradecane  (C16H36N4, CAS 54622-44-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        557121214Hexamethyl14811Tetraazacyclotetradecane;
formula     C16H36N4;
CAS         54622-44-5;
InChIKey    XHCNINMOALIGKM-UHFFFAOYSA-N;
MW          284.492;      // g/mol [origin=calculated method=formula-sum]
Tc          1062.85;      // K   [origin=predictive method=joback]
Pc          19.613;      // bar [origin=predictive method=joback]
omega       0.7060;      // -   [origin=predictive method=lee-kesler]
Tb          800.06;      // K   [origin=predictive method=joback]
HvapTb      76818.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-132.71 2.01992 -0.001213 3.294e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 2; } { group CH; count 2; } { group C; count 2; } { group CH2NH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2_ring; count 6; } { group CH_ring; count 2; } { group C_ring; count 2; } { group NH_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,5,7,12,12,14-hexamethyl-1,4,8,11-tetrazacyclotetradecane" "cis-(5,12)-7,7,14,14-hexamethyl-1,4,8,11-tetraazacyclotetradecane" "bim-0011484.p001" );
standardThermochemistry
{
    dHf_298   -247830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     895.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=328220.0
}
