/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4:5,8-dimethanonaphthalene, 1,2,3,4,5,8-hexahydro-, (1alpha,4alpha,5beta,8beta)-  (C12H14, CAS 102340-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1458Dimethanonaphthalene123458Hexahydro1alpha4alpha5beta8bet;
formula     C12H14;
CAS         102340-97-6;
InChIKey    QUKNLCCMKRXCSW-UHFFFAOYSA-N;
MW          158.244;      // g/mol [origin=calculated method=formula-sum]
Tc          732.72;      // K   [origin=predictive method=joback]
Pc          30.592;      // bar [origin=predictive method=joback]
omega       0.4450;      // -   [origin=predictive method=lee-kesler]
Tb          509.40;      // K   [origin=predictive method=joback]
HvapTb      43866.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-164.83 1.5164 -0.00135028 4.874e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 4; } { group CH=CH; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4:5,8-dimethanonaphthalene, 1,2,3,4,5,8-hexahydro-, (1alpha,4alpha,5alpha,8alpha)-" "1,4:5,8-dimethanonaphthalene, 1,2,3,4,5,8-hexahydro-, (1.alpha.,4.alpha.,5.alpha.,8.alpha.)-" "1,4:5,8-dimethanonaphthalene, 1,2,3,4,5,8-hexahydro-, (1.alpha.,4.alpha.,5.beta.,8.beta.)-" );
gibbsFormation
{
    dHf_298   92810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     175.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=333820.0
    phase     gas;
}
