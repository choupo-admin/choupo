/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 1-piperidinepropionate  (C10H19NO2, CAS 19653-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl1Piperidinepropionate;
formula     C10H19NO2;
CAS         19653-33-9;
InChIKey    MPAWVDTVWPPKJQ-UHFFFAOYSA-N;
MW          185.267;      // g/mol [origin=calculated method=formula-sum]
Tc          712.17;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.6365;      // -   [origin=predictive method=lee-kesler]
Tb          519.01;      // K   [origin=predictive method=joback]
HvapTb      47870.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.907 1.18112 -0.000721 1.558e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH2COO; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 5; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 3-piperidin-1-ylpropanoate" "1-piperidinepropanoic acid, ethyl ester" "ethyl 3-(piperidin-1-yl)propanoate" "1-piperidinepropionic acid, ethyl ester" "ethyl 3-(1-piperidinyl)propionate" "ethyl 3-piperidylpropanoate" "ethyl piperidine-1-propionate" "ethyl 3-(piperidino)propionate" "ethyl 3-(1-piperidinyl)propanoate" "ethyl 3-(piperidin-1-yl)propionate" "1-piperidinepropanoic acid ethyl ester" "1-piperidinepropanoicacid, ethyl ester" );
gibbsFormation
{
    dHf_298   -418660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-122010.0
    phase     gas;
}
