/*--------------------------------*- Choupo -*-----------------------*\
  Component: spiro[5.5]undecane-3-carboxylic acid  (C12H20O2, CAS 18244-47-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        spiro55Undecane3CarboxylicAcid;
formula     C12H20O2;
CAS         18244-47-8;
InChIKey    IMZALJRIJNIAON-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          898.63;      // K   [origin=predictive method=joback]
Pc          29.187;      // bar [origin=predictive method=joback]
omega       0.6947;      // -   [origin=predictive method=lee-kesler]
Tb          654.74;      // K   [origin=predictive method=joback]
HvapTb      59005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.5 1.7403 -0.0014426 5.067e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH; count 1; } { group C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 9; } { group CH_ring; count 1; } { group C_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "spiro(5.5)undecane-3-carboxylic acid" "spiro[5.5]undecane-9-carboxylic acid" );
gibbsFormation
{
    dHf_298   -511240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-238240.0
    phase     gas;
}
