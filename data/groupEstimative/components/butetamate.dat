/*--------------------------------*- Choupo -*-----------------------*\
  Component: butetamate  (C16H25NO2, CAS 14007-64-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        butetamate;
formula     C16H25NO2;
CAS         14007-64-8;
InChIKey    CKWHSYRZDLWQFV-UHFFFAOYSA-N;
MW          263.381;      // g/mol [origin=calculated method=formula-sum]
Tc          857.02;      // K   [origin=predictive method=joback]
Pc          17.189;      // bar [origin=predictive method=joback]
omega       0.8384;      // -   [origin=predictive method=lee-kesler]
Tb          662.58;      // K   [origin=predictive method=joback]
HvapTb      62548.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.525 1.51996 -0.000899 1.845e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 4; } { group ACH; count 5; } { group ACCH; count 1; } { group CH2N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 5; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(diethylamino)ethyl 2-phenylbutanoate" "butethamate" "beta-diethylaminoethyl-2-phenylbutyrate" "benzeneacetic acid, .alpha.-ethyl-, 2-(diethylamino)ethyl ester" "butetamato" "butetamatum" "butetamate (inn)" "butetamatum [inn-latin]" "agn-pc-04sxcl" "hh105" "2-diethylaminoethyl 2-phenylbutanoate" "(alpha-phenylbutansaeure-2-diethylaminoethylester" );
standardThermochemistry
{
    dHf_298   -392070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.66;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5780.0
}
