/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-hexen-1-ol, 2-ethyl-2-(3-methyl-2-butenyl)-  (C13H24O, CAS 85136-06-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Hexen1Ol2Ethyl23Methyl2Butenyl;
formula     C13H24O;
CAS         85136-06-7;
InChIKey    FVVHZRFAPSXWTL-VQHVLOKHSA-N;
MW          196.334;      // g/mol [origin=calculated method=formula-sum]
Tc          772.97;      // K   [origin=predictive method=joback]
Pc          19.824;      // bar [origin=predictive method=joback]
omega       0.8830;      // -   [origin=predictive method=lee-kesler]
Tb          594.19;      // K   [origin=predictive method=joback]
HvapTb      59911.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.166 1.43858 -0.0010555 3.218e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group CH=CH; count 1; } { group CH=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 4; } { group C; count 1; } { group dCH; count 3; } { group dC; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-2-ethyl-2-(3-methylbut-2-enyl)hex-3-en-1-ol" "3-hexen-1-ol, 2-ethyl-2-(3-methyl-2-buten-1-yl)-" "2-ethyl-2-prenyl-3-hexenol" "2-ethyl-2-(3-methylbut-2-enyl)hex-3-en-1-ol" );
gibbsFormation
{
    dHf_298   -247980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     657.07;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=76490.0
    phase     gas;
}
