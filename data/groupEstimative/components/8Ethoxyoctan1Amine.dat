/*--------------------------------*- Choupo -*-----------------------*\
  Component: 8-ethoxyoctan-1-amine  (C10H23NO, CAS 68603-39-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        8Ethoxyoctan1Amine;
formula     C10H23NO;
CAS         68603-39-4;
InChIKey    XEDVNUAPHHNVCC-UHFFFAOYSA-N;
MW          173.3;      // g/mol [origin=calculated method=formula-sum]
Tc          697.19;      // K   [origin=predictive method=joback]
Pc          21.877;      // bar [origin=predictive method=joback]
omega       0.7495;      // -   [origin=predictive method=lee-kesler]
Tb          523.35;      // K   [origin=predictive method=joback]
HvapTb      50905.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (25.789 0.95252 -0.0004526 6.4e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH2O; count 1; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 9; } { group O; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -348160.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     608.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-5230.0
}
