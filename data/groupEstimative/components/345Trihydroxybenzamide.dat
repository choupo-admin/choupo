/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,4,5-trihydroxybenzamide  (C7H7NO4, CAS 618-73-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        345Trihydroxybenzamide;
formula     C7H7NO4;
CAS         618-73-5;
InChIKey    RBQIPEJXQPQFJX-UHFFFAOYSA-N;
MW          169.136;      // g/mol [origin=calculated method=formula-sum]
Tc          1017.94;      // K   [origin=predictive method=joback]
Pc          101.619;      // bar [origin=predictive method=joback]
omega       1.5110;      // -   [origin=predictive method=lee-kesler]
Tb          754.70;      // K   [origin=predictive method=joback]
HvapTb      89881.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.29 1.0876 -0.00118198 4.9886e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group AC; count 1; } { group ACOH; count 3; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 3; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,5-tris(oxidanyl)benzamide" "gallamide" "benzamide, 3,4,5-trihydroxy-" "benzamide,4,5-trihydroxy-" "benzamide,3,4,5-trihydroxy-" );
gibbsFormation
{
    dHf_298   -562000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     479.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-405860.0
    phase     gas;
}
