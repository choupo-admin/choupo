/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-butenediol 1,4-diacrylate  (C10H12O4, CAS 18621-76-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Butenediol14Diacrylate;
formula     C10H12O4;
CAS         18621-76-6;
InChIKey    ZJWKFUBDXPALAF-UHFFFAOYSA-N;
MW          196.202;      // g/mol [origin=calculated method=formula-sum]
Tc          731.37;      // K   [origin=predictive method=joback]
Pc          24.219;      // bar [origin=predictive method=joback]
omega       0.7177;      // -   [origin=predictive method=lee-kesler]
Tb          542.36;      // K   [origin=predictive method=joback]
HvapTb      51286.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.452 0.8242 -0.0004606 7.58e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2=CH; count 2; } { group CH=CH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH2; count 2; } { group dCH; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-prop-2-enoyloxybut-2-enyl prop-2-enoate" "2-propenoic acid, 1,1'-(2-butene-1,4-diyl) ester" "but-2-enylene bisacrylate" "2-propenoic acid, 2-butene-1,4-diyl ester" );
gibbsFormation
{
    dHf_298   -516210.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     632.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-331520.0
    phase     gas;
}
