  Component: 2,2,7,7-tetramethyltricyclo[6.2.1.01,6]undec-5-en-4-yl formate  (C16H24O2, CAS 67874-82-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H24O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2277Tetramethyltricyclo621016Undec5En4YlFormate;
formula     C16H24O2;
CAS         67874-82-2;
InChIKey    WJZMQDGXHGRQSQ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.366;      // g/mol [origin=calculated method=formula-sum]
Tc          797.56;      // K   [origin=predictive method=joback]
Pc          20.438;      // bar [origin=predictive method=joback]
omega       0.3726;      // -   [origin=predictive method=lee-kesler]
Tb          566.38;      // K   [origin=predictive method=joback]
HvapTb      45803.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-308.14 2.67268 -0.00297464 1.3309e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 4; } { group CH; count 2; } { group C; count 3; } { group CH=C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group C_ring; count 3; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2h-2,4a-methanonaphthalen-7-ol, 1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-, 7-formate" "2h-2,4a-methanonaphthalen-7-ol, 1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-, formate" "1,3,4,5,6,7-hexahydro-1,1,5,5-tetramethyl-2h-2,4a-methanonaphthalen-7-yl formate" );
gibbsFormation
{
    dHf_298   -39690.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     812.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=274290.0
    phase     gas;
}
