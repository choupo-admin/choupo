/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-oxo-cycloheptanecarboxylic acid m  (C9H14O3, CAS 52784-32-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2OxoCycloheptanecarboxylicAcidM;
formula     C9H14O3;
CAS         52784-32-4;
InChIKey    BLNHITXSJKCQGZ-UHFFFAOYSA-N;
MW          170.208;      // g/mol [origin=calculated method=formula-sum]
Tc          784.32;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.5401;      // -   [origin=predictive method=lee-kesler]
Tb          555.38;      // K   [origin=predictive method=joback]
HvapTb      47883.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.18 0.74822 -0.0001618 -9.45e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-oxidanylidenecycloheptane-1-carboxylate" "methyl 2-oxo-1-cycloheptanecarboxylate" "methyl 2-oxocycloheptanecarboxylate" "methyl 2-oxo-cycloheptanecarboxylate" "2-oxo-cycloheptanecarboxylic acid ethyl ester" "methyl 2-oxocycloheptane-1-carboxylate" );
gibbsFormation
{
    dHf_298   -635910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     468.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-395710.0
    phase     gas;
}
