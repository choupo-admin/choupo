/*--------------------------------*- Choupo -*-----------------------*\
  Component: indolizine, octahydro-  (C8H15N, CAS 13618-93-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        indolizineOctahydro;
formula     C8H15N;
CAS         13618-93-4;
InChIKey    HAJKHJOABGFIGP-UHFFFAOYSA-N;
MW          125.215;      // g/mol [origin=calculated method=formula-sum]
Tc          629.69;      // K   [origin=predictive method=joback]
Pc          36.955;      // bar [origin=predictive method=joback]
omega       0.3492;      // -   [origin=predictive method=lee-kesler]
Tb          421.77;      // K   [origin=predictive method=joback]
HvapTb      35924.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-131.74 1.1968 -0.000927 2.884e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 7; } { group CH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3,5,6,7,8,8a-octahydroindolizine" "indolizidine" "octahydroindolizine" ".delta.-coniceine" "octahydro-indolizine" "indolizine, octahydro-, (r)-" "a-coniceine" "1-azabicyclo[4.3.0]nonane" "2,3,4,5,6,7,8,8a-octahydro-1h-indolizine" );
standardThermochemistry
{
    dHf_298   12700.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     385.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=232270.0
}
