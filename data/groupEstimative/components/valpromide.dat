/*--------------------------------*- Choupo -*-----------------------*\
  Component: valpromide  (C8H17NO, CAS 2430-27-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        valpromide;
formula     C8H17NO;
CAS         2430-27-5;
InChIKey    OMOMUFTZPTXCHP-UHFFFAOYSA-N;
MW          143.23;      // g/mol [origin=calculated method=formula-sum]
Tc          699.77;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.6745;      // -   [origin=predictive method=lee-kesler]
Tb          508.60;      // K   [origin=predictive method=joback]
HvapTb      50401.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.784 0.80364 -0.0004393 8.546e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 4; } { group CH; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-propylpentanamide" "depamide" "dipropylacetamide" "2-ethylvaleramide" "valpramide" "pentanamide, 2-propyl-" "2-propylpentamide" "2-propylvaleramide" "propyl-2 valeramide" "alpha-propylvaleramide" "valeramide, 2-propyl-" "valpromidum [inn-latin]" );
gibbsFormation
{
    dHf_298   -292520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     536.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-48430.0
    phase     gas;
}
