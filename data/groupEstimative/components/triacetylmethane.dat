/*--------------------------------*- Choupo -*-----------------------*\
  Component: triacetylmethane  (C7H10O3, CAS 815-68-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triacetylmethane;
formula     C7H10O3;
CAS         815-68-9;
InChIKey    AUZFRUHVDNDVJI-UHFFFAOYSA-N;
MW          142.154;      // g/mol [origin=calculated method=formula-sum]
Tc          722.68;      // K   [origin=predictive method=joback]
Pc          34.889;      // bar [origin=predictive method=joback]
omega       0.7128;      // -   [origin=predictive method=lee-kesler]
Tb          520.93;      // K   [origin=predictive method=joback]
HvapTb      51026.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (16.92 0.59076 -0.0003041 4.448e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 1; } { group CH3CO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH; count 1; } { group CdO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethanoylpentane-2,4-dione" "3-acetyl-2,4-pentanedione" "2,4-pentanedione, 3-acetyl-" "methine triacetate" "3-acetylpentane-2,4-dione" "2,4-pentanedione,3-acetyl-" );
standardThermochemistry
{
    dHf_298   -530830.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-381140.0
}
