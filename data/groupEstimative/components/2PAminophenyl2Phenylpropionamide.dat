/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(p-aminophenyl)-2-phenylpropionamide  (C15H16N2O, CAS 61706-44-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PAminophenyl2Phenylpropionamide;
formula     C15H16N2O;
CAS         61706-44-3;
InChIKey    CAOYRGMDWVIDGV-UHFFFAOYSA-N;
MW          240.306;      // g/mol [origin=calculated method=formula-sum]
Tc          1062.40;      // K   [origin=predictive method=joback]
Pc          30.356;      // bar [origin=predictive method=joback]
omega       0.9347;      // -   [origin=predictive method=lee-kesler]
Tb          796.84;      // K   [origin=predictive method=joback]
HvapTb      80930.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.39 1.43312 -0.00102746 2.7826e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACNH2; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group CdO; count 1; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(4-aminophenyl)-2-phenyl-propanamide" "2-phenyl-2-(p-aminophenyl)propionamide" "propionamide, 2-(p-aminophenyl)-2-phenyl-" "2-(4-aminophenyl)-2-phenylpropanamide" "2-fenil-2-(p-aminofenil)propionammide" );
gibbsFormation
{
    dHf_298   54910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     612.29;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=297430.0
    phase     gas;
}
