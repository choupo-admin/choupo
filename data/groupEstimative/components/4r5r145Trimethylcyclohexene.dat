/*--------------------------------*- Choupo -*-----------------------*\
  Component: (4r,5r)-1,4,5-trimethylcyclohexene  (C9H16, CAS 87954-39-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4r5r145Trimethylcyclohexene;
formula     C9H16;
CAS         87954-39-0;
InChIKey    FNZUANSNHGITHR-RKDXNWHRSA-N;
MW          124.227;      // g/mol [origin=calculated method=formula-sum]
Tc          626.67;      // K   [origin=predictive method=joback]
Pc          28.024;      // bar [origin=predictive method=joback]
omega       0.2928;      // -   [origin=predictive method=lee-kesler]
Tb          424.54;      // K   [origin=predictive method=joback]
HvapTb      36702.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-42.88 0.83896 -0.00041164 5.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
standardThermochemistry
{
    dHf_298   -148800.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=61970.0
}
