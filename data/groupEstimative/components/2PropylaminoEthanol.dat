/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(propylamino)ethanol  (C5H13NO, CAS 16369-21-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2PropylaminoEthanol;
formula     C5H13NO;
CAS         16369-21-4;
InChIKey    BCLSJHWBDUYDTR-UHFFFAOYSA-N;
MW          103.165;      // g/mol [origin=calculated method=formula-sum]
Tc          622.43;      // K   [origin=predictive method=joback]
Pc          39.407;      // bar [origin=predictive method=joback]
omega       0.8961;      // -   [origin=predictive method=lee-kesler]
Tb          456.35;      // K   [origin=predictive method=joback]
HvapTb      49839.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.424 0.58902 -0.0003272 6.86e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group OH; count 1; } { group CH2NH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group OH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethanol, 2-(propylamino)-" "n-propylethanolamine" "ethanol,2-(propylamino)-" "2-(propylamino)ethan-1-ol" "(2-hydroxyethyl)propylamine;2-propylaminoethanol; mono-n-propylaminoethanol;n-propyl-2-hydroxy-1-ethylamine; n-propyl-2-hydroxyethylamine;n-propylethanolamine; propyl(2-hydroxyethyl)amine" );
gibbsFormation
{
    dHf_298   -245290.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56210.0
    phase     gas;
}
