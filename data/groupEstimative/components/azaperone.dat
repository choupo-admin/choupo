/*--------------------------------*- Choupo -*-----------------------*\
  Component: azaperone  (C19H22FN3O, CAS 1649-18-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        azaperone;
formula     C19H22FN3O;
CAS         1649-18-9;
InChIKey    XTKDAFGWCDAMPY-UHFFFAOYSA-N;
MW          327.403;      // g/mol [origin=calculated method=formula-sum]
Tc          1073.91;      // K   [origin=predictive method=joback]
Pc          20.812;      // bar [origin=predictive method=joback]
omega       1.0839;      // -   [origin=predictive method=lee-kesler]
Tb          840.06;      // K   [origin=predictive method=joback]
HvapTb      79721.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-127.067 2.02466 -0.00146652 4.1176e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 4; } { group AC; count 1; } { group CH2CO; count 1; } { group CH2N; count 2; } { group C5H4N; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group CH2_ring; count 4; } { group dCH_ring; count 8; } { group dC_ring; count 3; } { group F; count 1; } { group CdO; count 1; } { group N; count 2; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-fluorophenyl)-4-(4-pyridin-2-ylpiperazin-1-yl)butan-1-one" "fluoperidol" "stresnil" "suicalm" "azeperone" "eucalmyl" "sedaperone vet" "azaperon" "azaperonum [inn-latin]" "1-butanone, 1-(4-fluorophenyl)-4-[4-(2-pyridinyl)-1-piperazinyl]-" "1-(3-(4-fluorobenzoyl)propyl)-4-(2-pyridyl)piperazine" "4'-fluoro-4-(4-(2-pyridyl)-1-piperazinyl)butyrophenone" );
gibbsFormation
{
    dHf_298   -27760.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=355530.0
    phase     gas;
}
