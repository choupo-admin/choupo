/*--------------------------------*- Choupo -*-----------------------*\
  Component: bullvalone  (C10H10O, CAS 15719-09-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        bullvalone;
formula     C10H10O;
CAS         15719-09-2;
InChIKey    LGIUJDXRMYAWEG-UHFFFAOYSA-N;
MW          146.189;      // g/mol [origin=calculated method=formula-sum]
Tc          750.45;      // K   [origin=predictive method=joback]
Pc          35.054;      // bar [origin=predictive method=joback]
omega       0.4318;      // -   [origin=predictive method=lee-kesler]
Tb          514.36;      // K   [origin=predictive method=joback]
HvapTb      42287.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-104.12 1.0901 -0.00080956 2.43e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 4; } { group CH=CH; count 2; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 4; } { group dCH_ring; count 4; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[3.3.2.02,8]deca-6,9-dien-3-one(8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -79970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     98.76;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133090.0
}
