/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,3-dimethyl-2-methylenebicyclo[  (C11H16O2, CAS 10309-20-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Dimethyl2Methylenebicyclo;
formula     C11H16O2;
CAS         10309-20-3;
InChIKey    JBNCRMFOHKBEFO-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          837.92;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       0.6988;      // -   [origin=predictive method=lee-kesler]
Tb          609.51;      // K   [origin=predictive method=joback]
HvapTb      54790.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-179.87 1.83164 -0.0019586 8.551e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group CH2=C; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 2; } { group dC_ring; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethyl-3-methylidene-bicyclo[2.2.1]heptane-4-carboxylic acid" "3,3-dimethyl-2-methylene-bicyclo[2.2.1]heptane-1-carboxylic acid" "2-methylene-3,3-dimethylbicyclo(2.2.1)heptane-1-carboxylic acid" "2-methylene-3,3-dimethylbicyclo[2.2.1]heptane-1-carboxylic acid" "3,3-dimethyl-2-methylenebicyclo[2.2.1]heptanecarboxylic acid" "3,3-dimethyl-2-methylene-bicyclo[" "3,3-dimethyl-2-methylene-bicyclo[2.2.1]heptane-1-c" "2,2-dimethyl-3-methylidenebicyclo[2.2.1]heptane-4-carboxylic acid" "3,3-dimethyl-2-methylenebicyclo[2.2.1]heptane-1-carboxylic acid" "3,3-dimethyl-2-methylidenebicyclo[2.2.1]heptane-1-carboxylic acid" "bicyclo[2.2.1]heptane-1-carboxylicacid, 3,3-dimethyl-2-methylene-" );
gibbsFormation
{
    dHf_298   -386820.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     547.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-158380.0
    phase     gas;
}
