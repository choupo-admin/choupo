/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-(2-chloro-6-propylphenoxy)propane-1,2-diol  (C12H17ClO3, CAS 63834-71-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        32Chloro6PropylphenoxyPropane12Diol;
formula     C12H17ClO3;
CAS         63834-71-9;
InChIKey    WBEXQMNCOCWOMJ-UHFFFAOYSA-N;
MW          244.715;      // g/mol [origin=calculated method=formula-sum]
Tc          944.38;      // K   [origin=predictive method=joback]
Pc          26.819;      // bar [origin=predictive method=joback]
omega       1.5304;      // -   [origin=predictive method=lee-kesler]
Tb          754.57;      // K   [origin=predictive method=joback]
HvapTb      85671.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.964 0.96342 -0.00049952 8.06e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group OH; count 1; } { group ACCl; count 1; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 1; } { group OH; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-chloranyl-6-propyl-phenoxy)propane-1,2-diol" "3-(2-chloro-6-propylphenoxy)-1,2-propanediol" "1,2-propanediol, 3-(2-chloro-6-propylphenoxy)-" );
standardThermochemistry
{
    dHf_298   -535120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     641.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-249700.0
}
