/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dimethyl-2-oxo-2h-pyran-5-carboxylic acid  (C8H8O4, CAS 480-65-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dimethyl2Oxo2hPyran5CarboxylicAcid;
formula     C8H8O4;
CAS         480-65-9;
InChIKey    QOADIMYPCZMZSG-UHFFFAOYSA-N;
MW          168.148;      // g/mol [origin=calculated method=formula-sum]
Tc          830.79;      // K   [origin=predictive method=joback]
Pc          35.558;      // bar [origin=predictive method=joback]
omega       0.9206;      // -   [origin=predictive method=lee-kesler]
Tb          615.31;      // K   [origin=predictive method=joback]
HvapTb      60937.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.78 0.63714 -0.00039204 8.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group COOH; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 3; } { group COOH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4-dimethyl-6-oxidanylidene-pyran-3-carboxylic acid" "isodehydroacetic acid" "2h-pyran-5-carboxylic acid, 4,6-dimethyl-2-oxo-" "2,4-dimethyl-6-oxopyran-3-carboxylic acid" "4,6-dimethyl-2-oxopyran-5-carboxylic acid" "2h-pyran-5-carboxylic acid,6-dimethyl-2-oxo-" "isodehydracetic acid" "4,6-dimethyl-5-formylpyran-2-one" "5-carboxy-4,6-dimethyl-2-pyrone" "2,4-dimethyl-6-oxo-6h-pyran-3-carboxylic acid" "2h-pyran-5-carboxylicacid, 4,6-dimethyl-2-oxo-" );
gibbsFormation
{
    dHf_298   -707870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-550410.0
    phase     gas;
}
