/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2-phenylethyl)aniline  (C14H15N, CAS 13024-49-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        42PhenylethylAniline;
formula     C14H15N;
CAS         13024-49-2;
InChIKey    ZRPMISJEZSOSQC-UHFFFAOYSA-N;
MW          197.281;      // g/mol [origin=calculated method=formula-sum]
Tc          898.17;      // K   [origin=predictive method=joback]
Pc          28.967;      // bar [origin=predictive method=joback]
omega       0.6544;      // -   [origin=predictive method=lee-kesler]
Tb          650.79;      // K   [origin=predictive method=joback]
HvapTb      62613.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.858 1.1784 -0.00077656 1.925e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 9; } { group ACCH2; count 2; } { group ACNH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "p-phenethylaniline" "benzenamine, 4-(2-phenylethyl)-" "aniline, p-phenethyl-" "4-aminodibenzyl" "4-phenethylaniline" "4-(2-phenylethyl)benzenamine" "aniline, p-phenethyl- (6ci,7ci,8ci)" "[4-(2-phenylethyl)phenyl]amine hydrochloride" "benzenamine,4-(2-phenylethyl)-" );
gibbsFormation
{
    dHf_298   163090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     533.92;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=348640.0
    phase     gas;
}
