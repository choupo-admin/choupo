/*--------------------------------*- Choupo -*-----------------------*\
  Component: triisopentylamine  (C15H33N, CAS 645-41-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        triisopentylamine;
formula     C15H33N;
CAS         645-41-0;
InChIKey    QKVUSSUOYHTOFQ-UHFFFAOYSA-N;
MW          227.436;      // g/mol [origin=calculated method=formula-sum]
Tc          720.21;      // K   [origin=predictive method=joback]
Pc          14.392;      // bar [origin=predictive method=joback]
omega       0.6766;      // -   [origin=predictive method=lee-kesler]
Tb          553.92;      // K   [origin=predictive method=joback]
HvapTb      49863.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.484 1.57052 -0.0009144 2.032e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 5; } { group CH; count 3; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 6; } { group CH; count 3; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyl-n,n-bis(3-methylbutyl)butan-1-amine" "triisoamylamine" "1-butanamine, 3-methyl-n,n-bis(3-methylbutyl)-" "3-methyl-n,n-bis(3-methylbutyl)butan-1-amin" "tris(3-methylbutyl)amine" );
standardThermochemistry
{
    dHf_298   -301240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     727.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=178880.0
}
