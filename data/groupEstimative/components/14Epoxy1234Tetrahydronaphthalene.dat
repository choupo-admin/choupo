/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-epoxy-1,2,3,4-tetrahydronaphthalene  (C10H10O, CAS 35185-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Epoxy1234Tetrahydronaphthalene;
formula     C10H10O;
CAS         35185-96-7;
InChIKey    SPELXJYTVLDKGB-UHFFFAOYSA-N;
MW          146.189;      // g/mol [origin=calculated method=formula-sum]
Tc          727.39;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       0.4349;      // -   [origin=predictive method=lee-kesler]
Tb          496.22;      // K   [origin=predictive method=joback]
HvapTb      44956.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.85 1.1238 -0.00095726 3.282e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-epoxynaphthalene, 1,2,3,4-tetrahydro-" "1,2,3,4-tetrahydro-1,4-epoxynaphthalene" "1,4-epoxynaphthalene,1,2,3,4-tetrahydro-" "11-oxatricyclo[6.2.1.0^{2,7}]undeca-2,4,6-triene" "11-oxatricyclo[6.2.1.0<2,7>]undeca-2(7),3,5-triene" "1,2,3,4-tetrahydronaphthalene1,4-endoxide;1,2,3,4-tetrahydronaphthalene-1,4-endo-oxide;1,4-epoxy-1,2,3,4-tetrahydronaphthalene;" );
gibbsFormation
{
    dHf_298   -4910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     181.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=183580.0
    phase     gas;
}
