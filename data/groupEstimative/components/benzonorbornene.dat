/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzonorbornene  (C11H12, CAS 4486-29-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzonorbornene;
formula     C11H12;
CAS         4486-29-7;
InChIKey    ILMCRZOMKCLIFZ-UHFFFAOYSA-N;
MW          144.217;      // g/mol [origin=calculated method=formula-sum]
Tc          721.27;      // K   [origin=predictive method=joback]
Pc          33.684;      // bar [origin=predictive method=joback]
omega       0.3952;      // -   [origin=predictive method=lee-kesler]
Tb          492.15;      // K   [origin=predictive method=joback]
HvapTb      42672.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-122.08 1.2218 -0.00102556 3.488e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group ACH; count 4; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 3; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-methanonaphthalene, 1,2,3,4-tetrahydro-" "1,2,3,4-tetrahydro-1,4-methanonaphthalene" );
gibbsFormation
{
    dHf_298   106450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     271.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278120.0
    phase     gas;
}
