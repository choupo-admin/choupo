/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,5-dichlorobenzotrifluoride  (C7H3Cl2F3, CAS 320-50-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        25Dichlorobenzotrifluoride;
formula     C7H3Cl2F3;
CAS         320-50-3;
InChIKey    DYBYUWVMLBBEMA-UHFFFAOYSA-N;
MW          214.995;      // g/mol [origin=calculated method=formula-sum]
Tc          673.68;      // K   [origin=predictive method=joback]
Pc          31.597;      // bar [origin=predictive method=joback]
omega       0.4321;      // -   [origin=predictive method=lee-kesler]
Tb          465.84;      // K   [origin=predictive method=joback]
HvapTb      39799.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.8 0.6457 -0.00051592 1.545e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 2; } { group CF3; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group C; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group F; count 3; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,4-bis(chloranyl)-2-(trifluoromethyl)benzene" "1,4-dichloro-2-(trifluoromethyl)benzene" "benzene, 1,4-dichloro-2-(trifluoromethyl)-" "2,5-dichloro-alpha,alpha,alpha-trifluorotoluene" "2,5-dichloro-a,a,a-trifluorotoluene" "toluene, 2,5-dichloro-alpha,alpha,alpha-trifluoro- (6ci,7ci,8ci)" "2,5-dichlorotrifluorotoluene" "1,4-dichloro-3-(trifluoromethyl)benzene" "1,4-dichloro-2-(trifluoromethyl)-benzen;2,5-dichloro-alpha,alpha,alpha-trifluoro-toluen" );
standardThermochemistry
{
    dHf_298   -602780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     432.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-504240.0
}
