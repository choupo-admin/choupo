/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-fluorophenyl)ethanamine  (C8H10FN, CAS 403-40-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14FluorophenylEthanamine;
formula     C8H10FN;
CAS         403-40-7;
InChIKey    QGCLEUGNYRXBMZ-UHFFFAOYSA-N;
MW          139.173;      // g/mol [origin=calculated method=formula-sum]
Tc          703.20;      // K   [origin=predictive method=joback]
Pc          36.731;      // bar [origin=predictive method=joback]
omega       0.4882;      // -   [origin=predictive method=lee-kesler]
Tb          485.66;      // K   [origin=predictive method=joback]
HvapTb      45776.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-13.09 0.70502 -0.00043856 1.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group CHNH2; count 1; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group F; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-fluoro-alpha-methylbenzylamine" "1-(4-fluorophenyl)ethylamine" "1-(4-fluorphenyl)ethanamin" "1-(4'-fluorophenyl)ethanamine" "4-fluoro-a-methylbenzylamine" "1-(p-fluorophenyl)-ethylamine" "dl-4-fluoro-alpha-methylbenzylamine" "p-fluoro-a-methylbenzylamine" "1-(4-fluorophenyl)ethan-1-amine" "(rs)-1-(4-fluorophenyl)ethylamine" "(+/-)-1-(4-fluorophenyl)ethylamine" "(1r)-(+)-1-(4-fluorophenyl)ethylamine" );
gibbsFormation
{
    dHf_298   -150990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     428.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-11540.0
    phase     gas;
}
