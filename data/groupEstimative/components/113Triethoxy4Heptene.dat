/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1,3-triethoxy-4-heptene  (C13H26O3, CAS 72152-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        113Triethoxy4Heptene;
formula     C13H26O3;
CAS         72152-79-5;
InChIKey    YMPURWKRLGBYLD-UHFFFAOYSA-N;
MW          230.348;      // g/mol [origin=calculated method=formula-sum]
Tc          739.75;      // K   [origin=predictive method=joback]
Pc          16.673;      // bar [origin=predictive method=joback]
omega       0.7537;      // -   [origin=predictive method=lee-kesler]
Tb          567.58;      // K   [origin=predictive method=joback]
HvapTb      50944.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (50.025 1.08108 -0.0004406 2.55e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH2O; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 5; } { group CH; count 2; } { group dCH; count 2; } { group O; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5,7,7-triethoxyhept-3-ene" "3-heptene, 5,7,7-triethoxy-" "5,7,7-triethoxy-3-heptene" );
standardThermochemistry
{
    dHf_298   -601650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     670.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-181080.0
}
