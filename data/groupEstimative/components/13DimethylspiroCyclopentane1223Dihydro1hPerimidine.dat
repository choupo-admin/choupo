/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1',3'-dimethylspiro[cyclopentane-1,2'-(2,3-dihydro-[1h]-perimidine)]  (C17H20N2, CAS 99643-50-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13DimethylspiroCyclopentane1223Dihydro1hPerimidine;
formula     C17H20N2;
CAS         99643-50-2;
InChIKey    ZIPKUUJFHNWWQX-UHFFFAOYSA-N;
MW          252.361;      // g/mol [origin=calculated method=formula-sum]
Tc          918.30;      // K   [origin=predictive method=joback]
Pc          25.125;      // bar [origin=predictive method=joback]
omega       0.7618;      // -   [origin=predictive method=lee-kesler]
Tb          683.18;      // K   [origin=predictive method=joback]
HvapTb      61574.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-221.99 2.29484 -0.00223484 8.774e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group C; count 1; } { group ACH; count 6; } { group AC; count 4; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 4; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1',3'-dimethylspiro[cyclopentane-1,2'-perimidine]" "1',3'-dimethylspiro(cyclopentane-1,2'-(2,3-dihydro-(1h)-perimidine))" "1',3'-dimethyl-1'h,3'h-spiro[cyclopentane-1,2'-perimidine]" );
standardThermochemistry
{
    dHf_298   332850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.13;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=649440.0
}
