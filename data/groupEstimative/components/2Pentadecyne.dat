/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-pentadecyne  (C15H28, CAS 52112-25-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Pentadecyne;
formula     C15H28;
CAS         52112-25-1;
InChIKey    VWWAVTXUUYIIEE-UHFFFAOYSA-N;
MW          208.389;      // g/mol [origin=calculated method=formula-sum]
Tc          727.92;      // K   [origin=predictive method=joback]
Pc          16.026;      // bar [origin=predictive method=joback]
omega       0.6356;      // -   [origin=predictive method=lee-kesler]
Tb          551.80;      // K   [origin=predictive method=joback]
HvapTb      51136.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.811 1.27904 -0.00070006 1.4628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 11; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 11; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "pentadec-2-yne" );
gibbsFormation
{
    dHf_298   -80630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     712.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=278220.0
    phase     gas;
}
