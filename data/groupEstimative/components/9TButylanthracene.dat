/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-t-butylanthracene  (C18H18, CAS 13719-97-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9TButylanthracene;
formula     C18H18;
CAS         13719-97-6;
InChIKey    GWJJSVKKSBCHJD-UHFFFAOYSA-N;
MW          234.342;      // g/mol [origin=calculated method=formula-sum]
Tc          930.58;      // K   [origin=predictive method=joback]
Pc          21.918;      // bar [origin=predictive method=joback]
omega       0.5917;      // -   [origin=predictive method=lee-kesler]
Tb          682.81;      // K   [origin=predictive method=joback]
HvapTb      61246.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-106.14 1.63436 -0.00129776 4.128e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 9; } { group AC; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group C; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-tert-butylanthracene" "anthracene,9-(1,1-dimethylethyl)-" "anthracene, 9-(1,1-dimethylethyl)-" );
gibbsFormation
{
    dHf_298   172130.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     481.72;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=409970.0
    phase     gas;
}
