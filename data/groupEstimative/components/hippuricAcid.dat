/*--------------------------------*- Choupo -*-----------------------*\
  Component: hippuric acid  (C9H9NO3, CAS 495-69-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hippuricAcid;
formula     C9H9NO3;
CAS         495-69-2;
InChIKey    QIAFMBKCNZACKA-UHFFFAOYSA-N;
MW          179.175;      // g/mol [origin=calculated method=formula-sum]
Tc          911.04;      // K   [origin=predictive method=joback]
Pc          39.755;      // bar [origin=predictive method=joback]
omega       1.0716;      // -   [origin=predictive method=lee-kesler]
Tb          681.75;      // K   [origin=predictive method=joback]
HvapTb      68250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-28.449 0.8789 -0.0005995 1.5086e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group COOH; count 1; } { group CONHCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-benzamidoethanoic acid" "n-benzoylglycine" "benzoylglycine" "glycine, n-benzoyl-" "2-benzamidoacetic acid" "benzamidoacetic acid" "hippursaeure" "phenylcarbonylaminoacetic acid" "benzamidoessigsaeure" "(benzoylamino)acetic acid" "hippurate" "benzoylaminoessigsaeure" );
gibbsFormation
{
    dHf_298   -401940.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246130.0
    phase     gas;
}
