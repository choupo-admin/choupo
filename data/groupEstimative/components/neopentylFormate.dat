/*--------------------------------*- Choupo -*-----------------------*\
  Component: neopentyl formate  (C6H12O2, CAS 23361-67-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C6H12O2 (delta C+1H+1O+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        neopentylFormate;
formula     C6H12O2;
CAS         23361-67-3;
InChIKey    DGMIPKNXUDSQGI-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          480.79;      // K   [origin=predictive method=joback]
Pc          32.173;      // bar [origin=predictive method=joback]
omega       0.1626;      // -   [origin=predictive method=lee-kesler]
Tb          310.07;      // K   [origin=predictive method=joback]
HvapTb      25281.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-46.539 0.70776 -0.0006274 2.288e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } { group HCOO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group C; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2-dimethylpropyl methanoate" "2,2-dimethylpropyl formate" "neopentyl methanoate" "1-propanol,2-dimethyl-, formate" "1-propanol,2,2-dimethyl-, 1-formate" );
standardThermochemistry
{
    dHf_298   -99470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     534.28;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=46440.0
}
