/*--------------------------------*- Choupo -*-----------------------*\
  Component: pentanoic acid, 4-formylphenyl ester  (C12H14O3, CAS 50262-50-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C12H14O3 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        pentanoicAcid4FormylphenylEster;
formula     C12H14O3;
CAS         50262-50-5;
InChIKey    YQTQMRFNTGBMQC-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          206.241;      // g/mol [origin=calculated method=formula-sum]
Tc          744.97;      // K   [origin=predictive method=joback]
Pc          24.875;      // bar [origin=predictive method=joback]
omega       0.5858;      // -   [origin=predictive method=lee-kesler]
Tb          540.46;      // K   [origin=predictive method=joback]
HvapTb      50278.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.717 0.95872 -0.00065156 1.718e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CHO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4-methanoylphenyl) pentanoate" "(4-formylphenyl) pentanoate" "(4-formylphenyl)pentanoate" "pentanoic acid 4-formylphenyl ester" );
standardThermochemistry
{
    dHf_298   -306780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     642.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-113470.0
}
