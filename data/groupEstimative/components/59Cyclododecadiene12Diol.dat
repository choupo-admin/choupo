/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5,9-cyclododecadiene-1,2-diol  (C12H20O2, CAS 15786-26-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        59Cyclododecadiene12Diol;
formula     C12H20O2;
CAS         15786-26-2;
InChIKey    BHYILZSOXKSYCF-UHFFFAOYSA-N;
MW          196.29;      // g/mol [origin=calculated method=formula-sum]
Tc          906.02;      // K   [origin=predictive method=joback]
Pc          31.140;      // bar [origin=predictive method=joback]
omega       1.1926;      // -   [origin=predictive method=lee-kesler]
Tb          697.34;      // K   [origin=predictive method=joback]
HvapTb      77400.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-72.27 1.1378 -0.00041156 -3.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH; count 2; } { group CH=CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group CH_ring; count 2; } { group dCH_ring; count 4; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclododeca-5,9-diene-1,2-diol" "(5z,9z)-cyclododeca-5,9-diene-1,2-diol" );
gibbsFormation
{
    dHf_298   -482890.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     697.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-219420.0
    phase     gas;
}
