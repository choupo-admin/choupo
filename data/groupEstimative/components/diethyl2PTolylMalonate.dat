/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethyl 2-(p-tolyl)malonate  (C14H18O4, CAS 29148-27-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyl2PTolylMalonate;
formula     C14H18O4;
CAS         29148-27-4;
InChIKey    WGBSHZUHSDGHLV-UHFFFAOYSA-N;
MW          250.294;      // g/mol [origin=calculated method=formula-sum]
Tc          873.06;      // K   [origin=predictive method=joback]
Pc          20.145;      // bar [origin=predictive method=joback]
omega       0.8473;      // -   [origin=predictive method=lee-kesler]
Tb          667.58;      // K   [origin=predictive method=joback]
HvapTb      64122.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (19.692 1.09176 -0.00051596 4.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 4; } { group ACCH3; count 1; } { group ACCH; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "diethyl 2-(4-methylphenyl)propanedioate" "diethyl 2-(4-methylphenyl)malonate" "diethyl 2-(4-methylphenyl)propane-1,3-dioate" "diethyl (4-methylphenyl)malonate" "1,3-diethyl 2-(4-methylphenyl)propanedioate" );
gibbsFormation
{
    dHf_298   -747070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     681.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-453400.0
    phase     gas;
}
