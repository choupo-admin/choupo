/*--------------------------------*- Choupo -*-----------------------*\
  Component: non-3-en-1-ol  (C9H18O, CAS 10340-23-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        non3En1Ol;
formula     C9H18O;
CAS         10340-23-5;
InChIKey    IFTBJDZSLBRRMC-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          667.61;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.8764;      // -   [origin=predictive method=lee-kesler]
Tb          501.86;      // K   [origin=predictive method=joback]
HvapTb      52265.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.184 0.91282 -0.00058 1.531e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH=CH; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group dCH; count 2; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-nonen-1-ol, (3z)-" "3-nonen-1-ol, (3e)-" );
standardThermochemistry
{
    dHf_298   -264100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     550.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31700.0
}
