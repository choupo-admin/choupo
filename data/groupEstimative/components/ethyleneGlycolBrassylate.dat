/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethylene glycol brassylate  (C15H30O6, CAS 28964-24-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyleneGlycolBrassylate;
formula     C15H30O6;
CAS         28964-24-1;
InChIKey    OYSADVQSKKIDTF-UHFFFAOYSA-N;
MW          306.399;      // g/mol [origin=calculated method=formula-sum]
Tc          1255.70;      // K   [origin=predictive method=joback]
Pc          17.595;      // bar [origin=predictive method=joback]
omega       1.3979;      // -   [origin=predictive method=lee-kesler]
Tb          1019.58;      // K   [origin=predictive method=joback]
HvapTb      116964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (49.853 1.3922 -0.0005834 2.57e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 11; } { group COOH; count 2; } { group _CH2OH_2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 13; } { group OH; count 2; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethane-1,2-diol;tridecanedioic acid" );
standardThermochemistry
{
    dHf_298   -1469550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1055.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-990800.0
}
