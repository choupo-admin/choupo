/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclopenten-1-one, 2-hydroxy-3,4-dimethyl-  (C7H10O2, CAS 21835-00-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclopenten1One2Hydroxy34Dimethyl;
formula     C7H10O2;
CAS         21835-00-7;
InChIKey    GXUQPCUHTNAVRJ-UHFFFAOYSA-N;
MW          126.155;      // g/mol [origin=calculated method=formula-sum]
Tc          749.32;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.8350;      // -   [origin=predictive method=lee-kesler]
Tb          544.16;      // K   [origin=predictive method=joback]
HvapTb      53975.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (14.14 0.49124 -0.000124 -3.72e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group dC_ring; count 2; } { group OH; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4-dimethyl-2-oxidanyl-cyclopent-2-en-1-one" "3,4-dimethyl-2-hydroxycyclopent-2-en-1-one" "2-hydroxy-3,4-dimethylcyclopent-2-en-1-one" "2-hydroxy-3,4-dimethyl-2-cyclopenten-1-one" "2-cyclopenten-1-one,2-hydroxy-3,4-dimethyl-" );
gibbsFormation
{
    dHf_298   -382420.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     300.63;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-204100.0
    phase     gas;
}
