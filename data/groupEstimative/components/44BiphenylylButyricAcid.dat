/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(4-biphenylyl)butyric acid  (C16H16O2, CAS 6057-60-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44BiphenylylButyricAcid;
formula     C16H16O2;
CAS         6057-60-9;
InChIKey    XSFAQQLHYUBFKV-UHFFFAOYSA-N;
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          1007.36;      // K   [origin=predictive method=joback]
Pc          24.556;      // bar [origin=predictive method=joback]
omega       0.9654;      // -   [origin=predictive method=lee-kesler]
Tb          769.53;      // K   [origin=predictive method=joback]
HvapTb      73588.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-60.567 1.3573 -0.00091456 2.333e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 9; } { group AC; count 2; } { group ACCH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(4-phenylphenyl)butanoic acid" "4-biphenyl-4-yl-butyric acid" "4-biphenylbutyric acid" "[1,1'-biphenyl]-4-butanoicacid" "4-biphenylbutyricacid (8ci);butyric acid, 4-(4-biphenylyl)- (6ci);butyric acid, g-4-biphenylyl- (4ci);4-(4-phenylphenyl)butyric acid;4-p-biphenylylbutanoic acid;g-(4-biphenylyl)butyric acid;g-(4-diphenylyl)butyric acid;g-(p-xenyl)butyric acid;" );
standardThermochemistry
{
    dHf_298   -262250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     613.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-44880.0
}
