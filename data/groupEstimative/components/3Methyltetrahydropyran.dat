/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyltetrahydropyran  (C6H12O, CAS 26093-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyltetrahydropyran;
formula     C6H12O;
CAS         26093-63-0;
InChIKey    UJQZTMFRMLEYQN-UHFFFAOYSA-N;
MW          100.161;      // g/mol [origin=calculated method=formula-sum]
Tc          588.33;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.2620;      // -   [origin=predictive method=lee-kesler]
Tb          383.38;      // K   [origin=predictive method=joback]
HvapTb      33889.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.85 0.69292 -0.0003697 6.11e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methyloxane" "2h-pyran, tetrahydro-3-methyl-" "tetrahydro-3-methyl-2h-pyran" "2h-pyran,tetrahydro-3-methyl-" "pyran,tetrahydro-3-methyl- (7ci);3-methyloxane;3-methyltetrahydropyran;tetrahydro-3-methylpyran;" );
standardThermochemistry
{
    dHf_298   -244850.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     307.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-62030.0
}
