/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-deoxy-d-ribose  (C5H10O4, CAS 533-67-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2DeoxyDRibose;
formula     C5H10O4;
CAS         533-67-5;
InChIKey    ASJSAQIRZKANQN-UHFFFAOYSA-N;
MW          134.131;      // g/mol [origin=calculated method=formula-sum]
Tc          804.14;      // K   [origin=predictive method=joback]
Pc          56.363;      // bar [origin=predictive method=joback]
omega       2.0186;      // -   [origin=predictive method=lee-kesler]
Tb          638.32;      // K   [origin=predictive method=joback]
HvapTb      82705.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (22.252 0.5671 -0.0003388 7.46e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group OH; count 3; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 2; } { group OH; count 3; } { group OdCH_al; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,5-tris(oxidanyl)pentanal" "d-erythro-pentose, 2-deoxy-" "2-deoxyribose" "d-ribose, 2-deoxy-" "deoxyribose" "d -erythro -2-deoxypentose" "d-2-deoxyribose" "2-deoxypentose" "2'-deoxyribose" "ribose, 2-deoxy-" "3,4,5-trihydroxypentanal" );
gibbsFormation
{
    dHf_298   -699360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     503.01;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-523640.0
    phase     gas;
}
