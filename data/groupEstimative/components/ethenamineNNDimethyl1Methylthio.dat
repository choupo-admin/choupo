/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethenamine, n,n-dimethyl-1-(methylthio)-  (C5H11NS, CAS 24854-14-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethenamineNNDimethyl1Methylthio;
formula     C5H11NS;
CAS         24854-14-6;
InChIKey    NNYJQHRRSIBJJA-UHFFFAOYSA-N;
MW          117.21;      // g/mol [origin=calculated method=formula-sum]
Tc          588.30;      // K   [origin=predictive method=joback]
Pc          37.362;      // bar [origin=predictive method=joback]
omega       0.3293;      // -   [origin=predictive method=lee-kesler]
Tb          391.78;      // K   [origin=predictive method=joback]
HvapTb      34994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.57 0.57705 -0.0003458 7.73e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=C; count 1; } { group CH3N; count 1; } { group CH3S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dC; count 1; } { group N; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-1-methylsulfanyl-ethenamine" "n,n-dimethyl-1-methylsulfanylethenamine" );
standardThermochemistry
{
    dHf_298   78510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     419.48;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=214410.0
}
