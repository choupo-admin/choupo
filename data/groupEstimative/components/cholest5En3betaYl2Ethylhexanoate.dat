/*--------------------------------*- Choupo -*-----------------------*\
  Component: cholest-5-en-3beta-yl 2-ethylhexanoate  (C35H60O2, CAS 41329-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cholest5En3betaYl2Ethylhexanoate;
formula     C35H60O2;
CAS         41329-01-5;
InChIKey    MOWZDRPKXFFKDM-MTYNKIQNSA-N;
MW          512.863;      // g/mol [origin=calculated method=formula-sum]
Tc          1342.60;      // K   [origin=predictive method=joback]
Pc          6.602;      // bar [origin=predictive method=joback]
omega       0.5868;      // -   [origin=predictive method=lee-kesler]
Tb          1096.22;      // K   [origin=predictive method=joback]
HvapTb      97984.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-295.223 4.23624 -0.00326324 1.0851e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 15; } { group CH; count 8; } { group C; count 2; } { group CH=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 7; } { group CH; count 3; } { group CH2_ring; count 8; } { group CH_ring; count 5; } { group C_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,8s,9s,10r,13r,14s,17r)-10,13-dimethyl-17-[(2r)-6-methylheptan-2-yl]-2,3,4,7,8,9,11,12,14,15,16,17-dodecahydro-1h-cyclopenta[a]phenanthren-3-yl] 2-ethylhexanoate" "cholest-5-en-3-ol (3beta)-, 2-ethylhexanoate" "cholest-5-en-3-ol (3beta)-, 3-(2-ethylhexanoate)" );
gibbsFormation
{
    dHf_298   -822680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1249.03;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=94850.0
    phase     gas;
}
