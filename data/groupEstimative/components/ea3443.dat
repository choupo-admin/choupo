name        ea3443;
formula     C19H27NO3;
CAS         37830-21-0;
InChIKey    DZFJGXMHIMAYMW-UHFFFAOYSA-N;
MW          317.429;      // g/mol [origin=calculated method=formula-sum]
Tc          1077.06;      // K   [origin=predictive method=joback]
Pc          19.983;      // bar [origin=predictive method=joback]
omega       1.1643;      // -   [origin=predictive method=lee-kesler]
Tb          851.17;      // K   [origin=predictive method=joback]
HvapTb      85511.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-173.72 2.22222 -0.001516 3.814e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 8; } { group CH; count 2; } { group C; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } { group CH3N; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group CH2_ring; count 8; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } { group COO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1-methylpiperidin-4-yl) 2-cyclopentyl-2-oxidanyl-2-phenyl-ethanoate" "n-methyl-4-piperidyl cyclopentylphenylglycolate" "mandelic acid, .alpha.-cyclopentyl-, 1-methyl-4-piperidyl ester" "mandelic acid, alpha-cyclopentyl-, 1-methyl-4-piperidyl ester" "benzeneacetic acid, .alpha.-cyclopentyl-.alpha.-hydroxy-, 1-methyl-4-piperidinyl ester" "1-methylpiperidin-4-yl cyclopentyl(hydroxy)phenylacetate" "(1-methyl-4-piperidyl) 2-cyclopentyl-2-hydroxy-2-phenyl-acetate" "(1-methylpiperidin-4-yl) 2-cyclopentyl-2-hydroxy-2-phenylacetate" "benzeneacetic acid, alpha-cyclopentyl-alpha-hydroxy-, 1-methyl-4-piperidinyl ester" "benzeneacetic acid, alpha-cyclopentyl-alpha-hydroxy-, 1-methyl-4-piperidinyl ester (9ci)" );
standardThermochemistry
{
    dHf_298   -488730.0;      // J/mol ideal-gas [origin=predictive method=joback]
