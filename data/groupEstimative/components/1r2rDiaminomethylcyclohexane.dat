/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1r,2r)-diaminomethylcyclohexane  (C8H18N2, CAS 68737-65-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1r2rDiaminomethylcyclohexane;
formula     C8H18N2;
CAS         68737-65-5;
InChIKey    JRHPOFJADXHYBR-HTQZYQBOSA-N;
MW          142.246;      // g/mol [origin=calculated method=formula-sum]
Tc          703.88;      // K   [origin=predictive method=joback]
Pc          31.280;      // bar [origin=predictive method=joback]
omega       0.5459;      // -   [origin=predictive method=lee-kesler]
Tb          497.86;      // K   [origin=predictive method=joback]
HvapTb      46394.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-66.47 1.01184 -0.0005342 8.64e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH3NH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group NH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2r)-n1,n2-dimethylcyclohexane-1,2-diamine" "(1r,2r)-(-)-n,n'-dimethylcyclohexane-1,2-diamine" "trans-1,2-bis(methylamino)cyclohexane" "(1r,2r)-n,n'-dimethyl-1,2-cyclohexanediamine" "(r,r)-(-)-n,n'-dimethyl-1,2-cyclohexanediamine" "trans-(1r,2r)-n,n'-bismethyl-1,2-cyclohexanediamine" "trans-(1r,2r)-n,n'-bismethyl-1,2-cyclohexane diamine" "trans-n,n'-dimethylcyclohexane-1,2-diamine" "(1r,2r)-(-)-1,2-bis(methylamino)cyclohexane" "(1r,2r)-1-n,2-n-dimethylcyclohexane-1,2-diamine" "(r,r)-n,n'-dimethylcyclohexan-1,2-diamine" "trans-n,n'-dimethyl-1,2-cyclohexanediamine" );
standardThermochemistry
{
    dHf_298   -67530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=212000.0
}
