/*--------------------------------*- Choupo -*-----------------------*\
  Component: hexaphenylcyclotrisiloxane  (C36H30O3Si3, CAS 512-63-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C36H30O3Si3 (delta Si+3; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        hexaphenylcyclotrisiloxane;
formula     C36H30O3Si3;
CAS         512-63-0;
InChIKey    VCYDUTCMKSROID-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          594.888;      // g/mol [origin=calculated method=formula-sum]
Tc          1595.60;      // K   [origin=predictive method=joback]
Pc          11.793;      // bar [origin=predictive method=joback]
omega       0.9103;      // -   [origin=predictive method=lee-kesler]
Tb          1279.82;      // K   [origin=predictive method=joback]
HvapTb      124020.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.03 2.5002 -0.0011113 2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 30; } { group AC; count 6; } { group SiO; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 30; } { group dC_ring; count 6; } { group O_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,4,4,6,6-hexakis-phenyl-1,3,5,2,4,6-trioxatrisilinane" "cyclotrisiloxane, hexaphenyl-" "diphenylsiloxane cyclic trimer" "cyclotrisiloxane, 2,2,4,4,6,6-hexaphenyl-" "o671" "cyclotrisiloxane,2,2,4,4,6,6-hexaphenyl-" "2,2,4,4,6,6-hexaphenyl-1,3,5,2,4,6-trioxatrisilinane" );
gibbsFormation
{
    dHf_298   -4910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1097.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=422520.0
    phase     gas;
}
