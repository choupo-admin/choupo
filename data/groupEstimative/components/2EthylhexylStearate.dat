/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethylhexyl stearate  (C26H52O2, CAS 22047-49-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthylhexylStearate;
formula     C26H52O2;
CAS         22047-49-0;
InChIKey    OPJWPPVYCOPDCM-UHFFFAOYSA-N;
MW          396.7;      // g/mol [origin=calculated method=formula-sum]
Tc          1043.98;      // K   [origin=predictive method=joback]
Pc          7.301;      // bar [origin=predictive method=joback]
omega       0.6765;      // -   [origin=predictive method=lee-kesler]
Tb          852.26;      // K   [origin=predictive method=joback]
HvapTb      80489.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (2.981 2.42496 -0.0012992 2.406e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 20; } { group CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 21; } { group CH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethylhexyl octadecanoate" "octadecanoic acid, 2-ethylhexyl ester" "ethylhexyl stearate" "agn-pc-00l26c" );
gibbsFormation
{
    dHf_298   -902530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1210.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-144770.0
    phase     gas;
}
