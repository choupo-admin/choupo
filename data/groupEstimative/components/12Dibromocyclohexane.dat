/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2-dibromocyclohexane  (C6H10Br2, CAS 5401-62-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        12Dibromocyclohexane;
formula     C6H10Br2;
CAS         5401-62-7;
InChIKey    CZNHKZKWKJNOTE-UHFFFAOYSA-N;
MW          241.954;      // g/mol [origin=calculated method=formula-sum]
Tc          729.55;      // K   [origin=predictive method=joback]
Pc          45.408;      // bar [origin=predictive method=joback]
omega       0.3837;      // -   [origin=predictive method=lee-kesler]
Tb          484.08;      // K   [origin=predictive method=joback]
HvapTb      41940.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-45.85 0.7458 -0.000471 1.098e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group Br; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group Br; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(bromanyl)cyclohexane" "cyclohexane, 1,2-dibromo-" "(+/-)-trans-1,2-dibromocyclohexane" "cyclohexane,2-dibromo-" "1,2-dibromo-cyclohexane" "agn-pc-02zqpl" "cyclohexane, 1,2-dibromo-, cis-" );
gibbsFormation
{
    dHf_298   -80530.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     418.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=45020.0
    phase     gas;
}
