/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-disila-s-indacene,1,2,3,5,6,7-hexahydro-2,2,6,6-tetramethyl-  (C14H22Si2, CAS 69020-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H22Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        26DisilaSIndacene123567Hexahydro2266Tetramethyl;
formula     C14H22Si2;
CAS         69020-20-8;
InChIKey    YLGDQINZVIURRM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          246.5;      // g/mol [origin=calculated method=formula-sum]
Tc          804.59;      // K   [origin=predictive method=joback]
Pc          19.930;      // bar [origin=predictive method=joback]
omega       0.4257;      // -   [origin=predictive method=lee-kesler]
Tb          578.62;      // K   [origin=predictive method=joback]
HvapTb      51708.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.33 1.03808 -0.00038228 -1.34e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group ACH; count 2; } { group ACCH2; count 4; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2_ring; count 4; } { group dCH_ring; count 2; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,6,6-tetramethyl-1,3,5,7-tetrahydrosilolo[3,4-f][2]benzosilole" );
standardThermochemistry
{
    dHf_298   -154810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     693.71;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=102120.0
}
