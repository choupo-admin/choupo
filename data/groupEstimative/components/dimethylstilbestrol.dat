/*--------------------------------*- Choupo -*-----------------------*\
  Component: dimethylstilbestrol  (C16H16O2, CAS 552-80-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dimethylstilbestrol;
formula     C16H16O2;
CAS         552-80-7;
InChIKey    XPINIPXARSNZDM-VAWYXSNFSA-N;
MW          240.302;      // g/mol [origin=calculated method=formula-sum]
Tc          1046.78;      // K   [origin=predictive method=joback]
Pc          33.335;      // bar [origin=predictive method=joback]
omega       0.9793;      // -   [origin=predictive method=lee-kesler]
Tb          784.20;      // K   [origin=predictive method=joback]
HvapTb      81908.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.87 1.69504 -0.00151012 5.474e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACOH; count 2; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(e)-3-(4-hydroxyphenyl)but-2-en-2-yl]phenol" "dimethylstilboestrol" "(e)-4,4'-(1,2-dimethyl-1,2-ethenediyl)bisphenol" "4,4'-(2e)-but-2-ene-2,3-diyldiphenol" "alpha,alpha'-dimethyl-4,4'-stilbenediol (e)-" "4,4'-stilbenediol, alpha,alpha'-dimethyl-, (e)-" "phenol, 4,4'-((1e)-1,2-dimethyl-1,2-ethenediyl)bis-" "4,4'-but-2-ene-2,3-diyldiphenol" "dimethylstibestrol" "dimethylstilbesterol" ".alpha.,4'-stilbenediol (e)-" "4, trans-.alpha.,.alpha.'-dimethyl-" );
gibbsFormation
{
    dHf_298   -157490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     604.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=62540.0
    phase     gas;
}
