/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-propenal, 3,3-bis(4-(dimethylamino)phenyl)-  (C19H22N2O, CAS 17665-72-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Propenal33Bis4DimethylaminoPhenyl;
formula     C19H22N2O;
CAS         17665-72-4;
InChIKey    ITCVZBUCTCGFHF-UHFFFAOYSA-N;
MW          294.398;      // g/mol [origin=calculated method=formula-sum]
Tc          1001.63;      // K   [origin=predictive method=joback]
Pc          19.186;      // bar [origin=predictive method=joback]
omega       0.9226;      // -   [origin=predictive method=lee-kesler]
Tb          775.22;      // K   [origin=predictive method=joback]
HvapTb      74608.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-77.45 1.77428 -0.00124242 3.38e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH=C; count 1; } { group ACH; count 8; } { group AC; count 4; } { group CHO; count 1; } { group CH3N; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group dCH; count 1; } { group dC; count 1; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OdCH_al; count 1; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,3-bis[4-(dimethylamino)phenyl]prop-2-enal" "2-propenal, 3,3-bis[4-(dimethylamino)phenyl]-" "3,3-bis(4-dimethylaminophenyl)prop-2-enal" "3,3-bis(4-(dimethylamino)phenyl)acrylaldehyde" );
gibbsFormation
{
    dHf_298   171540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     710.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=508370.0
    phase     gas;
}
