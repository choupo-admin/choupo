/*--------------------------------*- Choupo -*-----------------------*\
  Component: dl-benzylsuccinic acid  (C11H12O4, CAS 884-33-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dlBenzylsuccinicAcid;
formula     C11H12O4;
CAS         884-33-3;
InChIKey    GTOFKXZQQDSVFH-UHFFFAOYSA-N;
MW          208.213;      // g/mol [origin=calculated method=formula-sum]
Tc          997.24;      // K   [origin=predictive method=joback]
Pc          32.393;      // bar [origin=predictive method=joback]
omega       1.2324;      // -   [origin=predictive method=lee-kesler]
Tb          768.54;      // K   [origin=predictive method=joback]
HvapTb      76296.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.498 1.0774 -0.0007542 2.007e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(phenylmethyl)butanedioic acid" "2-benzylsuccinic acid" "benzylsuccinic acid" "2-benzylbutanedioic acid" ".alpha.-benzylsuccinic acid" "benzenebutanoic acid, .beta.-carboxy-" "2-benzyl-succinic acid" "benzyl butanedioic acid" "alpha-benzylsuccinic acid" "(phenylmethyl)butanedioic acid" "beta-carboxybenzenebutanoic acid" "2-benzylbutane-1,4-dioic acid" );
gibbsFormation
{
    dHf_298   -739660.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     574.79;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-536110.0
    phase     gas;
}
