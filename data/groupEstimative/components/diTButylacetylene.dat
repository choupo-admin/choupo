/*--------------------------------*- Choupo -*-----------------------*\
  Component: di-t-butylacetylene  (C10H18, CAS 17530-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diTButylacetylene;
formula     C10H18;
CAS         17530-24-4;
InChIKey    FXVDWKZNFZMSOU-UHFFFAOYSA-N;
MW          138.254;      // g/mol [origin=calculated method=formula-sum]
Tc          641.25;      // K   [origin=predictive method=joback]
Pc          25.508;      // bar [origin=predictive method=joback]
omega       0.2258;      // -   [origin=predictive method=lee-kesler]
Tb          430.94;      // K   [origin=predictive method=joback]
HvapTb      37414.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-37.59 1.05572 -0.00077166 2.3058e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group C; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group C; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,2,5,5-tetramethylhex-3-yne" "2,2,5,5-tetramethyl-2-hexyne" "2,2,5,5-tetramethyl-3-hexyne" "3-hexyne,2,2,5,5-tetramethyl-" "3-hexyne, 2,2,5,5-tetramethyl-" "2,2,5,5-tetramethyl-3-hexyne;di-tert-butylacetylene;di-tert-butylethyne;" );
standardThermochemistry
{
    dHf_298   5070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     439.52;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=241800.0
}
