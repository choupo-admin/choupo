/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl stearate  (C20H38O2, CAS 111-63-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylStearate;
formula     C20H38O2;
CAS         111-63-7;
InChIKey    AFSIMBWBBOJPJG-UHFFFAOYSA-N;
MW          310.522;      // g/mol [origin=calculated method=formula-sum]
Tc          881.28;      // K   [origin=predictive method=joback]
Pc          10.467;      // bar [origin=predictive method=joback]
omega       0.8883;      // -   [origin=predictive method=lee-kesler]
Tb          712.10;      // K   [origin=predictive method=joback]
HvapTb      66851.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (7.126 1.82902 -0.0009925 1.871e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group dCH2; count 1; } { group dCH; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl octadecanoate" "octadecanoic acid, ethenyl ester" "stearic acid, vinyl ester" "stearic acid vinyl ester" "stearic acid, vinyl ester (8ci)" );
gibbsFormation
{
    dHf_298   -647980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     981.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-105010.0
    phase     gas;
}
