/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-quercitol  (C6H12O5, CAS 488-73-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dQuercitol;
formula     C6H12O5;
CAS         488-73-3;
InChIKey    IMPKVMRTXBRHRB-MBMOQRBOSA-N;
MW          164.157;      // g/mol [origin=calculated method=formula-sum]
Tc          979.79;      // K   [origin=predictive method=joback]
Pc          62.888;      // bar [origin=predictive method=joback]
omega       2.5982;      // -   [origin=predictive method=lee-kesler]
Tb          798.65;      // K   [origin=predictive method=joback]
HvapTb      111538.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-17.96 0.7599 -0.000314 6e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 5; } { group OH; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 5; } { group OH; count 5; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,2s,4s,5r)-cyclohexane-1,2,3,4,5-pentol" "(+)-quercitol" "(+)-proto-quercitol" "viburnitol" "d-chiro-inositol, 2-deoxy-" "1l-1,3,4/2,5-cyclohexanepentol" "5-deoxyinositol" "quercitol" "acorn sugar" );
standardThermochemistry
{
    dHf_298   -955360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     444.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-690850.0
}
