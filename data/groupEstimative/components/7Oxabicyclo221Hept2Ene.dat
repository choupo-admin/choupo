/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-oxabicyclo[2.2.1]hept-2-ene  (C6H8O, CAS 6705-50-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Oxabicyclo221Hept2Ene;
formula     C6H8O;
CAS         6705-50-6;
InChIKey    YCNYCBYHUAGZIZ-UHFFFAOYSA-N;
MW          96.129;      // g/mol [origin=calculated method=formula-sum]
Tc          588.34;      // K   [origin=predictive method=joback]
Pc          45.531;      // bar [origin=predictive method=joback]
omega       0.2860;      // -   [origin=predictive method=lee-kesler]
Tb          380.74;      // K   [origin=predictive method=joback]
HvapTb      33750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-83.07 0.807 -0.00066998 2.244e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 1; } { group CH=CH; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "bicyclo[2.2.1]hept-2-ene, 7-oxa-" "bicyclo(2.2.1)hept-2-ene, 7-oxa-" "3,6-epoxycyclohexene" "tl469" "7-oxa-bicyclo[2.2.1]hept-2-ene" "7-oxabicyclo[2.2.1]hept-5-ene;7-oxanorbornene; cyclohexene, 3,6-epoxy-" );
gibbsFormation
{
    dHf_298   -101950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     140.43;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=52880.0
    phase     gas;
}
