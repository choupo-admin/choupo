/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-butylcyclopentanol  (C9H18O, CAS 1462-97-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Butylcyclopentanol;
formula     C9H18O;
CAS         1462-97-1;
InChIKey    GQTUSXZITATQAM-UHFFFAOYSA-N;
MW          142.242;      // g/mol [origin=calculated method=formula-sum]
Tc          702.35;      // K   [origin=predictive method=joback]
Pc          32.100;      // bar [origin=predictive method=joback]
omega       0.7640;      // -   [origin=predictive method=lee-kesler]
Tb          513.22;      // K   [origin=predictive method=joback]
HvapTb      51413.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.477 1.31642 -0.0011562 4.432e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-butylcyclopentan-1-ol" "1-butyl-1-cyclopentanol" "cyclopentanol, 1-butyl-" "1-n-butylcyclopentanol" );
gibbsFormation
{
    dHf_298   -305600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     576.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-80860.0
    phase     gas;
}
