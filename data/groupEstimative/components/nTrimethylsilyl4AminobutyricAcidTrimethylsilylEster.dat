/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-trimethylsilyl-4-aminobutyric acid trimethylsilyl ester  (C10H25NO2Si2, CAS 39538-11-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C10H25NO2Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nTrimethylsilyl4AminobutyricAcidTrimethylsilylEster;
formula     C10H25NO2Si2;
CAS         39538-11-9;
InChIKey    ZRQMOACDJFMJPD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          247.485;      // g/mol [origin=calculated method=formula-sum]
Tc          722.03;      // K   [origin=predictive method=joback]
Pc          17.361;      // bar [origin=predictive method=joback]
omega       0.5835;      // -   [origin=predictive method=lee-kesler]
Tb          539.59;      // K   [origin=predictive method=joback]
HvapTb      52285.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (99.633 0.56292 0.0003554 -3.732e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 1; } { group CH2COO; count 1; } { group CH2NH; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group COO; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethylsilyl 4-(trimethylsilylamino)butanoate" "butanoic acid, 4-[(trimethylsilyl)amino]-, trimethylsilyl ester" "4-[(trimethylsilyl)amino]butyric acid trimethylsilyl ester" );
gibbsFormation
{
    dHf_298   -736780.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     890.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-397180.0
    phase     gas;
}
