/*--------------------------------*- Choupo -*-----------------------*\
  Component: (2s,3s)-butane-2,3-diol  (C4H10O2, CAS 19132-06-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2s3sButane23Diol;
formula     C4H10O2;
CAS         19132-06-0;
InChIKey    OWBTYPJTUOEWEK-IMJSIDKUSA-N;
MW          90.122;      // g/mol [origin=calculated method=formula-sum]
Tc          639.52;      // K   [origin=predictive method=joback]
Pc          50.875;      // bar [origin=predictive method=joback]
omega       1.1362;      // -   [origin=predictive method=lee-kesler]
Tb          474.60;      // K   [origin=predictive method=joback]
HvapTb      57080.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.47 0.46364 -0.000261 5.5e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 2; } { group OH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 2; } { group OH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(s,s)-2,3-butanediol" "(2s,3s)-(+)-2,3-butanediol" "(s,s)-butane-2,3-diol" "(s,s)-(+)-2,3-butanediol" "l-(+)-2,3-butanediol" "(s,s)-2,3-butylene glycol" "(2s,3s)-(+)2,3-butanediol" "bud" "2,3-butanediol,(2s,3s)-" "(s,s)-(+)-2,3-dihydroxybutane" "(s,s)-(+)-2,3-butylene glycol" "h556" );
gibbsFormation
{
    dHf_298   -440910.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     394.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-295720.0
    phase     gas;
}
