/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-oxoheptanedioic acid  (C7H10O5, CAS 502-50-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4OxoheptanedioicAcid;
formula     C7H10O5;
CAS         502-50-1;
InChIKey    UDDSEESQRGPVIL-UHFFFAOYSA-N;
MW          174.152;      // g/mol [origin=calculated method=formula-sum]
Tc          912.27;      // K   [origin=predictive method=joback]
Pc          36.776;      // bar [origin=predictive method=joback]
omega       1.3420;      // -   [origin=predictive method=lee-kesler]
Tb          704.65;      // K   [origin=predictive method=joback]
HvapTb      72250.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (13.084 0.7424 -0.0004835 1.1906e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group CH2CO; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CdO; count 1; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylideneheptanedioic acid" "4-oxopimelic acid" "4-ketopimelic acid" "4-ketopimelic" ".gamma.-ketopimelic acid" "pimelic acid, 4-keto-" "heptanedioic acid,4-oxo-" );
gibbsFormation
{
    dHf_298   -1000930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     561.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-808680.0
    phase     gas;
}
