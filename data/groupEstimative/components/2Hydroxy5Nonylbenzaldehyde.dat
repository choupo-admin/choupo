/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-hydroxy-5-nonylbenzaldehyde  (C16H24O2, CAS 63753-10-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C16H24O2 (delta C+1H+1O+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        2Hydroxy5Nonylbenzaldehyde;
formula     C16H24O2;
CAS         63753-10-6;
InChIKey    JYWIGMQDJSGOMD-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          248.366;      // g/mol [origin=calculated method=formula-sum]
Tc          854.43;      // K   [origin=predictive method=joback]
Pc          19.841;      // bar [origin=predictive method=joback]
omega       0.8513;      // -   [origin=predictive method=lee-kesler]
Tb          654.38;      // K   [origin=predictive method=joback]
HvapTb      64789.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-59.682 1.54812 -0.00122012 4.096e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group ACH; count 3; } { group AC; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CHO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-nonyl-2-oxidanyl-benzaldehyde" "benzaldehyde, 2-hydroxy-5-nonyl-" "5-nonylsalicylaldehyde" "2-hydroxy-5-nonylbenzaldehyde;2-hydroxy-5-nonyl-benzaldehyde;63753-10-6;5-nonylsalicylaldehyde;" );
standardThermochemistry
{
    dHf_298   -249370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     773.98;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=75960.0
}
