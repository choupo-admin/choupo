/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl aconitate  (C9H12O6, CAS 20820-77-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylAconitate;
formula     C9H12O6;
CAS         20820-77-3;
InChIKey    DZAIBGWGBBQGPZ-XQRVVYSFSA-N;
MW          216.189;      // g/mol [origin=calculated method=formula-sum]
Tc          775.75;      // K   [origin=predictive method=joback]
Pc          24.752;      // bar [origin=predictive method=joback]
omega       0.8480;      // -   [origin=predictive method=lee-kesler]
Tb          584.22;      // K   [origin=predictive method=joback]
HvapTb      57887.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (57.061 0.71436 -0.0002681 -2.62e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH=C; count 1; } { group CH2COO; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trimethyl (z)-prop-1-ene-1,2,3-tricarboxylate" "trimethyl (1z)-1-propene-1,2,3-tricarboxylate" "1-propene-1,2,3-tricarboxylic acid, trimethyl ester" "trimethyl trans-aconitate" "1-propene-1,2,3-tricarboxylic acid, trimethyl ester, (z)-" "1-propene-1,3-tricarboxylic acid, trimethyl ester" "1-propene-1,2,3-tricarboxylic acid, trimethyl ester, (e)-" );
gibbsFormation
{
    dHf_298   -1073500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     649.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-834540.0
    phase     gas;
}
