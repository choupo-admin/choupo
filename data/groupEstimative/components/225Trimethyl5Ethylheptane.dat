/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2,5-trimethyl-5-ethylheptane  (C12H26, CAS 62199-12-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        225Trimethyl5Ethylheptane;
formula     C12H26;
CAS         62199-12-6;
InChIKey    KJWMMFYTYSUWMH-UHFFFAOYSA-N;
MW          170.34;      // g/mol [origin=calculated method=formula-sum]
Tc          648.33;      // K   [origin=predictive method=joback]
Pc          18.388;      // bar [origin=predictive method=joback]
omega       0.4029;      // -   [origin=predictive method=lee-kesler]
Tb          467.70;      // K   [origin=predictive method=joback]
HvapTb      39714.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-56.966 1.39552 -0.0009726 2.754e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 6; } { group CH2; count 4; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 4; } { group C; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-ethyl-2,2,5-trimethyl-heptane" );
gibbsFormation
{
    dHf_298   -308510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     545.68;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=55840.0
    phase     gas;
}
