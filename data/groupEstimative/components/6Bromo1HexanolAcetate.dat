/*--------------------------------*- Choupo -*-----------------------*\
  Component: 6-bromo-1-hexanol acetate  (C8H17BrO3, CAS 8052-41-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        6Bromo1HexanolAcetate;
formula     C8H17BrO3;
CAS         8052-41-3;
InChIKey    ORSNIUUONGZHEH-UHFFFAOYSA-N;
MW          241.125;      // g/mol [origin=calculated method=formula-sum]
Tc          880.47;      // K   [origin=predictive method=joback]
Pc          30.057;      // bar [origin=predictive method=joback]
omega       1.3330;      // -   [origin=predictive method=lee-kesler]
Tb          687.89;      // K   [origin=predictive method=joback]
HvapTb      73974.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (54.516 0.68062 -0.000171 -6.13e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group OH; count 1; } { group COOH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 6; } { group Br; count 1; } { group OH; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-bromanylhexan-1-ol;ethanoic acid" );
standardThermochemistry
{
    dHf_298   -796240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     730.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-554690.0
}
