/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2,4-di-tert-pentylphenoxy)butryic acid  (C20H32O3, CAS 13403-01-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        224DiTertPentylphenoxyButryicAcid;
formula     C20H32O3;
CAS         13403-01-5;
InChIKey    PHCYXPLSQNMCRY-UHFFFAOYSA-N;
MW          320.473;      // g/mol [origin=calculated method=formula-sum]
Tc          1070.09;      // K   [origin=predictive method=joback]
Pc          13.526;      // bar [origin=predictive method=joback]
omega       0.9791;      // -   [origin=predictive method=lee-kesler]
Tb          854.87;      // K   [origin=predictive method=joback]
HvapTb      80308.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-41.127 1.95114 -0.00126972 3.19e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 3; } { group C; count 2; } { group ACH; count 3; } { group AC; count 3; } { group CH-O; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group CH2; count 3; } { group CH; count 1; } { group C; count 2; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2,4-bis(2-methylbutan-2-yl)phenoxy]butanoic acid" "2-(2,4-di-tert-pentylphenoxy)butanoic acid" "2-(2,4-di-tert-pentylphenoxy)butyric acid" "butyric acid, 2-(2,4-di-tert-pentylphenoxy)-" "2-(2,4-bis(tert-pentyl)phenoxy)butyric acid" "butanoic acid, 2-(2,4-bis(1,1-dimethylpropyl)phenoxy)-" "butanoic acid, 2-[2,4-bis(1,1-dimethylpropyl)phenoxy]-" "p274" "2-(2,4-bis(1,1-dimethylpropyl)phenoxy)-butanoic acid" );
standardThermochemistry
{
    dHf_298   -747810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     793.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-235000.0
}
