/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylstilbestrol monomethyl ether  (C19H22O2, CAS 18839-90-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethylstilbestrolMonomethylEther;
formula     C19H22O2;
CAS         18839-90-2;
InChIKey    CKMDPZMWUZDKAI-VHEBQXMUSA-N;
MW          282.383;      // g/mol [origin=calculated method=formula-sum]
Tc          1037.92;      // K   [origin=predictive method=joback]
Pc          20.642;      // bar [origin=predictive method=joback]
omega       0.9295;      // -   [origin=predictive method=lee-kesler]
Tb          799.62;      // K   [origin=predictive method=joback]
HvapTb      78644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-64.878 1.70276 -0.00123892 3.703e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group ACH; count 8; } { group AC; count 3; } { group ACOH; count 1; } { group CH3O; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dC; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[(e)-4-(4-methoxyphenyl)hex-3-en-3-yl]phenol" "mestilbol" "monomestrol" "trans-diethylstilbestrol monomethyl ether" "alpha,alpha-diethyl-4'-methoxy-4-stilbenol" "3-p-hydroxyphenyl-4-p-methoxyphenyl-3-hexene" "4-(1-ethyl-2-(4-methoxyphenyl)-1-butenyl)phenol (e)-" "phenol, 4-((1e)-1-ethyl-2-(4-methoxyphenyl)-1-butenyl)-" "phenol, 4-(1-ethyl-2-(4-methoxyphenyl)-1-butenyl)-, (e)-" "mestilbol (van)" "des monomethyl ether" "4-stilbenol, alpha,alpha'-diethyl-4'-methoxy-" );
standardThermochemistry
{
    dHf_298   -185790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     699.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=127790.0
}
