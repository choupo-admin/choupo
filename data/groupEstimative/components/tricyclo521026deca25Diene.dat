/*--------------------------------*- Choupo -*-----------------------*\
  Component: tricyclo[5.2.1.02,6deca-2,5-diene  (C10H12, CAS 6675-72-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        tricyclo521026deca25Diene;
formula     C10H12;
CAS         6675-72-5;
InChIKey    UKZSKSGXADHPHP-UHFFFAOYSA-N;
MW          132.206;      // g/mol [origin=calculated method=formula-sum]
Tc          687.48;      // K   [origin=predictive method=joback]
Pc          35.096;      // bar [origin=predictive method=joback]
omega       0.3798;      // -   [origin=predictive method=lee-kesler]
Tb          465.84;      // K   [origin=predictive method=joback]
HvapTb      39982.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-123.83 1.1924 -0.00103028 3.626e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group CH=C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo(5.2.1.02,6)deca-2,5-diene" );
standardThermochemistry
{
    dHf_298   75470.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     249.93;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=251840.0
}
