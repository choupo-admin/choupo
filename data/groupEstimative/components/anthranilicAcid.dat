/*--------------------------------*- Choupo -*-----------------------*\
  Component: anthranilic acid  (C7H7NO2, CAS 118-92-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anthranilicAcid;
formula     C7H7NO2;
CAS         118-92-3;
InChIKey    RWZYAGGXGHYGMB-UHFFFAOYSA-N;
MW          137.138;      // g/mol [origin=calculated method=formula-sum]
Tc          851.35;      // K   [origin=predictive method=joback]
Pc          49.039;      // bar [origin=predictive method=joback]
omega       0.8304;      // -   [origin=predictive method=lee-kesler]
Tb          609.46;      // K   [origin=predictive method=joback]
HvapTb      61919.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.99 0.6431 -0.00043716 1.117e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group ACNH2; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COOH; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-azanylbenzoic acid" "2-aminobenzoic acid" "o-aminobenzoic acid" "anthranilate" "o-carboxyaniline" "2-carboxyaniline" "vitamin l1" "benzoic acid, 2-amino-" "o-anthranilic acid" "1-amino-2-carboxybenzene" "carboxyaniline" "ortho-aminobenzoic acid" );
gibbsFormation
{
    dHf_298   -279230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     420.8;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-166620.0
    phase     gas;
}
