/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-dichlorobiphenyl  (C12H8Cl2, CAS 2050-68-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dichlorobiphenyl;
formula     C12H8Cl2;
CAS         2050-68-2;
InChIKey    YTBRNEUEFCNVHC-UHFFFAOYSA-N;
MW          223.096;      // g/mol [origin=calculated method=formula-sum]
Tc          872.17;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.4936;      // -   [origin=predictive method=lee-kesler]
Tb          612.34;      // K   [origin=predictive method=joback]
HvapTb      56952.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-21.45 0.8806 -0.00059812 1.508e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 8; } { group AC; count 2; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 8; } { group dC_ring; count 4; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranyl-4-(4-chlorophenyl)benzene" "p,p-dcbp" "p,p'-dichlorobiphenyl" "biphenyl, 4,4'-dichloro-" "1,1'-biphenyl, 4,4'-dichloro-" "4,4'-dichloro-1,1'-biphenyl" "4,4'-dichloro-biphenyl" "pcb 15" "pcb no 15" "4,4'-pcb" "1-chloro-4-(4-chlorophenyl)benzene" "biphenyl,4'-dichloro-" );
gibbsFormation
{
    dHf_298   127630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     465.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=231860.0
    phase     gas;
}
