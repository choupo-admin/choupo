/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-tert-butyl-5-methylcatechol  (C11H16O2, CAS 1010-99-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TertButyl5Methylcatechol;
formula     C11H16O2;
CAS         1010-99-7;
InChIKey    YKYXORJDSTUCTN-UHFFFAOYSA-N;
MW          180.247;      // g/mol [origin=calculated method=formula-sum]
Tc          880.28;      // K   [origin=predictive method=joback]
Pc          37.135;      // bar [origin=predictive method=joback]
omega       0.8136;      // -   [origin=predictive method=lee-kesler]
Tb          640.95;      // K   [origin=predictive method=joback]
HvapTb      67750.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-69.03 1.34548 -0.00122328 4.584e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group C; count 1; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group C; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tert-butyl-5-methyl-benzene-1,2-diol" "3-tert-butyl-5-methylpyrocatechol" "3-tert-butyl-5-methylbenzene-1,2-diol" "1, 3-(1,1-dimethylethyl)-5-methyl-" "1,2-benzenediol,3-(1,1-dimethylethyl)-5-methyl-" );
gibbsFormation
{
    dHf_298   -408680.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     485.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-161880.0
    phase     gas;
}
