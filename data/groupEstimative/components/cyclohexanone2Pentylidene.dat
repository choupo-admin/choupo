/*--------------------------------*- Choupo -*-----------------------*\
  Component: cyclohexanone, 2-pentylidene-  (C11H18O, CAS 25677-40-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        cyclohexanone2Pentylidene;
formula     C11H18O;
CAS         25677-40-1;
InChIKey    KTETXLGRNPACFS-YFHOEESVSA-N;
MW          166.264;      // g/mol [origin=calculated method=formula-sum]
Tc          767.15;      // K   [origin=predictive method=joback]
Pc          25.715;      // bar [origin=predictive method=joback]
omega       0.5311;      // -   [origin=predictive method=lee-kesler]
Tb          549.96;      // K   [origin=predictive method=joback]
HvapTb      45852.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-31.127 0.95162 -0.0004355 4.54e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group CH=C; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group dCH; count 1; } { group CH2_ring; count 4; } { group dC_ring; count 1; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2z)-2-pentylidenecyclohexan-1-one" "2-pentylidenecyclohexanone" "2-pentylidenecyclohexan-1-one" "(2z)-2-pentylidene-cyclohexan-1-one" );
gibbsFormation
{
    dHf_298   -257380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     489.41;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-3230.0
    phase     gas;
}
