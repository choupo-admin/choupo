/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyanoethyl radical  (C3H4N, CAS 25840-11-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=radical. Tool: chemicals/thermo/rdkit (MIT/BSD).
  reactiveIntermediate (radical): KINETICS ONLY -- no VLE, no groups.
\*---------------------------------------------------------------------------*/

name        2CyanoethylRadical;
formula     C3H4N;
CAS         25840-11-3;
InChIKey    WEMXRTXQKRXSIO-UHFFFAOYSA-N;
role        radical;
MW          54.072;      // g/mol [origin=calculated method=formula-sum]
Tc          557.44;      // K   [origin=predictive method=joback]
Pc          43.569;      // bar [origin=predictive method=joback]
omega       0.3148;      // -   [origin=predictive method=lee-kesler]
Tb          364.92;      // K   [origin=predictive method=joback]
HvapTb      32101.0;      // J/mol [origin=predictive method=joback]

idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.261 0.1936 -8.94e-05 1.19e-08);
    Trange        (200 1000);
}
groups
{
    joback ( { group CH2; count 1; } { group dCH2; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "propanenitrile" "2-cyanoethyl" );
standardThermochemistry
{
    dHf_298   126450.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     277.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=155290.0
}
