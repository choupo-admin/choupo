/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,2-dimethoxypentane  (C7H16O2, CAS 55904-98-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22Dimethoxypentane;
formula     C7H16O2;
CAS         55904-98-8;
InChIKey    IRAHAFAANXPSRY-UHFFFAOYSA-N;
MW          132.203;      // g/mol [origin=calculated method=formula-sum]
Tc          576.93;      // K   [origin=predictive method=joback]
Pc          27.556;      // bar [origin=predictive method=joback]
omega       0.4042;      // -   [origin=predictive method=lee-kesler]
Tb          401.37;      // K   [origin=predictive method=joback]
HvapTb      34700.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (23.052 0.66828 -0.0003068 3.44e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C; count 1; } { group CH3O; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group C; count 1; } { group O; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -461000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     412.34;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-199100.0
    phase     gas;
}
