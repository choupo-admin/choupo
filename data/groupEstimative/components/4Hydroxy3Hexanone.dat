/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-hydroxy-3-hexanone  (C6H12O2, CAS 4984-85-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Hydroxy3Hexanone;
formula     C6H12O2;
CAS         4984-85-4;
InChIKey    SKCYVGUCBRYGTE-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          657.47;      // K   [origin=predictive method=joback]
Pc          37.592;      // bar [origin=predictive method=joback]
omega       0.8785;      // -   [origin=predictive method=lee-kesler]
Tb          482.49;      // K   [origin=predictive method=joback]
HvapTb      51987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.402 0.58574 -0.0003175 6.046e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanylhexan-3-one" "propioin" "4-hydroxyhexan-3-one" "3-hexanone, 4-hydroxy-" "propionoin" "3-hexanone, 4-hydroxy-, (4r)-" "3-hexanone, 4-hydroxy-, (4s)-" "3-hydroxyhexan-4-one" "agn-pc-00axwj" "skcyvgucbrygte-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   -437260.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.77;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-268540.0
}
