/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-methyl-5-(2,2,3-trimethylcyclopent-3-en-1-yl)pent-3-en-2-one  (C14H22O, CAS 65113-95-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Methyl5223Trimethylcyclopent3En1YlPent3En2One;
formula     C14H22O;
CAS         65113-95-3;
InChIKey    QQUWZMIGSXXJFV-UHFFFAOYSA-N;
MW          206.329;      // g/mol [origin=calculated method=formula-sum]
Tc          803.82;      // K   [origin=predictive method=joback]
Pc          20.127;      // bar [origin=predictive method=joback]
omega       0.5789;      // -   [origin=predictive method=lee-kesler]
Tb          592.82;      // K   [origin=predictive method=joback]
HvapTb      53293.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-98.809 1.6074 -0.00133004 4.8416e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 1; } { group C; count 1; } { group CH=C; count 2; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 1; } { group dCH; count 1; } { group dC; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -235750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     650.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=53430.0
    phase     gas;
}
