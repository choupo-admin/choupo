/*--------------------------------*- Choupo -*-----------------------*\
  Component: .gamma.-ionone  (C13H20O, CAS 79-76-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        gammaIonone;
formula     C13H20O;
CAS         79-76-5;
InChIKey    SFEOKXHPFMOVRM-BQYQJAHWSA-N;
MW          192.302;      // g/mol [origin=calculated method=formula-sum]
Tc          786.24;      // K   [origin=predictive method=joback]
Pc          22.355;      // bar [origin=predictive method=joback]
omega       0.5211;      // -   [origin=predictive method=lee-kesler]
Tb          569.35;      // K   [origin=predictive method=joback]
HvapTb      50364.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-103.12 1.50086 -0.0012143 4.3216e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH2; count 1; } { group dCH; count 2; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group C_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-4-(2,2-dimethyl-6-methylidene-cyclohexyl)but-3-en-2-one" "3-buten-2-one, 4-(2,2-dimethyl-6-methylenecyclohexyl)-" "4-(2,2-dimethyl-6-methylenecyclohexyl)-3-buten-2-one" "(e)-4-(2,2-dimethyl-6-methylidenecyclohexyl)but-3-en-2-one" "gamma-lonone" "gamma-ionon" "ionone, gamma-" "4-(2-methylene-6,6-dimethylcyclohexyl)-3-buten-2-one" "(3e)-4-(2,2-dimethyl-6-methylenecyclohexyl)-3-buten-2-one" "(3e)-4-(2,2-dimethyl-6-methylidenecyclohexyl)but-3-en-2-one" );
standardThermochemistry
{
    dHf_298   -173550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=74210.0
}
