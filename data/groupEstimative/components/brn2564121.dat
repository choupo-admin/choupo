/*--------------------------------*- Choupo -*-----------------------*\
  Component: brn 2564121  (C22H13F, CAS 1764-39-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        brn2564121;
formula     C22H13F;
CAS         1764-39-2;
InChIKey    ZVPJORXGYQZBIO-UHFFFAOYSA-N;
MW          296.344;      // g/mol [origin=calculated method=formula-sum]
Tc          1083.68;      // K   [origin=predictive method=joback]
Pc          22.166;      // bar [origin=predictive method=joback]
omega       0.8680;      // -   [origin=predictive method=lee-kesler]
Tb          824.75;      // K   [origin=predictive method=joback]
HvapTb      75233.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.5 1.7739 -0.00149932 5.065e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 13; } { group AC; count 8; } { group ACF; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH_ring; count 13; } { group dC_ring; count 9; } { group F; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "6-fluoranylnaphtho[1,2-b]phenanthrene" "4-fluoro-1,2:5,6-dibenzanthracene" "dibenz(a,h)anthracene, 6-fluoro-" "6-fluoronaphtho[1,2-b]phenanthrene" );
standardThermochemistry
{
    dHf_298   261410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     477.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=440040.0
}
