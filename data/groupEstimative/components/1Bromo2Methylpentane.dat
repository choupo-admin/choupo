/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-bromo-2-methylpentane  (C6H13Br, CAS 25346-33-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Bromo2Methylpentane;
formula     C6H13Br;
CAS         25346-33-2;
InChIKey    GSYMWZIKZUHBKV-UHFFFAOYSA-N;
MW          165.074;      // g/mol [origin=calculated method=formula-sum]
Tc          590.79;      // K   [origin=predictive method=joback]
Pc          33.920;      // bar [origin=predictive method=joback]
omega       0.3920;      // -   [origin=predictive method=lee-kesler]
Tb          402.60;      // K   [origin=predictive method=joback]
HvapTb      34997.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (3.943 0.61794 -0.0003772 9.38e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group Br; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-bromanyl-2-methyl-pentane" "pentane, 1-bromo-2-methyl-" "pentane, 1-bromo-2-methyl-, (2r)-" "1-bromo-2-methyl-pentane" );
standardThermochemistry
{
    dHf_298   -146120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     431.23;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=11520.0
}
