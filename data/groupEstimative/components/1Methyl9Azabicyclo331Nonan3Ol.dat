/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methyl-9-azabicyclo[3.3.1]nonan-3-ol  (C9H17NO, CAS 2038-40-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methyl9Azabicyclo331Nonan3Ol;
formula     C9H17NO;
CAS         2038-40-6;
InChIKey    DPTCGYGOXXZERV-UHFFFAOYSA-N;
MW          155.241;      // g/mol [origin=calculated method=formula-sum]
Tc          783.41;      // K   [origin=predictive method=joback]
Pc          38.198;      // bar [origin=predictive method=joback]
omega       0.7990;      // -   [origin=predictive method=lee-kesler]
Tb          568.11;      // K   [origin=predictive method=joback]
HvapTb      57947.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-142.98 1.41782 -0.001214 4.515e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group CH; count 1; } { group C; count 1; } { group OH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 2; } { group C_ring; count 1; } { group OH; count 1; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-methyl-9-azabicyclo[3.3.1]nonan-3-ol" "9-aza-1-methylbicyclo[3.3.1]nonan-3-ol" "9-aza-1-methylbicyclo(3.3.1)nonan-3-ol" );
gibbsFormation
{
    dHf_298   -221490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     457.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=47790.0
    phase     gas;
}
