/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,2,3-metheno-1h-benz[f]indene,2,3-dihydro  (C14H10, CAS 77669-79-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        123Metheno1hBenzFIndene23Dihydro;
formula     C14H10;
CAS         77669-79-5;
InChIKey    WVGZIULRVIBPDX-UHFFFAOYSA-N;
MW          178.234;      // g/mol [origin=calculated method=formula-sum]
Tc          802.81;      // K   [origin=predictive method=joback]
Pc          31.420;      // bar [origin=predictive method=joback]
omega       0.5670;      // -   [origin=predictive method=lee-kesler]
Tb          569.74;      // K   [origin=predictive method=joback]
HvapTb      50568.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-165.77 1.6064 -0.00160884 6.314e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH; count 2; } { group ACH; count 6; } { group AC; count 2; } { group ACCH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH_ring; count 4; } { group dCH_ring; count 6; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2,3-metheno-1h-benz(f)indene, 2,3-dihydro-" "2,3-dihydro-1h-1,2,3-(methanetriyl)cyclopenta[b]naphthalene" );
gibbsFormation
{
    dHf_298   301230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     60.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=501840.0
    phase     gas;
}
