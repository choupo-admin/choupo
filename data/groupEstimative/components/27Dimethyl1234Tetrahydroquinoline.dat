/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-dimethyl-1,2,3,4-tetrahydroquinoline  (C11H15N, CAS 42835-92-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        27Dimethyl1234Tetrahydroquinoline;
formula     C11H15N;
CAS         42835-92-7;
InChIKey    XIFZARBGEUHEHW-UHFFFAOYSA-N;
MW          161.248;      // g/mol [origin=calculated method=formula-sum]
Tc          781.99;      // K   [origin=predictive method=joback]
Pc          31.106;      // bar [origin=predictive method=joback]
omega       0.4880;      // -   [origin=predictive method=lee-kesler]
Tb          547.48;      // K   [origin=predictive method=joback]
HvapTb      50523.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.86 0.97884 -0.00058492 1.319e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group NH_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "quinoline, 1,2,3,4-tetrahydro-2,7-dimethyl-" "agn-pc-02tg1e" );
gibbsFormation
{
    dHf_298   47670.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=271250.0
    phase     gas;
}
