/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-aminoethylamino)ethanol; (z)-octadec-9-enoic acid  (C22H46N2O3, CAS 68815-51-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22AminoethylaminoEthanolZOctadec9EnoicAcid;
formula     C22H46N2O3;
CAS         68815-51-0;
InChIKey    YGJDXOJIYODGEO-KVVVOXFISA-N;
MW          386.621;      // g/mol [origin=calculated method=formula-sum]
Tc          1326.41;      // K   [origin=predictive method=joback]
Pc          10.306;      // bar [origin=predictive method=joback]
omega       0.8471;      // -   [origin=predictive method=lee-kesler]
Tb          1068.91;      // K   [origin=predictive method=joback]
HvapTb      115738.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.698 2.13052 -0.001037 1.401e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 16; } { group CH=CH; count 1; } { group OH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 18; } { group dCH; count 2; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-azanylethylamino)ethanol;(z)-octadec-9-enoic acid" "9-octadecenoic acid (9z)-, reaction products with 2-((2-aminoethyl)amino)ethanol" );
standardThermochemistry
{
    dHf_298   -907050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1310.32;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-215070.0
}
