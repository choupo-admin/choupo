/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-cyclohexylanisole  (C13H18O, CAS 2206-48-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Cyclohexylanisole;
formula     C13H18O;
CAS         2206-48-6;
InChIKey    CMMWEZJMZPQGJL-UHFFFAOYSA-N;
MW          190.286;      // g/mol [origin=calculated method=formula-sum]
Tc          804.64;      // K   [origin=predictive method=joback]
Pc          25.978;      // bar [origin=predictive method=joback]
omega       0.4761;      // -   [origin=predictive method=lee-kesler]
Tb          570.67;      // K   [origin=predictive method=joback]
HvapTb      50309.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-68.64 1.15932 -0.00061756 9.89e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 5; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-cyclohexyl-2-methoxy-benzene" "anisole, o-cyclohexyl-" "1-cyclohexyl-2-methoxybenzene" "benzene, 1-cyclohexyl-2-methoxy-" "o-cyclohexylanisole" );
gibbsFormation
{
    dHf_298   -164490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80810.0
    phase     gas;
}
