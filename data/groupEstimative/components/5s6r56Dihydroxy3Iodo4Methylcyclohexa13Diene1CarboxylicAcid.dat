/*--------------------------------*- Choupo -*-----------------------*\
  Component: (5s,6r)-5,6-dihydroxy-3-iodo-4-methylcyclohexa-1,3-diene-1-carboxylic acid  (C8H9IO4, CAS 205504-03-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5s6r56Dihydroxy3Iodo4Methylcyclohexa13Diene1CarboxylicAcid;
formula     C8H9IO4;
CAS         205504-03-6;
InChIKey    PHFNUCVOBHHQAQ-NKWVEPMBSA-N;
MW          296.056;      // g/mol [origin=calculated method=formula-sum]
Tc          1053.31;      // K   [origin=predictive method=joback]
Pc          42.386;      // bar [origin=predictive method=joback]
omega       1.7571;      // -   [origin=predictive method=lee-kesler]
Tb          833.79;      // K   [origin=predictive method=joback]
HvapTb      95987.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.28 0.72672 -0.00042524 8.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH; count 2; } { group CH=C; count 1; } { group OH; count 2; } { group COOH; count 1; } { group I; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 3; } { group I; count 1; } { group OH; count 2; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(5s,6r)-3-iodanyl-4-methyl-5,6-bis(oxidanyl)cyclohexa-1,3-diene-1-carboxylic acid" "1,3-cyclohexadiene-1-carboxylicacid, 5,6-dihydroxy-3-iodo-4-methyl-, (5s,6r)-" "1,3-cyclohexadiene-1-carboxylicacid, 5,6-dihydroxy-3-iodo-4-methyl-, (5s-cis)-" );
gibbsFormation
{
    dHf_298   -671180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     512.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-495180.0
    phase     gas;
}
