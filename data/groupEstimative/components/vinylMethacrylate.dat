/*--------------------------------*- Choupo -*-----------------------*\
  Component: vinyl methacrylate  (C6H8O2, CAS 4245-37-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        vinylMethacrylate;
formula     C6H8O2;
CAS         4245-37-8;
InChIKey    FFYWKOUKJFCBAM-UHFFFAOYSA-N;
MW          112.128;      // g/mol [origin=calculated method=formula-sum]
Tc          573.11;      // K   [origin=predictive method=joback]
Pc          34.602;      // bar [origin=predictive method=joback]
omega       0.3744;      // -   [origin=predictive method=lee-kesler]
Tb          388.34;      // K   [origin=predictive method=joback]
HvapTb      35097.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (17.17 0.47892 -0.0002561 3.97e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2=CH; count 1; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 2; } { group dCH; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethenyl 2-methylprop-2-enoate" "methacrylic acid, vinyl ester" "2-propenoic acid, 2-methyl-, ethenyl ester" "methacrylic acid, vinyl ester (8ci)" "2-methyl-2-propenoic acid, ethenyl ester" "methacrylic acid vinyl ester" "ffywkoukjfcbam-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -243380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     427.64;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143600.0
    phase     gas;
}
