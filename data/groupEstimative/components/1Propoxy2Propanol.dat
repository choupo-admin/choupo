/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-propoxy-2-propanol  (C6H14O2, CAS 1569-01-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Propoxy2Propanol;
formula     C6H14O2;
CAS         1569-01-3;
InChIKey    FENFUOGYJVOCRY-UHFFFAOYSA-N;
MW          118.176;      // g/mol [origin=calculated method=formula-sum]
Tc          615.73;      // K   [origin=predictive method=joback]
Pc          34.159;      // bar [origin=predictive method=joback]
omega       0.8143;      // -   [origin=predictive method=lee-kesler]
Tb          451.04;      // K   [origin=predictive method=joback]
HvapTb      47651.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (26.543 0.55054 -0.0002252 1.47e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group C2H4O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 3; } { group CH; count 1; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-propoxypropan-2-ol" "2-propanol, 1-propoxy-" "propasol solvent p" "propylene glycol n-propyl ether" "propylene glycol propyl ether" "propylene glycol-n-monopropyl ether" "dowanol&reg; pnp" "2-propanol, propoxy-" "dowanol(r) pnp" "agn-pc-03vfkp" "1,2-propyleneglycol 1-propyl ether; 1-propoxy-2-propanol; arcosolv pnp" );
gibbsFormation
{
    dHf_298   -456900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.35;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-244620.0
    phase     gas;
}
