/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3,6,9,12-tetraoxatetradecane-1,14-diyl diacetate  (C14H26O8, CAS 22790-13-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        36912Tetraoxatetradecane114DiylDiacetate;
formula     C14H26O8;
CAS         22790-13-2;
InChIKey    MBGINZGOPMLHQN-UHFFFAOYSA-N;
MW          322.354;      // g/mol [origin=calculated method=formula-sum]
Tc          900.32;      // K   [origin=predictive method=joback]
Pc          14.568;      // bar [origin=predictive method=joback]
omega       1.1468;      // -   [origin=predictive method=lee-kesler]
Tb          726.04;      // K   [origin=predictive method=joback]
HvapTb      71212.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (142.98 0.97144 -0.0001046 -1.78e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group CH3COO; count 2; } { group CH2O; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group O; count 4; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-[2-(2-acetyloxyethoxy)ethoxy]ethoxy]ethoxy]ethyl ethanoate" "16-oxo-3,6,9,12,15-pentaoxaheptadec-1-yl acetate" "3,6,9,12-tetraoxatetradecane-1,14-diol, diacetate" "pentaethyleneglycol, diacetate (7ci,8ci)" "3,6,9,12-tetraoxatetradecane-1,14-diol,diacetate (9ci)" "2-[2-[2-[2-(2-acetyloxyethoxy)ethoxy]ethoxy]ethoxy]ethyl acetate" );
gibbsFormation
{
    dHf_298   -1495730.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     849.0;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-973740.0
    phase     gas;
}
