/*--------------------------------*- Choupo -*-----------------------*\
  Component: desipramine  (C18H22N2, CAS 50-47-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        desipramine;
formula     C18H22N2;
CAS         50-47-5;
InChIKey    HCYAFALTSJYZDH-UHFFFAOYSA-N;
MW          266.388;      // g/mol [origin=calculated method=formula-sum]
Tc          970.30;      // K   [origin=predictive method=joback]
Pc          21.335;      // bar [origin=predictive method=joback]
omega       0.9147;      // -   [origin=predictive method=lee-kesler]
Tb          744.51;      // K   [origin=predictive method=joback]
HvapTb      70067.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-115.647 1.82412 -0.00136692 4.095e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group AC; count 2; } { group ACCH2; count 2; } { group CH3NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 3; } { group CH2_ring; count 2; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group NH; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(5,6-dihydrobenzo[b][1]benzazepin-11-yl)-n-methyl-propan-1-amine" "norimipramine" "desmethylimipramine" "demethylimipramine" "desipramin" "monodemethylimipramine" "desimipramine" "dezipramine" "dimethylimipramine" "pertofran" "desipraminum" "desipramina" );
standardThermochemistry
{
    dHf_298   255570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     620.88;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=586970.0
}
