/*--------------------------------*- Choupo -*-----------------------*\
  Component: [(3s)-5-oxooxolan-3-yl] acetate  (C6H8O4, CAS 191403-65-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3s5Oxooxolan3YlAcetate;
formula     C6H8O4;
CAS         191403-65-3;
InChIKey    QOAAHMCFVNHTBI-YFKPBYRVSA-N;
MW          144.126;      // g/mol [origin=calculated method=formula-sum]
Tc          656.10;      // K   [origin=predictive method=joback]
Pc          36.553;      // bar [origin=predictive method=joback]
omega       0.5668;      // -   [origin=predictive method=lee-kesler]
Tb          460.06;      // K   [origin=predictive method=joback]
HvapTb      43677.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.99 0.61512 -0.0003336 4.53e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 1; } { group CH3COO; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s)-5-oxidanylideneoxolan-3-yl] ethanoate" "(3s)-5-oxo-3-2,3,4-trihydrofuryl acetate" "acetic acid [(3s)-5-oxo-3-oxolanyl] ester" );
standardThermochemistry
{
    dHf_298   -728930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     402.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-560350.0
}
