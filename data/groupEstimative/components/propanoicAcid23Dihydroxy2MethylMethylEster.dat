/*--------------------------------*- Choupo -*-----------------------*\
  Component: propanoic acid, 2,3-dihydroxy-2-methyl-, methyl ester  (C5H10O4, CAS 147501-85-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        propanoicAcid23Dihydroxy2MethylMethylEster;
formula     C5H10O4;
CAS         147501-85-7;
InChIKey    LDZHNDDCTKHCFG-UHFFFAOYSA-N;
MW          134.131;      // g/mol [origin=calculated method=formula-sum]
Tc          725.42;      // K   [origin=predictive method=joback]
Pc          45.043;      // bar [origin=predictive method=joback]
omega       1.3361;      // -   [origin=predictive method=lee-kesler]
Tb          553.35;      // K   [origin=predictive method=joback]
HvapTb      66193.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.861 0.61784 -0.0003862 8.27e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 2; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group C; count 1; } { group OH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "methyl 2-methyl-2,3-bis(oxidanyl)propanoate" "methyl 2-methylglycerate" "(2s)-2,3-dihydroxy-2-methyl-propanoic acid methyl ester" "propanoic acid, 2,3-dihydroxy-2-methyl-, methyl ester, (2r)-" "propanoic acid,2,3-dihydroxy-2-methyl-, methyl ester, (2s)-" "2-methylglyceric acid methyl ester" "methyl 2,3-dihydroxy-2-methylpropanoate" );
gibbsFormation
{
    dHf_298   -777020.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     464.94;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-589950.0
    phase     gas;
}
