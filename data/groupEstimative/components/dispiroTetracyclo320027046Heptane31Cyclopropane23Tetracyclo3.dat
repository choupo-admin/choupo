/*--------------------------------*- Choupo -*-----------------------*\
  Component: (dispiro(tetracyclo(3.2.0.02,7.04,6)heptane-3,1'-cyclopropane-2',3''-tetracyclo(3.2.0.02,7.04,6)heptane)  (C15H14, CAS 73050-58-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dispiroTetracyclo320027046Heptane31Cyclopropane23Tetracyclo3;
formula     C15H14;
CAS         73050-58-5;
InChIKey    QGGHADUOSDKJIR-UHFFFAOYSA-N;
MW          194.277;      // g/mol [origin=calculated method=formula-sum]
Tc          739.45;      // K   [origin=predictive method=joback]
Pc          28.812;      // bar [origin=predictive method=joback]
omega       0.5771;      // -   [origin=predictive method=lee-kesler]
Tb          529.35;      // K   [origin=predictive method=joback]
HvapTb      42290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-471.76 3.3534 -0.004119 1.8748e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH; count 12; } { group C; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 12; } { group C_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(dispiro[tetracyclo[3.2.0.02,7.04,6]heptane-3,1'-cyclopropane-2',3''-tetracyclo[3.2.0.02,7.04,6]heptane)" );
gibbsFormation
{
    dHf_298   304970.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     -383.91;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=717840.0
    phase     gas;
}
