/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4'-morpholinoacetophenone  (C12H15NO2, CAS 39910-98-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Morpholinoacetophenone;
formula     C12H15NO2;
CAS         39910-98-0;
InChIKey    AKQWEDMTPCAESO-UHFFFAOYSA-N;
MW          205.257;      // g/mol [origin=calculated method=formula-sum]
Tc          853.34;      // K   [origin=predictive method=joback]
Pc          31.245;      // bar [origin=predictive method=joback]
omega       0.7001;      // -   [origin=predictive method=lee-kesler]
Tb          619.03;      // K   [origin=predictive method=joback]
HvapTb      59109.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-80.06 1.25652 -0.00085596 2.1956e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 4; } { group AC; count 2; } { group CH3CO; count 1; } { group FCH2O; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O_ring; count 1; } { group CdO; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-morpholin-4-ylphenyl)ethanone" "4-morpholinoacetophenone" "p-morpholinoacetophenone" "p-morpholino acetophenone" "1-(4-morpholinophenyl)ethanone" "1-acetyl-4-morpholin-4-ylbenzene" "para-morpholinoacetophenone" "akqwedmtpcaeso-uhfffaoysa-" "1-[4-(4-morpholinyl)phenyl]ethanone" "1-(4-morpholin-4-yl-phenyl)-ethanone" "ethanone, 1-[4-(4-morpholinyl)phenyl]-" "1-[4-(morpholin-4-yl)phenyl]ethan-1-one" );
standardThermochemistry
{
    dHf_298   -162180.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     494.24;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=92940.0
}
