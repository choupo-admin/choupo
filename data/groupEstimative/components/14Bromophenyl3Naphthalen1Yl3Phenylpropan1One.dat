/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-(4-bromophenyl)-3-(naphthalen-1-yl)-3-phenylpropan-1-one  (C25H19BrO, CAS 5472-05-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Bromophenyl3Naphthalen1Yl3Phenylpropan1One;
formula     C25H19BrO;
CAS         5472-05-9;
InChIKey    DZSMNBIDMCHTGR-UHFFFAOYSA-N;
MW          415.33;      // g/mol [origin=calculated method=formula-sum]
Tc          1274.42;      // K   [origin=predictive method=joback]
Pc          19.407;      // bar [origin=predictive method=joback]
omega       1.0674;      // -   [origin=predictive method=lee-kesler]
Tb          1000.17;      // K   [origin=predictive method=joback]
HvapTb      93829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-110.529 2.0355 -0.00148834 4.1866e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 16; } { group AC; count 5; } { group ACCH; count 1; } { group CH2CO; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 16; } { group dC_ring; count 6; } { group Br; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-(4-bromophenyl)-3-naphthalen-1-yl-3-phenyl-propan-1-one" "beta-phenyl, beta-1-naphthyl p-bromopropiophenone" "1-(4-bromophenyl)-3-naphthalen-1-yl-3-phenylpropan-1-one" "1-propanone,1-(4-bromophenyl)-3-(1-naphthalenyl)-3-phenyl-" );
standardThermochemistry
{
    dHf_298   226860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     757.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=467200.0
}
