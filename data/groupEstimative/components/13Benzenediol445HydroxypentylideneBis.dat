/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,3-benzenediol, 4,4'-(5-hydroxypentylidene)bis-  (C17H20O5, CAS 67828-51-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13Benzenediol445HydroxypentylideneBis;
formula     C17H20O5;
CAS         67828-51-7;
InChIKey    INPTVGAWRSNOSM-UHFFFAOYSA-N;
MW          304.342;      // g/mol [origin=calculated method=formula-sum]
Tc          1304.66;      // K   [origin=predictive method=joback]
Pc          44.922;      // bar [origin=predictive method=joback]
omega       2.1665;      // -   [origin=predictive method=lee-kesler]
Tb          1056.14;      // K   [origin=predictive method=joback]
HvapTb      126335.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-112.446 2.1193 -0.00202244 7.838e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group ACH; count 6; } { group AC; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group CH; count 1; } { group dCH_ring; count 6; } { group dC_ring; count 6; } { group OH; count 1; } { group OH_phenol; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-[2,4-bis(oxidanyl)phenyl]-5-oxidanyl-pentyl]benzene-1,3-diol" "4,4'-(5-hydroxypentylidene)bisresorcinol" "5,5-bis(2',4'-dihydroxyphenyl)-1-pentanol" "4-[1-(2,4-dihydroxyphenyl)-5-hydroxypentyl]benzene-1,3-diol" );
gibbsFormation
{
    dHf_298   -787900.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     752.58;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-440660.0
    phase     gas;
}
