/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-bromopentanenitrile  (C5H8BrN, CAS 14470-12-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        4Bromopentanenitrile;
formula     C5H8BrN;
CAS         14470-12-3;
InChIKey    HCHUIWDKAUWPJE-UHFFFAOYSA-N;
MW          162.03;      // g/mol [origin=calculated method=formula-sum]
Tc          694.84;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.5106;      // -   [origin=predictive method=lee-kesler]
Tb          481.80;      // K   [origin=predictive method=joback]
HvapTb      43249.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (21.852 0.45772 -0.0002918 7.56e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group CH2CN; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group CH; count 1; } { group Br; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-bromanylpentanenitrile" "pentanenitrile, 4-bromo-" "4-bromovaleronitrile" );
standardThermochemistry
{
    dHf_298   39400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     398.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=136280.0
}
