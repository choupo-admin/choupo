/*--------------------------------*- Choupo -*-----------------------*\
  Component: tetravinylsilane  (C8H12Si, CAS 1112-55-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C8H12Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        tetravinylsilane;
formula     C8H12Si;
CAS         1112-55-6;
InChIKey    UFHILTCGAOPTOV-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          136.269;      // g/mol [origin=calculated method=formula-sum]
Tc          555.00;      // K   [origin=predictive method=joback]
Pc          26.625;      // bar [origin=predictive method=joback]
omega       0.2193;      // -   [origin=predictive method=lee-kesler]
Tb          370.76;      // K   [origin=predictive method=joback]
HvapTb      31016.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.47 0.4776 -8.82e-05 -6.36e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 4; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 4; } { group dCH; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetrakis(ethenyl)silane" "silane, tetraethenyl-" "silane, tetravinyl-" "silane, tetravinyl- (8ci)" );
standardThermochemistry
{
    dHf_298   181650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     575.69;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=263080.0
}
