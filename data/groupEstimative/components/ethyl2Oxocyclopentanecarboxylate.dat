/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-oxocyclopentanecarboxylate  (C8H12O3, CAS 611-10-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Oxocyclopentanecarboxylate;
formula     C8H12O3;
CAS         611-10-9;
InChIKey    JHZPNBKZPAWCJD-UHFFFAOYSA-N;
MW          156.181;      // g/mol [origin=calculated method=formula-sum]
Tc          740.71;      // K   [origin=predictive method=joback]
Pc          32.064;      // bar [origin=predictive method=joback]
omega       0.5577;      // -   [origin=predictive method=lee-kesler]
Tb          523.96;      // K   [origin=predictive method=joback]
HvapTb      45313.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.029 0.67242 -0.0002002 -4.66e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH; count 1; } { group CH2CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH2_ring; count 3; } { group CH_ring; count 1; } { group CdO_ring; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-oxidanylidenecyclopentane-1-carboxylate" "2-carbethoxycyclopentanone" "ethyl cyclopentanone-2-carboxylate" "ethyl 2-oxocyclopentane-1-carboxylate" "2-(ethoxycarbonyl)cyclopentanone" ".alpha.-(carboethoxy)cyclopentanone" "ethyl2-oxocyclopentanecarboxylate" "2-ethoxy-carbonyl-cyclopentanone" "cyclopentanecarboxylic acid, 2-oxo-, ethyl ester" "2-(ethoxycarbonyl)cyclopentan-1-one" "ethyl 2-cyclopentanone-1-carboxylate" "2-cyclopentanonecarboxylic acid ethyl ester" );
gibbsFormation
{
    dHf_298   -602950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     389.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-379930.0
    phase     gas;
}
