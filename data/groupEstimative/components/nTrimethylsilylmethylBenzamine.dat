/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(trimethylsilylmethyl)benzamine  (C11H19NSi, CAS 53215-95-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C11H19NSi (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nTrimethylsilylmethylBenzamine;
formula     C11H19NSi;
CAS         53215-95-5;
InChIKey    WECLUYCAWLJMKM-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          193.365;      // g/mol [origin=calculated method=formula-sum]
Tc          739.63;      // K   [origin=predictive method=joback]
Pc          23.795;      // bar [origin=predictive method=joback]
omega       0.4865;      // -   [origin=predictive method=lee-kesler]
Tb          529.53;      // K   [origin=predictive method=joback]
HvapTb      49086.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-1.408 0.83996 -0.0002396 -6.15e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH2NH; count 1; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenyl-n-(trimethylsilylmethyl)methanamine" "n-(trimethylsilylmethyl)benzylamine" "n-[(trimethylsilyl)methyl]benzylamine" "n-benzyl-1-(trimethylsilyl)methylamine" "benzyl[(trimethylsilyl)methyl]amine" "n-benzylaminomethyltrimethylsilane" "phenyl-n-((trimethylsilyl)methyl)methanamine" "n-benzyl-1-(trimethylsilyl)methanamine" "benzenemethanamine,n-[(trimethylsilyl)methyl]-" "n-benzyl-n-[(trimethylsilyl)methyl]amine" "n-[(trimethylsilyl)methyl]-benzenemethanamine" "benzenemethanamine, n-[(trimethylsilyl)methyl]-" );
standardThermochemistry
{
    dHf_298   -91990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     645.2;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=138780.0
}
