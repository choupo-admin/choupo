/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-4-phenylbut-3-en-2-ol  (C11H14O, CAS 57132-28-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl4Phenylbut3En2Ol;
formula     C11H14O;
CAS         57132-28-2;
InChIKey    AHTMRLFEKXDXJS-UHFFFAOYSA-N;
MW          162.232;      // g/mol [origin=calculated method=formula-sum]
Tc          780.89;      // K   [origin=predictive method=joback]
Pc          31.562;      // bar [origin=predictive method=joback]
omega       0.7609;      // -   [origin=predictive method=lee-kesler]
Tb          571.07;      // K   [origin=predictive method=joback]
HvapTb      57697.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-74.38 1.14974 -0.0008918 2.743e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group CH=CH; count 1; } { group ACH; count 5; } { group AC; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dCH; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methyl-4-phenyl-but-3-en-2-ol" "3-buten-2-ol, 2-methyl-4-phenyl-, (3e)-" );
gibbsFormation
{
    dHf_298   -77600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     483.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=100390.0
    phase     gas;
}
