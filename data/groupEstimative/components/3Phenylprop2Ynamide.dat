/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-phenylprop-2-ynamide  (C9H7NO, CAS 7223-30-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Phenylprop2Ynamide;
formula     C9H7NO;
CAS         7223-30-5;
InChIKey    HJZZEVFDPBDIDQ-UHFFFAOYSA-N;
MW          145.161;      // g/mol [origin=calculated method=formula-sum]
Tc          826.73;      // K   [origin=predictive method=joback]
Pc          46.214;      // bar [origin=predictive method=joback]
omega       0.5511;      // -   [origin=predictive method=lee-kesler]
Tb          567.60;      // K   [origin=predictive method=joback]
HvapTb      57443.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.79 0.664 -0.00042956 1.0234e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group C_C; count 1; } { group CONH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group tC; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group CdO; count 1; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "phenylpropiolamide" "3-phenylpropiolamide" "2-propynamide, 3-phenyl-" "3-phenylpropynoic acid amide" "3-phenyl-prop-2-ynoic acid amide" );
gibbsFormation
{
    dHf_298   200950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     450.19;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=277640.0
    phase     gas;
}
