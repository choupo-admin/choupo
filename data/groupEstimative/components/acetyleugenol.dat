/*--------------------------------*- Choupo -*-----------------------*\
  Component: acetyleugenol  (C12H14O3, CAS 93-28-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        acetyleugenol;
formula     C12H14O3;
CAS         93-28-7;
InChIKey    SCCDQYPEOIRVGX-UHFFFAOYSA-N;
MW          206.241;      // g/mol [origin=calculated method=formula-sum]
Tc          795.75;      // K   [origin=predictive method=joback]
Pc          24.053;      // bar [origin=predictive method=joback]
omega       0.6901;      // -   [origin=predictive method=lee-kesler]
Tb          588.12;      // K   [origin=predictive method=joback]
HvapTb      55053.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (34.591 0.80794 -0.00034342 1.28e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 1; } { group ACH; count 3; } { group AC; count 2; } { group ACCH2; count 1; } { group CH3COO; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2-methoxy-4-prop-2-enyl-phenyl) ethanoate" "eugenyl acetate" "aceteugenol" "acetyl eugenol" "4-allyl-2-methoxyphenyl acetate" "phenol, 2-methoxy-4-(2-propenyl)-, acetate" "phenol, 4-allyl-2-methoxy-, acetate" "4-allyl-2-methoxyphenol acetate" "1-acetoxy-2-methoxy-4-allylbenzene" "1,3,4-eugenol acetate" "2-methoxy-4-(2-propenyl)phenyl acetate" "2-methoxy-4-(2-propen-1-yl)phenyl acetate" );
gibbsFormation
{
    dHf_298   -401490.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     562.62;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-184220.0
    phase     gas;
}
