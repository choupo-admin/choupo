/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-tert-butyl-2,2,5-trimethylhex-3-ene  (C13H26, CAS 50787-12-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3TertButyl225Trimethylhex3Ene;
formula     C13H26;
CAS         50787-12-7;
InChIKey    QAJPKKJZLRFSID-UHFFFAOYSA-N;
MW          182.351;      // g/mol [origin=calculated method=formula-sum]
Tc          688.86;      // K   [origin=predictive method=joback]
Pc          17.909;      // bar [origin=predictive method=joback]
omega       0.3614;      // -   [origin=predictive method=lee-kesler]
Tb          494.18;      // K   [origin=predictive method=joback]
HvapTb      41590.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-73.43 1.51636 -0.0011163 3.36e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 8; } { group CH; count 1; } { group C; count 2; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 8; } { group CH; count 1; } { group C; count 2; } { group dCH; count 1; } { group dC; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-tert-butyl-2,2,5-trimethyl-hex-3-ene" "2,2,5-trimethyl-3-(t-butyl)-3-hexene" "((ch3)3c)2c=chch(ch3)2" );
gibbsFormation
{
    dHf_298   -227000.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     564.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=133490.0
    phase     gas;
}
