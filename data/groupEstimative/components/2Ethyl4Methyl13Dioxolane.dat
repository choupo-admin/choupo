/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethyl-4-methyl-1,3-dioxolane  (C6H12O2, CAS 4359-46-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Ethyl4Methyl13Dioxolane;
formula     C6H12O2;
CAS         4359-46-0;
InChIKey    CSZCLQLJVFLXLI-UHFFFAOYSA-N;
MW          116.16;      // g/mol [origin=calculated method=formula-sum]
Tc          597.89;      // K   [origin=predictive method=joback]
Pc          36.072;      // bar [origin=predictive method=joback]
omega       0.3499;      // -   [origin=predictive method=lee-kesler]
Tb          401.39;      // K   [origin=predictive method=joback]
HvapTb      37918.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-22.469 0.67304 -0.0003468 5.41e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH-O; count 1; } { group FCH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dioxolane, 2-ethyl-4-methyl-" "propanal, cyclic 1-methyl-1,2-ethanediyl acetal" "agn-pc-03f40m" "1,3-dioxolane,2-ethyl-4-methyl-" "cis-2-thyl-4-methyl-1,3-dioxolane" "2-ethyl-4-methyl-1,3-dioxolane cis-" "1,3-dioxolane, 2-ethyl-4-methyl-, cis-" "2-ethyl-4-methyl-1,3-dioxolane;propanal, cyclic 1-methyl-1,2-ethanediyl acetal" );
standardThermochemistry
{
    dHf_298   -391030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     194.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-143760.0
}
