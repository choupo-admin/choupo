/*--------------------------------*- Choupo -*-----------------------*\
  Component: (3s,5s)-3-acetyl-5-(prop-2-enoxymethyl)oxolan-2-one  (C10H14O4, CAS 72269-65-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3s5s3Acetyl5Prop2EnoxymethylOxolan2One;
formula     C10H14O4;
CAS         72269-65-9;
InChIKey    LDUCJUWVVJOBAY-IUCAKERBSA-N;
MW          198.218;      // g/mol [origin=calculated method=formula-sum]
Tc          754.52;      // K   [origin=predictive method=joback]
Pc          25.303;      // bar [origin=predictive method=joback]
omega       0.7701;      // -   [origin=predictive method=lee-kesler]
Tb          561.66;      // K   [origin=predictive method=joback]
HvapTb      53351.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.772 0.91222 -0.0004836 7.536e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH; count 2; } { group CH2=CH; count 1; } { group CH3CO; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 2; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 1; } { group CH_ring; count 2; } { group O; count 1; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(3s,5s)-3-ethanoyl-5-(prop-2-enoxymethyl)oxolan-2-one" "3-acetyldihydro-5-((2-propenyloxy)methyl)-2(3h)-furanone" "pentonic acid, 2-acetyl-2,3-dideoxy-5-o-2-propen-1-yl-, gamma-lactone" );
gibbsFormation
{
    dHf_298   -633920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     497.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-370090.0
    phase     gas;
}
