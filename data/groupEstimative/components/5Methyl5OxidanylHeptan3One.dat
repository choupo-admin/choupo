/*--------------------------------*- Choupo -*-----------------------*\
  Component: 5-methyl-5-oxidanyl-heptan-3-one  (C8H16O2, CAS 39121-37-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        5Methyl5OxidanylHeptan3One;
formula     C8H16O2;
CAS         39121-37-4;
InChIKey    NGVUNKBOBWPIOQ-UHFFFAOYSA-N;
MW          144.214;      // g/mol [origin=calculated method=formula-sum]
Tc          703.67;      // K   [origin=predictive method=joback]
Pc          30.457;      // bar [origin=predictive method=joback]
omega       0.9001;      // -   [origin=predictive method=lee-kesler]
Tb          525.46;      // K   [origin=predictive method=joback]
HvapTb      55531.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-16.207 0.89566 -0.0005949 1.5666e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 1; } { group OH; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group C; count 1; } { group OH; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
gibbsFormation
{
    dHf_298   -482010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     506.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-246420.0
    phase     gas;
}
