/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,9,10-octadecanetriol  (C18H38O3, CAS 7023-01-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1910Octadecanetriol;
formula     C18H38O3;
CAS         7023-01-0;
InChIKey    RGQVEMVVEFTMJD-UHFFFAOYSA-N;
MW          302.499;      // g/mol [origin=calculated method=formula-sum]
Tc          1092.65;      // K   [origin=predictive method=joback]
Pc          14.197;      // bar [origin=predictive method=joback]
omega       1.2080;      // -   [origin=predictive method=lee-kesler]
Tb          887.10;      // K   [origin=predictive method=joback]
HvapTb      104923.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-0.965 1.82762 -0.001053 2.314e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 2; } { group OH; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group CH; count 2; } { group OH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadecane-1,9,10-triol" "1,9,10-trihydroxyoctadecane;9,10-dihydroxystearyl alcohol" );
standardThermochemistry
{
    dHf_298   -882100.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     990.75;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-314660.0
}
