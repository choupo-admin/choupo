/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenoxyacetone  (C9H10O2, CAS 621-87-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenoxyacetone;
formula     C9H10O2;
CAS         621-87-4;
InChIKey    QWAVNXZAQASOML-UHFFFAOYSA-N;
MW          150.177;      // g/mol [origin=calculated method=formula-sum]
Tc          724.74;      // K   [origin=predictive method=joback]
Pc          34.399;      // bar [origin=predictive method=joback]
omega       0.5434;      // -   [origin=predictive method=lee-kesler]
Tb          508.49;      // K   [origin=predictive method=joback]
HvapTb      47060.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-6.339 0.68872 -0.0003673 5.756e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 5; } { group AC; count 1; } { group CH3CO; count 1; } { group CH2O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group O; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-phenoxypropan-2-one" "2-propanone, 1-phenoxy-" "1-phenoxyacetone" "1-phenoxy-2-propanone" "phenoxymethyl methyl ketone" "phenoxy-2-propanone" "1-phenoxy-propan-2-one" "1-(phenoxy)propan-2-one" "qwavnxzaqasoml-uhfffaoysa-" );
gibbsFormation
{
    dHf_298   -237360.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     438.12;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-96610.0
    phase     gas;
}
