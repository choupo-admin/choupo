/*--------------------------------*- Choupo -*-----------------------*\
  Component: ccris 4647  (C11H21NO, CAS 10213-75-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ccris4647;
formula     C11H21NO;
CAS         10213-75-9;
InChIKey    HXBFULVLSKAGSQ-UHFFFAOYSA-N;
MW          183.295;      // g/mol [origin=calculated method=formula-sum]
Tc          757.44;      // K   [origin=predictive method=joback]
Pc          18.773;      // bar [origin=predictive method=joback]
omega       0.7486;      // -   [origin=predictive method=lee-kesler]
Tb          575.34;      // K   [origin=predictive method=joback]
HvapTb      52580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (33.707 0.92634 -0.0004358 5.81e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH; count 1; } { group CH2O; count 1; } { group CH2CN; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group CH; count 1; } { group O; count 1; } { group CN; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-(2-ethylhexoxy)propanenitrile" "3-[(2-ethylhexyl)oxy]propanenitrile" "propionitrile, 3-(2-ethylhexyloxy)-" "3-(2-ethylhexyloxy)propionitrile" "3-((2-ethylhexyl)oxy)propiononitrile" "propanenitrile, 3-((2-ethylhexyl)oxy)-" "propanenitrile, 3-[(2-ethylhexyl)oxy]-" "3-[(2-ethylhexyl)oxy]propionitrile" "3-(2-ethylhexyloxy)propannitril" "beta(2-ethyl hexoxy)propionitrile" "3-((ethylhexyl)oxy)propionitrile" "3-((ethylhexyl)oxy) propionitrile" );
gibbsFormation
{
    dHf_298   -242990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     592.33;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=67480.0
    phase     gas;
}
