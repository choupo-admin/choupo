/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,5,6,8,8-pentachlorooctyl 2,4,5-trichlorooctyl benzene-1,4-dicarboxylate  (C24H30Cl8O4, CAS 68515-61-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        45688Pentachlorooctyl245TrichlorooctylBenzene14Dicarboxylate;
formula     C24H30Cl8O4;
CAS         68515-61-7;
InChIKey    VYESZYDIRODEBT-UHFFFAOYSA-N;
MW          666.1;      // g/mol [origin=calculated method=formula-sum]
Tc          1463.54;      // K   [origin=predictive method=joback]
Pc          8.470;      // bar [origin=predictive method=joback]
omega       0.7972;      // -   [origin=predictive method=lee-kesler]
Tb          1193.18;      // K   [origin=predictive method=joback]
HvapTb      119134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (103.638 2.13152 -0.00124236 2.293e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group ACH; count 4; } { group AC; count 2; } { group CHCl; count 6; } { group CHCl2; count 1; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH; count 7; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 8; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o1-[4,5,6,8,8-pentakis(chloranyl)octyl] o4-[2,4,5-tris(chloranyl)octyl] benzene-1,4-dicarboxylate" "chlorinated dioctyl terephthalate" "dioctyl terephthalate, chlorinated" "1,4-benzenedicarboxylic acid, dioctyl ester, chlorinated" "1-o-(4,5,6,8,8-pentachlorooctyl) 4-o-(2,4,5-trichlorooctyl) benzene-1,4-dicarboxylate" );
gibbsFormation
{
    dHf_298   -1111070.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1281.53;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-479280.0
    phase     gas;
}
