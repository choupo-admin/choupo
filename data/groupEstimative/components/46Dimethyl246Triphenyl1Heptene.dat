/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,6-dimethyl-2,4,6-triphenyl-1-heptene  (C27H30, CAS 62604-62-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        46Dimethyl246Triphenyl1Heptene;
formula     C27H30;
CAS         62604-62-0;
InChIKey    OAMAKKTXAPRVDG-UHFFFAOYSA-N;
MW          354.537;      // g/mol [origin=calculated method=formula-sum]
Tc          1142.56;      // K   [origin=predictive method=joback]
Pc          13.398;      // bar [origin=predictive method=joback]
omega       0.7081;      // -   [origin=predictive method=lee-kesler]
Tb          887.50;      // K   [origin=predictive method=joback]
HvapTb      79342.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-174.998 2.56366 -0.0019074 5.496e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 2; } { group CH2=C; count 1; } { group ACH; count 15; } { group AC; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 2; } { group C; count 2; } { group dCH2; count 1; } { group dC; count 1; } { group dCH_ring; count 15; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(4,6-dimethyl-2,6-diphenyl-hept-1-en-4-yl)benzene" "benzene, 1,1',1''-(1,1,3-trimethyl-5-methylene-1,3,5-pentanetriyl)tris-" "(4,6-dimethyl-2,6-diphenylhept-1-en-4-yl)benzene" "1,1',1''-(1,1,3-trimethyl-5-methylenepentane-1,3,5-triyl)tribenzene" );
standardThermochemistry
{
    dHf_298   207120.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     801.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=598660.0
}
