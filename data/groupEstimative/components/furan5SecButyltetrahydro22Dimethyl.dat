/*--------------------------------*- Choupo -*-----------------------*\
  Component: furan, 5-sec-butyltetrahydro-2,2-dimethyl-  (C10H20O, CAS 33978-70-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        furan5SecButyltetrahydro22Dimethyl;
formula     C10H20O;
CAS         33978-70-0;
InChIKey    KGTIVYATFDLQDC-UHFFFAOYSA-N;
MW          156.269;      // g/mol [origin=calculated method=formula-sum]
Tc          667.22;      // K   [origin=predictive method=joback]
Pc          25.328;      // bar [origin=predictive method=joback]
omega       0.3845;      // -   [origin=predictive method=lee-kesler]
Tb          465.76;      // K   [origin=predictive method=joback]
HvapTb      40773.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-95.099 1.35388 -0.0011141 4.079e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 1; } { group C; count 1; } { group CH-O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 1; } { group CH2_ring; count 2; } { group CH_ring; count 1; } { group C_ring; count 1; } { group O_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "5-butan-2-yl-2,2-dimethyl-oxolane" "furan, tetrahydro-2,2-dimethyl-5-(1-methylpropyl)-" "5-butan-2-yl-2,2-dimethyloxolane" );
gibbsFormation
{
    dHf_298   -331630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     461.44;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-31890.0
    phase     gas;
}
