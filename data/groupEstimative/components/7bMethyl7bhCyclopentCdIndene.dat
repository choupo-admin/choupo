/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7b-methyl-7bh-cyclopent[cd]indene  (C12H10, CAS 79644-47-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7bMethyl7bhCyclopentCdIndene;
formula     C12H10;
CAS         79644-47-6;
InChIKey    IYMNWEQUDFDENP-UHFFFAOYSA-N;
MW          154.212;      // g/mol [origin=calculated method=formula-sum]
Tc          764.54;      // K   [origin=predictive method=joback]
Pc          35.263;      // bar [origin=predictive method=joback]
omega       0.4272;      // -   [origin=predictive method=lee-kesler]
Tb          523.24;      // K   [origin=predictive method=joback]
HvapTb      45302.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-149.06 1.46372 -0.00157548 6.704e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group CH=CH; count 2; } { group CH=C; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C_ring; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7b-methyl-7bh-cyclopent(cd)indene" "7b-methyl-7bh-cyclopenta[cd]indene" );
standardThermochemistry
{
    dHf_298   225480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     341.36;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=339050.0
}
