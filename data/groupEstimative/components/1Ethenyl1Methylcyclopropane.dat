/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-ethenyl-1-methylcyclopropane  (C6H10, CAS 16906-27-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Ethenyl1Methylcyclopropane;
formula     C6H10;
CAS         16906-27-7;
InChIKey    IVEZRSRZCUPBIF-UHFFFAOYSA-N;
MW          82.146;      // g/mol [origin=calculated method=formula-sum]
Tc          531.76;      // K   [origin=predictive method=joback]
Pc          40.210;      // bar [origin=predictive method=joback]
omega       0.2100;      // -   [origin=predictive method=lee-kesler]
Tb          340.54;      // K   [origin=predictive method=joback]
HvapTb      27042.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-105.79 0.99662 -0.0010783 4.749e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 1; } { group dCH; count 1; } { group CH2_ring; count 2; } { group C_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-ethenyl-1-methyl-cyclopropane" "cyclopropane, 1-ethenyl-1-methyl-" "cyclopropane, 1-methyl-1-vinyl-" );
gibbsFormation
{
    dHf_298   46300.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=142740.0
    phase     gas;
}
