/*--------------------------------*- Choupo -*-----------------------*\
  Component: undecyl methacrylate  (C15H28O2, CAS 16493-35-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        undecylMethacrylate;
formula     C15H28O2;
CAS         16493-35-9;
InChIKey    KRLHYNPADOCLAJ-UHFFFAOYSA-N;
MW          240.387;      // g/mol [origin=calculated method=formula-sum]
Tc          767.02;      // K   [origin=predictive method=joback]
Pc          14.725;      // bar [origin=predictive method=joback]
omega       0.7995;      // -   [origin=predictive method=lee-kesler]
Tb          597.58;      // K   [origin=predictive method=joback]
HvapTb      55801.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.98 1.35394 -0.0007228 1.294e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 10; } { group CH2=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 10; } { group dCH2; count 1; } { group dC; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "undecyl 2-methylprop-2-enoate" "2-propenoic acid, 2-methyl-, undecyl ester" "methacrylicacid, undecyl ester (8ci); undecyl alcohol, methacrylate (8ci); undecylmethacrylate" );
standardThermochemistry
{
    dHf_298   -554570.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     782.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-155660.0
}
