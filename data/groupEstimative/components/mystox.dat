/*--------------------------------*- Choupo -*-----------------------*\
  Component: mystox  (C18H23Cl5O2, CAS 3772-94-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        mystox;
formula     C18H23Cl5O2;
CAS         3772-94-9;
InChIKey    MKNJWAXSYGAMGJ-UHFFFAOYSA-N;
MW          448.63;      // g/mol [origin=calculated method=formula-sum]
Tc          1124.03;      // K   [origin=predictive method=joback]
Pc          12.140;      // bar [origin=predictive method=joback]
omega       1.0169;      // -   [origin=predictive method=lee-kesler]
Tb          908.39;      // K   [origin=predictive method=joback]
HvapTb      90580.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (113.98 1.31662 -0.0006588 9.19e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 9; } { group AC; count 1; } { group CH2COO; count 1; } { group ACCl; count 5; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group dC_ring; count 6; } { group Cl; count 5; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[2,3,4,5,6-pentakis(chloranyl)phenyl] dodecanoate" "pentachlorophenyl laurate" "mystox lpl" "mystox lsd" "mystox lsl" "pentachlorophenyl dodecanoate" "dodecanoic acid, pentachlorophenyl ester" "lauryl pentachlorophenate" "pentachlorophenol laurate" "lauroyl pentachlorophenate" "dodecanoic acid, 2,3,4,5,6-pentachlorophenyl ester" "lauric acid, pentachlorophenyl ester (6ci,7ci,8ci)" );
standardThermochemistry
{
    dHf_298   -631650.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     938.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-205080.0
}
