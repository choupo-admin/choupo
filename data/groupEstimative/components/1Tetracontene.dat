/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-Tetracontene  (C40H80, CAS 61868-18-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Tetracontene;
formula     C40H80;
CAS         61868-18-6;
InChIKey    YQPZJBVEKZISEF-UHFFFAOYSA-N;
MW          561.08;      // g/mol [origin=calculated method=formula-sum]
Tc          1478.56;      // K   [origin=predictive method=joback]
Pc          3.975;      // bar [origin=predictive method=joback]
omega       -0.2467;      // -   [origin=predictive method=lee-kesler]
Tb          1111.48;      // K   [origin=predictive method=joback]
HvapTb      103964.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-36.463 3.78382 -0.0021751 4.822e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 37; } { group CH2=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 37; } { group dCH2; count 1; } { group dCH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tetracont-1-ene" "Q27253680" );
gibbsFormation
{
    dHf_298   -743500.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1709.49;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=373760.0
    phase     gas;
}
