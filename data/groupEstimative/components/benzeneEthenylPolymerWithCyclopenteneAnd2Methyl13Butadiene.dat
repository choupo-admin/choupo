/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzene, ethenyl-, polymer with cyclopentene and 2-methyl-1,3-butadiene  (C18H24, CAS 98085-64-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzeneEthenylPolymerWithCyclopenteneAnd2Methyl13Butadiene;
formula     C18H24;
CAS         98085-64-4;
InChIKey    YDSLFQRJPBAQFA-UHFFFAOYSA-N;
MW          240.39;      // g/mol [origin=calculated method=formula-sum]
Tc          890.83;      // K   [origin=predictive method=joback]
Pc          17.203;      // bar [origin=predictive method=joback]
omega       0.4311;      // -   [origin=predictive method=lee-kesler]
Tb          649.95;      // K   [origin=predictive method=joback]
HvapTb      57454.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-33.05 1.26462 -0.00039808 -8e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 3; } { group CH2=CH; count 2; } { group CH=CH; count 1; } { group CH2=C; count 1; } { group ACH; count 5; } { group AC; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH2; count 3; } { group dCH; count 2; } { group dC; count 1; } { group CH2_ring; count 3; } { group dCH_ring; count 7; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "cyclopentene;ethenylbenzene;2-methylbuta-1,3-diene" );
standardThermochemistry
{
    dHf_298   103540.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     902.67;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=332760.0
}
