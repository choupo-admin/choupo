/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,4-methanonaphthalene,1,4-dihydro-6-iodo-  (C11H9I, CAS 63509-78-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        14Methanonaphthalene14Dihydro6Iodo;
formula     C11H9I;
CAS         63509-78-4;
InChIKey    DTDDVIVRIWDHCK-UHFFFAOYSA-N;
MW          268.093;      // g/mol [origin=calculated method=formula-sum]
Tc          855.40;      // K   [origin=predictive method=joback]
Pc          33.645;      // bar [origin=predictive method=joback]
omega       0.4409;      // -   [origin=predictive method=lee-kesler]
Tb          589.43;      // K   [origin=predictive method=joback]
HvapTb      52999.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-88.31 1.1453 -0.0010272 3.68e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 1; } { group CH=CH; count 1; } { group ACH; count 3; } { group AC; count 1; } { group ACCH; count 2; } { group I; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 1; } { group CH_ring; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group I; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "dtddvivriwdhck-uhfffaoysa-" "1,4-methanonaphthalene, 1,4-dihydro-6-iodo-" );
standardThermochemistry
{
    dHf_298   229630.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     283.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=356570.0
}
