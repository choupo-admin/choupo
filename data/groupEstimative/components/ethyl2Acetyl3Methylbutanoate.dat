/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethyl 2-acetyl-3-methylbutanoate  (C9H16O3, CAS 1522-46-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethyl2Acetyl3Methylbutanoate;
formula     C9H16O3;
CAS         1522-46-9;
InChIKey    DMIFFKCVURTPTG-UHFFFAOYSA-N;
MW          172.224;      // g/mol [origin=calculated method=formula-sum]
Tc          704.29;      // K   [origin=predictive method=joback]
Pc          25.050;      // bar [origin=predictive method=joback]
omega       0.6619;      // -   [origin=predictive method=lee-kesler]
Tb          516.73;      // K   [origin=predictive method=joback]
HvapTb      49005.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.111 0.78788 -0.0003589 2.876e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 1; } { group CH; count 2; } { group CH3CO; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group CH; count 2; } { group CdO; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "ethyl 2-ethanoyl-3-methyl-butanoate" "ethyl 2-isopropylacetoacetate" "butanoic acid, 2-acetyl-3-methyl-, ethyl ester" "2-isopropylacetoacetic acid ethyl ester" "acetoacetic acid, 2-isopropyl-, ethyl ester" "ethyl .alpha.-isopropylacetoacetate" "ghl.pd_mitscher_leg0.994" "ethyl alpha-isopropylacetoacetate" "ethyl 2-acetyl-3-methylbutyrate" "2-acetyl-3-methyl-butyric acid ethyl ester" "ethyl-alpha-isopropylacetoacetate, pract" "butanoic acid,2-acetyl-3-methyl-, ethyl ester" );
standardThermochemistry
{
    dHf_298   -669510.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     565.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-419270.0
}
