/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4-(2,4-dimethyl-3-cyclohexen-1-yl)-3-buten-2-one  (C12H18O, CAS 4687-77-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        424Dimethyl3Cyclohexen1Yl3Buten2One;
formula     C12H18O;
CAS         4687-77-8;
InChIKey    RAGGPHXESKFCRO-UHFFFAOYSA-N;
MW          178.275;      // g/mol [origin=calculated method=formula-sum]
Tc          764.49;      // K   [origin=predictive method=joback]
Pc          23.519;      // bar [origin=predictive method=joback]
omega       0.5210;      // -   [origin=predictive method=lee-kesler]
Tb          551.21;      // K   [origin=predictive method=joback]
HvapTb      50084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-52.43 1.11596 -0.00063994 1.3066e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 2; } { group CH=CH; count 1; } { group CH=C; count 1; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group dCH; count 2; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group dCH_ring; count 1; } { group dC_ring; count 1; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-(2,4-dimethylcyclohex-3-en-1-yl)but-3-en-2-one" "3-buten-2-one, 4-(2,4-dimethyl-3-cyclohexen-1-yl)-" );
standardThermochemistry
{
    dHf_298   -206080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     527.14;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=38530.0
}
