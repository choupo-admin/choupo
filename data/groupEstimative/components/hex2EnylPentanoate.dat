/*--------------------------------*- Choupo -*-----------------------*\
  Component: hex-2-enyl pentanoate  (C11H20O2, CAS 56922-74-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hex2EnylPentanoate;
formula     C11H20O2;
CAS         56922-74-8;
InChIKey    WDXAMNXWZLXISB-UHFFFAOYSA-N;
MW          184.279;      // g/mol [origin=calculated method=formula-sum]
Tc          689.00;      // K   [origin=predictive method=joback]
Pc          20.346;      // bar [origin=predictive method=joback]
omega       0.6575;      // -   [origin=predictive method=lee-kesler]
Tb          513.66;      // K   [origin=predictive method=joback]
HvapTb      47445.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (4.116 1.01404 -0.0005638 1.1e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 5; } { group CH=CH; count 1; } { group CH2COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(e)-2-hexenyl valerate" "pentanoic acid, (2e)-2-hexen-1-yl ester" "[(z)-hex-2-enyl] pentanoate" "pentanoicacid, (2e)-2-hexenyl ester (9ci);pentanoic acid, 2-hexenyl ester, (e)-;trans-2-hexenyl pentanoate;trans-2-hexenyl valerate;(2e)-hex-2-en-1-yl pentanoate;" );
standardThermochemistry
{
    dHf_298   -470430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     629.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-188410.0
}
