/*--------------------------------*- Choupo -*-----------------------*\
  Component: nylidrin  (C19H25NO2, CAS 447-41-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nylidrin;
formula     C19H25NO2;
CAS         447-41-6;
InChIKey    PTGXAUBQBSGPKF-UHFFFAOYSA-N;
MW          299.414;      // g/mol [origin=calculated method=formula-sum]
Tc          1134.28;      // K   [origin=predictive method=joback]
Pc          22.633;      // bar [origin=predictive method=joback]
omega       1.4380;      // -   [origin=predictive method=lee-kesler]
Tb          909.33;      // K   [origin=predictive method=joback]
HvapTb      97405.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-92.078 1.93354 -0.00141716 4.178e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group ACH; count 9; } { group ACCH2; count 1; } { group ACCH; count 1; } { group OH; count 1; } { group ACOH; count 1; } { group CHNH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group CH; count 3; } { group dCH_ring; count 9; } { group dC_ring; count 3; } { group OH; count 1; } { group OH_phenol; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-[1-oxidanyl-2-(4-phenylbutan-2-ylamino)propyl]phenol" "buphenine" "nylidrinum" "buphenin" "nilidrine" "suprifen-psb" "verina" "buphenine [inn:ban]" "bupheninum [inn-latin]" "phenyl-sec-butyl norsuprifen" "arlidin" "dilatol" );
gibbsFormation
{
    dHf_298   -254340.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     772.7;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=124550.0
    phase     gas;
}
