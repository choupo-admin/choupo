/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n',n''-tributyl-1-methylsilanetriamine  (C13H33N3Si, CAS 16411-33-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C13H33N3Si (delta Si+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        nNNTributyl1Methylsilanetriamine;
formula     C13H33N3Si;
CAS         16411-33-9;
InChIKey    GJQSLHYMHWQOQY-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          259.513;      // g/mol [origin=calculated method=formula-sum]
Tc          822.76;      // K   [origin=predictive method=joback]
Pc          15.415;      // bar [origin=predictive method=joback]
omega       0.9485;      // -   [origin=predictive method=lee-kesler]
Tb          648.95;      // K   [origin=predictive method=joback]
HvapTb      64134.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (28.259 1.26128 -0.0004144 -4.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 6; } { group CH2NH; count 3; } { group Si; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 9; } { group NH; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-[bis(butylamino)-methyl-silyl]butan-1-amine" "tris(butylamino)methylsilane" "silanetriamine, n,n',n''-tributyl-1-methyl-" "1-methyl-n,n',n''-tributylsilanetriamine" "n-[bis(butylamino)-methylsilyl]butan-1-amine" );
gibbsFormation
{
    dHf_298   -262860.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     910.86;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=221990.0
    phase     gas;
}
