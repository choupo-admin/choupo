/*--------------------------------*- Choupo -*-----------------------*\
  Component: divinylacetylene  (C6H6, CAS 821-08-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        divinylacetylene;
formula     C6H6;
CAS         821-08-9;
InChIKey    AUBDSFLQOBEOPX-UHFFFAOYSA-N;
MW          78.114;      // g/mol [origin=calculated method=formula-sum]
Tc          536.92;      // K   [origin=predictive method=joback]
Pc          41.623;      // bar [origin=predictive method=joback]
omega       0.1772;      // -   [origin=predictive method=lee-kesler]
Tb          339.24;      // K   [origin=predictive method=joback]
HvapTb      29762.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.01 0.384 -0.00025626 7.398e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2=CH; count 2; } { group C_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 2; } { group dCH; count 2; } { group tC; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexa-1,5-dien-3-yne" "1,5-hexadien-3-yne" );
gibbsFormation
{
    dHf_298   355990.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     352.26;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=378120.0
    phase     gas;
}
