/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,3-dichlorophenyl isocyanate  (C7H3Cl2NO, CAS 41195-90-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23DichlorophenylIsocyanate;
formula     C7H3Cl2NO;
CAS         41195-90-8;
InChIKey    FYWJWWMKCARWQG-UHFFFAOYSA-N;
MW          188.007;      // g/mol [origin=calculated method=formula-sum]
Tc          776.03;      // K   [origin=predictive method=joback]
Pc          39.605;      // bar [origin=predictive method=joback]
omega       0.5385;      // -   [origin=predictive method=lee-kesler]
Tb          537.93;      // K   [origin=predictive method=joback]
HvapTb      53078.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group ACH; count 3; } { group AC; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:1
    joback ( { group dCd; count 1; } { group dCH_ring; count 3; } { group dC_ring; count 3; } { group Cl; count 2; } { group dO_oth; count 1; } { group Nd; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,2-bis(chloranyl)-3-isocyanato-benzene" "1,2-dichloro-3-isocyanatobenzene" "benzene, 1,2-dichloro-3-isocyanato-" "2,3-dichlorobenzenisocyanate" "benzene, dichloroisocyanato-" "fywjwwmkcarwqg-uhfffaoysa-" "benzene,1,2-dichloro-3-isocyanato-" "isocyanic acid 2,3-dichlorophenyl ester" "1,2-dichloro-3-isocyanatobenzene;2,3-dichlorophenyl isocyanate" );
