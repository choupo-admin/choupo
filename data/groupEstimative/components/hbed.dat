/*--------------------------------*- Choupo -*-----------------------*\
  Component: hbed  (C20H24N2O6, CAS 35998-29-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        hbed;
formula     C20H24N2O6;
CAS         35998-29-9;
InChIKey    GRUVVLWKPGIYEG-UHFFFAOYSA-N;
MW          388.42;      // g/mol [origin=calculated method=formula-sum]
Tc          1454.15;      // K   [origin=predictive method=joback]
Pc          24.900;      // bar [origin=predictive method=joback]
omega       1.7980;      // -   [origin=predictive method=lee-kesler]
Tb          1187.70;      // K   [origin=predictive method=joback]
HvapTb      129108.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.124 2.4046 -0.00200972 6.748e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group ACCH2; count 2; } { group ACOH; count 2; } { group CH2N; count 2; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group dCH_ring; count 8; } { group dC_ring; count 4; } { group OH_phenol; count 2; } { group COOH; count 2; } { group N; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-[2-hydroxy-2-oxoethyl-[(2-hydroxyphenyl)methyl]amino]ethyl-[(2-hydroxyphenyl)methyl]amino]ethanoic acid" "chel ii" "n,n'-bis(2-hydroxybenzyl)ethylenediamine-n,n'-diacetic acid" "glycine, n,n'-ethylenebis(n-salicyl-" "n,n'-1,2-ethanediylbis(n-((2-hydroxyphenyl)methyl)glycine)" "glycine, n,n'-1,2-ethanediylbis(n-((2-hydroxyphenyl)methyl)-" "2-[2-[carboxymethyl-[(2-hydroxyphenyl)methyl]amino]ethyl-[(2-hydroxyphenyl)methyl]amino]ethanoic acid" "bhn" "n,n'-bis(o-hydroxybenzyl)ethylenediamine-n,n'-diacetate" "n,n-bis[2-hydroxybenzyl]ethylenediamine-n,n-diacetic acid" "2,2'-{ethane-1,2-diylbis[(2-hydroxybenzyl)imino]}diacetic acid (non-preferred name)" "n,n'-di(2-hydroxybenzyl)ethylenediamine-n,n'-diacetic acid monohydrochloride hydrate,? hbed" );
standardThermochemistry
{
    dHf_298   -903170.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     913.56;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-433160.0
}
