/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethanolamine formate  (C5H13NO4, CAS 68391-54-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C5H13NO4 (delta H+1; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        diethanolamineFormate;
formula     C5H13NO4;
CAS         68391-54-8;
InChIKey    BOZAGLYGUSSJHG-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          151.162;      // g/mol [origin=calculated method=formula-sum]
Tc          874.68;      // K   [origin=predictive method=joback]
Pc          45.164;      // bar [origin=predictive method=joback]
omega       1.8562;      // -   [origin=predictive method=lee-kesler]
Tb          694.74;      // K   [origin=predictive method=joback]
HvapTb      83829.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (32.724 0.5707 -0.0002228 -2.2e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 3; } { group OH; count 2; } { group CH2NH; count 1; } { group HCOOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 4; } { group OH; count 2; } { group COOH; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-hydroxyethylamino)ethanol;methanoic acid" "formic acid, compd. with 2,2'-iminobis(ethanol) (1:1)" "formic acid, compound with 2,2'-iminobis(ethanol) (1:1)" "formic acid compd. with 2,2'-iminobis[ethanol] (1:1)" );
standardThermochemistry
{
    dHf_298   -803600.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     665.5;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-589320.0
}
