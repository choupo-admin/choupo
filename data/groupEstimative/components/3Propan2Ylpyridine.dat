/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-propan-2-ylpyridine  (C8H11N, CAS 6304-18-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Propan2Ylpyridine;
formula     C8H11N;
CAS         6304-18-3;
InChIKey    PUACTIIESPYWSI-UHFFFAOYSA-N;
MW          121.183;      // g/mol [origin=calculated method=formula-sum]
Tc          689.75;      // K   [origin=predictive method=joback]
Pc          36.910;      // bar [origin=predictive method=joback]
omega       0.3541;      // -   [origin=predictive method=lee-kesler]
Tb          462.58;      // K   [origin=predictive method=joback]
HvapTb      41500.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-29.91 0.7246 -0.00045506 1.108e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH; count 1; } { group C5H4N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 1; } { group Nd_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-isopropylpyridine" "(s)-3-(isopropyl)pyridine" "3-(1-methylethyl)-pyridine" "pyridine, 3-isopropyl-" "agn-pc-0dbere" "pyridine, 3-(1-methylethyl)-" );
gibbsFormation
{
    dHf_298   55590.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     364.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=203500.0
    phase     gas;
}
