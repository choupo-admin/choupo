/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methoxycyclohexan-1-ol  (C7H14O2, CAS 2979-24-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methoxycyclohexan1Ol;
formula     C7H14O2;
CAS         2979-24-0;
InChIKey    DCQQZLGQRIVCNH-UHFFFAOYSA-N;
MW          130.187;      // g/mol [origin=calculated method=formula-sum]
Tc          680.66;      // K   [origin=predictive method=joback]
Pc          37.045;      // bar [origin=predictive method=joback]
omega       0.7231;      // -   [origin=predictive method=lee-kesler]
Tb          489.24;      // K   [origin=predictive method=joback]
HvapTb      50385.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-32.35 0.73522 -0.000302 8.5e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 2; } { group OH; count 1; } { group CH3O; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group CH_ring; count 2; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-methoxycyclohexanol" "cyclohexanol, 2-methoxy-" "cyclohexanol, 2-methoxy-, trans-" "trans-2-methoxycyclohexanol" "cyclohexanol,2-methoxy-,cis-" "cyclohexanol,2-methoxy-,trans-" "cyclohexanol, 2-methoxy-, cis-" "(1r, 2r)-2-methoxycyclohexanol" "2-methoxycyclohexanol, mixture of cis and trans" );
gibbsFormation
{
    dHf_298   -438280.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     417.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-217020.0
    phase     gas;
}
