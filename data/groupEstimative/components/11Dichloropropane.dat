/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,1-dichloropropane  (C3H6Cl2, CAS 78-99-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        11Dichloropropane;
formula     C3H6Cl2;
CAS         78-99-9;
InChIKey    WIHMGGWNMISDNJ-UHFFFAOYSA-N;
MW          112.981;      // g/mol [origin=calculated method=formula-sum]
Tc          529.63;      // K   [origin=predictive method=joback]
Pc          40.466;      // bar [origin=predictive method=joback]
omega       0.2470;      // -   [origin=predictive method=lee-kesler]
Tb          342.66;      // K   [origin=predictive method=joback]
HvapTb      30654.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (24.261 0.30832 -0.0001834 4.2e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group CHCl2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group Cl; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1-bis(chloranyl)propane" "propylidene chloride" "propane, 1,1-dichloro-" "propylidene dichloride" "alpha,alpha-dichloropropane" "alpha,alpha-propylene dichloride" "propane, dichloro-" "propane, dichloro-(7ci,8ci,9ci)" );
standardThermochemistry
{
    dHf_298   -142010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     330.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-51920.0
}
