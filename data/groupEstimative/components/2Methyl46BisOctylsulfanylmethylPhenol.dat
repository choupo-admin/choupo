/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-methyl-4,6-bis(octylsulfanylmethyl)phenol  (C25H44OS2, CAS 110553-27-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2Methyl46BisOctylsulfanylmethylPhenol;
formula     C25H44OS2;
CAS         110553-27-0;
InChIKey    GAODDBNJCKQQDY-UHFFFAOYSA-N;
MW          424.746;      // g/mol [origin=calculated method=formula-sum]
Tc          1257.04;      // K   [origin=predictive method=joback]
Pc          10.181;      // bar [origin=predictive method=joback]
omega       0.9809;      // -   [origin=predictive method=lee-kesler]
Tb          1026.42;      // K   [origin=predictive method=joback]
HvapTb      101492.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (5.136 2.32434 -0.00140928 3.399e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 13; } { group ACH; count 2; } { group AC; count 1; } { group ACCH3; count 1; } { group ACCH2; count 1; } { group ACOH; count 1; } { group CH2S; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 16; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group OH_phenol; count 1; } { group S; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4,6-bis(octylthiomethyl)-o-cresol" "phenol, 2-methyl-4,6-bis((octylthio)methyl)-" "phenol, 2-methyl-4,6-bis[(octylthio)methyl]-" );
gibbsFormation
{
    dHf_298   -439310.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1160.31;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=164390.0
    phase     gas;
}
