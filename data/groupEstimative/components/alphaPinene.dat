/*--------------------------------*- Choupo -*-----------------------*\
  Component: (+)-alpha-pinene  (C10H16, CAS 7785-70-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        alphaPinene;
formula     C10H16;
CAS         7785-70-8;
InChIKey    GRWFGVWFFZKLTI-RKDXNWHRSA-N;
MW          136.238;      // g/mol [origin=calculated method=formula-sum]
Tc          655.13;      // K   [origin=predictive method=joback]
Pc          28.905;      // bar [origin=predictive method=joback]
omega       0.3239;      // -   [origin=predictive method=lee-kesler]
Tb          445.86;      // K   [origin=predictive method=joback]
HvapTb      37346.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-133.78 1.39596 -0.00131164 5.256e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 2; } { group C; count 1; } { group CH=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 2; } { group CH_ring; count 2; } { group C_ring; count 1; } { group dCH_ring; count 1; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,5r)-4,6,6-trimethylbicyclo[3.1.1]hept-3-ene" "(1r)-(+)-alpha-pinene" "(1r,5r)-2,6,6-trimethylbicyclo[3.1.1]hept-2-ene" "1r-(+)-a-pinene" "(1r,5r)-2-pinene" "a-pinene" "alpha-pinene(dextro)" "tmh" "(1r)-(+)-a-pinene" "(+)-pin-2(3)-ene" "d-alpha-pinene" "(+)-.alpha.-pinene" );
gibbsFormation
{
    dHf_298   -69080.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     368.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=149850.0
    phase     gas;
}
