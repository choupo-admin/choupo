/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,6-diiodohexane  (C6H12I2, CAS 629-09-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        16Diiodohexane;
formula     C6H12I2;
CAS         629-09-4;
InChIKey    QLIMAARBRDAYGQ-UHFFFAOYSA-N;
MW          337.962;      // g/mol [origin=calculated method=formula-sum]
Tc          757.74;      // K   [origin=predictive method=joback]
Pc          29.601;      // bar [origin=predictive method=joback]
omega       0.3978;      // -   [origin=predictive method=lee-kesler]
Tb          523.16;      // K   [origin=predictive method=joback]
HvapTb      47696.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.816 0.6518 -0.0004654 1.4e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 6; } { group I; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group I; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,6-bis(iodanyl)hexane" "hexamethylene diiodide" "hexane, 1,6-diiodo-" "hexamethyleneiodide" "qlimaarbrdaygq-uhfffaoysa-" "1,6-diiodohexane;hexamethylene diiodide; a,w-diiodohexane" );
gibbsFormation
{
    dHf_298   -13430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     500.95;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=115880.0
    phase     gas;
}
