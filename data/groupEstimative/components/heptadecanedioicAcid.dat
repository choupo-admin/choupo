/*--------------------------------*- Choupo -*-----------------------*\
  Component: heptadecanedioic acid  (C17H32O4, CAS 2424-90-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        heptadecanedioicAcid;
formula     C17H32O4;
CAS         2424-90-0;
InChIKey    QCNWZROVPSVEJA-UHFFFAOYSA-N;
MW          300.439;      // g/mol [origin=calculated method=formula-sum]
Tc          1079.05;      // K   [origin=predictive method=joback]
Pc          14.006;      // bar [origin=predictive method=joback]
omega       1.2479;      // -   [origin=predictive method=lee-kesler]
Tb          879.58;      // K   [origin=predictive method=joback]
HvapTb      87764.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-3.365 1.7204 -0.0010462 2.471e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 15; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 15; } { group COOH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,15-pentadecanedicarboxylic acid" "1,15-pentadecanedicarboxylicacid; 1,17-heptadecanedioic acid; pentadecanedicarboxylic acid" );
gibbsFormation
{
    dHf_298   -1094750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     924.45;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-595560.0
    phase     gas;
}
