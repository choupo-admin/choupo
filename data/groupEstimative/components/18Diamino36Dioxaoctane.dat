/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,8-diamino-3,6-dioxaoctane  (C6H16N2O2, CAS 929-59-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        18Diamino36Dioxaoctane;
formula     C6H16N2O2;
CAS         929-59-9;
InChIKey    IWBOPFCKHIJFMS-UHFFFAOYSA-N;
MW          148.206;      // g/mol [origin=calculated method=formula-sum]
Tc          717.20;      // K   [origin=predictive method=joback]
Pc          34.039;      // bar [origin=predictive method=joback]
omega       0.8323;      // -   [origin=predictive method=lee-kesler]
Tb          526.78;      // K   [origin=predictive method=joback]
HvapTb      55052.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (61.416 0.5712 -0.0001674 -2.74e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CH2O; count 2; } { group CH2NH2; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 6; } { group O; count 2; } { group NH2; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-[2-(2-azanylethoxy)ethoxy]ethanamine" "1,2-bis(2-aminoethoxy)ethane" "2,2'-(ethylenedioxy)bis(ethylamine)" "2,2'-[ethane-1,2-diylbis(oxy)]diethanamine" "2,2'-(ethylenedioxy)diethylamine" "ethanamine, 2,2'-[1,2-ethanediylbis(oxy)]bis-" "pega polymer" "2-[2-(2-aminoethoxy)ethoxy]ethylamine" "2-[2-(2-aminoethoxy)ethoxy]ethanamine" "ethanamine, 2,2'-(1,2-ethanediylbis(oxy))bis-" "amino-peg2-amine" "3,6-dioxaoctamethylenediamine" );
standardThermochemistry
{
    dHf_298   -364030.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     515.46;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77460.0
}
