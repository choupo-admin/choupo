/*--------------------------------*- Choupo -*-----------------------*\
  Component: diphenylmethane  (C13H12, CAS 101-81-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diphenylmethane;
formula     C13H12;
CAS         101-81-5;
InChIKey    CZZYITDELCSZES-UHFFFAOYSA-N;
MW          168.239;      // g/mol [origin=calculated method=formula-sum]
Tc          795.15;      // K   [origin=predictive method=joback]
Pc          30.727;      // bar [origin=predictive method=joback]
omega       0.4255;      // -   [origin=predictive method=lee-kesler]
Tb          550.40;      // K   [origin=predictive method=joback]
HvapTb      49084.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-76.739 1.081 -0.0007458 1.945e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 10; } { group AC; count 1; } { group ACCH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 10; } { group dC_ring; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(phenylmethyl)benzene" "benzylbenzene" "ditan" "benzene, 1,1'-methylenebis-" "ditane" "benzene, benzyl-" "methane, diphenyl-" "1,1'-dimethylenebis(benzene)" "benzyl benzene" "diphenyl methane" "benzene, (phenylmethyl)-" "methylenedibenzene" );
standardThermochemistry
{
    dHf_298   161410.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     449.54;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=283400.0
}
