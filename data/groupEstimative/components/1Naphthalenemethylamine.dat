/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-naphthalenemethylamine  (C11H11N, CAS 118-31-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Naphthalenemethylamine;
formula     C11H11N;
CAS         118-31-0;
InChIKey    NVSYANRBXPURRQ-UHFFFAOYSA-N;
MW          157.216;      // g/mol [origin=calculated method=formula-sum]
Tc          818.44;      // K   [origin=predictive method=joback]
Pc          36.465;      // bar [origin=predictive method=joback]
omega       0.5711;      // -   [origin=predictive method=lee-kesler]
Tb          574.45;      // K   [origin=predictive method=joback]
HvapTb      55299.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-51.669 0.9686 -0.00071888 2.124e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 7; } { group AC; count 3; } { group CH2NH2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group dCH_ring; count 7; } { group dC_ring; count 3; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "naphthalen-1-ylmethanamine" "1-naphthalenemethanamine" "1-naphthalenemethyl amine" "1-(aminomethyl)naphthalene" "naphthylmethylamine" "1-naphthylmethylamine" "naphthalene-1-methylamine" "(naphth-1-yl)methylamine" "naphthalen-1-yl-methyl-amine" "c-naphthalen-1-yl-methylamine" "1-aminomethylnaphthalene" "nvsyanrbxpurrq-uhfffaoysa-" );
standardThermochemistry
{
    dHf_298   179550.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     414.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=317620.0
}
