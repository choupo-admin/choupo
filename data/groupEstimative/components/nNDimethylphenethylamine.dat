/*--------------------------------*- Choupo -*-----------------------*\
  Component: n,n-dimethylphenethylamine  (C10H15N, CAS 1126-71-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        nNDimethylphenethylamine;
formula     C10H15N;
CAS         1126-71-2;
InChIKey    TXOFSCODFRHERQ-UHFFFAOYSA-N;
MW          149.237;      // g/mol [origin=calculated method=formula-sum]
Tc          669.55;      // K   [origin=predictive method=joback]
Pc          29.250;      // bar [origin=predictive method=joback]
omega       0.4478;      // -   [origin=predictive method=lee-kesler]
Tb          467.52;      // K   [origin=predictive method=joback]
HvapTb      42173.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-50.798 0.99884 -0.000664 1.707e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 5; } { group ACCH2; count 1; } { group CH3N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 2; } { group dCH_ring; count 5; } { group dC_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n,n-dimethyl-2-phenyl-ethanamine" "n,n-dimethyl-2-phenylethanamine" "n-phenethyldimethylamine" "dimethyl-phenethyl-amine" "benzeneethanamine, dimethyl-" "n,n-dimethylbenzeneethanamine" "phenethylamine, n,n-dimethyl-" "benzeneethanamine, n,n-dimethyl-" "n,n-dimethylphenylethylamine" "n,n-dmpea" "dimethylphenethylamine" "n,n-dimethyl-2-phenylethylamine" );
standardThermochemistry
{
    dHf_298   54330.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     455.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=256510.0
}
