/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1,12-tridecadiene  (C13H24, CAS 21964-48-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        112Tridecadiene;
formula     C13H24;
CAS         21964-48-7;
InChIKey    BPHFKBMQSYYNGQ-UHFFFAOYSA-N;
MW          180.335;      // g/mol [origin=calculated method=formula-sum]
Tc          656.40;      // K   [origin=predictive method=joback]
Pc          17.624;      // bar [origin=predictive method=joback]
omega       0.5902;      // -   [origin=predictive method=lee-kesler]
Tb          490.40;      // K   [origin=predictive method=joback]
HvapTb      43192.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.911 1.1988 -0.0007292 1.783e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 9; } { group CH2=CH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 9; } { group dCH2; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "trideca-1,12-diene" "tridecadiene-1,12" );
gibbsFormation
{
    dHf_298   -60790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     653.18;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=234260.0
    phase     gas;
}
