/*--------------------------------*- Choupo -*-----------------------*\
  Component: fagarsterol  (C30H50O, CAS 545-47-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        fagarsterol;
formula     C30H50O;
CAS         545-47-1;
InChIKey    MQYXUWHLBZFQQO-JGGBMTAGSA-N;
MW          426.729;      // g/mol [origin=calculated method=formula-sum]
Tc          1246.20;      // K   [origin=predictive method=joback]
Pc          10.194;      // bar [origin=predictive method=joback]
omega       0.8686;      // -   [origin=predictive method=lee-kesler]
Tb          1007.24;      // K   [origin=predictive method=joback]
HvapTb      91451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-518.03 4.86524 -0.004817 2.0127e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 7; } { group CH2; count 10; } { group CH; count 6; } { group C; count 5; } { group CH2=C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 7; } { group dCH2; count 1; } { group dC; count 1; } { group CH2_ring; count 10; } { group CH_ring; count 6; } { group C_ring; count 5; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(1r,3ar,5br,7ar,9s,11ar,11br,13ar,13br)-3a,5a,5b,8,8,11a-hexamethyl-1-prop-1-en-2-yl-1,2,3,4,5,6,7,7a,9,10,11,11b,12,13,13a,13b-hexadecahydrocyclopenta[a]chrysen-9-ol" "lupeol" "beta-viscol" "triterpene lupeol" "lupenol" "fagarasterol" "(3-beta)-lup-20(29)-en-3-ol" "lup-20(29)-en-3-ol, (3beta)-" "lup-20(29)-en-3-ol, (3-beta)-" "(3" "a,14xi)-lup-20(29)-en-3-ol" "lup-20(29)-en-3-ol" "lup-20(29)-en-3beta-ol" );
standardThermochemistry
{
    dHf_298   -417920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1128.39;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=301630.0
}
