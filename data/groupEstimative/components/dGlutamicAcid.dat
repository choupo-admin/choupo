/*--------------------------------*- Choupo -*-----------------------*\
  Component: d-glutamic acid  (C5H9NO4, CAS 6893-26-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        dGlutamicAcid;
formula     C5H9NO4;
CAS         6893-26-1;
InChIKey    WHUUTDBJXJRKMK-GSVOUGTGSA-N;
MW          147.13;      // g/mol [origin=calculated method=formula-sum]
Tc          895.19;      // K   [origin=predictive method=joback]
Pc          47.236;      // bar [origin=predictive method=joback]
omega       1.2768;      // -   [origin=predictive method=lee-kesler]
Tb          677.11;      // K   [origin=predictive method=joback]
HvapTb      71305.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (12.352 0.6482 -0.00044 1.148e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group CHNH2; count 1; } { group COOH; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group COOH; count 2; } { group NH2; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r)-2-azanylpentanedioic acid" "d-glu" "d-glutamate" "(r)-2-aminopentanedioic acid" "(2r)-2-aminopentanedioic acid" "d-2-aminopentanedioic acid" "glutamic acid d-form" "h-d-glu-oh" "d-glutaminsaeure" "d-glutaminic acid" "d(-)-glutamic acid" "d-(-)-glutamic acid" );
gibbsFormation
{
    dHf_298   -818560.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     499.09;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-632590.0
    phase     gas;
}
