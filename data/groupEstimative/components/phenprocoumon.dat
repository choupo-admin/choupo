/*--------------------------------*- Choupo -*-----------------------*\
  Component: phenprocoumon  (C18H16O3, CAS 435-97-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phenprocoumon;
formula     C18H16O3;
CAS         435-97-2;
InChIKey    DQDAYGNAKTZFIW-UHFFFAOYSA-N;
MW          280.323;      // g/mol [origin=calculated method=formula-sum]
Tc          1063.85;      // K   [origin=predictive method=joback]
Pc          25.559;      // bar [origin=predictive method=joback]
omega       1.0698;      // -   [origin=predictive method=lee-kesler]
Tb          819.46;      // K   [origin=predictive method=joback]
HvapTb      81913.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-81.159 1.67372 -0.00135796 4.413e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 1; } { group ACH; count 9; } { group AC; count 2; } { group ACCH; count 1; } { group OH; count 1; } { group C=C; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH; count 1; } { group dCH_ring; count 9; } { group dC_ring; count 5; } { group OH_phenol; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4-oxidanyl-3-(1-phenylpropyl)chromen-2-one" "phenprocoumarol" "phenprocoumarole" "phenprocumone" "falithrom" "liquamar" "marcoumar" "marcumar" "fenprocumone" "phenprocoumone" "phenprocumonum" "fencumar" );
gibbsFormation
{
    dHf_298   -307520.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     594.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-50670.0
    phase     gas;
}
