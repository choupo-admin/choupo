/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-(2-aminoethylamino)ethanol; octanoic acid  (C12H28N2O3, CAS 70750-12-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        22AminoethylaminoEthanolOctanoicAcid;
formula     C12H28N2O3;
CAS         70750-12-8;
InChIKey    GOANEXYTWUVMDC-UHFFFAOYSA-N;
MW          248.367;      // g/mol [origin=calculated method=formula-sum]
Tc          1030.05;      // K   [origin=predictive method=joback]
Pc          20.530;      // bar [origin=predictive method=joback]
omega       1.5264;      // -   [origin=predictive method=lee-kesler]
Tb          835.95;      // K   [origin=predictive method=joback]
HvapTb      93520.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (47.97 1.16052 -0.0004092 -2.63e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 8; } { group OH; count 1; } { group CH2NH2; count 1; } { group CH2NH; count 1; } { group COOH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 10; } { group OH; count 1; } { group COOH; count 1; } { group NH2; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2-azanylethylamino)ethanol;octanoic acid" "reaction products of octanoic acid with aminoethylethanolamine" "caprylic acid, aminoethylethanolamine reaction product" "octanoic acid - 2-[(2-aminoethyl)amino]ethanol (1:1)" "octanoic acid, reaction products with 2-((2-aminoethyl)amino)ethanol" );
gibbsFormation
{
    dHf_298   -817870.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     927.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-379490.0
    phase     gas;
}
