/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,4,4-trichloro-3-chloromethyl-butenoic acid  (C5H4Cl4O2, CAS 215226-73-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        244Trichloro3ChloromethylButenoicAcid;
formula     C5H4Cl4O2;
CAS         215226-73-6;
InChIKey    FYUFQYDLNJTYNP-UHFFFAOYSA-N;
MW          237.885;      // g/mol [origin=calculated method=formula-sum]
Tc          844.91;      // K   [origin=predictive method=joback]
Pc          35.137;      // bar [origin=predictive method=joback]
omega       0.7570;      // -   [origin=predictive method=lee-kesler]
Tb          612.71;      // K   [origin=predictive method=joback]
HvapTb      61158.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (39.261 0.5825 -0.000494 1.628e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group COOH; count 1; } { group CH2Cl; count 1; } { group CHCl2; count 1; } { group Cl_C=C_; count 1; } { group C=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 1; } { group CH; count 1; } { group dC; count 2; } { group Cl; count 4; } { group COOH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,4,4-tris(chloranyl)-3-(chloromethyl)but-2-enoic acid" );
standardThermochemistry
{
    dHf_298   -467400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     513.15;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-339730.0
}
