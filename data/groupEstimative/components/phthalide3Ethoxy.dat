/*--------------------------------*- Choupo -*-----------------------*\
  Component: phthalide, 3-ethoxy-  (C10H10O3, CAS 16824-02-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phthalide3Ethoxy;
formula     C10H10O3;
CAS         16824-02-5;
InChIKey    VCBNFFOSUGMASJ-UHFFFAOYSA-N;
MW          178.187;      // g/mol [origin=calculated method=formula-sum]
Tc          748.38;      // K   [origin=predictive method=joback]
Pc          31.071;      // bar [origin=predictive method=joback]
omega       0.6494;      // -   [origin=predictive method=lee-kesler]
Tb          538.90;      // K   [origin=predictive method=joback]
HvapTb      50178.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-14.899 0.86752 -0.00059176 1.556e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 1; } { group CH_ring; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-ethoxy-3h-2-benzofuran-1-one" "1(3h)-isobenzofuranone, 3-ethoxy-" "3-ethoxy-1(3h)-isobenzofuranone" "3-ethoxy-1,3-dihydro-2-benzofuran-1-one" );
standardThermochemistry
{
    dHf_298   -389050.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     365.38;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-194320.0
}
