/*--------------------------------*- Choupo -*-----------------------*\
  Component: 7-bromo-1-heptanol  (C7H15BrO, CAS 10160-24-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        7Bromo1Heptanol;
formula     C7H15BrO;
CAS         10160-24-4;
InChIKey    MMXRRNUXCHUHOE-UHFFFAOYSA-N;
MW          195.1;      // g/mol [origin=calculated method=formula-sum]
Tc          692.89;      // K   [origin=predictive method=joback]
Pc          33.451;      // bar [origin=predictive method=joback]
omega       0.9652;      // -   [origin=predictive method=lee-kesler]
Tb          518.10;      // K   [origin=predictive method=joback]
HvapTb      54290.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (10.007 0.741 -0.0004588 1.16e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 7; } { group OH; count 1; } { group Br; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 7; } { group Br; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "7-bromanylheptan-1-ol" "1-heptanol, 7-bromo-" "7-bromoheptan-1-ol" "7-bromoheptanol;" "agn-pc-0cqx0y" );
gibbsFormation
{
    dHf_298   -313710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     530.6;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-114440.0
    phase     gas;
}
