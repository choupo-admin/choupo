/*--------------------------------*- Choupo -*-----------------------*\
  Component: oleyl acrylate  (C21H38O2, CAS 13533-18-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        oleylAcrylate;
formula     C21H38O2;
CAS         13533-18-1;
InChIKey    ASAPXSLRMDUMFX-UHFFFAOYSA-N;
MW          322.533;      // g/mol [origin=calculated method=formula-sum]
Tc          913.34;      // K   [origin=predictive method=joback]
Pc          10.175;      // bar [origin=predictive method=joback]
omega       0.8804;      // -   [origin=predictive method=lee-kesler]
Tb          739.14;      // K   [origin=predictive method=joback]
HvapTb      69035.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-7.965 1.94402 -0.0011307 2.464e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2=CH; count 1; } { group CH=CH; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 15; } { group dCH2; count 1; } { group dCH; count 3; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "octadec-9-enyl prop-2-enoate" "2-propenoic acid, (9z)-9-octadecen-1-yl ester" "2-propenoic acid,(9z)-9-octadecen-1-yl ester" "2-propenoic acid, 9-octadecenyl ester,(z)-;oleyl acrylate;2-propenoicacid, (9z)-9-octadecenyl ester (9ci);2-propenoic acid, (9z)-9-octadecenyl ester;(9z)-octadec-9-en-1-yl prop-2-enoate;" );
standardThermochemistry
{
    dHf_298   -551400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1014.1;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-16370.0
}
