/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,6-dichloro-3-methylphenol  (C7H6Cl2O, CAS 13481-70-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        26Dichloro3Methylphenol;
formula     C7H6Cl2O;
CAS         13481-70-4;
InChIKey    SXHLRMKATYCFRY-UHFFFAOYSA-N;
MW          177.024;      // g/mol [origin=calculated method=formula-sum]
Tc          794.71;      // K   [origin=predictive method=joback]
Pc          43.626;      // bar [origin=predictive method=joback]
omega       0.5889;      // -   [origin=predictive method=lee-kesler]
Tb          551.88;      // K   [origin=predictive method=joback]
HvapTb      56560.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.08 0.63912 -0.00055128 1.989e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 2; } { group ACCH3; count 1; } { group ACOH; count 1; } { group ACCl; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 4; } { group Cl; count 2; } { group OH_phenol; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,6-bis(chloranyl)-3-methyl-phenol" "phenol, 2,6-dichloro-3-methyl-" "2,6-dichloro-m-cresol" "phenol, 2, 6-dichloro-3-methyl-" "m-cresol, 2, 6-dichloro- (8ci);2, 6-dichloro-3-methylphenol;2, 6-dichloro-m-cresol;" );
gibbsFormation
{
    dHf_298   -183010.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     403.22;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-77270.0
    phase     gas;
}
