/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-methylcyclohexanol  (C7H14O, CAS 590-67-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Methylcyclohexanol;
formula     C7H14O;
CAS         590-67-0;
InChIKey    VTBOTOBFGSVRMA-UHFFFAOYSA-N;
MW          114.188;      // g/mol [origin=calculated method=formula-sum]
Tc          672.81;      // K   [origin=predictive method=joback]
Pc          41.731;      // bar [origin=predictive method=joback]
omega       0.6242;      // -   [origin=predictive method=lee-kesler]
Tb          471.73;      // K   [origin=predictive method=joback]
HvapTb      47133.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-113.78 1.11682 -0.001001 3.895e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 5; } { group C; count 1; } { group OH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 5; } { group C_ring; count 1; } { group OH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-methylcyclohexan-1-ol" "cyclohexanol, 1-methyl-" "1-methyl-1-cyclohexanol" "1-methyl-cyclohexan-1-ol" "1-methyl cyclohexanol" "ghl.pd_mitscher_leg0.946" );
standardThermochemistry
{
    dHf_298   -270480.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     518.59;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-109800.0
}
