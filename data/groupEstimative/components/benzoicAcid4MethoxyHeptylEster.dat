/*--------------------------------*- Choupo -*-----------------------*\
  Component: benzoic acid, 4-methoxy-, heptyl ester  (C15H22O3, CAS 5452-08-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        benzoicAcid4MethoxyHeptylEster;
formula     C15H22O3;
CAS         5452-08-4;
InChIKey    OEYMSYGFUQPUKZ-UHFFFAOYSA-N;
MW          250.338;      // g/mol [origin=calculated method=formula-sum]
Tc          849.95;      // K   [origin=predictive method=joback]
Pc          18.046;      // bar [origin=predictive method=joback]
omega       0.8441;      // -   [origin=predictive method=lee-kesler]
Tb          655.10;      // K   [origin=predictive method=joback]
HvapTb      61739.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.556 1.17244 -0.00055076 5.6e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 6; } { group ACH; count 4; } { group AC; count 2; } { group CH3O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 6; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "heptyl 4-methoxybenzoate" "p-methoxybenzoic acid, heptyl ester" "benzoic acid,4-methoxy-, heptyl ester" );
gibbsFormation
{
    dHf_298   -577370.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     690.25;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-237170.0
    phase     gas;
}
