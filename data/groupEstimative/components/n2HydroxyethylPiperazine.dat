/*--------------------------------*- Choupo -*-----------------------*\
  Component: n-(2-hydroxyethyl)piperazine  (C6H14N2O, CAS 103-76-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        n2HydroxyethylPiperazine;
formula     C6H14N2O;
CAS         103-76-4;
InChIKey    WFCSWCVEJLETKA-UHFFFAOYSA-N;
MW          130.191;      // g/mol [origin=calculated method=formula-sum]
Tc          702.11;      // K   [origin=predictive method=joback]
Pc          46.530;      // bar [origin=predictive method=joback]
omega       0.9108;      // -   [origin=predictive method=lee-kesler]
Tb          510.00;      // K   [origin=predictive method=joback]
HvapTb      54996.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-57.468 0.8765 -0.0005678 1.422e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group OH; count 1; } { group CH2NH; count 1; } { group CH2N; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH2_ring; count 4; } { group OH; count 1; } { group NH_ring; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-piperazin-1-ylethanol" "1-piperazineethanol" "1-(2-hydroxyethyl)piperazine" "2-piperazinoethanol" "2-hydroxyethylpiperazine" "1-piperazinethanol" "2-(1-piperazinyl)ethanol" "hydroxyethylpiperazine" "2-piperazin-1-yl-ethanol" "usaf do-22" "4-(2-hydroxyethyl)piperazine" "ethanol, 2-(1-piperazinyl)-" );
standardThermochemistry
{
    dHf_298   -133240.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     442.4;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=105570.0
}
