/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2,7-disilaoct-4-ene,2,2,3,3,6,6,7,7-octamethyl-, (e)- (8ci)  (C14H32Si2, CAS 16054-20-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
  WARNING: Joback fragmentation INCOMPLETE -- group atoms do not close the
  formula C14H32Si2 (delta Si+2; Joback lacks these groups).  The `joback`
  block AND every property estimate below are therefore UNRELIABLE for this
  compound.  Identity and UNIFAC groups are still valid.
\*---------------------------------------------------------------------------*/

name        27Disilaoct4Ene22336677OctamethylE8ci;
formula     C14H32Si2;
CAS         16054-20-9;
InChIKey    AYYNRBDPRMWWNJ-UHFFFAOYSA-N;
jobackIncomplete   true;   // group atoms do not close the formula
MW          256.58;      // g/mol [origin=calculated method=formula-sum]
Tc          717.40;      // K   [origin=predictive method=joback]
Pc          13.596;      // bar [origin=predictive method=joback]
omega       0.2811;      // -   [origin=predictive method=lee-kesler]
Tb          520.42;      // K   [origin=predictive method=joback]
HvapTb      44712.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.67 1.1932 -0.0003356 -8.78e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 10; } { group C; count 2; } { group CH=CH; count 1; } { group Si; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 10; } { group C; count 2; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2,5-dimethyl-5-trimethylsilyl-hex-3-en-2-yl)-trimethyl-silane" "silane,(1,1,4,4-tetramethyl-2-butene-1,4-diyl)bis[trimethyl-, (e)- (9ci)" );
standardThermochemistry
{
    dHf_298   -455810.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     869.97;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-56620.0
}
