/*--------------------------------*- Choupo -*-----------------------*\
  Component: methylenecyclopropene  (C4H4, CAS 4095-06-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        methylenecyclopropene;
formula     C4H4;
CAS         4095-06-1;
InChIKey    GOSMMPKSWSOPRZ-UHFFFAOYSA-N;
MW          52.076;      // g/mol [origin=calculated method=formula-sum]
Tc          483.09;      // K   [origin=predictive method=joback]
Pc          52.207;      // bar [origin=predictive method=joback]
omega       0.1981;      // -   [origin=predictive method=lee-kesler]
Tb          300.85;      // K   [origin=predictive method=joback]
HvapTb      25171.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-26.86 0.3877 -0.00036428 1.39e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH=CH; count 1; } { group CH2=C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group dCH2; count 1; } { group dCH_ring; count 2; } { group dC_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-methylidenecyclopropene" "cyclopropene,3-methylene-" "cyclopropene,methylene- (7ci,8ci,9ci); 3-methylenecyclopropene; methylenecyclopropene;triafulvene" );
standardThermochemistry
{
    dHf_298   109270.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     200.37;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=134300.0
}
