/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-dibutylamino-1-propyne  (C11H21N, CAS 6336-58-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3Dibutylamino1Propyne;
formula     C11H21N;
CAS         6336-58-9;
InChIKey    XTEBRELWTGWYDE-UHFFFAOYSA-N;
MW          167.296;      // g/mol [origin=calculated method=formula-sum]
Tc          624.64;      // K   [origin=predictive method=joback]
Pc          22.083;      // bar [origin=predictive method=joback]
omega       0.5347;      // -   [origin=predictive method=lee-kesler]
Tb          453.84;      // K   [origin=predictive method=joback]
HvapTb      41981.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-4.023 1.07884 -0.00068313 1.7549e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 6; } { group CH2N; count 1; } { group CH_C; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 7; } { group tCH; count 1; } { group tC; count 1; } { group N; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "n-butyl-n-prop-2-ynyl-butan-1-amine" "dibutylprop-2-ynylamine" "n,n-dibutylpropargylamine" "n-butyl-n-prop-2-ynylbutan-1-amine" "1-butanamine,n-butyl-n-2-propyn-1-yl-" );
gibbsFormation
{
    dHf_298   89060.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     570.05;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=375590.0
    phase     gas;
}
