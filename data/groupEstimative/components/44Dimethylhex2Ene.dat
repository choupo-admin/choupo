/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4-dimethylhex-2-ene  (C8H16, CAS 19550-83-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Dimethylhex2Ene;
formula     C8H16;
CAS         19550-83-5;
InChIKey    OQEVAISXHCRQGF-UHFFFAOYSA-N;
MW          112.216;      // g/mol [origin=calculated method=formula-sum]
Tc          567.07;      // K   [origin=predictive method=joback]
Pc          27.269;      // bar [origin=predictive method=joback]
omega       0.2761;      // -   [origin=predictive method=lee-kesler]
Tb          383.57;      // K   [origin=predictive method=joback]
HvapTb      32064.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-43.039 0.90968 -0.000667 2.033e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group CH=CH; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 1; } { group C; count 1; } { group dCH; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-hexene,4,4-dimethyl-, (2e)-" "2-hexene,4,4-dimethyl-, (e)- (8ci); (e)-4,4-dimethylhex-2-ene;4,4-dimethyl-trans-2-hexene" );
gibbsFormation
{
    dHf_298   -99980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     422.17;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=99540.0
    phase     gas;
}
