/*--------------------------------*- Choupo -*-----------------------*\
  Component: (1,3-dicyclohexylpropyl)cyclohexane  (C21H38, CAS 55682-89-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        13DicyclohexylpropylCyclohexane;
formula     C21H38;
CAS         55682-89-8;
InChIKey    VIDXNEQHNUTDHC-UHFFFAOYSA-N;
MW          290.535;      // g/mol [origin=calculated method=formula-sum]
Tc          973.50;      // K   [origin=predictive method=joback]
Pc          14.669;      // bar [origin=predictive method=joback]
omega       0.5844;      // -   [origin=predictive method=lee-kesler]
Tb          738.29;      // K   [origin=predictive method=joback]
HvapTb      63239.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-214.698 2.371 -0.0013648 2.67e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 17; } { group CH; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2; count 2; } { group CH; count 1; } { group CH2_ring; count 15; } { group CH_ring; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3-dicyclohexylpropylcyclohexane" "cyclohexane, 1,1',1''-(1-propanyl-2-ylidene)tris-" "1,1,3-tricyclohexylpropane" "1,1',1''-propane-1,1,3-triyltricyclohexane" );
gibbsFormation
{
    dHf_298   -319090.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     872.99;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=196850.0
    phase     gas;
}
