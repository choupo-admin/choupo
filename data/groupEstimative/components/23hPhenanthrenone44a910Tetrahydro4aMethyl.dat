/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2(3h)-phenanthrenone, 4,4a,9,10-tetrahydro-4a-methyl-  (C15H16O, CAS 6606-34-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        23hPhenanthrenone44a910Tetrahydro4aMethyl;
formula     C15H16O;
CAS         6606-34-4;
InChIKey    FSPGJSRKHCJARC-UHFFFAOYSA-N;
MW          212.292;      // g/mol [origin=calculated method=formula-sum]
Tc          935.83;      // K   [origin=predictive method=joback]
Pc          27.759;      // bar [origin=predictive method=joback]
omega       0.5897;      // -   [origin=predictive method=lee-kesler]
Tb          673.35;      // K   [origin=predictive method=joback]
HvapTb      56451.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-138.5 1.60762 -0.0013682 4.992e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 2; } { group C; count 1; } { group CH=C; count 1; } { group ACH; count 4; } { group AC; count 1; } { group ACCH2; count 1; } { group CH2CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2_ring; count 4; } { group C_ring; count 1; } { group dCH_ring; count 5; } { group dC_ring; count 3; } { group CdO_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "4a-methyl-3,4,9,10-tetrahydrophenanthren-2-one" "2(3h)-phenanthrone, 4,4a,9,10-tetrahydro-4a-methyl-" "4a-methyl-3,4,9,10-tetrahydro-phenanthren-2-one" "4a-methyl-4,4a,9,10-tetrahydro-2(3h)-phenanthrenone" );
standardThermochemistry
{
    dHf_298   -50400.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     476.57;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=175460.0
}
