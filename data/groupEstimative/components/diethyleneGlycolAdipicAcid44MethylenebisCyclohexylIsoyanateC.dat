/*--------------------------------*- Choupo -*-----------------------*\
  Component: diethylene glycol, adipic acid, 4,4'-methylenebis(cyclohexyl isoyanate) copolymer  (C25H42N2O9, CAS 67905-77-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        diethyleneGlycolAdipicAcid44MethylenebisCyclohexylIsoyanateC;
formula     C25H42N2O9;
CAS         67905-77-5;
InChIKey    UETVIZDXISKUAA-UHFFFAOYSA-N;
MW          514.616;      // g/mol [origin=calculated method=formula-sum]
Tc          1872.66;      // K   [origin=predictive method=joback]
Pc          11.437;      // bar [origin=predictive method=joback]
omega       0.5010;      // -   [origin=predictive method=lee-kesler]
Tb          1435.30;      // K   [origin=predictive method=joback]
HvapTb      161232.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
groups
{
    unifac ( { group CH2; count 15; } { group CH; count 4; } { group OH; count 1; } { group COOH; count 2; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    // UNRESOLVED unifac subgroup(s) not yet in data/standards/unifac/groups.dat: ?109:2
    joback ( { group CH2; count 9; } { group dCd; count 2; } { group CH2_ring; count 8; } { group CH_ring; count 4; } { group OH; count 2; } { group O; count 1; } { group COOH; count 2; } { group dO_oth; count 2; } { group Nd; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "hexanedioic acid;2-(2-hydroxyethyloxy)ethanol;1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" "hexanedioic acid, polymer with 1,1'-methylenebis(4-isocyanatocyclohexane) and 2,2'-oxybis(ethanol)" "hexanedioic acid; 2-(2-hydroxyethoxy)ethanol; 1-isocyanato-4-[(4-isocyanatocyclohexyl)methyl]cyclohexane" );
