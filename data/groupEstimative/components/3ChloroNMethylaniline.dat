/*--------------------------------*- Choupo -*-----------------------*\
  Component: 3-chloro-n-methylaniline  (C7H8ClN, CAS 7006-52-2)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        3ChloroNMethylaniline;
formula     C7H8ClN;
CAS         7006-52-2;
InChIKey    WFGYSQDPURFIFL-UHFFFAOYSA-N;
MW          141.598;      // g/mol [origin=calculated method=formula-sum]
Tc          702.25;      // K   [origin=predictive method=joback]
Pc          39.160;      // bar [origin=predictive method=joback]
omega       0.4528;      // -   [origin=predictive method=lee-kesler]
Tb          479.02;      // K   [origin=predictive method=joback]
HvapTb      44935.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-11.4 0.61342 -0.00039016 9.22e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 4; } { group AC; count 1; } { group CH3NH; count 1; } { group ACCl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group Cl; count 1; } { group NH; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3-chloranyl-n-methyl-aniline" "n-methyl-3-chloroaniline" "3-chloro-n-methylbenzenamine" "benzenamine, 3-chloro-n-methyl-" "n-(3-chlorophenyl)-n-methylamine" "3-chloro-1-methylaniline" "n1-methyl-3-chloroaniline" "benzenamine,3-chloro-n-methyl-" "(3-chloro-phenyl)-methyl-amine" );
standardThermochemistry
{
    dHf_298   74980.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     390.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=188300.0
}
