/*--------------------------------*- Choupo -*-----------------------*\
  Component: solvactant 7 solvent  (C9H20O2, CAS 132299-20-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        solvactant7Solvent;
formula     C9H20O2;
CAS         132299-20-8;
InChIKey    QXGSHGKOPJABTM-UHFFFAOYSA-N;
MW          160.257;      // g/mol [origin=calculated method=formula-sum]
Tc          686.97;      // K   [origin=predictive method=joback]
Pc          25.430;      // bar [origin=predictive method=joback]
omega       0.8873;      // -   [origin=predictive method=lee-kesler]
Tb          518.80;      // K   [origin=predictive method=joback]
HvapTb      53553.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (20.452 0.84738 -0.0003948 4.94e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH; count 3; } { group C2H5O2; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 4; } { group CH2; count 2; } { group CH; count 3; } { group OH; count 1; } { group O; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(2,4-dimethylpentan-3-yloxy)ethanol" "2-[(2,4-dimethylpentan-3-yl)oxy]ethanol" "poly(oxy-1,2-ethanediyl),a-[3-methyl-1-(2-methylpropyl)butyl]-w-hydroxy-" "alpha-(3-methyl-1-(2-methylpropyl)butyl)-omega-hydroxypoly(oxy-1,2-ethanediyl)" "poly(oxy-1,2-ethanediyl), alpha-(3-methyl-1-(2-methylpropyl)butyl)-omega-hydroxy-" );
standardThermochemistry
{
    dHf_298   -529380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     540.16;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-224240.0
}
