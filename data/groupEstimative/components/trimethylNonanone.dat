/*--------------------------------*- Choupo -*-----------------------*\
  Component: trimethyl nonanone  (C12H24O, CAS 1331-50-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        trimethylNonanone;
formula     C12H24O;
CAS         1331-50-6;
InChIKey    PKNKULBDCRZSBT-UHFFFAOYSA-N;
MW          184.323;      // g/mol [origin=calculated method=formula-sum]
Tc          707.06;      // K   [origin=predictive method=joback]
Pc          19.186;      // bar [origin=predictive method=joback]
omega       0.6188;      // -   [origin=predictive method=lee-kesler]
Tb          526.71;      // K   [origin=predictive method=joback]
HvapTb      47888.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-5.707 1.1336 -0.0006199 1.2106e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 4; } { group CH2; count 3; } { group CH; count 3; } { group CH3CO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 5; } { group CH2; count 3; } { group CH; count 3; } { group CdO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "3,4,5-trimethylnonan-2-one" "nonanone, trimethyl-" );
gibbsFormation
{
    dHf_298   -419430.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     621.55;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-86080.0
    phase     gas;
}
