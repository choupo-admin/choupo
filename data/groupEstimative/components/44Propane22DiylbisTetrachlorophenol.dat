/*--------------------------------*- Choupo -*-----------------------*\
  Component: 4,4'-propane-2,2-diylbis(tetrachlorophenol)  (C15H8Cl8O2, CAS 16669-42-4)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        44Propane22DiylbisTetrachlorophenol;
formula     C15H8Cl8O2;
CAS         16669-42-4;
InChIKey    OJTHLNYBRBMCBW-UHFFFAOYSA-N;
MW          503.827;      // g/mol [origin=calculated method=formula-sum]
Tc          1373.56;      // K   [origin=predictive method=joback]
Pc          22.784;      // bar [origin=predictive method=joback]
omega       1.3524;      // -   [origin=predictive method=lee-kesler]
Tb          1093.45;      // K   [origin=predictive method=joback]
HvapTb      118644.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (96.65 1.28444 -0.001166 4.292e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group C; count 1; } { group AC; count 2; } { group ACOH; count 2; } { group ACCl; count 8; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group C; count 1; } { group dC_ring; count 12; } { group Cl; count 8; } { group OH_phenol; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2,3,5,6-tetrakis(chloranyl)-4-[2-[2,3,5,6-tetrakis(chloranyl)-4-oxidanyl-phenyl]propan-2-yl]phenol" "phenol, 4,4'-(1-methylethylidene)bis(2,3,5,6-tetrachloro-" "phenol, 4,4'-(1-methylethylidene)bis[2,3,5,6-tetrachloro-" "isopropylidene bis-tetrachlorophenol" "2,3,5,6-tetrachloro-4-[2-(2,3,5,6-tetrachloro-4-hydroxyphenyl)propan-2-yl]phenol" );
gibbsFormation
{
    dHf_298   -460920.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     759.51;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-178640.0
    phase     gas;
}
