/*--------------------------------*- Choupo -*-----------------------*\
  Component: anhydroformaldehyde p-toluidine  (C24H27N3, CAS 6639-47-0)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        anhydroformaldehydePToluidine;
formula     C24H27N3;
CAS         6639-47-0;
InChIKey    UAJWDYLSRSNGFH-UHFFFAOYSA-N;
MW          357.501;      // g/mol [origin=calculated method=formula-sum]
Tc          1135.30;      // K   [origin=predictive method=joback]
Pc          17.118;      // bar [origin=predictive method=joback]
omega       0.9921;      // -   [origin=predictive method=lee-kesler]
Tb          892.43;      // K   [origin=predictive method=joback]
HvapTb      84183.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-166.0 2.41776 -0.00178768 5.159e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group ACH; count 12; } { group AC; count 3; } { group ACCH3; count 3; } { group CH2N; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2_ring; count 3; } { group dCH_ring; count 12; } { group dC_ring; count 6; } { group N; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,3,5-tris(4-methylphenyl)-1,3,5-triazinane" "anhydroformaldehyde paratoluidine" "s-triazine, hexahydro-1,3,5-tritolyl-" "hexahydro-1,3,5-tri-p-tolyl-s-triazine" "s-triazine, hexahydro-1,3,5-tri-p-tolyl-" "s-triazine,3,5-tritolyl-" "s-triazine,3,5-tri-p-tolyl-" "1,3,5-tris(4-methylphenyl)-1,3,5-triazaperhydroine" "1,5-triazine, hexahydro-1,3,5-tris(4-methylphenyl)-" "1,3,5-triazine, hexahydro-1,3,5-tris(4-methylphenyl)-" "1,3,5-triazine, hexahydro-1,3,5-tris(4-methylphenyl)- (9ci)" );
standardThermochemistry
{
    dHf_298   432220.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     753.42;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=860340.0
}
