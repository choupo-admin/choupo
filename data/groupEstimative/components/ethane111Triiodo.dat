/*--------------------------------*- Choupo -*-----------------------*\
  Component: ethane, 1,1,1-triiodo-  (C2H3I3, CAS 594-21-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ethane111Triiodo;
formula     C2H3I3;
CAS         594-21-8;
InChIKey    BASDZFQDZBHCAV-UHFFFAOYSA-N;
MW          407.746;      // g/mol [origin=calculated method=formula-sum]
Tc          838.42;      // K   [origin=predictive method=joback]
Pc          47.107;      // bar [origin=predictive method=joback]
omega       0.1657;      // -   [origin=predictive method=lee-kesler]
Tb          521.55;      // K   [origin=predictive method=joback]
HvapTb      46869.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (11.67 0.43662 -0.000501 2.042e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group C; count 1; } { group I; count 3; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group C; count 1; } { group I; count 3; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1,1,1-tris(iodanyl)ethane" "agn-pc-00nozz" );
standardThermochemistry
{
    dHf_298   137250.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     361.89;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=143160.0
}
