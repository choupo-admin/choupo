/*--------------------------------*- Choupo -*-----------------------*\
  Component: iptg  (C9H18O5S, CAS 367-93-1)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        iptg;
formula     C9H18O5S;
CAS         367-93-1;
InChIKey    BPHPUYQFMNQIOC-NXRLNHOXSA-N;
MW          238.298;      // g/mol [origin=calculated method=formula-sum]
Tc          1067.69;      // K   [origin=predictive method=joback]
Pc          37.870;      // bar [origin=predictive method=joback]
omega       2.1441;      // -   [origin=predictive method=lee-kesler]
Tb          870.40;      // K   [origin=predictive method=joback]
HvapTb      112476.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (9.261 1.00823 -0.0003959 -4.9e-09);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 4; } { group OH; count 4; } { group CH-O; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 2; } { group CH2; count 1; } { group CH; count 1; } { group CH_ring; count 5; } { group OH; count 4; } { group O_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "(2r,3r,4s,5r,6s)-2-(hydroxymethyl)-6-propan-2-ylsulfanyl-oxane-3,4,5-triol" "isopropyl-beta-d-thiogalactopyranoside" "isopropyl thiogalactoside" "isopropyl-beta-d-thiogalactoside" "isopropyl beta-d-1-thiogalactopyranoside" "d-beta-isopropylthiogalactioside" "isopropyl-1-beta-d-thiogalactoside" "isopropyl beta-d-thiogalactoside" "ipt" "1-(isopropylthio)-beta-galactopyranside" "isopropyl 1-thio-beta-d-galactopyranoside" "beta-d-galactopyranoside, 1-methylethyl 1-thio-" );
standardThermochemistry
{
    dHf_298   -960460.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     510.73;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-584210.0
}
