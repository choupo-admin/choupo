/*--------------------------------*- Choupo -*-----------------------*\
  Component: 9-thiabicyclo[4.2.1]non-7-ene  (C8H12S, CAS 13350-64-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        9Thiabicyclo421Non7Ene;
formula     C8H12S;
CAS         13350-64-6;
InChIKey    JUTWGWDMTMWRHN-UHFFFAOYSA-N;
MW          140.244;      // g/mol [origin=calculated method=formula-sum]
Tc          693.98;      // K   [origin=predictive method=joback]
Pc          38.057;      // bar [origin=predictive method=joback]
omega       0.2825;      // -   [origin=predictive method=lee-kesler]
Tb          455.92;      // K   [origin=predictive method=joback]
HvapTb      39848.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-90.63 0.99521 -0.00071858 2.059e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 4; } { group CH; count 1; } { group CH=CH; count 1; } { group CHS; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 4; } { group CH_ring; count 2; } { group dCH_ring; count 2; } { group S_ring; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "9-thiabicyclo(4.2.1)non-7-ene" );
standardThermochemistry
{
    dHf_298   21710.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     359.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=171500.0
}
