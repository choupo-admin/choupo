/*--------------------------------*- Choupo -*-----------------------*\
  Component: [3.3]paracyclophane  (C18H20, CAS 2913-24-8)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        33Paracyclophane;
formula     C18H20;
CAS         2913-24-8;
InChIKey    RUVOYPXKKFOGBH-UHFFFAOYSA-N;
MW          236.358;      // g/mol [origin=calculated method=formula-sum]
Tc          961.48;      // K   [origin=predictive method=joback]
Pc          23.203;      // bar [origin=predictive method=joback]
omega       0.5633;      // -   [origin=predictive method=lee-kesler]
Tb          698.98;      // K   [origin=predictive method=joback]
HvapTb      62276.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-124.23 1.5856 -0.00102012 2.42e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH2; count 2; } { group ACH; count 8; } { group ACCH2; count 4; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH2_ring; count 6; } { group dCH_ring; count 8; } { group dC_ring; count 4; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "tricyclo[10.2.2.2(5,8)]octadeca-5,7,12,14,15,17-hexaene" "tricyclo(10.2.2.25,8)octadeca-5,7,12,14,15,17-hexaene" "tricyclo[10.2.2.25,8]octadeca-1(14),5,7,12,15,17-hexaene" );
standardThermochemistry
{
    dHf_298   109930.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     643.83;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=338400.0
}
