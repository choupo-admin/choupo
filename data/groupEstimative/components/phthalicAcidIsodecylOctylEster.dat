/*--------------------------------*- Choupo -*-----------------------*\
  Component: phthalic acid, isodecyl octyl ester  (C26H42O4, CAS 1330-96-7)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        phthalicAcidIsodecylOctylEster;
formula     C26H42O4;
CAS         1330-96-7;
InChIKey    UXLBXTIBYMXRNX-UHFFFAOYSA-N;
MW          418.618;      // g/mol [origin=calculated method=formula-sum]
Tc          1153.45;      // K   [origin=predictive method=joback]
Pc          8.753;      // bar [origin=predictive method=joback]
omega       0.8471;      // -   [origin=predictive method=lee-kesler]
Tb          942.14;      // K   [origin=predictive method=joback]
HvapTb      90834.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (8.784 2.23176 -0.00116876 1.841e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group ACH; count 4; } { group AC; count 2; } { group COO; count 2; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 14; } { group CH; count 1; } { group dCH_ring; count 4; } { group dC_ring; count 2; } { group COO; count 2; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "o2-(8-methylnonyl) o1-octyl benzene-1,2-dicarboxylate" "1,2-benzenedicarboxylic acid, isodecyl octyl ester" "1,2-benzenedicarboxylic acid, 1-isodecyl 2-octyl ester" "dinopol ido" "octyl isodecyl phthalate" "isodecyl octyl phthalate" "1,2-benzenedicarboxylicacid, 1-isodecyl 2-octyl ester" "2-o-(8-methylnonyl) 1-o-octyl benzene-1,2-dicarboxylate" );
gibbsFormation
{
    dHf_298   -994750.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1149.21;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-352360.0
    phase     gas;
}
