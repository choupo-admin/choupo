/*--------------------------------*- Choupo -*-----------------------*\
  Component: ergostanol acetate  (C30H52O2, CAS 4356-09-6)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        ergostanolAcetate;
formula     C30H52O2;
CAS         4356-09-6;
InChIKey    YBIIYPHKAMDRNE-GRYSYPSMSA-N;
MW          444.744;      // g/mol [origin=calculated method=formula-sum]
Tc          1205.14;      // K   [origin=predictive method=joback]
Pc          8.485;      // bar [origin=predictive method=joback]
omega       0.7480;      // -   [origin=predictive method=lee-kesler]
Tb          977.68;      // K   [origin=predictive method=joback]
HvapTb      85900.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (-312.757 3.87672 -0.003071 1.0463e-06);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 5; } { group CH2; count 13; } { group CH; count 8; } { group C; count 2; } { group CH3COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 6; } { group CH2; count 3; } { group CH; count 3; } { group CH2_ring; count 10; } { group CH_ring; count 5; } { group C_ring; count 2; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "[(3s,6r)-6-[(8r,9s,10s,13r,14s,17r)-10,13-dimethyl-2,3,4,5,6,7,8,9,11,12,14,15,16,17-tetradecahydro-1h-cyclopenta[a]phenanthren-17-yl]-2,3-dimethyl-heptyl] ethanoate" );
gibbsFormation
{
    dHf_298   -765790.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     1097.81;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=32420.0
    phase     gas;
}
