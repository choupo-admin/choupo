/*--------------------------------*- Choupo -*-----------------------*\
  Component: 2-ethoxyethyl isobutyrate  (C8H16O3, CAS 54396-97-3)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        2EthoxyethylIsobutyrate;
formula     C8H16O3;
CAS         54396-97-3;
InChIKey    ANSOCBLHUNAGRK-UHFFFAOYSA-N;
MW          160.213;      // g/mol [origin=calculated method=formula-sum]
Tc          637.98;      // K   [origin=predictive method=joback]
Pc          25.252;      // bar [origin=predictive method=joback]
omega       0.5934;      // -   [origin=predictive method=lee-kesler]
Tb          462.84;      // K   [origin=predictive method=joback]
HvapTb      42831.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (44.843 0.65176 -0.000209 -2.84e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 3; } { group CH2; count 2; } { group CH; count 1; } { group CH2O; count 1; } { group COO; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 3; } { group CH2; count 3; } { group CH; count 1; } { group O; count 1; } { group COO; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-ethoxyethyl 2-methylpropanoate" "propanoic acid, 2-methyl-, 2-ethoxyethyl ester" "cellosolve isobutyrate" "2-ethoxyethylisobutyrate" "isobutyric acid,2-ethoxyethyl ester" "isobutyric acid 2-ethoxyethyl ester" "ethylene glycol monoethyl ether isobutyrate" "propanoic acid,2-methyl-, 2-ethoxyethyl ester" );
standardThermochemistry
{
    dHf_298   -663230.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     520.65;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-401330.0
}
