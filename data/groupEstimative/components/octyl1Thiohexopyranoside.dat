/*--------------------------------*- Choupo -*-----------------------*\
  Component: octyl 1-thiohexopyranoside  (C14H28O5S, CAS 85618-21-9)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        octyl1Thiohexopyranoside;
formula     C14H28O5S;
CAS         85618-21-9;
InChIKey    CGVLVOOFCGWBCS-UHFFFAOYSA-N;
MW          308.433;      // g/mol [origin=calculated method=formula-sum]
Tc          1211.90;      // K   [origin=predictive method=joback]
Pc          22.398;      // bar [origin=predictive method=joback]
omega       1.6290;      // -   [origin=predictive method=lee-kesler]
Tb          985.24;      // K   [origin=predictive method=joback]
HvapTb      123994.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (6.398 1.47731 -0.0006647 5.51e-08);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 7; } { group CH; count 4; } { group OH; count 4; } { group CH-O; count 1; } { group CH2S; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 8; } { group CH_ring; count 5; } { group OH; count 4; } { group O_ring; count 1; } { group S; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "2-(hydroxymethyl)-6-octylsulfanyl-oxane-3,4,5-triol" "octyl thioglucoside" "octyl-thioglucoside" "octyl-beta-d-thioglucopyranoside" "agn-pc-02yz37" "octyl " "a-d-thiogalactopyranoside" "galactopyranoside, 1-octylthio-1-deoxy-" "n-octyl-beta-d-thioglucopyranoside ultrapure" "2-(hydroxymethyl)-6-octylsulfanyloxane-3,4,5-triol" "(2r,3r,4s,5r)-2-(hydroxymethyl)-6-octylsulfanyloxane-3,4,5-triol" );
standardThermochemistry
{
    dHf_298   -1058380.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     715.02;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=-539670.0
}
