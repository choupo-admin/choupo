/*--------------------------------*- Choupo -*-----------------------*\
  Component: 1-chloroheptadecane  (C17H35Cl, CAS 62016-75-5)
  GROUP-ESTIMATE TIER -- UNVERIFIED.  Identity + UNIFAC groups are FACTS.
  Every NUMBER is an ESTIMATE computed from the `joback` groups below
  (Joback & Reid 1987) + Lee-Kesler omega; AAD Tb~10% Tc~11% Pc~11%.
  thermo_class=molecular. Tool: chemicals/thermo/rdkit (MIT/BSD).
\*---------------------------------------------------------------------------*/

name        1Chloroheptadecane;
formula     C17H35Cl;
CAS         62016-75-5;
InChIKey    FGIOHOBVUCNHBY-UHFFFAOYSA-N;
MW          274.917;      // g/mol [origin=calculated method=formula-sum]
Tc          789.77;      // K   [origin=predictive method=joback]
Pc          11.998;      // bar [origin=predictive method=joback]
omega       0.8061;      // -   [origin=predictive method=lee-kesler]
Tb          625.99;      // K   [origin=predictive method=joback]
HvapTb      57821.0;      // J/mol [origin=predictive method=joback]

vaporPressure
{
    model AmbroseWalton;   // [est: corresponding-states from Tc,Pc,omega]
}
idealGasHeatCapacity
{
    model         polynomial;   // J/(mol K), T in K [est: joback_gc]
    coefficients  (0.326 1.62562 -0.0009214 2.001e-07);
    Trange        (200 1000);
}
groups
{
    unifac ( { group CH3; count 1; } { group CH2; count 15; } { group CH2Cl; count 1; } );   // DDBST groups for MIXTURE activity (UNIFAC gamma)
    joback ( { group CH3; count 1; } { group CH2; count 16; } { group Cl; count 1; } );   // the fragmentation (RDKit, from SMILES) that PRODUCED the estimates above
}
aliases     ( "1-chloranylheptadecane" "heptadecyl chloride" );
gibbsFormation
{
    dHf_298   -409950.0;      // J/mol ideal-gas [origin=predictive method=joback]
    s_298     851.61;      // J/(mol K) absolute [origin=derived method=joback+element-entropies] reproduces Joback dGf=80330.0
    phase     gas;
}
